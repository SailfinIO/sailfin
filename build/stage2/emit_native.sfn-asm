.fn build_layout_context(program -> Program) -> LayoutContext
.meta return LayoutContext
.meta effects none
    .span 136 25 136 43
    .param program -> Program
    .span 137 5 137 54
    eval let mut structs -> LayoutStructDefinition[] = []
    .span 138 5 138 50
    eval let mut enums -> LayoutEnumDefinition[] = []
    .span 139 5 139 33
    eval let mut index -> number = 0
    .loop
        .if index >= program.statements.length
            break
        .endif
        .span 144 9 144 51
        eval let statement = program.statements[index]
        .if statement.variant == "StructDeclaration"
            .span 146 13 146 66
            eval let inputs = convert_struct_fields(statement.fields)
            .span 147 13 147 129
            eval structs = append_layout_struct_definition(structs, LayoutStructDefinition { name: statement.name, fields: inputs })
        .endif
        .if statement.variant == "EnumDeclaration"
            .span 150 13 150 68
            eval let mut variants -> LayoutEnumVariantDefinition[] = []
            .span 151 13 151 49
            eval let mut variant_index -> number = 0
            .loop
                .if variant_index >= statement.variants.length
                    break
                .endif
                .span 156 17 156 65
                eval let variant = statement.variants[variant_index]
                .span 157 17 157 62
                eval let inputs = convert_variant_fields(variant)
                .span 158 17 158 144
                eval variants = append_layout_enum_variant_definition(variants, LayoutEnumVariantDefinition { name: variant.name, fields: inputs })
                .span 159 17 159 36
                eval variant_index += 1
            .endloop
            .span 161 13 161 125
            eval enums = append_layout_enum_definition(enums, LayoutEnumDefinition { name: statement.name, variants: variants })
        .endif
        .span 163 9 163 20
        eval index += 1
    .endloop
    .span 165 5 165 61
    ret LayoutContext { structs: structs, enums: enums }
.endfn

