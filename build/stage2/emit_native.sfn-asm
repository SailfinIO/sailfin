    .span 172 5 172 52
    eval state = state_emit_line(state, ".module main")
    .if program.statements.length > 0
        .span 174 9 174 41
        eval state = state_emit_blank(state)
    .endif
    .span 177 5 177 33
    eval let mut index -> number = 0
    .loop
        .if index >= program.statements.length
            break
        .endif
        .span 182 9 182 66
        eval state = emit_statement(state, program.statements[index])
        .if index + 1 < program.statements.length
            .span 184 13 184 45
            eval state = state_emit_blank(state)
        .endif
        .span 186 9 186 20
        eval index += 1
    .endloop
    .span 189 5 193 7
    eval let artifact = NativeArtifact {
        name: "module.sfn-asm",
        format: "sailfin-native-text",
        contents: builder_to_string(state.builder),
    }
    .span 195 5 195 79
    eval let manifest_artifact = generate_layout_manifest(program, layout_context)
    .span 197 5 201 7
    eval let module = NativeModule {
        artifacts: [artifact, manifest_artifact],
