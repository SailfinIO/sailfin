    .if artifact == null
        .span 72 9 72 93
        eval diagnostics = append_string(diagnostics, "no sailfin-native-text artifact present")
        .span 73 9 73 77
        ret LoweredPythonResult { source: "", diagnostics: diagnostics }
    .endif
    .span 76 5 76 58
    eval let parse = parse_native_artifact(artifact.contents)
    .span 77 5 77 57
    eval diagnostics = diagnostics.concat(parse.diagnostics)
    .span 79 5 79 113
    eval let module = emit_python_module(parse.functions, parse.imports, parse.structs, parse.enums, parse.bindings)
    .span 80 5 80 58
    eval diagnostics = diagnostics.concat(module.diagnostics)
    .span 82 5 82 59
    eval let python_source = builder_to_string(module.builder)
    .span 83 5 83 84
    ret LoweredPythonResult { source: python_source, diagnostics: diagnostics }
.endfn

