    .for source_path in sources
        .span 210 9 210 58
        eval let result = compile_source_at_path(source_path)
        .if result.module != null
            .span 212 13 212 55
            eval modules = modules.concat([result.module])
        .endif
        .if result.diagnostics.length > 0
            .span 215 13 215 66
            eval diagnostics = diagnostics.concat(result.diagnostics)
        .endif
    .endfor
    .span 219 5 222 7
    ret ProjectCompilation { modules: modules, diagnostics: diagnostics }
.endfn

