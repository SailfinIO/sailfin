.fn compile_project(sources -> string[]) -> ProjectCompilation ![io]
.meta return ProjectCompilation
.meta effects io
    .span 215 20 215 39
    .param sources -> string[]
    .span 216 5 216 46
    eval let mut modules -> CompiledModule[] = []
    .span 217 5 217 53
    eval let mut diagnostics -> ModuleDiagnostics[] = []
    .for source_path in sources
        .span 220 9 220 58
        eval let result = compile_source_at_path(source_path)
        .if result.module != null
            .span 222 13 222 55
            eval modules = modules.concat([result.module])
        .endif
        .if result.diagnostics.length > 0
            .span 225 13 225 66
            eval diagnostics = diagnostics.concat(result.diagnostics)
        .endif
    .endfor
    .span 229 5 232 7
    ret ProjectCompilation { modules: modules, diagnostics: diagnostics }
.endfn

