.fn number_to_string(value -> number) -> string
.meta return string
.meta effects none
    .span 474 21 474 36
    .param value -> number
    .if value == 0
        .span 476 9 476 20
        ret "0"
    .endif
    .span 478 5 478 39
    eval let mut working -> number = value
    .span 479 5 479 41
    eval let mut negative -> boolean = false
    .if working < 0
        .span 481 9 481 25
        eval negative = true
        .span 482 9 482 31
        eval working = 0 - working
    .endif
    .span 484 5 484 31
    eval let digits = "0123456789"
    .span 485 5 485 43
    eval let mut remaining -> number = working
    .span 486 5 486 35
    eval let mut output -> string = ""
    .loop
        .if remaining <= 0
            break
        .endif
        .span 491 9 491 44
        eval let mut temp -> number = remaining
        .span 492 9 492 40
        eval let mut quotient -> number = 0
        .loop
            .if temp < 10
                break
            .endif
            .span 497 13 497 24
            eval temp -= 10
            .span 498 13 498 27
            eval quotient += 1
        .endloop
        .span 500 9 500 52
        eval let ch = substring(digits, temp, temp + 1)
        .span 501 9 501 30
        eval output = ch + output
        .span 502 9 502 30
        eval remaining = quotient
    .endloop
    .if negative
        .span 505 9 505 31
        eval output = "-" + output
    .endif
    .span 507 5 507 19
    ret output
.endfn

