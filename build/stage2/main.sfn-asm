    .span 469 5 469 41
    eval let mut negative -> boolean = false
    .if working < 0
        .span 471 9 471 25
        eval negative = true
        .span 472 9 472 31
        eval working = 0 - working
    .endif
    .span 474 5 474 31
    eval let digits = "0123456789"
    .span 475 5 475 43
    eval let mut remaining -> number = working
    .span 476 5 476 35
    eval let mut output -> string = ""
    .loop
        .if remaining <= 0
            break
        .endif
        .span 481 9 481 44
        eval let mut temp -> number = remaining
        .span 482 9 482 40
        eval let mut quotient -> number = 0
        .loop
            .if temp < 10
                break
            .endif
            .span 487 13 487 24
            eval temp -= 10
            .span 488 13 488 27
            eval quotient += 1
        .endloop
        .span 490 9 490 52
        eval let ch = substring(digits, temp, temp + 1)
        .span 491 9 491 30
        eval output = ch + output
        .span 492 9 492 30
        eval remaining = quotient
    .endloop
    .if negative
        .span 495 9 495 31
        eval output = "-" + output
    .endif
    .span 497 5 497 19
    ret output
.endfn

