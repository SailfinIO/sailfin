.fn resolve_import_module_slug(module -> string) -> string
.meta return string
.meta effects none
    .span 686 31 686 47
    .param module -> string
    .span 687 5 687 37
    eval let trimmed = trim_text(module)
    .if trimmed.length == 0
        .span 689 9 689 19
