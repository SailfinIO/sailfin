.fn is_unit_enum(enum_def -> NativeEnum) -> boolean
.meta return boolean
.meta effects none
    .span 16 17 16 39
    .param enum_def -> NativeEnum
    .span 17 5 17 33
    eval let mut index -> number = 0
    .loop
        .if index >= enum_def.variants.length
            break
        .endif
        .span 22 9 22 48
        eval let variant = enum_def.variants[index]
        .if variant.fields.length > 0
            .span 24 13 24 26
            ret false
        .endif
        .span 26 9 26 20
        eval index += 1
    .endloop
    .span 28 5 28 17
    ret true
.endfn

.fn synthesize_unit_enum_layout(enum_def -> NativeEnum) -> NativeEnumLayout
.meta return NativeEnumLayout
.meta effects none
    .span 31 32 31 54
    .param enum_def -> NativeEnum
    .span 32 5 32 32
    eval let tag_size -> number = 4
    .span 33 5 33 33
    eval let tag_align -> number = 4
    .span 34 5 34 55
    eval let mut layouts -> NativeEnumVariantLayout[] = []
    .span 35 5 35 33
    eval let mut index -> number = 0
    .loop
        .if index >= enum_def.variants.length
            break
        .endif
        .span 40 9 40 48
        eval let variant = enum_def.variants[index]
        .span 41 9 50 12
        eval layouts = layouts.concat([
            NativeEnumVariantLayout {
                name: variant.name,
                tag: index,
                offset: 0,
                size: tag_size,
                align: tag_align,
                fields: [],
            },
        ])
        .span 51 9 51 20
        eval index += 1
    .endloop
    .span 53 5 60 7
    ret NativeEnumLayout { size: tag_size, align: tag_align, tag_type: "i32", tag_size: tag_size, tag_align: tag_align, variants: layouts }
.endfn

.fn enum_layout_matches_variants(enum_def -> NativeEnum, layout -> NativeEnumLayout) -> boolean
.meta return boolean
.meta effects none
    .span 63 33 63 55
    .param enum_def -> NativeEnum
    .span 63 57 63 83
    .param layout -> NativeEnumLayout
    .if layout.variants.length != enum_def.variants.length
        .span 65 9 65 22
        ret false
    .endif
    .span 67 5 67 33
    eval let mut index -> number = 0
    .loop
        .if index >= enum_def.variants.length
            break
        .endif
        .span 72 9 72 54
        eval let expected = enum_def.variants[index].name
        .span 73 9 73 42
        eval let mut found -> boolean = false
        .span 74 9 74 44
        eval let mut layout_index -> number = 0
        .loop
            .if layout_index >= layout.variants.length
                break
            .endif
            .if layout.variants[layout_index].name == expected
                .span 80 17 80 30
                eval found = true
                break
            .endif
            .span 83 13 83 31
            eval layout_index += 1
        .endloop
        .if !found
            .span 86 13 86 26
            ret false
        .endif
        .span 88 9 88 20
        eval index += 1
    .endloop
    .span 90 5 90 17
    ret true
.endfn

.fn fixup_enum_layouts(enums -> NativeEnum[]) -> EnumLayoutFixupResult
.meta return EnumLayoutFixupResult
.meta effects none
    .span 93 23 93 44
    .param enums -> NativeEnum[]
    .span 94 5 94 42
    eval let mut diagnostics -> string[] = []
    .span 95 5 95 42
    eval let mut updated -> NativeEnum[] = []
    .span 96 5 96 33
    eval let mut index -> number = 0
    .loop
        .if index >= enums.length
            break
        .endif
        .span 101 9 101 37
        eval let enum_def = enums[index]
        .span 102 9 102 34
        eval let mut fixed = enum_def
        .if enum_def.layout == null
            .if is_unit_enum(enum_def)
                .span 106 17 106 136
                eval fixed = NativeEnum { name: enum_def.name, variants: enum_def.variants, layout: synthesize_unit_enum_layout(enum_def) }
                .span 107 17 107 153
                eval diagnostics = diagnostics.concat(["llvm lowering: enum `" + enum_def.name + "` missing layout metadata; synthesized unit-enum layout"])
            .endif
            .span 109 13 109 47
            eval updated = updated.concat([fixed])
            .span 110 13 110 24
            eval index += 1
            continue
        .endif
        .span 114 9 114 38
        eval let layout = enum_def.layout
        .if !enum_layout_matches_variants(enum_def, layout)
            .if is_unit_enum(enum_def)
                .span 117 17 117 136
                eval fixed = NativeEnum { name: enum_def.name, variants: enum_def.variants, layout: synthesize_unit_enum_layout(enum_def) }
                .span 118 17 118 164
                eval diagnostics = diagnostics.concat(["llvm lowering: enum `" + enum_def.name + "` layout variants incomplete/garbled; synthesized unit-enum layout"])
            .else
                .span 120 17 120 178
                eval diagnostics = diagnostics.concat(["llvm lowering: enum `" + enum_def.name + "` layout variants incomplete/garbled; payload enums require full layout metadata"])
            .endif
        .endif
        .span 124 9 124 43
        eval updated = updated.concat([fixed])
        .span 125 9 125 20
        eval index += 1
    .endloop
    .span 128 5 128 79
    ret EnumLayoutFixupResult { enums: updated, diagnostics: diagnostics }
.endfn

