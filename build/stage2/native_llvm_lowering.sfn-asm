    .endif
    .span 691 5 691 60
    eval let normalized = normalize_import_module_path(trimmed)
    .span 692 5 692 39
    eval let mut start_index -> number = 0
    .loop
        .if start_index >= normalized.length
            break
        .endif
        .span 697 9 697 42
        eval let ch = normalized[start_index]
        .if ch == "." || ch == "/"
            .span 699 13 699 30
            eval start_index += 1
            continue
        .endif
        break
    .endloop
    .span 704 5 704 36
    eval let mut candidate = normalized
    .if start_index > 0
        .span 706 9 706 75
        eval candidate = substring(normalized, start_index, normalized.length)
    .endif
    .span 708 5 708 62
    eval let last_slash = find_last_index_of_char(candidate, "/")
    .if last_slash >= 0
        .span 710 9 710 71
        ret substring(candidate, last_slash + 1, candidate.length)
    .endif
    .span 712 5 712 22
    ret candidate
.endfn

