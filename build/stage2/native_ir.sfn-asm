.fn select_text_artifact(artifacts -> NativeArtifact[]) -> NativeArtifact?
.meta return NativeArtifact?
.meta effects none
    .span 294 25 294 54
    .param artifacts -> NativeArtifact[]
    .span 295 5 295 33
    eval let mut index -> number = 0
    .loop
        .if index >= artifacts.length
            break
        .endif
        .span 300 9 300 41
        eval let artifact = artifacts[index]
        .if artifact.format == "sailfin-native-text"
            .span 302 13 302 29
            ret artifact
        .endif
        .span 304 9 304 20
        eval index += 1
    .endloop
    .span 306 5 306 17
    ret null
.endfn

