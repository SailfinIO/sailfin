.fn parse_native_artifact(text -> string) -> ParseNativeResult
.meta return ParseNativeResult
.meta effects none
    .span 324 26 324 40
    .param text -> string
    .span 325 5 325 35
    eval let lines = split_lines(text)
    .span 326 5 326 42
    eval let mut diagnostics -> string[] = []
    .span 327 5 327 48
    eval let mut functions -> NativeFunction[] = []
    .span 328 5 328 44
    eval let mut imports -> NativeImport[] = []
    .span 329 5 329 44
    eval let mut structs -> NativeStruct[] = []
    .span 330 5 330 50
    eval let mut interfaces -> NativeInterface[] = []
    .span 331 5 331 40
    eval let mut enums -> NativeEnum[] = []
    .span 332 5 332 46
    eval let mut bindings -> NativeBinding[] = []
    .span 333 5 333 47
    eval let mut current -> NativeFunction? = null
    .span 334 5 334 54
    eval let mut pending_span -> NativeSourceSpan? = null
    .span 335 5 335 60
    eval let mut pending_value_span -> NativeSourceSpan? = null
    .span 337 5 337 33
    eval let mut index -> number = 0
    .loop
        .if index >= lines.length
            break
        .endif
        .span 342 9 342 37
        eval let raw_line = lines[index]
        .span 343 9 343 40
        eval let line = trim_text(raw_line)
        .if line.length == 0
            .span 345 13 345 24
            eval index += 1
            continue
        .endif
        .if starts_with(line, ";")
            .span 349 13 349 24
            eval index += 1
            continue
        .endif
        .if starts_with(line, ".module ")
            .span 353 13 353 24
            eval index += 1
            continue
        .endif
        .if starts_with(line, ".import ")
            .span 357 13 357 94
            eval let parsed_import = parse_import_entry("import", strip_prefix(line, ".import "))
            .if parsed_import == null
                .span 359 17 359 93
                eval diagnostics = append_string(diagnostics, "unable to parse import: " + line)
            .else
                .span 361 17 361 65
                eval imports = append_import(imports, parsed_import)
            .endif
            .span 363 13 363 24
            eval index += 1
            continue
        .endif
        .if starts_with(line, ".export ")
            .span 367 13 367 94
            eval let parsed_export = parse_import_entry("export", strip_prefix(line, ".export "))
            .if parsed_export == null
                .span 369 17 369 93
                eval diagnostics = append_string(diagnostics, "unable to parse export: " + line)
            .else
                .span 371 17 371 65
                eval imports = append_import(imports, parsed_export)
            .endif
            .span 373 13 373 24
            eval index += 1
            continue
        .endif
        .if starts_with(line, ".span ")
            .span 377 13 377 79
            eval let parsed_span = parse_source_span(strip_prefix(line, ".span "))
            .if parsed_span == null
                .span 379 17 379 100
                eval diagnostics = append_string(diagnostics, "unable to parse span metadata: " + line)
            .else
                .span 381 17 381 44
                eval pending_span = parsed_span
            .endif
            .span 383 13 383 24
            eval index += 1
            continue
        .endif
        .if starts_with(line, ".init-span ")
            .span 387 13 387 89
            eval let parsed_init_span = parse_source_span(strip_prefix(line, ".init-span "))
            .if parsed_init_span == null
                .span 389 17 389 112
                eval diagnostics = append_string(diagnostics, "unable to parse initializer span metadata: " + line)
            .else
                .span 391 17 391 55
                eval pending_value_span = parsed_init_span
            .endif
            .span 393 13 393 24
            eval index += 1
            continue
        .endif
        .if starts_with(line, ".struct ")
            .span 397 13 397 71
            eval let struct_result = parse_struct_definition(lines, index)
            .span 398 13 398 73
            eval diagnostics = diagnostics.concat(struct_result.diagnostics)
            .if struct_result.definition != null
                .span 400 17 400 76
                eval structs = append_struct(structs, struct_result.definition)
            .endif
            .span 402 13 402 46
            eval index = struct_result.next_index
            continue
        .endif
        .if starts_with(line, ".interface ")
            .span 406 13 406 77
            eval let interface_result = parse_interface_definition(lines, index)
            .span 407 13 407 76
            eval diagnostics = diagnostics.concat(interface_result.diagnostics)
            .if interface_result.definition != null
                .span 409 17 409 88
                eval interfaces = append_interface(interfaces, interface_result.definition)
            .endif
            .span 411 13 411 49
            eval index = interface_result.next_index
            continue
        .endif
        .if starts_with(line, ".enum ")
            .span 415 13 415 67
            eval let enum_result = parse_enum_definition(lines, index)
            .span 416 13 416 71
            eval diagnostics = diagnostics.concat(enum_result.diagnostics)
            .if enum_result.definition != null
                .span 418 17 418 68
                eval enums = append_enum(enums, enum_result.definition)
            .endif
            .span 420 13 420 44
            eval index = enum_result.next_index
            continue
        .endif
        .if starts_with(line, ".fn ")
            .if current != null
                .span 425 17 425 119
                eval diagnostics = append_string(diagnostics, "encountered nested .fn while previous function still open")
            .endif
            .span 427 13 433 15
