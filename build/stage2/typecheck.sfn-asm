    .field kind -> string
    .field span -> SourceSpan?
.endstruct

.struct TypecheckResult
    .layout struct name=TypecheckResult size=16 align=8
    .layout field diagnostics type=Diagnostic[] offset=0 size=8 align=8
    .layout field symbols type=SymbolEntry[] offset=8 size=8 align=8
    .field diagnostics -> Diagnostic[]
    .field symbols -> SymbolEntry[]
.endstruct

.struct SymbolCollectionResult
    .layout struct name=SymbolCollectionResult size=16 align=8
    .layout field symbols type=SymbolEntry[] offset=0 size=8 align=8
    .layout field diagnostics type=Diagnostic[] offset=8 size=8 align=8
