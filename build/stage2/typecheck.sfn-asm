    .field diagnostics -> Diagnostic[]
.endstruct

.struct ScopeResult
    .layout struct name=ScopeResult size=16 align=8
    .layout field bindings type=SymbolEntry[] offset=0 size=8 align=8
    .layout field diagnostics type=Diagnostic[] offset=8 size=8 align=8
    .field bindings -> SymbolEntry[]
    .field diagnostics -> Diagnostic[]
.endstruct

