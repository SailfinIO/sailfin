# Top-level ignores for the whole repo
# OS/editor
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
.vscode/
.idea/
.claude/settings.local.json
.claude/scheduled_tasks.lock
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.pytest-stage1/
.tox/
.nox/
.mypy_cache/
.dmypy.json
dmypy.json
.pylint.d/
.pyre/
.hypothesis/

# Poetry
.poetry
bootstrap/poetry.lock

# Packaging
dist/
.eggs/
.eggs/**
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/
share/python-wheels/

# Virtualenvs (keep per-dir ignores as well)
.venv/
venv/
env/
ENV/
.virtualenv/

# Coverage
/htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Logs / temp
logs/
*.log
*.out
*.bak
*.tmp
*.temp
*.old
*.orig
*.rej

# Optional platform specific
$RECYCLE.BIN/

scratch/

# Build outputs (Stage2 bootstrap/native artifacts). These are generated and
# should never be committed; use dist/ for release packaging instead.
/build/

# Compiled runtime object files (generated during build)
runtime/native/obj/

# Stage1 bootstrap compiler (checked-in Python).
# We want CI to have the stage1 llvm support modules, but we do NOT want to
# commit bytecode caches.
!compiler/build/llvm/
!compiler/build/llvm/**/*.py
compiler/build/llvm/**/__pycache__/
compiler/build/llvm/**/*.pyc
