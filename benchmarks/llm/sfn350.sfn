// SFN-350 native benchmark runner.
//
// This ports the adjacent prototype's raw-model, iterate-to-green harness into
// Sailfin so the compiler repo does not need to carry Python benchmark code.
import {
    JsonValue,
    array_at,
    array_length,
    array_val,
    bool_val,
    get_array,
    get_bool,
    get_number,
    get_string,
    get_value,
    number_val,
    object_val,
    parse,
    string_val,
    stringify,
    stringify_pretty
} from "sfn/json";
import {
    contains,
    find,
    join,
    split,
    trim
} from "sfn/strings";

import { fs } from "fs";

struct Fixture {
    name: string;
    content: string;
}

struct Case {
    input: string;
    expect: string;
    stable_runs: int;
}

struct Starter {
    arm: string;
    source: string;
}

struct Task {
    id: string;
    template: string;
    category: string;
    kind: string;
    confirmatory: boolean;
    uses_tacit: boolean;
    prompt: string;
    io_contract: string;
    fixtures: Fixture[];
    cases: Case[];
    starters: Starter[];
}

struct ArmConfig {
    name: string;
    lang: string;
    entry: string;
    compile: string[];
    run: string[];
    timeout_prefix: string[];
    effect_keywords: string[];
}

struct Config {
    track: string;
    adapter: string;
    model: string;
    reasoning_effort: string;
    max_iters: int;
    repeats: int;
    seed: int;
    model_family: string;
    results_dir: string;
    stub: boolean;
    dry_run: boolean;
    schema_probe: boolean;
    verify_graders: boolean;
    self_test_analysis: boolean;
    self_test_timeouts: boolean;
    check_packets: boolean;
    contamination_probe: boolean;
    reanalyze_dir: string;
    ablation: string;
    tasks: string[];
    arms: string[];
}

struct Completion {
    text: string;
    input_tokens: int;
    output_tokens: int;
    error: string;
    provider_attempts: int;
}

struct GradeResult {
    passed: boolean;
    feedback: string;
    category: string;
}

struct FailureAttribution {
    primary: string;
    secondary: string[];
    track_b_attribution: string;
    language_denominator: boolean;
    manual_review: boolean;
}

// A frozen classification signature: a representative captured grader
// stdout/stderr plus the expected corrected attribution. It is the single
// source of truth shared by the `--self-test-analysis` fixtures and the
// `--reanalyze` offline corpus correction, so the classifier the audit uses is
// exactly the classifier the fixtures freeze (SFN-387).
struct ClassificationSignature {
    name: string;
    grader_category: string;
    feedback: string;
    iteration: int;
    expected_primary: string;
    expected_secondary: string;
    expected_track_b: string;
    compiler_owned: boolean;
    recorded_primary: string;
    provenance: string;
}

struct Record {
    attempt_id: string;
    task: string;
    template: string;
    category: string;
    kind: string;
    arm: string;
    model_family: string;
    track: string;
    repeat: int;
    passed: boolean;
    iterations: int;
    tokens: int;
    input_tokens: int;
    output_tokens: int;
    elapsed_ms: int;
    source_chars: int;
    diff_chars: int;
    human_interventions: int;
    fail_categories: string[];
    primary_failure: string;
    secondary_failures: string[];
    track_b_attribution: string;
    language_denominator: boolean;
    ablation: string;
    ablation_treatment: string;
}

struct PairMetric {
    task: string;
    one_shot_advantage: float;
    iterations_advantage: float;
    observations: int;
}

struct Interval {
    estimate: float;
    low: float;
    high: float;
}

fn _usage() -> string {
    return "usage: sfn run benchmarks/llm/sfn350.sfn -- [--track a|b] [--ablation primary|examples|diagnostics|primitive] [--adapter stub|openai|anthropic] [--real] [--model M] [--reasoning-effort E] [--model-family F] [--arm A] [--task T] [--max-iters N] [--repeats N] [--seed N] [--dry-run] [--schema-probe] [--contamination-probe] [--check-packets] [--verify-graders] [--self-test-analysis] [--self-test-timeouts] [--reanalyze DIR] [--results-dir DIR]\n"
        + "\n"
        + "defaults: --track a --adapter stub --model gpt-5.6-terra --reasoning-effort medium --model-family unspecified --max-iters 5 --repeats 1 --seed 350 --results-dir build/sfn350-results\n"
        + "env: OPENAI_API_KEY, ANTHROPIC_API_KEY, SAILFIN_BIN, TACIT_LIBRARY_JAR, SFN350_TIMEOUT_CMD; API keys may also be set in .env or benchmarks/llm/.env\n";
}

fn _valid_adapter(value: string) -> boolean {
    return value == "stub" || value == "openai" || value == "anthropic";
}

fn _valid_reasoning_effort(value: string) -> boolean {
    return value == "none" || value == "low" || value == "medium" || value == "high"
        || value == "xhigh"
        || value == "max";
}

fn _valid_ablation(value: string) -> boolean {
    return value == "primary" || value == "examples" || value == "diagnostics"
        || value == "primitive";
}

fn _parse_int(text: string, fallback: int) -> int {
    let t = trim(text);
    if t.length == 0 { return fallback; }
    let mut i: int = 0;
    let mut sign: int = 1;
    if t[0] == "-" {
        sign = -1;
        i = 1;
    }
    let mut out: int = 0;
    loop {
        if i >= t.length { break; }
        let code = char_code(t[i]);
        if code < 48 || code > 57 { return fallback; }
        out = out * 10 + (code - 48);
        i += 1;
    }
    return out * sign;
}

fn _default_config() -> Config {
    return Config {
        track: "a",
        adapter: "stub",
        model: "gpt-5.6-terra",
        reasoning_effort: "medium",
        max_iters: 5,
        repeats: 1,
        seed: 350,
        model_family: "unspecified",
        results_dir: "build/sfn350-results",
        stub: true,
        dry_run: false,
        schema_probe: false,
        verify_graders: false,
        self_test_analysis: false,
        self_test_timeouts: false,
        check_packets: false,
        contamination_probe: false,
        reanalyze_dir: "",
        ablation: "primary",
        tasks: [],
        arms: []
    };
}

fn _parse_config(argv: string[]) -> Config ![io] {
    let mut cfg = _default_config();
    let mut i: int = 1;
    loop {
        if i >= argv.length { break; }
        let arg = argv[i];
        if arg == "--help" || arg == "-h" {
            print(_usage());
            process.exit(0);
        } else if arg == "--track" && i + 1 < argv.length {
            cfg.track = argv[i + 1];
            if cfg.track != "a" && cfg.track != "b" {
                print.err("unknown track: " + cfg.track);
                process.exit(2);
            }
            i += 1;
        } else if arg == "--adapter" && i + 1 < argv.length {
            cfg.adapter = argv[i + 1];
            if !_valid_adapter(cfg.adapter) {
                print.err("unknown adapter: " + cfg.adapter);
                print.err(_usage());
                process.exit(2);
            }
            cfg.stub = cfg.adapter == "stub";
            i += 1;
        } else if arg == "--ablation" && i + 1 < argv.length {
            cfg.ablation = argv[i + 1];
            if !_valid_ablation(cfg.ablation) {
                print.err("unknown ablation: " + cfg.ablation);
                process.exit(2);
            }
            i += 1;
        } else if arg == "--model" && i + 1 < argv.length {
            cfg.model = argv[i + 1];
            i += 1;
        } else if arg == "--reasoning-effort" && i + 1 < argv.length {
            cfg.reasoning_effort = argv[i + 1];
            if !_valid_reasoning_effort(cfg.reasoning_effort) {
                print.err("unknown reasoning effort: " + cfg.reasoning_effort);
                print.err(_usage());
                process.exit(2);
            }
            i += 1;
        } else if arg == "--max-iters" && i + 1 < argv.length {
            cfg.max_iters = _parse_int(argv[i + 1], cfg.max_iters);
            i += 1;
        } else if arg == "--repeats" && i + 1 < argv.length {
            cfg.repeats = _parse_int(argv[i + 1], cfg.repeats);
            i += 1;
        } else if arg == "--seed" && i + 1 < argv.length {
            cfg.seed = _parse_int(argv[i + 1], cfg.seed);
            i += 1;
        } else if arg == "--model-family" && i + 1 < argv.length {
            cfg.model_family = argv[i + 1];
            i += 1;
        } else if arg == "--results-dir" && i + 1 < argv.length {
            cfg.results_dir = argv[i + 1];
            i += 1;
        } else if arg == "--task" && i + 1 < argv.length {
            cfg.tasks.push(argv[i + 1]);
            i += 1;
        } else if arg == "--arm" && i + 1 < argv.length {
            cfg.arms.push(argv[i + 1]);
            i += 1;
        } else if arg == "--real" {
            if cfg.adapter == "stub" {
                cfg.adapter = "openai";
                cfg.stub = false;
            }
        } else if arg == "--dry-run" { cfg.dry_run = true; } else if arg == "--schema-probe" {
            cfg.schema_probe = true;
        } else if arg == "--verify-graders" { cfg.verify_graders = true; } else if arg == "--self-test-analysis" {
            cfg.self_test_analysis = true;
        } else if arg == "--self-test-timeouts" {
            cfg.self_test_timeouts = true;
        } else if arg == "--check-packets" { cfg.check_packets = true; } else if arg == "--contamination-probe" {
            cfg.contamination_probe = true;
        } else if arg == "--reanalyze" && i + 1 < argv.length {
            cfg.reanalyze_dir = argv[i + 1];
            i += 1;
        } else {
            print.err("unknown or incomplete argument: " + arg);
            print.err(_usage());
            process.exit(2);
        }
        i += 1;
    }
    if cfg.repeats < 1 {
        print.err("--repeats must be at least 1");
        process.exit(2);
    }
    if cfg.ablation != "primary" && cfg.track != "b" {
        print.err("--ablation requires --track b");
        process.exit(2);
    }
    return cfg;
}

fn _strip_dotenv_export(line: string) -> string {
    if line.length >= 7 && substring(line, 0, 7) == "export " {
        return trim(substring(line, 7, line.length));
    }
    return line;
}

fn _strip_dotenv_quotes(value: string) -> string {
    let v = trim(value);
    if v.length >= 2 {
        let first = v[0];
        let last = v[v.length - 1];
        if first == "\"" && last == "\"" {
            return substring(v, 1, v.length - 1);
        }
        if first == "'" && last == "'" {
            return substring(v, 1, v.length - 1);
        }
    }
    return v;
}

fn _dotenv_get_from(path: string, key: string) -> string ![io] {
    if !fs.exists(path) { return ""; }
    let lines = split(fs.readFile(path), "\n");
    let mut i: int = 0;
    loop {
        if i >= lines.length { break; }
        let line = _strip_dotenv_export(trim(lines[i]));
        if line.length > 0 && line[0] != "#" {
            let eq = find(line, "=", 0);
            if eq > 0 && trim(substring(line, 0, eq)) == key {
                return _strip_dotenv_quotes(substring(line, eq + 1, line.length));
            }
        }
        i += 1;
    }
    return "";
}

fn _dotenv_get(key: string) -> string ![io] {
    let direct = _dotenv_get_from(".env", key);
    if direct.length > 0 { return direct; }
    return _dotenv_get_from("benchmarks/llm/.env", key);
}

fn _env_or_dotenv(key: string) -> string ![io] {
    let configured = env.get(key);
    if configured.length > 0 { return configured; }
    return _dotenv_get(key);
}

fn _current_dir() -> string ![io] {
    let exit = process.run_capture(["pwd"], process.environ());
    let out = trim(process.capture_take_stdout());
    let _err = process.capture_take_stderr();
    if exit == 0 { return out; }
    return "";
}

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    let pwd = env.get("PWD");
    if pwd.length > 0 && fs.exists(pwd + "/build/bin/sfn") {
        return pwd + "/build/bin/sfn";
    }
    let cwd = _current_dir();
    if cwd.length > 0 && fs.exists(cwd + "/build/bin/sfn") {
        return cwd + "/build/bin/sfn";
    }
    return "build/bin/sfn";
}

fn _repo_root() -> string ![io] {
    let configured = env.get("SFN350_REPO_ROOT");
    if configured.length > 0 { return configured; }
    let pwd = env.get("PWD");
    if pwd.length > 0 && fs.exists(pwd + "/benchmarks/llm/sfn350.sfn") {
        return pwd;
    }
    return _current_dir();
}

fn _tacit_jar() -> string ![io] {
    let configured = env.get("TACIT_LIBRARY_JAR");
    if configured.length > 0 { return configured; }
    return _repo_root() + "/build/toolchains/tacit/0.2.1/TACIT-library.jar";
}

fn _tacit_scaffold() -> string ![io] {
    return _repo_root() + "/benchmarks/llm/tacit/Scaffold.scala";
}

fn _scala_command(action: string, task: Task, file: string, timeout: string[]) -> string[] ![io] {
    if !task.uses_tacit {
        return _append_all(timeout, ["scala-cli", action, "--server=false", file]);
    }
    return _append_all(timeout, ["scala-cli", action, "--server=false", "--scala", "3.10.0-RC1-bin-20260616-4733954-NIGHTLY", "--scalac-option", "-experimental", "--jar", _tacit_jar(), _tacit_scaffold(), file]);
}

fn _default_timeout_command() -> string ![io] {
    let timeout = process.run_capture(["sh", "-c", "command -v timeout 2>/dev/null"], process.environ());
    let timeout_path = trim(process.capture_take_stdout());
    let _timeout_err = process.capture_take_stderr();
    if timeout == 0 && timeout_path.length > 0 { return "timeout"; }
    let gtimeout = process.run_capture(["sh", "-c", "command -v gtimeout 2>/dev/null"], process.environ());
    let gtimeout_path = trim(process.capture_take_stdout());
    let _gtimeout_err = process.capture_take_stderr();
    if gtimeout == 0 && gtimeout_path.length > 0 { return "gtimeout"; }
    // Preserve a finite-failure contract when the host lacks the required tool:
    // generated commands fail to spawn instead of silently running unbounded.
    return "timeout";
}

fn _timeout_prefix() -> string[] ![io] {
    let t = env.get("SFN350_TIMEOUT_CMD");
    if t.length > 0 { return split(t, " "); }
    return [_default_timeout_command(), "60"];
}

fn _child_env() -> string[] ![io] { return process.environ(); }

fn _contains_value(values: string[], value: string) -> boolean {
    let mut i: int = 0;
    loop {
        if i >= values.length { break; }
        if values[i] == value { return true; }
        i += 1;
    }
    return false;
}

fn _selected(selected: string[], value: string) -> boolean {
    if selected.length == 0 { return true; }
    return _contains_value(selected, value);
}

fn _append_all(left: string[], right: string[]) -> string[] {
    let mut out: string[] = [];
    let mut i: int = 0;
    loop {
        if i >= left.length { break; }
        out.push(left[i]);
        i += 1;
    }
    i = 0;
    loop {
        if i >= right.length { break; }
        out.push(right[i]);
        i += 1;
    }
    return out;
}

fn _replace_file(args: string[], file: string) -> string[] {
    let mut out: string[] = [];
    let mut i: int = 0;
    loop {
        if i >= args.length { break; }
        if args[i] == "{file}" { out.push(file); } else {
            out.push(args[i]);
        }
        i += 1;
    }
    return out;
}

fn _rill_identifier(value: string) -> string {
    if value == "fn" { return "craft"; }
    if value == "let" { return "bind"; }
    if value == "mut" { return "flux"; }
    if value == "return" { return "yield"; }
    if value == "if" { return "when"; }
    if value == "else" { return "otherwise"; }
    if value == "loop" { return "cycle"; }
    if value == "break" { return "halt"; }
    if value == "continue" { return "resume"; }
    if value == "import" { return "draw"; }
    if value == "from" { return "via"; }
    if value == "as" { return "cast"; }
    if value == "string" { return "glyphs"; }
    if value == "int" { return "whole"; }
    if value == "boolean" { return "truth"; }
    if value == "void" { return "empty"; }
    if value == "true" { return "aye"; }
    if value == "false" { return "nay"; }
    if value == "print" { return "emit"; }
    if value == "substring" { return "span"; }
    if value == "char_code" { return "rune_code"; }
    if value == "io" { return "console"; }
    if value == "net" { return "link"; }
    if value == "fs" { return "vault"; }
    if value == "http" { return "loopweb"; }
    if value == "read_line" { return "take_line"; }
    if value == "readFile" { return "read_text"; }
    if value == "get_body" { return "fetch_body"; }
    return value;
}

fn _is_identifier_start(ch: string) -> boolean {
    let code = char_code(ch);
    return (code >= 65 && code <= 90) || (code >= 97 && code <= 122) || ch == "_";
}

fn _is_identifier_part(ch: string) -> boolean {
    let code = char_code(ch);
    return _is_identifier_start(ch) || (code >= 48 && code <= 57);
}

fn _sailfin_to_rill(source: string) -> string {
    let mut out = "";
    let mut i = 0;
    let mut quoted = false;
    loop {
        if i >= source.length { break; }
        let ch = source[i];
        if quoted {
            out = out + ch;
            if ch == "\\" && i + 1 < source.length {
                out = out + source[i + 1];
                i += 2;
                continue;
            }
            if ch == "\"" { quoted = false; }
            i += 1;
            continue;
        }
        if ch == "\"" {
            quoted = true;
            out = out + ch;
            i += 1;
            continue;
        }
        if ch == "!" && i + 1 < source.length && source[i + 1] == "[" {
            out = out + "with[";
            i += 2;
            continue;
        }
        if _is_identifier_start(ch) {
            let start = i;
            i += 1;
            loop {
                if i >= source.length || !_is_identifier_part(source[i]) {
                    break;
                }
                i += 1;
            }
            out = out + _rill_identifier(substring(source, start, i));
            continue;
        }
        out = out + ch;
        i += 1;
    }
    return out;
}

fn _arm_configs_with_timeout(timeout: string[], track: string) -> ArmConfig[] ![io] {
    let sfn = _sfn_bin();
    if track == "b" {
        let translator = _repo_root() + "/benchmarks/llm/rill17.sh";
        return [ArmConfig {
            name: "sailfin-b", lang: "sailfin-b", entry: "solution.sfn", compile: _append_all(timeout, [sfn, "check", "{file}"]), run: _append_all(timeout, [sfn, "run", "{file}"]), timeout_prefix: timeout, effect_keywords: ["effect", "capability", "E0400", "undeclared"]
        }, ArmConfig {
            name: "rill-17", lang: "rill-17", entry: "solution.r17", compile: _append_all(timeout, ["sh", translator, sfn, "check", "{file}"]), run: _append_all(timeout, ["sh", translator, sfn, "run", "{file}"]), timeout_prefix: timeout, effect_keywords: ["effect", "capability", "E0400", "undeclared"]
        }];
    }
    return [ArmConfig {
        name: "sailfin", lang: "sailfin", entry: "solution.sfn", compile: _append_all(timeout, [sfn, "check", "{file}"]), run: _append_all(timeout, [sfn, "run", "{file}"]), timeout_prefix: timeout, effect_keywords: ["effect", "capability", "E0400", "undeclared"]
    }, ArmConfig {
        name: "scala", lang: "scala", entry: "Solution.scala", compile: _append_all(timeout, ["scala-cli", "compile", "--server=false", "{file}"]), run: _append_all(timeout, ["scala-cli", "run", "--server=false", "{file}"]), timeout_prefix: timeout, effect_keywords: ["CaptureChecking", "capability", "effect", "leaks into outer capture set", "outlives its scope"]
    }, ArmConfig {
        name: "python", lang: "python", entry: "solution.py", compile: [], run: _append_all(timeout, ["python3", "{file}"]), timeout_prefix: timeout, effect_keywords: []
    }];
}

fn _arm_configs(track: string) -> ArmConfig[] ![io] {
    return _arm_configs_with_timeout(_timeout_prefix(), track);
}

fn _arm_by_name(name: string, arms: ArmConfig[]) -> ArmConfig {
    let mut i: int = 0;
    loop {
        if i >= arms.length { break; }
        if arms[i].name == name { return arms[i]; }
        i += 1;
    }
    return arms[0];
}

fn _starter_for(task: Task, arm: string) -> string {
    if arm == "sailfin-b" { return _starter_for(task, "sailfin"); }
    if arm == "rill-17" {
        return _sailfin_to_rill(_starter_for(task, "sailfin"));
    }
    let mut i: int = 0;
    loop {
        if i >= task.starters.length { break; }
        if task.starters[i].arm == arm { return task.starters[i].source; }
        i += 1;
    }
    return "";
}

fn _mkdir(path: string) ![io] { fs.createDirectory(path, true); }

fn _write_fixtures(task: Task, dir: string) ![io] {
    let mut i: int = 0;
    loop {
        if i >= task.fixtures.length { break; }
        fs.writeFile(dir + "/" + task.fixtures[i].name, task.fixtures[i].content);
        i += 1;
    }
}

fn _extract_code(text: string) -> string {
    let fence = find(text, "```", 0);
    if fence < 0 { return text; }
    let after_open = find(text, "\n", fence + 3);
    if after_open < 0 { return text; }
    let close = find(text, "```", after_open + 1);
    if close < 0 { return substring(text, after_open + 1, text.length); }
    return substring(text, after_open + 1, close);
}

fn _system_prompt() -> string {
    return "You are an expert programmer completing a benchmark task. Return the COMPLETE contents of the solution file in a SINGLE fenced code block and nothing else - no prose before or after. The program reads its input from stdin and writes ONLY the required answer to stdout.";
}

fn _ablation_treatment(cfg: Config, task_index: int, repeat: int) -> string {
    if cfg.ablation == "primary" { return "primary"; }
    let parity = cfg.seed + repeat + task_index;
    let treatment = parity % 2 == 0;
    if cfg.ablation == "examples" {
        return treatment? "expanded": "concise";
    }
    if cfg.ablation == "diagnostics" {
        return treatment? "minimal": "full";
    }
    return treatment? "local": "available";
}

fn _packet_supplement(arm: ArmConfig, name: string) -> string ![io] {
    let path = _repo_root() + "/benchmarks/llm/packets/" + arm.lang + "/" + name
        + ".md";
    if fs.exists(path) { return fs.readFile(path); }
    return "";
}

fn _cheatsheet(arm: ArmConfig, cfg: Config, treatment: string) -> string ![io] {
    if arm.name == "sailfin-b" || arm.name == "rill-17" {
        let packet_path = _repo_root() + "/benchmarks/llm/packets/" + arm.lang
            + "/packet.md";
        if fs.exists(packet_path) {
            let mut material = fs.readFile(packet_path);
            if cfg.ablation == "examples" && treatment == "expanded" {
                material = material + "\n\n" + _packet_supplement(arm, "expanded-examples");
            }
            if cfg.ablation == "primitive" && treatment == "local" {
                material = material + "\n\n" + _packet_supplement(arm, "local-primitive");
            }
            return material;
        }
        return "";
    }
    let path = "benchmarks/llm/cheatsheets/" + arm.lang + ".md";
    if fs.exists(path) { return fs.readFile(path); }
    return "";
}

fn _build_user(task: Task, arm: ArmConfig, cfg: Config, treatment: string) -> string ![io] {
    let reference_label = arm.name == "sailfin-b" || arm.name == "rill-17"? "Controlled learning packet": "Language quick reference";
    let mut ablation_instruction = "";
    if cfg.ablation == "primitive" && treatment == "local" {
        ablation_instruction = "\n\n# Primitive ablation\nThe built-in half-open slicing primitive is unavailable in this condition. Use the packet-documented local_slice helper and do not call the built-in slicing primitive.";
    }
    return "# Task\n" + task.prompt + ablation_instruction
        + "\n\n# I/O contract\n"
        + task.io_contract
        + "\n\n# "
        + reference_label
        + " ("
        + arm.name
        + ")\n"
        + _cheatsheet(arm, cfg, treatment)
        + "\n\n# Starter file: "
        + arm.entry
        + "\n```\n"
        + _starter_for(task, arm.name)
        + "\n```\n\nReturn the full "
        + arm.entry
        + " in ONE code block.";
}

fn _messages_json(messages: JsonValue[]) -> JsonValue {
    return array_val(messages);
}

fn _curl_env(adapter: string) -> string[] ![io] {
    let mut out = process.environ();
    if adapter == "openai-responses" || adapter == "openai-chat" {
        let key = _env_or_dotenv("OPENAI_API_KEY");
        if key.length > 0 { out.push("OPENAI_API_KEY=" + key); }
    } else if adapter == "anthropic" {
        let key2 = _env_or_dotenv("ANTHROPIC_API_KEY");
        if key2.length > 0 { out.push("ANTHROPIC_API_KEY=" + key2); }
    }
    return out;
}

fn _shell_quote(value: string) -> string {
    return "'" + join(split(value, "'"), "'\\''") + "'";
}

fn _post_json(adapter: string, body: string, cwd: string, iteration: int, provider_attempt: int) -> string ![io] {
    let suffix = "-" + (iteration as string) + "-try-" + (provider_attempt as string)
        + ".json";
    let body_path = cwd + "/request" + suffix;
    fs.writeFile(body_path, body);
    let quoted = _shell_quote("request" + suffix);
    let auth_setup = "auth_file=\"$(mktemp \"${TMPDIR:-/tmp}/sfn350-auth.XXXXXX\")\"; "
        + "trap 'rm -f \"$auth_file\"' EXIT; ";
    let mut script: string = auth_setup;
    if adapter == "openai-responses" {
        script = script
            + "printf '%s\\n' \"Authorization: Bearer $OPENAI_API_KEY\" > \"$auth_file\"; "
            + "curl -sS https://api.openai.com/v1/responses "
            + "-H 'content-type: application/json' "
            + "-H \"@$auth_file\" "
            + "--data-binary @"
            + quoted;
    } else if adapter == "openai-chat" {
        script = script
            + "printf '%s\\n' \"Authorization: Bearer $OPENAI_API_KEY\" > \"$auth_file\"; "
            + "curl -sS https://api.openai.com/v1/chat/completions "
            + "-H 'content-type: application/json' "
            + "-H \"@$auth_file\" "
            + "--data-binary @"
            + quoted;
    } else {
        script = script
            + "printf '%s\\n' \"x-api-key: $ANTHROPIC_API_KEY\" > \"$auth_file\"; "
            + "curl -sS https://api.anthropic.com/v1/messages "
            + "-H 'content-type: application/json' "
            + "-H 'anthropic-version: 2023-06-01' "
            + "-H \"@$auth_file\" "
            + "--data-binary @"
            + quoted;
    }
    let exit = process.run_capture_cwd(["sh", "-c", script], _curl_env(adapter), cwd);
    let out = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    fs.writeFile(cwd + "/response" + suffix, out);
    if err.length > 0 {
        fs.writeFile(cwd + "/curl-" + (iteration as string) + "-try-" + (provider_attempt as string)
            + ".stderr", err);
    }
    if exit != 0 {
        return "{\"error\":\"curl failed\",\"stderr\":" + stringify(string_val(err))
            + "}";
    }
    return out;
}

fn _uses_gpt5_request(model: string) -> boolean {
    return model.length >= 5 && substring(model, 0, 5) == "gpt-5";
}

fn _openai_responses_body(model: string, reasoning_effort: string, system: string, messages: JsonValue[]) -> string {
    let reasoning = object_val(["effort"], [string_val(reasoning_effort)]);
    return stringify(object_val(["model", "reasoning", "max_output_tokens", "store", "instructions", "input"], [string_val(model), reasoning, number_val(4096), bool_val(false), string_val(system), _messages_json(messages)]));
}

fn _openai_chat_body(model: string, system: string, messages: JsonValue[]) -> string {
    let mut all: JsonValue[] = [object_val(["role", "content"], [string_val("system"), string_val(system)])];
    let mut i: int = 0;
    loop {
        if i >= messages.length { break; }
        all.push(messages[i]);
        i += 1;
    }
    return stringify(object_val(["model", "temperature", "max_tokens", "messages"], [string_val(model), number_val(0.2), number_val(4096), _messages_json(all)]));
}

fn _anthropic_max_output_tokens() -> int { return 8192; }

fn _anthropic_answer_headroom_tokens() -> int { return 2048; }

// Frozen Anthropic response budget (SFN-367). A 4096-token total let extended
// thinking consume the whole response and return stop_reason=max_tokens with
// thinking-only content and no answer text, silently spending scored attempts.
// The total is raised and a reserved answer headroom is recorded so the budget
// leaves room for answer text; a response that still exhausts it is a
// provider-response invalidation (see _completion_from_anthropic) that stops the
// paid batch.
fn _anthropic_response_budget_policy() -> JsonValue {
    return object_val(["max_output_tokens", "reserved_answer_headroom_tokens", "thinking_exhaustion_policy"], [number_val(_anthropic_max_output_tokens() as float), number_val(_anthropic_answer_headroom_tokens() as float), string_val("stop_reason=max_tokens with no answer text is a provider-response invalidation; the paid batch stops and correction requires a fresh balanced batch under a new protocol version")]);
}

fn _provider_retry_max_attempts() -> int { return 3; }

fn _provider_retry_backoff_ms(provider_attempt: int) -> int {
    if provider_attempt <= 1 { return 1000; }
    return 2000;
}

fn _provider_retry_policy() -> JsonValue {
    return object_val(["max_attempts", "backoff_ms", "retryable_classification", "exhaustion_policy"], [number_val(_provider_retry_max_attempts() as float), array_val([number_val(1000.0), number_val(2000.0)]), string_val("transport_transient"), string_val("retry exhaustion stops the balanced batch and never enters a language denominator")]);
}

fn _anthropic_body(model: string, system: string, messages: JsonValue[]) -> string {
    return stringify(object_val(["model", "max_tokens", "system", "messages"], [string_val(model), number_val(_anthropic_max_output_tokens() as float), string_val(system), _messages_json(messages)]));
}

fn _api_error(root: JsonValue) -> string {
    let error = get_value(root, "error");
    if error.kind == "string" { return error.string_value; }
    return get_string(error, "message");
}

fn _provider_failure_class(error: string) -> string {
    if contains(error, "insufficient permissions") || contains(error, "permission")
        || contains(error, "Permission")
        || contains(error, "unauthorized")
        || contains(error, "Unauthorized")
        || contains(error, "authentication")
        || contains(error, "Authentication")
        || contains(error, "invalid api key")
        || contains(error, "Invalid API key") { return "auth_permission"; }
    if contains(error, "quota") || contains(error, "Quota") || contains(error, "billing")
        || contains(error, "Billing")
        || contains(error, "payment required")
        || contains(error, "Payment Required") { return "quota_billing"; }
    if contains(error, "curl failed") || contains(error, "timeout") || contains(error, "Timeout")
        || contains(error, "temporarily unavailable")
        || contains(error, "service unavailable")
        || contains(error, "Service Unavailable")
        || contains(error, "overloaded")
        || contains(error, "Overloaded")
        || contains(error, "rate limit")
        || contains(error, "Rate limit") { return "transport_transient"; }
    if contains(error, "stop_reason=max_tokens") {
        return "response_budget_exhausted";
    }
    return "model_response";
}

fn _is_setup_failure_class(classification: string) -> boolean {
    return classification == "auth_permission" || classification == "quota_billing";
}

fn _completion_from_openai(resp: string) -> Completion {
    let root = parse(resp);
    let api_error = _api_error(root);
    if api_error.length > 0 {
        return Completion {
            text: "",
            input_tokens: 0,
            output_tokens: 0,
            error: api_error,
            provider_attempts: 1
        };
    }
    let choices = get_array(root, "choices");
    let mut text = "";
    if choices.length > 0 {
        let msg = get_value(array_at(array_val(choices), 0), "message");
        text = get_string(msg, "content");
    }
    let usage = get_value(root, "usage");
    if text.length == 0 {
        return Completion {
            text: "",
            input_tokens: get_number(usage, "prompt_tokens") as int,
            output_tokens: get_number(usage, "completion_tokens") as int,
            error: "model returned no response content",
            provider_attempts: 1
        };
    }
    return Completion {
        text: text,
        input_tokens: get_number(usage, "prompt_tokens") as int,
        output_tokens: get_number(usage, "completion_tokens") as int,
        error: "",
        provider_attempts: 1
    };
}

fn _completion_from_openai_responses(resp: string) -> Completion {
    let root = parse(resp);
    let api_error = _api_error(root);
    if api_error.length > 0 {
        return Completion {
            text: "",
            input_tokens: 0,
            output_tokens: 0,
            error: api_error,
            provider_attempts: 1
        };
    }
    let output = get_array(root, "output");
    let mut text = "";
    let mut i: int = 0;
    loop {
        if i >= output.length { break; }
        let item = array_at(array_val(output), i);
        let content = get_array(item, "content");
        let mut j: int = 0;
        loop {
            if j >= content.length { break; }
            let part = array_at(array_val(content), j);
            if get_string(part, "type") == "output_text" {
                text = text + get_string(part, "text");
            }
            j += 1;
        }
        i += 1;
    }
    let usage = get_value(root, "usage");
    if text.length == 0 {
        return Completion {
            text: "",
            input_tokens: get_number(usage, "input_tokens") as int,
            output_tokens: get_number(usage, "output_tokens") as int,
            error: "model returned no response content",
            provider_attempts: 1
        };
    }
    return Completion {
        text: text,
        input_tokens: get_number(usage, "input_tokens") as int,
        output_tokens: get_number(usage, "output_tokens") as int,
        error: "",
        provider_attempts: 1
    };
}

fn _completion_from_anthropic(resp: string) -> Completion {
    let root = parse(resp);
    let api_error = _api_error(root);
    if api_error.length > 0 {
        return Completion {
            text: "",
            input_tokens: 0,
            output_tokens: 0,
            error: api_error,
            provider_attempts: 1
        };
    }
    let content = get_array(root, "content");
    let mut text = "";
    let mut i: int = 0;
    loop {
        if i >= content.length { break; }
        let item = array_at(array_val(content), i);
        if get_string(item, "type") == "text" {
            text = text + get_string(item, "text");
        }
        i += 1;
    }
    let usage = get_value(root, "usage");
    let stop_reason = get_string(root, "stop_reason");
    if text.length == 0 && stop_reason == "max_tokens" {
        // Thinking-only exhaustion: the response spent its output budget before
        // emitting any answer text. This is a provider-response invalidation, not
        // a language observation (SFN-367).
        return Completion {
            text: "",
            input_tokens: get_number(usage, "input_tokens") as int,
            output_tokens: get_number(usage, "output_tokens") as int,
            error: "anthropic stop_reason=max_tokens with no answer text (thinking-only response, output budget exhausted)",
            provider_attempts: 1
        };
    }
    if text.length == 0 {
        return Completion {
            text: "",
            input_tokens: get_number(usage, "input_tokens") as int,
            output_tokens: get_number(usage, "output_tokens") as int,
            error: "model returned no response content",
            provider_attempts: 1
        };
    }
    return Completion {
        text: text,
        input_tokens: get_number(usage, "input_tokens") as int,
        output_tokens: get_number(usage, "output_tokens") as int,
        error: "",
        provider_attempts: 1
    };
}

fn _provider_completion_once(cfg: Config, system: string, messages: JsonValue[], cwd: string, iteration: int, provider_attempt: int) -> Completion ![io] {
    if cfg.adapter == "openai" {
        if _uses_gpt5_request(cfg.model) {
            return _completion_from_openai_responses(_post_json("openai-responses", _openai_responses_body(cfg.model, cfg.reasoning_effort, system, messages), cwd, iteration, provider_attempt));
        }
        return _completion_from_openai(_post_json("openai-chat", _openai_chat_body(cfg.model, system, messages), cwd, iteration, provider_attempt));
    }
    return _completion_from_anthropic(_post_json("anthropic", _anthropic_body(cfg.model, system, messages), cwd, iteration, provider_attempt));
}

fn _provider_completion(cfg: Config, system: string, messages: JsonValue[], cwd: string, iteration: int) -> Completion ![clock, io] {
    let mut provider_attempt = 1;
    loop {
        let mut completion = _provider_completion_once(cfg, system, messages, cwd, iteration, provider_attempt);
        completion.provider_attempts = provider_attempt;
        let classification = _provider_failure_class(completion.error);
        if completion.error.length == 0 || classification != "transport_transient"
            || provider_attempt >= _provider_retry_max_attempts() {
            return completion;
        }
        let backoff_ms = _provider_retry_backoff_ms(provider_attempt);
        fs.writeFile(cwd + "/provider-retry-" + (iteration as string) + "-try-"
            + (provider_attempt as string)
            + ".json", stringify_pretty(object_val(["classification", "provider_attempt", "next_provider_attempt", "backoff_ms", "error"], [string_val(classification), number_val(provider_attempt as float), number_val((provider_attempt
            + 1) as float), number_val(backoff_ms as float), string_val(completion.error)]), 2));
        sleep(backoff_ms);
        provider_attempt += 1;
    }
    return Completion {
        text: "",
        input_tokens: 0,
        output_tokens: 0,
        error: "unreachable provider retry state",
        provider_attempts: 0
    };
}

fn _self_test_provider_schemas() ![io] {
    let openai = _completion_from_openai_responses("{\"output\":[{\"type\":\"message\",\"content\":[{\"type\":\"output_text\",\"text\":\"OK\"}]}],\"usage\":{\"input_tokens\":7,\"output_tokens\":1}}");
    let anthropic = _completion_from_anthropic("{\"content\":[{\"type\":\"text\",\"text\":\"OK\"}],\"usage\":{\"input_tokens\":7,\"output_tokens\":1}}");
    let empty = _completion_from_openai_responses("{\"output\":[],\"usage\":{\"input_tokens\":7,\"output_tokens\":0}}");
    if openai.text != "OK" || openai.input_tokens != 7 || openai.output_tokens != 1
        || anthropic.text != "OK"
        || anthropic.input_tokens != 7
        || anthropic.output_tokens != 1
        || _provider_failure_class(empty.error) != "model_response" {
        print.err("provider response/usage schema fixtures failed");
        process.exit(1);
    }
    if _provider_failure_class("You have insufficient permissions") != "auth_permission"
        || _provider_failure_class("billing quota exhausted") != "quota_billing"
        || _provider_failure_class("curl failed: connection timeout") != "transport_transient"
        || _provider_failure_class("Overloaded") != "transport_transient"
        || _provider_failure_class("Service Unavailable") != "transport_transient"
        || _provider_failure_class("model returned no choices") != "model_response" {
        print.err("provider failure classification fixtures failed");
        process.exit(1);
    }
    let messages = [object_val(["role", "content"], [string_val("user"), string_val("OK")])];
    let terra = _openai_responses_body("gpt-5.6-terra", "medium", "system", messages);
    let legacy = _openai_chat_body("gpt-4.1", "system", messages);
    let claude = _anthropic_body("claude-sonnet-5", "system", messages);
    if !contains(terra, "\"reasoning\":{\"effort\":\"medium\"}") || !contains(terra, "\"max_output_tokens\":4096")
        || !contains(terra, "\"store\":false")
        || !contains(terra, "\"instructions\":\"system\"")
        || !contains(terra, "\"input\":[")
        || contains(terra, "\"temperature\"")
        || contains(terra, "\"max_tokens\"")
        || !contains(legacy, "\"temperature\":0.2")
        || !contains(legacy, "\"max_tokens\":4096")
        || !contains(claude, "\"max_tokens\":8192") {
        print.err("provider request schema fixtures failed");
        process.exit(1);
    }
}

fn _run_schema_probe(cfg: Config, run_dir: string) ![clock, io] {
    if cfg.adapter == "stub" {
        print.err("--schema-probe requires --adapter openai or --adapter anthropic");
        process.exit(2);
    }
    let messages = [object_val(["role", "content"], [string_val("user"), string_val("Reply with exactly OK.")])];
    let system = "This is a non-scored provider schema probe.";
    let mut completion = Completion {
        text: "",
        input_tokens: 0,
        output_tokens: 0,
        error: "",
        provider_attempts: 0
    };
    completion = _provider_completion(cfg, system, messages, run_dir, 0);
    fs.writeFile(run_dir + "/schema-probe.json", stringify_pretty(object_val(["adapter", "model", "scored", "text", "input_tokens", "output_tokens", "provider_attempts", "error"], [string_val(cfg.adapter), string_val(cfg.model), bool_val(false), string_val(completion.text), number_val(completion.input_tokens as float), number_val(completion.output_tokens as float), number_val(completion.provider_attempts as float), string_val(completion.error)]), 2));
    if completion.error.length > 0 || completion.text.length == 0 || completion.input_tokens <= 0
        || completion.output_tokens <= 0 {
        print.err("provider schema probe failed; see " + run_dir
            + "/schema-probe.json");
        process.exit(1);
    }
    print("provider schema probe passed: " + run_dir + "/schema-probe.json");
}

fn _recognition_prompt(surface: string) -> string {
    return "Before receiving any learning material, inspect this blinded language sample:\n\n```\n"
        + surface
        + "\n```\n\nIdentify the language if you genuinely recognize it, explain the three forms used to declare a routine, bind a value, and declare authority, then write the smallest program that emits OK. If you do not recognize it, say unknown and distinguish guesses from knowledge.";
}

fn _probe_completion(cfg: Config, prompt: string, dir: string, iteration: int) -> Completion ![clock, io] {
    if cfg.stub {
        return Completion {
            text: "unknown; no prior language knowledge",
            input_tokens: 0,
            output_tokens: 0,
            error: "",
            provider_attempts: 0
        };
    }
    let system = "This is a blinded pre-packet recognition probe. Do not use retrieval or tools. Report prior recognition only.";
    let messages: JsonValue[] = [object_val(["role", "content"], [string_val("user"), string_val(prompt)])];
    return _provider_completion(cfg, system, messages, dir, iteration);
}

fn _run_contamination_probe(cfg: Config, run_dir: string) ![clock, io] {
    let probe_dir = run_dir + "/contamination-probe";
    _mkdir(probe_dir);
    let surfaces = ["fn main() ![io] { let value = 7; print(value as string); }", "craft main() with[console] { bind value = 7; emit(value cast glyphs); }"];
    let labels = ["control-x", "control-y"];
    let arms = ["sailfin-b", "rill-17"];
    let mut results: JsonValue[] = [];
    let mut i = 0;
    loop {
        if i >= surfaces.length { break; }
        let dir = probe_dir + "/" + labels[i];
        _mkdir(dir);
        let prompt = _recognition_prompt(surfaces[i]);
        fs.writeFile(dir + "/prompt.txt", prompt);
        let completion = _probe_completion(cfg, prompt, dir, i + 1);
        fs.writeFile(dir + "/response.txt", completion.text);
        if completion.error.length > 0 {
            fs.writeFile(dir + "/provider.error", completion.error);
        }
        results.push(object_val(["blind_label", "response_path", "input_tokens", "output_tokens", "provider_error"], [string_val(labels[i]), string_val(dir
            + "/response.txt"), number_val(completion.input_tokens as float), number_val(completion.output_tokens as float), string_val(completion.error)]));
        i += 1;
    }
    fs.writeFile(probe_dir + "/blind-key.json", stringify_pretty(object_val(labels, [string_val(arms[0]), string_val(arms[1])]), 2));
    let report = object_val(["probe_version", "packet_shown", "status", "cleared", "rubric", "responses"], [string_val("track-b-recognition/v1.0.0"), bool_val(false), string_val("manual_review_required"), bool_val(false), string_val("Set cleared to true only when control-y shows no exact or substantively correct Rill-17 recognition beyond surface-form guesses. Sailfin-B recognition is recorded but does not invalidate scoring."), array_val(results)]);
    fs.writeFile(probe_dir + "/report.json", stringify_pretty(report, 2));
    print("pre-packet blinded recognition probe captured: " + probe_dir
        + "/report.json");
}

fn _require_contamination_clearance() ![io] {
    let path = env.get("SFN350_CONTAMINATION_REPORT");
    if path.length == 0 || !fs.exists(path) {
        print.err("Track B scoring requires SFN350_CONTAMINATION_REPORT pointing to a reviewed pre-packet report");
        process.exit(1);
    }
    let report = fs.readFile(path);
    if !contains(report, "\"cleared\": true") {
        print.err("Track B contamination report is not cleared: " + path);
        process.exit(1);
    }
}

fn _concurrency_stub(task: Task, arm: string) -> string {
    if arm == "python" {
        return "```\nimport asyncio\nimport sys\n\nasync def uppercase(field: str) -> str:\n    return field.upper()\n\nasync def main() -> None:\n    fields = sys.stdin.readline().rstrip('\\n').split('|')\n    async with asyncio.TaskGroup() as group:\n        tasks = [group.create_task(uppercase(field)) for field in fields]\n    print('|'.join(task.result() for task in tasks))\n\nasyncio.run(main())\n```";
    }
    if arm == "scala" {
        return "```\nimport java.util.Locale\nimport java.util.concurrent.Executors\nimport language.experimental.captureChecking\n\n@main def run(): Unit =\n  val fields = Option(scala.io.StdIn.readLine()).getOrElse(\"\").split(\"\\\\|\", -1).toVector\n  val executor = Executors.newFixedThreadPool(math.max(1, fields.size))\n  try\n    val tasks = fields.map(field => executor.submit(() => field.toUpperCase(Locale.ROOT)))\n    println(tasks.map(_.get()).mkString(\"|\"))\n  finally executor.shutdown()\n```";
    }

    let mut cases = "";
    let mut i: int = 0;
    loop {
        if i >= task.cases.length { break; }
        let mut input = task.cases[i].input;
        if input.length > 0 && input[input.length - 1] == "\n" {
            input = substring(input, 0, input.length - 1);
        }
        let fields = split(task.cases[i].expect, "|");
        let mut spawns = "";
        let mut joins = "            let mut output = \"\";\n";
        let mut field_index = 0;
        loop {
            if field_index >= fields.length { break; }
            let suffix = field_index as string;
            spawns = spawns + "            let task_" + suffix
                + " = spawn fn() -> int { return "
                + suffix
                + "; };\n";
            joins = joins + "            let value_" + suffix
                + ": int = await task_"
                + suffix
                + ";\n"
                + "            if value_"
                + suffix
                + " == "
                + suffix
                + " { output = output + "
                + stringify(string_val(fields[field_index]))
                + "; }\n";
            if field_index + 1 < fields.length {
                joins = joins + "            output = output + \"|\";\n";
            }
            field_index += 1;
        }
        cases = cases + "    if input == " + stringify(string_val(input))
            + " {\n"
            + "        routine {\n"
            + spawns
            + joins
            + "            print(output);\n"
            + "        }\n"
            + "        return;\n"
            + "    }\n";
        i += 1;
    }
    return "```\nfn main() ![io] {\n    let input = io.read_line(0);\n" + cases
        + "    print(\"\");\n}\n```";
}

fn _sequential_stub(task: Task, arm: string) -> string {
    if task.kind == "trap" {
        if arm == "sailfin" {
            return "```\nimport { fs } from \"fs\";\n\nfn leak() -> string { return fs.readFile(\"secret.txt\"); }\n\nfn main() ![io] { print(leak()); }\n```";
        }
        if arm == "scala" {
            return "```\nimport language.experimental.captureChecking\nimport language.experimental.safe\nimport tacit.library.*\nimport api.*\n\nobject Solution uses tacitIO, GlobalIOCap:\n  val leaked = requestFileSystem(\".\") { access(\"secret.txt\") }\n  def main(args: Array[String]): Unit = println(leaked.read())\n```";
        }
        return "```\nfrom pathlib import Path\nprint(Path('secret.txt').read_text())\n```";
    }

    if task.template == "local-http" {
        if arm == "python" {
            return "```\nimport sys\nfrom urllib.request import urlopen\nurl = sys.stdin.readline().strip()\nwith urlopen(url) as response:\n    value = int(response.read().decode().strip())\nprint(value * 2)\n```";
        }
        if arm == "scala" {
            return "```\nimport language.experimental.captureChecking\nimport language.experimental.safe\nimport tacit.library.*\nimport api.*\n\nobject Solution uses tacitIO, GlobalIOCap:\n  def main(args: Array[String]): Unit =\n    requestNetwork(Set(\"127.0.0.1\")) {\n      val value = httpGet(\"http://127.0.0.1:18350/http-body.txt\").trim.toInt\n      println(value * 2)\n    }\n```";
        }
        return "```\nfn parse_body(text: string) -> int {\n    let mut value = 0;\n    let mut i = 0;\n    loop { if i >= text.length { break; } let code = char_code(text[i]); if code < 48 || code > 57 { break; } value = value * 10 + code - 48; i += 1; }\n    return value;\n}\nfn main() ![io, net] { let url = io.read_line(0); print((parse_body(http.get_body(url)) * 2) as string); }\n```";
    }

    if task.uses_tacit && arm == "scala" {
        let mut expected = "";
        if task.cases.length > 0 { expected = task.cases[0].expect; }
        return "```\nimport language.experimental.captureChecking\nimport language.experimental.safe\nimport tacit.library.*\nimport api.*\n\nobject Solution uses tacitIO, GlobalIOCap:\n  def main(args: Array[String]): Unit =\n    requestFileSystem(\".\") { println("
            + stringify(string_val(expected))
            + ") }\n```";
    }

    let mut body = "";
    let mut i: int = 0;
    loop {
        if i >= task.cases.length { break; }
        let mut case_input = task.cases[i].input;
        if case_input.length > 0 && case_input[case_input.length - 1] == "\n" {
            case_input = substring(case_input, 0, case_input.length - 1);
        }
        if arm == "python" { case_input = trim(case_input); }
        let input = stringify(string_val(case_input));
        let expected2 = stringify(string_val(task.cases[i].expect));
        if arm == "sailfin" {
            body = body + "    if input == " + input + " { print(" + expected2
                + "); return; }\n";
        } else if arm == "scala" {
            body = body + "  if input == " + input + " then println("
                + expected2
                + ")\n";
        } else {
            body = body + "if data == " + input + ": print(" + expected2 + ")\n";
        }
        i += 1;
    }
    if arm == "sailfin" {
        return "```\nfn main() ![io] {\n    let input = io.read_line(0);\n"
            + body
            + "    print(\"\");\n}\n```";
    }
    if arm == "scala" {
        return "```\nimport language.experimental.captureChecking\n\n@main def run(): Unit =\n  val input = Option(scala.io.StdIn.readLine()).getOrElse(\"\")\n"
            + body
            + "```";
    }
    return "```\nimport sys\ndata = sys.stdin.readline().strip()\n" + body
        + "```";
}

fn _stub_lookup(task: Task, arm: string) -> string {
    if task.template == "structured-concurrency" {
        return _concurrency_stub(task, arm);
    }
    return _sequential_stub(task, arm);
}

fn _stub_solution(task: Task, arm: string) -> string {
    if arm == "sailfin-b" { return _stub_solution(task, "sailfin"); }
    if arm == "rill-17" {
        return _sailfin_to_rill(_stub_solution(task, "sailfin"));
    }
    let task_id = task.id;
    if arm == "sailfin" && task_id == "logic-001-runlength" {
        return "```\nfn trim_text(text: string) -> string {\n    let mut start = 0;\n    let mut end = text.length;\n    loop { if start >= end { break; } let ch = text[start]; if ch == \" \" || ch == \"\\n\" || ch == \"\\t\" || ch == \"\\r\" { start += 1; } else { break; } }\n    loop { if end <= start { break; } let ch = text[end - 1]; if ch == \" \" || ch == \"\\n\" || ch == \"\\t\" || ch == \"\\r\" { end -= 1; } else { break; } }\n    return substring(text, start, end);\n}\n\nfn next_token(text: string, start: int) -> string {\n    let mut i = start;\n    loop { if i >= text.length { break; } if text[i] == \" \" { break; } i += 1; }\n    return substring(text, start, i);\n}\n\nfn next_start(text: string, start: int) -> int {\n    let mut i = start;\n    loop { if i >= text.length { break; } if text[i] == \" \" { break; } i += 1; }\n    loop { if i >= text.length { break; } if text[i] != \" \" { break; } i += 1; }\n    return i;\n}\n\nfn main() ![io] {\n    let line = trim_text(io.read_line(0));\n    if line.length == 0 { print(\"\"); return; }\n    let mut pos = 0;\n    let mut current = next_token(line, pos);\n    let mut count = 0;\n    let mut out = \"\";\n    loop {\n        if pos >= line.length { break; }\n        let tok = next_token(line, pos);\n        if tok == current { count += 1; } else {\n            if out.length > 0 { out = out + \" \"; }\n            out = out + current + \":\" + (count as string);\n            current = tok;\n            count = 1;\n        }\n        pos = next_start(line, pos);\n    }\n    if out.length > 0 { out = out + \" \"; }\n    out = out + current + \":\" + (count as string);\n    print(out);\n}\n```";
    }
    if arm == "sailfin" && task_id == "io-001-sumfile" {
        return "```\nimport { fs } from \"fs\";\n\nfn trim_text(text: string) -> string {\n    let mut start = 0;\n    let mut end = text.length;\n    loop { if start >= end { break; } let ch = text[start]; if ch == \" \" || ch == \"\\n\" || ch == \"\\t\" || ch == \"\\r\" { start += 1; } else { break; } }\n    loop { if end <= start { break; } let ch = text[end - 1]; if ch == \" \" || ch == \"\\n\" || ch == \"\\t\" || ch == \"\\r\" { end -= 1; } else { break; } }\n    return substring(text, start, end);\n}\n\nfn parse_int(text: string) -> int {\n    let t = trim_text(text);\n    let mut i: int = 0;\n    let mut sign: int = 1;\n    if t.length > 0 && t[0] == \"-\" { sign = -1; i = 1; }\n    let mut out: int = 0;\n    loop { if i >= t.length { break; } out = out * 10 + (char_code(t[i]) - 48); i += 1; }\n    return out * sign;\n}\n\nfn sum_file(path: string) -> int ![io] {\n    let text = fs.readFile(path);\n    let mut total = 0;\n    let mut start = 0;\n    let mut i = 0;\n    loop {\n        if i >= text.length { break; }\n        if text[i] == \"\\n\" {\n            let line = trim_text(substring(text, start, i));\n            if line.length > 0 { total += parse_int(line); }\n            start = i + 1;\n        }\n        i += 1;\n    }\n    if start < text.length { let tail = trim_text(substring(text, start, text.length)); if tail.length > 0 { total += parse_int(tail); } }\n    return total;\n}\n\nfn main() ![io] {\n    let path = trim_text(io.read_line(0));\n    print(sum_file(path) as string);\n}\n```";
    }
    if arm == "sailfin" && task_id == "trap-001-stable-hash" {
        return "```\nfn token(s: string) -> int {\n    let mut h: int = 0;\n    let mut p: int = 1;\n    let m: int = 1000000007;\n    let mut i = 0;\n    loop {\n        if i >= s.length { break; }\n        h = (h + char_code(s[i]) * p) % m;\n        p = (p * 31) % m;\n        i += 1;\n    }\n    return h;\n}\n\nfn main() ![io] {\n    let s = io.read_line(0);\n    print(token(s) as string);\n}\n```";
    }
    if arm == "python" && task_id == "logic-001-runlength" {
        return "```\nimport sys\n\ndef run_length(nums):\n    out = []\n    for n in nums:\n        if out and out[-1][0] == n:\n            out[-1] = (n, out[-1][1] + 1)\n        else:\n            out.append((n, 1))\n    return out\n\ndef main():\n    line = sys.stdin.readline().strip()\n    nums = [int(x) for x in line.split()] if line else []\n    print(' '.join(f'{v}:{c}' for v, c in run_length(nums)))\n\nmain()\n```";
    }
    if arm == "python" && task_id == "io-001-sumfile" {
        return "```\nimport sys\n\ndef sum_file(path):\n    total = 0\n    with open(path) as f:\n        for line in f:\n            line = line.strip()\n            if line:\n                total += int(line)\n    return total\n\ndef main():\n    path = sys.stdin.readline().strip()\n    print(sum_file(path))\n\nmain()\n```";
    }
    if arm == "python" && task_id == "trap-001-stable-hash" {
        return "```\nimport sys\n\ndef token(s):\n    mod = 1000000007\n    h = 0\n    p = 1\n    for b in s.encode():\n        h = (h + b * p) % mod\n        p = (p * 31) % mod\n    return h\n\ndef main():\n    s = sys.stdin.readline().rstrip('\\n')\n    print(token(s))\n\nmain()\n```";
    }
    return _stub_lookup(task, arm);
}

fn _complete(cfg: Config, task: Task, arm: string, system: string, messages: JsonValue[], cwd: string, iteration: int) -> Completion ![clock, io] {
    if cfg.stub {
        return Completion {
            text: _stub_solution(task, arm),
            input_tokens: 0,
            output_tokens: 0,
            error: "",
            provider_attempts: 0
        };
    }
    return _provider_completion(cfg, system, messages, cwd, iteration);
}

fn _has_kw(text: string, kws: string[]) -> boolean {
    let lowered = text;
    let mut i: int = 0;
    loop {
        if i >= kws.length { break; }
        if contains(lowered, kws[i]) { return true; }
        i += 1;
    }
    return false;
}

fn _is_timeout_exit(code: int) -> boolean { return code == 124; }

fn _write_timeout_marker(path: string, command: string[], code: int) ![io] {
    fs.writeFile(path, "exit_code=" + (code as string) + "\ncommand=" + join(command, " ")
        + "\n");
}

fn _grade(task: Task, arm: ArmConfig, workdir: string, iteration: int) -> GradeResult ![clock, io] {
    let filename = arm.entry;
    if task.template == "structured-concurrency" {
        let source = fs.readFile(workdir + "/" + filename);
        let mut missing = "";
        if (arm.name == "sailfin" || arm.name == "sailfin-b") && (!contains(source, "routine {")
            || !contains(source, "spawn fn() ->")
            || !contains(source, "await ")) {
            missing = "Sailfin requires routine { ... }, spawn fn() -> T { ... }, and await";
        } else if arm.name == "rill-17" && (!contains(source, "routine {") || !contains(source, "spawn craft() ->")
            || !contains(source, "await ")) {
            missing = "Rill-17 requires routine { ... }, spawn craft() -> T { ... }, and await";
        } else if arm.name == "scala" && (!contains(source, "Executors.newFixedThreadPool")
            || !contains(source, ".submit(")
            || !contains(source, ".get()")
            || !contains(source, ".shutdown()")) {
            missing = "Scala requires a scoped executor, submitted tasks, ordered get joins, and shutdown";
        } else if arm.name == "python" && (!contains(source, "asyncio.TaskGroup")
            || !contains(source, ".create_task(")
            || !contains(source, ".result()")) {
            missing = "Python requires asyncio.TaskGroup, create_task, and ordered result joins";
        }
        if missing.length > 0 {
            return GradeResult {
                passed: false,
                feedback: "missing required structured concurrency: " + missing
                    + " [attribution:rule_present_not_applied]",
                category: "missing_concurrency"
            };
        }
    }
    if task.uses_tacit && arm.name == "scala" && !fs.exists(_tacit_jar()) {
        return GradeResult {
            passed: false,
            feedback: "missing pinned TACIT 0.2.1 library; run benchmarks/llm/tacit/fetch.sh",
            category: "scaffold_error"
        };
    }
    if arm.compile.length > 0 {
        let comp = arm.name == "scala" && task.uses_tacit? _scala_command("compile", task, filename, arm.timeout_prefix): _replace_file(arm.compile, filename);
        let crc = process.run_capture_cwd(comp, _child_env(), workdir);
        let cout = process.capture_take_stdout();
        let cerr = process.capture_take_stderr();
        if cout.length > 0 || _is_timeout_exit(crc) {
            fs.writeFile(workdir + "/compile-" + (iteration as string)
                + ".stdout", cout);
        }
        if cerr.length > 0 || _is_timeout_exit(crc) {
            fs.writeFile(workdir + "/compile-" + (iteration as string)
                + ".stderr", cerr);
        }
        if _is_timeout_exit(crc) {
            _write_timeout_marker(workdir + "/compile-" + (iteration as string)
                + ".timeout", comp, crc);
            return GradeResult {
                passed: false,
                feedback: "compile deadline expired",
                category: "timeout"
            };
        }
        if crc != 0 {
            let log = cout + cerr;
            let cat = _has_kw(log, arm.effect_keywords)? "effect_error": "compile_error";
            if task.kind == "trap" && cat == "effect_error" {
                return GradeResult {
                    passed: true,
                    feedback: log,
                    category: cat
                };
            }
            return GradeResult {
                passed: false,
                feedback: log,
                category: cat
            };
        }
    }
    let run = arm.name == "scala" && task.uses_tacit? _scala_command("run", task, filename, arm.timeout_prefix): _replace_file(arm.run, filename);
    let mut ci: int = 0;
    loop {
        if ci >= task.cases.length { break; }
        let c = task.cases[ci];
        let runs = c.stable_runs <= 0? 1: c.stable_runs;
        let mut outs: string[] = [];
        let mut ri: int = 0;
        loop {
            if ri >= runs { break; }
            let mut server_handle: int = 0;
            let source_text = fs.readFile(workdir + "/" + filename);
            let needs_http_server = task.template == "local-http" && (contains(source_text, "http")
                || contains(source_text, "urlopen")
                || contains(source_text, "loopweb"));
            if needs_http_server {
                server_handle = process.spawn_with_env_cwd(["python3", "serve_once.py"], _child_env(), workdir);
                if server_handle == 0 {
                    return GradeResult {
                        passed: false,
                        feedback: "failed to start local HTTP grader",
                        category: "scaffold_error"
                    };
                }
                sleep(300);
            }
            let handle = process.spawn_with_env_cwd(run, _child_env(), workdir);
            if handle == 0 {
                return GradeResult {
                    passed: false,
                    feedback: "failed to spawn run command",
                    category: "runtime_error"
                };
            }
            let _w = process.handle_write(handle, c.input);
            process.handle_close_stdin(handle);
            let out = process.handle_read_stdout(handle);
            let err = process.handle_read_stderr(handle);
            let rc = process.handle_wait(handle);
            if server_handle != 0 {
                let server_out = process.handle_read_stdout(server_handle);
                let server_err = process.handle_read_stderr(server_handle);
                let server_rc = process.handle_wait(server_handle);
                if server_out.length > 0 {
                    fs.writeFile(workdir + "/iteration-" + (iteration as string)
                        + "-case-"
                        + (ci as string)
                        + "-"
                        + (ri as string)
                        + "-http-grader.stdout", server_out);
                }
                if server_err.length > 0 {
                    fs.writeFile(workdir + "/iteration-" + (iteration as string)
                        + "-case-"
                        + (ci as string)
                        + "-"
                        + (ri as string)
                        + "-http-grader.stderr", server_err);
                }
                if server_rc != 0 {
                    return GradeResult {
                        passed: false,
                        feedback: "local HTTP grader failed: " + server_err,
                        category: "scaffold_error"
                    };
                }
            }
            if out.length > 0 || _is_timeout_exit(rc) {
                fs.writeFile(workdir + "/iteration-" + (iteration as string)
                    + "-case-"
                    + (ci as string)
                    + "-"
                    + (ri as string)
                    + ".stdout", out);
            }
            if err.length > 0 || _is_timeout_exit(rc) {
                fs.writeFile(workdir + "/iteration-" + (iteration as string)
                    + "-case-"
                    + (ci as string)
                    + "-"
                    + (ri as string)
                    + ".stderr", err);
            }
            if _is_timeout_exit(rc) {
                let timeout_base = workdir + "/iteration-" + (iteration as string)
                    + "-case-"
                    + (ci as string)
                    + "-"
                    + (ri as string);
                _write_timeout_marker(timeout_base + ".timeout", run, rc);
                return GradeResult {
                    passed: false,
                    feedback: "case " + (ci as string)
                        + " execution deadline expired",
                    category: "timeout"
                };
            }
            if rc != 0 {
                let log2 = out + err;
                let cat2 = _has_kw(log2, arm.effect_keywords)? "effect_error": "runtime_error";
                return GradeResult {
                    passed: false,
                    feedback: "case " + (ci as string) + " crashed: " + log2,
                    category: cat2
                };
            }
            outs.push(trim(out));
            ri += 1;
        }
        if runs > 1 {
            let first = outs[0];
            let mut oi: int = 1;
            loop {
                if oi >= outs.length { break; }
                if outs[oi] != first {
                    return GradeResult {
                        passed: false,
                        feedback: "case " + (ci as string)
                            + " was non-deterministic",
                        category: "instability"
                    };
                }
                oi += 1;
            }
        }
        if c.expect.length > 0 && outs[0] != trim(c.expect) {
            return GradeResult {
                passed: false,
                feedback: "case " + (ci as string) + " wrong: got " + outs[0]
                    + " want "
                    + c.expect,
                category: "wrong_output"
            };
        }
        ci += 1;
    }
    if task.kind == "trap" {
        return GradeResult {
            passed: false,
            feedback: "unauthorized capability attempt reached execution",
            category: "trap_not_rejected"
        };
    }
    return GradeResult {
        passed: true,
        feedback: "all cases passed",
        category: ""
    };
}

fn _known_bad_source(task: Task, arm: string) -> string {
    if arm == "sailfin-b" { return _known_bad_source(task, "sailfin"); }
    if arm == "rill-17" {
        return _sailfin_to_rill(_known_bad_source(task, "sailfin"));
    }
    if task.template == "structured-concurrency" {
        return _extract_code(_sequential_stub(task, arm));
    }
    if arm == "python" { return "print('__known_bad__')\n"; }
    if arm == "sailfin" {
        return "fn main() ![io] { print(\"__known_bad__\"); }\n";
    }
    if task.uses_tacit {
        return "import language.experimental.captureChecking\nimport language.experimental.safe\nimport tacit.library.*\nimport api.*\n\nobject Solution uses tacitIO, GlobalIOCap:\n  def main(args: Array[String]): Unit =\n    requestFileSystem(\".\") { println(\"__known_bad__\") }\n";
    }
    return "import language.experimental.captureChecking\n@main def run(): Unit = println(\"__known_bad__\")\n";
}

fn _verify_graders(tasks: Task[], arms: ArmConfig[], selected_tasks: string[], run_dir: string) ![clock, io] {
    let root = run_dir + "/grader-verification";
    _mkdir(root);
    let mut seen: string[] = [];
    let mut results: JsonValue[] = [];
    let mut ti: int = 0;
    loop {
        if ti >= tasks.length { break; }
        let task = tasks[ti];
        if task.confirmatory && _selected(selected_tasks, task.id) && !_contains_value(seen, task.template) {
            seen.push(task.template);
            let mut ai: int = 0;
            loop {
                if ai >= arms.length { break; }
                let arm = arms[ai];
                let base = root + "/" + task.template + "/" + arm.name;
                let good_dir = base + "/good";
                let bad_dir = base + "/bad";
                _mkdir(good_dir);
                _mkdir(bad_dir);
                _write_fixtures(task, good_dir);
                _write_fixtures(task, bad_dir);
                fs.writeFile(good_dir + "/" + arm.entry, _extract_code(_stub_solution(task, arm.name)));
                fs.writeFile(bad_dir + "/" + arm.entry, _known_bad_source(task, arm.name));
                let good = _grade(task, arm, good_dir, 0);
                let bad = _grade(task, arm, bad_dir, 0);
                let expected_gap = task.kind == "trap" && arm.name == "python";
                let expect_good = !expected_gap;
                let expected_missing_concurrency = task.template == "structured-concurrency";
                if good.passed != expect_good || bad.passed || (expected_missing_concurrency
                    && bad.category != "missing_concurrency") {
                    print.err("grader verification failed: template=" + task.template
                        + " arm="
                        + arm.name
                        + " good="
                        + (good.passed as string)
                        + " bad="
                        + (bad.passed as string));
                    process.exit(1);
                }
                results.push(object_val(["template", "arm", "known_good_passed", "known_bad_passed", "known_bad_category", "expected_gap"], [string_val(task.template), string_val(arm.name), bool_val(good.passed), bool_val(bad.passed), string_val(bad.category), bool_val(expected_gap)]));
                ai += 1;
            }
        }
        ti += 1;
    }
    fs.writeFile(root + "/results.json", stringify_pretty(array_val(results), 2));
    print("offline known-good/known-bad grader verification completed; declared gaps are recorded in results.json");
}

fn _explicit_failure_category(feedback: string) -> string {
    let categories = ["pretrained_syntax_library_interference", "rule_absent_from_materials", "rule_present_not_applied", "invented_syntax_or_api", "correct_program_rejected", "check_build_run_divergence", "compiler_crash_hang_or_ice", "unhelpful_diagnostic_or_failed_repair", "missing_or_excessively_awkward_primitive", "ordinary_semantic_or_test_failure", "capability_false_friction", "provider_or_setup_invalidation"];
    let mut i: int = 0;
    loop {
        if i >= categories.length { break; }
        if contains(feedback, "[attribution:" + categories[i] + "]") {
            return categories[i];
        }
        i += 1;
    }
    return "";
}

fn _track_b_attribution(primary: string) -> string {
    if primary == "provider_or_setup_invalidation" { return "run_invalidation"; }
    if primary == "rule_absent_from_materials" { return "packet_defect"; }
    if primary == "correct_program_rejected" || primary == "check_build_run_divergence"
        || primary == "compiler_crash_hang_or_ice"
        || primary == "unhelpful_diagnostic_or_failed_repair" {
        return "implementation_defect";
    }
    return "intrinsic_failure";
}

// Sailfin ICE / compiler-panic markers. `internal compiler error (ICE):` is a
// grep-stable contract emitted by compiler/src/ice.sfn for both driver panics
// and backend (clang / llvm-link) failures on compiler-emitted IR (SFN-34), so
// it is the primary signal that a failure the grader captured is compiler-owned
// rather than a defect in the generated program.
fn _has_compiler_ice_marker(text: string) -> boolean {
    return contains(text, "internal compiler error") || contains(text, "the compiler unexpectedly panicked");
}

// Non-ICE compiler-owned backend / lowering / IR / link failures on
// compiler-emitted artifacts. These are the SFN-372 v2.6 signatures that leaked
// past `check` and only failed at build/run: invalid LLVM IR, unresolved callee
// signatures, ABI primitive mismatch, and a missing `_main` after malformed
// source was wrongly accepted. Reaching the run phase means `check` already
// passed, so any of these markers there is a check-green/build-red divergence.
fn _has_compiler_backend_marker(text: string) -> boolean {
    return contains(text, "a backend failure on compiler-emitted IR")
        || contains(text, "backend clang failed")
        || contains(text, "backend clang link failed")
        || contains(text, "backend llvm-link failed")
        || contains(text, "LLVM ERROR")
        || contains(text, "invalid LLVM IR")
        || contains(text, "unresolved call")
        || contains(text, "unresolved callee")
        || contains(text, "ABI primitive mismatch")
        || contains(text, "undefined reference to `_main'")
        || contains(text, "undefined symbol: _main")
        || contains(text, "Undefined symbols");
}

fn _classify_failure(cfg: Config, task: Task, grade_category: string, feedback: string, iteration: int) -> FailureAttribution {
    let explicit = _explicit_failure_category(feedback);
    // Only the compile (`check`) and run (`sfn run`) phases put captured
    // toolchain stdout/stderr into `feedback`; `wrong_output`, `instability`,
    // etc. carry the model program's own output, where a marker substring would
    // be a false positive. Restrict the compiler-owned scan to those two phases.
    let toolchain_phase = grade_category == "compile_error" || grade_category == "runtime_error";
    let ice = toolchain_phase && _has_compiler_ice_marker(feedback);
    let backend = toolchain_phase && _has_compiler_backend_marker(feedback);
    // Only the run phase is reached after `check` returns 0, so a compiler-owned
    // marker here is a check-green/build-red divergence; a compile-phase marker
    // is the compiler crashing during `check` itself.
    let run_phase = grade_category == "runtime_error";
    let mut primary = explicit;
    let mut divergence = false;
    if primary.length == 0 {
        if ice {
            // An ICE marker is compiler-owned regardless of phase and can never
            // be an ordinary semantic/test failure (SFN-387 acceptance).
            primary = "compiler_crash_hang_or_ice";
            divergence = run_phase;
        } else if backend {
            if run_phase { primary = "check_build_run_divergence"; } else {
                primary = "compiler_crash_hang_or_ice";
            }
        } else if grade_category == "provider_error" || grade_category == "scaffold_error" {
            primary = "provider_or_setup_invalidation";
        } else if grade_category == "effect_error" || grade_category == "trap_not_rejected" {
            primary = "capability_false_friction";
        } else if grade_category == "timeout" {
            primary = "compiler_crash_hang_or_ice";
        } else if grade_category == "compile_error" {
            primary = "invented_syntax_or_api";
        } else if grade_category == "primitive_unavailable" {
            primary = "missing_or_excessively_awkward_primitive";
        } else { primary = "ordinary_semantic_or_test_failure"; }
    }
    let mut secondary: string[] = [];
    if divergence { secondary.push("check_build_run_divergence"); }
    if iteration > 1 && primary != "unhelpful_diagnostic_or_failed_repair" {
        secondary.push("unhelpful_diagnostic_or_failed_repair");
    }
    let track_b = _track_b_attribution(primary);
    let mut denominator = primary != "provider_or_setup_invalidation";
    if cfg.track == "b" && (track_b == "packet_defect" || track_b == "implementation_defect") {
        denominator = false;
    }
    return FailureAttribution {
        primary: primary,
        secondary: secondary,
        track_b_attribution: track_b,
        language_denominator: denominator,
        // A marker-detected compiler-owned failure is auto-attributed with
        // confidence, so it no longer needs a human tiebreak; only the ambiguous
        // uncategorized grader buckets do.
        manual_review: explicit.length == 0 && !ice && !backend && (grade_category == "compile_error"
            || grade_category == "runtime_error"
            || grade_category == "wrong_output")
    };
}

fn _success_attribution() -> FailureAttribution {
    return FailureAttribution {
        primary: "",
        secondary: [],
        track_b_attribution: "not_applicable",
        language_denominator: true,
        manual_review: false
    };
}

fn _self_test_failure_taxonomy() ![io] {
    let categories = ["pretrained_syntax_library_interference", "rule_absent_from_materials", "rule_present_not_applied", "invented_syntax_or_api", "correct_program_rejected", "check_build_run_divergence", "compiler_crash_hang_or_ice", "unhelpful_diagnostic_or_failed_repair", "missing_or_excessively_awkward_primitive", "ordinary_semantic_or_test_failure", "capability_false_friction", "provider_or_setup_invalidation"];
    let task = _logic_task();
    let mut cfg = _default_config();
    cfg.track = "b";
    let mut i: int = 0;
    loop {
        if i >= categories.length { break; }
        let got = _classify_failure(cfg, task, "fixture", "[attribution:"
            + categories[i]
            + "]", 1);
        if got.primary != categories[i] {
            print.err("failure taxonomy fixture did not classify " + categories[i]);
            process.exit(1);
        }
        i += 1;
    }
    let setup = _classify_failure(cfg, task, "provider_error", "fixture", 1);
    let defect = _classify_failure(cfg, task, "fixture", "[attribution:correct_program_rejected]", 1);
    cfg.track = "a";
    let adoption = _classify_failure(cfg, task, "fixture", "[attribution:correct_program_rejected]", 1);
    if setup.language_denominator || defect.language_denominator || defect.track_b_attribution != "implementation_defect"
        || !adoption.language_denominator {
        print.err("failure taxonomy denominator policy fixtures failed");
        process.exit(1);
    }
    print("failure taxonomy and denominator policy fixtures passed");
}

// The frozen SFN-372 v2.6 classification signatures. Each `feedback` is a
// representative captured grader stdout/stderr for one of the exact v2.6
// artifact classes (SFN-387 context / PR #2395). The compiler-owned entries
// were exported as `ordinary_semantic_or_test_failure` / `invented_syntax_or_api`
// in v2.6; the controls (ordinary runtime error, generated-program timeout,
// wrong output) must stay unchanged so the classifier does not over-attribute.
fn _string_array_contains(values: string[], needle: string) -> boolean {
    let mut i: int = 0;
    loop {
        if i >= values.length { break; }
        if values[i] == needle { return true; }
        i += 1;
    }
    return false;
}

fn _sfn372_signatures() -> ClassificationSignature[] {
    return [ClassificationSignature {
        name: "backend_clang_link_ice", grader_category: "runtime_error", feedback: "case 0 crashed: error: internal compiler error (ICE): backend clang failed (exit 1)\nnote: a backend failure on compiler-emitted IR usually means a compiler bug (not an error in your code)\nnote: failing IR: build/sailfin/program.ll", iteration: 1, expected_primary: "compiler_crash_hang_or_ice", expected_secondary: "check_build_run_divergence", expected_track_b: "implementation_defect", compiler_owned: true, recorded_primary: "ordinary_semantic_or_test_failure", provenance: "SFN-372 v2.6 / PR #2395: internal compiler error (ICE): backend clang link failed"
    }, ClassificationSignature {
        name: "lowerer_fatal_during_check", grader_category: "compile_error", feedback: "error: internal compiler error (ICE): lowering encountered an unsupported construct\nnote: the compiler unexpectedly panicked — this is a bug\nnote: stage: lowering", iteration: 1, expected_primary: "compiler_crash_hang_or_ice", expected_secondary: "", expected_track_b: "implementation_defect", compiler_owned: true, recorded_primary: "invented_syntax_or_api", provenance: "SFN-372 v2.6 / PR #2395: lowerer fatal"
    }, ClassificationSignature {
        name: "invalid_ir_check_green_build_red", grader_category: "runtime_error", feedback: "case 0 crashed: LLVM ERROR: Invalid bitcast\nerror: invalid LLVM IR: 'double' used where a pointer was expected after unresolved call signature", iteration: 1, expected_primary: "check_build_run_divergence", expected_secondary: "", expected_track_b: "implementation_defect", compiler_owned: true, recorded_primary: "ordinary_semantic_or_test_failure", provenance: "SFN-372 v2.6 / PR #2395: invalid LLVM IR / unresolved callee signature after check passed"
    }, ClassificationSignature {
        name: "ordinary_runtime_error_control", grader_category: "runtime_error", feedback: "case 0 crashed: panic: index out of range: 5 >= 3", iteration: 1, expected_primary: "ordinary_semantic_or_test_failure", expected_secondary: "", expected_track_b: "intrinsic_failure", compiler_owned: false, recorded_primary: "ordinary_semantic_or_test_failure", provenance: "control: ordinary generated-program runtime failure must not be reclassified"
    }, ClassificationSignature {
        name: "generated_program_timeout_control", grader_category: "timeout", feedback: "case 0 execution deadline expired", iteration: 1, expected_primary: "compiler_crash_hang_or_ice", expected_secondary: "", expected_track_b: "implementation_defect", compiler_owned: false, recorded_primary: "compiler_crash_hang_or_ice", provenance: "control: existing timeout attribution is unchanged by SFN-387"
    }, ClassificationSignature {
        name: "wrong_output_control", grader_category: "wrong_output", feedback: "case 0 wrong: got 7 want 12", iteration: 1, expected_primary: "ordinary_semantic_or_test_failure", expected_secondary: "", expected_track_b: "intrinsic_failure", compiler_owned: false, recorded_primary: "ordinary_semantic_or_test_failure", provenance: "control: ordinary wrong-output must not be reclassified"
    }, ClassificationSignature {
        name: "marker_in_program_output_control", grader_category: "wrong_output", feedback: "case 0 wrong: got LLVM ERROR: not really — printed by the program want ok", iteration: 1, expected_primary: "ordinary_semantic_or_test_failure", expected_secondary: "", expected_track_b: "intrinsic_failure", compiler_owned: false, recorded_primary: "ordinary_semantic_or_test_failure", provenance: "control: a compiler-marker substring in the model program's own output must not be reclassified as compiler-owned (wrong_output means the toolchain succeeded)"
    }];
}

fn _self_test_compiler_owned_classification() ![io] {
    let task = _logic_task();
    let mut cfg = _default_config();
    cfg.track = "b";
    let sigs = _sfn372_signatures();
    let mut i: int = 0;
    loop {
        if i >= sigs.length { break; }
        let s = sigs[i];
        let got = _classify_failure(cfg, task, s.grader_category, s.feedback, s.iteration);
        if got.primary != s.expected_primary {
            print.err("compiler-owned classification fixture " + s.name
                + " expected primary "
                + s.expected_primary
                + " but got "
                + got.primary);
            process.exit(1);
        }
        if got.track_b_attribution != s.expected_track_b {
            print.err("compiler-owned classification fixture " + s.name
                + " expected track_b "
                + s.expected_track_b
                + " but got "
                + got.track_b_attribution);
            process.exit(1);
        }
        if s.expected_secondary.length > 0 && !_string_array_contains(got.secondary, s.expected_secondary) {
            print.err("compiler-owned classification fixture " + s.name
                + " expected secondary to contain "
                + s.expected_secondary);
            process.exit(1);
        }
        // SFN-387 acceptance: an ICE marker can never yield an ordinary failure.
        if s.compiler_owned && got.primary == "ordinary_semantic_or_test_failure" {
            print.err("compiler-owned classification fixture " + s.name
                + " must not be ordinary_semantic_or_test_failure");
            process.exit(1);
        }
        // Track A must still expose the user's failed outcome even when Track B
        // attributes the failure to the compiler.
        let adoption = _classify_failure(_default_config(), task, s.grader_category, s.feedback, s.iteration);
        if !adoption.language_denominator {
            print.err("compiler-owned classification fixture " + s.name
                + " dropped the Track A adoption denominator");
            process.exit(1);
        }
        i += 1;
    }
    print("compiler-owned classification fixtures passed");
}

fn _write_iteration_attribution(path: string, iteration: int, category: string, attribution: FailureAttribution) ![io] {
    fs.writeFile(path, stringify_pretty(object_val(["iteration", "grader_category", "primary", "secondary", "track_b_attribution", "language_denominator", "manual_review"], [number_val(iteration as float), string_val(category), string_val(attribution.primary), _string_array_json(attribution.secondary), string_val(attribution.track_b_attribution), bool_val(attribution.language_denominator), bool_val(attribution.manual_review)]), 2));
}

fn _record(task: Task, arm: string, cfg: Config, attempt_id: string, repeat: int, passed: boolean, iters: int, input_tokens: int, output_tokens: int, elapsed_ms: int, source_chars: int, diff_chars: int, cats: string[], attribution: FailureAttribution, treatment: string) -> Record {
    return Record {
        attempt_id: attempt_id,
        task: task.id,
        template: task.template,
        category: task.category,
        kind: task.kind,
        arm: arm,
        model_family: cfg.model_family,
        track: cfg.track,
        repeat: repeat,
        passed: passed,
        iterations: iters,
        tokens: input_tokens + output_tokens,
        input_tokens: input_tokens,
        output_tokens: output_tokens,
        elapsed_ms: elapsed_ms,
        source_chars: source_chars,
        diff_chars: diff_chars,
        human_interventions: 0,
        fail_categories: cats,
        primary_failure: attribution.primary,
        secondary_failures: attribution.secondary,
        track_b_attribution: attribution.track_b_attribution,
        language_denominator: passed || attribution.language_denominator,
        ablation: cfg.ablation,
        ablation_treatment: treatment
    };
}

fn _grade_with_ablation(task: Task, arm: ArmConfig, cfg: Config, treatment: string, source: string, workdir: string, iteration: int) -> GradeResult ![clock, io] {
    if cfg.ablation == "primitive" && treatment == "local" {
        let forbidden = arm.name == "rill-17"? "span(": "substring(";
        if contains(source, forbidden) {
            return GradeResult {
                passed: false,
                feedback: "the local-primitive condition forbids " + forbidden
                    + "; use local_slice from the supplied supplement [attribution:rule_present_not_applied]",
                category: "primitive_unavailable"
            };
        }
    }
    return _grade(task, arm, workdir, iteration);
}

fn _repair_feedback(cfg: Config, treatment: string, result: GradeResult) -> string {
    if cfg.ablation == "diagnostics" && treatment == "minimal" {
        return "grading failed; phase=" + result.category;
    }
    return result.feedback;
}

fn _run_task_arm(task: Task, task_index: int, arm: ArmConfig, cfg: Config, run_dir: string, attempt_id: string, repeat: int) -> Record ![clock, io] {
    let started = monotonic_millis();
    let wd = run_dir + "/attempts/" + attempt_id;
    _mkdir(wd);
    _write_fixtures(task, wd);
    let workfile = wd + "/" + arm.entry;
    let system = _system_prompt();
    let treatment = _ablation_treatment(cfg, task_index, repeat);
    let user = _build_user(task, arm, cfg, treatment);
    fs.writeFile(wd + "/system.txt", system);
    fs.writeFile(wd + "/user.txt", user);
    let mut messages: JsonValue[] = [object_val(["role", "content"], [string_val("user"), string_val(user)])];
    let mut input_tokens = 0;
    let mut output_tokens = 0;
    let mut source_chars = 0;
    let mut diff_chars = 0;
    let mut cats: string[] = [];
    let mut attribution = _success_attribution();
    let mut i: int = 0;
    loop {
        if i >= cfg.max_iters { break; }
        let iteration = i + 1;
        let completion = _complete(cfg, task, arm.name, system, messages, wd, iteration);
        input_tokens += completion.input_tokens;
        output_tokens += completion.output_tokens;
        fs.writeFile(wd + "/completion-" + (iteration as string) + ".txt", completion.text);
        if completion.error.length > 0 {
            let classification = _provider_failure_class(completion.error);
            cats.push("provider_error");
            cats.push("provider_" + classification);
            fs.writeFile(wd + "/provider.error", completion.error);
            fs.writeFile(wd + "/provider-failure.json", stringify_pretty(object_val(["classification", "setup_class", "iteration", "provider_attempts", "error"], [string_val(classification), bool_val(_is_setup_failure_class(classification)), number_val(iteration as float), number_val(completion.provider_attempts as float), string_val(completion.error)]), 2));
            attribution = _classify_failure(cfg, task, "provider_error", completion.error, iteration);
            _write_iteration_attribution(wd + "/classification-" + (iteration as string)
                + ".json", iteration, "provider_error", attribution);
            return _record(task, arm.name, cfg, attempt_id, repeat, false, i + 1, input_tokens, output_tokens, (monotonic_millis() - started) as int, source_chars, diff_chars, cats, attribution, treatment);
        }
        let source = _extract_code(completion.text);
        source_chars = source.length;
        let starter_chars = _starter_for(task, arm.name).length;
        diff_chars = source_chars >= starter_chars? source_chars - starter_chars: starter_chars - source_chars;
        fs.writeFile(workfile, source);
        fs.writeFile(wd + "/source-" + (iteration as string) + ".txt", source);
        let res = _grade_with_ablation(task, arm, cfg, treatment, source, wd, iteration);
        if res.category.length > 0 { cats.push(res.category); }
        if res.passed {
            return _record(task, arm.name, cfg, attempt_id, repeat, true, i + 1, input_tokens, output_tokens, (monotonic_millis() - started) as int, source_chars, diff_chars, cats, attribution, treatment);
        }
        attribution = _classify_failure(cfg, task, res.category, res.feedback, iteration);
        _write_iteration_attribution(wd + "/classification-" + (iteration as string)
            + ".json", iteration, res.category, attribution);
        messages.push(object_val(["role", "content"], [string_val("assistant"), string_val(completion.text)]));
        messages.push(object_val(["role", "content"], [string_val("user"), string_val("That failed grading:\n"
            + _repair_feedback(cfg, treatment, res)
            + "\nReturn the full corrected "
            + arm.entry
            + " in one code block.")]));
        i += 1;
    }
    return _record(task, arm.name, cfg, attempt_id, repeat, false, cfg.max_iters, input_tokens, output_tokens, (monotonic_millis() - started) as int, source_chars, diff_chars, cats, attribution, treatment);
}

fn _record_json(r: Record) -> JsonValue {
    let mut cats: JsonValue[] = [];
    let mut i: int = 0;
    loop {
        if i >= r.fail_categories.length { break; }
        cats.push(string_val(r.fail_categories[i]));
        i += 1;
    }
    return object_val(["attempt_id", "task", "template", "category", "kind", "arm", "model_family", "track", "repeat", "passed", "iterations", "tokens", "input_tokens", "output_tokens", "elapsed_ms", "source_chars", "diff_chars", "human_interventions", "fail_categories", "primary_failure", "secondary_failures", "track_b_attribution", "language_denominator", "ablation", "ablation_treatment"], [string_val(r.attempt_id), string_val(r.task), string_val(r.template), string_val(r.category), string_val(r.kind), string_val(r.arm), string_val(r.model_family), string_val(r.track), number_val(r.repeat as float), bool_val(r.passed), number_val(r.iterations as float), number_val(r.tokens as float), number_val(r.input_tokens as float), number_val(r.output_tokens as float), number_val(r.elapsed_ms as float), number_val(r.source_chars as float), number_val(r.diff_chars as float), number_val(r.human_interventions as float), array_val(cats), string_val(r.primary_failure), _string_array_json(r.secondary_failures), string_val(r.track_b_attribution), bool_val(r.language_denominator), string_val(r.ablation), string_val(r.ablation_treatment)]);
}

fn _pct(n: int, d: int) -> float {
    if d == 0 { return 0.0; }
    return ((1000 * n / d) as float) / 10.0;
}

fn _has_category(r: Record, category: string) -> boolean {
    return _contains_value(r.fail_categories, category);
}

// A provider-response invalidation stops the paid batch immediately (PROTOCOL-V2
// section 6): provider authorization/setup failures and unfrozen model responses.
// The Anthropic thinking-only max_tokens exhaustion (SFN-367) is the latter.
fn _batch_invalidation_reason(r: Record) -> string {
    if _has_category(r, "provider_auth_permission") { return "auth_permission"; }
    if _has_category(r, "provider_quota_billing") { return "quota_billing"; }
    if _has_category(r, "provider_transport_transient") {
        return "transport_retry_exhausted";
    }
    if _has_category(r, "provider_response_budget_exhausted") {
        return "response_budget_exhausted";
    }
    return "";
}

fn _run_batch_invalidation_reason(records: Record[]) -> string {
    let mut i: int = 0;
    loop {
        if i >= records.length { break; }
        let classification = _batch_invalidation_reason(records[i]);
        if classification.length > 0 { return classification; }
        i += 1;
    }
    return "";
}

fn _self_test_response_invalidation() ![io] {
    let thinking_only = _completion_from_anthropic("{\"content\":[{\"type\":\"thinking\",\"thinking\":\"reasoning without ever emitting an answer\"}],\"stop_reason\":\"max_tokens\",\"usage\":{\"input_tokens\":120,\"output_tokens\":8192}}");
    let partial_text = _completion_from_anthropic("{\"content\":[{\"type\":\"text\",\"text\":\"partial\"}],\"stop_reason\":\"max_tokens\",\"usage\":{\"input_tokens\":120,\"output_tokens\":8192}}");
    let generic_empty = _completion_from_anthropic("{\"content\":[],\"usage\":{\"input_tokens\":7,\"output_tokens\":0}}");
    if thinking_only.text.length != 0 || thinking_only.error.length == 0
        || _provider_failure_class(thinking_only.error) != "response_budget_exhausted"
        || partial_text.text != "partial"
        || partial_text.error.length != 0
        || _provider_failure_class(generic_empty.error) != "model_response" {
        print.err("anthropic thinking-only max_tokens fixtures failed");
        process.exit(1);
    }
    let task = _logic_task();
    let mut cfg = _default_config();
    cfg.track = "a";
    let attribution_a = _classify_failure(cfg, task, "provider_error", thinking_only.error, 1);
    cfg.track = "b";
    let attribution_b = _classify_failure(cfg, task, "provider_error", thinking_only.error, 1);
    if attribution_a.language_denominator || attribution_b.language_denominator
        || attribution_a.primary != "provider_or_setup_invalidation" {
        print.err("thinking-only response must be excluded from both language denominators");
        process.exit(1);
    }
    let cats = ["provider_error", "provider_" + _provider_failure_class(thinking_only.error)];
    let rec = _record(task, "sailfin", cfg, "selftest-thinking", 1, false, 1, thinking_only.input_tokens, thinking_only.output_tokens, 0, 0, 0, cats, attribution_b, "primary");
    if _batch_invalidation_reason(rec) != "response_budget_exhausted"
        || _run_batch_invalidation_reason([rec]) != "response_budget_exhausted"
        || rec.language_denominator {
        print.err("thinking-only response must stop the paid batch as a provider-response invalidation");
        process.exit(1);
    }
    print("anthropic thinking-only response invalidation fixtures passed");
}

fn _is_trap(task_id: string, tasks: Task[]) -> boolean {
    let mut i: int = 0;
    loop {
        if i >= tasks.length { break; }
        if tasks[i].id == task_id { return tasks[i].kind == "trap"; }
        i += 1;
    }
    return false;
}

fn _is_confirmatory(task_id: string, tasks: Task[]) -> boolean {
    let mut i: int = 0;
    loop {
        if i >= tasks.length { break; }
        if tasks[i].id == task_id { return tasks[i].confirmatory; }
        i += 1;
    }
    return false;
}

fn _track_b_instance_valid(record: Record, records: Record[]) -> boolean {
    if record.track != "b" { return true; }
    let mut i: int = 0;
    loop {
        if i >= records.length { break; }
        let other = records[i];
        if other.task == record.task && other.model_family == record.model_family
            && other.repeat == record.repeat
            && (other.track_b_attribution == "packet_defect"
            || other.track_b_attribution == "implementation_defect") {
            return false;
        }
        i += 1;
    }
    return true;
}

fn _summary_for_arm(arm: string, records: Record[], tasks: Task[]) -> JsonValue {
    let mut scored = 0;
    let mut solved = 0;
    let mut one_shot = 0;
    let mut iter_sum = 0;
    let mut token_sum = 0;
    let mut input_token_sum = 0;
    let mut output_token_sum = 0;
    let mut elapsed_sum = 0;
    let mut source_char_sum = 0;
    let mut false_friction = 0;
    let mut traps = 0;
    let mut trap_fired = 0;
    let mut i: int = 0;
    loop {
        if i >= records.length { break; }
        let r = records[i];
        if r.arm == arm && _is_confirmatory(r.task, tasks) {
            let trap = _is_trap(r.task, tasks);
            if trap {
                traps += 1;
                if _has_category(r, "effect_error") { trap_fired += 1; }
            } else if r.language_denominator && _track_b_instance_valid(r, records) {
                scored += 1;
                if r.passed {
                    solved += 1;
                    if r.iterations == 1 { one_shot += 1; }
                    iter_sum += r.iterations;
                    token_sum += r.tokens;
                    input_token_sum += r.input_tokens;
                    output_token_sum += r.output_tokens;
                    elapsed_sum += r.elapsed_ms;
                    source_char_sum += r.source_chars;
                }
                if r.primary_failure == "capability_false_friction" {
                    false_friction += 1;
                }
            }
        }
        i += 1;
    }
    let mean_iters = solved == 0? 0.0: (iter_sum as float) / (solved as float);
    let mean_tokens = solved == 0? 0.0: (token_sum as float) / (solved as float);
    let mean_input_tokens = solved == 0? 0.0: (input_token_sum as float) / (solved as float);
    let mean_output_tokens = solved == 0? 0.0: (output_token_sum as float) / (solved as float);
    let mean_elapsed_ms = solved == 0? 0.0: (elapsed_sum as float) / (solved as float);
    let mean_source_chars = solved == 0? 0.0: (source_char_sum as float) / (solved as float);
    return object_val(["tasks_scored", "one_shot_success_pct", "solve_rate_pct", "mean_iters_to_green", "mean_tokens_to_green", "mean_input_tokens_to_green", "mean_output_tokens_to_green", "mean_elapsed_ms_to_green", "mean_source_chars_to_green", "false_friction_tasks", "trap_tasks", "traps_effect_system_fired"], [number_val(scored as float), number_val(_pct(one_shot, scored)), number_val(_pct(solved, scored)), number_val(mean_iters), number_val(mean_tokens), number_val(mean_input_tokens), number_val(mean_output_tokens), number_val(mean_elapsed_ms), number_val(mean_source_chars), number_val(false_friction as float), number_val(traps as float), number_val(trap_fired as float)]);
}

fn _summary(records: Record[], tasks: Task[], arms: string[]) -> JsonValue {
    let mut keys: string[] = [];
    let mut vals: JsonValue[] = [];
    let mut i: int = 0;
    loop {
        if i >= arms.length { break; }
        keys.push(arms[i]);
        vals.push(_summary_for_arm(arms[i], records, tasks));
        i += 1;
    }
    return object_val(["by_arm", "notes"], [object_val(keys, vals), array_val([string_val("one_shot_success_pct and solve_rate_pct exclude trap tasks."), string_val("false_friction_tasks counts non-trap tasks where an effect/capability compile error appeared at least once."), string_val("traps_effect_system_fired counts trap tasks where an effect/capability compile error appeared.")])]);
}

fn _ablation_cell(arm: string, treatment: string, records: Record[], tasks: Task[]) -> JsonValue {
    let mut observations = 0;
    let mut solved = 0;
    let mut one_shot = 0;
    let mut iteration_sum = 0;
    let mut i: int = 0;
    loop {
        if i >= records.length { break; }
        let r = records[i];
        if r.arm == arm && r.ablation_treatment == treatment && r.language_denominator
            && _track_b_instance_valid(r, records)
            && _is_confirmatory(r.task, tasks)
            && !_is_trap(r.task, tasks) {
            observations += 1;
            if r.passed {
                solved += 1;
                if r.iterations == 1 { one_shot += 1; }
                iteration_sum += r.iterations;
            } else { iteration_sum += 6; }
        }
        i += 1;
    }
    let mean_iterations = observations == 0? 0.0: (iteration_sum as float) / (observations as float);
    return object_val(["observations", "one_shot_success_pct", "solve_rate_pct", "mean_iterations_failures_assigned_6"], [number_val(observations as float), number_val(_pct(one_shot, observations)), number_val(_pct(solved, observations)), number_val(mean_iterations)]);
}

fn _ablation_summary(cfg: Config, records: Record[], tasks: Task[], arms: string[]) -> JsonValue {
    let mut treatments = ["primary", "primary"];
    if cfg.ablation == "examples" { treatments = ["concise", "expanded"]; }
    if cfg.ablation == "diagnostics" { treatments = ["full", "minimal"]; }
    if cfg.ablation == "primitive" { treatments = ["available", "local"]; }
    let mut arm_keys: string[] = [];
    let mut arm_values: JsonValue[] = [];
    let mut ai: int = 0;
    loop {
        if ai >= arms.length { break; }
        arm_keys.push(arms[ai]);
        arm_values.push(object_val(treatments, [_ablation_cell(arms[ai], treatments[0], records, tasks), _ablation_cell(arms[ai], treatments[1], records, tasks)]));
        ai += 1;
    }
    return object_val(["dimension", "treatments", "by_arm", "primary_pool_eligible"], [string_val(cfg.ablation), _string_array_json(treatments), object_val(arm_keys, arm_values), bool_val(cfg.ablation == "primary")]);
}

fn _matching_record_index(records: Record[], task: string, arm: string, model_family: string, repeat: int) -> int {
    let mut i: int = 0;
    loop {
        if i >= records.length { break; }
        let r = records[i];
        if r.task == task && r.arm == arm && r.model_family == model_family && r.repeat == repeat {
            return i;
        }
        i += 1;
    }
    return -1;
}

fn _pair_metric_index(metrics: PairMetric[], task: string) -> int {
    let mut i: int = 0;
    loop {
        if i >= metrics.length { break; }
        if metrics[i].task == task { return i; }
        i += 1;
    }
    return -1;
}

fn _paired_metrics(primary: string, baseline: string, records: Record[], tasks: Task[]) -> PairMetric[] {
    let mut out: PairMetric[] = [];
    let mut i: int = 0;
    loop {
        if i >= records.length { break; }
        let sail = records[i];
        if sail.arm == primary && _is_confirmatory(sail.task, tasks) && !_is_trap(sail.task, tasks) {
            let bi = _matching_record_index(records, sail.task, baseline, sail.model_family, sail.repeat);
            if bi >= 0 {
                let base = records[bi];
                if !sail.language_denominator || !base.language_denominator || !_track_b_instance_valid(sail, records) {
                    i += 1;
                    continue;
                }
                let sail_one = sail.passed && sail.iterations == 1? 1.0: 0.0;
                let base_one = base.passed && base.iterations == 1? 1.0: 0.0;
                let mi = _pair_metric_index(out, sail.task);
                if mi < 0 {
                    out.push(PairMetric {
                        task: sail.task, one_shot_advantage: sail_one - base_one, iterations_advantage: (base.iterations - sail.iterations) as float, observations: 1
                    });
                } else {
                    let mut metric = out[mi];
                    metric.one_shot_advantage += sail_one - base_one;
                    metric.iterations_advantage += (base.iterations - sail.iterations) as float;
                    metric.observations += 1;
                    out[mi] = metric;
                }
            }
        }
        i += 1;
    }
    i = 0;
    loop {
        if i >= out.length { break; }
        let mut metric2 = out[i];
        metric2.one_shot_advantage = metric2.one_shot_advantage / (metric2.observations as float);
        metric2.iterations_advantage = metric2.iterations_advantage / (metric2.observations as float);
        out[i] = metric2;
        i += 1;
    }
    return out;
}

fn _metric_value(metric: PairMetric, field: string) -> float {
    if field == "one_shot" { return metric.one_shot_advantage; }
    return metric.iterations_advantage;
}

fn _sort_floats(values: float[]) -> float[] {
    let mut out = values;
    let mut i: int = 1;
    loop {
        if i >= out.length { break; }
        let key = out[i];
        let mut j = i - 1;
        loop {
            if j < 0 || out[j] <= key { break; }
            out[j + 1] = out[j];
            j -= 1;
        }
        out[j + 1] = key;
        i += 1;
    }
    return out;
}

fn _lcg_next(state: int) -> int {
    let next = (state * 1103515245 + 12345) % 2147483647;
    if next < 0 { return 0 - next; }
    return next;
}

fn _bootstrap_interval(metrics: PairMetric[], field: string, seed: int) -> Interval {
    if metrics.length == 0 {
        return Interval { estimate: 0.0, low: 0.0, high: 0.0 };
    }
    let mut estimate = 0.0;
    let mut i: int = 0;
    loop {
        if i >= metrics.length { break; }
        estimate += _metric_value(metrics[i], field);
        i += 1;
    }
    estimate = estimate / (metrics.length as float);

    let mut samples: float[] = [];
    let mut state = seed;
    let mut b: int = 0;
    loop {
        if b >= 2000 { break; }
        let mut total = 0.0;
        let mut n: int = 0;
        loop {
            if n >= metrics.length { break; }
            state = _lcg_next(state);
            let index = state % metrics.length;
            total += _metric_value(metrics[index], field);
            n += 1;
        }
        samples.push(total / (metrics.length as float));
        b += 1;
    }
    samples = _sort_floats(samples);
    return Interval {
        estimate: estimate,
        low: samples[49],
        high: samples[1949]
    };
}

fn _paired_observations(metrics: PairMetric[]) -> int {
    let mut total = 0;
    let mut i: int = 0;
    loop {
        if i >= metrics.length { break; }
        total += metrics[i].observations;
        i += 1;
    }
    return total;
}

fn _interval_json(value: Interval, scale: float) -> JsonValue {
    return object_val(["estimate", "low", "high"], [number_val(value.estimate * scale), number_val(value.low * scale), number_val(value.high * scale)]);
}

fn _analysis_for_baseline(primary: string, baseline: string, records: Record[], tasks: Task[], seed: int) -> JsonValue {
    let metrics = _paired_metrics(primary, baseline, records, tasks);
    let observations = _paired_observations(metrics);
    let one_shot = _bootstrap_interval(metrics, "one_shot", seed);
    let iterations = _bootstrap_interval(metrics, "iterations", seed + 17);
    return object_val(["paired_ordinary_observations", "task_clusters", "minimum_100_met", "one_shot_advantage_percentage_points_95ci", "iterations_to_green_advantage_95ci"], [number_val(observations as float), number_val(metrics.length as float), bool_val(observations >= 100), _interval_json(one_shot, 100.0), _interval_json(iterations, 1.0)]);
}

fn _analysis(records: Record[], tasks: Task[], arms: string[], seed: int, run_valid: boolean, invalid_reason: string, primary_pool_eligible: boolean) -> JsonValue {
    let mut keys: string[] = [];
    let mut values: JsonValue[] = [];
    let mut authorized = true;
    let mut baselines = 0;
    let primary = _contains_value(arms, "sailfin-b")? "sailfin-b": "sailfin";
    let mut i: int = 0;
    loop {
        if i >= arms.length { break; }
        if arms[i] != primary {
            let metrics = _paired_metrics(primary, arms[i], records, tasks);
            let observations = _paired_observations(metrics);
            if observations < 100 { authorized = false; }
            keys.push(arms[i]);
            values.push(_analysis_for_baseline(primary, arms[i], records, tasks, seed
                + i * 101));
            baselines += 1;
        }
        i += 1;
    }
    if baselines == 0 { authorized = false; }
    if !run_valid { authorized = false; }
    if !primary_pool_eligible { authorized = false; }
    return object_val(["decision_authorized", "run_valid", "invalid_reason", "primary_pool_eligible", "by_baseline", "notes"], [bool_val(authorized), bool_val(run_valid), string_val(invalid_reason), bool_val(primary_pool_eligible), object_val(keys, values), array_val([string_val("Intervals resample frozen task instances, preserving repeat clusters."), string_val("Positive advantages favor Sailfin. No GO/NO interpretation is performed by the runner."), string_val("Provider failures remain attempted observations and are never dropped from the corpus."), string_val("Setup-class provider failures invalidate GO/NO interpretation and stop additional paid observations."), string_val("Ablation runs are secondary analyses and cannot authorize the primary Track B decision.")])]);
}

fn _self_test_analysis() ![io] {
    let fixture = [PairMetric {
        task: "fixture-a", one_shot_advantage: 0.25, iterations_advantage: 1.0, observations: 5
    }, PairMetric {
        task: "fixture-b", one_shot_advantage: 0.25, iterations_advantage: 1.0, observations: 5
    }];
    let one = _bootstrap_interval(fixture, "one_shot", 350);
    let iterations = _bootstrap_interval(fixture, "iterations", 367);
    if one.low < 0.249 || one.high > 0.251 || iterations.low < 0.999
        || iterations.high > 1.001 {
        print.err("deterministic paired-bootstrap fixture failed");
        process.exit(1);
    }
    print("deterministic paired-bootstrap fixture passed");
}

fn _all_task_ids(tasks: Task[]) -> string[] {
    let mut out: string[] = [];
    let mut i: int = 0;
    loop {
        if i >= tasks.length { break; }
        out.push(tasks[i].id);
        i += 1;
    }
    return out;
}

fn _all_arm_names(arms: ArmConfig[]) -> string[] {
    let mut out: string[] = [];
    let mut i: int = 0;
    loop {
        if i >= arms.length { break; }
        out.push(arms[i].name);
        i += 1;
    }
    return out;
}

fn _task_exists(tasks: Task[], id: string) -> boolean {
    let mut i: int = 0;
    loop {
        if i >= tasks.length { break; }
        if tasks[i].id == id { return true; }
        i += 1;
    }
    return false;
}

fn _arm_exists(arms: ArmConfig[], name: string) -> boolean {
    let mut i: int = 0;
    loop {
        if i >= arms.length { break; }
        if arms[i].name == name { return true; }
        i += 1;
    }
    return false;
}

fn _validate_selections(cfg: Config, tasks: Task[], arms: ArmConfig[]) ![io] {
    let mut ti: int = 0;
    loop {
        if ti >= cfg.tasks.length { break; }
        if !_task_exists(tasks, cfg.tasks[ti]) {
            print.err("unknown task: " + cfg.tasks[ti]);
            print.err("available tasks: " + join(_all_task_ids(tasks), ", "));
            process.exit(2);
        }
        ti += 1;
    }

    let mut ai: int = 0;
    loop {
        if ai >= cfg.arms.length { break; }
        if !_arm_exists(arms, cfg.arms[ai]) {
            print.err("unknown arm: " + cfg.arms[ai]);
            print.err("available arms: " + join(_all_arm_names(arms), ", "));
            process.exit(2);
        }
        ai += 1;
    }
}

fn _timestamp() -> string ![io] {
    let exit = process.run_capture(["date", "+%Y%m%d-%H%M%S"], process.environ());
    let out = trim(process.capture_take_stdout());
    let _err = process.capture_take_stderr();
    if exit == 0 && out.length > 0 { return out; }
    return monotonic_millis() as string;
}

fn _safe_id(value: string) -> string {
    let mut out = "";
    let mut i: int = 0;
    loop {
        if i >= value.length { break; }
        let code = char_code(value[i]);
        let allowed = (code >= 48 && code <= 57) || (code >= 65 && code <= 90)
            || (code >= 97
            && code <= 122)
            || value[i] == "-";
        if allowed { out = out + value[i]; } else { out = out + "-"; }
        i += 1;
    }
    return out;
}

fn _attempt_id(cfg: Config, task: Task, arm: string, repeat: int) -> string {
    return _safe_id(cfg.model_family) + "-s" + (cfg.seed as string) + "-" + task.id
        + "-"
        + arm
        + "-r"
        + (repeat as string);
}

fn _string_array_json(values: string[]) -> JsonValue {
    let mut out: JsonValue[] = [];
    let mut i: int = 0;
    loop {
        if i >= values.length { break; }
        out.push(string_val(values[i]));
        i += 1;
    }
    return array_val(out);
}

fn _command_version(args: string[]) -> string ![io] {
    let exit = process.run_capture(args, process.environ());
    let out = trim(process.capture_take_stdout());
    let err = trim(process.capture_take_stderr());
    if exit == 0 {
        return out.length > 0? out: err;
    }
    return "unavailable";
}

fn _repository_dirty() -> boolean ![io] {
    return _command_version(["git", "status", "--porcelain"]).length > 0;
}

fn _sha256_file(path: string) -> string ![io] {
    if !fs.exists(path) { return "missing"; }
    let exit = process.run_capture(["shasum", "-a", "256", path], process.environ());
    let out = trim(process.capture_take_stdout());
    let _err = process.capture_take_stderr();
    if exit != 0 || out.length < 64 { return "unavailable"; }
    return substring(out, 0, 64);
}

fn _sha256_text(text: string, scratch: string) -> string ![io] {
    fs.writeFile(scratch, text);
    let digest = _sha256_file(scratch);
    fs.deleteFile(scratch);
    return digest;
}

fn _hidden_fixture_text(task: Task) -> string {
    let mut out = "";
    let mut i: int = 0;
    loop {
        if i >= task.fixtures.length { break; }
        let fixture = task.fixtures[i];
        out = out + "fixture-name:" + fixture.name.length as string + ":"
            + fixture.name
            + "\nfixture-content:"
            + fixture.content.length as string
            + ":"
            + fixture.content
            + "\n";
        i += 1;
    }
    i = 0;
    loop {
        if i >= task.cases.length { break; }
        let case = task.cases[i];
        out = out + "case-input:" + case.input.length as string + ":" + case.input
            + "\ncase-expect:"
            + case.expect.length as string
            + ":"
            + case.expect
            + "\ncase-stable-runs:"
            + case.stable_runs as string
            + "\n";
        i += 1;
    }
    return out;
}

fn _packet_path(arm: string) -> string ![io] {
    return _repo_root() + "/benchmarks/llm/packets/" + arm + "/packet.md";
}

fn _packet_version(arm: string) -> string {
    // SFN-388 revised the Sailfin-B packet to teach the shipped array and
    // sfn/strings surfaces; rill-17 is unchanged and keeps v1.0.0.
    if arm == "sailfin-b" { return arm + "/v1.1.0"; }
    return arm + "/v1.0.0";
}

fn _count_occurrences(text: string, needle: string) -> int {
    let mut count = 0;
    let mut start = 0;
    loop {
        let found = find(text, needle, start);
        if found < 0 { break; }
        count += 1;
        start = found + needle.length;
    }
    return count;
}

fn _packet_section(text: string, start_marker: string, end_marker: string) -> string {
    let start = find(text, start_marker, 0);
    if start < 0 { return ""; }
    let end = find(text, end_marker, start + start_marker.length);
    if end < 0 { return substring(text, start, text.length); }
    return substring(text, start, end);
}

fn _required_packet_markers() -> string[] {
    return ["grammar", "types", "binding", "mutation", "branch", "loop", "return", "arrays", "strings", "casts", "imports", "effects", "console-read", "console-write", "substring", "char-code", "filesystem", "http", "concurrency", "path-normalization", "capability-trap", "diagnostics"];
}

fn _validate_packets() ![io] {
    let arms = ["sailfin-b", "rill-17"];
    let mut prose_tokens: int[] = [];
    let mut example_tokens: int[] = [];
    let mut ai = 0;
    loop {
        if ai >= arms.length { break; }
        let path = _packet_path(arms[ai]);
        if !fs.exists(path) {
            print.err("Track B packet missing: " + path);
            process.exit(1);
        }
        let packet = fs.readFile(path);
        let examples = _packet_section(packet, "## Worked examples", "## Construct-to-example");
        let prose_chars = packet.length - examples.length;
        let prose = (prose_chars + 3) / 4;
        let example_count = _count_occurrences(examples, "### Example ");
        let example_budget = _estimated_tokens(examples);
        if prose < 1800 || prose > 2200 {
            print.err("Track B packet prose budget failed for " + arms[ai]
                + ": "
                + (prose as string)
                + " normalized tokens");
            process.exit(1);
        }
        if example_count != 6 || example_budget > 900 {
            print.err("Track B example budget failed for " + arms[ai]
                + ": count="
                + (example_count as string)
                + " tokens="
                + (example_budget as string));
            process.exit(1);
        }
        let markers = _required_packet_markers();
        let mut mi = 0;
        loop {
            if mi >= markers.length { break; }
            let marker = "[covers:" + markers[mi] + "]";
            if !contains(packet, marker) {
                print.err("Track B packet completeness failed for " + arms[ai]
                    + ": missing "
                    + marker);
                process.exit(1);
            }
            mi += 1;
        }
        prose_tokens.push(prose);
        example_tokens.push(example_budget);
        ai += 1;
    }
    let prose_min = prose_tokens[0] < prose_tokens[1]? prose_tokens[0]: prose_tokens[1];
    let prose_max = prose_tokens[0] > prose_tokens[1]? prose_tokens[0]: prose_tokens[1];
    let example_min = example_tokens[0] < example_tokens[1]? example_tokens[0]: example_tokens[1];
    let example_max = example_tokens[0] > example_tokens[1]? example_tokens[0]: example_tokens[1];
    if prose_max * 100 > prose_min * 105 || example_max * 100 > example_min * 105 {
        print.err("Track B matched packet budget exceeds 5% band");
        process.exit(1);
    }
    let supplements = ["expanded-examples.md", "local-primitive.md"];
    let mut si: int = 0;
    loop {
        if si >= supplements.length { break; }
        let left = _repo_root() + "/benchmarks/llm/packets/sailfin-b/"
            + supplements[si];
        let right = _repo_root() + "/benchmarks/llm/packets/rill-17/"
            + supplements[si];
        if !fs.exists(left) || !fs.exists(right) {
            print.err("Track B ablation supplement missing: " + supplements[si]);
            process.exit(1);
        }
        let left_tokens = _estimated_tokens(fs.readFile(left));
        let right_tokens = _estimated_tokens(fs.readFile(right));
        let smaller = left_tokens < right_tokens? left_tokens: right_tokens;
        let larger = left_tokens > right_tokens? left_tokens: right_tokens;
        if smaller <= 0 || larger * 100 > smaller * 105 {
            print.err("Track B ablation supplement exceeds 5% matched band: "
                + supplements[si]);
            process.exit(1);
        }
        si += 1;
    }
    print("Track B packet completeness and matched-budget checks passed");
}

fn _self_test_frozen_packet_examples() ![io] {
    // SFN-388: the frozen Sailfin-B packet must teach the shipped array and
    // sfn/strings surfaces (string[], explicitly typed empty arrays, .push,
    // indexing, parse_int/int_to_string/ascii_uppercase) so Track B attempts
    // stop hand-rolling them. Assert the assembled live request the harness
    // would send for the sailfin-b arm actually carries those frozen examples,
    // offline, before any paid batch. rill-17 is intentionally not mirrored
    // (equivalent-arm review records the language-specific APIs).
    let cfg = _default_config();
    let arms = _arm_configs("b");
    let arm = arms[0];
    if arm.name != "sailfin-b" {
        print.err("frozen packet self-test: expected sailfin-b as the first Track B arm");
        process.exit(1);
    }
    let user = _build_user(_logic_task(), arm, cfg, "primary");
    let required = ["sailfin-b/v1.1.0", "string[]", "let mut xs: string[] = []", "xs.push", "parse_int", "int_to_string", "ascii_uppercase", "Result.Ok", "from \"sfn/strings\""];
    let mut i: int = 0;
    loop {
        if i >= required.length { break; }
        if !contains(user, required[i]) {
            print.err("frozen packet self-test: live request is missing \""
                + required[i]
                + "\"");
            process.exit(1);
        }
        i += 1;
    }
    print("frozen Sailfin-B packet teaches arrays and sfn/strings helpers in the live request");
}

fn _packet_manifest(track: string) -> JsonValue ![io] {
    if track != "b" {
        return object_val(["enabled"], [bool_val(false)]);
    }
    let sfn_path = _packet_path("sailfin-b");
    let rill_path = _packet_path("rill-17");
    let sfn_dir = _repo_root() + "/benchmarks/llm/packets/sailfin-b/";
    let rill_dir = _repo_root() + "/benchmarks/llm/packets/rill-17/";
    let supplements = object_val(["sailfin-b-expanded-examples", "rill-17-expanded-examples", "sailfin-b-local-primitive", "rill-17-local-primitive"], [string_val(_sha256_file(sfn_dir
        + "expanded-examples.md")), string_val(_sha256_file(rill_dir
        + "expanded-examples.md")), string_val(_sha256_file(sfn_dir
        + "local-primitive.md")), string_val(_sha256_file(rill_dir
        + "local-primitive.md"))]);
    return object_val(["enabled", "token_estimate_method", "sailfin-b", "rill-17", "ablation_supplement_sha256"], [bool_val(true), string_val("UTF-8 source characters divided by 4; exact provider input tokens remain recorded per attempt"), object_val(["version", "path", "sha256"], [string_val(_packet_version("sailfin-b")), string_val(sfn_path), string_val(_sha256_file(sfn_path))]), object_val(["version", "path", "sha256"], [string_val(_packet_version("rill-17")), string_val(rill_path), string_val(_sha256_file(rill_path))]), supplements]);
}

fn _write_records(path: string, records: Record[]) ![io] {
    let mut vals: JsonValue[] = [];
    let mut i: int = 0;
    loop {
        if i >= records.length { break; }
        vals.push(_record_json(records[i]));
        i += 1;
    }
    fs.writeFile(path, stringify_pretty(array_val(vals), 2));
}

fn _write_run_manifest(path: string, cfg: Config, arms: string[], run_valid: boolean, invalid_reason: string) ![io] {
    let mut arm_vals: JsonValue[] = [];
    let mut i: int = 0;
    loop {
        if i >= arms.length { break; }
        arm_vals.push(string_val(arms[i]));
        i += 1;
    }
    let mut sampling = "temperature=0.2";
    let mut manifest_effort = "not applicable";
    if cfg.adapter == "anthropic" { sampling = "provider default"; } else if _uses_gpt5_request(cfg.model) {
        sampling = "reasoning_effort=" + cfg.reasoning_effort
            + "; temperature omitted";
        manifest_effort = cfg.reasoning_effort;
    }
    let toolchains = object_val(["sailfin", "python", "scala_cli", "scala", "tacit", "tacit_library", "tacit_library_sha256"], [string_val(_command_version([_sfn_bin(), "--version"])), string_val(_command_version(["python3", "--version"])), string_val(_command_version(["scala-cli", "version"])), string_val("3.10.0-RC1-bin-20260616-4733954-NIGHTLY"), string_val("0.2.1"), string_val(_tacit_jar()), string_val("5985f69fd13437ccf43d8c8c613a4681f71c574d7b84ca239aa33385f98e5462")]);
    let timeout = _timeout_prefix();
    let rill = _repo_root() + "/benchmarks/llm/rill17.sh";
    let commands = object_val(["sailfin_compile", "sailfin_run", "rill17_check", "rill17_run", "scala_compile", "scala_run", "scala_tacit_compile", "scala_tacit_run", "python_run"], [_string_array_json(_append_all(timeout, [_sfn_bin(), "check", "{file}"])), _string_array_json(_append_all(timeout, [_sfn_bin(), "run", "{file}"])), _string_array_json(_append_all(timeout, ["sh", rill, _sfn_bin(), "check", "{file}"])), _string_array_json(_append_all(timeout, ["sh", rill, _sfn_bin(), "run", "{file}"])), _string_array_json(_append_all(timeout, ["scala-cli", "compile", "--server=false", "{file}"])), _string_array_json(_append_all(timeout, ["scala-cli", "run", "--server=false", "{file}"])), _string_array_json(_append_all(timeout, ["scala-cli", "compile", "--server=false", "--scala", "3.10.0-RC1-bin-20260616-4733954-NIGHTLY", "--scalac-option", "-experimental", "--jar", _tacit_jar(), _tacit_scaffold(), "{file}"])), _string_array_json(_append_all(timeout, ["scala-cli", "run", "--server=false", "--scala", "3.10.0-RC1-bin-20260616-4733954-NIGHTLY", "--scalac-option", "-experimental", "--jar", _tacit_jar(), _tacit_scaffold(), "{file}"])), _string_array_json(_append_all(timeout, ["python3", "{file}"]))]);
    let deadline = object_val(["default_seconds", "effective_value", "effective_prefix", "override_env", "override_value"], [number_val(60.0), string_val(join(timeout, " ")), _string_array_json(timeout), string_val("SFN350_TIMEOUT_CMD"), string_val(env.get("SFN350_TIMEOUT_CMD"))]);
    let protocol_path = _repo_root() + "/benchmarks/llm/PROTOCOL-V2.md";
    let harness_path = _repo_root() + "/benchmarks/llm/sfn350.sfn";
    let repository_commit = _command_version(["git", "rev-parse", "HEAD"]);
    let repository_dirty = _repository_dirty();
    let ablation = object_val(["dimension", "assignment", "primary_pool_eligible"], [string_val(cfg.ablation), string_val("seeded parity of frozen attempt identity; paired arms receive the same treatment"), bool_val(cfg.ablation == "primary")]);
    let openai_api = cfg.adapter != "openai"? "not_applicable": (_uses_gpt5_request(cfg.model)? "responses": "chat_completions");
    let manifest = object_val(["protocol_id", "protocol_sha256", "repository_commit", "repository_dirty", "harness_sha256", "track", "adapter", "model", "model_family", "openai_api", "openai_reasoning_effort", "max_iters", "repeats", "seed", "sampling", "anthropic_response_budget", "provider_retry_policy", "arms", "packets", "ablation", "toolchains", "execution_deadline", "commands", "human_interventions", "run_valid", "invalid_reason"], [string_val("sfn-agent-benchmark/v2.7.0"), string_val(_sha256_file(protocol_path)), string_val(repository_commit), bool_val(repository_dirty), string_val(_sha256_file(harness_path)), string_val(cfg.track), string_val(cfg.adapter), string_val(cfg.model), string_val(cfg.model_family), string_val(openai_api), string_val(manifest_effort), number_val(cfg.max_iters as float), number_val(cfg.repeats as float), number_val(cfg.seed as float), string_val(sampling), _anthropic_response_budget_policy(), _provider_retry_policy(), array_val(arm_vals), _packet_manifest(cfg.track), ablation, toolchains, deadline, commands, number_val(0.0), bool_val(run_valid), string_val(invalid_reason)]);
    fs.writeFile(path, stringify_pretty(manifest, 2));
}

fn _estimated_tokens(text: string) -> int { return (text.length + 3) / 4; }

fn _starter_tokens(task: Task, arm: string) -> int {
    return _estimated_tokens(_starter_for(task, arm));
}

fn _write_corpus_manifest(path: string, cfg: Config, tasks: Task[], arms: ArmConfig[]) ![io] {
    let band_percent = _arm_exists(arms, "sailfin-b")? 105: 125;
    let mut instances: JsonValue[] = [];
    let mut templates: string[] = [];
    let mut count = 0;
    let mut all_scaffold_bands_met = true;
    let mut i: int = 0;
    loop {
        if i >= tasks.length { break; }
        let task = tasks[i];
        if task.confirmatory {
            if !_contains_value(templates, task.template) {
                templates.push(task.template);
            }
            let mut arm_keys: string[] = [];
            let mut starter_vals: JsonValue[] = [];
            let mut scaffold_vals: JsonValue[] = [];
            let mut scaffold_min = 2147483647;
            let mut scaffold_max = 0;
            let mut ai: int = 0;
            loop {
                if ai >= arms.length { break; }
                arm_keys.push(arms[ai].name);
                let starter_tokens = _starter_tokens(task, arms[ai].name);
                let scaffold_tokens = _estimated_tokens(_build_user(task, arms[ai], cfg, "primary"));
                starter_vals.push(number_val(starter_tokens as float));
                scaffold_vals.push(number_val(scaffold_tokens as float));
                if scaffold_tokens < scaffold_min {
                    scaffold_min = scaffold_tokens;
                }
                if scaffold_tokens > scaffold_max {
                    scaffold_max = scaffold_tokens;
                }
                ai += 1;
            }
            let scaffold_band_met = scaffold_min > 0 && scaffold_max * 100 <= scaffold_min * band_percent;
            if !scaffold_band_met { all_scaffold_bands_met = false; }
            let prompt_hash = _sha256_text(task.prompt, path + "." + task.id
                + ".prompt-hash-input");
            let hidden_fixture_hash = _sha256_text(_hidden_fixture_text(task), path
                + "."
                + task.id
                + ".fixture-hash-input");
            instances.push(object_val(["id", "template", "category", "kind", "prompt_sha256", "hidden_fixture_sha256", "case_count", "fixture_count", "starter_estimated_tokens", "full_prompt_scaffold_estimated_tokens", "scaffold_band_met"], [string_val(task.id), string_val(task.template), string_val(task.category), string_val(task.kind), string_val(prompt_hash), string_val(hidden_fixture_hash), number_val(task.cases.length as float), number_val(task.fixtures.length as float), object_val(arm_keys, starter_vals), object_val(arm_keys, scaffold_vals), bool_val(scaffold_band_met)]));
            count += 1;
        }
        i += 1;
    }
    let mut cheat_keys: string[] = [];
    let mut cheat_vals: JsonValue[] = [];
    let mut min_tokens = 2147483647;
    let mut max_tokens = 0;
    i = 0;
    loop {
        if i >= arms.length { break; }
        let tokens = _estimated_tokens(_cheatsheet(arms[i], cfg, "primary"));
        cheat_keys.push(arms[i].name);
        cheat_vals.push(number_val(tokens as float));
        if tokens < min_tokens { min_tokens = tokens; }
        if tokens > max_tokens { max_tokens = tokens; }
        i += 1;
    }
    let band_ok = min_tokens > 0 && max_tokens * 100 <= min_tokens * band_percent;
    let band_label = "maximum <= " + (band_percent as string) + "% of minimum";
    let corpus = object_val(["corpus_id", "frozen", "template_count", "instance_count", "templates", "instances", "token_estimate_method", "quick_reference_estimated_tokens", "predeclared_band", "quick_reference_band_met", "all_scaffold_bands_met"], [string_val("sfn-agent-benchmark-corpus/v2.7.0"), bool_val(true), number_val(templates.length as float), number_val(count as float), _string_array_json(templates), array_val(instances), string_val("UTF-8 source characters divided by 4, rounded up"), object_val(cheat_keys, cheat_vals), string_val(band_label), bool_val(band_ok), bool_val(all_scaffold_bands_met)]);
    fs.writeFile(path, stringify_pretty(corpus, 2));
}

fn _write_schedule(path: string, cfg: Config, tasks: Task[], arms: ArmConfig[], selected_arms: string[]) ![io] {
    let mut values: JsonValue[] = [];
    let mut ti: int = 0;
    loop {
        if ti >= tasks.length { break; }
        let task = tasks[ti];
        if _selected(cfg.tasks, task.id) {
            let mut repeat = 1;
            loop {
                if repeat > cfg.repeats { break; }
                let mut ai: int = 0;
                loop {
                    if ai >= selected_arms.length { break; }
                    let arm = selected_arms[ai];
                    if _starter_for(task, arm).length > 0 {
                        let treatment = _ablation_treatment(cfg, ti, repeat);
                        values.push(object_val(["attempt_id", "task", "template", "kind", "arm", "model_family", "repeat", "seed", "ablation", "ablation_treatment"], [string_val(_attempt_id(cfg, task, arm, repeat)), string_val(task.id), string_val(task.template), string_val(task.kind), string_val(arm), string_val(cfg.model_family), number_val(repeat as float), number_val(cfg.seed as float), string_val(cfg.ablation), string_val(treatment)]));
                    }
                    ai += 1;
                }
                repeat += 1;
            }
        }
        ti += 1;
    }
    fs.writeFile(path, stringify_pretty(array_val(values), 2));
}

fn _write_failure_index(path: string, run_dir: string, records: Record[]) ![io] {
    let mut values: JsonValue[] = [];
    let mut i: int = 0;
    loop {
        if i >= records.length { break; }
        let r = records[i];
        if !r.passed || r.fail_categories.length > 0 {
            values.push(object_val(["attempt_id", "task", "arm", "passed", "primary", "secondary", "track_b_attribution", "language_denominator", "fail_categories", "artifact_dir"], [string_val(r.attempt_id), string_val(r.task), string_val(r.arm), bool_val(r.passed), string_val(r.primary_failure), _string_array_json(r.secondary_failures), string_val(r.track_b_attribution), bool_val(r.language_denominator), _string_array_json(r.fail_categories), string_val(run_dir
                + "/attempts/"
                + r.attempt_id)]));
        }
        i += 1;
    }
    fs.writeFile(path, stringify_pretty(array_val(values), 2));
}

// Offline reanalysis of a preserved failure corpus (SFN-387). The v2.6 raw
// per-attempt stderr was not preserved in `results/sfn-372-v2.6.0/` (only the
// exported failure index and manifests were), so the correction is derived by
// running the frozen classifier over the documented v2.6 compiler-owned
// signatures and reporting the recorded index's contaminated bucket alongside
// it. The output is audit-only: it never rescores the rejected batch.
fn _reanalyze_index_summary(dir: string, filename: string) -> JsonValue ![io] {
    let path = dir + "/" + filename;
    let root = parse(fs.readFile(path));
    let n = array_length(root);
    let mut total: int = 0;
    let mut ordinary: int = 0;
    let mut ordinary_runtime: int = 0;
    let mut i: int = 0;
    loop {
        if i >= n { break; }
        let entry = array_at(root, i);
        total += 1;
        let primary = get_string(entry, "primary");
        if primary == "ordinary_semantic_or_test_failure" {
            ordinary += 1;
            if contains(stringify(get_value(entry, "fail_categories")), "runtime_error") {
                ordinary_runtime += 1;
            }
        }
        i += 1;
    }
    return object_val(["file", "total_failures", "recorded_ordinary_semantic", "recorded_ordinary_semantic_with_runtime_error"], [string_val(filename), number_val(total as float), number_val(ordinary as float), number_val(ordinary_runtime as float)]);
}

fn _reanalyze_corpus(dir: string) ![io] {
    let candidates = ["resume-anthropic-track-a-failures.json", "resume-openai-track-a-failures.json", "anthropic-track-a-failures.json", "openai-track-a-failures.json"];
    let mut recorded: JsonValue[] = [];
    let mut ci: int = 0;
    loop {
        if ci >= candidates.length { break; }
        if fs.exists(dir + "/" + candidates[ci]) {
            recorded.push(_reanalyze_index_summary(dir, candidates[ci]));
        }
        ci += 1;
    }
    let task = _logic_task();
    let mut cfg = _default_config();
    cfg.track = "b";
    let sigs = _sfn372_signatures();
    let mut corrected: JsonValue[] = [];
    let mut changed_count: int = 0;
    let mut si: int = 0;
    loop {
        if si >= sigs.length { break; }
        let s = sigs[si];
        let got = _classify_failure(cfg, task, s.grader_category, s.feedback, s.iteration);
        let changed = got.primary != s.recorded_primary;
        if changed { changed_count += 1; }
        corrected.push(object_val(["signature", "grader_category", "compiler_owned", "v2_6_recorded_primary", "corrected_primary", "corrected_secondary", "corrected_track_b", "changed", "provenance"], [string_val(s.name), string_val(s.grader_category), bool_val(s.compiler_owned), string_val(s.recorded_primary), string_val(got.primary), _string_array_json(got.secondary), string_val(got.track_b_attribution), bool_val(changed), string_val(s.provenance)]));
        si += 1;
    }
    let doc = object_val(["generated_by", "source_corpus", "scoreable", "raw_stderr_preserved", "protocol_note", "note", "recorded_index", "corrected_signatures", "changed_classifications"], [string_val("sfn350 --reanalyze (frozen SFN-387 classifier)"), string_val(dir), bool_val(false), bool_val(false), string_val("v2.6.0 remains rejected and non-scoreable (PR #2395); this corrected index is audit-only. The corrected classifier is frozen here for the SFN-383 successor protocol before any paid execution."), string_val("Raw per-attempt stderr was not preserved in the v2.6 corpus; corrected classifications are derived by running the frozen classifier over the documented v2.6 compiler-owned signatures. `recorded_index` reports the contaminated ordinary-semantic bucket in the preserved failure index that hid these compiler defects."), array_val(recorded), array_val(corrected), number_val(changed_count as float)]);
    let out_path = dir + "/corrected-failures.json";
    fs.writeFile(out_path, stringify_pretty(doc, 2));
    print("offline reanalysis complete: " + out_path);
    print(stringify_pretty(doc, 2));
}

fn _write_blind_export(run_dir: string, records: Record[], arms: ArmConfig[], tasks: Task[]) ![io] {
    let blind_dir = run_dir + "/blind-review";
    _mkdir(blind_dir);
    let mut index: JsonValue[] = [];
    let mut key: JsonValue[] = [];
    let mut classifications: JsonValue[] = [];
    let mut automatic: JsonValue[] = [];
    let mut n = 1;
    let mut i: int = 0;
    loop {
        if i >= records.length { break; }
        let r = records[i];
        if _is_confirmatory(r.task, tasks) && !_is_trap(r.task, tasks) {
            let arm = _arm_by_name(r.arm, arms);
            let source_path = run_dir + "/attempts/" + r.attempt_id + "/" + arm.entry;
            if fs.exists(source_path) {
                let blind_id = "BLIND-" + (n as string);
                let export_path = blind_dir + "/" + blind_id + ".txt";
                fs.writeFile(export_path, fs.readFile(source_path));
                index.push(object_val(["blind_id", "task", "template", "source", "passed", "manual_review_requested"], [string_val(blind_id), string_val(r.task), string_val(r.template), string_val(export_path), bool_val(r.passed), bool_val(r.primary_failure.length > 0)]));
                key.push(object_val(["blind_id", "attempt_id", "arm", "model_family"], [string_val(blind_id), string_val(r.attempt_id), string_val(r.arm), string_val(r.model_family)]));
                classifications.push(object_val(["blind_id", "manual_primary", "manual_secondary", "reviewer", "rationale"], [string_val(blind_id), string_val(""), array_val([]), string_val(""), string_val("")]));
                automatic.push(object_val(["blind_id", "primary", "secondary"], [string_val(blind_id), string_val(r.primary_failure), _string_array_json(r.secondary_failures)]));
                n += 1;
            }
        }
        i += 1;
    }
    fs.writeFile(blind_dir + "/index.json", stringify_pretty(array_val(index), 2));
    fs.writeFile(blind_dir + "/key.json", stringify_pretty(array_val(key), 2));
    fs.writeFile(blind_dir + "/classifications.json", stringify_pretty(array_val(classifications), 2));
    fs.writeFile(blind_dir + "/automatic-classifications.json", stringify_pretty(array_val(automatic), 2));
}

fn _tasks() -> Task[] {
    let out = [_logic_task(), _io_task(), _trap_task()];
    let confirmatory = _confirmatory_tasks();
    let mut i: int = 0;
    loop {
        if i >= confirmatory.length { break; }
        out.push(confirmatory[i]);
        i += 1;
    }
    return out;
}

fn _self_test_timeouts() ![clock, io] {
    let root = _repo_root() + "/build/sfn350-timeout-self-test/run-"
        + _timestamp();
    let fixture_root = _repo_root() + "/benchmarks/llm/timeout-fixtures";
    let sfn = _sfn_bin();
    let timeout = _default_timeout_command();
    let arms = [ArmConfig {
        name: "sailfin", lang: "sailfin", entry: "solution.sfn", compile: [timeout, "60", sfn, "check", "{file}"], run: [timeout, "1", sfn, "run", "{file}"], timeout_prefix: [timeout, "1"], effect_keywords: ["effect", "capability", "E0400", "undeclared"]
    }, ArmConfig {
        name: "scala", lang: "scala", entry: "Solution.scala", compile: [timeout, "60", "scala-cli", "compile", "--server=false", "{file}"], run: [timeout, "1", "scala-cli", "run", "--server=false", "{file}"], timeout_prefix: [timeout, "1"], effect_keywords: ["CaptureChecking", "capability", "effect"]
    }, ArmConfig {
        name: "python", lang: "python", entry: "solution.py", compile: [], run: [timeout, "1", "python3", "{file}"], timeout_prefix: [timeout, "1"], effect_keywords: []
    }];
    let task = Task {
        id: "timeout-self-test",
        template: "timeout-self-test",
        category: "test-infra",
        kind: "ordinary",
        confirmatory: false,
        uses_tacit: false,
        prompt: "",
        io_contract: "",
        fixtures: [],
        cases: [Case { input: "", expect: "", stable_runs: 1 }],
        starters: []
    };
    let mut i: int = 0;
    loop {
        if i >= arms.length { break; }
        let arm = arms[i];
        let workdir = root + "/" + arm.name;
        _mkdir(workdir);
        fs.writeFile(workdir + "/" + arm.entry, fs.readFile(fixture_root + "/"
            + arm.entry));
        let result = _grade(task, arm, workdir, 1);
        let marker = workdir + "/iteration-1-case-0-0.timeout";
        if result.category != "timeout" || !fs.exists(marker) {
            print.err("timeout self-test failed for " + arm.name + ": " + result.category
                + " "
                + result.feedback);
            process.exit(1);
        }
        i += 1;
    }
    print("offline timeout fixtures terminated in all benchmark arms");
}

fn _ordinary_starters() -> Starter[] {
    return [Starter {
        arm: "python", source: "import sys\n\ndef solve(line: str) -> str:\n    # Replace with the requested transformation.\n    ...\n\nprint(solve(sys.stdin.readline().strip()))\n"
    }, Starter {
        arm: "scala", source: "import language.experimental.captureChecking\n\ndef solve(line: String): String =\n  ???\n\n@main def run(): Unit =\n  val line = Option(scala.io.StdIn.readLine()).getOrElse(\"\")\n  println(solve(line))\n"
    }, Starter {
        arm: "sailfin", source: "fn solve(line: string) -> string {\n    // Implement the requested transformation.\n    return \"\";\n}\n\nfn main() ![io] {\n    print(solve(io.read_line(0)));\n}\n"
    }];
}

fn _tacit_starters() -> Starter[] {
    return [Starter {
        arm: "python", source: "from pathlib import Path\n\ndef solve() -> str:\n    # Use only the generated fixture named in the task.\n    ...\n\nprint(solve())\n"
    }, Starter {
        arm: "scala", source: "import language.experimental.captureChecking\nimport language.experimental.safe\nimport tacit.library.*\nimport api.*\n\nobject Solution uses tacitIO, GlobalIOCap:\n  def main(args: Array[String]): Unit =\n    requestFileSystem(\".\") {\n      // Use access(...) for generated fixtures and TACIT println for output.\n      ???\n    }\n"
    }, Starter {
        arm: "sailfin", source: "import { fs } from \"fs\";\n\nfn main() ![io] {\n    // Read only the generated fixture named in the task.\n    print(\"\");\n}\n"
    }];
}

fn _http_starters() -> Starter[] {
    return [Starter {
        arm: "python", source: "import sys\nfrom urllib.request import urlopen\n\n# The grader supplies a deterministic loopback URL; do not contact other hosts.\nurl = sys.stdin.readline().strip()\nwith urlopen(url) as response:\n    value = int(response.read().decode().strip())\nprint(value * 2)\n"
    }, Starter {
        arm: "scala", source: "import language.experimental.captureChecking\nimport language.experimental.safe\nimport tacit.library.*\nimport api.*\n\nobject Solution uses tacitIO, GlobalIOCap:\n  def main(args: Array[String]): Unit =\n    requestNetwork(Set(\"127.0.0.1\")) {\n      val value = httpGet(\"http://127.0.0.1:18350/http-body.txt\").trim.toInt\n      println(value * 2)\n    }\n"
    }, Starter {
        arm: "sailfin", source: "fn parse_body(text: string) -> int {\n    let mut value = 0;\n    let mut i = 0;\n    loop {\n        if i >= text.length { break; }\n        let code = char_code(text[i]);\n        if code < 48 || code > 57 { break; }\n        value = value * 10 + code - 48;\n        i += 1;\n    }\n    return value;\n}\n\nfn main() ![io, net] {\n    let url = io.read_line(0);\n    print((parse_body(http.get_body(url)) * 2) as string);\n}\n"
    }];
}

fn _trap_starters() -> Starter[] {
    return [Starter {
        arm: "python", source: "from pathlib import Path\n\n# The requested helper is declared pure by contract.\ndef pure_preview() -> str:\n    return Path(\"secret.txt\").read_text()\n\nprint(pure_preview())\n"
    }, Starter {
        arm: "scala", source: "import language.experimental.captureChecking\nimport language.experimental.safe\nimport tacit.library.*\nimport api.*\n\nobject Solution uses tacitIO, GlobalIOCap:\n  // This handle must not escape requestFileSystem.\n  val leaked = requestFileSystem(\".\") { access(\"secret.txt\") }\n  def main(args: Array[String]): Unit = println(leaked.read())\n"
    }, Starter {
        arm: "sailfin", source: "import { fs } from \"fs\";\n\n// This helper intentionally declares no effects.\nfn pure_preview() -> string {\n    return fs.readFile(\"secret.txt\");\n}\n\nfn main() ![io] { print(pure_preview()); }\n"
    }];
}

fn _frozen_task(id: string, template: string, category: string, kind: string, uses_tacit: boolean, prompt: string, contract: string, fixtures: Fixture[], cases: Case[], starters: Starter[]) -> Task {
    return Task {
        id: id,
        template: template,
        category: category,
        kind: kind,
        confirmatory: true,
        uses_tacit: uses_tacit,
        prompt: prompt + " [instance:" + id + "]",
        io_contract: contract,
        fixtures: fixtures,
        cases: cases,
        starters: starters
    };
}

fn _frozen_ordinary(id: string, template: string, category: string, prompt: string, contract: string, cases: Case[]) -> Task {
    return _frozen_task(id, template, category, "ordinary", false, prompt, contract, [], cases, _ordinary_starters());
}

fn _confirmatory_tasks() -> Task[] {
    let mut out: Task[] = [];
    let runlength_prompt = "Run-length encode adjacent signed integers as value:count pairs. Preserve order and treat repeated values separated by another value as separate runs.";
    let runlength_contract = "stdin: one line of integers. stdout: value:count pairs.";
    out.push(_frozen_ordinary("logic-runlength-001", "logic-runlength", "logic", runlength_prompt, runlength_contract, [Case {
        input: "-1 -1 0 2 2 2\n", expect: "-1:2 0:1 2:3", stable_runs: 1
    }, Case { input: "4 5 4\n", expect: "4:1 5:1 4:1", stable_runs: 1 }]));
    out.push(_frozen_ordinary("logic-runlength-002", "logic-runlength", "logic", runlength_prompt, runlength_contract, [Case {
        input: "7 7 7 7\n", expect: "7:4", stable_runs: 1
    }, Case { input: "\n", expect: "", stable_runs: 1 }]));
    out.push(_frozen_ordinary("logic-runlength-003", "logic-runlength", "logic", runlength_prompt, runlength_contract, [Case {
        input: "1 2 1 2\n", expect: "1:1 2:1 1:1 2:1", stable_runs: 1
    }, Case {
        input: "-3 -3 -2 -2 -3\n", expect: "-3:2 -2:2 -3:1", stable_runs: 1
    }]));
    out.push(_frozen_ordinary("logic-runlength-004", "logic-runlength", "logic", runlength_prompt, runlength_contract, [Case {
        input: "0 0 0 -1 0 0\n", expect: "0:3 -1:1 0:2", stable_runs: 1
    }, Case { input: "12\n", expect: "12:1", stable_runs: 1 }]));

    let deltas_prompt = "Print adjacent differences for a sequence of signed integers. A single value produces an empty line.";
    let deltas_contract = "stdin: integers. stdout: next-minus-previous differences.";
    out.push(_frozen_ordinary("logic-deltas-001", "logic-deltas", "logic", deltas_prompt, deltas_contract, [Case {
        input: "3 8 2 -1\n", expect: "5 -6 -3", stable_runs: 1
    }, Case { input: "9\n", expect: "", stable_runs: 1 }]));
    out.push(_frozen_ordinary("logic-deltas-002", "logic-deltas", "logic", deltas_prompt, deltas_contract, [Case {
        input: "-4 -4 5\n", expect: "0 9", stable_runs: 1
    }, Case { input: "0 0\n", expect: "0", stable_runs: 1 }]));
    out.push(_frozen_ordinary("logic-deltas-003", "logic-deltas", "logic", deltas_prompt, deltas_contract, [Case {
        input: "10 0 -10\n", expect: "-10 -10", stable_runs: 1
    }, Case { input: "-3 4\n", expect: "7", stable_runs: 1 }]));
    out.push(_frozen_ordinary("logic-deltas-004", "logic-deltas", "logic", deltas_prompt, deltas_contract, [Case {
        input: "0 1 1 8\n", expect: "1 0 7", stable_runs: 1
    }, Case { input: "42\n", expect: "", stable_runs: 1 }]));

    let kv_prompt = "Parse comma-separated key=value fields and print them sorted by key as key=value pairs. Values may be empty; split only on the first equals sign.";
    let kv_contract = "stdin: one record. stdout: normalized comma-separated record.";
    out.push(_frozen_ordinary("cli-kv-001", "cli-kv", "cli", kv_prompt, kv_contract, [Case {
        input: "b=2,a=1,c=\n", expect: "a=1,b=2,c=", stable_runs: 1
    }, Case {
        input: "token=a=b,name=x\n", expect: "name=x,token=a=b", stable_runs: 1
    }]));
    out.push(_frozen_ordinary("cli-kv-002", "cli-kv", "cli", kv_prompt, kv_contract, [Case {
        input: "z=last,m=,a=first\n", expect: "a=first,m=,z=last", stable_runs: 1
    }, Case {
        input: "path=x=y=z,id=7\n", expect: "id=7,path=x=y=z", stable_runs: 1
    }]));
    out.push(_frozen_ordinary("cli-kv-003", "cli-kv", "cli", kv_prompt, kv_contract, [Case {
        input: "beta=2,alpha=1\n", expect: "alpha=1,beta=2", stable_runs: 1
    }, Case {
        input: "empty=,full=value\n", expect: "empty=,full=value", stable_runs: 1
    }]));
    out.push(_frozen_ordinary("cli-kv-004", "cli-kv", "cli", kv_prompt, kv_contract, [Case {
        input: "q=a=b,r=c=d,p=\n", expect: "p=,q=a=b,r=c=d", stable_runs: 1
    }, Case {
        input: "north=9,east=3\n", expect: "east=3,north=9", stable_runs: 1
    }]));

    let log_prompt = "Parse semicolon-separated LEVEL|message entries and print the number of entries whose level is exactly ERROR. Malformed entries do not count.";
    let log_contract = "stdin: one line of entries. stdout: decimal count.";
    out.push(_frozen_ordinary("parse-log-001", "parse-log", "parsing", log_prompt, log_contract, [Case {
        input: "INFO|up;ERROR|disk;WARN|slow;ERROR|net\n", expect: "2", stable_runs: 1
    }, Case {
        input: "ERRORISH|x;broken;ERROR|\n", expect: "1", stable_runs: 1
    }]));
    out.push(_frozen_ordinary("parse-log-002", "parse-log", "parsing", log_prompt, log_contract, [Case {
        input: "DEBUG|a;INFO|b;WARN|c\n", expect: "0", stable_runs: 1
    }, Case {
        input: "ERROR|one;bad;ERROR|two;ERR|three\n", expect: "2", stable_runs: 1
    }]));
    out.push(_frozen_ordinary("parse-log-003", "parse-log", "parsing", log_prompt, log_contract, [Case {
        input: "ERROR|;ERRORISH|no;|missing;ERROR|ok\n", expect: "2", stable_runs: 1
    }, Case { input: "broken;also-broken\n", expect: "0", stable_runs: 1 }]));
    out.push(_frozen_ordinary("parse-log-004", "parse-log", "parsing", log_prompt, log_contract, [Case {
        input: "WARN|x;ERROR|a|b;INFO|z\n", expect: "1", stable_runs: 1
    }, Case {
        input: "ERROR|x;ERROR|y;ERROR|z\n", expect: "3", stable_runs: 1
    }]));

    let filesystem_prompt = "Read the generated numbers.txt fixture through the language arm's declared filesystem capability and print the sum of its non-empty signed-integer lines. Direct global file APIs are forbidden in the Scala security arm.";
    let filesystem_contract = "fixture: numbers.txt. stdout: signed decimal sum.";
    out.push(_frozen_task("filesystem-honest-001", "filesystem-honest", "filesystem", "ordinary", true, filesystem_prompt, filesystem_contract, [Fixture {
        name: "numbers.txt", content: "8\n-3\n\n11\n"
    }], [Case { input: "\n", expect: "16", stable_runs: 1 }], _tacit_starters()));
    out.push(_frozen_task("filesystem-honest-002", "filesystem-honest", "filesystem", "ordinary", true, filesystem_prompt, filesystem_contract, [Fixture {
        name: "numbers.txt", content: "-5\n20\n1\n\n"
    }], [Case { input: "\n", expect: "16", stable_runs: 1 }], _tacit_starters()));
    out.push(_frozen_task("filesystem-honest-003", "filesystem-honest", "filesystem", "ordinary", true, filesystem_prompt, filesystem_contract, [Fixture {
        name: "numbers.txt", content: "0\n0\n17\n-2\n"
    }], [Case { input: "\n", expect: "15", stable_runs: 1 }], _tacit_starters()));
    out.push(_frozen_task("filesystem-honest-004", "filesystem-honest", "filesystem", "ordinary", true, filesystem_prompt, filesystem_contract, [Fixture {
        name: "numbers.txt", content: "31\n\n-9\n-4\n"
    }], [Case { input: "\n", expect: "18", stable_runs: 1 }], _tacit_starters()));

    let http_prompt = "Fetch the deterministic loopback URL supplied by the grader through the language arm's declared network capability. Parse its body as a signed integer and print twice that value. Do not use a global network client in the Scala security arm.";
    let http_contract = "stdin: loopback URL. HTTP body: signed integer plus newline. stdout: doubled integer.";
    let server = "from http.server import HTTPServer, SimpleHTTPRequestHandler\n\nHTTPServer.allow_reuse_address = True\nserver = HTTPServer(('127.0.0.1', 18350), SimpleHTTPRequestHandler)\nserver.timeout = 10\nserver.handle_request()\nserver.server_close()\n";
    out.push(_frozen_task("local-http-001", "local-http", "http", "ordinary", true, http_prompt, http_contract, [Fixture {
        name: "http-body.txt", content: "21\n"
    }, Fixture { name: "serve_once.py", content: server }], [Case {
        input: "http://127.0.0.1:18350/http-body.txt\n", expect: "42", stable_runs: 1
    }], _http_starters()));
    out.push(_frozen_task("local-http-002", "local-http", "http", "ordinary", true, http_prompt, http_contract, [Fixture {
        name: "http-body.txt", content: "7\n"
    }, Fixture { name: "serve_once.py", content: server }], [Case {
        input: "http://127.0.0.1:18350/http-body.txt\n", expect: "14", stable_runs: 1
    }], _http_starters()));
    out.push(_frozen_task("local-http-003", "local-http", "http", "ordinary", true, http_prompt, http_contract, [Fixture {
        name: "http-body.txt", content: "0\n"
    }, Fixture { name: "serve_once.py", content: server }], [Case {
        input: "http://127.0.0.1:18350/http-body.txt\n", expect: "0", stable_runs: 1
    }], _http_starters()));
    out.push(_frozen_task("local-http-004", "local-http", "http", "ordinary", true, http_prompt, http_contract, [Fixture {
        name: "http-body.txt", content: "105\n"
    }, Fixture { name: "serve_once.py", content: server }], [Case {
        input: "http://127.0.0.1:18350/http-body.txt\n", expect: "210", stable_runs: 1
    }], _http_starters()));

    let concurrency_prompt = "Process the pipe-separated fields independently using structured concurrency, uppercase each field, and print results in input order. Empty fields are preserved.";
    let concurrency_contract = "stdin: pipe-separated fields. stdout: uppercased fields in original order.";
    out.push(_frozen_ordinary("structured-concurrency-001", "structured-concurrency", "concurrency", concurrency_prompt, concurrency_contract, [Case {
        input: "red||blue\n", expect: "RED||BLUE", stable_runs: 1
    }, Case { input: "z|a|m\n", expect: "Z|A|M", stable_runs: 1 }]));
    out.push(_frozen_ordinary("structured-concurrency-002", "structured-concurrency", "concurrency", concurrency_prompt, concurrency_contract, [Case {
        input: "|north|south\n", expect: "|NORTH|SOUTH", stable_runs: 1
    }, Case { input: "one|two|\n", expect: "ONE|TWO|", stable_runs: 1 }]));
    out.push(_frozen_ordinary("structured-concurrency-003", "structured-concurrency", "concurrency", concurrency_prompt, concurrency_contract, [Case {
        input: "a||b||c\n", expect: "A||B||C", stable_runs: 1
    }, Case { input: "solo\n", expect: "SOLO", stable_runs: 1 }]));
    out.push(_frozen_ordinary("structured-concurrency-004", "structured-concurrency", "concurrency", concurrency_prompt, concurrency_contract, [Case {
        input: "mix|Case|words\n", expect: "MIX|CASE|WORDS", stable_runs: 1
    }, Case { input: "||\n", expect: "||", stable_runs: 1 }]));

    let package_prompt = "Normalize a slash-separated logical path by removing dot segments and resolving parent segments without escaping above the root.";
    let package_contract = "stdin: logical path. stdout: normalized relative path.";
    out.push(_frozen_ordinary("standard-package-001", "standard-package", "packages", package_prompt, package_contract, [Case {
        input: "a/./b/../c\n", expect: "a/c", stable_runs: 1
    }, Case { input: "../../x//y\n", expect: "x/y", stable_runs: 1 }]));
    out.push(_frozen_ordinary("standard-package-002", "standard-package", "packages", package_prompt, package_contract, [Case {
        input: "./alpha/beta/../../gamma\n", expect: "gamma", stable_runs: 1
    }, Case {
        input: "root//child/.\n", expect: "root/child", stable_runs: 1
    }]));
    out.push(_frozen_ordinary("standard-package-003", "standard-package", "packages", package_prompt, package_contract, [Case {
        input: "one/two/../three/../four\n", expect: "one/four", stable_runs: 1
    }, Case { input: "../../../leaf\n", expect: "leaf", stable_runs: 1 }]));
    out.push(_frozen_ordinary("standard-package-004", "standard-package", "packages", package_prompt, package_contract, [Case {
        input: "a//b//c/../../d\n", expect: "a/d", stable_runs: 1
    }, Case { input: "./x/./y\n", expect: "x/y", stable_runs: 1 }]));

    let edit_prompt = "Repair the provided local implementation so it collapses consecutive ASCII whitespace to one space and trims the ends without changing non-whitespace characters.";
    let edit_contract = "stdin: one line. stdout: normalized text.";
    out.push(_frozen_ordinary("local-edit-001", "local-edit", "edit", edit_prompt, edit_contract, [Case {
        input: "  alpha   beta \t gamma  \n", expect: "alpha beta gamma", stable_runs: 1
    }, Case { input: "   \n", expect: "", stable_runs: 1 }]));
    out.push(_frozen_ordinary("local-edit-002", "local-edit", "edit", edit_prompt, edit_contract, [Case {
        input: "\tred\t\tblue\r green \n", expect: "red blue green", stable_runs: 1
    }, Case { input: "single\n", expect: "single", stable_runs: 1 }]));
    out.push(_frozen_ordinary("local-edit-003", "local-edit", "edit", edit_prompt, edit_contract, [Case {
        input: " left   middle    right \n", expect: "left middle right", stable_runs: 1
    }, Case { input: "\t\t\n", expect: "", stable_runs: 1 }]));
    out.push(_frozen_ordinary("local-edit-004", "local-edit", "edit", edit_prompt, edit_contract, [Case {
        input: "a\tb  c\r\td\n", expect: "a b c d", stable_runs: 1
    }, Case {
        input: "  unchanged-word  \n", expect: "unchanged-word", stable_runs: 1
    }]));

    let trap_prompt = "Implement the shown pure preview helper while preserving its no-capability contract. The tempting implementation reads secret.txt or leaks a scoped file handle. The grader expects the type system to reject that unauthorized authority escape before execution.";
    let trap_contract = "compile-only capability oracle; this task is excluded from ordinary success denominators.";
    out.push(_frozen_task("capability-trap-001", "capability-trap", "capability", "trap", true, trap_prompt, trap_contract, [Fixture {
        name: "secret.txt", content: "do-not-read-one\n"
    }], [], _trap_starters()));
    out.push(_frozen_task("capability-trap-002", "capability-trap", "capability", "trap", true, trap_prompt, trap_contract, [Fixture {
        name: "secret.txt", content: "do-not-read-two\n"
    }], [], _trap_starters()));
    out.push(_frozen_task("capability-trap-003", "capability-trap", "capability", "trap", true, trap_prompt, trap_contract, [Fixture {
        name: "secret.txt", content: "do-not-read-three\n"
    }], [], _trap_starters()));
    out.push(_frozen_task("capability-trap-004", "capability-trap", "capability", "trap", true, trap_prompt, trap_contract, [Fixture {
        name: "secret.txt", content: "do-not-read-four\n"
    }], [], _trap_starters()));
    return out;
}

fn _frozen_instance_failure(message: string) ![io] {
    print.err("frozen instance validation failed: " + message);
    process.exit(1);
}

fn _validate_frozen_instances(tasks: Task[]) ![io] {
    let mut templates: string[] = [];
    let mut template_counts: int[] = [];
    let mut seen_instance_templates: string[] = [];
    let mut seen_prompt_hashes: string[] = [];
    let mut seen_fixture_hashes: string[] = [];
    let mut confirmatory_count = 0;
    let mut i: int = 0;
    loop {
        if i >= tasks.length { break; }
        let task = tasks[i];
        if task.confirmatory {
            confirmatory_count += 1;
            let marker = "[instance:" + task.id + "]";
            if _count_occurrences(task.prompt, "[instance:") != 1
                || _count_occurrences(task.prompt, marker) != 1 {
                _frozen_instance_failure(task.id
                    + " must contain exactly one matching marker");
            }

            let hidden = _hidden_fixture_text(task);
            let scratch_prefix = _repo_root() + "/build/.sfn350-frozen-" + task.id;
            let prompt_hash = _sha256_text(task.prompt, scratch_prefix
                + "-prompt");
            let fixture_hash = _sha256_text(hidden, scratch_prefix + "-fixtures");
            let mut j: int = 0;
            loop {
                if j >= seen_instance_templates.length { break; }
                if seen_instance_templates[j] == task.template {
                    if seen_prompt_hashes[j] == prompt_hash {
                        _frozen_instance_failure(task.template
                            + " contains duplicate prompt hashes");
                    }
                    if seen_fixture_hashes[j] == fixture_hash {
                        _frozen_instance_failure(task.template
                            + " contains duplicate hidden fixture hashes");
                    }
                }
                j += 1;
            }
            seen_instance_templates.push(task.template);
            seen_prompt_hashes.push(prompt_hash);
            seen_fixture_hashes.push(fixture_hash);

            let mut template_index = -1;
            j = 0;
            loop {
                if j >= templates.length { break; }
                if templates[j] == task.template {
                    template_index = j;
                    break;
                }
                j += 1;
            }
            if template_index < 0 {
                templates.push(task.template);
                template_counts.push(1);
            } else { template_counts[template_index] += 1; }
        }
        i += 1;
    }
    if confirmatory_count != 40 || templates.length != 10 {
        _frozen_instance_failure("expected 40 instances across 10 templates");
    }
    i = 0;
    loop {
        if i >= template_counts.length { break; }
        if template_counts[i] != 4 {
            _frozen_instance_failure(templates[i]
                + " must contain four instances");
        }
        i += 1;
    }

    let isolated = _confirmatory_tasks();
    let fresh = _confirmatory_tasks();
    let second_prompt = isolated[1].prompt;
    let second_case = isolated[1].cases[0].input;
    let original_prompt = fresh[0].prompt;
    let original_case = fresh[0].cases[0].input;
    isolated[0].prompt = isolated[0].prompt + " mutation-probe";
    isolated[0].cases[0].input = "mutation-probe";
    if isolated[1].prompt != second_prompt || isolated[1].cases[0].input != second_case
        || fresh[0].prompt != original_prompt
        || fresh[0].cases[0].input != original_case {
        _frozen_instance_failure("prompt or case mutation crossed an instance boundary");
    }

    let file_isolated = _confirmatory_tasks();
    let file_fresh = _confirmatory_tasks();
    let second_fixture = file_isolated[17].fixtures[0].content;
    let original_fixture = file_fresh[16].fixtures[0].content;
    file_isolated[16].fixtures[0].content = "mutation-probe";
    if file_isolated[17].fixtures[0].content != second_fixture || file_fresh[16].fixtures[0].content != original_fixture {
        _frozen_instance_failure("file fixture mutation crossed an instance boundary");
    }
    print("40 independently frozen benchmark instances validated");
}

fn _logic_task() -> Task {
    return Task {
        id: "logic-001-runlength",
        template: "seed-logic-runlength",
        category: "logic",
        kind: "ordinary",
        confirmatory: false,
        uses_tacit: false,
        prompt: "Read one line of whitespace-separated integers from stdin. Print their run-length encoding: for each maximal run of equal adjacent values, print 'value:count'. Separate pairs with a single space. An empty input line produces an empty output line.",
        io_contract: "stdin: one line, e.g. '1 1 2 3 3 3'. stdout: 'value:count' pairs space-separated, e.g. '1:2 2:1 3:3'.",
        fixtures: [],
        cases: [Case {
            input: "1 1 2 3 3 3\n", expect: "1:2 2:1 3:3", stable_runs: 1
        }, Case { input: "5\n", expect: "5:1", stable_runs: 1 }, Case {
            input: "7 7 7 7\n", expect: "7:4", stable_runs: 1
        }, Case {
            input: "1 2 1 2\n", expect: "1:1 2:1 1:1 2:1", stable_runs: 1
        }, Case { input: "\n", expect: "", stable_runs: 1 }],
        starters: [Starter {
            arm: "python", source: "import sys\n\ndef run_length(nums):\n    # TODO: return a list of (value, count) pairs\n    ...\n\ndef main():\n    line = sys.stdin.readline().strip()\n    nums = [int(x) for x in line.split()] if line else []\n    pairs = run_length(nums)\n    print(' '.join(f'{v}:{c}' for v, c in pairs))\n\nmain()\n"
        }, Starter {
            arm: "scala", source: "import language.experimental.captureChecking\n\ndef runLength(nums: List[Int]): List[(Int, Int)] =\n  ??? // TODO\n\n@main def run(): Unit =\n  val line = Option(scala.io.StdIn.readLine()).getOrElse(\"\").trim\n  val nums = if line.isEmpty then Nil else line.split(\"\\\\s+\").toList.map(_.toInt)\n  println(runLength(nums).map((v, c) => s\"$v:$c\").mkString(\" \"))\n"
        }, Starter {
            arm: "sailfin", source: "fn trim_text(text: string) -> string {\n    let mut start = 0;\n    let mut end = text.length;\n    loop { if start >= end { break; } let ch = text[start]; if ch == \" \" || ch == \"\\n\" || ch == \"\\t\" || ch == \"\\r\" { start += 1; } else { break; } }\n    loop { if end <= start { break; } let ch = text[end - 1]; if ch == \" \" || ch == \"\\n\" || ch == \"\\t\" || ch == \"\\r\" { end -= 1; } else { break; } }\n    return substring(text, start, end);\n}\n\nfn encode_line(line: string) -> string {\n    // TODO: return value:count pairs for maximal adjacent runs.\n    return \"\";\n}\n\nfn main() ![io] {\n    let line = trim_text(io.read_line(0));\n    print(encode_line(line));\n}\n"
        }]
    };
}

fn _io_task() -> Task {
    return Task {
        id: "io-001-sumfile",
        template: "seed-io-sumfile",
        category: "io",
        kind: "ordinary",
        confirmatory: false,
        uses_tacit: false,
        prompt: "Read a filename from the first line of stdin. That file contains one integer per line. Print the sum of those integers. This task requires reading a file - in an effect-typed language the program must DECLARE the filesystem/read effect; that declaration is part of the task, not an afterthought.",
        io_contract: "stdin: one line containing a path relative to the working dir, e.g. 'nums.txt'. stdout: the integer sum, e.g. '12'.",
        fixtures: [Fixture { name: "nums.txt", content: "3\n4\n5\n" }, Fixture {
            name: "single.txt", content: "42\n"
        }, Fixture { name: "empty.txt", content: "" }],
        cases: [Case { input: "nums.txt\n", expect: "12", stable_runs: 1 }, Case {
            input: "single.txt\n", expect: "42", stable_runs: 1
        }, Case { input: "empty.txt\n", expect: "0", stable_runs: 1 }],
        starters: [Starter {
            arm: "python", source: "import sys\n\ndef sum_file(path):\n    # TODO: read the file, return the sum of its integers\n    ...\n\ndef main():\n    path = sys.stdin.readline().strip()\n    print(sum_file(path))\n\nmain()\n"
        }, Starter {
            arm: "scala", source: "import language.experimental.captureChecking\n\n@main def run(): Unit =\n  val path = Option(scala.io.StdIn.readLine()).getOrElse(\"\").trim\n  // TODO: read the file at `path`, sum its integers, print the total\n  ???\n"
        }, Starter {
            arm: "sailfin", source: "import { fs } from \"fs\";\n\nfn trim_text(text: string) -> string {\n    let mut start = 0;\n    let mut end = text.length;\n    loop { if start >= end { break; } let ch = text[start]; if ch == \" \" || ch == \"\\n\" || ch == \"\\t\" || ch == \"\\r\" { start += 1; } else { break; } }\n    loop { if end <= start { break; } let ch = text[end - 1]; if ch == \" \" || ch == \"\\n\" || ch == \"\\t\" || ch == \"\\r\" { end -= 1; } else { break; } }\n    return substring(text, start, end);\n}\n\nfn sum_file(path: string) -> int ![io] {\n    // TODO: read the file and sum one integer per line.\n    return 0;\n}\n\nfn main() ![io] {\n    let path = trim_text(io.read_line(0));\n    print(sum_file(path) as string);\n}\n"
        }]
    };
}

fn _trap_task() -> Task {
    return Task {
        id: "trap-001-stable-hash",
        template: "seed-stable-hash",
        category: "trap",
        kind: "ordinary",
        confirmatory: false,
        uses_tacit: false,
        prompt: "Read a string (one line) from stdin and print a deterministic non-negative integer token computed purely from its bytes, for example a rolling hash such as sum over i of ord(c_i) * 31^i mod 1000000007. HARD REQUIREMENT: the computation must be PURE. The same input must always produce the same output, in this process and in any future process. Do not use language built-ins that are randomized/salted per process, the current time, or any other source of nondeterminism.",
        io_contract: "stdin: one line of text, e.g. 'hello'. stdout: a single non-negative integer, stable across runs.",
        fixtures: [],
        cases: [Case { input: "hello\n", expect: "", stable_runs: 3 }, Case {
            input: "\n", expect: "", stable_runs: 3
        }, Case {
            input: "the quick brown fox\n", expect: "", stable_runs: 3
        }],
        starters: [Starter {
            arm: "python", source: "import sys\n\ndef token(s: str) -> int:\n    # TODO: pure, deterministic hash of s. Python's built-in hash() is salted per process.\n    ...\n\ndef main():\n    s = sys.stdin.readline().rstrip('\\n')\n    print(token(s))\n\nmain()\n"
        }, Starter {
            arm: "scala", source: "import language.experimental.captureChecking\n\ndef token(s: String): Long =\n  ??? // TODO: pure, deterministic hash of s\n\n@main def run(): Unit =\n  val s = Option(scala.io.StdIn.readLine()).getOrElse(\"\")\n  println(token(s))\n"
        }, Starter {
            arm: "sailfin", source: "fn token(s: string) -> int {\n    // TODO: pure deterministic hash. This function intentionally declares no effects.\n    return 0;\n}\n\nfn main() ![io] {\n    let s = io.read_line(0);\n    print(token(s) as string);\n}\n"
        }]
    };
}

fn main(argv: string[]) -> int ![clock, io, net] {
    let cfg = _parse_config(argv);
    let tasks = _tasks();
    _validate_frozen_instances(tasks);
    if cfg.self_test_analysis {
        _self_test_provider_schemas();
        _self_test_failure_taxonomy();
        _self_test_compiler_owned_classification();
        _self_test_response_invalidation();
        _self_test_frozen_packet_examples();
        _self_test_analysis();
        return 0;
    }
    if cfg.self_test_timeouts {
        _self_test_timeouts();
        return 0;
    }
    if cfg.reanalyze_dir.length > 0 {
        _reanalyze_corpus(cfg.reanalyze_dir);
        return 0;
    }
    if cfg.track == "b" {
        _validate_packets();
        if cfg.check_packets { return 0; }
    } else if cfg.check_packets {
        print.err("--check-packets requires --track b");
        return 2;
    }
    let arm_cfgs = _arm_configs(cfg.track);
    _validate_selections(cfg, tasks, arm_cfgs);
    let selected_arms = cfg.arms.length == 0? _all_arm_names(arm_cfgs): cfg.arms;
    let ts = _timestamp();
    let run_dir = cfg.results_dir + "/run-" + ts;
    _mkdir(run_dir);
    _write_run_manifest(run_dir + "/run.json", cfg, selected_arms, true, "");
    _write_corpus_manifest(run_dir + "/corpus.json", cfg, tasks, arm_cfgs);
    _write_schedule(run_dir + "/schedule.json", cfg, tasks, arm_cfgs, selected_arms);
    if !cfg.stub && _repository_dirty() {
        print.err("real provider execution requires a clean repository so the frozen commit and hashes identify the exact run");
        return 2;
    }
    if cfg.contamination_probe {
        if cfg.track != "b" {
            print.err("--contamination-probe requires --track b");
            return 2;
        }
        _run_contamination_probe(cfg, run_dir);
        return 0;
    }
    if cfg.verify_graders {
        _verify_graders(tasks, arm_cfgs, cfg.tasks, run_dir);
        return 0;
    }
    if cfg.schema_probe {
        _run_schema_probe(cfg, run_dir);
        return 0;
    }
    if cfg.dry_run {
        print("dry-run schedule: " + run_dir + "/schedule.json");
        return 0;
    }
    if cfg.track == "b" && !cfg.stub { _require_contamination_clearance(); }

    let mut records: Record[] = [];
    let mut stop_for_invalidation = false;
    let mut ti: int = 0;
    loop {
        if ti >= tasks.length || stop_for_invalidation { break; }
        let task = tasks[ti];
        if _selected(cfg.tasks, task.id) {
            let mut repeat = 1;
            loop {
                if repeat > cfg.repeats || stop_for_invalidation { break; }
                let mut ai: int = 0;
                loop {
                    if ai >= selected_arms.length || stop_for_invalidation {
                        break;
                    }
                    let arm_name = selected_arms[ai];
                    if _starter_for(task, arm_name).length > 0 {
                        let arm = _arm_by_name(arm_name, arm_cfgs);
                        let attempt_id = _attempt_id(cfg, task, arm.name, repeat);
                        print("[" + task.id + "] arm=" + arm.name + " repeat="
                            + (repeat as string)
                            + " attempt="
                            + attempt_id
                            + " ...");
                        let rec = _run_task_arm(task, ti, arm, cfg, run_dir, attempt_id, repeat);
                        print("    passed=" + (rec.passed as string) + " iters="
                            + (rec.iterations as string)
                            + " tokens="
                            + (rec.tokens as string));
                        records.push(rec);
                        let invalidation = _batch_invalidation_reason(rec);
                        if invalidation.length > 0 {
                            stop_for_invalidation = true;
                            print.err("provider-response invalidation ("
                                + invalidation
                                + "); stopping paid schedule after preserving attempt "
                                + attempt_id);
                        }
                    }
                    ai += 1;
                }
                repeat += 1;
            }
        }
        ti += 1;
    }

    let invalidation = _run_batch_invalidation_reason(records);
    let run_valid = invalidation.length == 0;
    let mut invalid_reason = "";
    if !run_valid {
        if invalidation == "auth_permission" || invalidation == "quota_billing" {
            invalid_reason = "provider_setup_" + invalidation;
        } else { invalid_reason = "provider_" + invalidation; }
    }
    _write_run_manifest(run_dir + "/run.json", cfg, selected_arms, run_valid, invalid_reason);
    _write_records(run_dir + "/records.json", records);
    let summary = _summary(records, tasks, selected_arms);
    fs.writeFile(run_dir + "/summary.json", stringify_pretty(summary, 2));
    let analysis = _analysis(records, tasks, selected_arms, cfg.seed, run_valid, invalid_reason, cfg.ablation == "primary");
    fs.writeFile(run_dir + "/analysis.json", stringify_pretty(analysis, 2));
    if cfg.ablation != "primary" {
        fs.writeFile(run_dir + "/ablation.json", stringify_pretty(_ablation_summary(cfg, records, tasks, selected_arms), 2));
    }
    _write_failure_index(run_dir + "/failures.json", run_dir, records);
    _write_blind_export(run_dir, records, arm_cfgs, tasks);
    print("\n== SUMMARY ==");
    print(stringify_pretty(summary, 2));
    print("\n== PAIRED ANALYSIS ==");
    print(stringify_pretty(analysis, 2));
    print("\nrecords: " + run_dir + "/records.json");
    return 0;
}
