// benchmarks/runtime/io_throughput.sfn
//
// Runtime-execution benchmark: file I/O throughput.
//
// Writes a fixed number of lines to a temporary file via repeated
// `fs.appendFile`, then reads the whole file back once. Writes to a temp
// file (under $TMPDIR, falling back to /tmp) rather than stdout so the
// single machine-parseable RESULT line is the only thing on stdout.
// Stresses the filesystem adapter path (`runtime/sfn/adapters/filesystem.sfn`).
//
// Fixed work: LINES is a compile-time constant.
import { fs } from "fs";

fn main() ![io, clock] {
    let lines = 20000;
    let tmp = env.get("TMPDIR");
    let dir = tmp.length > 0? tmp: "/tmp/";
    let path = dir + "sfn_bench_io_throughput.txt";

    // Truncate any previous run's file.
    fs.writeFile(path, "");

    let start = monotonic_millis();
    let mut i = 0;
    loop {
        if i >= lines { break; }
        fs.appendFile(path, "log line for io throughput benchmark\n");
        i = i + 1;
    }
    // Read the whole file back once.
    let content = fs.readFile(path);
    let end = monotonic_millis();

    if content.length < 0 { return; }
    let dur = end - start;
    print("RESULT io_throughput {{dur}} {{lines}}");
}
