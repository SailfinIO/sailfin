// compiler/tests/unit/fs_write_full_payload_test.sfn
//
// Regression guard for the file writer's short-`fwrite` completeness
// contract. `sfn_fs_write_file` / `sfn_fs_append_file` / `sfn_fs_write_lines`
// must write the whole payload even when the underlying `fwrite` returns a
// short count under IO pressure — a partial write silently drops the payload
// tail, and for a compiler `.ll` that tail is the trailing `define @main`,
// which links as `undefined main`. We can't force a short write in-process,
// so this asserts the round-trip completeness invariant the fix guarantees:
// a multi-KiB payload survives write→read byte-for-byte, tail included.
//
// Structure mirrors the proven `runtime_capsule_resolver_test.sfn` shape:
// a fixed relative scratch dir set up via `process.run` (no `with_tmp_dir`),
// small deterministic payloads.
import { find } from "sfn/strings";

// A multi-KiB payload (6 doublings ≈ 3 KiB) plus a distinctive terminal
// marker that stands in for the `define @main` tail. The completeness
// invariant is size-independent — a short `fwrite` cannot be forced
// in-process — so the payload only needs to be large enough that a
// truncation regression would drop the marker.
fn _payload() -> string {
    let mut body = "sailfin-fs-writer-regression-chunk-0123456789ABCDEF\n";
    let mut i: int = 0;
    loop {
        if i >= 6 { break; }
        body = body + body;
        i += 1;
    }
    return body + ";; TAIL-MARKER-END";
}

test "fs writer: writeFile round-trips a multi-KiB payload without tail loss" ![io] {
    let scratch = "build/sailfin/.fs-writer-test-1";
    process.run(["rm", "-rf", scratch]);
    process.run(["mkdir", "-p", scratch]);
    let path = scratch + "/payload.bin";
    let payload = _payload();
    fs.writeFile(path, payload);
    let readback = fs.readFile(path);
    // Exact length proves no bytes were dropped mid-write; the marker
    // (written last) proves the tail specifically survived.
    assert readback.length == payload.length;
    assert find(readback, ";; TAIL-MARKER-END", 0) >= 0;
    process.run(["rm", "-rf", scratch]);
}

test "fs writer: appendFile accumulates the full payload" ![io] {
    let scratch = "build/sailfin/.fs-writer-test-2";
    process.run(["rm", "-rf", scratch]);
    process.run(["mkdir", "-p", scratch]);
    let path = scratch + "/payload.bin";
    let payload = _payload();
    fs.writeFile(path, payload);
    fs.appendFile(path, payload);
    let readback = fs.readFile(path);
    assert readback.length == payload.length * 2;
    process.run(["rm", "-rf", scratch]);
}

// `fs.writeLines` is the primary self-host IR emit path
// (`emit_native.sfn` → `write_llvm_lines_chunked`); a long final line must
// survive intact, since the module's trailing `define @main` is emitted as
// the last line.
test "fs writer: writeLines preserves a long final line" ![io] {
    let scratch = "build/sailfin/.fs-writer-test-3";
    process.run(["rm", "-rf", scratch]);
    process.run(["mkdir", "-p", scratch]);
    let path = scratch + "/payload.ll";
    let mut lines: string[] = [];
    lines.push("define i32 @main(i32 %argc, i8** %argv) {");
    lines.push("entry:");
    lines.push(_payload());
    lines.push("  ret i32 0");
    lines.push("}");
    fs.writeLines(path, lines);
    let readback = fs.readFile(path);
    // Every line body plus its one newline must land — computed from the
    // array itself so the assert proves "no line truncated" without brittle
    // hand-counted literal lengths.
    let mut expected: int = 0;
    let mut k: int = 0;
    loop {
        if k >= lines.length { break; }
        expected = expected + lines[k].length + 1;
        k += 1;
    }
    assert readback.length == expected;
    assert find(readback, ";; TAIL-MARKER-END", 0) >= 0;
    process.run(["rm", "-rf", scratch]);
}
