// Golden-IR test for the `runtime/sfn/platform/net.sfn` skeleton — the
// BSD-sockets surface used by the v0 HTTP adapter and the `serve` accept
// loop (see `docs/runtime_architecture.md` §2.7.2 / §2.6.6).
//
// Replaces `compiler/tests/e2e/test_runtime_net_skeleton.sh` as part of
// the bash-collapse migration (epic #842, issue #1223). The `.sh` ran
// `sfn check` + `sfn fmt --check` + `sfn emit llvm` and grepped the IR
// for a `declare` per extern; this pins the same `declare` surface
// in-process. The typecheck/fmt halves are covered elsewhere — CI runs
// `sfn fmt --check` over `runtime/` and `make compile` typechecks these
// sfn-sources.
//
// Strategy: ONE `lower_to_llvm_ir_from_text` call over the REAL skeleton
// file (read via `fs.readFile`). `net.sfn` has no imports, so
// single-module lowering resolves every symbol it declares — including
// the primitive-pointer out-parameter (`accept`'s `* i32` addrlen) the
// libc skeleton does not exercise.
import { emit_native_text_with_module_name } from "../../src/emit_native";
import { lower_to_llvm_ir_from_text } from "../../src/llvm/lowering/entrypoints";
import { parse_program } from "../../src/parser/mod";
import { index_of } from "../../src/string_utils";

fn _contains(haystack: string, needle: string) -> boolean {
    return index_of(haystack, needle) >= 0;
}

test "lowering: runtime/sfn/platform/net.sfn emits a declare for every extern" ![io] {
    let source = fs.readFile("runtime/sfn/platform/net.sfn");
    let program = parse_program(source);
    let native = emit_native_text_with_module_name(program, "runtime/sfn/platform/net");
    let ir = lower_to_llvm_ir_from_text(native, "runtime/sfn/platform/net");

    assert _contains(ir, "declare ");
    assert _contains(ir, "@socket(");
    assert _contains(ir, "@close(");
    assert _contains(ir, "@connect(");
    assert _contains(ir, "@bind(");
    assert _contains(ir, "@listen(");
    assert _contains(ir, "@accept(");
    assert _contains(ir, "@send(");
    assert _contains(ir, "@recv(");
    assert _contains(ir, "@setsockopt(");
}
