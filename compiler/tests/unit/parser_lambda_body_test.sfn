// Unit tests for structured lambda-body parsing (issue #520).
//
// Before #520 the expression-side lambda parser used a placeholder
// (`parse_block_for_lambda`) that only collected raw tokens, leaving
// `Expression.Lambda.body.statements` empty; downstream passes had to
// re-parse `body.tokens` to recover structure. The parser now delegates
// to the structured `parse_block` in statements.sfn, so a lambda body
// arrives with its `statements` list populated. These tests pin that:
// every lambda whose source has at least one parsed statement exposes a
// non-empty `body.statements`, and nested blocks / nested lambdas parse
// into structured nodes too.
//
// Sources use a top-level `let f = fn(...) { ... };` binding because that
// parse path produces a structured `Expression.Lambda` in the
// declaration's initializer (the same path the capture analysis relies
// on). Block-scoped `let` is still parsed into an opaque statement and is
// deliberately avoided here — its migration is tracked separately.
import { Block, Expression } from "../../src/ast";
import { parse_program } from "../../src/parser/mod";

// Unwrap the body block of a lambda expression. The early-return null
// guard narrows `expr` to a non-optional `Expression`; the variant
// assertion then pins that the initializer is actually a `Lambda` so a
// shape change fails here with a clear message instead of trapping on
// the duck-typed `body` access.
fn lambda_body(expr: Expression?) -> Block {
    if expr == null {
        return Block { tokens: [], text: "", statements: [] };
    }
    assert expr.variant == "Lambda";
    return expr.body;
}

// Body of the lambda bound by the first top-level `let` in `source`.
fn first_let_lambda_body(source: string) -> Block ![io] {
    let program = parse_program(source);
    let stmt = program.statements[0];
    assert stmt.variant == "VariableDeclaration";
    return lambda_body(stmt.initializer);
}

// The lambda expression bound by the first top-level `let` in `source`.
fn first_let_lambda(source: string) -> Expression? ![io] {
    let program = parse_program(source);
    let stmt = program.statements[0];
    assert stmt.variant == "VariableDeclaration";
    return stmt.initializer;
}

// -------------------------------------------------------------------
// Empty body — boundary case: a lambda with no statements parses to an
// empty (but structured) statement list, not a token blob.
// -------------------------------------------------------------------
test "lambda body: empty body has zero structured statements" ![io] {
    let body = first_let_lambda_body("let f = fn() -> int { };");
    assert body.statements.length == 0;
}

// -------------------------------------------------------------------
// Single statement — the core acceptance criterion: a lambda whose
// source has one statement exposes exactly one structured statement.
// -------------------------------------------------------------------
test "lambda body: single return parses to one structured statement" ![io] {
    let body = first_let_lambda_body("let f = fn() -> int { return 0; };");
    assert body.statements.length == 1;
    assert body.statements[0].variant == "ReturnStatement";
}

// -------------------------------------------------------------------
// Nested block — a `{ ... }` inside the lambda body parses to a
// `BlockStatement` carrying its own structured statement list.
// -------------------------------------------------------------------
test "lambda body: nested block parses to a structured BlockStatement" ![io] {
    let body = first_let_lambda_body("let f = fn() -> int { { return 0; } };");
    assert body.statements.length == 1;
    let inner = body.statements[0];
    assert inner.variant == "BlockStatement";
    assert inner.body.statements.length == 1;
    assert inner.body.statements[0].variant == "ReturnStatement";
}

// -------------------------------------------------------------------
// Nested lambda — a lambda returned from another lambda's body also
// arrives with structured statements, so future passes can walk the
// whole tree without re-parsing any level.
// -------------------------------------------------------------------
test "lambda body: nested lambda body is itself structured" ![io] {
    let body = first_let_lambda_body("let f = fn() -> int { return fn() -> int { return 1; }; };");
    assert body.statements.length == 1;
    let ret = body.statements[0];
    assert ret.variant == "ReturnStatement";
    let inner_body = lambda_body(ret.expression);
    assert inner_body.statements.length == 1;
    assert inner_body.statements[0].variant == "ReturnStatement";
}

// -------------------------------------------------------------------
// Effect annotation on a lambda return type (#1546) — a trailing
// `![...]` must NOT be folded into the return-type text. Before the fix
// the parser collected the return type through the body `{`, producing
// `return_type.text == "int ![io]"`; that mis-text made the spawn
// future-kind classifier fall to the `ptr` catch-all and corrupted the
// `await` result. The return type must read exactly `int`, and the body
// must still parse structurally after the effect tokens are consumed.
// -------------------------------------------------------------------
test "lambda return type: effect annotation is not folded into return type (#1546)" ![io] {
    let expr = first_let_lambda("let f = fn() -> int ![io] { return 0; };");
    assert expr != null;
    assert expr.variant == "Lambda";
    let rt = expr.return_type;
    assert rt != null;
    assert rt.text == "int";
    assert expr.body.statements.length == 1;
    assert expr.body.statements[0].variant == "ReturnStatement";
}

// -------------------------------------------------------------------
// Expression-bodied short form (SFEP-0029, #1683) — `fn(x) => expr`
// desugars to a single-`return` block so the `Expression.Lambda.body`
// shape is identical to the block form downstream.
// -------------------------------------------------------------------
test "lambda expr form: untyped `fn(x) => x * x` desugars to single return" ![io] {
    let expr = first_let_lambda("let f = fn(x) => x * x;");
    assert expr != null;
    assert expr.variant == "Lambda";
    assert expr.parameters.length == 1;
    assert expr.parameters[0].name == "x";
    assert expr.body.statements.length == 1;
    assert expr.body.statements[0].variant == "ReturnStatement";
}

test "lambda expr form: multi-param `fn(x: int, y: int) => x + y` parses" ![io] {
    let expr = first_let_lambda("let f = fn(x: int, y: int) => x + y;");
    assert expr != null;
    assert expr.variant == "Lambda";
    assert expr.parameters.length == 2;
    assert expr.body.statements.length == 1;
    assert expr.body.statements[0].variant == "ReturnStatement";
}

test "lambda expr form: typed head `fn(x: int) -> int => x` keeps return type" ![io] {
    let expr = first_let_lambda("let f = fn(x: int) -> int => x;");
    assert expr != null;
    assert expr.variant == "Lambda";
    let rt = expr.return_type;
    assert rt != null;
    assert rt.text == "int";
    assert expr.body.statements.length == 1;
    assert expr.body.statements[0].variant == "ReturnStatement";
}

// The expr body's `return` value is the full expression to the right of
// `=>` — the desugared `ReturnStatement` carries it, so the block form
// and the short form produce the same statement shape.
test "lambda expr form: return value is the full body expression" ![io] {
    let expr = first_let_lambda("let f = fn(x) => x + 1;");
    assert expr != null;
    assert expr.variant == "Lambda";
    let ret = expr.body.statements[0];
    assert ret.variant == "ReturnStatement";
    let val = ret.expression;
    assert val != null;
    assert val.variant == "Binary";
}

// Block form remains valid — the short form is purely additive.
test "lambda expr form: block form `fn(x) -> int { ... }` still parses (no regression)" ![io] {
    let expr = first_let_lambda("let f = fn(x) -> int { return x; };");
    assert expr != null;
    assert expr.variant == "Lambda";
    assert expr.body.statements.length == 1;
    assert expr.body.statements[0].variant == "ReturnStatement";
}

// -------------------------------------------------------------------
// Effect annotation with NO return type (#2430) — `fn() ![io] { ... }`
// must parse as a lambda even though no `->`/`:` return-type separator
// precedes the effect marker. The `![...]` skip previously ran only
// inside the return-type branch, so with no separator `current` stayed
// parked on `!`; the lambda degraded to `Expression.Raw` and tripped the
// `E0818` fail-closed backstop, blocking bare `spawn fn() ![io] {...}`
// siblings. The return type is absent (null) and the body parses
// structurally.
// -------------------------------------------------------------------
test "lambda effect: `fn() ![io] { ... }` with no return type parses as a lambda (#2430)" ![io] {
    let expr = first_let_lambda("let f = fn() ![io] { return 0; };");
    assert expr != null;
    assert expr.variant == "Lambda";
    assert expr.return_type == null;
    assert expr.body.statements.length == 1;
    assert expr.body.statements[0].variant == "ReturnStatement";
}

// A parameterized effectful lambda with no return type parses too — the
// hoisted skip is independent of the parameter list.
test "lambda effect: `fn(x: int) ![io] { ... }` with no return type parses as a lambda (#2430)" ![io] {
    let expr = first_let_lambda("let f = fn(x: int) ![io] { return x; };");
    assert expr != null;
    assert expr.variant == "Lambda";
    assert expr.return_type == null;
    assert expr.parameters.length == 1;
    assert expr.body.statements.length == 1;
    assert expr.body.statements[0].variant == "ReturnStatement";
}
