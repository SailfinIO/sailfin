// compiler/tests/data/cross_module/shared_types.sfn
// Defines structs and enums that will be imported by consumer modules
struct Point {
    x: number;  // alias-coverage: cross-module fixture preserves number-aliased API
    y: number;  // alias-coverage: cross-module fixture preserves number-aliased API

    fn distance_from_origin(self: Point) -> number {  // alias-coverage: cross-module fixture preserves number-aliased API
        let x_squared = self.x * self.x;
        let y_squared = self.y * self.y;
        return x_squared + y_squared;  // simplified - no sqrt for now
    }
}

struct Rectangle {
    top_left: Point;
    width: number;  // alias-coverage: cross-module fixture preserves number-aliased API
    height: number;  // alias-coverage: cross-module fixture preserves number-aliased API
}

enum Color {
    Red,
    Green,
    Blue,
    Custom {
        r: int;
        g: int;
        b: int;
    }
}

enum Shape {
    Circle {
        center: Point;
        radius: number;  // alias-coverage: cross-module fixture preserves number-aliased API
    }
    Box {
        bounds: Rectangle;
    }
    Empty;
}

fn make_red() -> Color { return Color.Red; }

fn make_circle(x: number, y: number, r: number) -> Shape {  // alias-coverage: cross-module fixture preserves number-aliased API
    return Shape.Circle {
        center: Point { x: x, y: y },
        radius: r
    };
}
