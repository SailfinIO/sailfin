interface Meter {
    fn total(self: Meter) -> int;
}

struct Person implements Meter {
    years: int;

    fn total(self: Person) -> int { return self.years; }
}

fn make_people() -> Person[] {
    return [Person { years: 36 }, Person { years: 42 }];
}

fn total_years(values: Person[]) -> int {
    let mut total: int = 0;
    for person in values { total = total + person.years; }
    return total;
}

fn main() -> int {
    let people = make_people();
    return total_years(people);
}
