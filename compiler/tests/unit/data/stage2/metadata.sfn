interface Meter {
    fn total(self: Meter) -> number;  // alias-coverage: cross-module fixture preserves number-aliased API
}

struct Person implements Meter {
    years: number;  // alias-coverage: cross-module fixture preserves number-aliased API

    fn total(self: Person) -> number {  // alias-coverage: cross-module fixture preserves number-aliased API
        return self.years;
    }
}

fn make_people() -> Person[] {
    return [Person { years: 36 }, Person { years: 42 }];
}

fn total_years(values: Person[]) -> number {  // alias-coverage: cross-module fixture preserves number-aliased API
    let mut total: number = 0;  // alias-coverage: cross-module fixture preserves number-aliased API
    for person in values { total = total + person.years; }
    return total;
}

fn main() -> number {  // alias-coverage: cross-module fixture preserves number-aliased API
    let people = make_people();
    return total_years(people);
}
