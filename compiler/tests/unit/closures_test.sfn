fn _apply(value -> number, f -> (number) -> number) -> number {
    return f(value);
}

fn _apply_twice(value -> number, f -> (number) -> number) -> number {
    return f(f(value));
}

fn _compose(f -> (number) -> number, g -> (number) -> number) -> (number) -> number {
    return fn(x -> number) -> number { return f(g(x)); };
}

fn _double(x -> number) -> number {
    return x * 2;
}

fn _increment(x -> number) -> number {
    return x + 1;
}

test "closures: inline lambda computes correctly" {
    let add = fn(x -> number, y -> number) -> number { return x + y; };
    assert add(3, 4) == 7;
}

test "closures: lambda assigned to variable and invoked" {
    let square = fn(x -> number) -> number { return x * x; };
    assert square(5) == 25;
    assert square(0) == 0;
}

test "closures: higher-order apply with named function" {
    assert _apply(6, _double) == 12;
    assert _apply(0, _increment) == 1;
}

test "closures: apply with inline lambda" {
    let result = _apply(10, fn(x -> number) -> number { return x - 3; });
    assert result == 7;
}

test "closures: apply_twice doubles increment" {
    assert _apply_twice(5, _increment) == 7;
    assert _apply_twice(3, _double) == 12;
}

test "closures: lambda captures surrounding let binding" {
    let offset -> number = 100;
    let add_offset = fn(x -> number) -> number { return x + offset; };
    assert add_offset(5) == 105;
    assert add_offset(0) == 100;
}

test "closures: composed function applies both transforms" {
    let double_then_inc = _compose(_increment, _double);
    assert double_then_inc(3) == 7;
}

test "closures: lambda used inline with map" {
    let nums = [1, 2, 3];
    let result = nums.map(fn(x) -> number { return x + 10; });
    assert result[0] == 11;
    assert result[1] == 12;
    assert result[2] == 13;
}

test "closures: lambda used inline with filter" {
    let nums = [1, 2, 3, 4, 5];
    let big = nums.filter(fn(x) -> boolean { return x > 3; });
    assert big.length == 2;
    assert big[0] == 4;
    assert big[1] == 5;
}
