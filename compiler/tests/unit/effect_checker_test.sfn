    let v = violations[0];
    let mut found_io: boolean = false;
    let mut i: int = 0;
    loop {
        if i >= v.missing_effects.length { break; }
        if v.missing_effects[i] == "io.console" { found_io = true; }
        i += 1;
    }
    assert found_io;
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.lexeme == "console";
}

test "effect (#1183): http.download Member call requires net AND io from the registry" {
    // Registry-driven proof. The descriptor for `http.download` carries
    // `effects: ["net.http", "io"]`, while `http.get` carries
    // `["net.http"]`. A hardcoded `root == "http" -> net` chain could
    // never produce the `io` requirement here — it can only come from
    // `effects_for_callee_target` reading the descriptor's effects.
    let stmt = _routine_with_member_call("save_remote", [], 1, "http", "download", 9, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert _effects_contains(v.missing_effects, "net.http");
    assert _effects_contains(v.missing_effects, "io");
}

test "effect (#1183): http.download declaring ![net, io] is clean" {
    let stmt = _routine_with_member_call("save_remote_ok", ["net", "io"], 1, "http", "download", 9, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 0;
}

test "effect (#1183): fs.read_bytes Member call requires io from the registry" {
    // Exact descriptor `fs.read_bytes` -> io, beyond the `fs.exists`
    // case above — exercises a different registry row via the accessor.
    let stmt = _routine_with_member_call("slurp", [], 1, "fs", "read_bytes", 4, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    assert _effects_contains(violations[0].missing_effects, "io.fs");
}

test "effect (#1183): fs.read Member call (no exact row) still requires io via namespace union" {
    // `fs.read` has no exact descriptor; the namespace-union fallback in
    // `effects_for_callee_target` must still derive io from the `fs.*`
    // family so conservative coverage is never dropped — an
    // under-approximation here would be a capability escape.
    let stmt = _routine_with_member_call("reader", [], 1, "fs", "read", 4, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    assert _effects_contains(violations[0].missing_effects, "io.fs");
}

test "effect (#1183): console.log Member call requires io from the registry" {
    let stmt = _routine_with_member_call("logger", [], 1, "console", "log", 4, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    assert _effects_contains(violations[0].missing_effects, "io.console");
}

test "effect (#1601): websocket.send Member call requires net from the registry" {
    // `websocket.*` is now registry-derived (#1601): the
    // `websocket.send` metadata row resolves to `["net"]` via
    // `effects_for_callee_target`, replacing the former hardcoded
    // `if root == "websocket"` check. Lock that net enforcement is NOT
    // regressed by the registry refactor.
    let stmt = _routine_with_member_call("push", [], 1, "websocket", "send", 4, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    assert _effects_contains(violations[0].missing_effects, "net.ws");
}

test "effect (#1601): websocket.serve Member call requires net from the registry" {
    // A second op beyond `send` — proves the namespace surface (not a
    // single hardcoded member) resolves to net via the registry.
    let stmt = _routine_with_member_call("host", [], 1, "websocket", "serve", 4, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    assert _effects_contains(violations[0].missing_effects, "net.ws");
}

test "effect (#1601): websocket.broadcast (no exact row) requires net via namespace union" {
    // `websocket.broadcast` has no exact descriptor; the namespace-union
    // fallback in `effects_for_callee_target` must still derive net from
    // the `websocket.*` family so conservative coverage is never dropped
    // for an op the future runtime might add.
    let stmt = _routine_with_member_call("fanout", [], 1, "websocket", "broadcast", 4, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    assert _effects_contains(violations[0].missing_effects, "net.ws");
}

test "effect (#1601): websocket.close declaring ![net] is clean" {
    // Use `close` to isolate the #1601 net requirement cleanly. (`send`/
    // `receive` also match the object-agnostic channel send/receive arm, which
    // is now effect-transparent under SFEP-0049 — it adds nothing — so
    // `websocket.send` requires only net today; `close` keeps this test
    // independent of that arm regardless.)
    let stmt = _routine_with_member_call("close_ok", ["net"], 1, "websocket", "close", 4, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 0;
}

test "effect (#1601): Call-form serve requires both io and net from the registry" {
    // The Call-arm `serve` is now registry-driven (#1601), replacing the
    // former hardcoded net-only `if name == "serve"`. The `serve`
    // metadata row carries `["io", "net"]`, so a bare `serve(...)` Call
    // missing both effects must surface BOTH — impossible under the old
    // net-only check. (Real `serve(...)` source commits to the `Serve`
    // AST node; this exercises the latent Call-callee form via the
    // direct-AST helper, mirroring the `spawn` test.)
    let stmt = _routine_with_bare_call("srv", [], 50, "serve", 200, 4);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert _effects_contains(v.missing_effects, "net");
    assert _effects_contains(v.missing_effects, "io");
}

test "effect (#1601): Call-form serve declaring ![io, net] is clean" {
    let stmt = _routine_with_bare_call("srv_ok", ["io", "net"], 50, "serve", 200, 4);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 0;
}

// Direct accessor assertions pinning the #1601 acceptance criteria at
// the registry level, independent of the effect-checker wiring above.
test "registry (#1601): effects_for_callee_target(\"websocket.\") returns net" {
    let effects = effects_for_callee_target("websocket.");
    assert effects.length == 1;
    assert _effects_contains(effects, "net.ws");
}

test "registry (#1601): effects_for_callee_target(\"websocket.send\") contains net" {
    let effects = effects_for_callee_target("websocket.send");
    assert _effects_contains(effects, "net.ws");
}

test "registry (#1601): effects_for_callee_target(\"serve\") contains io and net" {
    let effects = effects_for_callee_target("serve");
    assert _effects_contains(effects, "io");
    assert _effects_contains(effects, "net");
}

test "effect violation: AST trigger overrides signature fallback" {
    // Lock the precedence rule in: when the body walker captures a
    // per-call-site trigger, that trigger wins over the signature
    // token. Otherwise effect diagnostics on long routines would
    // continue carets at the declaration. Uses a bare `sleep` (clock) as the
    // effect generator — `spawn` is effect-transparent post-SFEP-0049 and no
    // longer yields a violation to caret.
    let stmt = _routine_with_bare_call("longfn", [], 50, "sleep", 200, 4);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert v.signature_token != null;
    let sig: Token? = v.signature_token;
    assert sig.line == 50;
    // 150 lines between declaration and call site — the diagnostic
    // must caret at the call (200), not the declaration (50).
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.line == 200;
}

// -------------------------------------------------------------------
// B3 — body_open_token plumbing
// -------------------------------------------------------------------
//
// `EffectViolation` now carries `body_open_token`, sourced from
// `body.tokens[0]` in `analyze_routine`. The renderer in
// `diagnostics_render.effect_violation_to_diagnostic` reads this slot
// to construct the structured `FixSuggestion` (insert `![effects] `
// at the brace column). Tests below construct `Block { tokens: [...] }`
// fixtures directly to exercise the brace-capture path.
fn _brace_token(line: int, column: int) -> Token {
    return Token {
        kind: TokenKind.Symbol(),
        lexeme: "{",
        line: line,
        column: column
    };
}

fn _routine_with_brace(name: string, sig_line: int, brace_line: int, brace_column: int) -> Statement {
    let sig_span = _span(sig_line, 4);
    let mut block_tokens: Token[] = [];
    block_tokens.push(_brace_token(brace_line, brace_column));
    let body_block = Block {
        tokens: block_tokens,
        text: "",
        statements: [_io_member_body_stmt()]
    };
    let mut empty_decorators: Decorator[] = [];
    let mut empty_effects: string[] = [];
    return Statement.FunctionDeclaration {
        signature: _signature(name, empty_effects, sig_span),
        body: body_block,
        decorators: empty_decorators,
        is_unsafe: false
    };
}

test "effect violation: body_open_token captures the body's opening brace" {
    let stmt = _routine_with_brace("noisy", 3, 3, 38);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert v.body_open_token != null;
    let brace: Token? = v.body_open_token;
    assert brace.line == 3;
    assert brace.column == 38;
    assert brace.lexeme == "{";
}

test "effect violation: body_open_token is null when block has no tokens" {
    // Synthesized routines (no parser-captured tokens) leave Block
    // tokens empty. The renderer must accept the null and skip
    // structured-suggestion generation; the human-readable
    // suggestion line in the message stays.
    let stmt = _make_io_violating_routine("nameless", [], 7);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    assert violations[0].body_open_token == null;
}

// -------------------------------------------------------------------
// G1b (#1184): local + member user-defined callee resolution
// -------------------------------------------------------------------
// Build a top-level `fn` declaration with an empty body and the given
// declared effects. Stands in for a same-module callee whose signature
// the checker resolves when another routine calls it by bare name.
fn _fn_decl_with_effects(name: string, effects: string[], sig_line: int) -> Statement {
    let mut empty_decorators: Decorator[] = [];
    return Statement.FunctionDeclaration {
        signature: _signature(name, effects, _span(sig_line, 4)),
        body: _empty_block(),
        decorators: empty_decorators,
        is_unsafe: false
    };
}

// Build `import { <name> } from "<source>";` so the localizer keeps the
// synthesized import-table entry for `<name>` in scope for the program.
fn _import_decl(name: string, source: string) -> Statement {
    let spec = ImportSpecifier { name: name, alias: null };
    return Statement.ImportDeclaration {
        import_specifiers: [spec],
        source: source
    };
}

test "effect violation: local callee propagates its declared effects (E0400)" {
    // `fn does_io() ![io] {}` declared at line 4; `fn caller()` at line
    // 10 calls it without declaring `![io]`. The transitive requirement
    // surfaces on `caller` as an in-module E0400 (not the cross-module
    // E0402 reserved for imported callees).
    let callee = _fn_decl_with_effects("does_io", ["io"], 4);
    let caller = _routine_with_bare_call("caller", [], 10, "does_io", 11, 9);
    let program = Program { statements: [callee, caller] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert v.routine_name == "caller";
    assert _effects_contains(v.missing_effects, "io");
    // Trigger carets at the call site, not the callee declaration.
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.line == 11;
    assert trig.lexeme == "does_io";
    // In-module callee → E0400, never the cross-module E0402.
    assert code_for_missing_effect(v.missing_effects, v.requirements) == "E0400";
}

test "effect ok: caller declaring the local callee's effect is clean" {
    let callee = _fn_decl_with_effects("does_io", ["io"], 4);
    let caller = _routine_with_bare_call("caller", ["io"], 10, "does_io", 11, 9);
    let program = Program { statements: [callee, caller] };
    let violations = validate_effects(program);
    assert violations.length == 0;
}

test "effect ok: a pure local callee requires nothing of its caller" {
    let callee = _fn_decl_with_effects("pure_helper", [], 4);
    let caller = _routine_with_bare_call("caller", [], 10, "pure_helper", 11, 9);
    let program = Program { statements: [callee, caller] };
    let violations = validate_effects(program);
    assert violations.length == 0;
}

test "effect violation: member callee mod.fetch() requires imported net (E0402)" {
    // `import { fetch } from "remote";` keeps the synthesized table
    // entry in scope; `mod.fetch()` then requires `![net]` of the
    // caller, carated at the member expression (`fetch`), as a
    // cross-module E0402.
    let import_stmt = _import_decl("fetch", "remote");
    let caller = _routine_with_member_call("caller", [], 4, "mod", "fetch", 17, 9);
    let program = Program { statements: [import_stmt, caller] };
    let table = append_import_function(empty_import_symbols(), "fetch", ["net"]);
    let violations = validate_effects_with_imports(program, table);
    assert violations.length == 1;
    let v = violations[0];
    assert v.routine_name == "caller";
    assert _effects_contains(v.missing_effects, "net");
    // Caret lands on the member expression token, not the `mod` object.
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.line == 17;
    assert trig.lexeme == "fetch";
    // Imported callee → cross-module E0402.
    assert code_for_missing_effect(v.missing_effects, v.requirements) == "E0402";
}

test "effect ok: caller declaring the imported member's effect is clean" {
    let import_stmt = _import_decl("fetch", "remote");
    let caller = _routine_with_member_call("caller", ["net"], 4, "mod", "fetch", 17, 9);
    let program = Program { statements: [import_stmt, caller] };
    let table = append_import_function(empty_import_symbols(), "fetch", ["net"]);
    let violations = validate_effects_with_imports(program, table);
    assert violations.length == 0;
}

// -------------------------------------------------------------------
// Gate G6: validate_recognized_effects (E0404, SFEP-0017 D1)
// -------------------------------------------------------------------
test "recognized effects: an unrecognized root produces one violation" {
    let stmt = _fn_decl_with_effects("write_to_disk", ["disk"], 5);
    let program = Program { statements: [stmt] };
    let violations = validate_recognized_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert v.routine_name == "write_to_disk";
    assert v.unrecognized_effects.length == 1;
    assert v.unrecognized_effects[0] == "disk";
}

test "recognized effects: the pure sentinel is not flagged" {
    let stmt = _fn_decl_with_effects("pure_helper", ["pure"], 5);
    let program = Program { statements: [stmt] };
    let violations = validate_recognized_effects(program);
    assert violations.length == 0;
}

test "recognized effects: canonical effects are not flagged" {
    let stmt = _fn_decl_with_effects("with_io", ["io"], 5);
    let program = Program { statements: [stmt] };
    let violations = validate_recognized_effects(program);
    assert violations.length == 0;
}

test "recognized effects: multiple canonical effects are not flagged" {
    let stmt = _fn_decl_with_effects("with_net_and_clock", ["net", "clock"], 5);
    let program = Program { statements: [stmt] };
    let violations = validate_recognized_effects(program);
    assert violations.length == 0;
}

test "recognized effects: a nested fn with an unrecognized root is flagged" {
    // SFEP-0042: a nested/local `fn g() ![disk] { }` declared inside a
    // routine body must not bypass E0404 just because it is not top-level.
    // The missing-effect path walks nested fns, so recognition must too.
    let nested = _fn_decl_with_effects("g", ["disk"], 5);
    let mut outer_decorators: Decorator[] = [];
    let outer_body = Block { tokens: [], text: "", statements: [nested] };
    let outer = Statement.FunctionDeclaration {
        signature: _signature("outer", ["io"], _span(4, 4)),
        body: outer_body,
        decorators: outer_decorators,
        is_unsafe: false
    };
    let program = Program { statements: [outer] };
    let violations = validate_recognized_effects(program);
    assert violations.length == 1;
    assert violations[0].routine_name == "g";
    assert violations[0].unrecognized_effects[0] == "disk";
}
