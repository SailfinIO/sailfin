// Unit tests for compiler/src/effect_taxonomy.sfn and the
// Phase-A enrichments to compiler/src/effect_checker.sfn:
// `EffectViolation` now carries `signature_token`, `trigger`, and
// `severity` fields, populated from the routine's signature span.
// See docs/proposals/0008-effect-validation.md (Part 5, Phase A) for the
// full design.
//
// The tests construct AST values via small helper functions to stay
// flat — some seed compilers previously segfaulted on deeply nested
// struct-literal initialisers in test bodies (see
// check_tool_test.sfn preamble for the same dodge).
import {
    Block,
    Decorator,
    Expression,
    FieldDeclaration,
    FunctionSignature,
    ImportSpecifier,
    MethodDeclaration,
    Program,
    SourceSpan,
    Statement,
    TypeAnnotation,
    TypeParameter
} from "../../src/ast";
import { code_for_missing_effect } from "../../src/diagnostics_render";
import {
    EffectViolation,
    validate_effects,
    validate_effects_with_imports,
    validate_recognized_effects
} from "../../src/effect_checker";
import { append_import_function, empty_import_symbols } from "../../src/effect_imports";
import { canonical_effects, is_canonical_effect } from "../../src/effect_taxonomy";
import { effects_for_callee_target } from "../../src/llvm/runtime_helpers";
import { Token } from "../../src/token";

// -------------------------------------------------------------------
// Builder helpers
// -------------------------------------------------------------------
fn _empty_block() -> Block {
    return Block { tokens: [], text: "", statements: [] };
}

fn _span(line: int, column: int) -> SourceSpan {
    return SourceSpan {
        start_line: line,
        start_column: column,
        end_line: line,
        end_column: column + 1
    };
}

fn _signature(name: string, effects: string[], span: SourceSpan?) -> FunctionSignature {
    return FunctionSignature {
        name: name,
        is_async: false,
        parameters: [],
        return_type: null,
        effects: effects,
        type_parameters: [],
        name_span: span
    };
}

// A structured `print.info(...)` body statement that triggers an `![io]`
// requirement via the name-resolution detector — the production path after
// the text-pattern fallback was deleted (#1186, epic #1180 Phase G). Inner
// spans are left null, so the requirement's per-call-site trigger is null and
// the violation falls back to `signature_token` for its caret; tests that
// want a call-site trigger build a spanned body via `_routine_with_member_call`.
fn _io_member_body_stmt() -> Statement {
    let object = Expression.Identifier { name: "print", span: null };
    let member_expr = Expression.Member {
        object: object,
        member: "info",
        span: null
    };
    let no_args: Expression[] = [];
    let call_expr = Expression.Call {
        callee: member_expr,
        arguments: no_args,
        span: null
    };
    return Statement.ExpressionStatement { expression: call_expr, span: null };
}

// Build a FunctionDeclaration statement whose body triggers an `![io]`
// requirement (a `print.info(...)` call) via the name-resolution detector.
// Used by the span-attribution / severity / suppression tests below as a
// convenient violation generator; the body carries no spans, so the
// violation's trigger falls back to the signature token.
fn _make_io_violating_routine(name: string, declared_effects: string[], span_line: int) -> Statement {
    let span = _span(span_line, 4);
    let body_block = Block {
        tokens: [],
        text: "",
        statements: [_io_member_body_stmt()]
    };
    let mut empty_decorators: Decorator[] = [];
    return Statement.FunctionDeclaration {
        signature: _signature(name, declared_effects, span),
        body: body_block,
        decorators: empty_decorators,
        is_unsafe: false
    };
}

// Build a FunctionDeclaration whose body is a structured `spawn worker()`
// expression (an AST `Spawn` node, not a `Raw` text body). `worker` is an
// unresolved, effect-free callee, so under effect-transparency (SFEP-0049)
// the spawn attributes nothing — exercising the #1082 effect-checker descent
// (the old `"spawn("` text heuristic misses the prefix syntax) and the
// "never a phantom io" fallback for an unresolved spawn target.
fn _make_spawn_routine(name: string, declared_effects: string[], span_line: int) -> Statement {
    let span = _span(span_line, 4);
    let callee = Expression.Identifier { name: "worker", span: null };
    let mut no_args: Expression[] = [];
    let call = Expression.Call {
        callee: callee,
        arguments: no_args,
        span: null
    };
    let spawn_expr = Expression.Spawn {
        operand: call,
        span: span,
        kind: ""
    };
    let body_stmt = Statement.ExpressionStatement {
        expression: spawn_expr,
        span: null
    };
    let body_block = Block {
        tokens: [],
        text: "",
        statements: [body_stmt]
    };
    let mut empty_decorators: Decorator[] = [];
    return Statement.FunctionDeclaration {
        signature: _signature(name, declared_effects, span),
        body: body_block,
        decorators: empty_decorators,
        is_unsafe: false
    };
}

// Build a FunctionDeclaration whose body is `spawn print.info(...)` — the
// spawned operand itself requires `io`. Under effect-transparency (SFEP-0049)
// the `spawn` primitive contributes nothing, so the caller must declare
// exactly the spawned body's effects; a `[]` declaration under-declares `io`
// and violates — the positive counterpart proving io-body propagation still
// enforces after the primitive stopped fabricating a fixed `io`.
fn _make_spawn_io_routine(name: string, declared_effects: string[], span_line: int) -> Statement {
    let span = _span(span_line, 4);
    let object = Expression.Identifier { name: "print", span: null };
    let member_expr = Expression.Member {
        object: object,
        member: "info",
        span: null
    };
    let no_args: Expression[] = [];
    let io_call = Expression.Call {
        callee: member_expr,
        arguments: no_args,
        span: null
    };
    let spawn_expr = Expression.Spawn {
        operand: io_call,
        span: span,
        kind: ""
    };
    let body_stmt = Statement.ExpressionStatement {
        expression: spawn_expr,
        span: null
    };
    let body_block = Block {
        tokens: [],
        text: "",
        statements: [body_stmt]
    };
    let mut empty_decorators: Decorator[] = [];
    return Statement.FunctionDeclaration {
        signature: _signature(name, declared_effects, span),
        body: body_block,
        decorators: empty_decorators,
        is_unsafe: false
    };
}

fn _effects_contains(effects: string[], target: string) -> boolean {
    let mut index: int = 0;
    loop {
        if index >= effects.length { break; }
        if effects[index] == target { return true; }
        index += 1;
    }
    return false;
}

// -------------------------------------------------------------------
// Canonical taxonomy — locked at 1.0
// -------------------------------------------------------------------
test "canonical_effects: returns the locked 1.0 set" {
    let effects = canonical_effects();
    // Six effects, ordered for stable diagnostic rendering.
    assert effects.length == 6;
    assert effects[0] == "clock";
    assert effects[1] == "gpu";
    assert effects[2] == "io";
    assert effects[3] == "model";
    assert effects[4] == "net";
    assert effects[5] == "rand";
}

test "is_canonical_effect: accepts every locked-in name" {
    assert is_canonical_effect("io");
    assert is_canonical_effect("net");
    assert is_canonical_effect("clock");
    assert is_canonical_effect("rand");
    // §7.2 decision: `model` is reserved at 1.0 even though `sfn/ai`
    // is post-1.0. Regression-guard the reservation here so a future
    // refactor that "tidies up the taxonomy" can't quietly drop it.
    assert is_canonical_effect("model");
    // §7.4-adjacent: `gpu` is reserved at 1.0 for the same forward-
    // compatibility reason.
    assert is_canonical_effect("gpu");
}

test "is_canonical_effect: rejects non-canonical names" {
    // None of these are part of the 1.0 set. The checker must reject
    // them so user-defined effect names can't sneak through and
    // create silent capability holes when Phase F's capability
    // cross-check lands.
    assert ! is_canonical_effect("filesystem");
    assert ! is_canonical_effect("io_extra");
    assert ! is_canonical_effect("");
    assert ! is_canonical_effect("IO");
    assert ! is_canonical_effect("net2");
}

// -------------------------------------------------------------------
// EffectViolation source-span attribution
// -------------------------------------------------------------------
test "effect violation: signature_token populated from name_span" {
    let stmt = _make_io_violating_routine("boom", [], 7);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert v.routine_name == "boom";
    assert v.signature_token != null;
    let tok: Token? = v.signature_token;
    assert tok.line == 7;
    assert tok.column == 4;
    assert tok.lexeme == "boom";
}

test "effect violation: trigger falls back to signature_token when no call-site span" {
    // A violation whose missing requirement carries no per-call-site
    // trigger (the body's effectful call has null spans — e.g. a
    // synthesized routine or a parser-recovery edge) must fall back to
    // signature_token so the diagnostic still carets at the declaration.
    // B1 promotes the primary path (Identifier / Member walk) to
    // per-call-site triggers when spans are present; this locks in the
    // fallback for the span-less case.
    let stmt = _make_io_violating_routine("ping", [], 12);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.line == 12;
    assert trig.column == 4;
    assert trig.lexeme == "ping";
}

// -------------------------------------------------------------------
// Concurrency-node effect descent (#1082)
// -------------------------------------------------------------------
test "effect transparency: spawn of an unresolved/pure body requires no effect" {
    // Effect-transparency (SFEP-0049): `spawn worker()` over an unresolved
    // (effect-free) callee attributes nothing — the primitive contributes no
    // effect of its own and there is no visible body effect to inherit — so a
    // routine declaring `[]` type-checks clean. This is the canonical witness
    // of the "never a phantom io" fallback for an unresolved spawn target.
    let stmt = _make_spawn_routine("launcher", [], 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 0;
}

test "effect transparency: spawn of an io body propagates io" {
    // The spawned body's effects propagate to the caller: a `spawn print.info(...)`
    // body requires `io`, so a routine declaring `[]` under-declares and
    // violates — proving io-body propagation still enforces (SFEP-0049).
    let stmt = _make_spawn_io_routine("leaky", [], 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    assert violations[0].routine_name == "leaky";
}

test "effect transparency: spawn over-declaring io type-checks clean" {
    // Over-declaration remains legal: a routine may declare `![io]` even though
    // its pure `spawn worker()` body requires nothing (SFEP-0049).
    let mut io_effects: string[] = ["io"];
    let stmt = _make_spawn_routine("ok", io_effects, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 0;
}

test "effect violation: severity defaults to error" {
    let stmt = _make_io_violating_routine("err", [], 3);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    // Phase A hardcodes "error" at the factory; Phase B will wire
    // `SAILFIN_EFFECT_ENFORCE` to flip this to "warning". Lock the
    // current default in so Phase B's wiring is an obvious change.
    assert violations[0].severity == "error";
}

test "effect violation: routines without name_span produce a null trigger" {
    // A FunctionDeclaration with `name_span: null` (not currently
    // produced by the parser, but possible for synthesized routines)
    // should still produce a violation, with `signature_token` and
    // `trigger` left null. The renderer falls back to `file_path`-
    // only rendering when primary is null, so this case must not
    // crash.
    let body_block = Block {
        tokens: [],
        text: "",
        statements: [_io_member_body_stmt()]
    };
    let mut empty_decorators: Decorator[] = [];
    let stmt = Statement.FunctionDeclaration {
        signature: _signature("nameless", [], null),
        body: body_block,
        decorators: empty_decorators,
        is_unsafe: false
    };
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    assert violations[0].signature_token == null;
    assert violations[0].trigger == null;
    assert violations[0].severity == "error";
}

test "effect violation: declared effect suppresses violation" {
    // A function that declares the right effect should produce zero
    // violations. Smoke-test the happy path so we know the
    // span-attribution change didn't regress the underlying detection.
    let stmt = _make_io_violating_routine("ok", ["io"], 1);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 0;
}

// -------------------------------------------------------------------
// Regressions for PR #241 review feedback
// -------------------------------------------------------------------
test "effect violation: struct method uses bare identifier in token lexeme" {
    // PR #241 review #1: when `analyze_routine` is called for a
    // struct method, the qualified `routine_name` is `Struct.method`
    // but the synthesized Token.lexeme must be the bare method
    // identifier — otherwise the renderer's caret width covers the
    // wrong span. Lock the bare-vs-qualified split in.
    let span = _span(5, 8);
    let body_block = Block {
        tokens: [],
        text: "",
        statements: [_io_member_body_stmt()]
    };
    let mut empty_decorators: Decorator[] = [];
    let method_sig = _signature("noisy", [], span);
    let method = MethodDeclaration {
        signature: method_sig,
        body: body_block,
        decorators: empty_decorators
    };
    let mut empty_type_params: TypeParameter[] = [];
    let mut empty_implements: TypeAnnotation[] = [];
    let mut empty_fields: FieldDeclaration[] = [];
    let mut struct_decorators: Decorator[] = [];
    let stmt = Statement.StructDeclaration {
        name: "Speaker",
        name_span: null,
        type_parameters: empty_type_params,
        implements_types: empty_implements,
        fields: empty_fields,
        methods: [method],
        decorators: struct_decorators
    };
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    // routine_name carries the qualified display string for the
    // user-facing message…
    assert v.routine_name == "Speaker.noisy";
    // …but Token.lexeme is the bare identifier so the caret width
    // matches `noisy`'s actual source span.
    assert v.signature_token != null;
    let tok: Token? = v.signature_token;
    assert tok.lexeme == "noisy";
    assert tok.line == 5;
    assert tok.column == 8;
}

test "effect violation: TestDeclaration plumbs name_span" {
    // PR #241 review #2: `Statement.TestDeclaration.name_span` is
    // recorded by the parser; analyze_statement must thread it into
    // the synthesized FunctionSignature so test diagnostics get the
    // same signature-token attribution functions/methods get.
    let span = _span(42, 6);
    let body_block = Block {
        tokens: [],
        text: "",
        statements: [_io_member_body_stmt()]
    };
    let mut empty_decorators: Decorator[] = [];
    let mut empty_effects: string[] = [];
    let stmt = Statement.TestDeclaration {
        name: "exercises print",
        name_span: span,
        body: body_block,
        effects: empty_effects,
        decorators: empty_decorators
    };
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    // routine_name still includes the `test "name"` qualifier for
    // the diagnostic message.
    assert v.routine_name == "test exercises print";
    // …but the Token comes from the parser-recorded span. Lexeme is
    // the bare test name (matches the qualified-name fix in #1).
    assert v.signature_token != null;
    let tok: Token? = v.signature_token;
    assert tok.line == 42;
    assert tok.column == 6;
    assert tok.lexeme == "exercises print";
}

// -------------------------------------------------------------------
// B1 — Per-Expression call-site trigger plumbing
// -------------------------------------------------------------------
//
// `EffectRequirement` now carries a `trigger: Token?`. The body
// walker populates it from `Expression.Identifier.span` (for bare
// callees like `spawn(...)`) and `Expression.Member.object.span`
// (for `fs.<x>` / `print.<x>` / `http.<x>` etc.). `analyze_routine`
// picks the first non-null trigger from the missing-requirements
// list as the violation's `trigger` so the diagnostic carets at the
// offending call rather than at the function declaration. The
// fallback to signature_token is exercised by the span-less test
// above.
//
// These tests construct AST bodies directly so we don't depend on
// the parser. They exercise the two trigger-emitting branches of
// `collect_effects_from_expression`: `Member` (with `Identifier`
// object, e.g. `fs.exists(...)`) and `Call` with `Identifier`
// callee (e.g. `spawn(...)`).
fn _routine_with_member_call(name: string, declared_effects: string[], sig_line: int, namespace: string, member: string, namespace_line: int, namespace_column: int) -> Statement {
    let sig_span = _span(sig_line, 4);
    let object_span = _span(namespace_line, namespace_column);
    let member_span = _span(namespace_line, namespace_column + namespace.length
        + 1);
    let object = Expression.Identifier { name: namespace, span: object_span };
    let member_expr = Expression.Member {
        object: object,
        member: member,
        span: member_span
    };
    let no_args: Expression[] = [];
    let call_expr = Expression.Call {
        callee: member_expr,
        arguments: no_args,
        span: null
    };
    let body_stmt = Statement.ExpressionStatement {
        expression: call_expr,
        span: null
    };
    let body_block = Block {
        tokens: [],
        text: "",
        statements: [body_stmt]
    };
    let mut empty_decorators: Decorator[] = [];
    return Statement.FunctionDeclaration {
        signature: _signature(name, declared_effects, sig_span),
        body: body_block,
        decorators: empty_decorators,
        is_unsafe: false
    };
}

fn _routine_with_bare_call(name: string, declared_effects: string[], sig_line: int, callee: string, call_line: int, call_column: int) -> Statement {
    let sig_span = _span(sig_line, 4);
    let call_span = _span(call_line, call_column);
    let callee_expr = Expression.Identifier { name: callee, span: call_span };
    let no_args: Expression[] = [];
    let call_expr = Expression.Call {
        callee: callee_expr,
        arguments: no_args,
        span: null
    };
    let body_stmt = Statement.ExpressionStatement {
        expression: call_expr,
        span: null
    };
    let body_block = Block {
        tokens: [],
        text: "",
        statements: [body_stmt]
    };
    let mut empty_decorators: Decorator[] = [];
    return Statement.FunctionDeclaration {
        signature: _signature(name, declared_effects, sig_span),
        body: body_block,
        decorators: empty_decorators,
        is_unsafe: false
    };
}

test "effect violation: Member call carets at the namespace identifier" {
    // `fs.exists(...)` should caret at `fs` (the namespace) — that's
    // what flags the operation as effectful. Function declared at
    // line 4; the offending call is at line 17. The caret must land
    // on the call, not the declaration.
    let stmt = _routine_with_member_call("read_config", [], 4, "fs", "exists", 17, 9);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert v.routine_name == "read_config";
    // signature_token still points at the declaration site for fix-it
    // suggestions ("add ![io] here").
    assert v.signature_token != null;
    let sig: Token? = v.signature_token;
    assert sig.line == 4;
    // …but trigger now points at the call site.
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.line == 17;
    assert trig.column == 9;
    assert trig.lexeme == "fs";
}

test "effect violation: print.<x> Member call carets at print" {
    let stmt = _routine_with_member_call("noisy", [], 1, "print", "info", 22, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.line == 22;
    assert trig.column == 5;
    assert trig.lexeme == "print";
}

test "effect violation: http.<x> Member call carets at http" {
    let stmt = _routine_with_member_call("fetch_user", [], 100, "http", "get", 105, 12);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.line == 105;
    assert trig.column == 12;
    assert trig.lexeme == "http";
    // E0400 message text references the namespace, not the member.
    let mut found_net: boolean = false;
    let mut i: int = 0;
    loop {
        if i >= v.missing_effects.length { break; }
        if v.missing_effects[i] == "net.http" { found_net = true; }
        i += 1;
    }
    assert found_net;
}

// Regression for PR #869 (issue #828): the postfix `?` operator parses
// to `Expression.TryOperator { operand }`. The body walker must recurse
// into `operand` so effectful calls inside it (`fs.read()?`) still
// surface — otherwise `?` would silently hide its operand's effects
// from `sfn check`, a blind spot in the headline effect-enforcement
// feature. This wraps the same `fs.read()` Member call the tests above
// exercise in a TryOperator and asserts the io violation is unchanged.
fn _routine_with_try_member_call(name: string, declared_effects: string[], sig_line: int, namespace: string, member: string, namespace_line: int, namespace_column: int) -> Statement {
    let sig_span = _span(sig_line, 4);
    let object_span = _span(namespace_line, namespace_column);
    let member_span = _span(namespace_line, namespace_column + namespace.length
        + 1);
    let object = Expression.Identifier { name: namespace, span: object_span };
    let member_expr = Expression.Member {
        object: object,
        member: member,
        span: member_span
    };
    let no_args: Expression[] = [];
    let call_expr = Expression.Call {
        callee: member_expr,
        arguments: no_args,
        span: null
    };
    let try_expr = Expression.TryOperator { operand: call_expr, span: null };
    let body_stmt = Statement.ExpressionStatement {
        expression: try_expr,
        span: null
    };
    let body_block = Block {
        tokens: [],
        text: "",
        statements: [body_stmt]
    };
    let mut empty_decorators: Decorator[] = [];
    return Statement.FunctionDeclaration {
        signature: _signature(name, declared_effects, sig_span),
        body: body_block,
        decorators: empty_decorators,
        is_unsafe: false
    };
}

test "effect violation: TryOperator operand still surfaces fs io effect" {
    let stmt = _routine_with_try_member_call("read_config", [], 4, "fs", "read", 17, 9);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    assert v.routine_name == "read_config";
    let mut found_io: boolean = false;
    let mut i: int = 0;
    loop {
        if i >= v.missing_effects.length { break; }
        if v.missing_effects[i] == "io.fs" { found_io = true; }
        i += 1;
    }
    assert found_io;
    // The caret still lands on the namespace identifier inside the `?`.
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.line == 17;
    assert trig.column == 9;
    assert trig.lexeme == "fs";
}

test "effect violation: declared ![io] suppresses TryOperator operand violation" {
    // Mirror of the happy path — declaring the effect clears it even
    // through the `?` wrapper, confirming the pass-through doesn't
    // double-count or spuriously fire.
    let stmt = _routine_with_try_member_call("read_config", ["io"], 4, "fs", "read", 17, 9);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 0;
}

test "effect transparency: bare spawn() Call requires no effect" {
    // Effect-transparency (SFEP-0049): the Call-form `spawn(...)` arm appends
    // the `spawn_task` row's (now empty) effects, so a bare `spawn(...)` over
    // no effectful argument produces no violation — the Call-form went
    // transparent alongside the prefix form. (Caret-at-callee for a primitive
    // that DOES carry an effect stays covered by the sleep/print/console
    // bare-call tests below.)
    let stmt = _routine_with_bare_call("worker", [], 8, "spawn", 11, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 0;
}

test "effect violation: bare sleep() Call carets at the callee for clock effect" {
    let stmt = _routine_with_bare_call("backoff", [], 30, "sleep", 33, 9);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    let mut found_clock: boolean = false;
    let mut i: int = 0;
    loop {
        if i >= v.missing_effects.length { break; }
        if v.missing_effects[i] == "clock" { found_clock = true; }
        i += 1;
    }
    assert found_clock;
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.line == 33;
    assert trig.column == 9;
    assert trig.lexeme == "sleep";
}

test "effect violation: bare print() Call carets at the callee for io effect" {
    // Closes #614. The Member-form `print.info(...)` already trips
    // E0400 (covered by "effect violation: print.<x> Member call
    // carets at print" above). The bare Call-form was uncovered
    // because the Call-with-Identifier branch in `effect_checker.sfn`
    // skipped over `print` / `console`. This test locks the parity in.
    let stmt = _routine_with_bare_call("noisy", [], 4, "print", 7, 5);
    let program = Program { statements: [stmt] };
    let violations = validate_effects(program);
    assert violations.length == 1;
    let v = violations[0];
    let mut found_io: boolean = false;
    let mut i: int = 0;
    loop {
        if i >= v.missing_effects.length { break; }
        if v.missing_effects[i] == "io.console" { found_io = true; }
        i += 1;
    }
    assert found_io;
    assert v.trigger != null;
    let trig: Token? = v.trigger;
    assert trig.line == 7;
    assert trig.column == 5;
    assert trig.lexeme == "print";
}

test "effect violation: bare console() Call carets at the callee for io effect" {
    let stmt = _routine_with_bare_call("chatty", [], 12, "console", 14, 3);
    let program = Program { statements: [stmt] };
