// compiler/tests/unit/number_format_test.sfn
//
// Regression coverage for the hand-rolled Sailfin number/int formatting
// bodies (#1314, C3 of epic #1308). `number_to_string` now lowers to the
// bare `sfn_number_to_str` emission target, whose real body lives in
// `runtime/sfn/string.sfn` (the C trampoline is `static`). These cases
// pin the output bit-for-bit against libc `%.15g` (the behaviour the C
// trampoline produced), the contract this migration must preserve.
//
// The expected strings were generated with `printf("%.15g", v)`. They
// exercise: the exact integer fast path (incl. negatives and the 15-digit
// boundary), fixed-form fractions, the `%f`/`%e` style cut at exponent
// X = 15 and X < -4, and the >= 2-digit signed exponent in scientific
// form. Trailing-zero / trailing-point stripping is covered throughout.
// ---- Exact integer fast path (integer-valued doubles < 1e15) ----
test "number_format: zero" {
    assert strings_equal(number_to_string(0), "0");
}

test "number_format: small positive integers" {
    assert strings_equal(number_to_string(7), "7");
    assert strings_equal(number_to_string(42), "42");
    assert strings_equal(number_to_string(120), "120");
    assert strings_equal(number_to_string(1000000), "1000000");
    assert strings_equal(number_to_string(123456789), "123456789");
}

test "number_format: negative integers" {
    assert strings_equal(number_to_string(-7), "-7");
    assert strings_equal(number_to_string(-3), "-3");
}

test "number_format: fifteen-digit integer stays fixed" {
    assert strings_equal(number_to_string(999999999999999.0), "999999999999999");
    assert strings_equal(number_to_string(123456789012345.0), "123456789012345");
}

// ---- Fixed-form fractions (-4 <= X < 15) ----
test "number_format: simple fractions" {
    assert strings_equal(number_to_string(3.14), "3.14");
    assert strings_equal(number_to_string(-3.14), "-3.14");
    assert strings_equal(number_to_string(0.5), "0.5");
    assert strings_equal(number_to_string(0.6), "0.6");
    assert strings_equal(number_to_string(0.1), "0.1");
    assert strings_equal(number_to_string(0.25), "0.25");
    assert strings_equal(number_to_string(2.5), "2.5");
    assert strings_equal(number_to_string(1.5), "1.5");
}

test "number_format: mixed integer-and-fraction" {
    assert strings_equal(number_to_string(1234.5), "1234.5");
    assert strings_equal(number_to_string(100.125), "100.125");
    assert strings_equal(number_to_string(0.0625), "0.0625");
}

test "number_format: leading-zero fractions at the fixed/scientific edge" {
    assert strings_equal(number_to_string(0.001), "0.001");
    assert strings_equal(number_to_string(0.0001), "0.0001");
}

// ---- Scientific form (X >= 15 or X < -4) ----
test "number_format: scientific for large magnitudes" {
    assert strings_equal(number_to_string(1000000000000000.0), "1e+15");
    assert strings_equal(number_to_string(100000000000000000000.0), "1e+20");
    assert strings_equal(number_to_string(1234567890123460.0), "1.23456789012346e+15");
}

test "number_format: scientific for small magnitudes" {
    assert strings_equal(number_to_string(0.00001), "1e-05");
    assert strings_equal(number_to_string(0.0000000001), "1e-10");
    assert strings_equal(number_to_string(-0.000000015), "-1.5e-08");
}
