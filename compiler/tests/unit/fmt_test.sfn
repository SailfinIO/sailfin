// Regression tests for sfn/fmt capsule additions.
// Tests only functions that don't depend on char_code/char_at (prelude
// functions unavailable in standalone test files).

fn _find(text: string, needle: string, start: number) -> number {
    if needle.length == 0 { return start; }
    if needle.length > text.length { return -1; }
    let mut i: number = start;
    let limit = text.length - needle.length;
    loop {
        if i > limit { return -1; }
        if strings_equal(substring(text, i, i + needle.length), needle) {
            return i;
        }
        i += 1;
    }
    return -1;
}

fn _trim(text: string) -> string {
    let mut start: number = 0;
    let mut end: number = text.length;
    loop {
        if start >= end { break; }
        let ch = text[start];
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            start += 1;
        } else { break; }
    }
    loop {
        if end <= start { break; }
        let ch = text[end - 1];
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            end -= 1;
        } else { break; }
    }
    return substring(text, start, end);
}

fn _trim_left(text: string) -> string {
    let mut start: number = 0;
    loop {
        if start >= text.length { break; }
        let ch = text[start];
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            start += 1;
        } else { break; }
    }
    return substring(text, start, text.length);
}

fn _trim_right(text: string) -> string {
    let mut end: number = text.length;
    loop {
        if end <= 0 { break; }
        let ch = text[end - 1];
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            end -= 1;
        } else { break; }
    }
    return substring(text, 0, end);
}

fn _char_at_index(text: string, index: number) -> string {
    if index < 0 || index >= text.length { return ""; }
    return substring(text, index, index + 1);
}

fn _reverse(text: string) -> string {
    let mut out: string = "";
    let mut i: number = text.length;
    loop {
        if i <= 0 { break; }
        i -= 1;
        out = out + substring(text, i, i + 1);
    }
    return out;
}

fn _count(text: string, needle: string) -> number {
    if needle.length == 0 { return 0; }
    let mut total: number = 0;
    let mut pos: number = 0;
    loop {
        let idx = _find(text, needle, pos);
        if idx < 0 { break; }
        total += 1;
        pos = idx + needle.length;
    }
    return total;
}

fn _is_empty(text: string) -> boolean {
    return text.length == 0;
}

fn _is_blank(text: string) -> boolean {
    return _trim(text).length == 0;
}

// -- Tests --

test "fmt: trim_left" {
    assert strings_equal(_trim_left("  hello"), "hello");
    assert strings_equal(_trim_left("hello  "), "hello  ");
    assert strings_equal(_trim_left("  "), "");
    assert strings_equal(_trim_left(""), "");
}

test "fmt: trim_right" {
    assert strings_equal(_trim_right("hello  "), "hello");
    assert strings_equal(_trim_right("  hello"), "  hello");
    assert strings_equal(_trim_right("  "), "");
}

test "fmt: char_at_index" {
    assert strings_equal(_char_at_index("hello", 0), "h");
    assert strings_equal(_char_at_index("hello", 4), "o");
    assert strings_equal(_char_at_index("hello", -1), "");
    assert strings_equal(_char_at_index("hello", 5), "");
}

test "fmt: reverse" {
    assert strings_equal(_reverse("abc"), "cba");
    assert strings_equal(_reverse(""), "");
    assert strings_equal(_reverse("a"), "a");
    assert strings_equal(_reverse("12345"), "54321");
}

test "fmt: count occurrences" {
    assert _count("hello world hello", "hello") == 2;
    assert _count("aaa", "a") == 3;
    assert _count("abc", "x") == 0;
    assert _count("", "a") == 0;
    assert _count("hello", "") == 0;
}

test "fmt: is_empty" {
    assert _is_empty("") == true;
    assert _is_empty("a") == false;
    assert _is_empty(" ") == false;
}

test "fmt: is_blank" {
    assert _is_blank("") == true;
    assert _is_blank("   ") == true;
    assert _is_blank("  a  ") == false;
}
