// Regression test for cross-module call coercion fix.
// Verifies that array parameters are passed correctly across module
// boundaries — previously, failed coercion substituted i8* null,
// corrupting the array argument.

fn _make_array() -> string[] {
    let mut arr: string[] = [];
    arr.push("alpha");
    arr.push("beta");
    arr.push("gamma");
    return arr;
}

fn _join_local(values: string[], sep: string) -> string {
    if values.length == 0 { return ""; }
    let mut result: string = values[0];
    let mut i: number = 1;
    loop {
        if i >= values.length { break; }
        result = result + sep + values[i];
        i += 1;
    }
    return result;
}

fn _pass_through(arr: string[]) -> string[] {
    return arr;
}

fn _count_elements(arr: string[]) -> number {
    return arr.length;
}

test "cross-module: array round-trip preserves elements" {
    let original = _make_array();
    let passed = _pass_through(original);
    assert passed.length == 3;
    assert passed[0] == "alpha";
    assert passed[1] == "beta";
    assert passed[2] == "gamma";
}

test "cross-module: array length survives function call" {
    let arr = _make_array();
    let count = _count_elements(arr);
    assert count == 3;
}

test "cross-module: array join after pass-through" {
    let arr = _make_array();
    let passed = _pass_through(arr);
    let joined = _join_local(passed, ", ");
    assert joined == "alpha, beta, gamma";
}

test "cross-module: empty array pass-through" {
    let empty: string[] = [];
    let passed = _pass_through(empty);
    assert passed.length == 0;
}

test "cross-module: single element array" {
    let mut arr: string[] = [];
    arr.push("only");
    let passed = _pass_through(arr);
    assert passed.length == 1;
    assert passed[0] == "only";
}
