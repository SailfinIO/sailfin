// Regression coverage for SFN-384: `parse_program` must reject a
// function body that opens with `{` but reaches EOF before its closing
// `}`, yielding a top-level `Statement.Unknown` carrying parse code
// `E0505` instead of silently truncating the AST. Also covers the
// sibling malformed-`let`-name recovery (`let{`), which yields
// `Statement.Unknown` with code `E0504`. Exercises the parser directly
// (no `sfn check`/`sfn build` round trip) — see
// `compiler/tests/e2e/parse_truncated_body_test.sfn` for the
// diagnostics-envelope and build-side coverage.
import { Block, Program, Statement } from "../../src/ast";
import { parse_program } from "../../src/parser/mod";

test "parser truncated: cut-off function body yields Unknown E0505" ![io] {
    let program = parse_program("fn foo() {\n    let x = 1;\n");
    assert program.statements.length >= 1;
    let stmt = program.statements[0];
    assert stmt.variant == "Unknown";
    assert stmt.code == "E0505";
}

test "parser truncated: malformed let name yields Unknown E0504" ![io] {
    let program = parse_program("let{\n");
    let stmt = program.statements[0];
    assert stmt.variant == "Unknown";
    assert stmt.code == "E0504";
}

test "parser truncated: closed body with nested let stays a FunctionDeclaration" ![io] {
    let program = parse_program("fn foo() {\n    let x = 1;\n}\n");
    assert program.statements[0].variant == "FunctionDeclaration";
}

// SFN-390: a malformed `let` whose stray name token is the enclosing block's
// own closing `}` must not swallow that `}`. The body stays closed, so the
// function parses as a `FunctionDeclaration` carrying the precise
// `let`-anchored `E0504` — never degrading to a top-level `E0505` on `fn f`.
test "parser truncated: let taking the body's close brace keeps E0504, not E0505" ![io] {
    let program = parse_program("fn f() { let }\n");
    let stmt = program.statements[0];
    assert stmt.variant == "FunctionDeclaration";
    assert stmt.body.statements.length == 1;
    let inner = stmt.body.statements[0];
    assert inner.variant == "Unknown";
    assert inner.code == "E0504";
}

// SFN-390 adjacent guard: a genuinely truncated body — `let{` opening a
// nested block that then hits EOF with no closing `}` for `fn f` — is still
// an unclosed body and must keep the `E0505` truncated-body diagnostic
// (SFN-384). The `{` here is an opening delimiter, not the block's own `}`,
// so recovery still advances past it.
test "parser truncated: let-open-brace at EOF stays Unknown E0505" ![io] {
    let program = parse_program("fn f() { let{\n");
    let stmt = program.statements[0];
    assert stmt.variant == "Unknown";
    assert stmt.code == "E0505";
}
