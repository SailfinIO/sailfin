// Effect-detector coverage: the name-resolution detector attributes the
// correct effect for every builtin/concurrency family.
//
// History: this began as the G1c parity harness (#1185), proving the
// name-resolution detector (`collect_effects_from_expression`, wired to the
// runtime descriptor registry in #1183 + symbol resolution in #1184) was a
// superset of the legacy text-pattern detector. That text fallback
// (`collect_effects_from_text`) was deleted in G4 (#1186, epic #1180,
// Phase G), so there is no longer a second path to compare against. The
// resolution-path assertions are retained here as a standalone regression
// net: now that the text safety-net is gone, these are the only thing
// guarding against a silent enforcement hole if the detector regresses.
//
// FAITHFULNESS: each case is parsed from real source through `parse_program`
// ŌĆö the exact frontend path enforcement relies on ŌĆö not from a hand-built
// AST that could drift from what the parser actually produces.
//
//   construct          effect   resolution-path node
//   ---------          ------   --------------------
//   fs.exists / fs.read  io     Member  (descriptor + namespace union)
//   print("ŌĆ”")           io     Call    (bare builtin)
//   print.info("ŌĆ”")      io     Member  (descriptor)
//   console.log("ŌĆ”")     io     Member  (descriptor)
//   http.get("ŌĆ”")        net    Member  (descriptor + namespace union)
//   websocket.send("ŌĆ”")  net    Member  (explicit net, #1601)
//   spawn(task)          none   Spawn   (parser ŌåÆ Spawn node; effect-transparent, SFEP-0049)
//   spawn(io body)        io    Spawn   (effect inherited from the spawned body)
//   parallel [task]      none   Parallel(parser ŌåÆ Parallel node; effect-transparent, SFEP-0049)
//   parallel [io task]    io    Parallel(effect inherited from the task body)
//   ch.send(v)           none   Member  (effect-transparent, SFEP-0049)
//   ch.send(io arg)       io    Member  (effect inherited from the argument walk)
//   ch.receive()          none  Member  (effect-transparent, SFEP-0049)
//   serve(handler)       net    Serve   (parser ŌåÆ Serve node; Call arm also covered)
//   sleep(1.0)           clock  Call    (descriptor)
//
// NOTE on spawn/serve: the parser intercepts `spawn(...)`/`serve(...)` into
// dedicated `Spawn`/`Serve` AST nodes (concurrency frontend), NOT generic
// `Call` expressions ŌĆö so real source is covered by the `Spawn`/`Serve`
// variant arms of `collect_effects_from_expression`. The detector ALSO keeps
// defensive `Call`+Identifier arms for `spawn`/`serve` (effect_checker.sfn,
// the `name == "spawn"` / `name == "serve"` branches); those are exercised
// here via a hand-built `Call` node so neither arm is left uncovered.
//
// >>> WHEN YOU ADD A NEW EFFECTFUL BUILTIN FAMILY TO THE DETECTOR, ADD A
// >>> MATCHING COVERAGE CASE HERE. A missed family becomes a silent
// >>> enforcement hole.
import { Expression } from "../../src/ast";
import { EffectRequirement, collect_effects_from_expression } from "../../src/effect_checker";
import { empty_import_symbols } from "../../src/effect_imports";
import { parse_program } from "../../src/parser/mod";

// -------------------------------------------------------------------
// Helpers
// -------------------------------------------------------------------
// Parse `snippet` as the sole expression-statement of a probe function and
// return the resulting `Expression`. Asserts the shape so a parser change
// fails here with a clear message rather than trapping downstream. The
// referenced identifiers (`p`, `task`, `handler`) need not be declared ŌĆö
// this is parse + effect-collection only, no typecheck.
fn _probe_expr(snippet: string) -> Expression ![io] {
    let program = parse_program("fn probe() { " + snippet + "; }");
    assert program.statements.length >= 1;
    let fn_stmt = program.statements[0];
    assert fn_stmt.variant == "FunctionDeclaration";
    assert fn_stmt.body.statements.length >= 1;
    let stmt = fn_stmt.body.statements[0];
    assert stmt.variant == "ExpressionStatement";
    return stmt.expression;
}

// A hand-built `Call` over a bare `Identifier` callee ŌĆö the shape the
// parser does NOT produce for the keyword forms `spawn`/`serve` (it routes
// them to `Spawn`/`Serve` nodes), so the only way to exercise the detector's
// defensive `Call`+Identifier arms for those names is to construct the node
// directly.
fn _bare_call(callee: string) -> Expression {
    let no_args: Expression[] = [];
    return Expression.Call {
        callee: Expression.Identifier { name: callee, span: null },
        arguments: no_args,
        span: null
    };
}

fn _reqs_contain(reqs: EffectRequirement[], effect: string) -> boolean {
    let mut index: int = 0;
    loop {
        if index >= reqs.length { break; }
        if reqs[index].effect == effect { return true; }
        index += 1;
    }
    return false;
}

// Resolution path requirements for a parsed snippet (empty import table ŌĆö
// these are all runtime builtins / concurrency anchors, not cross-module
// imports, so no import symbols are needed).
fn _resolution_reqs(snippet: string) -> EffectRequirement[] ![io] {
    return collect_effects_from_expression(_probe_expr(snippet), empty_import_symbols());
}

// The core coverage invariant for one construct: the resolution path
// attributes `effect` for `snippet`.
fn _assert_detects(snippet: string, effect: string) ![io] {
    let reqs = _resolution_reqs(snippet);
    assert _reqs_contain(reqs, effect);
}

// The effect-transparency counterpart (SFEP-0049): the resolution path
// attributes NO effect for `snippet` ŌĆö used to prove a concurrency
// primitive (spawn/parallel/channel op) over a pure body/argument
// contributes nothing of its own.
fn _assert_no_detect(snippet: string) ![io] {
    let reqs = _resolution_reqs(snippet);
    assert reqs.length == 0;
}

// -------------------------------------------------------------------
// Per-family coverage cases (one per effectful builtin/concurrency family)
// -------------------------------------------------------------------
test "detect: fs.* filesystem helper -> io (exact descriptor)" ![io] {
    _assert_detects("fs.exists(p)", "io");
}

test "detect: fs.* non-exact member -> io (namespace union)" ![io] {
    // No `fs.read` descriptor row exists; the resolution path must still
    // attribute `io` via the namespace-union fallback in
    // `effects_for_callee_target`.
    _assert_detects("fs.read(p)", "io");
}

test "detect: print(...) bare call -> io" ![io] {
    _assert_detects("print(\"x\")", "io");
}

test "detect: print.info(...) member -> io" ![io] {
    _assert_detects("print.info(\"x\")", "io");
}

test "detect: console.* member -> io" ![io] {
    _assert_detects("console.log(\"x\")", "io");
}

test "detect: http.* member -> net" ![io] {
    _assert_detects("http.get(\"u\")", "net");
}

test "detect: websocket.* member -> net" ![io] {
    _assert_detects("websocket.send(\"m\")", "net");
}

test "detect: spawn(...) requires nothing over a pure body (Spawn node, real source)" ![io] {
    // Pin the parser routing: real `spawn(...)` source becomes a `Spawn`
    // node, so the `Spawn` variant arm still routes here. If a future
    // parser change re-routes this through the generic `Call` path, this
    // assertion fails and forces a re-check of arm coverage. SFEP-0049
    // (effect transparency): the primitive itself contributes no effect ŌĆö
    // a pure spawned body attributes nothing.
    assert _probe_expr("spawn(task)").variant == "Spawn";
    _assert_no_detect("spawn(task)");
}

test "detect: spawn(...) attributes io from an io body (Spawn node)" ![io] {
    // The primitive stays transparent; the caller inherits exactly the
    // effects of the spawned body.
    _assert_detects("spawn(fn () { print.info(\"x\"); })", "io");
}

test "detect: spawn(...) requires nothing over no argument (defensive Call+Identifier arm)" ![io] {
    // The detector also keeps a `Call`+Identifier arm for `spawn` that the
    // parser never reaches; cover it directly so a future change can't
    // silently reintroduce a phantom effect there.
    let reqs = collect_effects_from_expression(_bare_call("spawn"), empty_import_symbols());
    assert reqs.length == 0;
}

test "detect: parallel [...] requires nothing over a pure task (Parallel node)" ![io] {
    // Pin parser routing: `parallel [...]` becomes a `Parallel` node. SFEP-0049
    // (effect transparency): parallel contributes no effect of its own ŌĆö a
    // pure task body attributes nothing.
    assert _probe_expr("parallel [task]").variant == "Parallel";
    _assert_no_detect("parallel [task]");
}

test "detect: parallel [...] attributes io from an io task (Parallel node)" ![io] {
    _assert_detects("parallel [fn () { print.info(\"x\"); }]", "io");
}

test "detect: channel .send(...) requires nothing over a pure value (Member arm)" ![io] {
    // `ch.send(v)` is a Member-callee call. SFEP-0049 (effect transparency):
    // the channel op contributes no effect of its own ŌĆö a pure value
    // attributes nothing.
    _assert_no_detect("ch.send(v)");
}

test "detect: channel .send(...) attributes io from an io argument (Member arm)" ![io] {
    // The effect is inherited via the argument walk, not the `send` op.
    _assert_detects("ch.send(fs.read(p))", "io");
}

test "detect: channel .receive() requires nothing (Member arm)" ![io] {
    _assert_no_detect("ch.receive()");
}

test "detect: serve(...) -> net (Serve node, real source)" ![io] {
    assert _probe_expr("serve(handler)").variant == "Serve";
    _assert_detects("serve(handler)", "net");
}

test "detect: serve(...) -> net (defensive Call+Identifier arm)" ![io] {
    let reqs = collect_effects_from_expression(_bare_call("serve"), empty_import_symbols());
    assert _reqs_contain(reqs, "net");
}

test "detect: sleep(...) call -> clock" ![io] {
    _assert_detects("sleep(1.0)", "clock");
}

// -------------------------------------------------------------------
// Baseline: a non-effectful call requires nothing. Proves the suite is not
// trivially satisfied and that the resolution path introduces no false
// positives for ordinary user calls.
// -------------------------------------------------------------------
test "detect: non-effectful call requires nothing" ![io] {
    let reqs = _resolution_reqs("compute(a, b)");
    assert reqs.length == 0;
}
