// Unit tests for `compiler/src/diagnostics_json.sfn` —
// `sfn check --json`'s encoder. Pure-encoder boundary tests.
//
// The schema is locked at `sailfin-check/1` and documented at
// `docs/reference/check-json-schema.md`. These tests cover the
// classifier and the empty-envelope path so schema-version drift
// shows up here as a unit failure before the e2e schema-lock test
// (`compiler/tests/e2e/test_check_json_schema.sh`) catches it.
//
// Encoder bytes for diagnostic-event paths are exercised end-to-end
// by the schema-lock e2e test (which runs `jq` over the actual
// envelope). Keeping the unit-side string-literal volume tight
// avoids the seed compiler's globals-phase memory ceiling.
import {
    CheckJsonEvent,
    CheckJsonSummary,
    classify_producer,
    render_check_json_envelope
} from "../../src/diagnostics_json";
import { index_of } from "../../src/string_utils";
import { Token, TokenKind } from "../../src/token";
import { Diagnostic, FixSuggestion, TextEdit } from "../../src/typecheck_types";

// -------------------------------------------------------------------
// Builder helpers
// -------------------------------------------------------------------
fn _empty_events() -> CheckJsonEvent[] {
    let events: CheckJsonEvent[] = [];
    return events;
}

fn _empty_summary() -> CheckJsonSummary {
    return CheckJsonSummary {
        files_checked: 0,
        errors: 0,
        warnings: 0,
        duration_ms: 0
    };
}

fn _contains(haystack: string, needle: string) -> boolean {
    return index_of(haystack, needle) >= 0;
}

// -------------------------------------------------------------------
// Producer classification
// -------------------------------------------------------------------
test "classify_producer: E0400 maps to effect" {
    assert classify_producer("E0400") == "effect";
}

test "classify_producer: E0401 maps to effect" {
    assert classify_producer("E0401") == "effect";
}

test "classify_producer: E0402 maps to effect" {
    assert classify_producer("E0402") == "effect";
}

test "classify_producer: E0403 maps to effect" {
    assert classify_producer("E0403") == "effect";
}

test "classify_producer: E0001 maps to typecheck" {
    assert classify_producer("E0001") == "typecheck";
}

test "classify_producer: E0301 maps to typecheck" {
    assert classify_producer("E0301") == "typecheck";
}

test "classify_producer: W0001 maps to load" {
    assert classify_producer("W0001") == "load";
}

test "classify_producer: W0002 maps to load" {
    assert classify_producer("W0002") == "load";
}

test "classify_producer: unknown codes fall through to unknown" {
    // Regression-guard the "fall through" branch — a future code
    // range outside E00xx/E03xx/E04xx/W01xx must surface as
    // `unknown` so a producer mismatch is visible.
    assert classify_producer("X9999") == "unknown";
    assert classify_producer("E0500") == "unknown";
}

// -------------------------------------------------------------------
// Empty envelope
// -------------------------------------------------------------------
test "envelope: clean run includes summary even when events is empty" {
    let events = _empty_events();
    let summary = CheckJsonSummary {
        files_checked: 12,
        errors: 0,
        warnings: 0,
        duration_ms: 0
    };
    let out = render_check_json_envelope(events, summary, 0);
    assert _contains(out, "sailfin-check/1");
    assert _contains(out, "sfn check");
    assert _contains(out, "files_checked");
    assert _contains(out, "events");
}

test "envelope: schema_version field is sailfin-check/1" {
    let events = _empty_events();
    let summary = _empty_summary();
    let out = render_check_json_envelope(events, summary, 0);
    assert _contains(out, "sailfin-check/1");
}

test "envelope: command field is sfn check" {
    let events = _empty_events();
    let summary = _empty_summary();
    let out = render_check_json_envelope(events, summary, 0);
    assert _contains(out, "sfn check");
}

test "envelope: ends with trailing newline" {
    let events = _empty_events();
    let summary = _empty_summary();
    let out = render_check_json_envelope(events, summary, 0);
    assert out.length > 0;
    assert _contains(out, "\n");
}

test "envelope: encodes summary numbers" {
    let events = _empty_events();
    let summary = CheckJsonSummary {
        files_checked: 7,
        errors: 3,
        warnings: 2,
        duration_ms: 0
    };
    let out = render_check_json_envelope(events, summary, 1);
    assert _contains(out, "files_checked");
    assert _contains(out, "errors");
    assert _contains(out, "warnings");
}

// -------------------------------------------------------------------
// B3: FixSuggestion / TextEdit encoder paths
// -------------------------------------------------------------------
fn _identifier_token(line: number, column: number, lexeme: string) -> Token {
    return Token {
        kind: TokenKind.Identifier(),
        lexeme: lexeme,
        line: line,
        column: column
    };
}

fn _diag_with_suggestion(suggestion: FixSuggestion?) -> Diagnostic {
    return Diagnostic {
        code: "E0400",
        severity: "error",
        message: "msg",
        file_path: "f.sfn",
        primary: _identifier_token(1, 1, "x"),
        suggestion: suggestion
    };
}

fn _wrap_event(d: Diagnostic) -> CheckJsonEvent[] {
    let mut events: CheckJsonEvent[] = [];
    events.push(CheckJsonEvent {
        kind: "diagnostic", producer: "effect", diagnostic: d
    });
    return events;
}

test "envelope: null suggestion renders as JSON null" {
    let diag = _diag_with_suggestion(null);
    let events = _wrap_event(diag);
    let summary = _empty_summary();
    let out = render_check_json_envelope(events, summary, 1);
    assert _contains(out, "suggestion");
    // The literal `\"suggestion\":null` is the wire shape pre-B3 and
    // for diagnostics that legitimately have no fix-it (W01xx,
    // typecheck factories, capability cross-check until later).
    assert _contains(out, "null");
}

test "envelope: populated suggestion renders message + edits array" {
    let mut edits: TextEdit[] = [];
    edits.push(TextEdit {
        start_line: 12, start_column: 38, end_line: 12, end_column: 38, replacement: "![io] "
    });
    let suggestion = FixSuggestion {
        message: "add ![io] to the function signature",
        edits: edits
    };
    let diag = _diag_with_suggestion(suggestion);
    let events = _wrap_event(diag);
    let summary = _empty_summary();
    let out = render_check_json_envelope(events, summary, 1);
    assert _contains(out, "add ![io] to the function signature");
    assert _contains(out, "start_line");
    assert _contains(out, "start_column");
    assert _contains(out, "end_line");
    assert _contains(out, "end_column");
    assert _contains(out, "replacement");
    assert _contains(out, "![io] ");
}

test "envelope: empty edits array renders as []" {
    let no_edits: TextEdit[] = [];
    let suggestion = FixSuggestion { message: "no-op", edits: no_edits };
    let diag = _diag_with_suggestion(suggestion);
    let events = _wrap_event(diag);
    let summary = _empty_summary();
    let out = render_check_json_envelope(events, summary, 1);
    assert _contains(out, "no-op");
    assert _contains(out, "edits");
    // Empty array shape
    assert _contains(out, "[]");
}

test "envelope: multi-edit suggestion preserves all entries" {
    let mut edits: TextEdit[] = [];
    edits.push(TextEdit {
        start_line: 10, start_column: 1, end_line: 10, end_column: 1, replacement: "first"
    });
    edits.push(TextEdit {
        start_line: 20, start_column: 5, end_line: 20, end_column: 5, replacement: "second"
    });
    let suggestion = FixSuggestion { message: "two-step", edits: edits };
    let diag = _diag_with_suggestion(suggestion);
    let events = _wrap_event(diag);
    let summary = _empty_summary();
    let out = render_check_json_envelope(events, summary, 1);
    assert _contains(out, "first");
    assert _contains(out, "second");
    assert _contains(out, "two-step");
}
