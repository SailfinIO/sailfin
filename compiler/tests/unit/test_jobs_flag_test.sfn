// #1236 / SFN-91: unit coverage for the explicit jobs parser and the pure
// RAM+CPU budget behind the native default.
import { _parse_jobs_value, _test_jobs_budget } from "../../src/cli/commands/test";

test "jobs: plain positive integer parses" {
    assert _parse_jobs_value("4") == 4;
}

test "jobs: 1 parses (serial default shape)" {
    assert _parse_jobs_value("1") == 1;
}

test "jobs: multi-digit value parses" {
    assert _parse_jobs_value("32") == 32;
}

test "jobs: cap value 256 accepted" {
    assert _parse_jobs_value("256") == 256;
}

test "jobs: above-cap value rejected" {
    assert _parse_jobs_value("257") == -1;
}

test "jobs: zero rejected" { assert _parse_jobs_value("0") == -1; }

test "jobs: negative rejected" { assert _parse_jobs_value("-2") == -1; }

test "jobs: empty rejected" { assert _parse_jobs_value("") == -1; }

test "jobs: non-numeric rejected" { assert _parse_jobs_value("four") == -1; }

test "jobs: trailing garbage rejected" {
    assert _parse_jobs_value("4x") == -1;
}

test "jobs: leading whitespace rejected" {
    assert _parse_jobs_value(" 4") == -1;
}

test "jobs: auto budget is bounded by CPU and memory (SFN-91)" {
    assert _test_jobs_budget(17179869184, 8, false) == 8;
    assert _test_jobs_budget(1610612736, 8, false) == 4;
}

test "jobs: auto budget floors small and unknown hosts to serial (SFN-91)" {
    assert _test_jobs_budget(268435456, 8, false) == 1;
    assert _test_jobs_budget(0, 8, false) == 1;
}

test "jobs: auto budget applies global and Darwin caps (SFN-91)" {
    assert _test_jobs_budget(68719476736, 64, false) == 16;
    assert _test_jobs_budget(68719476736, 64, true) == 2;
}
