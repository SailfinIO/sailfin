// Golden-IR test for the `runtime/sfn/io.sfn` skeleton — the first
// Sailfin-native runtime service module. Where the `platform/*.sfn`
// skeletons prove standalone `extern` declarations lower to `declare`s,
// this proves a sibling runtime module can *import* one of those
// declarations (`write` from `platform/libc.sfn`) and lower an actual
// call site against it.
//
// Replaces `compiler/tests/e2e/test_runtime_io_skeleton.sh` as part of
// the bash-collapse migration (epic #842, issue #1223). The `.sh` ran
// `sfn check` + `sfn fmt --check` + `sfn emit llvm` and grepped the IR
// for the imported `write` declaration and call; this pins the same
// surface in-process. The typecheck/fmt halves are covered elsewhere —
// CI runs `sfn fmt --check` over `runtime/` and `make compile`
// typechecks these sfn-sources.
//
// Strategy: ONE `lower_to_llvm_ir_from_text` call over the REAL `io.sfn`
// (read via `fs.readFile`). Unlike the `platform/*` skeletons, `io.sfn`
// imports `write` from `./platform/libc`; `lower_to_llvm_ir_from_text`
// resolves imported `extern` signatures through
// `collect_imported_module_context_for_module` (the same path the `sfn
// emit llvm` driver uses), so the cross-module `write` call lowers to a
// `declare` + `call` exactly as the `.sh` asserted.
import { emit_native_text_with_module_name } from "../../src/emit_native";
import { lower_to_llvm_ir_from_text } from "../../src/llvm/lowering/entrypoints";
import { parse_program } from "../../src/parser/mod";
import { index_of } from "../../src/string_utils";

fn _contains(haystack: string, needle: string) -> boolean {
    return index_of(haystack, needle) >= 0;
}

test "lowering: runtime/sfn/io.sfn lowers the imported libc write call" ![io] {
    let source = fs.readFile("runtime/sfn/io.sfn");
    let program = parse_program(source);
    let native = emit_native_text_with_module_name(program, "runtime/sfn/io");
    let ir = lower_to_llvm_ir_from_text(native, "runtime/sfn/io");

    // The inlined extern is declared and called against.
    assert _contains(ir, "declare i64 @write(");
    assert _contains(ir, "call i64 @write(");
}

// Symbol-surface coverage for the print-family flip (#1310, C4/R3 of
// #1308). Replaces the emit-shape / no-bare-canonical-define / routing
// assertions that lived in the retired `test_runtime_io_extended.sh`
// (migrated to native sfn/test per epic #842). Lowers the REAL io.sfn
// in-process and pins the new ownership: io.sfn now defines the bare
// `sfn_print*` symbols directly (native `write(2)` bodies) and keeps the
// surviving Sailfin exports. (The bare `sfn_getenv` / `sfn_home_dir`
// canonical names are now ALSO Sailfin-defined — C7/R7, #1312 — asserted
// in the dedicated env test below.)
test "lowering: io.sfn defines the bare native sfn_print* family" ![io] {
    let source = fs.readFile("runtime/sfn/io.sfn");
    let program = parse_program(source);
    let native = emit_native_text_with_module_name(program, "runtime/sfn/io");
    let ir = lower_to_llvm_ir_from_text(native, "runtime/sfn/io");

    // Bare canonical printers — now Sailfin-defined.
    assert _contains(ir, "define void @sfn_print(");
    assert _contains(ir, "define void @sfn_print_err(");
    assert _contains(ir, "define void @sfn_print_info(");
    assert _contains(ir, "define void @sfn_print_warn(");
    assert _contains(ir, "define void @sfn_print_error(");
    // Surviving Sailfin exports (prelude import + baselines).
    assert _contains(ir, "define void @sfn_print_sfn(");
    assert _contains(ir, "@sfn_write_fd(");
}

test "lowering: io.sfn defines the bare native env readers (C7/R7 flipped)" ![io] {
    let source = fs.readFile("runtime/sfn/io.sfn");
    let program = parse_program(source);
    let native = emit_native_text_with_module_name(program, "runtime/sfn/io");
    let ir = lower_to_llvm_ir_from_text(native, "runtime/sfn/io");

    // C7/R7 of #1308 (issue #1312): `env.get` / `env.home` are now real
    // Sailfin bodies. io.sfn defines the bare canonical `sfn_getenv` /
    // `sfn_home_dir` with the `{i8*, i64}` SfnString aggregate return ABI
    // (the M1.A.2 `SfnString` return spelling) — the symbols user emission
    // calls against. The two-eightbyte name aggregate arrives as a
    // `(data, len)` scalar pair, so the param list is `(i8*, i64, i8*)`.
    assert _contains(ir, "define {i8*, i64} @sfn_getenv(");
    assert _contains(ir, "define {i8*, i64} @sfn_home_dir(");
    // The retired proof-of-life forwarders and their C trampoline externs
    // are gone (their `sailfin_runtime_*` C bodies retire with #822).
    assert ! _contains(ir, "@sfn_getenv_sfn(");
    assert ! _contains(ir, "@sfn_home_dir_sfn(");
    assert ! _contains(ir, "@sailfin_runtime_getenv");
    assert ! _contains(ir, "@sailfin_runtime_home_dir");
}

test "lowering: io.sfn immediate-codepoint guard decodes natively (no C printers)" ![io] {
    let source = fs.readFile("runtime/sfn/io.sfn");
    let program = parse_program(source);
    let native = emit_native_text_with_module_name(program, "runtime/sfn/io");
    let ir = lower_to_llvm_ir_from_text(native, "runtime/sfn/io");

    // #1308: tagged immediate-codepoint pointers (pre-M1.A.2) are now decoded
    // in pure Sailfin (`_sfn_print_immediate` → the native
    // `sfn_str_from_codepoint`) instead of delegating to the C
    // `sailfin_runtime_print_*` entrypoints, which io.sfn no longer references.
    assert _contains(ir, "@sfn_str_from_codepoint");
    assert ! _contains(ir, "@sailfin_runtime_print_raw");
    assert ! _contains(ir, "@sailfin_runtime_print_info");
}

// User-emission routing: a `print.info(...)` call site flips to the bare
// `@sfn_print_info` runtime symbol against the SfnString aggregate ABI
// (the registry's `native_signature`), the call site the native io.sfn
// body links against — not the legacy `@sailfin_runtime_print_info` C
// entrypoint.
test "lowering: print.info user call routes to @sfn_print_info" ![io] {
    let program = parse_program("fn main() -> void ![io] { print.info(\"x\"); }");
    let native = emit_native_text_with_module_name(program, "io_probe");
    let ir = lower_to_llvm_ir_from_text(native, "io_probe");

    assert _contains(ir, "call void @sfn_print_info({i8*, i64}");
}
