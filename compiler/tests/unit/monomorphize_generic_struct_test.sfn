// Unit coverage for generic-struct monomorphization (#1871, SFEP-0038
// §3.3). Exercises the pure `monomorphize_native_text` text→text transform
// directly on hand-written `.sfn-asm`: specializing a generic struct's
// layout manifest and field declarations at a construct site, and the
// byte-for-byte no-op on a module with no generic struct.
//
// At the native-IR level the mangled struct name is clean (`Box$int`) — the
// module symbol suffix is applied later, in LLVM lowering — so these
// assertions pin the mangling scheme without a build.
import { contains } from "sfn/strings";

import { monomorphize_native_text } from "../../src/llvm/monomorphize";

fn _has(haystack: string, needle: string) -> boolean {
    return contains(haystack, needle);
}

test "monomorphize struct: Box at int emits a specialized struct block" {
    let src = ".module m\n" + ".struct Box<T>\n"
        + ".layout struct name=Box size=8 align=8\n"
        + ".layout field value type=T offset=0 size=8 align=8\n"
        + "    .field value: T\n"
        + ".endstruct\n"
        + "\n"
        + ".fn main() -> int\n"
        + ".meta return int\n"
        + ".meta effects none\n"
        + "    .let b = Box { value: 42 }\n"
        + "    ret 0\n"
        + ".endfn\n";
    let out = monomorphize_native_text(src);
    // The specialized struct header exists.
    assert _has(out, ".struct Box$int");
    // The construct site is rewritten to target it.
    assert _has(out, "Box$int { value: 42 }");
    // The layout manifest line is substituted with the concrete type.
    assert _has(out, "type=int");
    // The field declaration is substituted with the concrete type.
    assert _has(out, ".field value: int");
    // The original generic definition is dropped (no leftover `Box<T>` header).
    assert ! _has(out, ".struct Box<T>");
    // No bare type-parameter token survives into the specialized field.
    assert ! _has(out, "value: T");
}

test "monomorphize struct: specialized header preserves a substituted implements clause" {
    // A generic struct with a trailing `implements Foo<T>` clause must keep
    // that clause (with `T` substituted) in the specialized header — only the
    // struct's own type-parameter clause is dropped, not every `<...>` (#1896
    // review).
    let src = ".module m\n" + ".struct Wrap<T> implements Show<T>\n"
        + ".layout struct name=Wrap size=8 align=8\n"
        + ".layout field value type=T offset=0 size=8 align=8\n"
        + "    .field value: T\n"
        + ".endstruct\n"
        + "\n"
        + ".fn main() -> int\n"
        + ".meta return int\n"
        + ".meta effects none\n"
        + "    .let w = Wrap { value: 5 }\n"
        + "    ret 0\n"
        + ".endfn\n";
    let out = monomorphize_native_text(src);
    // The implements clause survives with its argument substituted to int.
    assert _has(out, ".struct Wrap$int implements Show<int>");
    // The generic type-parameter clause on the struct itself is gone.
    assert ! _has(out, ".struct Wrap$int<");
    // The unsubstituted implements argument must not survive.
    assert ! _has(out, "implements Show<T>");
}

test "monomorphize struct: static constructor call instantiates from the binding annotation" {
    // `let numbers: List<int> = List.new()` — a static method on a generic
    // struct whose instantiation comes from the binding's expected type, not
    // from an argument (SFEP-0038 §3.6, #1941). The annotation `List<int>`
    // seeds the `List$int` specialization; the call receiver `List` is then
    // rewritten to `List$int` so it resolves like a concrete struct's static
    // method. The nested `.method` blocks (`new`, `add`) mirror emit_native's
    // shape.
    let src = ".module m\n" + ".struct List<T>\n"
        + ".layout struct name=List size=8 align=8\n"
        + ".layout field items type=T[] offset=0 size=8 align=8\n"
        + "    .field items: T[]\n"
        + "    .method new() -> List<T>\n"
        + "    .meta return List<T>\n"
        + "    .meta effects none\n"
        + "        ret null\n"
        + "    .endmethod\n"
        + "    .method add(self, item: T) -> void\n"
        + "    .meta return void\n"
        + "    .meta effects none\n"
        + "    .param self\n"
        + "    .param item: T\n"
        + "        eval self.items.push(item)\n"
        + "    .endmethod\n"
        + ".endstruct\n"
        + "\n"
        + ".fn main() ![io]\n"
        + ".meta return void\n"
        + ".meta effects io\n"
        + "    .let numbers : List<int> = List.new()\n"
        + "    eval numbers.add(1)\n"
        + ".endfn\n";
    let out = monomorphize_native_text(src);
    // The static constructor call resolves to the specialization (`List$int.new`).
    assert _has(out, "List$int.new(");
    // The specialized struct block exists, carrying its methods.
    assert _has(out, ".struct List$int");
    assert _has(out, ".method new");
    assert _has(out, ".method add");
    // No generic `T` field type survives into the specialized layout/field.
    assert _has(out, ".field items: int[]");
    // The original generic definition is dropped.
    assert ! _has(out, ".struct List<T>");
    // The unmangled receiver must not survive at the call site.
    assert ! _has(out, "List.new(");
}

test "monomorphize struct: constructor body struct literal is mangled to the specialization" {
    // The specialized method body itself must be swept: `return List<T> {
    // items: [] }` substitutes to `List<int> { ... }`, which must then be
    // mangled to `List$int { ... }`. Without the second sweep over struct
    // method bodies the literal stays the unregistered `List<int>`, fails
    // struct-literal resolution, and the constructor collapses to `ret i8*
    // null` — the caller then loads through null and traps (#1941). The
    // `.method`/`.meta return` return-type annotations must mangle too.
    let src = ".module m\n" + ".struct List<T>\n"
        + ".layout struct name=List size=8 align=8\n"
        + ".layout field items type=T[] offset=0 size=8 align=8\n"
        + "    .field items: T[]\n"
        + "    .method new() -> List<T>\n"
        + "    .meta return List<T>\n"
        + "    .meta effects none\n"
        + "        ret List<T> { items: [] }\n"
        + "    .endmethod\n"
        + ".endstruct\n"
        + "\n"
        + ".fn main() ![io]\n"
        + ".meta return void\n"
        + ".meta effects io\n"
        + "    .let numbers : List<int> = List.new()\n"
        + ".endfn\n";
    let out = monomorphize_native_text(src);
    // The constructor's return struct literal is mangled to the specialization.
    assert _has(out, "List$int { items: [] }");
    // The method return-type annotations are mangled, not left as `List<int>`.
    assert _has(out, ".method new() -> List$int");
    assert _has(out, ".meta return List$int");
    // No unmangled generic-syntax literal survives in the specialized body.
    assert ! _has(out, "List<int> { items: [] }");
    assert ! _has(out, "ret List<int>");
}

test "monomorphize struct: unannotated static constructor call is not instantiated" {
    // Without a binding annotation (`let n = List.new()`) the instantiation
    // is unknowable — there is no `T`-typed argument to infer from. The pass
    // must leave the call unmangled and force no specialization, so the
    // downstream lowering fails on the genuinely uninstantiable call rather
    // than the pass guessing a type (SFEP-0038 §3.6, #1941). This pins the
    // feature as strictly return-type-site driven.
    let src = ".module m\n" + ".struct List<T>\n"
        + ".layout struct name=List size=8 align=8\n"
        + ".layout field items type=T[] offset=0 size=8 align=8\n"
        + "    .field items: T[]\n"
        + "    .method new() -> List<T>\n"
        + "    .meta return List<T>\n"
        + "    .meta effects none\n"
        + "        ret null\n"
        + "    .endmethod\n"
        + ".endstruct\n"
        + "\n"
        + ".fn main() ![io]\n"
        + ".meta return void\n"
        + ".meta effects io\n"
        + "    .let n = List.new()\n"
        + ".endfn\n";
    let out = monomorphize_native_text(src);
    // The call is left unmangled (no expected type to instantiate from).
    assert _has(out, "List.new(");
    // No specialization is fabricated from a guessed type.
    assert ! _has(out, "List$int");
    assert ! _has(out, ".struct List$");
}

test "monomorphize struct: two methods reusing a local name mangle from their own env" {
    // Two methods of one generic struct each bind a local named `item` at a
    // different concrete type and construct `Box { value: item }`. The env used
    // to sweep a method body must be scoped to that method: `push_a`'s `item` is
    // `int` (→ `Box$int`) and `push_b`'s `item` is `string` (→ `Box$string`).
    // A single block-scoped env would flatten both `item` bindings and, first
    // match winning, mis-infer `push_b`'s literal as `Box$int` — never emitting
    // `Box$string`. Scoping per method (mirroring the free-fn path) fixes the
    // cross-method name capture (SFN-406).
    let src = ".module m\n" + ".struct Box<U>\n"
        + ".layout struct name=Box size=8 align=8\n"
        + ".layout field value type=U offset=0 size=8 align=8\n"
        + "    .field value: U\n"
        + ".endstruct\n"
        + "\n"
        + ".struct Holder<T>\n"
        + ".layout struct name=Holder size=8 align=8\n"
        + ".layout field slot type=T offset=0 size=8 align=8\n"
        + "    .field slot: T\n"
        + "    .method push_a(self, item: int) -> void\n"
        + "    .meta return void\n"
        + "    .meta effects none\n"
        + "    .param self\n"
        + "    .param item: int\n"
        + "        .let bx = Box { value: item }\n"
        + "    .endmethod\n"
        + "    .method push_b(self, item: string) -> void\n"
        + "    .meta return void\n"
        + "    .meta effects none\n"
        + "    .param self\n"
        + "    .param item: string\n"
        + "        .let bx = Box { value: item }\n"
        + "    .endmethod\n"
        + ".endstruct\n"
        + "\n"
        + ".fn main() -> int\n"
        + ".meta return int\n"
        + ".meta effects none\n"
        + "    .let h = Holder { slot: 0 }\n"
        + "    ret 0\n"
        + ".endfn\n";
    let out = monomorphize_native_text(src);
    // `push_a`'s body infers `Box$int` from its own `item: int`.
    assert _has(out, "Box$int { value: item }");
    // `push_b`'s body infers `Box$string` from its own `item: string` — this is
    // the binding a block-scoped env would have lost to `push_a`'s `int`.
    assert _has(out, "Box$string { value: item }");
    // Neither generic literal survives unmangled.
    assert ! _has(out, "Box { value: item }");
}

test "monomorphize struct: module with no generic struct is a byte-for-byte no-op" {
    let src = ".module m\n" + ".struct Plain\n"
        + ".layout struct name=Plain size=8 align=8\n"
        + ".layout field v type=int offset=0 size=8 align=8\n"
        + "    .field v: int\n"
        + ".endstruct\n"
        + "\n"
        + ".fn main() -> int\n"
        + ".meta return int\n"
        + ".meta effects none\n"
        + "    ret 0\n"
        + ".endfn\n";
    let out = monomorphize_native_text(src);
    // Byte-for-byte identical — the guarantee that non-generic code (the whole
    // compiler source) flows through untouched, preserving self-hosting.
    assert out == src;
}
