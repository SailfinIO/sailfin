test "llvm: injects round declare when used" {
    let lines = [
        "source_filename = \"m1.ll\"",
        "",
        "define double @foo(double %x) {",
        "entry:",
        "  %y = call double @round(double %x)",
        "  ret double %y",
        "}",
    ];

    let out = ensure_intrinsic_declarations(lines);

    let decl = "declare double @round(double)";
    let mut saw_decl: boolean = false;
    for line in out {
        if line == decl {
            saw_decl = true;
        }
    }
    if !saw_decl {
        runtime_raise_value_error_fn("missing round decl");
    }
}

fn _index_of(haystack: string, needle: string) -> number {
    if needle.length == 0 {
        return 0;
    }
    if haystack.length < needle.length {
        return -1;
    }
    let mut i: number = 0;
    loop {
        if i + needle.length > haystack.length {
            break;
        }
        let mut j: number = 0;
        let mut matches: boolean = true;
        loop {
            if j >= needle.length {
                break;
            }
            if haystack[i + j] != needle[j] {
                matches = false;
                break;
            }
            j += 1;
        }
        if matches {
            return i;
        }
        i += 1;
    }
    return -1;
}

fn _contains(haystack: string, needle: string) -> boolean {
    return _index_of(haystack, needle) >= 0;
}

fn _trim(value: string) -> string {
    if value.length == 0 {
        return value;
    }
    let mut start: number = 0;
    loop {
        if start >= value.length {
            break;
        }
        let ch = value[start];
        if ch != " " && ch != "\t" && ch != "\n" && ch != "\r" {
            break;
        }
        start += 1;
    }
    let mut end: number = value.length;
    loop {
        if end <= start {
            break;
        }
        let ch = value[end - 1];
        if ch != " " && ch != "\t" && ch != "\n" && ch != "\r" {
            break;
        }
        end -= 1;
    }
    if start == 0 && end == value.length {
        return value;
    }
    return value[start:end];
}

fn ensure_intrinsic_declarations(lines: string[]) -> string[] {
    let mut uses_round: boolean = false;
    let mut has_round_decl: boolean = false;
    let decl = "declare double @round(double)";

    for line in lines {
        if _contains(line, "call double @round(") {
            uses_round = true;
        }
        if _trim(line) == decl {
            has_round_decl = true;
        }
    }

    if !uses_round || has_round_decl {
        return lines;
    }

    let mut out = lines;
    out.push("");
    out.push(decl);
    return out;
}
