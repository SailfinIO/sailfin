// Prelude `Result<T, E>` + `Error` (#832, epic #371 R.2c).
//
// #829 (typecheck substitution) and #830 (per-instantiation lowering)
// reached the pinned seed, so the prelude can now declare the canonical
// `Result<T, E>` enum and `Error` struct with by-value generic payloads
// instead of type-erasing them to `i8*`. This test exercises the prelude
// declarations directly from a user file (no in-file `enum` / `import`):
// `Result` and `Error` resolve implicitly because the prelude is linked
// into every Sailfin binary.
//
// `?` type rules (#833) and emitter (#834) are out of scope here — this
// only proves construction + `match` over the prelude `Result`.
// Each helper takes its `Result<…>` instantiation as a parameter, so the
// `match` arms resolve `value` / `error` against a concrete instantiation
// (`Result<int, int>` here, `Result<string, Error>` below) rather than the
// bare type parameters.
fn unwrap_or(r: Result<int, int>, fallback: int) -> int {
    match r {
        Result.Ok { value } => { return value; },
        Result.Err { error } => { return fallback + error; }
    }
}

// `Result<string, Error>` — a distinct instantiation whose `Err` payload is
// the prelude `Error` struct, proving the default error type round-trips by
// value alongside the int instantiation above.
fn ok_len_or(r: Result<string, Error>, fallback: int) -> int {
    match r {
        Result.Ok { value } => { return value.length; },
        Result.Err { error } => { return fallback + error.message.length; }
    }
}

// `opaque*` are identity functions that the optimizer cannot fold: `sfn test`
// links at -O0 (`cli_commands.sfn::_clang_link_test_cmd_with_deps`), so these
// calls stay real boundaries and their results are runtime SSA values, not
// literals. Routing every `Result` payload (and every expected operand) through
// one forces the `match` to perform a genuine discriminant test + payload load
// at runtime instead of letting a future regression const-fold or silently drop
// the construction and elide the `assert` to an empty `ret void` body (the
// #1020 false-pass shape). A wrong result now fails loudly. The IR-level
// companion guard lives in `compiler/tests/e2e/test_result_prelude_discriminant.sh`.
fn opaque(x: int) -> int { return x; }

fn opaque_str(s: string) -> string { return s; }

test "prelude Result: by-value int payload through both arms" {
    assert unwrap_or(Result.Ok { value: opaque(5) }, opaque(0)) == opaque(5);
    assert unwrap_or(Result.Err { error: opaque(7) }, opaque(100)) == opaque(107);
}

test "prelude Result: Error struct payload round-trips" {
    assert ok_len_or(Result.Ok { value: opaque_str("hello") }, opaque(-1)) == opaque(5);
    assert ok_len_or(Result.Err {
        error: Error { message: opaque_str("boom") }
    }, opaque(10)) == opaque(14);
}
