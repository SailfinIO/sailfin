test "arrays: literal length is correct" {
    let arr = [1, 2, 3, 4, 5];
    assert arr.length == 5;
}

test "arrays: index access returns correct element" {
    let arr = [10, 20, 30];
    assert arr[0] == 10;
    assert arr[1] == 20;
    assert arr[2] == 30;
}

test "arrays: empty array has zero length" {
    let arr = [];
    assert arr.length == 0;
}

test "arrays: string array indexing" {
    let words = ["hello", "world", "sailfin"];
    assert words[0] == "hello";
    assert words[2] == "sailfin";
    assert words.length == 3;
}

test "arrays: boolean array values" {
    let flags = [true, false, true];
    assert flags[0] == true;
    assert flags[1] == false;
    assert flags.length == 3;
}

test "arrays: filter keeps matching elements" {
    let nums = [1, 2, 3, 4, 5, 6];
    let evens = nums.filter(fn(x) -> boolean { return x % 2 == 0; });
    assert evens.length == 3;
    assert evens[0] == 2;
    assert evens[1] == 4;
    assert evens[2] == 6;
}

test "arrays: filter with no matches produces empty array" {
    let nums = [1, 3, 5];
    let evens = nums.filter(fn(x) -> boolean { return x % 2 == 0; });
    assert evens.length == 0;
}

test "arrays: map transforms each element" {
    let nums = [1, 2, 3];
    let doubled = nums.map(fn(x) -> number { return x * 2; });
    assert doubled.length == 3;
    assert doubled[0] == 2;
    assert doubled[1] == 4;
    assert doubled[2] == 6;
}

test "arrays: reduce produces a single accumulated value" {
    let nums = [1, 2, 3, 4, 5];
    let sum = nums.reduce(0, fn(acc, x) -> number { return acc + x; });
    assert sum == 15;
}

test "arrays: reduce with multiply accumulator" {
    let nums = [1, 2, 3, 4];
    let product = nums.reduce(1, fn(acc, x) -> number { return acc * x; });
    assert product == 24;
}

test "arrays: concat joins two arrays" {
    let a = [1, 2];
    let b = [3, 4];
    let c = a.concat(b);
    assert c.length == 4;
    assert c[0] == 1;
    assert c[3] == 4;
}

test "arrays: map followed by filter" {
    let nums = [1, 2, 3, 4, 5];
    let result = nums.map(fn(x) -> number { return x * x; })
                     .filter(fn(x) -> boolean { return x > 5; });
    assert result.length == 3;
    assert result[0] == 9;
    assert result[1] == 16;
    assert result[2] == 25;
}
