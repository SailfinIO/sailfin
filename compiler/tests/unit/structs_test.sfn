struct Point {
    x -> number;
    y -> number;

    fn distance_squared_from_origin(self) -> number {
        return self.x * self.x + self.y * self.y;
    }

    fn translate(self, dx -> number, dy -> number) -> Point {
        return Point { x: self.x + dx, y: self.y + dy };
    }
}

struct Rectangle {
    width -> number;
    height -> number;

    fn new(w -> number, h -> number) -> Rectangle {
        return Rectangle { width: w, height: h };
    }

    fn area(self) -> number {
        return self.width * self.height;
    }

    fn perimeter(self) -> number {
        return 2 * (self.width + self.height);
    }

    fn is_square(self) -> boolean {
        return self.width == self.height;
    }
}

struct Counter {
    mut value -> number;

    fn new() -> Counter {
        return Counter { value: 0 };
    }

    fn increment(self) -> void {
        self.value += 1;
    }

    fn reset(self) -> void {
        self.value = 0;
    }

    fn get(self) -> number {
        return self.value;
    }
}

test "structs: field access returns correct values" {
    let p = Point { x: 3, y: 4 };
    assert p.x == 3;
    assert p.y == 4;
}

test "structs: method computes distance squared from origin" {
    let p = Point { x: 3, y: 4 };
    assert p.distance_squared_from_origin() == 25;
}

test "structs: method returns new struct with translated coordinates" {
    let p = Point { x: 1, y: 2 };
    let q = p.translate(3, -1);
    assert q.x == 4;
    assert q.y == 1;
}

test "structs: constructor via static method" {
    let r = Rectangle.new(5, 3);
    assert r.width == 5;
    assert r.height == 3;
}

test "structs: area method returns correct value" {
    let r = Rectangle.new(6, 4);
    assert r.area() == 24;
}

test "structs: perimeter method returns correct value" {
    let r = Rectangle.new(5, 3);
    assert r.perimeter() == 16;
}

test "structs: is_square true for equal sides" {
    let r = Rectangle.new(4, 4);
    assert r.is_square() == true;
}

test "structs: is_square false for unequal sides" {
    let r = Rectangle.new(3, 5);
    assert r.is_square() == false;
}

test "structs: mutable field updated by method" {
    let c = Counter.new();
    c.increment();
    c.increment();
    assert c.get() == 2;
}

test "structs: reset brings mutable field back to zero" {
    let c = Counter.new();
    c.increment();
    c.increment();
    c.reset();
    assert c.get() == 0;
}
