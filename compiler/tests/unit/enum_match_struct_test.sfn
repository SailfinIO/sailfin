// Seed viability tests: enum match + struct field access + loop filtering.
// Targets: match on enum, enum equality in loops, struct with enum fields.
enum Priority {
    Low,
    Medium,
    High,
    Critical
}

enum TaskStatus {
    Todo,
    InProgress,
    Done,
    Blocked
}

struct Task {
    name: string;
    priority: Priority;
    status: TaskStatus;
    effort: int;
}

// ---------------------------------------------------------------------------
// Enum equality in loops and conditions
// ---------------------------------------------------------------------------
fn _count_by_status(tasks: Task[], status: TaskStatus) -> int {
    let mut count: int = 0;
    let mut i: int = 0;
    loop {
        if i >= tasks.length { break; }
        if tasks[i].status == status { count += 1; }
        i += 1;
    }
    return count;
}

test "enum_match: count tasks by status" {
    let mut tasks: Task[] = [];
    tasks.push(Task {
        name: "A", priority: Priority.High, status: TaskStatus.Todo, effort: 1
    });
    tasks.push(Task {
        name: "B", priority: Priority.Low, status: TaskStatus.Done, effort: 2
    });
    tasks.push(Task {
        name: "C", priority: Priority.Medium, status: TaskStatus.Todo, effort: 3
    });
    tasks.push(Task {
        name: "D", priority: Priority.High, status: TaskStatus.InProgress, effort: 1
    });
    tasks.push(Task {
        name: "E", priority: Priority.Low, status: TaskStatus.Todo, effort: 4
    });

    assert _count_by_status(tasks, TaskStatus.Todo) == 3;
    assert _count_by_status(tasks, TaskStatus.Done) == 1;
    assert _count_by_status(tasks, TaskStatus.InProgress) == 1;
    assert _count_by_status(tasks, TaskStatus.Blocked) == 0;
}

// ---------------------------------------------------------------------------
// Match on enum in combination with struct
// _format_task calls _priority_label, so _priority_label (which uses match)
// must appear below _format_task for the seedcheck's recovery parser.
// ---------------------------------------------------------------------------
fn _format_task(t: Task) -> string {
    let plabel = _priority_label(t.priority);
    return "[" + plabel + "] " + t.name;
}

test "enum_match: format with struct" {
    let t = Task {
        name: "Deploy",
        priority: Priority.Critical,
        status: TaskStatus.Todo,
        effort: 5
    };
    assert _format_task(t) == "[P0] Deploy";
}

fn _priority_label(p: Priority) -> string {
    match p {
        Priority.Low: return "P3",
        Priority.Medium: return "P2",
        Priority.High: return "P1",
        Priority.Critical: return "P0"
    }
}

test "enum_match: all priority labels" {
    assert _priority_label(Priority.Low) == "P3";
    assert _priority_label(Priority.Medium) == "P2";
    assert _priority_label(Priority.High) == "P1";
    assert _priority_label(Priority.Critical) == "P0";
}

// ---------------------------------------------------------------------------
// Monomorphic enum with an INLINE struct payload (#830 / #1021 regression).
//
// A non-generic enum stores a user-struct variant payload INLINE (by value),
// so the `match` binding must load the struct by value. This is the
// `!substituted == true` branch of the pointer-strip in
// `instructions_match_condition.sfn`: the boxed-payload fix (#830) only diverts
// the GENERIC, monomorphised path (where the payload is stored boxed as `%T*`)
// to keep the pointer — the non-generic inline path here must keep stripping to
// a by-value load. Without this test, a future change to that branch could
// silently regress non-generic struct payloads with no coverage to catch it.
struct Letter {
    sender: string;
    weight: int;
}

enum Mail {
    Empty,
    Parcel { item: Letter }
}

fn _parcel_weight(m: Mail, fallback: int) -> int {
    match m {
        Mail.Empty => { return fallback; },
        Mail.Parcel { item } => {
            return item.weight + item.sender.length;
        }
    }
}

test "enum_match: monomorphic inline struct payload binds by value" {
    assert _parcel_weight(Mail.Empty, 7) == 7;
    assert _parcel_weight(Mail.Parcel {
        item: Letter { sender: "ann", weight: 12 }
    }, 0) == 15;
}
