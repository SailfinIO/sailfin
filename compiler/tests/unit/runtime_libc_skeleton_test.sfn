// Golden-IR test for the `runtime/sfn/platform/libc.sfn` skeleton —
// the first file on the path to a pure-Sailfin runtime (see
// `docs/runtime_architecture.md` §2.9 "Platform Extern Declarations").
//
// Replaces `compiler/tests/e2e/test_runtime_libc_skeleton.sh` as part of
// the bash-collapse migration (epic #842, issue #1223). The `.sh` ran
// `sfn check` + `sfn fmt --check` + `sfn emit llvm` and grepped the IR
// for a `declare` per extern; this pins the same `declare` surface
// in-process. The typecheck/fmt halves are covered elsewhere — CI runs
// `sfn fmt --check` over `runtime/` and `make compile` typechecks these
// sfn-sources; an in-process lowering that reached a malformed file would
// fail outright before the assertions ran.
//
// Strategy: ONE `lower_to_llvm_ir_from_text` call over the REAL skeleton
// file (read via `fs.readFile`, so a regression in the live source is
// caught). `libc.sfn` has no imports, so single-module lowering resolves
// every symbol it declares.
import { emit_native_text_with_module_name } from "../../src/emit_native";
import { lower_to_llvm_ir_from_text } from "../../src/llvm/lowering/entrypoints";
import { parse_program } from "../../src/parser/mod";
import { index_of } from "../../src/string_utils";

fn _contains(haystack: string, needle: string) -> boolean {
    return index_of(haystack, needle) >= 0;
}

// Every extern lowers to a referenced symbol in the emitted IR. The
// skeleton has no function bodies, so each `@sym(` appears only in its
// `declare` line — a missing entry means that extern stopped emitting a
// declaration (the regression the `.sh` guarded against).
test "lowering: runtime/sfn/platform/libc.sfn emits a declare for every extern" ![io] {
    let source = fs.readFile("runtime/sfn/platform/libc.sfn");
    let program = parse_program(source);
    let native = emit_native_text_with_module_name(program, "runtime/sfn/platform/libc");
    let ir = lower_to_llvm_ir_from_text(native, "runtime/sfn/platform/libc");

    assert _contains(ir, "declare ");
    assert _contains(ir, "@malloc(");
    assert _contains(ir, "@free(");
    assert _contains(ir, "@realloc(");
    assert _contains(ir, "@memcpy(");
    assert _contains(ir, "@memcmp(");
    assert _contains(ir, "@write(");
    assert _contains(ir, "@read(");
    assert _contains(ir, "@fopen(");
    assert _contains(ir, "@fclose(");
    assert _contains(ir, "@fread(");
    assert _contains(ir, "@fwrite(");
    assert _contains(ir, "@getenv(");
}
