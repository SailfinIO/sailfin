// #1318 (C5 of epic #1308): regression coverage for the Sailfin-native
// `sfn_str_concat` body that replaced the C entrypoint. The interesting case
// the existing `string_concat_test` / `string_stress_test` files do not pin is
// concatenation where an operand is an indexed character (`s[i]`). With the
// immediate-codepoint encoding retired (#1420/#822), `s[i]` yields an ordinary
// one-byte grapheme string; these tests confirm that indexed-character
// concatenation round-trips byte-for-byte.
test "concat: immediate char + real string" {
    let src = "hello";
    let r = src[0] + "!";
    assert r == "h!";
    assert r.length == 2;
}

test "concat: real string + immediate char" {
    let src = "hello";
    let r = "(" + src[1];
    assert r == "(e";
}

test "concat: immediate char + immediate char" {
    let src = "hello";
    let r = src[0] + src[1];
    assert r == "he";
    assert r.length == 2;
}

test "concat: chained immediate characters" {
    let src = "hello";
    let r = src[0] + src[1] + src[2] + src[3] + src[4];
    assert r == "hello";
    assert r.length == 5;
}

test "concat: empty-operand identities" {
    let a = "" + "ab";
    let b = "ab" + "";
    let c = "" + "";
    assert a == "ab";
    assert b == "ab";
    assert c == "";
    assert c.length == 0;
}

// Reuse-window non-regression: a chained build at moderate scale must complete
// within the normal memory budget (the abandoned reuse-protocol attempt
// regressed this to O(n²)/OOM; the window-agnostic native body does not).
fn _repeat(base: string, n: int) -> string {
    let mut result: string = "";
    let mut i: int = 0;
    loop {
        if i >= n { break; }
        result = result + base;
        i += 1;
    }
    return result;
}

test "concat: chained build at scale stays correct" {
    let s = _repeat("ab", 500);
    assert s.length == 1000;
    assert s[0] == "a";
    assert s[1] == "b";
    assert s[998] == "a";
    assert s[999] == "b";
}
