// E2E test for the Sailfin-native clock_gettime field-reader (#878,
// epic #763).
//
// Native replacement for the former `test_clock_gettime_reader.sh`
// (test-infra Phase 3, epic #842; ratchet #1327).
//
// `runtime/sfn/clock.sfn` defines `sfn_clock_monotonic_nanos() -> i64`,
// the shared field-reader: it stack-allocates a `Timespec`, hands the
// kernel `& ts`, calls `clock_gettime(CLOCK_MONOTONIC, &ts)`, then reads
// `tv_sec` (offset 0) and `tv_nsec` (the second `i64`, reached by a `+ 1`
// pointer step that lowers to a `getelementptr`) back through the
// `sailfin_intrinsic_pointer_read_i64` registry sentinel (#875), which
// lowers directly to an LLVM `load i64` — there is no C symbol behind it.
//
// Pins the shape against the *real shipped module*, and runs the adapter
// to prove monotonic advance:
//
//   1. typecheck   — `sfn check clock.sfn` exits 0.
//   2. call shape  — emitted IR `declare`s `i32 @clock_gettime` and the
//                    adapter body has exactly one `call i32 @clock_gettime`.
//   3. two reads   — the body has >= 2 local-pointer `load i64, i64* %…`.
//   4. STALE-READ GUARD — no local-pointer `load i64, i64* %…` precedes
//                    the `call @clock_gettime` (the kernel's write must be
//                    observed; no earlier cached load of the slot is reused)
//                    and >= 2 follow it.
//   5. gep field   — the second field is reached via
//                    `getelementptr i64, i64* %…` (the `+ 1` step).
//   6. no sentinel — the pointer-read sentinel never surfaces as a
//                    `call`/`declare` (it must be a load).
//   7. monotonic   — the adapter returns a non-decreasing, non-zero value
//                    across two back-to-back calls.
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]` and so
// cannot be called from an `![io]` test like this. Assert on the captured
// `.ll` text with `sfn/strings` predicates instead. (#842.)
import { contains, find, split } from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

fn _child_env() -> string[] ![io] {
    // Inherit the full parent environment: PATH/HOME/TMPDIR plus the macOS
    // SDK/toolchain vars the nested clang/ld need (a minimal set links on
    // Linux but fails on macOS with `ld: library 'm' not found`, #1410),
    // and SAILFIN_TEST_SCRATCH for per-invocation build-cache isolation
    // (#1333). Mirrors serve_loopback_test.sfn / process_environ_test.sfn.
    return process.environ();
}

fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    return dir;
}

let _CLOCK_SFN: string = "runtime/sfn/clock.sfn";

fn _emit_clock() -> string ![io] {
    let dir = _scratch_dir();
    let ll = dir + "/sfn-clock.ll";
    if fs.exists(ll) { fs.deleteFile(ll); }
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", ll, "llvm", _CLOCK_SFN], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    if exit != 0 { return ""; }
    if !fs.exists(ll) { return ""; }
    let ir = fs.readFile(ll);
    fs.deleteFile(ll);
    return ir;
}

// Isolate the `@sfn_clock_monotonic_nanos` body — the lines from its
// `define` through the closing `}` — for the ordering-sensitive checks
// (the faithful stand-in for the bash `awk '/define .../,/^}/'`).
fn _isolate_body(ir: string) -> string[] {
    let lines = split(ir, "\n");
    let mut body: string[] = [];
    let mut inside = false;
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if !inside {
            if contains(line, "define i64 @sfn_clock_monotonic_nanos") {
                inside = true;
                body.push(line);
            }
        } else {
            body.push(line);
            if line == "}" { break; }
        }
        i += 1;
    }
    return body;
}

fn _count_lines_with(lines: string[], needle: string) -> int {
    let mut n = 0;
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        if contains(lines[i], needle) { n += 1; }
        i += 1;
    }
    return n;
}

// First index of a line containing `needle`, or -1.
fn _first_index(lines: string[], needle: string) -> int {
    let mut i = 0;
    loop {
        if i >= lines.length { return -1; }
        if contains(lines[i], needle) { return i; }
        i += 1;
    }
}

fn _any_line_with(text: string, a: string, b: string) -> bool {
    let lines = split(text, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        if contains(lines[i], a) && contains(lines[i], b) { return true; }
        i += 1;
    }
    return false;
}

test "clock-reader: sfn check passes on runtime/sfn/clock.sfn" ![io] {
    let exit = process.run_capture([_sfn_bin(), "check", _CLOCK_SFN], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    assert exit == 0;
}

test "clock-reader: declares + calls i32 @clock_gettime exactly once" ![io] {
    let ir = _emit_clock();
    assert ir.length > 0;
    assert contains(ir, "declare i32 @clock_gettime(");
    let body = _isolate_body(ir);
    assert body.length > 0;
    // Exactly one syscall: the #909 sentinel swap folds the platform clk_id
    // to an emit-time immediate, collapsing the #905 runtime probe.
    assert _count_lines_with(body, "call i32 @clock_gettime(") == 1;
}

test "clock-reader: >= 2 local-pointer i64 field reads" ![io] {
    let ir = _emit_clock();
    assert ir.length > 0;
    let body = _isolate_body(ir);
    // `load i64, i64* @global.…` (constant loads) do not match the local
    // `%` prefix, so this counts only field reads through local pointers.
    assert _count_lines_with(body, "load i64, i64* %") >= 2;
}

test "clock-reader: STALE-READ GUARD — field loads only after the call" ![io] {
    let ir = _emit_clock();
    assert ir.length > 0;
    let body = _isolate_body(ir);
    let call_idx = _first_index(body, "call i32 @clock_gettime(");
    assert call_idx >= 0;
    // No local-pointer i64 load may precede the call (it would read stale
    // alloca data before the kernel writes the Timespec).
    let mut pre = 0;
    let mut post = 0;
    let mut i = 0;
    loop {
        if i >= body.length { break; }
        if contains(body[i], "load i64, i64* %") {
            if i < call_idx { pre += 1; } else { post += 1; }
        }
        i += 1;
    }
    assert pre == 0;
    assert post >= 2;
}

test "clock-reader: tv_nsec reached via getelementptr i64" ![io] {
    let ir = _emit_clock();
    assert ir.length > 0;
    let body = _isolate_body(ir);
    assert _count_lines_with(body, "getelementptr i64, i64* %") >= 1;
}

test "clock-reader: pointer-read sentinel is a load, not a call/declare" ![io] {
    let ir = _emit_clock();
    assert ir.length > 0;
    assert ! _any_line_with(ir, "call ", "@sailfin_intrinsic_pointer_read_i64");
    assert ! _any_line_with(ir, "declare ", "@sailfin_intrinsic_pointer_read_i64");
}

test "clock-reader: adapter returns a monotonic, non-zero reading" ![io] {
    // Compile + link + run a fixture that calls the runtime primitive via
    // an extern declaration (the same linkage path that makes `sfn_sleep`
    // callable). The child env threads PATH (clang + linker) and
    // SAILFIN_TEST_SCRATCH (per-invocation program.ll cache, #1333).
    let dir = _scratch_dir();
    let src = dir + "/sfn-clock-mono.sfn";
    fs.writeFile(src, "extern fn sfn_clock_monotonic_nanos() -> i64;\n\nfn main() ![io] {\n    let a: i64 = sfn_clock_monotonic_nanos();\n    let b: i64 = sfn_clock_monotonic_nanos();\n    if b >= a {\n        print(\"MONO_OK\");\n    } else {\n        print(\"MONO_FAIL\");\n    }\n    if a > 0 {\n        print(\"NONZERO_OK\");\n    } else {\n        print(\"NONZERO_FAIL\");\n    }\n}\n");
    let exit = process.run_capture([_sfn_bin(), "run", src], _child_env());
    let out = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    fs.deleteFile(src);
    assert exit == 0;
    assert find(out + err, "MONO_OK", 0) >= 0;
    assert find(out + err, "NONZERO_OK", 0) >= 0;
}
