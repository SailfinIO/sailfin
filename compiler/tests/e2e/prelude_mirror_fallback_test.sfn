// compiler/tests/e2e/prelude_mirror_fallback_test.sfn
//
// E2E test for #1780 (SFEP-0035 §3.2): pins the derived prelude-mirror ABI
// end-to-end on the fallback (non-importing-caller) path. A module that
// calls the six prelude "mirror" free functions (`char_code`, `char_at`,
// `char_from_code`, `find_char`, `string_starts_with`,
// `record_eq_flag_message`) without importing the prelude is emitted via the
// derived `declare` lines in `render_runtime_helper_declarations`
// (`prelude_mirror_signatures.sfn`) rather than a hand-typed registry row.
// The one that mattered was `char_from_code`, whose derived shape is now
// `{i8*, i64}` (previously a latent `i8*` drift) — building and running this
// fixture proves the corrected ABI actually links and round-trips, not just
// that it type-checks.
//
// Modeled on `guillermo_test.sfn` for `_sfn_bin()` and on
// `sailfin_main_entry_test.sfn` for the build-and-run + parallel-runner
// isolation shape (`.claude/rules/no-bash-e2e.md`).
import { find } from "sfn/strings";
import { with_tmp_dir } from "sfn/test";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

// Child environment for the spawned `sfn build`: inherit the full parent
// environment (PATH/HOME/TMPDIR plus SAILFIN_TEST_SCRATCH, so the nested
// build's `program.ll` build-cache dir is routed per-invocation (#1333) and
// does not collide with a sibling build under the parallel `sfn test` pool).
fn _child_env() -> string[] ![io] { return process.environ(); }

fn _fixture_src() -> string {
    return "fn main() -> int ![io] {\n" + "    let s = char_from_code(104);\n"
        + "    let code = char_code(s);\n"
        + "    let c = char_at(\"hello\", 1);\n"
        + "    let idx = find_char(\"hello\", \"l\", 0);\n"
        + "    let sw = string_starts_with(\"hello\", \"he\");\n"
        + "    let req = record_eq_flag_message(true, \"ok\", true, \"ok\");\n"
        + "    print.info(\"roundtrip=\" + number_to_string(code) + \" at=\" + c + \" idx=\" + number_to_string(idx));\n"
        + "    if code == 104 { if sw { if req { return 0; } } }\n"
        + "    return 1;\n"
        + "}\n";
}

// Build the fixture in a temp dir and run it. Stashes the run's captured
// stdout to `out_marker` (a path outside the temp dir, so it survives
// `with_tmp_dir` teardown) and returns the run's exit code, or `-100` if the
// build itself failed.
fn _build_and_run(out_marker: string) -> int ![io] {
    return with_tmp_dir(fn (dir: string) -> int {
        let srcpath = dir + "/fallback_probe.sfn";
        fs.writeFile(srcpath, _fixture_src());
        let binpath = dir + "/fallback_probe";
        let build_exit = process.run_capture([_sfn_bin(), "build", "-o", binpath, srcpath], _child_env());
        let _bo = process.capture_take_stdout();
        let _be = process.capture_take_stderr();
        if build_exit != 0 { return -100; }
        let run_exit = process.run_capture([binpath], []);
        let out = process.capture_take_stdout();
        let _re = process.capture_take_stderr();
        fs.writeFile(out_marker, out);
        return run_exit;
    });
}

fn _marker(name: string) -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    let path = dir + "/sfn-prelude-mirror-fallback-" + name + ".out";
    if fs.exists(path) { fs.deleteFile(path); }
    return path;
}

test "prelude-mirror fallback (#1780): non-importing caller builds and runs; char_from_code roundtrips" ![io] {
    let marker = _marker("roundtrip");
    let exit = _build_and_run(marker);
    // Assert the build+run succeeded (`-100` == build failure) before
    // touching the marker: on a build failure the marker is never written.
    assert exit == 0;
    let out = fs.readFile(marker);
    if fs.exists(marker) { fs.deleteFile(marker); }
    assert find(out, "roundtrip=104", 0) >= 0;
    assert find(out, "at=e", 0) >= 0;
    assert find(out, "idx=2", 0) >= 0;
}
