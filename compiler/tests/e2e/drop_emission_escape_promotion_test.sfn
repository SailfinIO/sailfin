// End-to-end test for the M1.5.5 conservative escape-promotion rule
// (issue #329).
//
// Native replacement for the former `test_drop_emission_escape_promotion.sh`
// (test-infra Phase 3, epic #842; ratchet #1327). Drives `sfn emit llvm`
// on `fixtures/escape_promotion_basic.sfn` and asserts on the emitted IR:
//
//   1. The compiler still emits `declare void @sfn_rc_release(i8*)` for
//      the module — the M1.5.2 runtime ABI seam survives.
//   2. A primitive-typed return (`make_int` -> `i64`) emits NO
//      `sfn_rc_release` call (`is_heap_type` excludes scalars).
//   3. A parameter return (`forwarder`) does not promote the parameter.
//   4. The total release-call count meets the current floor (0): the only
//      escape path that flips a local to rc today also marks it consumed,
//      so the seam fires but emits zero releases for this fixture.
//
// IR assertions use `sfn/strings::find`/`contains` over the read-back `.ll`
// (the `sfn/test` `expect_*` matchers are `![pure]` and cannot be called
// from an `![io]` test; #842). The emitting child inherits the full parent
// environment via `process.environ()` so its build-cache routes under the
// runner's `SAILFIN_TEST_SCRATCH` (#1333) for parallel-pool isolation.
import { find, contains } from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

// Count non-overlapping occurrences of `needle` in `haystack`.
fn _count(haystack: string, needle: string) -> int {
    if needle.length == 0 { return 0; }
    let mut n: int = 0;
    let mut pos: int = 0;
    loop {
        let idx = find(haystack, needle, pos);
        if idx < 0 { break; }
        n += 1;
        pos = idx + needle.length;
    }
    return n;
}

// Return the body text of the function whose `define` line contains
// `anchor` (e.g. "@make_int"), from the start of its `define` line through
// its closing `}`. Empty string when the anchor is absent.
fn _fn_body(ll: string, anchor: string) -> string {
    let idx = find(ll, anchor, 0);
    if idx < 0 { return ""; }
    let mut start = idx;
    loop {
        if start <= 0 { break; }
        if substring(ll, start - 1, start) == "\n" { break; }
        start -= 1;
    }
    let close = find(ll, "\n}", idx);
    let mut end = close;
    if end < 0 { end = ll.length; } else { end = close + 2; }
    return substring(ll, start, end);
}

// A fresh emit-target path under the runner's scratch dir (or /tmp), keyed
// by `tag` so concurrent tests never collide; any stale file is removed.
fn _ll_path(tag: string) -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    let path = dir + "/sfn-escape-promotion-" + tag + ".ll";
    if fs.exists(path) { fs.deleteFile(path); }
    return path;
}

// Emit LLVM IR for the fixture to `out_path` and return it as a string.
// Returns "" when the emit failed.
fn _emit_ir(out_path: string) -> string ![io] {
    let fixture = "compiler/tests/e2e/fixtures/escape_promotion_basic.sfn";
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", out_path, "llvm", fixture], process.environ());
    let _ = process.capture_take_stdout();
    let _ = process.capture_take_stderr();
    if exit != 0 { return ""; }
    if !fs.exists(out_path) { return ""; }
    return fs.readFile(out_path);
}

test "escape-promotion: emits declare void @sfn_rc_release(i8*)" ![io] {
    let ll = _emit_ir(_ll_path("declare"));
    assert ll.length > 0;
    assert contains(ll, "declare void @sfn_rc_release(i8*)");
}

test "escape-promotion: primitive (i64) return emits no release call" ![io] {
    let ll = _emit_ir(_ll_path("primitive"));
    assert ll.length > 0;
    let body = _fn_body(ll, "@make_int");
    assert _count(body, "call void @sfn_rc_release") == 0;
}

test "escape-promotion: parameter return emits no release call" ![io] {
    let ll = _emit_ir(_ll_path("parameter"));
    assert ll.length > 0;
    let body = _fn_body(ll, "@forwarder");
    assert _count(body, "call void @sfn_rc_release") == 0;
}

test "escape-promotion: total release-call count meets the floor (0)" ![io] {
    let ll = _emit_ir(_ll_path("total"));
    assert ll.length > 0;
    // EXPECT_RELEASE_CALLS_GE = 0: every escape-promoted local is also
    // consumed at the same return today, so the seam emits zero releases.
    assert _count(ll, "call void @sfn_rc_release") >= 0;
}
