// End-to-end coverage for `sfn completion <shell>` script generation.
//
// The completion script is emitted from the live `sfn/cli` HelpNode derived
// from the root command tree — the same introspection source as
// `--help --json` — not a hand-maintained list. This test pins deterministic
// output, command coverage, target-shell syntax validity, and the
// unsupported-/missing-shell error paths (SFN-130, SFEP-0027 Phase D).
import { contains } from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    return dir;
}

// Probe for a runnable `bash`; the syntax-check leg is skipped when absent,
// mirroring the `command -v` SKIP the legacy shell tests used
// (.claude/rules/no-bash-e2e.md).
fn _has_bash() -> boolean ![io] {
    let exit = process.run_capture(["bash", "--version"], _child_env());
    let _ = process.capture_take_stdout();
    let _ = process.capture_take_stderr();
    return exit == 0;
}

test "cli completion: bash script is deterministic and names registered commands" ![io] {
    let exit1 = process.run_capture([_sfn_bin(), "completion", "bash"], _child_env());
    let out1 = process.capture_take_stdout();
    let err1 = process.capture_take_stderr();
    assert exit1 == 0;
    assert err1.length == 0;

    let exit2 = process.run_capture([_sfn_bin(), "completion", "bash"], _child_env());
    let out2 = process.capture_take_stdout();
    let err2 = process.capture_take_stderr();
    assert exit2 == 0;
    assert err2.length == 0;
    assert strings_equal(out1, out2);

    // The `complete -F` registration and the completion function are the
    // structural anchors of a bash completion script.
    assert contains(out1, "complete -F _sfn_complete sfn");
    assert contains(out1, "_sfn_complete()");
    assert contains(out1, "compgen -W");

    // Command coverage is derived from the registered tree, so known
    // subcommands appear both in the top-level word list and as case arms.
    assert contains(out1, "build");
    assert contains(out1, "run");
    assert contains(out1, "check");
    assert contains(out1, "test");
    assert contains(out1, "completion");
}

test "cli completion: generated bash script passes bash -n syntax check" ![io] {
    if !_has_bash() {
        assert true;
        return;
    }
    let exit = process.run_capture([_sfn_bin(), "completion", "bash"], _child_env());
    let script = process.capture_take_stdout();
    let _err = process.capture_take_stderr();
    assert exit == 0;

    let path = _scratch_dir() + "/sfn-completion.bash";
    fs.writeFile(path, script);

    // `bash -n` parses without executing: a syntactically invalid completion
    // script fails here even though `sfn` emitted it happily.
    let check_exit = process.run_capture(["bash", "-n", path], _child_env());
    let check_out = process.capture_take_stdout();
    let check_err = process.capture_take_stderr();
    assert check_exit == 0;
    assert check_out.length == 0;
    assert check_err.length == 0;
}

test "cli completion: unsupported shell exits 2 with a diagnostic" ![io] {
    let exit = process.run_capture([_sfn_bin(), "completion", "powershell"], _child_env());
    let out = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    assert exit == 2;
    assert contains(out + err, "unsupported shell");
}

test "cli completion: missing shell argument is a usage error" ![io] {
    let exit = process.run_capture([_sfn_bin(), "completion"], _child_env());
    let out = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    assert exit == 2;
    assert contains(out + err, "usage: sfn completion");
}
