// compiler/tests/e2e/dep_object_cache_test.sfn
//
// End-to-end regression coverage for the object-only test link cache
// (#2013, SFN-453).
//
// Verifies two contracts:
//   A. When a nested `sfn test` run uses a shared
//      SAILFIN_TEST_RUNTIME_OBJDIR, the link-object cache contains `.o`
//      entries for the test source and dependency LLVM modules.
//   B. When `link-obj` is unwritable (chmod 555), the nested `sfn test` run
//      still exits 0 by assembling ephemeral objects beside the `.ll` inputs;
//      raw IR never crosses the final-link boundary.
//
// Follows the `guillermo_test.sfn` shape: `_sfn_bin()` honours `SAILFIN_BIN`,
// `_child_env()` threads PATH/HOME/TMPDIR/SAILFIN_TEST_SCRATCH and the
// parent cache knobs per the build-and-run isolation rule
// (`.claude/rules/no-bash-e2e.md`). env-safe (SFN-401): hand-built minimal
// env, no raw process.environ() pool-key leak.
import { find, split, contains } from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

fn _child_env(scratch: string, objdir: string) -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    let build_cache = env.get("SAILFIN_BUILD_CACHE_DIR");
    if build_cache.length > 0 {
        e.push("SAILFIN_BUILD_CACHE_DIR=" + build_cache);
    }
    let no_cache = env.get("SAILFIN_NO_CACHE");
    if no_cache.length > 0 { e.push("SAILFIN_NO_CACHE=" + no_cache); }
    if objdir.length > 0 {
        e.push("SAILFIN_TEST_RUNTIME_OBJDIR=" + objdir);
    }
    return e;
}

fn _scratch_base() -> string ![io] {
    let mut base = env.get("SAILFIN_TEST_SCRATCH");
    if base.length == 0 { base = "/tmp"; }
    fs.createDirectory(base, true);
    return base;
}

test "test link: dep objects cached content-addressed in the shared objdir" ![io] {
    let base = _scratch_base();
    let d = fs.mkdtemp(base + "/sfn-dep-obj-cache-a-");
    let env_args = _child_env(d, d);
    // `--no-test-cache` bypasses the test-binary artifact cache so the
    // cold compile+link path always runs and populates `link-obj/`; without
    // it a warm test-bin cache hit skips `_clang_link_test_cmd_with_deps`
    // entirely and the link-obj dir is never created.
    let exit = process.run_capture([_sfn_bin(), "test", "--no-test-cache", "compiler/tests/unit/string_utils_test.sfn"], env_args);
    let _out = process.capture_take_stdout();
    let _err = process.capture_take_stderr();
    assert exit == 0;
    // Verify link-obj was created and contains at least one cached object.
    let ls_exit = process.run_capture(["sh", "-c", "ls '" + d
        + "/link-obj' 2>/dev/null"], []);
    let ls_out = process.capture_take_stdout();
    let _ls_err = process.capture_take_stderr();
    assert ls_exit == 0;
    assert find(ls_out, ".o", 0) >= 0;
}

test "test link: unwritable link-obj dir uses ephemeral objects" ![io] {
    let base = _scratch_base();
    let d2 = fs.mkdtemp(base + "/sfn-dep-obj-cache-b-");
    // Pre-create link-obj and make it unwritable so cache publication fails.
    let link_obj_dir = d2 + "/link-obj";
    fs.createDirectory(link_obj_dir, true);
    let chmod_rc = process.run(["chmod", "555", link_obj_dir]);
    assert chmod_rc == 0;
    let env_args = _child_env(d2, d2);
    let exit = process.run_capture([_sfn_bin(), "test", "--no-test-cache", "compiler/tests/unit/string_utils_test.sfn"], env_args);
    let _out = process.capture_take_stdout();
    let _err = process.capture_take_stderr();
    // Restore before any early-return so tmp cleanup works.
    let _chmod_back = process.run(["chmod", "755", link_obj_dir]);
    // The suite must pass even when the shared object cache is unavailable;
    // the final link still receives objects only.
    assert exit == 0;
}
