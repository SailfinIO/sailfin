fn _min(a -> number, b -> number) -> number {
    if a < b {
        return a;
    }
    return b;
}

fn _starts_with(haystack -> string, needle -> string) -> boolean {
    if needle.length == 0 {
        return true;
    }
    if haystack.length < needle.length {
        return false;
    }
    let mut i -> number = 0;
    loop {
        if i >= needle.length {
            break;
        }
        if haystack[i] != needle[i] {
            return false;
        }
        i += 1;
    }
    return true;
}

test "stage2: emit-llvm-file writes module preamble" ![io] {
    // Regression test for prior stage2-native corruption where emitted LLVM
    // started mid-body with a stray leading character and was missing the
    // `source_filename = ...` preamble entirely.

    let compiler = "./build/native/sailfin-stage2";
    let input = "compiler/src/llvm/lowering/instructions.sfn";
    let out_dir = "build/sailfin";
    let out_path = "build/sailfin/emit_llvm_file_preamble_test.ll";

    // Best-effort: ensure output dir exists and remove stale file.
    fs.createDirectory(out_dir, true);
    fs.deleteFile(out_path);

    assert fs.exists(compiler);
    assert fs.exists(input);

    let rc = process.run([compiler, "emit-llvm-file", input, out_path]);
    assert rc == 0;
    assert fs.exists(out_path);

    // Validate the preamble without reading the entire file into a Sailfin string.
    // (The runtime currently guards `string_length` with a 1MiB scan cap.)
    let code = "import sys\n" +
        "p=sys.argv[1]\n" +
        "data=open(p,'rb').read(4096)\n" +
        "text=data.decode('utf-8','replace').replace('\\r\\n','\\n')\n" +
        "expected='source_filename = \\\"llvm/lowering/instructions.sfn\\\"'\n" +
        "# Accept optional '; ModuleID = ...' header before source_filename.\n" +
        "for line in text.split('\\n')[:50]:\n" +
        "    if not line.strip():\n" +
        "        continue\n" +
        "    if line.lstrip().startswith(';'):\n" +
        "        continue\n" +
        "    if line.startswith('source_filename = '):\n" +
        "        sys.exit(0 if line == expected else 2)\n" +
        "    # If we reach other top-level entities first, treat as failure.\n" +
        "    if line.startswith(('target ', 'declare ', 'define ', '@', '%', '!', 'attributes ')):\n" +
        "        sys.exit(3)\n" +
        "# Fallback: still allow finding it very early in file.\n" +
        "sys.exit(0 if expected in text else 1)\n";
    let python_abs = "/usr/bin/python3";
    let env = "/usr/bin/env";

    let mut check -> number = 1;
    if fs.exists(python_abs) {
        check = process.run([python_abs, "-c", code, out_path]);
    } else {
        assert fs.exists(env);
        check = process.run([env, "python3", "-c", code, out_path]);
    }
    assert check == 0;
}
