// End-to-end test for the M5.3 `@main` lowering's argv pass-through
// (#471).
//
// Native replacement for the former `test_sailfin_main_entry.sh`
// (test-infra Phase 3, epic #842; ratchet #1327). Builds the fixture at
// `compiler/tests/e2e/fixtures/sailfin_main_entry_probe.sfn`, runs it,
// and asserts the user-visible `argv[1]` round-trips through the
// synthesized `@main(argc, argv)` prologue's
// `sailfin_runtime_argv_to_string_array` call into the user body.
//
// Pinned shape:
//   1. exit code   — the fixture returns 0 on success / 2 on a missing
//                    argument; verifies the wrapper's `fptosi double to
//                    i32` cast lands the user return value on the exit
//                    status.
//   2. argv pass-  — stdout echoes the second argv element (the first
//      through        user argument); confirms argv[1] is readable from
//                    inside user main.
//
// Build hygiene: the fixture source is written into a fresh temp dir
// (via `with_tmp_dir`) before building, so `sfn build` does not auto-
// discover `runtime/native/capsule.toml` and pull in native_driver.c's
// `main`, which would collide with the emitted `@main` at link time.
// This mirrors the legacy script's "copy out of the repo tree" step.
//
// `with_tmp_dir`'s body returns an `int` and assertions run on that
// return value outside the closure (the `sfn/test` idiom — see
// `capsules/sfn/test/tests/fixtures_test.sfn`). Captured stdout is
// stashed to an out-of-tree marker file so it survives the temp-dir
// teardown and can be asserted after the fixture returns.
import { find } from "sfn/strings";
import { with_tmp_dir } from "sfn/test";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/native/sailfin";
}

fn _fixture_src() -> string ![io] {
    return fs.readFile("compiler/tests/e2e/fixtures/sailfin_main_entry_probe.sfn");
}

// A fresh marker-file path under the runner's scratch dir (or `/tmp`),
// with any stale value removed so each run starts clean. Lives outside
// the `with_tmp_dir` tree so it survives teardown.
fn _marker(name: string) -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    let path = dir + "/sfn-main-entry-" + name + ".out";
    if fs.exists(path) { fs.deleteFile(path); }
    return path;
}

// Build the entry-probe fixture in a temp dir and run it. When `extra`
// is non-empty it is passed as the single user argument. Stashes the
// run's captured stdout to `out_marker` and returns the run's exit code,
// or `-100` if the build itself failed.
fn _build_and_run(out_marker: string, extra: string) -> int ![io] {
    return with_tmp_dir(fn (dir: string) -> int {
        let srcpath = dir + "/probe.sfn";
        fs.writeFile(srcpath, _fixture_src());
        let binpath = dir + "/probe";
        let build_exit = process.run_capture([_sfn_bin(), "build", "-o", binpath, srcpath], []);
        let _bo = process.capture_take_stdout();
        let _be = process.capture_take_stderr();
        if build_exit != 0 { return -100; }
        let mut run_argv: string[] = [binpath];
        if extra.length > 0 { run_argv.push(extra); }
        let run_exit = process.run_capture(run_argv, []);
        let out = process.capture_take_stdout();
        let _re = process.capture_take_stderr();
        fs.writeFile(out_marker, out);
        return run_exit;
    });
}

test "main-entry: argv[1] round-trips through @main into user main" ![io] {
    let marker = _marker("argv");
    let exit = _build_and_run(marker, "sentinel-token");
    let out = fs.readFile(marker);
    if fs.exists(marker) { fs.deleteFile(marker); }
    assert exit == 0;
    assert find(out, "sentinel-token", 0) >= 0;
}

test "main-entry: user non-zero return propagates through the fptosi cast" ![io] {
    let marker = _marker("missing");
    let exit = _build_and_run(marker, "");
    let out = fs.readFile(marker);
    if fs.exists(marker) { fs.deleteFile(marker); }
    assert exit == 2;
    assert find(out, "missing-arg", 0) >= 0;
}
