// End-to-end closure-bloat guard (#1050, epic #1046).
//
// Native replacement for the former `test_capsule_dead_strip_guard.sh`
// (test-infra Phase 3, epic #842; `.claude/rules/no-bash-e2e.md`).
//
// Pins the dead-code strip behavior added in #1047: when a consumer
// imports ONE symbol from a multi-function capsule, the dep's
// unreferenced functions must NOT survive into the linked binary. Before
// #1047 the capsule link step linked every `.ll` from a dep's whole src/
// tree with no garbage collection, so a binary that used only
// `sfn/math::abs` still dragged `clamp`, `mean`, ... into the executable.
//
// `sfn/math` is a deliberate fixture: `abs` is standalone (no internal
// calls), while `clamp` and `mean` are not reachable from it, so a correct
// dead-strip drops them. The guard asserts via `nm` that:
//   - the USED symbol is present (the capsule actually linked — keeps the
//     absence checks from passing vacuously if the dep failed to link), and
//   - clearly-unreferenced sibling symbols are ABSENT (dead-strip ran).
// Reverting #1047's `-ffunction-sections` / `--gc-sections` (Linux) /
// `-dead_strip` (Darwin) flags makes the absence assertions fail.
//
// Fixture: build/sfn-dead-strip-guard-test/ (in-tree so
// discover_workspace_root finds the repo's workspace.toml, which registers
// the in-tree capsules/ tree; no symlinks required). Content is
// deterministic so concurrent parallel runs are safe.
//
// NOTE: assert on captured output with `sfn/strings` predicates — the
// `sfn/test` `expect_*` matchers are `![pure]` and cannot be used from an
// `![io]` test. (#842.)
import { contains, ends_with, split } from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/native/sailfin";
}

// The build spawns a nested clang + linker, so the child needs PATH.
// SAILFIN_TEST_SCRATCH routes the program.ll build-cache per invocation
// so the parallel pool does not collide on build/sailfin. `nm` is also
// resolved through PATH.
fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

// In-tree fixture root (CWD-relative = repo root).
fn _capsule_root() -> string { return "build/sfn-dead-strip-guard-test"; }

// Per-test binary output: SAILFIN_TEST_SCRATCH or /tmp, keyed by tag.
fn _bin_path(tag: string) -> string ![io] {
    let mut base = env.get("SAILFIN_TEST_SCRATCH");
    if base.length == 0 { base = "/tmp"; }
    return base + "/sfn-dead-strip-guard-" + tag + "-prog";
}

// Materialize the consumer that imports ONLY abs from the multi-fn
// sfn/math. `clamp`, `mean`, `pow`, `sign`, ... are never referenced, so a
// correct dead-strip must collect them.
fn _ensure_fixture() ![io] {
    let root = _capsule_root();
    fs.createDirectory(root + "/src", true);
    fs.writeFile(root + "/capsule.toml", "[capsule]\n"
        + "name = \"dead-strip-guard\"\n"
        + "version = \"0.1.0\"\n"
        + "description = \"Closure-bloat guard: one symbol from a multi-fn capsule\"\n\n"
        + "[dependencies]\n"
        + "\"sfn/math\" = \"0.1.0\"\n\n"
        + "[capabilities]\n"
        + "required = [\"io\"]\n\n"
        + "[build]\n"
        + "entry = \"src/main.sfn\"\n");
    fs.writeFile(root + "/src/main.sfn", "import { abs } from \"sfn/math\";\n\n"
        + "fn main() ![io] {\n"
        + "    let a = abs(-7);\n"
        + "    if a != 7 {\n"
        + "        print(\"FAIL abs(-7)\");\n"
        + "    } else {\n"
        + "        print(\"OK\");\n"
        + "    }\n"
        + "}\n");
}

// Capsule functions lower to LLVM symbols mangled
// `<fn>__sfn__<scope>__<mod>` (e.g. `abs__sfn__math__mod`). Matching the
// full mangled suffix keeps the assertions precise — no false hits from
// unrelated symbols that happen to contain a substring like `abs`/`mean`.
fn _mangle_suffix() -> string { return "__sfn__math__mod"; }

// Match a *defined* capsule function symbol in `nm` output, precisely:
//   - ` T ` / ` t ` — a defined symbol in the text section (external `T`
//     or local `t`); anything else (undefined `U`, data, ...) is ignored.
//   - optional leading `_` — ld64 on Darwin prefixes user symbols with an
//     underscore (`_abs__...`); GNU nm on Linux does not. Tolerate both.
//   - end-of-line anchor — the whole mangled name must match, not a
//     substring of some longer symbol.
fn _symbol_defined(syms: string, bare: string) -> boolean {
    let mangled = bare + _mangle_suffix();
    let lines = split(syms, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        let is_text = contains(line, " T ") || contains(line, " t ");
        if is_text && (ends_with(line, " " + mangled) || ends_with(line, "_"
            + mangled)) { return true; }
        i = i + 1;
    }
    return false;
}

// Capture the symbol table of the binary once. Returns "" on nm failure.
fn _dump_symbols(binary: string) -> string ![io] {
    let exit = process.run_capture(["nm", binary], _child_env());
    let out = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    if exit != 0 { return ""; }
    return out;
}

// Build the consumer to `out_bin`; returns the build exit code.
fn _build_consumer(out_bin: string) -> int ![io] {
    _ensure_fixture();
    let exit = process.run_capture([_sfn_bin(), "build", "-p", _capsule_root(), "-o", out_bin], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    return exit;
}

// ---- Test 1: the consumer builds and runs ----
test "dead-strip guard: consumer importing one capsule symbol builds and runs" ![io] {
    let out_bin = _bin_path("run");
    let build_exit = _build_consumer(out_bin);
    assert build_exit == 0;
    assert fs.exists(out_bin);

    let run_exit = process.run_capture([out_bin], _child_env());
    let run_out = process.capture_take_stdout();
    let run_err = process.capture_take_stderr();
    assert run_exit == 0;
    assert contains(run_out + run_err, "OK");
}

// ---- Test 2: the USED symbol survives (sanity: the dep really linked) ----
// Without this check the absence assertions in Test 3 could pass vacuously
// if the whole capsule failed to link or got dropped.
test "dead-strip guard: used capsule symbol (abs) is present in the linked binary" ![io] {
    let out_bin = _bin_path("present");
    let build_exit = _build_consumer(out_bin);
    assert build_exit == 0;
    assert fs.exists(out_bin);

    let syms = _dump_symbols(out_bin);
    assert _symbol_defined(syms, "abs");
}

// ---- Test 3: unreferenced sibling symbols are dead-stripped (#1047) ----
// `clamp` and `mean` are never reachable from `abs`; a correct dead-strip
// drops them. If #1047's strip flags regress, these functions reappear.
test "dead-strip guard: unreferenced capsule symbols (clamp, mean) are stripped" ![io] {
    let out_bin = _bin_path("strip");
    let build_exit = _build_consumer(out_bin);
    assert build_exit == 0;
    assert fs.exists(out_bin);

    let syms = _dump_symbols(out_bin);
    assert ! _symbol_defined(syms, "clamp");
    assert ! _symbol_defined(syms, "mean");
}
