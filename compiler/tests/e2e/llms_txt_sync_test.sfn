// llms.txt drift guard — native replacement for `test_llms_txt_sync.sh`
// (test-infra Phase 3, epic #842; no-bash-e2e ratchet).
//
// llms.txt is the in-context language reference LLM agents read before
// generating Sailfin code — a stale or self-contradictory copy directly
// causes systematic agent errors. This pins the two cheap, mechanical
// freshness invariants the old bash guard pinned:
//
//   1. Single source of truth — site/public/llms.txt is a symlink that
//      resolves to the repo-root llms.txt (exactly one copy).
//   2. Version stamp — the "> Version:" line in llms.txt matches the
//      [capsule] version in compiler/capsule.toml, so every release bump
//      forces an llms.txt review.
//
// There is no sfn-level readlink/symlink probe, so test 1 SHELLS OUT to
// `test -L` and `readlink -f` (Linux always has both); content accuracy
// beyond the version stamp stays a review concern (docs/status.md).
//
// NOTE on matchers: `sfn/test`'s `expect_*` matchers are `![pure]` and so
// cannot be called from an `![io]` test like this. Assert on captured
// subprocess output and on file text via `sfn/strings` predicates and
// `==` instead. (#842.)
import {
    find,
    contains,
    split,
    starts_with,
    trim
} from "sfn/strings";

// PATH/HOME/TMPDIR for the spawned `test`/`readlink` helpers. run_capture's
// empty env is the *empty* environment (not "inherit"), so PATH must be
// threaded explicitly or the helpers are not found.
fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    return e;
}

fn _repo_root() -> string ![io] {
    let root = env.get("SAILFIN_REPO_ROOT");
    if root.length > 0 { return root; }
    return ".";
}

// Run `readlink -f <path>`, capture stdout, and strip a single trailing
// newline so two canonicalized paths compare cleanly.
fn _readlink_f(path: string, e: string[]) -> string ![io] {
    let exit = process.run_capture(["readlink", "-f", path], e);
    let out = process.capture_take_stdout();
    let _err = process.capture_take_stderr();
    if exit != 0 { return ""; }
    return trim(out);
}

test "llms.txt: site copy is a symlink resolving to repo-root llms.txt" ![io] {
    let root = _repo_root();
    let e = _child_env();

    // Probe: skip (not fail) if readlink is unavailable. On Linux it is
    // always present, so this path is for portability only.
    let probe = process.run_capture(["readlink", "--version"], e);
    let _po = process.capture_take_stdout();
    let _pe = process.capture_take_stderr();
    if probe != 0 {
        assert true;
        return;
    }

    let site_copy = root + "/site/public/llms.txt";

    // 1a. It must be a symlink: `test -L` exits 0.
    let is_link = process.run_capture(["test", "-L", site_copy], e);
    let _lo = process.capture_take_stdout();
    let _le = process.capture_take_stderr();
    assert is_link == 0;

    // 1b. It must resolve to the repo-root llms.txt. Canonicalize both
    // sides with `readlink -f` so relative/absolute forms match.
    let resolved_site = _readlink_f(site_copy, e);
    let resolved_root = _readlink_f(root + "/llms.txt", e);
    assert resolved_site.length > 0;
    assert resolved_root.length > 0;
    assert resolved_site == resolved_root;
}

// Extract the value of the first `version = "..."` line in a TOML file:
// the text between the first pair of double quotes on a `version`-prefixed
// (after trim) line.
fn _capsule_version(toml: string) -> string {
    let lines = split(toml, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = trim(lines[i]);
        if starts_with(line, "version") {
            let q1 = find(line, "\"", 0);
            if q1 >= 0 {
                let q2 = find(line, "\"", q1 + 1);
                if q2 > q1 { return substring(line, q1 + 1, q2); }
            }
        }
        i += 1;
    }
    return "";
}

// Extract the version token from the `> Version: <token>` line in llms.txt.
// The token runs from after `Version:` up to the first space or `|`.
fn _llms_version(text: string) -> string {
    let lines = split(text, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if starts_with(line, "> Version:") {
            // Slice off the "> Version:" prefix, then trim, then cut at the
            // first space or '|'.
            let rest = trim(substring(line, 10, line.length));
            let mut j = 0;
            loop {
                if j >= rest.length { break; }
                let ch = rest[j];
                if ch == " " || ch == "|" { break; }
                j += 1;
            }
            return substring(rest, 0, j);
        }
        i += 1;
    }
    return "";
}

test "llms.txt: > Version: line matches compiler/capsule.toml" ![io] {
    let root = _repo_root();

    let toml = fs.readFile(root + "/compiler/capsule.toml");
    let llms = fs.readFile(root + "/llms.txt");

    let capsule_version = _capsule_version(toml);
    let llms_version = _llms_version(llms);

    assert capsule_version.length > 0;
    assert llms_version.length > 0;
    assert capsule_version == llms_version;
}
