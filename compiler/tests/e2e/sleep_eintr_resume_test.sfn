// E2E EINTR-resume regression test for sleep() — issue #693.
//
// Native (no-bash) replacement for the former
// `test_sleep_eintr_resume.sh` (test-infra Phase 3, epic #842;
// `.claude/rules/no-bash-e2e.md`).
//
// Pre-#693, `sfn_sleep` called `nanosleep` exactly once; a signal
// interrupting the call short-circuited the wait (EINTR), so a
// `sleep(500)` could return early. Post-#693, the body wraps
// `nanosleep` in a bounded retry loop (cap = 32) that breaks on
// `ret == 0` and re-issues the same `req` on EINTR, so the requested
// duration is honored across a mid-flight signal.
//
// WHAT THIS LEG PINS: the *IR structure* of the EINTR-resume loop. The
// original .sh injected a real `SIGURG` mid-`nanosleep` via an
// LD_PRELOAD / DYLD_INSERT_LIBRARIES C shim (it installed a handler and
// forked a child to deliver the signal) and timed the wall-clock. A
// preloaded shared library and signal injection are an OS-preload-class
// dependency that cannot run as an `![io]` `sfn/test` leg per
// `.claude/rules/no-bash-e2e.md`, so the wall-clock timing leg is
// OMITTED. Instead we assert the post-#693 retry-loop shape survives in
// the emitted `sfn_sleep` body: a `nanosleep` declare/call, the
// errno-read after a non-zero return (`@__errno_location()`, which the
// errno-locator trampoline lowers to), and the EINTR re-check against
// `@global.EINTR` — the structural fingerprint a regression that
// reverts to a single, errno-unaware `nanosleep` call would erase.
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]`, so
// they cannot be called from an `![io]` test. Use `sfn/strings`
// (`find` / `split` / `starts_with` / `contains`).
import {
    find,
    split,
    starts_with,
    contains
} from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/native/sailfin";
}

fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    dir = dir + "/sfn-sleep-eintr";
    fs.createDirectory(dir, true);
    return dir;
}

fn _emit_module(tag: string, module_path: string) -> string ![io] {
    let dir = _scratch_dir();
    let outpath = dir + "/" + tag + ".ll";
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", outpath, "llvm", module_path], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    if exit != 0 { return "EMIT_FAILED"; }
    return fs.readFile(outpath);
}

fn _has_define(ir: string, sym: string) -> boolean {
    let lines = split(ir, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if starts_with(line, "define ") && contains(line, "@" + sym + "(") {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn _has_declare(ir: string, sym: string) -> boolean {
    let lines = split(ir, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if starts_with(line, "declare ") && contains(line, "@" + sym + "(") {
            return true;
        }
        i = i + 1;
    }
    return false;
}

// Does any `call`/`invoke` line target `@sym(`?
fn _calls(ir: string, sym: string) -> boolean {
    let lines = split(ir, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        let is_call = contains(line, "call ") || contains(line, "invoke ");
        if is_call && contains(line, "@" + sym + "(") { return true; }
        i = i + 1;
    }
    return false;
}

test "runtime/sfn/clock.sfn typechecks cleanly" ![io] {
    let exit = process.run_capture([_sfn_bin(), "check", "runtime/sfn/clock.sfn"], _child_env());
    let out = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    assert exit == 0;
    assert find(out + err, "ok", 0) >= 0;
}

test "runtime/sfn/clock.sfn is fmt-canonical" ![io] {
    let exit = process.run_capture([_sfn_bin(), "fmt", "--check", "runtime/sfn/clock.sfn"], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    assert exit == 0;
}

test "sleep emit: sfn_sleep is defined and declares nanosleep" ![io] {
    let ir = _emit_module("clock", "runtime/sfn/clock.sfn");
    assert ir != "EMIT_FAILED";
    assert _has_define(ir, "sfn_sleep");
    // The wait is still backed by libc nanosleep.
    assert _has_declare(ir, "nanosleep");
}

test "sleep emit: EINTR-resume loop reads errno after a non-zero return (#693)" ![io] {
    let ir = _emit_module("clock", "runtime/sfn/clock.sfn");
    assert ir != "EMIT_FAILED";
    // The bounded retry loop re-checks errno on a non-zero nanosleep
    // return and resumes only on EINTR. The errno-location locator
    // trampoline (#887) lowers to libc @__errno_location(); a single,
    // errno-unaware nanosleep body would never read errno at all.
    assert _calls(ir, "__errno_location");
    // The re-check compares the read errno against the EINTR sentinel.
    assert contains(ir, "@global.EINTR");
}

test "sleep emit: user sleep(N) routes to the native @sfn_sleep body" ![io] {
    // Emit a probe that calls sleep so the user-side routing is visible.
    // The body (with the nanosleep retry loop, asserted above against
    // clock.sfn) lives in the implicit runtime capsule, so the user
    // emit unit only declares + calls @sfn_sleep — pin that linkage.
    let dir = _scratch_dir();
    let probe = dir + "/sleep_probe.sfn";
    fs.writeFile(probe, "fn main() ![io, clock] {\n" + "    sleep(1);\n"
        + "    print(\"done\");\n"
        + "}\n");
    let ir = _emit_module("sleep_probe", probe);
    assert ir != "EMIT_FAILED";
    assert _has_declare(ir, "sfn_sleep");
    assert _calls(ir, "sfn_sleep");
}
