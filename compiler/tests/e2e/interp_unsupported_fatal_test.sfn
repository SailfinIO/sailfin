// End-to-end negative regression for SFN-408 / GitHub #2448 — the safety floor.
//
// Before SFN-408, interpolating an operand with no `coerce_operand_to_string`
// arm returned a null operand that silently dropped the enclosing `print` at
// exit 0. The fix makes that path a `[fatal]` E0832 diagnostic so the build
// fails loudly. This test builds a fixture interpolating a struct and asserts
// the build is rejected with the fatal E0832 diagnostic rather than succeeding
// with empty output.
import { find } from "sfn/strings";
import { expect_eq_bool, with_tmp_dir } from "sfn/test";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

fn _fixture_src() -> string ![io] {
    return fs.readFile("compiler/tests/e2e/fixtures/interp_unsupported_fatal.sfn");
}

fn _child_env() -> string[] ![io] { return process.environ(); }

test "interpolation fatal floor: an unsupported operand fails the build with E0832" ![io] {
    let _done = with_tmp_dir(fn (dir: string) -> int {
        let srcpath = dir + "/probe.sfn";
        fs.writeFile(srcpath, _fixture_src());
        let binpath = dir + "/probe";
        let build_exit = process.run_capture([_sfn_bin(), "build", "-o", binpath, srcpath], _child_env());
        let out = process.capture_take_stdout();
        let err = process.capture_take_stderr();
        let diag = out + err;

        // The build must be rejected (non-zero), not silently succeed.
        assert expect_eq_bool(build_exit != 0, true).ok;
        // The diagnostic must carry the E-code and the fatal marker.
        assert expect_eq_bool(find(diag, "E0832", 0) >= 0, true).ok;
        assert expect_eq_bool(find(diag, "[fatal]", 0) >= 0, true).ok;
        // The output binary must not have been produced.
        assert expect_eq_bool(fs.exists(binpath), false).ok;
        return 0;
    });
}
