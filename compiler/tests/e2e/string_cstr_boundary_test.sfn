// compiler/tests/e2e/string_cstr_boundary_test.sfn
//
// #1705 — regression coverage for the NUL-termination cstr boundary helpers
// (`sfn_str_to_cstr` / `sfn_str_sfn_to_cstr` / `sfn_str_sfn_from_cstr`) over the
// `{i8*, i64}` SfnString aggregate. The reworked bodies copy the carried byte
// length into the arena with a trailing NUL (`to_cstr`) and recover length via
// `memchr` (`from_cstr`), instead of returning the input pointer unchanged. A
// non-NUL-terminated interior view (#1454) handed to a libc call must therefore
// NOT over-read past its slice into the source remainder.
//
// As with the sibling `string_length_aware_lv_test.sfn` (#1704), there is no
// pure-`.sfn` path that produces a non-NUL-terminated string until `string.slice`
// returns a real non-owning view (#1454), so the hazard is synthesized directly
// via a C harness (per `.claude/rules/no-bash-e2e.md`, mirroring the clang-harness
// pattern of `runtime_memory_arena_test.sfn`). A buffer `"abcXYZ"` is handed to
// `to_cstr` with `len = 3`; the result must be a fresh `"abc\0"` buffer — NOT the
// 6-byte source — proving the copy terminates at the carried length, not at the
// source's own NUL.
//
// Unlike the #1704 harness (which stubs `sfn_arena_alloc` to return 0 because its
// `_lv` helpers never allocate), `to_cstr` MUST allocate, so this harness backs
// `sfn_arena_global` / `sfn_arena_alloc` with libc `malloc`. The remaining
// cross-module stubs satisfy the linker for the rest of `string.sfn`; main calls
// only the three boundary helpers.
import {
    find,
    contains,
    split,
    starts_with
} from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    dir = dir + "/sfn-cstr-boundary";
    fs.createDirectory(dir, true);
    return dir;
}

fn _repo_root() -> string ![io] {
    let configured = env.get("SAILFIN_REPO_ROOT");
    if configured.length > 0 { return configured; }
    return ".";
}

fn _string_path() -> string ![io] {
    return _repo_root() + "/runtime/sfn/string.sfn";
}

fn _emit_string_ll() -> string ![io] {
    let dir = _scratch_dir();
    let ll = dir + "/string.ll";
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", ll, "llvm", _string_path()], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    assert exit == 0;
    return ll;
}

fn _has_define_named(ir: string, sym: string) -> boolean {
    let lines = split(ir, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if starts_with(line, "define ") && contains(line, "@" + sym + "(") {
            return true;
        }
        i = i + 1;
    }
    return false;
}

// The C harness. `main` exercises the boundary helpers against a buffer with no
// NUL at the carried boundary; the stubs satisfy the linker for the rest of the
// module. `sfn_arena_global` / `sfn_arena_alloc` are real (malloc-backed) so
// `to_cstr` can copy. Returns 0 iff every boundary leg holds.
fn _harness_c() -> string {
    return "#include <stdio.h>\n" + "#include <stdlib.h>\n"
        + "void* sfn_arena_global(void){return (void*)1;}\n"
        + "void* sfn_arena_alloc(void* a,unsigned long s,unsigned long g){(void)a;(void)g;return malloc(s);}\n"
        + "void* sfn_arena_realloc(void* a,void* p,unsigned long o,unsigned long s,unsigned long g){(void)a;(void)o;(void)g;return realloc(p,s);}\n"
        + "void* owned_buf_new(long a,long b){(void)a;(void)b;return 0;}\n"
        + "void  sailfin_runtime_mark_persistent(void* p){(void)p;}\n"
        + "_Bool sfn_arena_enabled(void){return 1;}\n"
        + "void  sfn_type_register(void* d){(void)d;}\n"
        + "void* sfn_alloc_struct(long n){(void)n;return 0;}\n"
        + "void  sfn_raise_value_error(void* a){(void)a;}\n"
        + "typedef struct { char* data; long len; } SfnStr;\n"
        + "extern char*  sfn_str_to_cstr(char*,long,void*);\n"
        + "extern char*  sfn_str_sfn_to_cstr(char*,long,void*);\n"
        + "extern SfnStr sfn_str_sfn_from_cstr(char*);\n"
        + "int main(void){\n"
        + "  int ok=1;\n"
        + "  char buf[]=\"abcXYZ\"; /* no NUL at offset 3 */\n"
        + "  /* to_cstr copies the carried 3 bytes + NUL into a FRESH buffer; it\n"
        + "   * must not be the source pointer and must terminate at 3, not scan\n"
        + "   * into \"XYZ\". A strnlen/identity body would yield \"abcXYZ\". */\n"
        + "  char* c=sfn_str_to_cstr(buf,3,0);\n"
        + "  if(c==buf){printf(\"to_cstr identity FAIL\\n\");ok=0;}\n"
        + "  else{\n"
        + "    if(c[0]!='a'||c[1]!='b'||c[2]!='c'){printf(\"to_cstr bytes FAIL\\n\");ok=0;}\n"
        + "    if(c[3]!=0){printf(\"to_cstr over-read FAIL\\n\");ok=0;}\n"
        + "  }\n"
        + "  /* len 0 yields a valid empty C string. */\n"
        + "  char* e=sfn_str_to_cstr(buf,0,0);\n"
        + "  if(e==0||e[0]!=0){printf(\"to_cstr empty FAIL\\n\");ok=0;}\n"
        + "  /* the _sfn_ infix alias shares the same copy semantics. */\n"
        + "  char* c2=sfn_str_sfn_to_cstr(buf,3,0);\n"
        + "  if(c2==0||c2[0]!='a'||c2[3]!=0){printf(\"sfn_to_cstr FAIL\\n\");ok=0;}\n"
        + "  /* from_cstr recovers length via memchr and returns {data,len}. */\n"
        + "  SfnStr r=sfn_str_sfn_from_cstr(\"hello\");\n"
        + "  if(r.len!=5){printf(\"from_cstr len FAIL %ld\\n\",r.len);ok=0;}\n"
        + "  printf(ok?\"ALL OK\\n\":\"SOME FAIL\\n\");\n"
        + "  return ok?0:1;\n"
        + "}\n";
}

// ---- typecheck ----
test "runtime/sfn/string.sfn typechecks cleanly" ![io] {
    let exit = process.run_capture([_sfn_bin(), "check", _string_path()], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    assert exit == 0;
}

// ---- emit shape: the boundary helpers are defined with the new ABI ----
test "string.sfn emit: defines the cstr boundary helpers" ![io] {
    let ll = _emit_string_ll();
    let ir = fs.readFile(ll);
    assert _has_define_named(ir, "sfn_str_to_cstr");
    assert _has_define_named(ir, "sfn_str_sfn_to_cstr");
    assert _has_define_named(ir, "sfn_str_sfn_from_cstr");
}

// ---- soundness: carried-len copy + NUL, no over-read (C harness via clang) ----
test "cstr boundary copies carried len + NUL, no over-read (C harness via clang)" ![io] {
    let dir = _scratch_dir();
    let ll = _emit_string_ll();
    let harness = dir + "/cstr_harness.c";
    fs.writeFile(harness, _harness_c());
    let bin = dir + "/cstr_roundtrip";
    let clang_exit = process.run_capture(["clang", "-Wno-override-module", harness, ll, "-o", bin, "-lm"], _child_env());
    let _co = process.capture_take_stdout();
    let _ce = process.capture_take_stderr();
    if clang_exit != 0 {
        // clang unavailable or link failed — skip the roundtrip; the emit-shape
        // assertions above still pin the boundary define contract.
        assert true;
    } else {
        let run_exit = process.run_capture([bin], _child_env());
        let out = process.capture_take_stdout();
        let _re = process.capture_take_stderr();
        assert run_exit == 0;
        assert find(out, "ALL OK", 0) >= 0;
    }
}
