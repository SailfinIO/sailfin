// End-to-end test for the make `JSON=1` report-file contract (#1125, epic
// #1056 Phase 2). Sibling of make_result_contract_test.sfn (the
// verdict-block contract).
//
// Native (no-bash) replacement for the former
// `test_make_report_contract.sh` (test-infra Phase 3, epic #842;
// `.claude/rules/no-bash-e2e.md`). Locks the per-target report file:
//
//   JSON=1 make <target>  -> writes build/agent-report.<target>.json, a
//                            parseable `sailfin-make/1` report whose
//                            `report` field self-references that path, and
//                            sets the verdict block's `report` to it.
//   make <target>         -> writes NO report file; the verdict block's
//                            `report` field stays null (additive,
//                            default-off invariant).
//
// Schema/design: docs/reference/make-result-schema.md,
// docs/proposals/0014-agent-output-orchestration.md §3.
//
// Cases (cheap, deterministic, network-free):
//   - off:   gate cleared -> no file, verdict `report` null.
//   - on:    `JSON=1 make compile` -> build/agent-report.compile.json
//            exists, parses-ish, target=="compile", `report`
//            self-references, phases is an array, verdict `report` equals
//            the path.
//   - paths: `JSON=1 make check-fast NATIVE_BIN=/nonexistent` writes a
//            DISTINCT build/agent-report.check-fast.json; both exist,
//            paths distinct, each report's target + self-reference match.
//
// CRITICAL — recursive-make + env hygiene. The e2e suite runs under a
// wrapped `make test` exporting SAILFIN_INNER=1 (and possibly
// SAILFIN_AGENT_REPORT). `process.run_capture(argv, env)` takes the
// COMPLETE child env (empty array == empty env), so the bash
// `env -u SAILFIN_INNER [-u SAILFIN_AGENT_REPORT]` is reproduced by
// BUILDING the child env WITHOUT those two vars and adding JSON=1 (as a
// make arg) only where the gate must be ON. run_capture does not cd, so
// make runs with `-C <repo_root> --no-print-directory`.
//
// For top-level fields read from the report FILE (which nests the same
// keys inside phases[]), take the FIRST occurrence — write_report_file
// emits every top-level field before phases[], so first-occurrence
// selects the top-level value (mirrors the bash report_file_field note).
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]`, so
// they cannot be called from an `![io]` test. Assert on the captured
// output text and report-file contents with `sfn/strings`. (#842.)
import { find, contains, split } from "sfn/strings";

fn _repo_root() -> string ![io] {
    let root = env.get("SAILFIN_REPO_ROOT");
    if root.length > 0 { return root; }
    return ".";
}

// Per-target report paths under test (relative to the repo root, as the
// report's own self-reference records them).
fn _compile_report_rel() -> string { return "build/agent-report.compile.json"; }

fn _checkfast_report_rel() -> string {
    return "build/agent-report.check-fast.json";
}

// Absolute on-disk path for fs.* operations.
fn _report_abs(rel: string) -> string ![io] {
    return _repo_root() + "/" + rel;
}

// Base child env WITHOUT SAILFIN_INNER and WITHOUT SAILFIN_AGENT_REPORT.
fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

fn _last_marker_line(lines: string[], marker: string) -> int {
    let mut idx = -1;
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        if contains(lines[i], marker) { idx = i; }
        i = i + 1;
    }
    return idx;
}

// The verdict JSON line: the single line after the LAST START marker.
fn _verdict_json(output: string) -> string {
    let lines = split(output, "\n");
    let start = _last_marker_line(lines, "===SAILFIN-RESULT===");
    if start < 0 { return ""; }
    let next = start + 1;
    if next >= lines.length { return ""; }
    return lines[next];
}

// FIRST occurrence of `"field":"value"` -> value, or "" if absent. Used
// for both the (flat) verdict line and the (nested) report file, where
// the top-level field always precedes any phases[] copy.
fn _json_str_field(json: string, field: string) -> string {
    let key = "\"" + field + "\":\"";
    let at = find(json, key, 0);
    if at < 0 { return ""; }
    let value_start = at + key.length;
    let close = find(json, "\"", value_start);
    if close < 0 { return ""; }
    return substring(json, value_start, close);
}

fn _json_is_null(json: string, field: string) -> boolean {
    let key = "\"" + field + "\":null";
    return find(json, key, 0) >= 0;
}

// Delete a report file if present, so the "no file is created" / "file
// appears" assertions are measured deterministically.
fn _clear_report(rel: string) -> void ![io] {
    let abs = _report_abs(rel);
    if fs.exists(abs) { fs.deleteFile(abs); }
}

// Run a make target without the report-file gate (default-off path).
fn _run_make_off(args: string[]) -> string ![io] {
    let mut argv: string[] = ["make", "-C", _repo_root(), "--no-print-directory"];
    let mut i = 0;
    loop {
        if i >= args.length { break; }
        argv.push(args[i]);
        i = i + 1;
    }
    let _exit = process.run_capture(argv, _child_env());
    let out = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    return out + err;
}

// Run a make target with the report-file gate ON (JSON=1 make arg, mapped
// by the Makefile to the exported SAILFIN_AGENT_REPORT=1 the wrapper reads).
fn _run_make_json(args: string[]) -> string ![io] {
    let mut argv: string[] = ["make", "JSON=1", "-C", _repo_root(), "--no-print-directory"];
    let mut i = 0;
    loop {
        if i >= args.length { break; }
        argv.push(args[i]);
        i = i + 1;
    }
    let _exit = process.run_capture(argv, _child_env());
    let out = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    return out + err;
}

test "make report: gate off -> no report file, verdict report is null" ![io] {
    _clear_report(_compile_report_rel());
    let output = _run_make_off(["compile"]);
    // No report file must be created.
    assert ! fs.exists(_report_abs(_compile_report_rel()));
    // Verdict block's report field is null.
    let json = _verdict_json(output);
    assert json.length > 0;
    assert _json_is_null(json, "report");
}

test "make report: gate on -> per-target report file exists, parses, self-references" ![io] {
    _clear_report(_compile_report_rel());
    let output = _run_make_json(["compile"]);
    let abs = _report_abs(_compile_report_rel());
    assert fs.exists(abs);
    let report = fs.readFile(abs);
    // Parses-ish: it is a JSON object carrying the schema.
    assert contains(report, "{");
    assert _json_str_field(report, "schema_version") == "sailfin-make/1";
    assert _json_str_field(report, "target") == "compile";
    // `report` self-references the file's own (repo-relative) path.
    assert _json_str_field(report, "report") == _compile_report_rel();
    // `phases` is present and an array.
    assert contains(report, "\"phases\":[");
    // The verdict block's report field equals the report path.
    let json = _verdict_json(output);
    assert json.length > 0;
    assert _json_str_field(json, "report") == _compile_report_rel();
}

test "make report: per-target paths distinct + self-referential (compile vs check-fast)" ![io] {
    // Reuse / re-create the compile report, then a second deterministic
    // target writes its OWN distinctly-named report.
    _clear_report(_compile_report_rel());
    let _c = _run_make_json(["compile"]);
    _clear_report(_checkfast_report_rel());
    let _f = _run_make_json(["check-fast", "NATIVE_BIN=/nonexistent/sailfin"]);

    let compile_abs = _report_abs(_compile_report_rel());
    let checkfast_abs = _report_abs(_checkfast_report_rel());
    assert fs.exists(compile_abs);
    assert fs.exists(checkfast_abs);
    // Paths distinct.
    assert _compile_report_rel() != _checkfast_report_rel();

    // Each report's target + self-reference match its own path.
    let compile_report = fs.readFile(compile_abs);
    assert _json_str_field(compile_report, "target") == "compile";
    assert _json_str_field(compile_report, "report") == _compile_report_rel();

    let checkfast_report = fs.readFile(checkfast_abs);
    assert _json_str_field(checkfast_report, "target") == "check-fast";
    assert _json_str_field(checkfast_report, "report") == _checkfast_report_rel();
}
