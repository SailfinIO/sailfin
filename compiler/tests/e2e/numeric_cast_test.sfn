// End-to-end test for the numeric `as` cast LLVM lowering matrix
// (Slice D, docs/proposals/0025-native-runtime-architecture.md `#396-numeric-types-int--float`).
//
// Native replacement for the former `test_numeric_cast.sh` (test-infra
// Phase 3, epic #842; ratchet #1327). PR #289 shipped the parser + AST +
// native-IR rendering for `as` casts but deferred the LLVM lowering
// matrix; Slice D adds the matrix on top of the existing
// pointer↔pointer / int↔pointer branches:
//
//   i1  → int (wider)    → zext
//   i*  → int (wider)    → sext
//   i*  → int (narrower) → trunc
//   i1  → double/float   → uitofp
//   i*  → double/float   → sitofp
//   double/float → i*    → fptosi
//   float → double       → fpext
//   double → float       → fptrunc
//   any  → i1 via `as`   → diagnostic ("use `x != 0`")
//
// Each sub-test compiles a tiny fixture to LLVM IR via `sfn emit llvm`,
// extracts the relevant function body, and asserts the expected cast
// instruction is present (and, where it matters, that the wrong one is
// absent).
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]` and so
// cannot be called from an `![io]` test like these. Assert on the captured
// `.ll` text with `sfn/strings` predicates instead. (#842.)
import { contains, split, starts_with } from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

// Child environment for the spawned `sfn emit`. `process.run_capture` treats
// an empty array as the *empty* environment (not "inherit"), so the relevant
// variables must be threaded explicitly:
//   - `PATH` (+ `HOME`/`TMPDIR`): keeps any subprocess the compiler shells out
//     to resolvable.
//   - `SAILFIN_TEST_SCRATCH`: the runner's per-file scratch, which the
//     compiler routes its build-cache dir under (#1333) so a parallel run
//     (`--jobs N>1`) does not collide on the fixed `build/sailfin`.
fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    return dir;
}

// Extract the body of the function whose `define` line starts with
// `header_prefix` (the `sed -n "/define .../,/^}/p"` shape). LLVM `define`
// lines start at column 0, so a prefix match is exact; collection stops at
// the closing `}` at column 0.
fn _fn_body(ir: string, header_prefix: string) -> string {
    let lines = split(ir, "\n");
    let mut out = "";
    let mut inside = false;
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if !inside {
            if starts_with(line, header_prefix) {
                inside = true;
                out = out + line + "\n";
            }
        } else {
            out = out + line + "\n";
            if starts_with(line, "}") { break; }
        }
        i += 1;
    }
    return out;
}

// Write `source` to a scratch `.sfn` keyed by `tag`, lower it to LLVM IR via
// `sfn emit llvm`, then return the body of the function selected by
// `header_prefix`. Returns "" on emit failure so callers assert on the
// emptiness.
fn _emit_body(source: string, header_prefix: string, tag: string) -> string ![io] {
    let dir = _scratch_dir();
    let src = dir + "/sfn-cast-" + tag + ".sfn";
    let ll = dir + "/sfn-cast-" + tag + ".ll";
    fs.writeFile(src, source);
    if fs.exists(ll) { fs.deleteFile(ll); }
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", ll, "llvm", src], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    if exit != 0 { return ""; }
    if !fs.exists(ll) { return ""; }
    let ir = fs.readFile(ll);
    fs.deleteFile(ll);
    fs.deleteFile(src);
    return _fn_body(ir, header_prefix);
}

// ---- int → float lowers as sitofp ----
test "numeric-cast: int → float lowers as sitofp i64 to double" ![io] {
    let body = _emit_body("fn convert(x: int) -> float { return x as float; }", "define double @convert", "int_to_float");
    assert body.length > 0;
    assert contains(body, "sitofp i64 %x to double");
}

// ---- float → int lowers as fptosi ----
test "numeric-cast: float → int lowers as fptosi double to i64" ![io] {
    let body = _emit_body("fn back(x: float) -> int { return x as int; }", "define i64 @back", "float_to_int");
    assert body.length > 0;
    assert contains(body, "fptosi double %x to i64");
}

// ---- i32 → i64 lowers as sext ----
test "numeric-cast: i32 → i64 widening lowers as sext" ![io] {
    let body = _emit_body("fn widen(x: i32) -> i64 { return x as i64; }", "define i64 @widen", "i32_to_i64");
    assert body.length > 0;
    assert contains(body, "sext i32 %x to i64");
}

// ---- i8 → i64 lowers as sext ----
test "numeric-cast: i8 → i64 widening lowers as sext" ![io] {
    let body = _emit_body("fn widen(x: i8) -> i64 { return x as i64; }", "define i64 @widen", "i8_to_i64");
    assert body.length > 0;
    assert contains(body, "sext i8 %x to i64");
}

// ---- i64 → i32 lowers as trunc ----
test "numeric-cast: i64 → i32 narrowing lowers as trunc" ![io] {
    let body = _emit_body("fn narrow(x: i64) -> i32 { return x as i32; }", "define i32 @narrow", "i64_to_i32");
    assert body.length > 0;
    assert contains(body, "trunc i64 %x to i32");
}

// ---- bool (i1) → i64 lowers as zext (not sext) ----
// Source-side `bool` maps to LLVM `i1`. Widening to i64 must use `zext`
// (not sext) so `true` becomes 1 (not -1).
test "numeric-cast: bool (i1) → i64 widening lowers as zext (not sext)" ![io] {
    let body = _emit_body("fn widen(x: bool) -> i64 { return x as i64; }", "define i64 @widen", "i1_to_i64");
    assert body.length > 0;
    assert contains(body, "zext i1 %x to i64");
    assert ! contains(body, "sext i1 ");
}

// ---- bool → double uses uitofp (not sitofp; true → 1.0) ----
// `sitofp i1 1` produces -1.0 because LLVM treats `i1` as signed where
// `true` = -1. For `bool as float` the user expects `true` → 1.0, so the
// lowering must use `uitofp` for the i1 source.
test "numeric-cast: bool → double uses uitofp (not sitofp; true → 1.0)" ![io] {
    let body = _emit_body("fn promote(x: bool) -> float { return x as float; }", "define double @promote", "i1_to_double");
    assert body.length > 0;
    assert contains(body, "uitofp i1 %x to double");
    assert ! contains(body, "sitofp i1 ");
}

// ---- f32 (LLVM float) → double lowers as fpext ----
test "numeric-cast: f32 → double widening lowers as fpext" ![io] {
    let body = _emit_body("fn widen(x: f32) -> float { return x as float; }", "define double @widen", "f32_to_double");
    assert body.length > 0;
    assert contains(body, "fpext float %x to double");
}

// ---- double → f32 (LLVM float) lowers as fptrunc ----
test "numeric-cast: double → f32 narrowing lowers as fptrunc" ![io] {
    let body = _emit_body("fn narrow(x: float) -> f32 { return x as f32; }", "define float @narrow", "double_to_f32");
    assert body.length > 0;
    assert contains(body, "fptrunc double %x to float");
}

// ---- int → string stringifies (not a silent constant 0) — #1505 ----
// Regression for #1505: `n as string` previously hit no arm of the cast
// matrix (there is no `i64 → {i8*, i64}` numeric case), emitted a non-fatal
// "unsupported cast" diagnostic, and returned a null operand — so the binding
// defaulted to `double 0.0` and silently printed "0". The fix routes the
// `as string` cast through the same int→string aggregate lowering the `{{ }}`
// interpolation path uses: `sitofp i64 → double`, the number→string helper,
// then `insertvalue {i8*, i64}` to build the SfnString aggregate.
test "string-cast: int → string stringifies via the number→string aggregate (#1505)" ![io] {
    let body = _emit_body("fn label(x: int) -> string { return x as string; }", "define {i8*, i64} @label", "int_to_string");
    assert body.length > 0;
    assert contains(body, "sitofp i64 %x to double");
    assert contains(body, "insertvalue {i8*, i64}");
}

// ---- float → string stringifies (double source arm) — #1505 ----
test "string-cast: float → string stringifies via the number→string aggregate (#1505)" ![io] {
    let body = _emit_body("fn label(x: float) -> string { return x as string; }", "define {i8*, i64} @label", "float_to_string");
    assert body.length > 0;
    assert contains(body, "insertvalue {i8*, i64}");
}

// ---- narrow int / bool / f32 → string stringify (narrow-width arms) — #1587 ----
// #1505 only added the source-level `int` (i64) and `float` (double) arms;
// narrower scalar numerics (`i32`/`i16`/`i8`, `bool`/`i1`, `f32`/float) fell
// through to a null operand and silently lowered to "0". These widen to the
// i64/double the #1505 arms stringify (`sext`/`zext` to i64, `fpext` to
// double) then reuse the number→string + length-recovery aggregate.
test "string-cast: i32 → string widens via sext then stringifies (#1587)" ![io] {
    let body = _emit_body("fn label(x: i32) -> string { return x as string; }", "define {i8*, i64} @label", "i32_to_string");
    assert body.length > 0;
    assert contains(body, "sext i32 %x to i64");
    assert contains(body, "sitofp i64");
    assert contains(body, "insertvalue {i8*, i64}");
}

test "string-cast: i8 → string widens via sext then stringifies (#1587)" ![io] {
    let body = _emit_body("fn label(x: i8) -> string { return x as string; }", "define {i8*, i64} @label", "i8_to_string");
    assert body.length > 0;
    assert contains(body, "sext i8 %x to i64");
    assert contains(body, "insertvalue {i8*, i64}");
}

test "string-cast: bool → string widens via zext then stringifies (#1587)" ![io] {
    let body = _emit_body("fn label(x: bool) -> string { return x as string; }", "define {i8*, i64} @label", "bool_to_string");
    assert body.length > 0;
    assert contains(body, "zext i1 %x to i64");
    assert contains(body, "insertvalue {i8*, i64}");
}

test "string-cast: f32 → string widens via fpext then stringifies (#1587)" ![io] {
    let body = _emit_body("fn label(x: f32) -> string { return x as string; }", "define {i8*, i64} @label", "f32_to_string");
    assert body.length > 0;
    assert contains(body, "fpext float %x to double");
    assert contains(body, "insertvalue {i8*, i64}");
}

// ---- f32 local from a double literal narrows via fptrunc (#1587 bundled) ----
// Float literals lower as `double` constants; storing one into an `f32` slot
// needs a narrowing `fptrunc`. Without the `double → float` arm in
// `coerce_numeric_primitive` the store defaulted to `zeroinitializer`, so
// `let x: f32 = 3.5` silently became 0 and `x as string` printed "0".
test "numeric-cast: f32 local from double literal narrows via fptrunc (#1587)" ![io] {
    let body = _emit_body("fn mk() -> f32 { let x: f32 = 3.5; return x; }", "define float @mk", "f32_local_fptrunc");
    assert body.length > 0;
    assert contains(body, "fptrunc double");
    assert ! contains(body, "store float zeroinitializer");
}

// ---- pointer → bool is rejected (not ptrtoint) ----
// Without the early `as bool` check, `ptr as bool` would lower to
// `ptrtoint ptr to i1`, a low-bit reinterpretation rather than the
// documented "is non-null" comparison. The rejection runs before the
// pointer→int branch, the cast bails with a null operand, and `lower_return`
// falls back to the default literal `false` for i1.
test "numeric-cast: ptr → bool is rejected (not ptrtoint)" ![io] {
    let body = _emit_body("fn isset(x: *u8) -> bool { return x as bool; }", "define i1 @isset", "ptr_to_bool");
    assert body.length > 0;
    assert ! contains(body, "ptrtoint i8* %x to i1");
    assert contains(body, "ret i1 false");
}

// ---- f16 / bf16 (SFEP-0054 Phase 1) ----
test "numeric-cast: f16 → f32 widening lowers as fpext" ![io] {
    let body = _emit_body("fn widen(x: f16) -> f32 { return x as f32; }", "define float @widen", "f16_to_f32");
    assert body.length > 0;
    assert contains(body, "fpext half %x to float");
}

test "numeric-cast: bf16 → f32 widening lowers as fpext" ![io] {
    let body = _emit_body("fn widen(x: bf16) -> f32 { return x as f32; }", "define float @widen", "bf16_to_f32");
    assert body.length > 0;
    assert contains(body, "fpext bfloat %x to float");
}

test "numeric-cast: f32 → f16 narrowing lowers as fptrunc" ![io] {
    let body = _emit_body("fn narrow(x: f32) -> f16 { return x as f16; }", "define half @narrow", "f32_to_f16");
    assert body.length > 0;
    assert contains(body, "fptrunc float %x to half");
}

test "numeric-cast: f32 → bf16 narrowing lowers as fptrunc" ![io] {
    let body = _emit_body("fn narrow(x: f32) -> bf16 { return x as bf16; }", "define bfloat @narrow", "f32_to_bf16");
    assert body.length > 0;
    assert contains(body, "fptrunc float %x to bfloat");
}

test "numeric-cast: f16 round-trips through f32 (fptrunc back to half)" ![io] {
    let body = _emit_body("fn roundtrip(x: f16) -> f16 { let w: f32 = x as f32; return w as f16; }", "define half @roundtrip", "f16_roundtrip");
    assert body.length > 0;
    assert contains(body, "fpext half %x to float");
    assert contains(body, "fptrunc float");
}

test "numeric-cast: f16 local from double literal narrows via fptrunc" ![io] {
    let body = _emit_body("fn mk() -> f16 { let x: f16 = 0.5; return x; }", "define half @mk", "f16_local_fptrunc");
    assert body.length > 0;
    assert contains(body, "fptrunc double");
    assert ! contains(body, "store half zeroinitializer");
}

test "numeric-cast: bf16 local from double literal narrows via fptrunc" ![io] {
    let body = _emit_body("fn mk() -> bf16 { let x: bf16 = 0.5; return x; }", "define bfloat @mk", "bf16_local_fptrunc");
    assert body.length > 0;
    assert contains(body, "fptrunc double");
}
