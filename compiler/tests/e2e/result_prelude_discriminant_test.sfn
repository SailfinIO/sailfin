// End-to-end IR guard for prelude `Result` lowering (#1022, epic #371 R.2).
//
// Native replacement for the former `test_result_prelude_discriminant.sh`
// (test-infra Phase 3, epic #842; ratchet #1327). Drives `sfn emit llvm`
// against a bare-prelude-`Result` fixture (no in-file enum, no import) and
// asserts the emitted IR carries a REAL discriminant: a `%Result` named
// type, an `icmp eq` tag test, a conditional `br i1`, and a payload `load`.
// This fails on the pre-#1021 (PR #1027) shape documented in #1020 — an
// unconditional `matchcase0 → matchmerge` chain with no `icmp`, no
// `%Result` type, and an `i8*` subject — directly catching the elision /
// no-discriminant miscompilation class.
//
// It is the IR-level companion to the runtime assertions in
// compiler/tests/unit/result_prelude_test.sfn.
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]`, so a
// caller must itself be `![pure]` — they cannot be used from an `![io]`
// test like these. For emitted-IR assertions use `sfn/strings` predicates
// over the captured `.ll` text. (Making the matchers usable from `![io]`
// tests is tracked against #842.)
import { contains, split } from "sfn/strings";

// The compiler-under-test: `$SAILFIN_BIN` if set, else the self-hosted
// binary relative to the repo root the runner starts from. Mirrors
// `sfn/test`'s `_resolve_sfn_bin` (compile_assert.sfn) so CI can point the
// test at any compiler without editing it.
fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/native/sailfin";
}

fn _fixture() -> string {
    return "compiler/tests/e2e/fixtures/result_prelude_discriminant.sfn";
}

// Child environment for the spawned `sfn emit`. `process.run_capture` treats
// an empty array as the *empty* environment (not "inherit"), so the relevant
// variables must be threaded explicitly:
//   - `PATH` (+ `HOME`/`TMPDIR`): keeps any subprocess the compiler shells out
//     to (e.g. `mkdir`) resolvable.
//   - `SAILFIN_TEST_SCRATCH`: the runner's per-file scratch, which the
//     compiler routes its build-cache dir under (#1333) so a parallel run
//     (`--jobs N>1`) does not collide on the fixed `build/sailfin`.
fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

// Lower `fixture` to a standalone `.ll` via `sfn emit llvm` (the exact path
// `_emit_runtime_sfn_to_obj` feeds to `clang -c`) and return the IR text.
// The `.ll` is written to a unique scratch path keyed by `tag` so parallel
// sub-tests do not collide; returns "" if the emit failed so the caller can
// assert on the emptiness.
fn _emit_llvm(fixture: string, tag: string) -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    let ll = dir + "/sfn-result-prelude-" + tag + ".ll";
    if fs.exists(ll) { fs.deleteFile(ll); }
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", ll, "llvm", fixture], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    if exit != 0 { return ""; }
    if !fs.exists(ll) { return ""; }
    let ir = fs.readFile(ll);
    fs.deleteFile(ll);
    return ir;
}

// Extract the `@unwrap_or` function body (from its `define` line through the
// closing `}`). The emitter mangles the symbol (e.g.
// `@unwrap_or__compiler__tests__...`), so match `@unwrap_or` as a substring
// rather than requiring a trailing `(`.
fn _unwrap_or_body(ir: string) -> string {
    let lines = split(ir, "\n");
    let mut out = "";
    let mut in_body = false;
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if in_body {
            out = out + line + "\n";
            if line == "}" { break; }
        } else if contains(line, "define ") && contains(line, "@unwrap_or") {
            in_body = true;
            out = out + line + "\n";
        }
        i += 1;
    }
    return out;
}

// ---- Prelude Result match lowers to a real discriminant + payload load ----
// A `%Result` layout, an `icmp eq` discriminant test, a conditional `br i1`,
// and a `getelementptr`/`load i64` payload read must all be present
// (pre-#1021: absent; subject was `i8*` with an unconditional match chain).
test "result-prelude: match emits %Result + icmp discriminant + payload load" ![io] {
    let ir = _emit_llvm(_fixture(), "discriminant");
    assert ir.length > 0;
    assert contains(ir, "%Result = type");
    assert contains(ir, "icmp eq");
    assert contains(ir, "br i1 ");
    assert contains(ir, "getelementptr");
    assert contains(ir, "load i64");
}

// ---- Defence against the exact pre-#1021 degenerate shape ----
// Pre-#1021 the @unwrap_or body was an unconditional `matchcase0 →
// matchcase2 → matchmerge` chain with no discriminant. Assert the function
// itself carries at least one `icmp eq`, so a regression to the
// no-discriminant shape is caught even if some other module in the IR
// happens to contain an `icmp`.
test "result-prelude: @unwrap_or body carries a real discriminant icmp" ![io] {
    let ir = _emit_llvm(_fixture(), "body");
    assert ir.length > 0;
    let body = _unwrap_or_body(ir);
    assert body.length > 0;
    assert contains(body, "icmp eq");
}
