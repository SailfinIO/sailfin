// End-to-end test for the pointer-read intrinsics (#875, epic #763).
//
// `sailfin_intrinsic_pointer_read_i32` / `_i64` / `_f64` are registry sentinels
// that lower directly to an LLVM `load` of the matching width — there is no C
// symbol behind them. This test pins that shape:
//
//   1. typecheck   — `sfn check <fixture>` exits 0 (the intrinsics are bare
//                    calls; no accept-list change).
//   2. load i32    — emitted IR contains `load i32, i32* %…` for the i32 read.
//   3. load i64    — emitted IR contains `load i64, i64* %…` for the i64 read.
//   3b. load double — emitted IR contains `load double, double* %…` for the
//                    f64 read (parity with `_i64`; seeds `float[]` stringify).
//   4. no call     — no `call` instruction targets any sentinel symbol.
//   5. no declare  — no `declare …@sailfin_intrinsic_pointer_read_*` line, so
//                    the sentinel never links to a nonexistent symbol.
//   6. bitcast     — an `i8*` operand is bitcast to the matching pointer type
//                    before the load (the conditional-bitcast edge).
//
// Native replacement for the former `test_pointer_read_intrinsic.sh`
// (test-infra Phase 3, epic #842; ratchet #1327).
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]` and so
// cannot be called from an `![io]` test like this. Assert on the captured
// `.ll` text with `sfn/strings` predicates instead. (#842.)
import { contains, split } from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    return dir;
}

// Whether any single line of `text` contains both `a` and `b` — the faithful
// stand-in for a `grep -E "a.*b"` over one line.
fn _any_line_with(text: string, a: string, b: string) -> bool {
    let lines = split(text, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        if contains(lines[i], a) && contains(lines[i], b) { return true; }
        i += 1;
    }
    return false;
}

// The intrinsics are called bare (no `extern fn`) — like the arena-mark prior
// art in `cli_check.sfn`. A bare call leaves no function entry, so the lowering
// fallback resolves it against the runtime-helper registry and the
// load-not-call branch fires.
fn _fixture_source() -> string {
    return "extern fn malloc(size: usize) -> * u8;\n\nfn read_i32(p: * u8) -> i32 {\n    return sailfin_intrinsic_pointer_read_i32(p);\n}\n\nfn read_i64(p: * u8) -> i64 {\n    return sailfin_intrinsic_pointer_read_i64(p);\n}\n\nfn read_f64(p: * u8) -> float {\n    return sailfin_intrinsic_pointer_read_f64(p);\n}\n\nfn main() -> void {\n    let p: * u8 = malloc(8 as usize);\n    let a: i32 = read_i32(p);\n    let b: i64 = read_i64(p);\n    let c: float = read_f64(p);\n}\n";
}

fn _fixture_path() -> string ![io] {
    let dir = _scratch_dir();
    let src = dir + "/sfn-pointer-read.sfn";
    fs.writeFile(src, _fixture_source());
    return src;
}

fn _emit_llvm(src: string) -> string ![io] {
    let dir = _scratch_dir();
    let ll = dir + "/sfn-pointer-read.ll";
    if fs.exists(ll) { fs.deleteFile(ll); }
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", ll, "llvm", src], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    if exit != 0 { return ""; }
    if !fs.exists(ll) { return ""; }
    let ir = fs.readFile(ll);
    fs.deleteFile(ll);
    return ir;
}

test "pointer-read: sfn check passes on the fixture" ![io] {
    let src = _fixture_path();
    let exit = process.run_capture([_sfn_bin(), "check", src], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    fs.deleteFile(src);
    assert exit == 0;
}

test "pointer-read: i32 read lowers to 'load i32', i64 to 'load i64'" ![io] {
    let src = _fixture_path();
    let ir = _emit_llvm(src);
    fs.deleteFile(src);
    assert ir.length > 0;
    assert contains(ir, "load i32, i32* %");
    assert contains(ir, "load i64, i64* %");
}

test "pointer-read: f64 read lowers to 'load double'" ![io] {
    let src = _fixture_path();
    let ir = _emit_llvm(src);
    fs.deleteFile(src);
    assert ir.length > 0;
    assert contains(ir, "load double, double* %");
}

test "pointer-read: sentinels are not emitted as 'call' or 'declare'" ![io] {
    let src = _fixture_path();
    let ir = _emit_llvm(src);
    fs.deleteFile(src);
    assert ir.length > 0;
    // No `call …@sailfin_intrinsic_pointer_read_*` (lowers to a load, not a call).
    assert ! _any_line_with(ir, "call ", "@sailfin_intrinsic_pointer_read_i32");
    assert ! _any_line_with(ir, "call ", "@sailfin_intrinsic_pointer_read_i64");
    assert ! _any_line_with(ir, "call ", "@sailfin_intrinsic_pointer_read_f64");
    // No `declare …@sailfin_intrinsic_pointer_read_*` (sentinel has no symbol).
    assert ! _any_line_with(ir, "declare ", "@sailfin_intrinsic_pointer_read_i32");
    assert ! _any_line_with(ir, "declare ", "@sailfin_intrinsic_pointer_read_i64");
    assert ! _any_line_with(ir, "declare ", "@sailfin_intrinsic_pointer_read_f64");
}

test "pointer-read: i8* operand is bitcast to the matching pointer type" ![io] {
    let src = _fixture_path();
    let ir = _emit_llvm(src);
    fs.deleteFile(src);
    assert ir.length > 0;
    assert _any_line_with(ir, "bitcast i8* ", "to i32*");
    assert _any_line_with(ir, "bitcast i8* ", "to i64*");
    assert _any_line_with(ir, "bitcast i8* ", "to double*");
}
