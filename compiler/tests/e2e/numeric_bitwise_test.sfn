// End-to-end test for bitwise + shift operators on integer types
// (Slice B of the int/float numeric types migration —
// `docs/runtime_architecture.md` §3.7 L4).
//
// Native replacement for the former `test_numeric_bitwise.sh` (test-infra
// Phase 3, epic #842; ratchet #1327). Pre-Slice-B, `x & y` parsed and
// typechecked cleanly but the LLVM lowering had no dispatch for
// `&`/`|`/`^` and the expression silently fell through to a default —
// `return x & y;` emitted `ret i64 0` with no diagnostic. `x << y` was
// worse: the comparison matcher matched the inner `<` of `<<` and tried to
// lower it as a comparison, producing nonsense.
//
// Each sub-test lowers a tiny fixture to LLVM IR via `sfn emit llvm` and
// pins the emission for each bitwise + shift operator. A regression where
// any one silently emits broken IR or a non-bitwise instruction surfaces
// here.
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]` and so
// cannot be called from an `![io]` test like these. Assert on the captured
// `.ll` text with `sfn/strings` predicates instead. (#842.)
import {
    contains,
    replace,
    split,
    starts_with
} from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/native/sailfin";
}

// Child environment for the spawned `sfn emit`. `process.run_capture` treats
// an empty array as the *empty* environment (not "inherit"), so the relevant
// variables must be threaded explicitly:
//   - `PATH` (+ `HOME`/`TMPDIR`): keeps any subprocess the compiler shells out
//     to resolvable.
//   - `SAILFIN_TEST_SCRATCH`: the runner's per-file scratch, which the
//     compiler routes its build-cache dir under (#1333) so a parallel run
//     (`--jobs N>1`) does not collide on the fixed `build/sailfin`.
fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    return dir;
}

// Collapse every run of consecutive spaces down to a single space. Lets a
// single-space substring check (`" = double "`) match the original
// `=[[:space:]]+` grep — i.e. the canonical malformed shape `%t0 =  double`
// (two spaces, empty opcode) as well as any wider run.
fn _collapse_spaces(text: string) -> string {
    let mut out = text;
    loop {
        if !contains(out, "  ") { break; }
        out = replace(out, "  ", " ");
    }
    return out;
}

// Whether any single line of `text` contains both `a` and `b` — the
// faithful stand-in for a `grep -E "a.*b"` over one line.
fn _has_line_with_both(text: string, a: string, b: string) -> bool {
    let lines = split(text, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        if contains(lines[i], a) && contains(lines[i], b) { return true; }
        i += 1;
    }
    return false;
}

// Extract the body of the function whose `define` line starts with
// `header_prefix` (the `sed -n "/define .../,/^}/p"` shape). LLVM `define`
// lines start at column 0, so a prefix match is exact; collection stops at
// the closing `}` at column 0.
fn _fn_body(ir: string, header_prefix: string) -> string {
    let lines = split(ir, "\n");
    let mut out = "";
    let mut inside = false;
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if !inside {
            if starts_with(line, header_prefix) {
                inside = true;
                out = out + line + "\n";
            }
        } else {
            out = out + line + "\n";
            if starts_with(line, "}") { break; }
        }
        i += 1;
    }
    return out;
}

// Write `source` to a scratch `.sfn` keyed by `tag`, lower it to LLVM IR via
// `sfn emit llvm`, and return the whole IR text. Returns "" on emit failure
// so callers assert on the emptiness.
fn _emit_llvm(source: string, tag: string) -> string ![io] {
    let dir = _scratch_dir();
    let src = dir + "/sfn-bitwise-" + tag + ".sfn";
    let ll = dir + "/sfn-bitwise-" + tag + ".ll";
    fs.writeFile(src, source);
    if fs.exists(ll) { fs.deleteFile(ll); }
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", ll, "llvm", src], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    if exit != 0 { return ""; }
    if !fs.exists(ll) { return ""; }
    let ir = fs.readFile(ll);
    fs.deleteFile(ll);
    fs.deleteFile(src);
    return ir;
}

// ---- each bitwise/shift op emits the right LLVM op ----
test "numeric-bitwise: & | ^ << >> emit and/or/xor/shl/ashr i64" ![io] {
    let ir = _emit_llvm("fn test(x: int, y: int) -> int {\n"
        + "    let a = x & y;\n"
        + "    let b = x | y;\n"
        + "    let c = x ^ y;\n"
        + "    let d = x << 2;\n"
        + "    let e = x >> 1;\n"
        + "    return a + b + c + d + e;\n"
        + "}\n", "ops");
    assert ir.length > 0;
    let body = _fn_body(ir, "define i64 @test");
    assert body.length > 0;
    assert contains(body, " = and i64 ");
    assert contains(body, " = or i64 ");
    assert contains(body, " = xor i64 ");
    assert contains(body, " = shl i64 ");
    // Signed right shift lowers to `ashr`.
    assert contains(body, " = ashr i64 ");
    // Pre-Slice-B regression: an int operand sitofp'd to double inside the
    // bitwise/shift body (literals defaulted to `double`, then both sides
    // widened). Assert no such spurious conversion.
    assert ! _has_line_with_both(body, "sitofp i64 ", "to double");
}

// ---- bitwise + shift literals get integer-typed RHS ----
// Pre-fix, `x << 2` lowered the literal `2` as `double 2.0`; now the
// LHS-type-propagation in `lower_binary_operation` threads `i64` as the
// expected_type so the integer-literal short-circuit fires.
test "numeric-bitwise: shift with int literal RHS keeps i64 typing" ![io] {
    let ir = _emit_llvm("fn shift_lit(x: int) -> int {\n    return x << 8;\n}\n", "shift_lit");
    assert ir.length > 0;
    // `shl i64 %<reg>, 8` — the literal RHS stays i64-typed.
    assert _has_line_with_both(ir, "shl i64 %", ", 8");
}

// ---- precedence: the flag-mask idiom parses correctly ----
// `(flags & mask) == mask` must lower as `icmp eq` over the bitwise-AND
// result, not as `flags & (mask == mask)`. The parser's binary_precedence
// change is what pins this.
test "numeric-bitwise: (flags & mask) == mask — AND inside, comparison outside" ![io] {
    let ir = _emit_llvm("fn has_flag(flags: int, mask: int) -> bool {\n    return (flags & mask) == mask;\n}\n", "flag_mask");
    assert ir.length > 0;
    let body = _fn_body(ir, "define i1 @has_flag");
    assert body.length > 0;
    // Bitwise-AND inside the parens lowered.
    assert contains(body, "and i64");
    // Outer comparison lowered.
    assert contains(body, "icmp eq i64");
}

// ---- bitwise on float emits no malformed IR ----
// Pre-fix, `operation_name_for_symbol` returned empty for bitwise/shift on
// `double`, but `lower_binary_operation` concatenated that empty string
// into the LLVM line, producing malformed IR like `%t0 =  double <a>, <b>`.
// Now the lowering detects the empty op-name, registers a diagnostic, and
// returns a null operand so the function body falls through cleanly. The
// malformed shape is a `%reg = <type>` line with no opcode between `=` and
// the type; valid IR always has an opcode (`= alloca double`, `= load i64`).
// The malformed line carries a DOUBLE space (`=  double`) where the empty
// opcode was spliced in, so normalize space runs first — otherwise a
// single-space check would slip right past the very shape it guards.
test "numeric-bitwise: bitwise on float emits no malformed LLVM IR" ![io] {
    let ir = _emit_llvm("fn bad(x: float, y: float) -> float {\n    return x & y;\n}\n", "bitwise_float");
    // Emission must not crash; a clean fall-through still produces IR.
    assert ir.length > 0;
    let norm = _collapse_spaces(ir);
    assert ! contains(norm, " = double ");
    assert ! contains(norm, " = i64 ");
    assert ! contains(norm, " = i32 ");
    assert ! contains(norm, " = i8 ");
}
