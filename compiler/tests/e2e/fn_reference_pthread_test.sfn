// End-to-end test for function-reference → address lowering (issue #1146).
//
// Native (no-bash) replacement for `test_fn_reference_pthread.sh`
// (test-infra Phase 3, epic #842; `.claude/rules/no-bash-e2e.md`).
//
// A defined Sailfin function used in value position via `<fn> as * u8`
// must lower to a real code pointer — `bitcast <fnty> @<symbol> to i8*` —
// not the silent `null` the frontend emitted before #1146. The
// load-bearing proof is a linked round-trip: the fixture takes
// `sfn_fnref_worker as * u8`, hands it to `pthread_create`, joins the
// thread, and the worker writes a sentinel the C harness then checks.
//
// Pins, end-to-end:
//   1. typecheck   — `sfn check` on the fixture exits ok.
//   2. fmt         — the fixture is fmt-canonical.
//   3. emit shape  — IR carries `bitcast <fnty> @sfn_fnref_worker... to
//                    i8*` and `bitcast <fnty> @malloc to i8*` (extern stays
//                    bare), and the @sfn_fnref_spawn_join body does NOT
//                    `store i8* null` nor build a {i8*, i8*} closure pair /
//                    __closure__ sentinel for the bare fn-ref.
//   4. round-trip  — clang links the emitted IR + a pthread C harness and
//                    the worker observably runs (sentinel == 42). Skipped
//                    (not failed) when clang is unavailable; the IR-shape
//                    assertions still pin the contract. The host-OS guard
//                    from the original (Linux-only pthread_t-as-usize) is
//                    preserved.
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]`, so
// they cannot be called from an `![io]` test. For subprocess/IR-output
// assertions use `sfn/strings` (`find` / `split` / `starts_with` /
// `contains` / `char_at_index`).
import {
    find,
    split,
    starts_with,
    contains,
    char_at_index
} from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

// `run_capture`'s empty array is the *empty* environment; thread the
// variables the toolchain needs. The round-trip leg spawns clang + the
// linker, so PATH is load-bearing there.
fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

fn _fixture() -> string {
    return "compiler/tests/e2e/fixtures/fn_reference_pthread.sfn";
}

fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    dir = dir + "/sfn-fnref-pthread";
    fs.createDirectory(dir, true);
    return dir;
}

fn _emit_fixture(tag: string) -> string ![io] {
    let dir = _scratch_dir();
    let outpath = dir + "/" + tag + ".ll";
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", outpath, "llvm", _fixture()], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    if exit != 0 { return "EMIT_FAILED"; }
    return fs.readFile(outpath);
}

fn _is_word_char(ch: string) -> boolean {
    if ch.length == 0 { return false; }
    let word = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
    return find(word, ch, 0) >= 0;
}

// Does any line contain BOTH needles `a` and `b`? Used to match a
// `bitcast ... @sym ... to i8*` shape without anchoring on exact spacing.
fn _line_has_both(ir: string, a: string, b: string) -> boolean {
    let lines = split(ir, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if contains(line, a) && contains(line, b) { return true; }
        i = i + 1;
    }
    return false;
}

// Extract the body of `define ... @sfn_fnref_spawn_join...(` up to the
// closing `}` line, returning it as a single string (empty if not found).
fn _spawn_join_body(ir: string) -> string {
    let lines = split(ir, "\n");
    let mut i = 0;
    let mut in_body = false;
    let mut body = "";
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if !in_body {
            if starts_with(line, "define ") && contains(line, "@sfn_fnref_spawn_join") {
                in_body = true;
                body = body + line + "\n";
            }
        } else {
            body = body + line + "\n";
            if starts_with(line, "}") { break; }
        }
        i = i + 1;
    }
    return body;
}

// Extract the module-mangled spawn-join symbol name (no leading `@`) from
// the IR's `define` line, e.g. `sfn_fnref_spawn_join__<slug>`. Empty if
// not found.
fn _spawn_join_symbol(ir: string) -> string {
    let needle = "@sfn_fnref_spawn_join";
    let pos = find(ir, needle, 0);
    if pos < 0 { return ""; }
    let mut end = pos + 1;  // skip the '@'
    loop {
        if end >= ir.length { break; }
        let ch = char_at_index(ir, end);
        if !_is_word_char(ch) { break; }
        end = end + 1;
    }
    // [pos+1, end) is the bare symbol name.
    let mut sym = "";
    let mut k = pos + 1;
    loop {
        if k >= end { break; }
        sym = sym + char_at_index(ir, k);
        k = k + 1;
    }
    return sym;
}

test "fixtures/fn_reference_pthread.sfn typechecks cleanly" ![io] {
    let exit = process.run_capture([_sfn_bin(), "check", _fixture()], _child_env());
    let out = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    assert exit == 0;
    assert find(out + err, "ok", 0) >= 0;
}

test "fixtures/fn_reference_pthread.sfn is fmt-canonical" ![io] {
    let exit = process.run_capture([_sfn_bin(), "fmt", "--check", _fixture()], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    assert exit == 0;
}

test "fn-ref emit: materializes worker + extern as bitcasts to i8*" ![io] {
    let ir = _emit_fixture("fnref");
    assert ir != "EMIT_FAILED";
    // The defined worker's address: a bitcast of its typed fn-pointer to i8*.
    assert _line_has_both(ir, "@sfn_fnref_worker", "to i8*");
    // The extern reference must materialize the BARE symbol — the mangling
    // post-pass touches only defined-fn names, so `@malloc` reaches the
    // linker unmodified.
    assert _line_has_both(ir, "@malloc", "to i8*");
}

test "fn-ref emit: spawn_join does not drop the ref to null or a closure" ![io] {
    let ir = _emit_fixture("fnref");
    assert ir != "EMIT_FAILED";
    let body = _spawn_join_body(ir);
    assert body.length > 0;
    // The silent-null regression #1146 fixes: the start slot must not be null.
    assert ! contains(body, "store i8* null");
    // A bare top-level fn-ref must NOT engage the closure-pair path.
    assert ! contains(body, "{i8*, i8*}");
    assert ! contains(body, "__closure__");
}

// Linked pthread round-trip. The emitted spawn-join symbol carries a
// module-mangled suffix; extract it from the IR so the harness links the
// real name (that the use-site bitcast mangles to the *same* slug as the
// define is itself part of what this proves). Skips (does not fail) when
// clang is unavailable. Host-OS guard: the fixture models pthread_t as
// pointer-sized usize for Linux x86_64.
test "fn-ref: linked pthread_create round-trip runs the worker" ![io] {
    let host = env.get("SAILFIN_HOST_OS");
    // Best-effort: if a non-Linux host is signalled, skip the executing
    // leg (the fixture's pthread_t-as-usize modeling is Linux x86_64).
    if host.length > 0 && host != "Linux" {
        assert true;
        return;
    }

    let dir = _scratch_dir();
    let ir = _emit_fixture("fnref");
    assert ir != "EMIT_FAILED";
    let ll = dir + "/fnref.ll";

    let spawn_sym = _spawn_join_symbol(ir);
    assert spawn_sym.length > 0;

    let harness = dir + "/harness.c";
    fs.writeFile(harness, "#include <stdint.h>\n" + "#include <stdio.h>\n"
        + "\n"
        + "extern int SPAWN_JOIN(void *arg);\n"
        + "\n"
        + "void sailfin_runtime_mark_persistent(void *ptr) { (void)ptr; }\n"
        + "void sfn_type_register(void *desc) { (void)desc; }\n"
        + "\n"
        + "int main(void) {\n"
        + "    long flag = 0;\n"
        + "    int rc = SPAWN_JOIN(&flag);\n"
        + "    if (rc != 0) {\n"
        + "        fprintf(stderr, \"spawn_join returned rc=%d (expected 0)\\n\", rc);\n"
        + "        return 1;\n"
        + "    }\n"
        + "    if (flag != 42) {\n"
        + "        fprintf(stderr, \"worker did not run: flag=%ld (expected 42)\\n\", flag);\n"
        + "        return 2;\n"
        + "    }\n"
        + "    return 0;\n"
        + "}\n");

    let bin = dir + "/roundtrip";
    let clang_exit = process.run_capture(["clang", "-Wno-override-module", "-DSPAWN_JOIN="
        + spawn_sym, harness, ll, "-o", bin, "-lpthread", "-lm"], _child_env());
    let _co = process.capture_take_stdout();
    let _ce = process.capture_take_stderr();
    if clang_exit != 0 {
        // clang not available or link failed — skip the executing leg.
        // The IR-shape assertions above still pin the #1146 contract.
        assert true;
    } else {
        let run_exit = process.run_capture([bin], _child_env());
        let _ro = process.capture_take_stdout();
        let _re = process.capture_take_stderr();
        assert run_exit == 0;
    }
}
