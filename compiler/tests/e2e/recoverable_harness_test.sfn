// End-to-end tests for the recoverable test harness (SFN-17).
//
// A `sfn test --json` run continues past a failing test body, marks every
// test under a failing `before_each` as failed, and attributes a failing
// `after_all` to the hook rather than to any individual test. This is a
// build-and-run e2e: the spawned `sfn test` compiles the fixture to a
// harness binary, so the child env threads the parent environment
// (PATH/HOME/TMPDIR for clang + its linker) but points the nested runner
// at an isolated per-file scratch subdir — see `_nested_scratch` below and
// `.claude/rules/no-bash-e2e.md`.
//
// NOTE: assert on captured output with `sfn/strings` predicates — the
// `sfn/test` `expect_*` matchers are `![pure]` and cannot be called from
// an `![io]` test (#842).
import { find } from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

// This test spawns a nested `sfn test`, which is itself a full runner. To
// behave as a clean TOP-LEVEL runner, that nested process must inherit the
// ambient environment (PATH/HOME/TMPDIR + macOS SDK/toolchain vars, needed
// by its clang/linker) but NONE of the per-child test-orchestration keys
// the *parent* runner set on us — they bind the nested runner to the
// parent's private state. `_pool_child_env` (`cli/commands/test.sfn`) owns
// exactly this key set; leaking any of them into a nested run breaks it:
//   - `SAILFIN_TEST_SCRATCH` — the nested runner ADOPTS it verbatim and
//     routes ITS `results.log`/`fail.bin` there, clobbering the ones our
//     own recoverable harness writes for THIS file's tests (mis-classifies
//     later tests). We replace it with an isolated per-file subdir.
//   - `SAILFIN_TEST_JSON_SUBFRAME` — set on us under the parallel pool;
//     inherited, it makes the nested runner emit as a *subframe*, writing
//     its `summary` event to `_subframe_summary.json` instead of stdout,
//     so our `find(out, "\"passed\":2,...")` assertions never see it. This
//     was the pool-only 3/3 failure.
//   - `SAILFIN_TEST_RUNTIME_OBJDIR` / `SAILFIN_TEST_RUNTIME_STAMP` — bind
//     the nested build to the parent's shared runtime object cache + its
//     invocation stamp nonce (#1996: a nested runner's nonce must never
//     validate the parent's stamp). Dropped so the nested build stays
//     self-contained under its own scratch.
//   - `SAILFIN_UPDATE_SNAPSHOTS` — orthogonal to this test; dropped so a
//     parent `--update-snapshots` run can't leak snapshot-writes into it.
// Only `SAILFIN_TEST_SCRATCH` is re-added, pointed at a subdir of our own
// scratch: isolated from our harness-IPC files, unique per test file (our
// scratch is per-file in the pool), and warm across this file's sequential
// nested runs (only the first pays the cold runtime compile).
fn _nested_scratch() -> string ![io] {
    let outer = env.get("SAILFIN_TEST_SCRATCH");
    if outer.length > 0 { return outer + "/nested-runner"; }
    // Standalone run (no test runner set our scratch): mint a private dir.
    return fs.mkdtemp("sfn-recoverable-scratch-");
}

// True when `entry` ("KEY=VALUE") is one of the per-child test-runner keys
// the parent manages — the set `_pool_child_env` strips + re-adds. Matched
// by exact `KEY=` prefix so a value containing the substring is unaffected.
fn _is_runner_managed(entry: string) -> boolean {
    if find(entry, "SAILFIN_TEST_SCRATCH=", 0) == 0 { return true; }
    if find(entry, "SAILFIN_TEST_RUNTIME_OBJDIR=", 0) == 0 { return true; }
    if find(entry, "SAILFIN_TEST_RUNTIME_STAMP=", 0) == 0 { return true; }
    if find(entry, "SAILFIN_TEST_JSON_SUBFRAME=", 0) == 0 { return true; }
    if find(entry, "SAILFIN_UPDATE_SNAPSHOTS=", 0) == 0 { return true; }
    return false;
}

// Build the nested child env: the ambient environment minus every
// per-child runner key, plus our isolated nested `SAILFIN_TEST_SCRATCH`.
fn _child_env(nested_scratch: string) -> string[] ![io] {
    let all = process.environ();
    let mut out: string[] = [];
    let mut i: int = 0;
    loop {
        if i >= all.length { break; }
        if !_is_runner_managed(all[i]) { out.push(all[i]); }
        i += 1;
    }
    out.push("SAILFIN_TEST_SCRATCH=" + nested_scratch);
    return out;
}

struct TestRun {
    exit: int,
    out: string
}

// Write `src` into a fresh temp dir and run `sfn test <dir> --json`,
// returning the exit code and combined stdout+stderr.
fn _run_json(src: string) -> TestRun ![io] {
    let dir = fs.mkdtemp("sfn-recoverable-");
    fs.writeFile(dir + "/recoverable_test.sfn", src);
    let argv: string[] = [_sfn_bin(), "test", dir, "--json", "--no-test-cache"];
    let exit = process.run_capture(argv, _child_env(_nested_scratch()));
    let out = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    return TestRun { exit: exit, out: out + err };
}

// ---- Test 1: a failing test does not stop later tests from running ----
test "recoverable harness: continue after a failing test" ![io] {
    let src = "test \"alpha passes\" {\n    assert 1 == 1;\n}\n\n"
        + "test \"beta fails\" {\n    assert 1 == 2;\n}\n\n"
        + "test \"gamma passes\" {\n    assert 3 == 3;\n}\n";
    let r = _run_json(src);
    let out = r.out;
    assert find(out, "\"name\":\"alpha passes\"", 0) >= 0;
    assert find(out, "\"name\":\"gamma passes\"", 0) >= 0;
    // The key proof: gamma ran AND passed after beta failed — continuation
    // across more than one test, not just a single retry.
    assert find(out, "\"passed\":2,\"failed\":1,\"skipped\":0", 0) >= 0;
}

// ---- Test 2: a failing before_each fails every test it wraps ----
test "recoverable harness: failing before_each fails each test" ![io] {
    let src = "before_each {\n    assert 1 == 2;\n}\n\n"
        + "test \"one\" {\n    assert 1 == 1;\n}\n\n"
        + "test \"two\" {\n    assert 1 == 1;\n}\n";
    let r = _run_json(src);
    let out = r.out;
    assert find(out, "\"passed\":0,\"failed\":2,\"skipped\":0", 0) >= 0;
    assert find(out, "\"name\":\"one\"", 0) >= 0;
    assert find(out, "\"name\":\"two\"", 0) >= 0;
}

// ---- Test 3: a failing after_all is attributed to the hook, not a test ----
test "recoverable harness: failing after_all is attributed to the hook" ![io] {
    let src = "after_all {\n    assert 1 == 2;\n}\n\n"
        + "test \"one\" {\n    assert 1 == 1;\n}\n\n"
        + "test \"two\" {\n    assert 2 == 2;\n}\n";
    let r = _run_json(src);
    let out = r.out;
    assert find(out, "\"event\":\"hook\"", 0) >= 0;
    assert find(out, "\"hook\":\"after_all\"", 0) >= 0;
    assert find(out, "\"passed\":2", 0) >= 0;
}
