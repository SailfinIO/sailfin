// E2E golden-IR regression test for the concurrency frontend lowering — issue
// #1085, epic #965 (M4). Verifies that `channel`/`spawn`/`parallel`/`serve`
// lower to the correct runtime-helper call symbols in LLVM IR, with no
// `[fatal]: not yet lowered` diagnostics.
//
// Native replacement for the former `test_concurrency_lowering_ir.sh`
// (test-infra Phase 3, epic #842; ratchet #1327). Drives `sfn emit llvm`
// against inline fixtures and asserts on the captured `.ll` text.
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]` and so
// cannot be called from an `![io]` test like these. Assert on the captured
// `.ll` text with `sfn/strings` predicates instead. (#842.)
import { contains } from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

// Child environment for the spawned `sfn emit`. `process.run_capture` treats
// an empty array as the *empty* environment (not "inherit"), so the relevant
// variables must be threaded explicitly (PATH for any subprocess the compiler
// shells out to; SAILFIN_TEST_SCRATCH so a parallel run does not collide on
// the fixed `build/sailfin` build-cache dir — #1333).
fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    return dir;
}

// Lower `source` to a standalone `.ll` via `sfn emit llvm` and return the IR
// text. Writes the fixture and `.ll` to unique scratch paths keyed by `tag`
// so sub-tests do not collide; returns "" on emit failure.
fn _emit_llvm(source: string, tag: string) -> string ![io] {
    let dir = _scratch_dir();
    let src = dir + "/sfn-concurrency-ir-" + tag + ".sfn";
    let ll = dir + "/sfn-concurrency-ir-" + tag + ".ll";
    fs.writeFile(src, source);
    if fs.exists(ll) { fs.deleteFile(ll); }
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", ll, "llvm", src], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    fs.deleteFile(src);
    if exit != 0 { return ""; }
    if !fs.exists(ll) { return ""; }
    let ir = fs.readFile(ll);
    fs.deleteFile(ll);
    return ir;
}

// channel(N) → sfn_channel_create(i64 N, i64 8) (#1266; was 1-arg i32 in #1091)
test "concurrency-ir: channel(N) lowers to sfn_channel_create (#1091)" ![io] {
    let ir = _emit_llvm("fn main() ![io] {\n    let ch = channel(4);\n}\n", "channel_create");
    assert ir.length > 0;
    assert contains(ir, "sfn_channel_create");
}

// channel_create call carries the capacity, the elem_size operand AND the
// `owned` flag (#1476), matching runtime/sfn/concurrency/channel.sfn (§2.6.4):
// a bare channel(N) is monomorphized to pointer-sized, non-owned elements, so
// elem_size is 8 and owned is 0.
test "concurrency-ir: channel_create carries i64 capacity + elem_size + owned (#1266, #1476)" ![io] {
    let ir = _emit_llvm("fn main() ![io] {\n    let ch = channel(4);\n}\n", "channel_create_i64");
    assert ir.length > 0;
    assert contains(ir, "sfn_channel_create(i64 4, i64 8, i64 0)");
}

// channel:OwnedBuf(N) sizes the ring slot to the 32-byte aggregate AND sets
// the `owned` flag to 1 (#1476), so sfn_channel_destroy drains abandoned
// buffers. A struct named OwnedBuf is defined inline so the kind resolves and
// the elem_size GEP-sizeof idiom yields 32.
test "concurrency-ir: channel:OwnedBuf carries elem_size 32 + owned 1 (#1476)" ![io] {
    let src = "struct OwnedBuf {\n    ptr_addr: int;\n    len: int;\n    cap: int;\n    arena_addr: int;\n}\n\nfn main() ![io] {\n    let ch = channel:OwnedBuf(2);\n}\n";
    let ir = _emit_llvm(src, "channel_create_owned");
    assert ir.length > 0;
    assert contains(ir, "@sfn_channel_create");
    assert contains(ir, ", i64 1)");
}

// spawn:int <lambda> → sfn_spawn_int (#1090 flip)
test "concurrency-ir: spawn:int lowers to sfn_spawn_int (#1090)" ![io] {
    let ir = _emit_llvm("fn main() ![io] {\n    let f = spawn fn() -> int { return 1; };\n}\n", "spawn_int");
    assert ir.length > 0;
    assert contains(ir, "sfn_spawn_int");
}

// #1476: a spawn task capturing a moved OwnedBuf stores the 32-byte aggregate
// by VALUE in the closure env (env field `%OwnedBuf`, not a `%OwnedBuf*`
// pointer — the by-value capture fix) and routes the spawn through the
// `_owned_buf_ctx` trampoline family, whose worker reclaims the libc-backed
// buffer at env offset 0. A struct named OwnedBuf is defined inline so the
// capture type resolves.
test "concurrency-ir: spawn capturing OwnedBuf uses by-value env + owned_buf_ctx (#1476)" ![io] {
    let src = "struct OwnedBuf {\n    ptr_addr: int;\n    len: int;\n    cap: int;\n    arena_addr: int;\n}\n\nfn main() ![io] {\n    let buf: OwnedBuf = OwnedBuf { ptr_addr: 0, len: 7, cap: 8, arena_addr: 0 };\n    let f = spawn fn() -> int { return buf.len; };\n}\n";
    let ir = _emit_llvm(src, "spawn_owned_buf");
    assert ir.length > 0;
    // env field is the by-value aggregate, NOT a pointer.
    assert contains(ir, "%sfn_closure_env_0 = type { %OwnedBuf }");
    // spawn routes through the owned-buffer reclaim trampoline family.
    assert contains(ir, "sfn_spawn_int_owned_buf_ctx");
}

// SFN-381: the same fixture with a *mutable* first-capture OwnedBuf must be
// REFUSED, never silently miscompiled. A `let mut buf` binding encodes the
// capture as `ref_mut` (an 8-byte `%OwnedBuf*` slot pointer at env offset 0),
// but the `owned_buf` tag (set from `type_text == "OwnedBuf"` alone) would
// select the `_owned_buf_ctx` trampoline that reads offset 0 as a by-value
// 32-byte OwnedBuf — a pointer/aggregate size collision (corruption / UAF).
// The lowering emits a `[fatal]` diagnostic and writes no `.ll`. `_emit_llvm`
// is not reused here because it discards stderr; this drives the compile
// directly to assert on the diagnostic text.
test "concurrency-ir: spawn capturing mutable OwnedBuf is rejected, not miscompiled (SFN-381)" ![io] {
    let dir = _scratch_dir();
    let src = dir + "/sfn-concurrency-ir-spawn_owned_buf_mut.sfn";
    let ll = dir + "/sfn-concurrency-ir-spawn_owned_buf_mut.ll";
    let source = "struct OwnedBuf {\n    ptr_addr: int;\n    len: int;\n    cap: int;\n    arena_addr: int;\n}\n\nfn main() ![io] {\n    let mut buf: OwnedBuf = OwnedBuf { ptr_addr: 0, len: 7, cap: 8, arena_addr: 0 };\n    let f = spawn fn() -> int { return buf.len; };\n}\n";
    fs.writeFile(src, source);
    if fs.exists(ll) { fs.deleteFile(ll); }
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", ll, "llvm", src], _child_env());
    let _o = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    fs.deleteFile(src);
    let ll_exists = fs.exists(ll);
    if ll_exists { fs.deleteFile(ll); }
    // Refused: non-zero exit and no `.ll` written (fail-closed).
    assert exit != 0;
    assert ! ll_exists;
    // Fatal diagnostic names the offending mutable OwnedBuf capture and cites
    // SFN-381 so the user sees why the build aborted.
    assert contains(err, "[fatal]");
    assert contains(err, "OwnedBuf");
    assert contains(err, "SFN-381");
}

// parallel [<lambda>, ...] → a single sfn_parallel fan-out/join call (#1474).
// Each task's lifted-lambda closure pair `{i8*, i8*}` is unpacked (extractvalue)
// into an (fn_ptr, ctx) i64 pair and handed to the runtime combinator, which
// spawns every task onto the shared pool and joins them. This replaced the
// former per-task `sfn_spawn_task` stub call, which allocated a Task but never
// enqueued it (the tasks never ran).
test "concurrency-ir: parallel [tasks] lowers to sfn_parallel (#1474)" ![io] {
    let source = "fn main() ![io] {\n    let p = parallel [fn() -> int { return 1; }, fn() -> int { return 2; }];\n}\n";
    let ir = _emit_llvm(source, "parallel_join");
    assert ir.length > 0;
    assert contains(ir, "call i8* @sfn_parallel(");
    assert contains(ir, "extractvalue {i8*, i8*}");
}

// serve(handler, port) → sfn_serve (Sailfin-native server, #1092).
test "concurrency-ir: serve(handler, port) lowers to sfn_serve (#1092)" ![io] {
    let source = "fn handler() ![net, io] { }\nfn main() ![net, io] {\n    serve(handler, 8080);\n}\n";
    let ir = _emit_llvm(source, "serve_serve_start");
    assert ir.length > 0;
    assert contains(ir, "sfn_serve");
}
