// Fixture for the SFN-408 array-interpolation regression
// (compiler/tests/e2e/array_interpolation_test.sfn).
//
// Interpolating a primitive-element array into a `{{ }}` string used to
// stringify to a null operand, dropping the entire enclosing `print` (and
// its literal prefix) at exit 0. Each `print` below exercises one supported
// element kind plus nested array recursion; the driving test asserts the
// bracketed rendering appears between `before` and `after`.
fn main() ![io] {
    print("before");
    let m = [[19, 22], [43, 50]];
    print("Result: {{m}}");
    let ns = [1, 2, 3];
    print("ints: {{ns}}");
    let bs: boolean[] = [true, false];
    print("bools: {{bs}}");
    let ss: string[] = ["a", "b"];
    print("strs: {{ss}}");
    let fs: float[] = [1.5, 2.5];
    print("floats: {{fs}}");
    let fss: float[][] = [[1.5, 2.5], [3.25, 4.75]];
    print("nested floats: {{fss}}");
    print("after");
}
