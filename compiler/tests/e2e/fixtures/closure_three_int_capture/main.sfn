// compiler/tests/e2e/fixtures/closure_three_int_capture/main.sfn
//
// Issue #1106 acceptance — a lambda that captures THREE enclosing
// locals. Guards against an off-by-one in the env-struct field walk
// (the fix makes the type-decl, alloc/populate, and load prologue
// agree on field count and order for N >= 2 captures). Capture order
// is first-use: a, b, c.
//
// Expected stdout: 16 (10 argument + 1 + 2 + 3 captured).
fn apply(cb: fn (int) -> int, x: int) -> int { return cb(x); }

fn main() ![io] {
    let a: int = 1;
    let b: int = 2;
    let c: int = 3;
    print(apply(fn (d: int) -> int { return d + a + b + c; }, 10));
}
