// Fixture for compiler/tests/e2e/arena_loop_rewind_test.sfn (#1514).
//
// Positive case: a generic `loop { … }` whose only heap allocation is a
// per-iteration `Cell` struct that never escapes — it is read field-wise
// (`cell.a`) into a primitive accumulator and then discarded. The lowering
// must wrap the body in exactly one `@sfn_arena_sfn_mark` / one
// `@sfn_arena_sfn_rewind` pair so the bump space is reclaimed each iteration.
struct Cell {
    a: int;
    b: int;
    c: int;
}

fn main() ![io] {
    let iterations = 1000;
    let mut acc = 0;
    let mut i = 0;
    loop {
        if i >= iterations { break; }
        let cell = Cell { a: i, b: i + 1, c: i + 2 };
        acc = acc + cell.a + cell.b + cell.c;
        i = i + 1;
    }
    if acc < 0 { return; }
    print("done");
}
