// Fixture for compiler/tests/e2e/runtime_io_print_test.sfn (#1310).
//
// Exercises the native `write(2)` print-family bodies in
// `runtime/sfn/io.sfn` end-to-end: each `print.*` surface must emit its
// prefix + message + newline on the correct file descriptor (info/raw →
// stdout, err/warn/error → stderr), byte-identical to the retired C
// `_print_line`. Literal arguments only — no capsule imports — so the
// fixture builds standalone in a temp dir.
fn main() -> void ![io] {
    print.info("alpha");
    print.warn("bravo");
    print.error("charlie");
    print.err("delta");
    print("echo");
}
