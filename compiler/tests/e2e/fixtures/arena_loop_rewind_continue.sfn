// Fixture for compiler/tests/e2e/arena_loop_rewind_test.sfn (#1514).
//
// Positive-with-continue case: an eligible body (all-scalar `Cell`, fields
// only read) that also takes an early `continue`. The body is still wrapped
// in one mark + one rewind; the rewind sits on the fall-through-to-latch
// path, so the `continue` branch reaches the latch WITHOUT rewinding. That is
// a deliberate, safe missed-reclamation (the iteration's allocations leak to
// the next mark, never a dangling pointer) — this fixture pins that the IR
// stays well-formed and the program runs correctly.
struct Cell {
    a: int;
    b: int;
    c: int;
}

fn main() ![io] {
    let iterations = 1000;
    let mut acc = 0;
    let mut i = 0;
    loop {
        if i >= iterations { break; }
        let cell = Cell { a: i, b: i + 1, c: i + 2 };
        i = i + 1;
        if cell.a > 500 { continue; }
        acc = acc + cell.b + cell.c;
    }
    if acc < 0 { return; }
    print("done");
}
