// End-to-end test for the int/float numeric types Phase 1 #2 work.
//
// Native replacement for the former `test_numeric_int_float.sh`
// (test-infra Phase 3, epic #842; ratchet #1327). Pins the LLVM
// emission for `int` (i64), `float` (double), and the extern
// accept-list extensions. Pre-fix, `let x: float = 3.14` was silently
// lowered as a string pointer (i8*) — `+` then routed through
// `sailfin_runtime_string_concat`. These assertions surface that
// regression at `make test-e2e` before it can ship.
//
// Acceptance:
//   - `let x: int = 42; let y = x + 1;` emits `add i64`, no `fadd double`.
//   - `let x: float = 3.14; let y = x + 2.0;` emits `fadd double`, no
//     `alloca i8*` / `string_concat`.
//   - `extern fn add_one(x: int) -> int;` lowers to
//     `declare i64 @add_one(i64 ...)`.
//   - `extern fn double_it(x: float) -> float;` lowers to
//     `declare double @double_it(double ...)`.
//   - wider int/float widths (i16/u16/u32/u64/isize/f32) lower to the
//     expected LLVM types.
//   - `i8` struct fields lower as `i8`, not `i8*`.
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]` and so
// cannot be called from an `![io]` test like these. Assert on the captured
// `.ll` text with `sfn/strings` predicates instead. (#842.)
import { contains, starts_with, split } from "sfn/strings";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/native/sailfin";
}

// Child environment for the spawned `sfn emit`. `process.run_capture` treats
// an empty array as the *empty* environment (not "inherit"), so the relevant
// variables must be threaded explicitly:
//   - `PATH` (+ `HOME`/`TMPDIR`): keeps any subprocess the compiler shells out
//     to resolvable.
//   - `SAILFIN_TEST_SCRATCH`: the runner's per-file scratch, which the
//     compiler routes its build-cache dir under (#1333) so a parallel run
//     (`--jobs N>1`) does not collide on the fixed `build/sailfin`.
fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    return dir;
}

// Isolate the body of the synthesised `@sailfin_user_main__...` function from
// emitted IR. The emitted module always carries a trailing `add____<module>`
// helper (lowered as `fadd double`) regardless of whether `main`'s body uses
// doubles, so a whole-file grep can't distinguish "main uses fadd" from "the
// helper uses fadd". LLVM `define` lines start at column 0, so the prefix
// match is exact; collection stops at the column-0 closing `}`.
fn _main_body(ir: string) -> string {
    let lines = split(ir, "\n");
    let mut out = "";
    let mut inside = false;
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if !inside {
            if starts_with(line, "define") && contains(line, "@sailfin_user_main__") {
                inside = true;
                out = out + line + "\n";
            }
        } else {
            out = out + line + "\n";
            if starts_with(line, "}") { break; }
        }
        i += 1;
    }
    return out;
}

// Write `source` to a scratch `.sfn` keyed by `tag`, lower it to LLVM IR via
// `sfn emit llvm`, and return the whole IR text. Returns "" on emit failure
// so callers assert on the emptiness.
fn _emit_llvm(source: string, tag: string) -> string ![io] {
    let dir = _scratch_dir();
    let src = dir + "/sfn-numeric-int-float-" + tag + ".sfn";
    let ll = dir + "/sfn-numeric-int-float-" + tag + ".ll";
    fs.writeFile(src, source);
    if fs.exists(ll) { fs.deleteFile(ll); }
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", ll, "llvm", src], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    if exit != 0 { return ""; }
    if !fs.exists(ll) { return ""; }
    let ir = fs.readFile(ll);
    fs.deleteFile(ll);
    fs.deleteFile(src);
    return ir;
}

// ---- int arithmetic emits `add i64` (no `fadd double`) ----
test "numeric-int-float: int + int emits 'add i64' (no fadd double)" ![io] {
    let ir = _emit_llvm("fn main() {\n" + "    let x: int = 42;\n"
        + "    let y: int = 1;\n"
        + "    let z = x + y;\n"
        + "}\n", "int_add");
    assert ir.length > 0;
    let body = _main_body(ir);
    assert body.length > 0;
    assert contains(body, "add i64");
    // int operands must not coerce onto the double side.
    assert ! contains(body, "fadd double");
}

// ---- float arithmetic emits `fadd double`, NOT string lowering ----
test "numeric-int-float: float + float emits 'fadd double' (no string lowering)" ![io] {
    let ir = _emit_llvm("fn main() {\n" + "    let x: float = 3.14;\n"
        + "    let y: float = 2.0;\n"
        + "    let z = x + y;\n"
        + "}\n", "float_add");
    assert ir.length > 0;
    let body = _main_body(ir);
    assert body.length > 0;
    assert contains(body, "fadd double");
    // The pre-fix bug routed `let x: float = ...` through string lowering
    // (i8* alloca + sailfin_runtime_string_concat). Neither may appear.
    assert ! contains(body, "alloca i8*");
    assert ! contains(body, "string_concat");
}

// ---- extern fn with int/float lowers to clean declares ----
test "numeric-int-float: extern int/float signatures lower to clean declares" ![io] {
    let ir = _emit_llvm("extern fn add_one(x: int) -> int;\n"
        + "extern fn double_it(x: float) -> float;\n"
        + "extern fn scale(value: int, factor: float) -> float;\n", "extern_if");
    // Emit succeeds only if the frontend accepts the int/float externs.
    assert ir.length > 0;
    assert contains(ir, "declare i64 @add_one(i64");
    assert contains(ir, "declare double @double_it(double");
    assert contains(ir, "declare double @scale(i64");
}

// ---- float comparison emits `fcmp ogt double` ----
test "numeric-int-float: annotated float comparison emits 'fcmp ogt double'" ![io] {
    let ir = _emit_llvm("fn cmp(x: float, y: float) -> bool {\n"
        + "    return x > y;\n"
        + "}\n", "float_cmp");
    assert ir.length > 0;
    assert contains(ir, "fcmp ogt double");
}

// ---- int comparison emits `icmp sgt i64` ----
test "numeric-int-float: annotated int comparison emits 'icmp sgt i64'" ![io] {
    let ir = _emit_llvm("fn cmp(x: int, y: int) -> bool {\n"
        + "    return x > y;\n"
        + "}\n", "int_cmp");
    assert ir.length > 0;
    assert contains(ir, "icmp sgt i64");
}

// ---- wider int/float widths (Slice C) lower correctly ----
test "numeric-int-float: wider int/float widths lower to expected LLVM types" ![io] {
    let ir = _emit_llvm("extern fn read_u16(buf: *u8) -> u16;\n"
        + "extern fn ioctl(fd: i32, request: u64) -> i32;\n"
        + "extern fn read_bytes(fd: i32, buf: *u8, count: usize) -> isize;\n"
        + "extern fn pad(x: i16) -> i32;\n"
        + "extern fn fchmod(fd: i32, mode: u32) -> i32;\n"
        + "extern fn fast_sin(x: f32) -> f32;\n", "wider");
    assert ir.length > 0;
    assert contains(ir, "declare i16 @read_u16(i8*");
    assert contains(ir, "declare i32 @ioctl(i32");
    // isize → i64 return.
    assert contains(ir, "declare i64 @read_bytes(i32");
    assert contains(ir, "declare i32 @pad(i16");
    // u32 → i32.
    assert contains(ir, "declare i32 @fchmod(i32");
    // f32 → float.
    assert contains(ir, "declare float @fast_sin(float");
}

// ---- i8 struct fields lower as i8, not i8* ----
test "numeric-int-float: i8 struct fields lower as i8 (not i8*)" ![io] {
    let ir = _emit_llvm("struct Pixel {\n" + "    r: i8;\n" + "    g: i8;\n"
        + "    b: i8;\n"
        + "}\n\n"
        + "fn make() -> Pixel {\n"
        + "    return Pixel { r: 0, g: 0, b: 0 };\n"
        + "}\n", "i8_struct");
    assert ir.length > 0;
    assert contains(ir, "%Pixel = type { i8, i8, i8 }");
}
