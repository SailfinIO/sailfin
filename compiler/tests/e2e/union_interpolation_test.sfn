// End-to-end regression for SFN-343 / GitHub #2281 and SFN-346 / GitHub #2292.
//
// Interpolating an `int | null` value used to stringify to a null operand,
// causing the entire print statement to disappear with exit 0. A null literal
// in the same union slot later regressed into a null-pointer aggregate load.
// This builds and runs a fixture so LLVM lowering, union boxing,
// stringification, and the runtime print path all have to agree on both arms.
import { find } from "sfn/strings";
import { expect_eq_bool, expect_eq_int, with_tmp_dir } from "sfn/test";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

fn _fixture_src() -> string ![io] {
    return fs.readFile("compiler/tests/e2e/fixtures/union_interpolation_optional_int.sfn");
}

fn _child_env() -> string[] ![io] { return process.environ(); }

fn _marker(name: string) -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    let path = dir + "/sfn-union-interp-" + name + ".out";
    if fs.exists(path) { fs.deleteFile(path); }
    return path;
}

fn _build_and_run(out_marker: string) -> int ![io] {
    return with_tmp_dir(fn (dir: string) -> int {
        let srcpath = dir + "/probe.sfn";
        fs.writeFile(srcpath, _fixture_src());
        let binpath = dir + "/probe";
        let build_exit = process.run_capture([_sfn_bin(), "build", "-o", binpath, srcpath], _child_env());
        let _bo = process.capture_take_stdout();
        let _be = process.capture_take_stderr();
        if build_exit != 0 { return -100; }
        let run_exit = process.run_capture([binpath], []);
        let out = process.capture_take_stdout();
        let _re = process.capture_take_stderr();
        fs.writeFile(out_marker, out);
        return run_exit;
    });
}

fn _emit_ir(out_marker: string) -> int ![io] {
    return with_tmp_dir(fn (dir: string) -> int {
        let srcpath = dir + "/probe.sfn";
        fs.writeFile(srcpath, _fixture_src());
        let llpath = dir + "/probe.ll";
        let emit_exit = process.run_capture([_sfn_bin(), "emit", "-o", llpath, "llvm", srcpath], _child_env());
        let _eo = process.capture_take_stdout();
        let _ee = process.capture_take_stderr();
        if emit_exit != 0 { return emit_exit; }
        fs.writeFile(out_marker, fs.readFile(llpath));
        return 0;
    });
}

test "union interpolation: optional int payload renders in direct, narrowed, and match-bound forms" ![io] {
    let marker = _marker("optional-int");
    let exit = _build_and_run(marker);
    assert expect_eq_int(exit, 0).ok;
    let out = fs.readFile(marker);
    if fs.exists(marker) { fs.deleteFile(marker); }

    assert expect_eq_bool(find(out, "before\n", 0) >= 0, true).ok;
    assert expect_eq_bool(find(out, "mid 5 end\n", 0) >= 0, true).ok;
    assert expect_eq_bool(find(out, "narrow 5\n", 0) >= 0, true).ok;
    assert expect_eq_bool(find(out, "match 5\n", 0) >= 0, true).ok;
    assert expect_eq_bool(find(out, "null null\n", 0) >= 0, true).ok;
    assert expect_eq_bool(find(out, "label ready\n", 0) >= 0, true).ok;
    assert expect_eq_bool(find(out, "after\n", 0) >= 0, true).ok;
    assert expect_eq_bool(find(out, "mid 0 end", 0) < 0, true).ok;
}

test "union interpolation: null literal uses declared null arm for ambiguous pointer unions" ![io] {
    let marker = _marker("ambiguous-null-ir");
    let exit = _emit_ir(marker);
    assert expect_eq_int(exit, 0).ok;
    let ir = fs.readFile(marker);
    if fs.exists(marker) { fs.deleteFile(marker); }

    assert expect_eq_bool(find(ir, "insertvalue { i32, i8*, i8* } undef, i32 1, 0", 0) >= 0, true).ok;
    assert expect_eq_bool(find(ir, "bitcast i8* null to { i32", 0) < 0, true).ok;
}
