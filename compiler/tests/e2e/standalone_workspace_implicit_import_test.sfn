// Regressions for SFN-348 and SFN-352: a standalone source file outside the
// repo workspace can import a bundled workspace capsule regardless of whether
// the compiler starts in the checkout or the entry file's directory. Before
// SFN-352, `sfn check` passed from the entry cwd, but `build` and `run` did not
// stage `sfn/strings` and failed during lowering.
import { contains, find } from "sfn/strings";
import { with_tmp_dir } from "sfn/test";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

fn _sfn_bin_abs() -> string ![io] {
    let bin = _sfn_bin();
    if bin.length > 0 {
        if find(bin, "/", 0) == 0 { return bin; }
    }
    let root = env.get("PWD");
    if root.length > 0 { return root + "/" + bin; }
    return bin;
}

fn _child_env() -> string[] ![io] {
    let parent = process.environ();
    let mut out: string[] = [];
    let mut i: int = 0;
    loop {
        if i >= parent.length { break; }
        let entry = parent[i];
        i += 1;
        if find(entry, "SAILFIN_TEST_RUNTIME_OBJDIR=", 0) == 0 { continue; }
        if find(entry, "SAILFIN_TEST_RUNTIME_STAMP=", 0) == 0 { continue; }
        out.push(entry);
    }
    return out;
}

fn _marker(name: string) -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    fs.createDirectory(dir, true);
    let path = dir + "/sfn-348-standalone-" + name + ".out";
    if fs.exists(path) { fs.deleteFile(path); }
    return path;
}

fn _run_standalone_program_from_entry_cwd(marker: string) -> int ![io] {
    return with_tmp_dir(fn (dir: string) -> int {
        let src = dir + "/repro.sfn";
        let bin = dir + "/repro";
        fs.writeFile(src, "import { split, trim, join } from \"sfn/strings\";\n\n"
            + "fn main() ![io] {\n"
            + "    let text = trim(\" a b \");\n"
            + "    let parts = split(text, \" \");\n"
            + "    print(join(parts, \"-\"));\n"
            + "}\n");

        let sfn = _sfn_bin_abs();
        let check_exit = process.run_capture_cwd([sfn, "check", "repro.sfn"], _child_env(), dir);
        let check_out = process.capture_take_stdout();
        let check_err = process.capture_take_stderr();
        if check_exit != 0 {
            fs.writeFile(marker, check_out + check_err);
            return check_exit;
        }

        let build_exit = process.run_capture_cwd([sfn, "build", "-o", bin, "repro.sfn"], _child_env(), dir);
        let build_out = process.capture_take_stdout();
        let build_err = process.capture_take_stderr();
        if build_exit != 0 {
            fs.writeFile(marker, build_out + build_err);
            return build_exit;
        }

        let run_exit = process.run_capture_cwd([sfn, "run", "repro.sfn"], _child_env(), dir);
        let run_out = process.capture_take_stdout();
        let run_err = process.capture_take_stderr();
        fs.writeFile(marker, run_out + run_err);
        return run_exit;
    });
}

test "standalone check/build/run: entry cwd stages bundled sfn/strings" ![io] {
    let marker = _marker("strings-entry-cwd");
    let exit = _run_standalone_program_from_entry_cwd(marker);
    assert exit == 0;
    let output = fs.readFile(marker);
    if fs.exists(marker) { fs.deleteFile(marker); }
    assert contains(output, "a-b");
}
