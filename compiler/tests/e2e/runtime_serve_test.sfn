// End-to-end test for runtime/sfn/concurrency/serve.sfn — the
// Sailfin-native `serve` HTTP/1.1 server (M4 #1092, epic #965).
//
// Native (no-bash) replacement for the former `test_runtime_serve.sh`
// (test-infra Phase 3, epic #842; `.claude/rules/no-bash-e2e.md`).
// Mirrors runtime_adapter_http_test.sfn, inverted to the server side.
// Pins, end-to-end:
//   1. typecheck   — `sfn check runtime/sfn/concurrency/serve.sfn` is ok.
//   2. fmt         — the module is fmt-canonical.
//   3. emit shape  — `define` for sfn_serve + sfn_serve_handler_dispatch,
//                    `declare` of the BSD-sockets server surface
//                    (socket/bind/listen/accept/send/recv/close), and
//                    references to the M4.1 scheduler externs.
//   4. routing     — `serve(handler, port)` lowers to a `@sfn_serve` call
//                    and NOT the legacy `@sailfin_adapter_serve_start`.
//
// OMITTED: the original script's behavioral loopback round-trip leg
// (test_loopback_round_trip) started a real Sailfin `serve()` program in
// the background and drove a Python HTTP/1.1 client against it. A live
// network server / Python client cannot run as an `![io]` `sfn/test` leg
// per `.claude/rules/no-bash-e2e.md` (no network, no Python), so it is
// dropped here; the emit-shape + routing checks pin the registry-flip
// behavior without a network.
//
// NOTE on matchers: the `sfn/test` `expect_*` matchers are `![pure]`, so
// they cannot be called from an `![io]` test. For subprocess/IR-output
// assertions use `sfn/strings` (`find` / `split` / `starts_with` /
// `contains` / `char_at_index`), as the http adapter exemplar does.
import {
    find,
    split,
    starts_with,
    contains,
    char_at_index
} from "sfn/strings";

// The compiler-under-test: `$SAILFIN_BIN` if set, else the self-hosted
// binary relative to the repo root the runner starts from.
fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/native/sailfin";
}

// `run_capture`'s empty array is the *empty* environment; thread the
// variables the toolchain needs. `emit` / `check` neither link nor spawn
// clang (no PATH required), but keep the standard set for portability.
fn _child_env() -> string[] ![io] {
    let mut e: string[] = [];
    let path = env.get("PATH");
    if path.length > 0 { e.push("PATH=" + path); }
    let home = env.get("HOME");
    if home.length > 0 { e.push("HOME=" + home); }
    let tmpdir = env.get("TMPDIR");
    if tmpdir.length > 0 { e.push("TMPDIR=" + tmpdir); }
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    if scratch.length > 0 { e.push("SAILFIN_TEST_SCRATCH=" + scratch); }
    return e;
}

// A unique scratch dir for this test (under the runner's per-file scratch
// when present, else /tmp).
fn _scratch_dir() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    dir = dir + "/sfn-runtime-serve";
    fs.createDirectory(dir, true);
    return dir;
}

// Emit LLVM IR for the module at `module_path` and return it (or
// "EMIT_FAILED" on a non-zero exit).
fn _emit_module(tag: string, module_path: string) -> string ![io] {
    let dir = _scratch_dir();
    let outpath = dir + "/" + tag + ".ll";
    let exit = process.run_capture([_sfn_bin(), "emit", "-o", outpath, "llvm", module_path], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    if exit != 0 { return "EMIT_FAILED"; }
    return fs.readFile(outpath);
}

// Emit LLVM IR for source written to a scratch `.sfn` file, then read it
// back (or "EMIT_FAILED" on a non-zero exit).
fn _emit_source(tag: string, source: string) -> string ![io] {
    let dir = _scratch_dir();
    let srcpath = dir + "/" + tag + ".sfn";
    fs.writeFile(srcpath, source);
    return _emit_module(tag, srcpath);
}

// `^define .* @sym(` — a line that starts the symbol's definition.
fn _has_define(ir: string, sym: string) -> boolean {
    let lines = split(ir, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if starts_with(line, "define ") && contains(line, "@" + sym + "(") {
            return true;
        }
        i = i + 1;
    }
    return false;
}

// `^declare .* @sym(` — the module declares the libc trampoline.
fn _has_declare(ir: string, sym: string) -> boolean {
    let lines = split(ir, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        if starts_with(line, "declare ") && contains(line, "@" + sym + "(") {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn _is_word_char(ch: string) -> boolean {
    if ch.length == 0 { return false; }
    let word = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
    return find(word, ch, 0) >= 0;
}

// `@sym\b` — does the IR reference the bare symbol at a word boundary?
fn _references(ir: string, sym: string) -> boolean {
    let needle = "@" + sym;
    let mut pos = find(ir, needle, 0);
    loop {
        if pos < 0 { break; }
        let after = pos + needle.length;
        if after >= ir.length { return true; }
        let ch = char_at_index(ir, after);
        if !_is_word_char(ch) { return true; }
        pos = find(ir, needle, after);
    }
    return false;
}

// Does any `call`/`invoke` line target `@sym(`? (A `declare` of `@sym`
// is tolerated for seed compat; only call sites are load-bearing here.)
fn _calls(ir: string, sym: string) -> boolean {
    let lines = split(ir, "\n");
    let mut i = 0;
    loop {
        if i >= lines.length { break; }
        let line = lines[i];
        let is_call = contains(line, "call ") || contains(line, "invoke ");
        if is_call && contains(line, "@" + sym + "(") { return true; }
        i = i + 1;
    }
    return false;
}

test "runtime/sfn/concurrency/serve.sfn typechecks cleanly" ![io] {
    let exit = process.run_capture([_sfn_bin(), "check", "runtime/sfn/concurrency/serve.sfn"], _child_env());
    let out = process.capture_take_stdout();
    let err = process.capture_take_stderr();
    assert exit == 0;
    assert find(out + err, "ok", 0) >= 0;
}

test "runtime/sfn/concurrency/serve.sfn is fmt-canonical" ![io] {
    let exit = process.run_capture([_sfn_bin(), "fmt", "--check", "runtime/sfn/concurrency/serve.sfn"], _child_env());
    let _o = process.capture_take_stdout();
    let _e = process.capture_take_stderr();
    assert exit == 0;
}

test "serve emit: define for sfn_serve + sfn_serve_handler_dispatch" ![io] {
    let ir = _emit_module("serve", "runtime/sfn/concurrency/serve.sfn");
    assert ir != "EMIT_FAILED";
    assert _has_define(ir, "sfn_serve");
    assert _has_define(ir, "sfn_serve_handler_dispatch");
}

test "serve emit: declares the BSD-sockets server surface" ![io] {
    let ir = _emit_module("serve", "runtime/sfn/concurrency/serve.sfn");
    assert ir != "EMIT_FAILED";
    assert _has_declare(ir, "socket");
    assert _has_declare(ir, "bind");
    assert _has_declare(ir, "listen");
    assert _has_declare(ir, "accept");
    assert _has_declare(ir, "send");
    assert _has_declare(ir, "recv");
    assert _has_declare(ir, "close");
}

test "serve emit: references the M4.1 scheduler/task externs" ![io] {
    let ir = _emit_module("serve", "runtime/sfn/concurrency/serve.sfn");
    assert ir != "EMIT_FAILED";
    assert _references(ir, "sfn_taskqueue_create");
    assert _references(ir, "sfn_task_create");
    assert _references(ir, "sfn_taskqueue_enqueue");
    assert _references(ir, "sfn_scheduler_create");
}

test "serve(handler, port) lowers to @sfn_serve, not the legacy adapter" ![io] {
    let source = "fn handle(req: string) -> string {\n" + "    return \"ok\";\n"
        + "}\n\n"
        + "fn main() -> int ![net, io] {\n"
        + "    serve(handle, 8080);\n"
        + "    return 0;\n"
        + "}\n";
    let ir = _emit_source("serve_probe", source);
    assert ir != "EMIT_FAILED";
    // The flipped registry row routes through @sfn_serve.
    assert _calls(ir, "sfn_serve");
    // The legacy never-defined adapter symbol must not be CALLED anymore.
    assert ! _calls(ir, "sailfin_adapter_serve_start");
}
