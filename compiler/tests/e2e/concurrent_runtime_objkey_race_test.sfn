// Concurrent cold-build smoke test for the runtime object cache.
//
// History (the macOS nightly self-host check, roaming build-and-run
// failures): `_sha256_of_string` (compiler/src/build_cache.sfn) once
// hashed the runtime object cache key by writing to a SINGLE fixed tmp
// path `/tmp/.sfn_build_cache_hash_<suffix>` and then `rm -f`-ing it. The
// `<suffix>` (`cap_prefix + basename + opt_flag`, e.g.
// `sfn__runtime-native__prelude_sfn-O2`) was IDENTICAL across concurrent
// builds of the same runtime source, so two parallel `sfn run`/`sfn
// build` workers collided on that path — one `rm`-ed the file out from
// under the other's `sha256sum` (`No such file or directory`), and the
// poisoned key flipped a cache hit into a partial/wrong result, ending in
// a nested-build failure (assert abort, exit 134). That collision was
// PROCESS-GLOBAL — it bit even when each nested build was otherwise
// isolated via its own `SAILFIN_TEST_SCRATCH`.
//
// That race is now structurally impossible: `_sha256_of_string` hashes
// in-process (no shared tmp file, no deterministic
// `/tmp/.sfn_build_cache_hash_*` path). This test therefore no longer
// guards a live race — it is a concurrent cold-build smoke test plus a
// macOS-arm64 peak-RSS bound (see the fan-out note on the test itself,
// #1726 / SFN-87). It models the CI contention: N concurrent cold `sfn
// run`s, EACH with its own `SAILFIN_TEST_SCRATCH` (so the per-invocation
// `run.ll`/`.o`/binary stay isolated per child), asserting every child
// builds and prints its own marker with no cross-contamination.
import { contains } from "sfn/strings";
import { report_child_failure } from "sfn/test";

fn _sfn_bin() -> string ![io] {
    let configured = env.get("SAILFIN_BIN");
    if configured.length > 0 { return configured; }
    return "build/bin/sfn";
}

fn _scratch_base() -> string ![io] {
    let mut dir = env.get("SAILFIN_TEST_SCRATCH");
    if dir.length == 0 { dir = "/tmp"; }
    dir = dir + "/objkey-race";
    fs.createDirectory(dir, true);
    return dir;
}

// One concurrent round: write N distinct fixtures, build+run them
// concurrently (each with its OWN per-child scratch), and assert each
// child exits 0 and prints its own marker with no cross-contamination.
fn _race_round(base: string, round: int, n: int) -> boolean ![io] {
    // Build the `bash -c` vehicle: launch N `sfn run`s in the background,
    // each with a distinct SAILFIN_TEST_SCRATCH, then `wait`. Concurrent
    // cold runtime compiles are what this stresses.
    let bin = _sfn_bin();
    let mut script = "";
    let mut k = 0;
    loop {
        if k >= n { break; }
        let tag = number_to_string(round) + "_" + number_to_string(k);
        let marker = "OBJKEY_MARK_" + tag;
        let src = base + "/m_" + tag + ".sfn";
        let outp = base + "/o_" + tag + ".txt";
        let child_scratch = base + "/s_" + tag;
        fs.createDirectory(child_scratch, true);
        fs.writeFile(src, "fn main() ![io] {\n    print.info(\"" + marker
            + "\");\n}\n");
        // Each child gets its own scratch so run.ll/.o/binary are isolated;
        // the runtime object cache they populate is the only shared state.
        script = script + "( export SAILFIN_TEST_SCRATCH='" + child_scratch
            + "'; '"
            + bin
            + "' run '"
            + src
            + "' > '"
            + outp
            + "' 2>&1 ) &\n";
        k += 1;
    }
    script = script + "wait\n";

    let exit = process.run_capture(["bash", "-c", script], process.environ());
    let o = process.capture_take_stdout();
    let e = process.capture_take_stderr();
    if exit != 0 {
        // Surface the child output so a re-fire in the macOS nightly is
        // diagnosable (OOM/SIGABRT vs. a genuine cache-key race) — these
        // background `sfn run`s otherwise swallow their stderr (#1462).
        report_child_failure("objkey-race round " + number_to_string(round), exit, o, e);
        return false;
    }

    // Verify every child produced exactly its own marker.
    let mut ok = true;
    let mut j = 0;
    loop {
        if j >= n { break; }
        let tag = number_to_string(round) + "_" + number_to_string(j);
        let marker = "OBJKEY_MARK_" + tag;
        let outp = base + "/o_" + tag + ".txt";
        if !fs.exists(outp) {
            print.err("[objkey-race] missing child output " + outp);
            ok = false;
        } else {
            let got = fs.readFile(outp);
            // Own marker present...
            if !contains(got, marker) {
                print.err("[objkey-race] child " + tag
                    + " missing own marker; got:\n"
                    + got);
                ok = false;
            }
            // ...and no sibling's marker leaked in (cross-contamination).
            let mut s = 0;
            loop {
                if s >= n { break; }
                if s != j {
                    let other = "OBJKEY_MARK_" + number_to_string(round) + "_"
                        + number_to_string(s);
                    if contains(got, other) { ok = false; }
                }
                s += 1;
            }
        }
        j += 1;
    }
    return ok;
}

test "concurrent cold builds do not race on the runtime objkey tmp file" ![io] {
    let base = _scratch_base();
    // 3 concurrent builds × 2 rounds. The tmp-file race this guards is
    // now structurally impossible — `_sha256_of_string` hashes in-process
    // (`build_cache.sfn`), so there is no shared tmp path left to collide
    // on — leaving this a concurrent-cold-build smoke test. The fan-out is
    // capped at 3 (was 6) to bound peak RSS: each cold runtime compile
    // peaks ~1.3–1.8 GB, and on the memory-constrained macOS-arm64 runner
    // (~7 GB) this test's burst was the sole amplifier tipping the e2e
    // pool into OOM — the roaming SIGABRT (exit 134) nightly flake, #1726
    // / SFN-87. Every peer build-and-run e2e test runs its nested compiles
    // sequentially (≤1 concurrent); only this one bursts, so bounding it
    // here bounds the pool-wide peak. 3-way still exercises concurrent
    // cold runtime compiles.
    assert _race_round(base, 0, 3);
    assert _race_round(base, 1, 3);
}
