// Seed viability integration test: bootstrap readiness.
// This test exercises ALL patterns required for the compiler to compile itself:
// - Complex string building (LLVM IR generation)
// - Struct with array fields (AST nodes, instruction lists)
// - Recursive processing (AST walking)
// - Enum dispatch (instruction type routing)
// - Multi-function data flow (pass pipeline)
// - Conditional string generation (type mapping)
// - Array of structs with filtering (symbol tables)
// If all these pass, the seed has the core functionality needed for self-hosting.

// ---------------------------------------------------------------------------
// Phase 1: Lexer-like tokenization
// ---------------------------------------------------------------------------

enum TokType {
    Keyword,
    Ident,
    Num,
    Op,
    Paren,
    Semi,
    Unknown,
}

struct Tok {
    kind: TokType;
    text: string;
    pos: number;
}

fn _is_alpha(ch: string) -> boolean {
    if ch == "a" { return true; } if ch == "b" { return true; }
    if ch == "c" { return true; } if ch == "d" { return true; }
    if ch == "e" { return true; } if ch == "f" { return true; }
    if ch == "g" { return true; } if ch == "h" { return true; }
    if ch == "i" { return true; } if ch == "j" { return true; }
    if ch == "k" { return true; } if ch == "l" { return true; }
    if ch == "m" { return true; } if ch == "n" { return true; }
    if ch == "o" { return true; } if ch == "p" { return true; }
    if ch == "q" { return true; } if ch == "r" { return true; }
    if ch == "s" { return true; } if ch == "t" { return true; }
    if ch == "u" { return true; } if ch == "v" { return true; }
    if ch == "w" { return true; } if ch == "x" { return true; }
    if ch == "y" { return true; } if ch == "z" { return true; }
    return false;
}

fn _is_digit(ch: string) -> boolean {
    if ch == "0" { return true; } if ch == "1" { return true; }
    if ch == "2" { return true; } if ch == "3" { return true; }
    if ch == "4" { return true; } if ch == "5" { return true; }
    if ch == "6" { return true; } if ch == "7" { return true; }
    if ch == "8" { return true; } if ch == "9" { return true; }
    return false;
}

fn _is_keyword(text: string) -> boolean {
    if text == "let" { return true; }
    if text == "fn" { return true; }
    if text == "if" { return true; }
    if text == "return" { return true; }
    if text == "mut" { return true; }
    return false;
}

fn _lex(input: string) -> Tok[] {
    let mut tokens: Tok[] = [];
    let mut i: number = 0;
    loop {
        if i >= input.length { break; }
        let ch = substring(input, i, i + 1);

        // Skip whitespace
        if ch == " " { i += 1; continue; }

        // Operators
        if ch == "+" || ch == "-" || ch == "*" || ch == "=" {
            tokens.push(Tok { kind: TokType.Op, text: ch, pos: i });
            i += 1;
            continue;
        }

        // Parens
        if ch == "(" || ch == ")" {
            tokens.push(Tok { kind: TokType.Paren, text: ch, pos: i });
            i += 1;
            continue;
        }

        // Semicolons
        if ch == ";" {
            tokens.push(Tok { kind: TokType.Semi, text: ch, pos: i });
            i += 1;
            continue;
        }

        // Numbers
        if _is_digit(ch) {
            let start = i;
            loop {
                if i >= input.length { break; }
                let nc = substring(input, i, i + 1);
                if !_is_digit(nc) { break; }
                i += 1;
            }
            tokens.push(Tok { kind: TokType.Num, text: substring(input, start, i), pos: start });
            continue;
        }

        // Identifiers and keywords
        if _is_alpha(ch) {
            let start = i;
            loop {
                if i >= input.length { break; }
                let nc = substring(input, i, i + 1);
                if !_is_alpha(nc) && !_is_digit(nc) { break; }
                i += 1;
            }
            let text = substring(input, start, i);
            if _is_keyword(text) {
                tokens.push(Tok { kind: TokType.Keyword, text: text, pos: start });
            } else {
                tokens.push(Tok { kind: TokType.Ident, text: text, pos: start });
            }
            continue;
        }

        // Unknown
        tokens.push(Tok { kind: TokType.Unknown, text: ch, pos: i });
        i += 1;
    }
    return tokens;
}

test "bootstrap: lexer tokenizes variable declaration" {
    let tokens = _lex("let x = 42;");
    assert tokens.length == 5;
    assert tokens[0].kind == TokType.Keyword;
    assert tokens[0].text == "let";
    assert tokens[1].kind == TokType.Ident;
    assert tokens[1].text == "x";
    assert tokens[2].kind == TokType.Op;
    assert tokens[2].text == "=";
    assert tokens[3].kind == TokType.Num;
    assert tokens[3].text == "42";
    assert tokens[4].kind == TokType.Semi;
}

test "bootstrap: lexer tokenizes function call" {
    // "fn add(a b)" → fn, add, (, a, b, ) = 6 tokens
    let tokens = _lex("fn add(a b)");
    assert tokens.length == 6;
    assert tokens[0].kind == TokType.Keyword;
    assert tokens[0].text == "fn";
    assert tokens[1].kind == TokType.Ident;
    assert tokens[2].kind == TokType.Paren;
    assert tokens[2].text == "(";
    assert tokens[5].kind == TokType.Paren;
    assert tokens[5].text == ")";
}

// ---------------------------------------------------------------------------
// Phase 2: AST-like structure building
// ---------------------------------------------------------------------------

enum NodeKind {
    LetBinding,
    BinaryOp,
    NumLit,
    VarRef,
    FnCall,
    Return,
}

struct ASTNode {
    kind: NodeKind;
    text: string;
    value: number;
    child_count: number;
}

fn _make_num_lit(val: number) -> ASTNode {
    return ASTNode { kind: NodeKind.NumLit, text: "", value: val, child_count: 0 };
}

fn _make_var_ref(name: string) -> ASTNode {
    return ASTNode { kind: NodeKind.VarRef, text: name, value: 0, child_count: 0 };
}

fn _make_binary_op(op: string) -> ASTNode {
    return ASTNode { kind: NodeKind.BinaryOp, text: op, value: 0, child_count: 2 };
}

fn _make_let_binding(name: string) -> ASTNode {
    return ASTNode { kind: NodeKind.LetBinding, text: name, value: 0, child_count: 1 };
}

fn _make_return_node() -> ASTNode {
    return ASTNode { kind: NodeKind.Return, text: "", value: 0, child_count: 1 };
}

test "bootstrap: AST node construction" {
    let num = _make_num_lit(42);
    assert num.kind == NodeKind.NumLit;
    assert num.value == 42;

    let var = _make_var_ref("x");
    assert var.kind == NodeKind.VarRef;
    assert var.text == "x";

    let op = _make_binary_op("+");
    assert op.kind == NodeKind.BinaryOp;
    assert op.child_count == 2;
}

// ---------------------------------------------------------------------------
// Phase 3: Code generation from AST
// ---------------------------------------------------------------------------

fn _codegen_node(node: ASTNode, ssa_counter: number) -> string {
    if node.kind == NodeKind.NumLit {
        let digits = "0123456789";
        let mut result: string = "";
        let mut rem: number = node.value;
        if rem == 0 { return "0.0"; }
        loop {
            if rem <= 0 { break; }
            let mut temp: number = rem;
            let mut q: number = 0;
            loop {
                if temp < 10 { break; }
                temp -= 10;
                q += 1;
            }
            result = substring(digits, temp, temp + 1) + result;
            rem = q;
        }
        return result + ".0";
    }
    if node.kind == NodeKind.VarRef {
        return "%" + node.text;
    }
    return "%unknown";
}

test "bootstrap: codegen number literal" {
    let node = _make_num_lit(42);
    assert _codegen_node(node, 0) == "42.0";
}

test "bootstrap: codegen zero literal" {
    let node = _make_num_lit(0);
    assert _codegen_node(node, 0) == "0.0";
}

test "bootstrap: codegen variable reference" {
    let node = _make_var_ref("result");
    assert _codegen_node(node, 0) == "%result";
}

// ---------------------------------------------------------------------------
// Phase 4: Full pipeline - lex → build AST → emit
// ---------------------------------------------------------------------------

struct CompileResult {
    success: boolean;
    output: string;
    error_count: number;
}

fn _compile_expression(input: string) -> CompileResult {
    let tokens = _lex(input);
    if tokens.length == 0 {
        return CompileResult { success: false, output: "", error_count: 1 };
    }

    // Simple: if single number, emit it
    if tokens.length == 1 && tokens[0].kind == TokType.Num {
        let node = _make_num_lit(0);  // Simplified
        return CompileResult {
            success: true,
            output: "  ret double " + tokens[0].text + ".0",
            error_count: 0,
        };
    }

    // If pattern: a + b
    if tokens.length == 3 && tokens[1].kind == TokType.Op && tokens[1].text == "+" {
        let left = tokens[0].text;
        let right = tokens[2].text;
        let mut output: string = "";
        output = output + "  %sum = fadd double " + left + ", " + right + "\n";
        output = output + "  ret double %sum";
        return CompileResult { success: true, output: output, error_count: 0 };
    }

    return CompileResult { success: false, output: "", error_count: 1 };
}

test "bootstrap: compile single number" {
    let result = _compile_expression("42");
    assert result.success == true;
    assert result.output == "  ret double 42.0";
    assert result.error_count == 0;
}

test "bootstrap: compile addition" {
    let result = _compile_expression("a + b");
    assert result.success == true;
    assert result.error_count == 0;
}

test "bootstrap: compile empty fails" {
    let result = _compile_expression("");
    assert result.success == false;
    assert result.error_count == 1;
}

// ---------------------------------------------------------------------------
// Phase 5: Multiple compilation units (simulates multi-module compilation)
// ---------------------------------------------------------------------------

struct Module {
    name: string;
    source: string;
    compiled: boolean;
    output: string;
}

fn _compile_module(mod: Module) -> Module {
    let result = _compile_expression(mod.source);
    return Module {
        name: mod.name,
        source: mod.source,
        compiled: result.success,
        output: result.output,
    };
}

fn _compile_all(modules: Module[]) -> number {
    let mut success_count: number = 0;
    let mut i: number = 0;
    loop {
        if i >= modules.length { break; }
        let compiled = _compile_module(modules[i]);
        if compiled.compiled {
            success_count += 1;
        }
        i += 1;
    }
    return success_count;
}

test "bootstrap: multi-module compilation" {
    let mut modules: Module[] = [];
    modules.push(Module { name: "mod_a", source: "42", compiled: false, output: "" });
    modules.push(Module { name: "mod_b", source: "a + b", compiled: false, output: "" });
    modules.push(Module { name: "mod_c", source: "100", compiled: false, output: "" });

    let successes = _compile_all(modules);
    assert successes == 3;
}

test "bootstrap: module compilation with failures" {
    let mut modules: Module[] = [];
    modules.push(Module { name: "good", source: "42", compiled: false, output: "" });
    modules.push(Module { name: "bad", source: "", compiled: false, output: "" });
    modules.push(Module { name: "good2", source: "10", compiled: false, output: "" });

    let successes = _compile_all(modules);
    assert successes == 2;
}

// ---------------------------------------------------------------------------
// Phase 6: Struct with array field manipulation (mimics real compiler data)
// ---------------------------------------------------------------------------

struct FunctionDef {
    name: string;
    params: string[];
    param_types: string[];
    return_type: string;
    body_lines: string[];
}

fn _build_function_ir(func: FunctionDef) -> string {
    let mut output: string = "";
    // Header
    output = output + "define " + func.return_type + " @" + func.name + "(";
    let mut i: number = 0;
    loop {
        if i >= func.params.length { break; }
        if i > 0 { output = output + ", "; }
        if i < func.param_types.length {
            output = output + func.param_types[i];
        } else {
            output = output + "i8*";
        }
        output = output + " %" + func.params[i];
        i += 1;
    }
    output = output + ") {\nentry:\n";
    // Body
    let mut j: number = 0;
    loop {
        if j >= func.body_lines.length { break; }
        output = output + "  " + func.body_lines[j] + "\n";
        j += 1;
    }
    output = output + "}\n";
    return output;
}

test "bootstrap: function IR generation" {
    let mut params: string[] = [];
    params.push("x");
    params.push("y");
    let mut types: string[] = [];
    types.push("double");
    types.push("double");
    let mut body: string[] = [];
    body.push("%sum = fadd double %x, %y");
    body.push("ret double %sum");

    let func = FunctionDef {
        name: "add",
        params: params,
        param_types: types,
        return_type: "double",
        body_lines: body,
    };

    let ir = _build_function_ir(func);

    // Verify the output contains expected parts
    let has_define = substring(ir, 0, 6);
    assert has_define == "define";
}

test "bootstrap: function IR with empty body" {
    let mut params: string[] = [];
    let mut types: string[] = [];
    let mut body: string[] = [];
    body.push("ret void");

    let func = FunctionDef {
        name: "noop",
        params: params,
        param_types: types,
        return_type: "void",
        body_lines: body,
    };

    let ir = _build_function_ir(func);
    let has_define = substring(ir, 0, 6);
    assert has_define == "define";
}
