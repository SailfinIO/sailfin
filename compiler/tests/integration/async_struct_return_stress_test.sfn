struct Person {
    id: int;

    fn id_plus(self, x: int) -> int { return self.id + x; }
}

async fn make_person(id: int) -> Person {
    return Person { id: id };
}

test "async: struct return stress" {
    let mut i: int = 0;
    loop {
        if i >= 200 { break; }

        // Await a FuturePtr in a typed context so the lowering unboxes + frees.
        let person: Person = await make_person(i);
        assert person.id_plus(1) == (i + 1);

        i += 1;
    }
}
