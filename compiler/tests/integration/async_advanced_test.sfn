// Seed viability integration test: async patterns.
// Tests async function declarations with various return types.
// The compiler itself doesn't use async heavily, but this verifies
// the async lowering path works correctly in the seed.

// ---------------------------------------------------------------------------
// Async with string return
// ---------------------------------------------------------------------------

async fn fetch_greeting() -> string {
    return "Hello from async!";
}

test "async_adv: string return" {
    let future = fetch_greeting();
    let result = await future;
    assert result == "Hello from async!";
}

// ---------------------------------------------------------------------------
// Async with computation
// ---------------------------------------------------------------------------

async fn compute_sum(n: number) -> number {
    let mut total: number = 0;
    let mut i: number = 1;
    loop {
        if i > n { break; }
        total += i;
        i += 1;
    }
    return total;
}

test "async_adv: computation in async" {
    let future = compute_sum(10);
    let result = await future;
    assert result == 55;
}

// ---------------------------------------------------------------------------
// Multiple async calls with different types
// ---------------------------------------------------------------------------

async fn get_number() -> number {
    return 42;
}

async fn get_string() -> string {
    return "hello";
}

async fn get_bool() -> boolean {
    return true;
}

test "async_adv: multiple async different types" {
    let f1 = get_number();
    let f2 = get_string();
    let f3 = get_bool();

    let n = await f1;
    let s = await f2;
    let b = await f3;

    assert n == 42;
    assert s == "hello";
    assert b == true;
}

// ---------------------------------------------------------------------------
// Async result used in further computation
// ---------------------------------------------------------------------------

async fn compute_a() -> number {
    return 10;
}

async fn compute_b() -> number {
    return 20;
}

test "async_adv: results combined" {
    let fa = compute_a();
    let fb = compute_b();
    let a = await fa;
    let b = await fb;
    let sum = a + b;
    assert sum == 30;
}

// ---------------------------------------------------------------------------
// Async with conditional logic
// ---------------------------------------------------------------------------

async fn conditional_async(flag: boolean) -> number {
    if flag {
        return 100;
    }
    return 0;
}

test "async_adv: conditional true" {
    let f = conditional_async(true);
    assert await f == 100;
}

test "async_adv: conditional false" {
    let f = conditional_async(false);
    assert await f == 0;
}

// ---------------------------------------------------------------------------
// Async with struct return
// ---------------------------------------------------------------------------

struct AsyncResult {
    value: number;
    label: string;
}

async fn compute_with_label(v: number, l: string) -> AsyncResult {
    return AsyncResult { value: v * 2, label: l };
}

test "async_adv: struct return" {
    let f = compute_with_label(21, "answer");
    let r = await f;
    assert r.value == 42;
    assert r.label == "answer";
}

// ---------------------------------------------------------------------------
// Sequential await pattern
// ---------------------------------------------------------------------------

async fn step1() -> number {
    return 5;
}

async fn step2(input: number) -> number {
    return input * 3;
}

async fn step3(input: number) -> number {
    return input + 10;
}

test "async_adv: sequential steps" {
    let f1 = step1();
    let v1 = await f1;

    let f2 = step2(v1);
    let v2 = await f2;

    let f3 = step3(v2);
    let v3 = await f3;

    assert v3 == 25;
}
