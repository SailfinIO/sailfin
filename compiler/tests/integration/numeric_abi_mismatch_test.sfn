// Slice E.1.5 (#528, relaxed by #550): regression coverage for the ABI
// primitive kind diagnostic. Exercises both `numeric_type_kind` (the
// helper in `type_mapping.sfn`) and `coerce_operand_to_type`'s
// boundary-mode behaviour on int↔float coercion.
//
// During the Slice E.2 source migration window the boundary-mode
// kind check emits a `[warning]` diagnostic and falls through to silent
// `round + fptosi` widening. The fatal refusal landed in #528 was
// downgraded by #550 — the cluster-internal boundary turned out to span
// all of `compiler/src/llvm/` and could not be flipped atomically, so
// the diagnostic provides visibility without aborting emission. Slice
// E.3 (#490) re-promotes the diagnostic to `[fatal]` symmetrically once
// every `: number` site has migrated.  // alias-coverage: numeric migration coverage
import { coerce_operand_to_type, harmonise_operands } from "../../src/llvm/expression_lowering/native/core_operands";
import { numeric_type_kind } from "../../src/llvm/type_mapping";
import { LLVMOperand } from "../../src/llvm/types";

// -------------------------------------------------------------------
// Helper classification
// -------------------------------------------------------------------
test "numeric_type_kind: classifies signed integer LLVM types as int" {
    assert numeric_type_kind("i64") == "int";
    assert numeric_type_kind("i32") == "int";
    assert numeric_type_kind("i16") == "int";
    assert numeric_type_kind("i8") == "int";
}

test "numeric_type_kind: classifies floating-point LLVM types as float" {
    assert numeric_type_kind("double") == "float";
    assert numeric_type_kind("float") == "float";
}

test "numeric_type_kind: classifies non-numeric scalars and aggregates as other" {
    // Booleans deliberately fall outside the int/float partition — the
    // existing tree relies on silent i1 ↔ double widening in arithmetic
    // harmonisation and bool-to-string interpolation; classifying them as
    // `int` would cause spurious diagnostics on today's source.
    assert numeric_type_kind("i1") == "other";
    assert numeric_type_kind("i8*") == "other";
    assert numeric_type_kind("{i8*, i64}") == "other";
    assert numeric_type_kind("%MyStruct*") == "other";
    assert numeric_type_kind("void") == "other";
    assert numeric_type_kind("") == "other";
}

// -------------------------------------------------------------------
// `coerce_operand_to_type` strict mode (allow_widen = false)
// -------------------------------------------------------------------
fn _make_operand(llvm_type: string, value: string) -> LLVMOperand {
    return LLVMOperand { llvm_type: llvm_type, value: value };
}

test "coerce_operand_to_type: warns + silently widens double → i64 in boundary mode" ![io] {
    let operand = _make_operand("double", "%t0");
    let mut lines: string[] = [];
    let result = coerce_operand_to_type(operand, "i64", 0, lines, false, null);
    // #550: the kind-check now logs a warning and falls through to
    // `round + fptosi`. Coercion succeeds with a non-null operand and
    // the i64 LLVM type. The fatal refusal returns in #490 once Slice
    // E.2 completes the source migration.
    assert result.operand != null;
    assert result.operand.llvm_type == "i64";
    // The diagnostic carries the `[warning]` tag — NOT `[fatal]` —
    // so `has_fatal_lowering_diagnostic` (lowering_core.sfn:294) does
    // not trip and emission continues.
    let mut found_warning = false;
    let mut found_fatal = false;
    let mut i: number = 0;  // alias-coverage: numeric migration coverage
    loop {
        if i >= result.diagnostics.length { break; }
        let diag = result.diagnostics[i];
        let mut _has_warning = false;
        let mut _has_fatal = false;
        let mut _has_double = false;
        let mut _has_i64 = false;
        let mut j: number = 0;  // alias-coverage: numeric migration coverage
        loop {
            if j + 9 > diag.length { break; }
            if substring(diag, j, j + 9) == "[warning]" { _has_warning = true; }
            j += 1;
        }
        j = 0;
        loop {
            if j + 7 > diag.length { break; }
            if substring(diag, j, j + 7) == "[fatal]" { _has_fatal = true; }
            j += 1;
        }
        j = 0;
        loop {
            if j + 6 > diag.length { break; }
            if substring(diag, j, j + 6) == "double" { _has_double = true; }
            j += 1;
        }
        j = 0;
        loop {
            if j + 3 > diag.length { break; }
            if substring(diag, j, j + 3) == "i64" { _has_i64 = true; }
            j += 1;
        }
        if _has_warning {
            if _has_double {
                if _has_i64 { found_warning = true; }
            }
        }
        if _has_fatal { found_fatal = true; }
        i += 1;
    }
    assert found_warning;
    assert ! found_fatal;
}

test "coerce_operand_to_type: keeps i64 → double silent in this slice" ![io] {
    // Slice E.1.5 (#528) is asymmetric: only `float → int` is rejected at
    // boundaries that don't opt in to widening, because every existing
    // `arr.length`-into-`:number` callsite in the compiler source relies
    // on the reverse direction widening silently. Slice E.3 (#490)
    // tightens the check to symmetric once the migration completes.
    let operand = _make_operand("i64", "%t1");
    let mut lines: string[] = [];
    let result = coerce_operand_to_type(operand, "double", 0, lines, false, null);
    assert result.operand != null;
}

// -------------------------------------------------------------------
// `coerce_operand_to_type` permissive mode (allow_widen = true)
// -------------------------------------------------------------------
test "coerce_operand_to_type: silently widens i64 → double when widening is allowed" ![io] {
    let operand = _make_operand("i64", "%t2");
    let mut lines: string[] = [];
    let result = coerce_operand_to_type(operand, "double", 0, lines, true, null);
    // Existing behaviour (sitofp) preserved for arithmetic harmonisation
    // and the explicit `arr.push(...)` value-shape adjust.
    assert result.operand != null;
}

test "coerce_operand_to_type: silently coerces double → i64 when widening is allowed" ![io] {
    let operand = _make_operand("double", "%t3");
    let mut lines: string[] = [];
    let result = coerce_operand_to_type(operand, "i64", 0, lines, true, null);
    assert result.operand != null;
}

// -------------------------------------------------------------------
// Temp-index recovery across module boundaries (#543)
// -------------------------------------------------------------------
test "coerce_operand_to_type: recovers temp_index from existing emitted lines" ![io] {
    let operand = _make_operand("i64", "%t1");
    let mut lines: string[] = [];
    lines.push("  %t0 = add i64 1, 2");
    lines.push("  %t1 = add i64 %t0, 3");

    let result = coerce_operand_to_type(operand, "i64", 0, lines, false);

    assert result.operand != null;
    assert result.temp_index == 2;
}

test "harmonise_operands: recovers temp_index from existing emitted lines" {
    let left = _make_operand("i64", "%t0");
    let right = _make_operand("i64", "%t1");
    let mut lines: string[] = [];
    lines.push("  %t0 = add i64 1, 2");
    lines.push("  %t1 = add i64 %t0, 3");

    let result = harmonise_operands(left, right, 0, lines);

    assert result.left != null;
    assert result.right != null;
    assert result.temp_index == 2;
}

// -------------------------------------------------------------------
// Equal-type fast path
// -------------------------------------------------------------------
test "coerce_operand_to_type: same-type passthrough is a no-op in strict mode" ![io] {
    let operand = _make_operand("i64", "%t4");
    let mut lines: string[] = [];
    let result = coerce_operand_to_type(operand, "i64", 0, lines, false, null);
    assert result.operand != null;
    assert result.diagnostics.length == 0;
}

// -------------------------------------------------------------------
// `other`-kind exemption (pointers, aggregates, booleans)
// -------------------------------------------------------------------
test "coerce_operand_to_type: i1 → double bypasses the strict diagnostic" ![io] {
    // Boolean → double widening is common today (interpolation, print,
    // arithmetic harmonisation). The kind check classifies `i1` as `other`
    // to keep this path silent until Slice E.3 (#490) tightens it.
    let operand = _make_operand("i1", "%t5");
    let mut lines: string[] = [];
    let result = coerce_operand_to_type(operand, "double", 0, lines, false, null);
    assert result.operand != null;
}
