async fn computeTask1() -> number {
    return 21;
}

async fn computeTask2() -> number {
    return 21;
}

test "async: await futures" {
    let future1 = computeTask1();
    let future2 = computeTask2();

    let result1 = await future1;
    let result2 = await future2;

    assert result1 + result2 == 42;
}
