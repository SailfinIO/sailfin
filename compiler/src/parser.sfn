// compiler/src/parser.sfn
//
// Initial Sailfin-native parser that recognises a pragmatic subset of the
// language. The goal is to mirror the bootstrap parser for common top-level
// declarations so later phases can consume a structured AST when running in
// Sailfin.

import { lex } from "./lexer";
import { Token } from "./token";
import {
    Block,
    Decorator,
    Expression,
    FieldDeclaration,
    FunctionSignature,
    EnumVariant,
    MethodDeclaration,
    ModelDeclaration,
    ModelProperty,
    Parameter,
    PipelineDeclaration,
    Program,
    Statement,
    TypeParameter,
    TestDeclaration,
    TypeAnnotation,
    ToolDeclaration,
    WithClause,
} from "./ast";
import { evaluate_decorators, infer_effects } from "./decorator_semantics";

struct Parser {
    tokens -> Token[];
    index -> number;
}

struct StatementParseResult {
    parser -> Parser;
    statement -> Statement;
}

struct ParameterParseResult {
    parser -> Parser;
    parameter -> Parameter;
}

struct ParameterListParseResult {
    parser -> Parser;
    parameters -> Parameter[];
}

struct StructFieldParseResult {
    parser -> Parser;
    field -> FieldDeclaration?;
    success -> boolean;
}

struct ModelPropertyParseResult {
    parser -> Parser;
    property -> ModelProperty?;
    success -> boolean;
}

struct MethodParseResult {
    parser -> Parser;
    method -> MethodDeclaration?;
    success -> boolean;
}

struct InterfaceMemberParseResult {
    parser -> Parser;
    signature -> FunctionSignature?;
    success -> boolean;
}

struct EnumVariantParseResult {
    parser -> Parser;
    variant -> EnumVariant?;
    success -> boolean;
}

struct TypeParameterParseResult {
    parser -> Parser;
    parameters -> TypeParameter[];
}

struct ImplementsParseResult {
    parser -> Parser;
    types -> TypeAnnotation[];
    found -> boolean;
}

struct DecoratorParseResult {
    parser -> Parser;
    decorators -> Decorator[];
}

struct BlockStatementParseResult {
    parser -> Parser;
    statement -> Statement?;
    success -> boolean;
}

struct ParenthesizedParseResult {
    parser -> Parser;
    tokens -> Token[];
    success -> boolean;
}

struct CaptureResult {
    parser -> Parser;
    tokens -> Token[];
}

struct EffectParseResult {
    parser -> Parser;
    effects -> string[];
}

struct BlockParseResult {
    parser -> Parser;
    block -> Block;
}

fn parse_program(source -> string) -> Program {
    let tokens = lex(source);
    return parse_tokens(tokens);
}

fn parse_tokens(tokens -> Token[]) -> Program {
    let mut parser -> Parser = Parser { tokens: tokens, index: 0 };
    let mut statements -> Statement[] = [];
    parser = skip_trivia(parser);

    loop {
        let token = parser_peek_raw(parser);
        if token.kind.variant == "EndOfFile" {
            break;
        }

        let result = parse_statement(parser);
        parser = result.parser;
        statements = append_statement(statements, result.statement);
        parser = skip_trivia(parser);
    }

    return Program { statements: statements };
}

fn parse_statement(parser -> Parser) -> StatementParseResult {
    let original = parser;
    parser = skip_trivia(parser);

    let decorator_result = parse_decorators(parser);
    parser = decorator_result.parser;
    let decorators = decorator_result.decorators;

    parser = skip_trivia(parser);
    let token = parser_peek_raw(parser);

    if identifier_matches(token, "import") {
        if decorators.length > 0 {
            return parse_unknown(original);
        }
        return parse_import(parser);
    }
    if identifier_matches(token, "let") {
        if decorators.length > 0 {
            return parse_unknown(original);
        }
        return parse_variable(parser);
    }
    if identifier_matches(token, "const") {
        if decorators.length > 0 {
            return parse_unknown(original);
        }
        return parse_constant(parser);
    }
    if identifier_matches(token, "model") {
        if decorators.length > 0 {
            return parse_unknown(original);
        }
        return parse_model(parser, decorators);
    }
    if identifier_matches(token, "pipeline") {
        if decorators.length > 0 {
            return parse_unknown(original);
        }
        return parse_pipeline(parser, decorators);
    }
    if identifier_matches(token, "tool") {
        if decorators.length > 0 {
            return parse_unknown(original);
        }
        return parse_tool(parser, decorators);
    }
    if identifier_matches(token, "test") {
        if decorators.length > 0 {
            return parse_unknown(original);
        }
        return parse_test(parser, decorators);
    }
    if identifier_matches(token, "fn") {
        return parse_function(parser, false, decorators);
    }
    if identifier_matches(token, "async") {
        let lookahead = skip_trivia(parser_advance_raw(parser));
        let after = parser_peek_raw(lookahead);
        if identifier_matches(after, "fn") {
            return parse_function(parser, true, decorators);
        }
    }
    if identifier_matches(token, "struct") {
        return parse_struct(parser, decorators);
    }
    if identifier_matches(token, "type") {
        return parse_type_alias(parser, decorators);
    }
    if identifier_matches(token, "interface") {
        return parse_interface(parser, decorators);
    }
    if identifier_matches(token, "enum") {
        return parse_enum(parser, decorators);
    }

    if decorators.length > 0 {
        return parse_unknown(original);
    }

    return parse_unknown(parser);
}

fn parse_import(parser -> Parser) -> StatementParseResult {
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "import");
    parser = skip_trivia(parser);
    parser = consume_symbol(parser, "{");

    let mut items -> string[] = [];
    parser = skip_trivia(parser);
    loop {
        let current = parser_peek_raw(parser);
        if current.kind.variant == "Symbol" && current.kind.value == "}" {
            parser = parser_advance_raw(parser);
            break;
        }
        if current.kind.variant != "Identifier" {
            break;
        }
        let item = identifier_text(current);
        items = append_string(items, item);
        parser = parser_advance_raw(parser);
        parser = skip_trivia(parser);
        let separator = parser_peek_raw(parser);
        if separator.kind.variant == "Symbol" && separator.kind.value == "," {
            parser = parser_advance_raw(parser);
            parser = skip_trivia(parser);
            continue;
        }
    }

    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "from");

    parser = skip_trivia(parser);
    let capture = collect_until(parser, [";"]);
    parser = capture.parser;
    let mut source = trim_text(tokens_to_text(capture.tokens));
    source = strip_surrounding_quotes(source);

    parser = skip_trivia(parser);
    if parser_peek_raw(parser).kind.variant == "Symbol" && parser_peek_raw(parser).kind.value == ";" {
        parser = parser_advance_raw(parser);
    }

    let statement = Statement.ImportDeclaration {
        items: items,
        source: source,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_variable(parser -> Parser) -> StatementParseResult {
    return parse_variable_like(parser, false);
}

fn parse_constant(parser -> Parser) -> StatementParseResult {
    return parse_variable_like(parser, true);
}

fn parse_struct(parser -> Parser, decorators -> Decorator[]) -> StatementParseResult {
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "struct");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    let implements_result = parse_implements_clause(parser);
    parser = implements_result.parser;
    let mut implements_types = implements_result.types;

    parser = skip_trivia(parser);
    parser = advance_to_symbol(parser, "{");
    parser = consume_symbol(parser, "{");

    let mut fields -> FieldDeclaration[] = [];
    let mut methods -> MethodDeclaration[] = [];

    loop {
        parser = skip_trivia(parser);
        let member_start = parser;

        let decorator_result = parse_decorators(parser);
        parser = decorator_result.parser;
        let member_decorators = decorator_result.decorators;

        parser = skip_trivia(parser);
        let token = parser_peek_raw(parser);
        if token.kind.variant == "Symbol" && token.kind.value == "}" {
            parser = parser_advance_raw(parser);
            break;
        }
        if token.kind.variant == "EndOfFile" {
            break;
        }

        let field_result = parse_struct_field(parser);
        if field_result.success && member_decorators.length == 0 {
            if field_result.field != null {
                fields = append_field(fields, field_result.field);
            }
            parser = field_result.parser;
            continue;
        }

        let method_result = parse_struct_method(parser, member_decorators);
        if method_result.success {
            if method_result.method != null {
                methods = append_method(methods, method_result.method);
            }
            parser = method_result.parser;
            continue;
        }

        parser = skip_struct_member(member_start);
    }

    let statement = Statement.StructDeclaration {
        name: name,
        type_parameters: type_parameters,
        implements_types: implements_types,
        fields: fields,
        methods: methods,
        decorators: decorators,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_type_alias(parser -> Parser, decorators -> Decorator[]) -> StatementParseResult {
    let original = parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "type");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    if name_token.kind.variant != "Identifier" {
        return parse_unknown(original);
    }
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    parser = skip_trivia(parser);
    let equals = parser_peek_raw(parser);
    if !(equals.kind.variant == "Symbol" && equals.kind.value == "=") {
        return parse_unknown(original);
    }
    parser = parser_advance_raw(parser);

    let capture = collect_until(skip_trivia(parser), [";"]);
    parser = capture.parser;
    let aliased_text = trim_text(tokens_to_text(capture.tokens));
    if aliased_text.length == 0 {
        return parse_unknown(original);
    }
    let aliased_type = TypeAnnotation { text: aliased_text };

    parser = skip_trivia(parser);
    if parser_peek_raw(parser).kind.variant == "Symbol" && parser_peek_raw(parser).kind.value == ";" {
        parser = parser_advance_raw(parser);
    }

    let statement = Statement.TypeAliasDeclaration {
        name: name,
        type_parameters: type_parameters,
        aliased_type: aliased_type,
        decorators: decorators,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_interface(parser -> Parser, decorators -> Decorator[]) -> StatementParseResult {
    let original = parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "interface");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    if name_token.kind.variant != "Identifier" {
        return parse_unknown(original);
    }
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    parser = skip_trivia(parser);
    parser = advance_to_symbol(parser, "{");
    parser = consume_symbol(parser, "{");

    let mut members -> FunctionSignature[] = [];
    loop {
        parser = skip_trivia(parser);
        let token = parser_peek_raw(parser);
        if token.kind.variant == "Symbol" && token.kind.value == "}" {
            parser = parser_advance_raw(parser);
            break;
        }
        if token.kind.variant == "EndOfFile" {
            break;
        }

        let member_start = parser;
        let decorator_result = parse_decorators(parser);
        parser = decorator_result.parser;
        let member_decorators = decorator_result.decorators;

        parser = skip_trivia(parser);
        let member_result = parse_interface_member(parser, member_decorators);
        if member_result.success {
            parser = member_result.parser;
            if member_result.signature != null {
                members = append_signature(members, member_result.signature);
            }
            continue;
        }

        parser = skip_struct_member(member_start);
    }

    let statement = Statement.InterfaceDeclaration {
        name: name,
        type_parameters: type_parameters,
        members: members,
        decorators: decorators,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_enum(parser -> Parser, decorators -> Decorator[]) -> StatementParseResult {
    let original = parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "enum");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    if name_token.kind.variant != "Identifier" {
        return parse_unknown(original);
    }
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    parser = skip_trivia(parser);
    parser = advance_to_symbol(parser, "{");
    parser = consume_symbol(parser, "{");

    let mut variants -> EnumVariant[] = [];
    loop {
        parser = skip_trivia(parser);
        let token = parser_peek_raw(parser);
        if token.kind.variant == "Symbol" && token.kind.value == "}" {
            parser = parser_advance_raw(parser);
            break;
        }
        if token.kind.variant == "EndOfFile" {
            break;
        }

        let variant_result = parse_enum_variant(parser);
        if variant_result.success {
            parser = variant_result.parser;
            if variant_result.variant != null {
                variants = append_enum_variant(variants, variant_result.variant);
            }
            parser = skip_trailing_comma(parser);
            continue;
        }

        parser = skip_struct_member(parser);
    }

    let statement = Statement.EnumDeclaration {
        name: name,
        type_parameters: type_parameters,
        variants: variants,
        decorators: decorators,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_interface_member(parser -> Parser, decorators -> Decorator[]) -> InterfaceMemberParseResult {
    let original = parser;
    let mut current = skip_trivia(parser);

    let mut is_async = false;
    let peek = parser_peek_raw(current);
    if identifier_matches(peek, "async") {
        let lookahead = skip_trivia(parser_advance_raw(current));
        if identifier_matches(parser_peek_raw(lookahead), "fn") {
            current = consume_keyword(current, "async");
            is_async = true;
        }
    }

    current = skip_trivia(current);
    if !identifier_matches(parser_peek_raw(current), "fn") {
        return InterfaceMemberParseResult { parser: original, signature: null, success: false };
    }
    current = consume_keyword(current, "fn");

    current = skip_trivia(current);
    let name_token = parser_peek_raw(current);
    if name_token.kind.variant != "Identifier" {
        return InterfaceMemberParseResult { parser: original, signature: null, success: false };
    }
    let name = identifier_text(name_token);
    current = parser_advance_raw(current);

    let type_param_result = parse_type_parameter_clause(current);
    current = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    current = skip_trivia(current);
    current = consume_symbol(current, "(");
    let parameter_result = parse_parameter_list(current);
    current = parameter_result.parser;
    let parameters = parameter_result.parameters;

    current = skip_trivia(current);
    let mut return_type -> TypeAnnotation? = null;
    let separator = parser_peek_raw(current);
    if separator.kind.variant == "Symbol" && (separator.kind.value == ":" || separator.kind.value == "->") {
        current = parser_advance_raw(current);
        let capture = collect_until(skip_trivia(current), ["!", ";", "{" ]);
        current = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            return_type = TypeAnnotation { text: text };
        }
    }

    let effect_result = parse_effect_list(current);
    current = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let decorator_info = evaluate_decorators(decorators);
    let inferred_effects = infer_effects(parsed_effects, decorator_info);

    current = skip_trivia(current);
    if current.index < current.tokens.length {
        let terminator = parser_peek_raw(current);
        if terminator.kind.variant == "Symbol" && terminator.kind.value == ";" {
            current = parser_advance_raw(current);
        }
    }

    let signature = FunctionSignature {
        name: name,
        is_async: is_async,
        parameters: parameters,
        return_type: return_type,
        effects: inferred_effects,
        type_parameters: type_parameters,
    };

    return InterfaceMemberParseResult {
        parser: current,
        signature: signature,
        success: true,
    };
}

fn parse_enum_variant(parser -> Parser) -> EnumVariantParseResult {
    let original = parser;
    let mut current = skip_trivia(parser);
    let name_token = parser_peek_raw(current);
    if name_token.kind.variant != "Identifier" {
        return EnumVariantParseResult { parser: original, variant: null, success: false };
    }
    let name = identifier_text(name_token);
    current = parser_advance_raw(current);

    let mut fields -> FieldDeclaration[] = [];
    current = skip_trivia(current);
    let next = parser_peek_raw(current);
    if next.kind.variant == "Symbol" && next.kind.value == "{" {
        current = parser_advance_raw(current);
        loop {
            current = skip_trivia(current);
            let token = parser_peek_raw(current);
            if token.kind.variant == "Symbol" && token.kind.value == "}" {
                current = parser_advance_raw(current);
                break;
            }
            if token.kind.variant == "EndOfFile" {
                break;
            }

            let field_result = parse_struct_field(current);
            if field_result.success {
                current = field_result.parser;
                if field_result.field != null {
                    fields = append_field(fields, field_result.field);
                }
                continue;
            }

            current = skip_struct_member(current);
        }
    }

    current = skip_trivia(current);
    let mut terminator = parser_peek_raw(current);
    if terminator.kind.variant == "Symbol" && terminator.kind.value == ";" {
        current = parser_advance_raw(current);
        current = skip_trivia(current);
        terminator = parser_peek_raw(current);
    }

    let variant = EnumVariant {
        name: name,
        fields: fields,
    };

    return EnumVariantParseResult {
        parser: current,
        variant: variant,
        success: true,
    };
}

fn skip_trailing_comma(parser -> Parser) -> Parser {
    let mut current = skip_trivia(parser);
    let token = parser_peek_raw(current);
    if token.kind.variant == "Symbol" && token.kind.value == "," {
        current = parser_advance_raw(current);
    }
    return current;
}

fn parse_model(parser -> Parser, decorators -> Decorator[]) -> StatementParseResult {
    let original = parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "model");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    parser = skip_trivia(parser);
    parser = advance_to_symbol(parser, ":");
    parser = consume_symbol(parser, ":");

    let type_capture = collect_until(skip_trivia(parser), ["!", "{"]);
    parser = type_capture.parser;
    let type_text = trim_text(tokens_to_text(type_capture.tokens));
    if type_text.length == 0 {
        return parse_unknown(original);
    }
    let model_type = TypeAnnotation { text: type_text };

    let effect_result = parse_effect_list(parser);
    parser = effect_result.parser;
    let effects = effect_result.effects;

    parser = skip_trivia(parser);
    parser = advance_to_symbol(parser, "{");
    parser = consume_symbol(parser, "{");

    let mut properties -> ModelProperty[] = [];
    loop {
        parser = skip_trivia(parser);
        let token = parser_peek_raw(parser);
        if token.kind.variant == "Symbol" && token.kind.value == "}" {
            parser = parser_advance_raw(parser);
            break;
        }
        if token.kind.variant == "EndOfFile" {
            break;
        }

        let entry_start = parser;
        let property_result = parse_model_property(parser);
        if property_result.success && property_result.property != null {
            parser = property_result.parser;
            properties = append_model_property(properties, property_result.property);
            continue;
        }

        parser = skip_struct_member(entry_start);
        parser = skip_trivia(parser);
        let maybe_close = parser_peek_raw(parser);
        if maybe_close.kind.variant == "Symbol" && maybe_close.kind.value == "}" {
            parser = parser_advance_raw(parser);
            break;
        }
        if maybe_close.kind.variant == "EndOfFile" {
            break;
        }
    }

    let statement = Statement.ModelDeclaration {
        name: name,
        model_type: model_type,
        properties: properties,
        effects: effects,
        decorators: decorators,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_pipeline(parser -> Parser, decorators -> Decorator[]) -> StatementParseResult {
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "pipeline");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    parser = skip_trivia(parser);
    parser = consume_symbol(parser, "(");
    let parameter_result = parse_parameter_list(parser);
    parser = parameter_result.parser;
    let parameters = parameter_result.parameters;

    parser = skip_trivia(parser);
    let mut return_type -> TypeAnnotation? = null;
    let separator = parser_peek_raw(parser);
    if separator.kind.variant == "Symbol" && (separator.kind.value == ":" || separator.kind.value == "->") {
        parser = parser_advance_raw(parser);
        let capture = collect_until(skip_trivia(parser), ["!", "{"]);
        parser = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            return_type = TypeAnnotation { text: text };
        }
    }

    let effect_result = parse_effect_list(parser);
    parser = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let decorator_info = evaluate_decorators(decorators);
    let inferred_effects = infer_effects(parsed_effects, decorator_info);

    let block_result = parse_block(parser);
    parser = block_result.parser;
    let body = block_result.block;

    let signature = FunctionSignature {
        name: name,
        is_async: false,
        parameters: parameters,
        return_type: return_type,
        effects: inferred_effects,
        type_parameters: [],
    };

    let statement = Statement.PipelineDeclaration {
        signature: signature,
        body: body,
        decorators: decorators,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_tool(parser -> Parser, decorators -> Decorator[]) -> StatementParseResult {
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "tool");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    parser = skip_trivia(parser);
    parser = consume_symbol(parser, "(");
    let parameter_result = parse_parameter_list(parser);
    parser = parameter_result.parser;
    let parameters = parameter_result.parameters;

    parser = skip_trivia(parser);
    let mut return_type -> TypeAnnotation? = null;
    let separator = parser_peek_raw(parser);
    if separator.kind.variant == "Symbol" && (separator.kind.value == ":" || separator.kind.value == "->") {
        parser = parser_advance_raw(parser);
        let capture = collect_until(skip_trivia(parser), ["!", "{"]);
        parser = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            return_type = TypeAnnotation { text: text };
        }
    }

    let effect_result = parse_effect_list(parser);
    parser = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let decorator_info = evaluate_decorators(decorators);
    let inferred_effects = infer_effects(parsed_effects, decorator_info);

    let block_result = parse_block(parser);
    parser = block_result.parser;
    let body = block_result.block;

    let signature = FunctionSignature {
        name: name,
        is_async: false,
        parameters: parameters,
        return_type: return_type,
        effects: inferred_effects,
        type_parameters: [],
    };

    let statement = Statement.ToolDeclaration {
        signature: signature,
        body: body,
        decorators: decorators,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_test(parser -> Parser, decorators -> Decorator[]) -> StatementParseResult {
    let original = parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "test");

    let name_capture = collect_until(skip_trivia(parser), ["!", "{"]);
    parser = name_capture.parser;
    let name_text = trim_text(tokens_to_text(name_capture.tokens));
    if name_text.length == 0 {
        return parse_unknown(original);
    }
    let name = normalize_test_name(name_text);

    let effect_result = parse_effect_list(parser);
    parser = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let decorator_info = evaluate_decorators(decorators);
    let inferred_effects = infer_effects(parsed_effects, decorator_info);

    let block_result = parse_block(parser);
    parser = block_result.parser;
    let body = block_result.block;

    let statement = Statement.TestDeclaration {
        name: name,
        body: body,
        effects: inferred_effects,
        decorators: decorators,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_variable_like(parser -> Parser, is_const -> boolean) -> StatementParseResult {
    parser = skip_trivia(parser);
    if is_const {
        parser = consume_keyword(parser, "const");
    } else {
        parser = consume_keyword(parser, "let");
    }

    let mut mutable_flag = false;
    if !is_const {
        let look = skip_trivia(parser);
        let token = parser_peek_raw(look);
        if identifier_matches(token, "mut") {
            parser = skip_trivia(parser);
            parser = consume_keyword(parser, "mut");
            mutable_flag = true;
        }
    }

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    let mut type_annotation -> TypeAnnotation? = null;
    parser = skip_trivia(parser);
    let separator = parser_peek_raw(parser);
    if separator.kind.variant == "Symbol" && (separator.kind.value == ":" || separator.kind.value == "->") {
        parser = parser_advance_raw(parser);
        let capture = collect_until(skip_trivia(parser), select_type_terminators(is_const));
        parser = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            type_annotation = TypeAnnotation { text: text };
        }
    }

    let mut initializer -> Expression? = null;
    parser = skip_trivia(parser);
    let assign = parser_peek_raw(parser);
    if assign.kind.variant == "Symbol" && assign.kind.value == "=" {
        parser = parser_advance_raw(parser);
        let capture = collect_until(skip_trivia(parser), [";"]);
        parser = capture.parser;
        let expression = expression_from_tokens(capture.tokens);
        initializer = expression;
    } else if is_const {
        initializer = Expression.Raw { text: "" };
    }

    parser = skip_trivia(parser);
    if parser_peek_raw(parser).kind.variant == "Symbol" && parser_peek_raw(parser).kind.value == ";" {
        parser = parser_advance_raw(parser);
    }

    if is_const {
        let statement = Statement.ConstantDeclaration {
            name: name,
            type_annotation: type_annotation,
            initializer: initializer,
        };
        return StatementParseResult { parser: parser, statement: statement };
    }

    let statement = Statement.VariableDeclaration {
        name: name,
        mutable: mutable_flag,
        type_annotation: type_annotation,
        initializer: initializer,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_function(parser -> Parser, starts_with_async -> boolean, decorators -> Decorator[]) -> StatementParseResult {
    parser = skip_trivia(parser);
    let mut is_async = false;
    if starts_with_async {
        parser = consume_keyword(parser, "async");
        is_async = true;
    } else {
        let look = parser_peek_raw(parser);
        if identifier_matches(look, "async") {
            let lookahead = skip_trivia(parser_advance_raw(parser));
            let next = parser_peek_raw(lookahead);
            if identifier_matches(next, "fn") {
                parser = consume_keyword(parser, "async");
                parser = skip_trivia(parser);
                is_async = true;
            }
        }
    }

    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "fn");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    parser = skip_trivia(parser);
    parser = consume_symbol(parser, "(");
    let parameter_result = parse_parameter_list(parser);
    parser = parameter_result.parser;
    let parameters = parameter_result.parameters;

    parser = skip_trivia(parser);
    let mut return_type -> TypeAnnotation? = null;
    let separator = parser_peek_raw(parser);
    if separator.kind.variant == "Symbol" && (separator.kind.value == ":" || separator.kind.value == "->") {
        parser = parser_advance_raw(parser);
        let capture = collect_until(skip_trivia(parser), ["!", "{"]);
        parser = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            return_type = TypeAnnotation { text: text };
        }
    }

    let effect_result = parse_effect_list(parser);
    parser = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let decorator_info = evaluate_decorators(decorators);
    let inferred_effects = infer_effects(parsed_effects, decorator_info);

    let block_result = parse_block(parser);
    parser = block_result.parser;
    let body = block_result.block;

    let signature = FunctionSignature {
        name: name,
        is_async: is_async,
        parameters: parameters,
        return_type: return_type,
        effects: inferred_effects,
        type_parameters: type_parameters,
    };

    let statement = Statement.FunctionDeclaration {
        signature: signature,
        body: body,
        decorators: decorators,
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_parameter_list(parser -> Parser) -> ParameterListParseResult {
    parser = skip_trivia(parser);
    let mut parameters -> Parameter[] = [];

    let token = parser_peek_raw(parser);
    if token.kind.variant == "Symbol" && token.kind.value == ")" {
        parser = parser_advance_raw(parser);
        return ParameterListParseResult { parser: parser, parameters: parameters };
    }

    loop {
        let param_result = parse_single_parameter(parser);
        parser = param_result.parser;
        parameters = append_parameter(parameters, param_result.parameter);
        parser = skip_trivia(parser);
        let separator = parser_peek_raw(parser);
        if separator.kind.variant == "Symbol" && separator.kind.value == "," {
            parser = parser_advance_raw(parser);
            parser = skip_trivia(parser);
            continue;
        }
        if separator.kind.variant == "Symbol" && separator.kind.value == ")" {
            parser = parser_advance_raw(parser);
            break;
        }
        if separator.kind.variant == "EndOfFile" {
            break;
        }
    }

    return ParameterListParseResult { parser: parser, parameters: parameters };
}

fn parse_struct_field(parser -> Parser) -> StructFieldParseResult {
    let mut current = skip_trivia(parser);

    let mut is_mutable = false;
    let token = parser_peek_raw(current);
    let mut token_to_use = token;
    if identifier_matches(token_to_use, "mut") {
        current = parser_advance_raw(current);
        is_mutable = true;
        current = skip_trivia(current);
        token_to_use = parser_peek_raw(current);
    }

    if token_to_use.kind.variant != "Identifier" {
        return StructFieldParseResult { parser: parser, field: null, success: false };
    }

    let name = identifier_text(token_to_use);
    current = parser_advance_raw(current);

    current = skip_trivia(current);
    let separator = parser_peek_raw(current);
    let is_type_sep = separator.kind.variant == "Symbol"
        && (separator.kind.value == ":" || separator.kind.value == "->");
    if !is_type_sep {
        return StructFieldParseResult { parser: parser, field: null, success: false };
    }
    current = parser_advance_raw(current);

    let capture = collect_until(skip_trivia(current), [";"]);
    current = capture.parser;
    let type_text = trim_text(tokens_to_text(capture.tokens));
    if type_text.length == 0 {
        return StructFieldParseResult { parser: parser, field: null, success: false };
    }

    current = skip_trivia(current);
    let terminator = parser_peek_raw(current);
    if !(terminator.kind.variant == "Symbol" && terminator.kind.value == ";") {
        return StructFieldParseResult { parser: parser, field: null, success: false };
    }
    current = parser_advance_raw(current);

    let field = FieldDeclaration {
        name: name,
        type_annotation: TypeAnnotation { text: type_text },
        mutable: is_mutable,
    };

    return StructFieldParseResult {
        parser: current,
        field: field,
        success: true,
    };
}

fn parse_model_property(parser -> Parser) -> ModelPropertyParseResult {
    let mut current = skip_trivia(parser);
    let name_token = parser_peek_raw(current);
    if name_token.kind.variant != "Identifier" {
        return ModelPropertyParseResult { parser: parser, property: null, success: false };
    }
    let name = identifier_text(name_token);
    current = parser_advance_raw(current);

    current = skip_trivia(current);
    let equals = parser_peek_raw(current);
    if !(equals.kind.variant == "Symbol" && equals.kind.value == "=") {
        return ModelPropertyParseResult { parser: parser, property: null, success: false };
    }
    current = parser_advance_raw(current);

    let capture = collect_until(skip_trivia(current), [";"]);
    current = capture.parser;
    let value_expression = expression_from_tokens(capture.tokens);

    current = skip_trivia(current);
    let terminator = parser_peek_raw(current);
    if !(terminator.kind.variant == "Symbol" && terminator.kind.value == ";") {
        return ModelPropertyParseResult { parser: parser, property: null, success: false };
    }
    current = parser_advance_raw(current);

    let property = ModelProperty {
        name: name,
        value: value_expression,
    };

    return ModelPropertyParseResult { parser: current, property: property, success: true };
}

fn parse_struct_method(parser -> Parser, decorators -> Decorator[]) -> MethodParseResult {
    let mut current = skip_trivia(parser);

    let mut is_async = false;
    let peek = parser_peek_raw(current);
    if identifier_matches(peek, "async") {
        let lookahead = skip_trivia(parser_advance_raw(current));
        if identifier_matches(parser_peek_raw(lookahead), "fn") {
            current = consume_keyword(current, "async");
            is_async = true;
        }
    }

    current = skip_trivia(current);
    if !identifier_matches(parser_peek_raw(current), "fn") {
        return MethodParseResult { parser: parser, method: null, success: false };
    }
    current = consume_keyword(current, "fn");

    current = skip_trivia(current);
    let name_token = parser_peek_raw(current);
    if name_token.kind.variant != "Identifier" {
        return MethodParseResult { parser: parser, method: null, success: false };
    }
    let name = identifier_text(name_token);
    current = parser_advance_raw(current);

    let type_param_result = parse_type_parameter_clause(current);
    current = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    current = skip_trivia(current);
    current = consume_symbol(current, "(");
    let parameter_result = parse_parameter_list(current);
    current = parameter_result.parser;
    let parameters = parameter_result.parameters;

    current = skip_trivia(current);
    let mut return_type -> TypeAnnotation? = null;
    let separator = parser_peek_raw(current);
    if separator.kind.variant == "Symbol" && (separator.kind.value == ":" || separator.kind.value == "->") {
        current = parser_advance_raw(current);
        let capture = collect_until(skip_trivia(current), ["!", "{"]);
        current = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            return_type = TypeAnnotation { text: text };
        }
    }

    let effect_result = parse_effect_list(current);
    current = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let decorator_info = evaluate_decorators(decorators);
    let inferred_effects = infer_effects(parsed_effects, decorator_info);

    let block_result = parse_block(current);
    current = block_result.parser;
    let body = block_result.block;

    let signature = FunctionSignature {
        name: name,
        is_async: is_async,
        parameters: parameters,
        return_type: return_type,
        effects: inferred_effects,
        type_parameters: type_parameters,
    };

    let method = MethodDeclaration {
        signature: signature,
        body: body,
        decorators: decorators,
    };

    return MethodParseResult {
        parser: current,
        method: method,
        success: true,
    };
}

fn parse_decorators(parser -> Parser) -> DecoratorParseResult {
    let mut current = parser;
    let mut decorators -> Decorator[] = [];

    loop {
        current = skip_trivia(current);
        let token = parser_peek_raw(current);
        if !(token.kind.variant == "Symbol" && token.kind.value == "@") {
            break;
        }

        let decorator_start = current;
        current = parser_advance_raw(current);
        current = skip_trivia(current);

        let name_token = parser_peek_raw(current);
        if name_token.kind.variant != "Identifier" {
            current = decorator_start;
            break;
        }

        let name = identifier_text(name_token);
        current = parser_advance_raw(current);
        current = skip_trivia(current);

        let mut decorator_arguments -> DecoratorArgument[] = [];
        let after = parser_peek_raw(current);
        if after.kind.variant == "Symbol" && after.kind.value == "(" {
            let paren_result = collect_parenthesized(current);
            if paren_result.success {
                let mut segment_tokens -> Token[] = [];
                let mut angle -> number = 0;
                let mut paren -> number = 0;
                let mut brace -> number = 0;
                let mut bracket -> number = 0;

                let mut index -> number = 0;
                loop {
                    if index >= paren_result.tokens.length {
                        break;
                    }
                    let tok = paren_result.tokens[index];
                    if tok.kind.variant == "Symbol" {
                        let sym = tok.kind.value;
                        if sym == "<" {
                            angle += 1;
                        } else if sym == ">" && angle > 0 {
                            angle -= 1;
                        } else if sym == "(" {
                            paren += 1;
                        } else if sym == ")" && paren > 0 {
                            paren -= 1;
                        } else if sym == "{" {
                            brace += 1;
                        } else if sym == "}" && brace > 0 {
                            brace -= 1;
                        } else if sym == "[" {
                            bracket += 1;
                        } else if sym == "]" && bracket > 0 {
                            bracket -= 1;
                        }

                        let at_top_level = angle == 0 && paren == 0 && brace == 0 && bracket == 0;
                        if sym == "," && at_top_level {
                            let trimmed_tokens = trim_token_edges(segment_tokens);
                            let argument = parse_decorator_argument(trimmed_tokens);
                            if argument != null {
                                decorator_arguments = append_decorator_argument(decorator_arguments, argument);
                            }
                            segment_tokens = [];
                            index += 1;
                            continue;
                        }
                    }
                    segment_tokens = append_token(segment_tokens, tok);
                    index += 1;
                }

                let final_tokens = trim_token_edges(segment_tokens);
                let trailing_argument = parse_decorator_argument(final_tokens);
                if trailing_argument != null {
                    decorator_arguments = append_decorator_argument(decorator_arguments, trailing_argument);
                }
                current = paren_result.parser;
            } else {
                current = decorator_start;
                break;
            }
        }

        decorators = append_decorator(decorators, Decorator { name: name, arguments: decorator_arguments });
    }

    return DecoratorParseResult { parser: current, decorators: decorators };
}

fn parse_type_parameter_clause(parser -> Parser) -> TypeParameterParseResult {
    let mut current = skip_trivia(parser);
    let token = parser_peek_raw(current);
    if !(token.kind.variant == "Symbol" && token.kind.value == "<") {
        return TypeParameterParseResult { parser: parser, parameters: [] };
    }

    current = parser_advance_raw(current);
    let mut collected -> Token[] = [];
    let mut depth -> number = 1;

    loop {
        let tok = parser_peek_raw(current);
        if tok.kind.variant == "EndOfFile" {
            break;
        }
        if tok.kind.variant == "Symbol" {
            let sym = tok.kind.value;
            if sym == "<" {
                depth += 1;
            } else if sym == ">" {
                depth -= 1;
                if depth == 0 {
                    current = parser_advance_raw(current);
                    break;
                }
            }
        }
        collected = append_token(collected, tok);
        current = parser_advance_raw(current);
    }

    let slices = split_token_slices_by_comma(collected);
    let mut parameters -> TypeParameter[] = [];
    let mut index -> number = 0;
    loop {
        if index >= slices.length {
            break;
        }
        let slice_tokens = trim_token_edges(slices[index]);
        if slice_tokens.length > 0 {
            let colon_index = find_top_level_symbol(slice_tokens, ":");
            let mut name_tokens = slice_tokens;
            let mut bound_tokens -> Token[] = [];
            if colon_index != -1 {
                name_tokens = token_slice(slice_tokens, 0, colon_index);
                bound_tokens = token_slice(slice_tokens, colon_index + 1, slice_tokens.length);
            }

            let name_text = trim_text(tokens_to_text(name_tokens));
            if name_text.length > 0 {
                let mut bound -> TypeAnnotation? = null;
                let bound_text = trim_text(tokens_to_text(bound_tokens));
                if bound_tokens.length > 0 && bound_text.length > 0 {
                    bound = TypeAnnotation { text: bound_text };
                }
                parameters = append_type_parameter(parameters, TypeParameter { name: name_text, bound: bound });
            }
        }
        index += 1;
    }

    return TypeParameterParseResult { parser: current, parameters: parameters };
}

fn parse_implements_clause(parser -> Parser) -> ImplementsParseResult {
    let mut current = skip_trivia(parser);
    if !identifier_matches(parser_peek_raw(current), "implements") {
        return ImplementsParseResult { parser: parser, types: [], found: false };
    }

    current = consume_keyword(current, "implements");
    current = skip_trivia(current);

    let capture = collect_until(current, ["{"]);
    current = capture.parser;

    let mut implements_types -> TypeAnnotation[] = [];
    let entries = split_tokens_by_comma(capture.tokens);
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        let text = trim_text(entries[index]);
        if text.length > 0 {
            implements_types = append_type_annotation(implements_types, TypeAnnotation { text: text });
        }
        index += 1;
    }

    return ImplementsParseResult {
        parser: current,
        types: implements_types,
        found: true,
    };
}

fn parse_single_parameter(parser -> Parser) -> ParameterParseResult {
    parser = skip_trivia(parser);

    let mut is_mutable = false;
    let token = parser_peek_raw(parser);
    if identifier_matches(token, "mut") {
        parser = parser_advance_raw(parser);
        is_mutable = true;
    }

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    let mut type_annotation -> TypeAnnotation? = null;
    parser = skip_trivia(parser);
    let separator = parser_peek_raw(parser);
    if separator.kind.variant == "Symbol" && (separator.kind.value == ":" || separator.kind.value == "->") {
        parser = parser_advance_raw(parser);
        let capture = collect_until(skip_trivia(parser), ["=", ",", ")"]);
        parser = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            type_annotation = TypeAnnotation { text: text };
        }
    }

    let mut default_value -> Expression? = null;
    parser = skip_trivia(parser);
    let assign = parser_peek_raw(parser);
    if assign.kind.variant == "Symbol" && assign.kind.value == "=" {
        parser = parser_advance_raw(parser);
        let capture = collect_until(skip_trivia(parser), [",", ")"]);
        parser = capture.parser;
        default_value = expression_from_tokens(capture.tokens);
    }

    let parameter = Parameter {
        name: name,
        type_annotation: type_annotation,
        default_value: default_value,
        mutable: is_mutable,
    };
    return ParameterParseResult { parser: parser, parameter: parameter };
}

fn parse_effect_list(parser -> Parser) -> EffectParseResult {
    parser = skip_trivia(parser);
    let token = parser_peek_raw(parser);
    if !(token.kind.variant == "Symbol" && token.kind.value == "!") {
        return EffectParseResult { parser: parser, effects: [] };
    }

    parser = parser_advance_raw(parser);
    parser = skip_trivia(parser);
    parser = consume_symbol(parser, "[");

    let mut effects -> string[] = [];
    parser = skip_trivia(parser);
    loop {
        let current = parser_peek_raw(parser);
        if current.kind.variant == "Symbol" && current.kind.value == "]" {
            parser = parser_advance_raw(parser);
            break;
        }
        if current.kind.variant == "Identifier" {
            let effect = identifier_text(current);
            effects = append_string(effects, effect);
            parser = parser_advance_raw(parser);
            parser = skip_trivia(parser);
            let separator = parser_peek_raw(parser);
            if separator.kind.variant == "Symbol" && separator.kind.value == "," {
                parser = parser_advance_raw(parser);
                parser = skip_trivia(parser);
                continue;
            }
            continue;
        }
        parser = parser_advance_raw(parser);
        parser = skip_trivia(parser);
    }

    return EffectParseResult { parser: parser, effects: effects };
}

fn parse_block(parser -> Parser) -> BlockParseResult {
    parser = skip_trivia(parser);
    let token = parser_peek_raw(parser);
    if !(token.kind.variant == "Symbol" && token.kind.value == "{") {
        return BlockParseResult {
            parser: parser,
            block: Block { tokens: [], text: "", statements: [] },
        };
    }

    let start_index = parser.index;
    let mut current = parser_advance_raw(parser);
    let mut block_end_index -> number = start_index;
    let mut statements -> Statement[] = [];

    loop {
        current = skip_trivia(current);
        let tok = parser_peek_raw(current);
        if tok.kind.variant == "Symbol" && tok.kind.value == "}" {
            block_end_index = current.index + 1;
            current = parser_advance_raw(current);
            break;
        }
        if tok.kind.variant == "EndOfFile" {
            break;
        }

        let block_result = parse_block_statement(current);
        if block_result.success {
            current = block_result.parser;
            if block_result.statement != null {
                statements = append_statement(statements, block_result.statement);
            }
            continue;
        }

        let before_index = current.index;
        let unknown_result = parse_unknown(current);
        current = unknown_result.parser;
        if unknown_result.statement.variant == "Unknown" {
            statements = append_statement(statements, unknown_result.statement);
        }

        if current.index <= before_index {
            current = parser_advance_raw(current);
        }
    }

    let mut end_index = current.index;
    if block_end_index > start_index {
        end_index = block_end_index;
    }
    let mut block_tokens = token_slice(parser.tokens, start_index, end_index);
    block_tokens = trim_block_tokens(block_tokens);
    let text = tokens_to_text(block_tokens);
    let block = Block { tokens: block_tokens, text: text, statements: statements };
    return BlockParseResult { parser: skip_trivia(current), block: block };
}

fn parse_block_statement(parser -> Parser) -> BlockStatementParseResult {
    let original = parser;
    let decorator_result = parse_decorators(parser);
    let current = decorator_result.parser;
    let decorators = decorator_result.decorators;

    let after_decorators = skip_trivia(current);
    let token = parser_peek_raw(after_decorators);
    if identifier_matches(token, "for") {
        return parse_for_statement(after_decorators, decorators);
    }
    if identifier_matches(token, "if") {
        return parse_if_statement(after_decorators, decorators);
    }
    if identifier_matches(token, "prompt") {
        return parse_prompt_statement(after_decorators, decorators);
    }
    if identifier_matches(token, "with") {
        return parse_with_statement(after_decorators, decorators);
    }
    if identifier_matches(token, "return") {
        if decorators.length > 0 {
            return BlockStatementParseResult { parser: original, statement: null, success: false };
        }
        return parse_return_statement(after_decorators);
    }

    let expression_result = parse_expression_statement(after_decorators, decorators);
    if expression_result.success {
        return expression_result;
    }

    return BlockStatementParseResult { parser: original, statement: null, success: false };
}

fn parse_for_statement(parser -> Parser, decorators -> Decorator[]) -> BlockStatementParseResult {
    let original = parser;
    let mut current = skip_trivia(parser);
    if !identifier_matches(parser_peek_raw(current), "for") {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }
    current = consume_keyword(current, "for");

    let clause_capture = collect_until(skip_trivia(current), ["{"]);
    current = clause_capture.parser;
    let clause_tokens = trim_token_edges(clause_capture.tokens);
    if clause_tokens.length == 0 {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }

    let in_index = find_top_level_identifier(clause_tokens, "in");
    if in_index == -1 {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }

    let target_tokens = trim_token_edges(token_slice(clause_tokens, 0, in_index));
    let iterable_tokens = trim_token_edges(token_slice(clause_tokens, in_index + 1, clause_tokens.length));
    if target_tokens.length == 0 || iterable_tokens.length == 0 {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }

    let target_expression = expression_from_tokens(target_tokens);
    let iterable_expression = expression_from_tokens(iterable_tokens);
    let clause = ForClause {
        target: target_expression,
        iterable: iterable_expression,
        tokens: clause_tokens,
    };

    let body_result = parse_block(current);
    if body_result.block.tokens.length == 0 {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }
    current = body_result.parser;
    let body = body_result.block;

    current = skip_trivia(current);
    let terminator = parser_peek_raw(current);
    if terminator.kind.variant == "Symbol" && terminator.kind.value == ";" {
        current = parser_advance_raw(current);
    }

    let statement = Statement.ForStatement {
        clause: clause,
        body: body,
        decorators: decorators,
    };

    return BlockStatementParseResult {
        parser: current,
        statement: statement,
        success: true,
    };
}

fn parse_if_statement(parser -> Parser, decorators -> Decorator[]) -> BlockStatementParseResult {
    let original = parser;
    let mut current = skip_trivia(parser);
    if !identifier_matches(parser_peek_raw(current), "if") {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }
    current = consume_keyword(current, "if");

    let condition_capture = collect_until(skip_trivia(current), ["{"]);
    current = condition_capture.parser;
    let condition_tokens = trim_token_edges(condition_capture.tokens);
    if condition_tokens.length == 0 {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }
    let condition_expression = expression_from_tokens(condition_tokens);

    let then_result = parse_block(current);
    if then_result.block.tokens.length == 0 {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }
    current = then_result.parser;
    let then_block = then_result.block;

    current = skip_trivia(current);
    let mut else_branch -> ElseBranch? = null;
    if identifier_matches(parser_peek_raw(current), "else") {
        current = consume_keyword(current, "else");
        current = skip_trivia(current);
        let next_token = parser_peek_raw(current);
        if identifier_matches(next_token, "if") {
            let nested_result = parse_if_statement(current, []);
            if !nested_result.success {
                return BlockStatementParseResult { parser: original, statement: null, success: false };
            }
            if nested_result.statement == null {
                return BlockStatementParseResult { parser: original, statement: null, success: false };
            }
            current = nested_result.parser;
            else_branch = ElseBranch { statement: nested_result.statement, body: null };
        } else {
            let else_result = parse_block(current);
            if else_result.block.tokens.length == 0 {
                return BlockStatementParseResult { parser: original, statement: null, success: false };
            }
            current = else_result.parser;
            else_branch = ElseBranch { statement: null, body: else_result.block };
        }

        current = skip_trivia(current);
        let terminator = parser_peek_raw(current);
        if terminator.kind.variant == "Symbol" && terminator.kind.value == ";" {
            current = parser_advance_raw(current);
        }
    }

    let statement = Statement.IfStatement {
        condition: condition_expression,
        then_block: then_block,
        else_branch: else_branch,
        decorators: decorators,
    };

    return BlockStatementParseResult {
        parser: current,
        statement: statement,
        success: true,
    };
}

fn parse_prompt_statement(parser -> Parser, decorators -> Decorator[]) -> BlockStatementParseResult {
    let original = parser;
    let mut current = skip_trivia(parser);
    if !identifier_matches(parser_peek_raw(current), "prompt") {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }
    current = consume_keyword(current, "prompt");

    current = skip_trivia(current);
    let channel_token = parser_peek_raw(current);
    let mut channel -> string = "";
    if channel_token.kind.variant == "Identifier" {
        channel = identifier_text(channel_token);
        current = parser_advance_raw(current);
    } else if channel_token.kind.variant == "StringLiteral" {
        channel = string_literal_value(channel_token);
        current = parser_advance_raw(current);
    } else {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }

    let block_result = parse_block(current);
    if block_result.block.tokens.length == 0 {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }
    current = block_result.parser;
    let body = block_result.block;

    current = skip_trivia(current);
    if parser_peek_raw(current).kind.variant == "Symbol" && parser_peek_raw(current).kind.value == ";" {
        current = parser_advance_raw(current);
    }

    let statement = Statement.PromptStatement {
        channel: channel,
        body: body,
        decorators: decorators,
    };
    return BlockStatementParseResult {
        parser: current,
        statement: statement,
        success: true,
    };
}

fn parse_with_statement(parser -> Parser, decorators -> Decorator[]) -> BlockStatementParseResult {
    let original = parser;
    let mut current = skip_trivia(parser);
    if !identifier_matches(parser_peek_raw(current), "with") {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }
    current = consume_keyword(current, "with");

    let clauses_capture = collect_until(skip_trivia(current), ["{"]);
    current = clauses_capture.parser;
    let clause_slices = split_token_slices_by_comma(clauses_capture.tokens);
    let mut clauses -> WithClause[] = [];
    let mut index -> number = 0;
    loop {
        if index >= clause_slices.length {
            break;
        }
        let slice_tokens = trim_token_edges(clause_slices[index]);
        if slice_tokens.length > 0 {
            let expression = expression_from_tokens(slice_tokens);
            clauses = append_with_clause(clauses, WithClause { expression: expression });
        }
        index += 1;
    }

    let block_result = parse_block(current);
    if block_result.block.tokens.length == 0 {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }
    current = block_result.parser;
    let body = block_result.block;

    current = skip_trivia(current);
    if parser_peek_raw(current).kind.variant == "Symbol" && parser_peek_raw(current).kind.value == ";" {
        current = parser_advance_raw(current);
    }

    let statement = Statement.WithStatement {
        clauses: clauses,
        body: body,
        decorators: decorators,
    };

    return BlockStatementParseResult {
        parser: current,
        statement: statement,
        success: true,
    };
}

fn parse_return_statement(parser -> Parser) -> BlockStatementParseResult {
    let original = parser;
    let mut current = skip_trivia(parser);
    if !identifier_matches(parser_peek_raw(current), "return") {
        return BlockStatementParseResult { parser: original, statement: null, success: false };
    }
    current = consume_keyword(current, "return");

    let capture = collect_until(skip_trivia(current), [";", "}"]);
    current = capture.parser;
    let trimmed = trim_token_edges(capture.tokens);

    let mut expression -> Expression? = null;
    if trimmed.length > 0 {
        expression = expression_from_tokens(trimmed);
    }

    current = skip_trivia(current);
    let terminator = parser_peek_raw(current);
    if terminator.kind.variant == "Symbol" && terminator.kind.value == ";" {
        current = parser_advance_raw(current);
    }

    let statement = Statement.ReturnStatement { expression: expression };
    return BlockStatementParseResult {
        parser: current,
        statement: statement,
        success: true,
    };
}

fn parse_expression_statement(parser -> Parser, decorators -> Decorator[]) -> BlockStatementParseResult {
    if decorators.length > 0 {
        return BlockStatementParseResult { parser: parser, statement: null, success: false };
    }

    let mut current = skip_trivia(parser);
    let start = parser_peek_raw(current);
    if start.kind.variant == "EndOfFile" {
        return BlockStatementParseResult { parser: parser, statement: null, success: false };
    }
    if start.kind.variant == "Symbol" {
        let sym = start.kind.value;
        if sym == "}" || sym == "{" {
            return BlockStatementParseResult { parser: parser, statement: null, success: false };
        }
    }

    let capture = collect_until(current, [";"]);
    if capture.tokens.length == 0 {
        return BlockStatementParseResult { parser: parser, statement: null, success: false };
    }

    let trimmed = trim_token_edges(capture.tokens);
    if trimmed.length == 0 {
        return BlockStatementParseResult { parser: parser, statement: null, success: false };
    }

    current = capture.parser;
    current = skip_trivia(current);
    let terminator = parser_peek_raw(current);
    if !(terminator.kind.variant == "Symbol" && terminator.kind.value == ";") {
        return BlockStatementParseResult { parser: parser, statement: null, success: false };
    }
    current = parser_advance_raw(current);

    let expression = expression_from_tokens(trimmed);
    let statement = Statement.ExpressionStatement { expression: expression };
    return BlockStatementParseResult {
        parser: current,
        statement: statement,
        success: true,
    };
}

fn parse_unknown(parser -> Parser) -> StatementParseResult {
    parser = skip_trivia(parser);
    let mut tokens -> Token[] = [];
    let mut current = parser;
    let mut depth -> number = 0;

    loop {
        let tok = parser_peek_raw(current);
        tokens = append_token(tokens, tok);

        if tok.kind.variant == "Symbol" {
            let sym = tok.kind.value;
            if sym == "{" {
                depth += 1;
            } else if sym == "}" {
                if depth > 0 {
                    depth -= 1;
                }
                if depth == 0 && sym == "}" {
                    current = parser_advance_raw(current);
                    break;
                }
            } else if sym == ";" && depth == 0 {
                current = parser_advance_raw(current);
                break;
            }
        }

        if tok.kind.variant == "EndOfFile" {
            current = parser_advance_raw(current);
            break;
        }

        current = parser_advance_raw(current);
    }

    let text = tokens_to_text(tokens);
    let block = Statement.Unknown { tokens: tokens, text: text };
    parser = skip_trivia(current);
    return StatementParseResult { parser: parser, statement: block };
}

fn identifier_matches(token -> Token, expected -> string) -> boolean {
    if token.kind.variant != "Identifier" {
        return false;
    }
    if token.kind.value == expected {
        return true;
    }
    return token.lexeme == expected;
}

fn identifier_text(token -> Token) -> string {
    if token.kind.variant == "Identifier" {
        let value = token.kind.value;
        if value.length > 0 {
            return value;
        }
    }
    return token.lexeme;
}

fn string_literal_value(token -> Token) -> string {
    if token.kind.variant == "StringLiteral" {
        let value = token.kind.value;
        if value.length > 0 {
            return value;
        }
    }
    let lexeme = token.lexeme;
    return strip_surrounding_quotes(lexeme);
}

fn skip_trivia(parser -> Parser) -> Parser {
    let mut current = parser;
    loop {
        if current.index >= current.tokens.length {
            break;
        }
        let token = current.tokens[current.index];
        if is_trivia_token(token) {
            current = parser_advance_raw(current);
            continue;
        }
        break;
    }
    return current;
}

fn parser_peek_raw(parser -> Parser) -> Token {
    if parser.index >= parser.tokens.length {
        return parser.tokens[parser.tokens.length - 1];
    }
    return parser.tokens[parser.index];
}

fn parser_advance_raw(parser -> Parser) -> Parser {
    if parser.index + 1 > parser.tokens.length {
        return parser;
    }
    return Parser {
        tokens: parser.tokens,
        index: parser.index + 1,
    };
}

fn consume_keyword(parser -> Parser, keyword -> string) -> Parser {
    parser = skip_trivia(parser);
    let token = parser_peek_raw(parser);
    if identifier_matches(token, keyword) {
        return parser_advance_raw(parser);
    }
    return parser;
}

fn consume_symbol(parser -> Parser, symbol -> string) -> Parser {
    parser = skip_trivia(parser);
    let token = parser_peek_raw(parser);
    if token.kind.variant == "Symbol" && token.kind.value == symbol {
        return parser_advance_raw(parser);
    }
    return parser;
}

fn collect_until(parser -> Parser, terminators -> string[]) -> CaptureResult {
    let mut current = parser;
    let mut captured -> Token[] = [];
    let mut paren_depth -> number = 0;
    let mut brace_depth -> number = 0;
    let mut bracket_depth -> number = 0;

    loop {
        let token = parser_peek_raw(current);
        if token.kind.variant == "EndOfFile" {
            break;
        }

        let should_stop = paren_depth == 0 && brace_depth == 0 && bracket_depth == 0
            && token.kind.variant == "Symbol"
            && string_array_contains(terminators, token.kind.value);
        if should_stop {
            break;
        }

        captured = append_token(captured, token);

        if token.kind.variant == "Symbol" {
            let sym = token.kind.value;
            if sym == "(" {
                paren_depth += 1;
            } else if sym == ")" && paren_depth > 0 {
                paren_depth -= 1;
            } else if sym == "{" {
                brace_depth += 1;
            } else if sym == "}" && brace_depth > 0 {
                brace_depth -= 1;
            } else if sym == "[" {
                bracket_depth += 1;
            } else if sym == "]" && bracket_depth > 0 {
                bracket_depth -= 1;
            }
        }

        let advanced = parser_advance_raw(current);
        if advanced.index == current.index {
            break;
        }
        current = advanced;
    }

    return CaptureResult { parser: current, tokens: captured };
}

fn select_type_terminators(is_const -> boolean) -> string[] {
    if is_const {
        return ["="];
    }
    return ["=", ";"];
}

fn collect_parenthesized(parser -> Parser) -> ParenthesizedParseResult {
    let mut current = skip_trivia(parser);
    let start = parser_peek_raw(current);
    if !(start.kind.variant == "Symbol" && start.kind.value == "(") {
        return ParenthesizedParseResult { parser: parser, tokens: [], success: false };
    }

    current = parser_advance_raw(current);
    let mut tokens -> Token[] = [];
    let mut depth -> number = 1;

    loop {
        let token = parser_peek_raw(current);
        if token.kind.variant == "EndOfFile" {
            return ParenthesizedParseResult { parser: parser, tokens: [], success: false };
        }

        if token.kind.variant == "Symbol" {
            let sym = token.kind.value;
            if sym == "(" {
                depth += 1;
            } else if sym == ")" {
                depth -= 1;
                if depth == 0 {
                    current = parser_advance_raw(current);
                    break;
                }
            }
        }

        tokens = append_token(tokens, token);
        current = parser_advance_raw(current);
    }

    return ParenthesizedParseResult { parser: current, tokens: tokens, success: true };
}

fn parse_decorator_argument(tokens -> Token[]) -> DecoratorArgument? {
    if tokens.length == 0 {
        return null;
    }

    let colon_index = find_top_level_colon(tokens);
    if colon_index == -1 {
        let trimmed_tokens = trim_token_edges(tokens);
        if trimmed_tokens.length == 0 {
            return null;
        }
        let expr = normalize_expression(trimmed_tokens, expression_from_tokens(trimmed_tokens));
        return DecoratorArgument { name: null, expression: expr };
    }

    let name_tokens = trim_token_edges(token_slice(tokens, 0, colon_index));
    let value_tokens = trim_token_edges(token_slice(tokens, colon_index + 1, tokens.length));

    if value_tokens.length == 0 {
        return null;
    }

    let name_text = trim_text(tokens_to_text(name_tokens));
    if name_text.length == 0 {
        return null;
    }

    let mut expr = normalize_expression(value_tokens, expression_from_tokens(value_tokens));
    if expr.variant == "Raw" {
        let raw_text = trim_text(tokens_to_text(value_tokens));
        if raw_text.length >= 2 && raw_text[0] == "\"" && raw_text[raw_text.length - 1] == "\"" {
            let literal = strip_surrounding_quotes(raw_text);
            expr = Expression.StringLiteral { value: literal };
        } else if raw_text == "true" {
            expr = Expression.BooleanLiteral { value: true };
        } else if raw_text == "false" {
            expr = Expression.BooleanLiteral { value: false };
        } else if looks_like_number(raw_text) {
            expr = Expression.NumberLiteral { value: raw_text };
        }
    }
    return DecoratorArgument { name: name_text, expression: expr };
}

fn normalize_expression(tokens -> Token[], expr -> Expression) -> Expression {
    if expr.variant == "Raw" {
        let filtered = filter_trivia(tokens);
        if filtered.length == 1 {
            let token = filtered[0];
            if token.kind.variant == "StringLiteral" {
                return Expression.StringLiteral { value: token.kind.value };
            }
            if token.kind.variant == "BooleanLiteral" {
                return Expression.BooleanLiteral { value: token.kind.value };
            }
            if token.kind.variant == "NumberLiteral" {
                return Expression.NumberLiteral { value: token.kind.value };
            }
        }
        let raw_text = trim_text(expr.text);
        if raw_text.length >= 2 && raw_text[0] == "\"" && raw_text[raw_text.length - 1] == "\"" {
            let literal = strip_surrounding_quotes(raw_text);
            return Expression.StringLiteral { value: literal };
        }
        if raw_text == "true" {
            return Expression.BooleanLiteral { value: true };
        }
        if raw_text == "false" {
            return Expression.BooleanLiteral { value: false };
        }
        if looks_like_number(raw_text) {
            return Expression.NumberLiteral { value: raw_text };
        }
    }
    return expr;
}

fn looks_like_number(text -> string) -> boolean {
    if text.length == 0 {
        return false;
    }
    let mut has_decimal -> boolean = false;
    let mut index -> number = 0;
    if text[0] == "-" {
        if text.length == 1 {
            return false;
        }
        index = 1;
    }
    loop {
        if index >= text.length {
            break;
        }
        let ch = text[index];
        if ch == "." {
            if has_decimal {
                return false;
            }
            has_decimal = true;
            index += 1;
            continue;
        }
        if !is_decimal_digit(ch) {
            return false;
        }
        index += 1;
    }
    return true;
}

fn is_decimal_digit(ch -> string) -> boolean {
    return ch == "0"
        || ch == "1"
        || ch == "2"
        || ch == "3"
        || ch == "4"
        || ch == "5"
        || ch == "6"
        || ch == "7"
        || ch == "8"
        || ch == "9";
}

fn trim_token_edges(tokens -> Token[]) -> Token[] {
    let mut start -> number = 0;
    let mut end -> number = tokens.length;

    loop {
        if start >= end {
            break;
        }
        let token = tokens[start];
        if is_trivia_token(token) {
            start += 1;
            continue;
        }
        break;
    }

    loop {
        if end <= start {
            break;
        }
        let token = tokens[end - 1];
        if is_trivia_token(token) {
            end -= 1;
            continue;
        }
        break;
    }

    return token_slice(tokens, start, end);
}

fn token_slice(tokens -> Token[], start -> number, end -> number) -> Token[] {
    let mut result -> Token[] = [];
    let mut index -> number = start;
    loop {
        if index >= end {
            break;
        }
        result = append_token(result, tokens[index]);
        index += 1;
    }
    return result;
}

fn trim_block_tokens(tokens -> Token[]) -> Token[] {
    let mut depth -> number = 0;
    let mut index -> number = 0;
    let mut end -> number = tokens.length;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if token.kind.variant == "Symbol" {
            let sym = token.kind.value;
            if sym == "{" {
                depth += 1;
            } else if sym == "}" {
                if depth > 0 {
                    depth -= 1;
                }
                if depth == 0 {
                    end = index + 1;
                    break;
                }
            }
        }
        index += 1;
    }
    return token_slice(tokens, 0, end);
}

fn find_top_level_colon(tokens -> Token[]) -> number {
    let mut angle -> number = 0;
    let mut paren -> number = 0;
    let mut brace -> number = 0;
    let mut bracket -> number = 0;

    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if token.kind.variant == "Symbol" {
            let sym = token.kind.value;
            if sym == "<" {
                angle += 1;
            } else if sym == ">" && angle > 0 {
                angle -= 1;
            } else if sym == "(" {
                paren += 1;
            } else if sym == ")" && paren > 0 {
                paren -= 1;
            } else if sym == "{" {
                brace += 1;
            } else if sym == "}" && brace > 0 {
                brace -= 1;
            } else if sym == "[" {
                bracket += 1;
            } else if sym == "]" && bracket > 0 {
                bracket -= 1;
            } else if sym == ":" {
                let at_top = angle == 0 && paren == 0 && brace == 0 && bracket == 0;
                if at_top {
                    return index;
                }
            }
        }
        index += 1;
    }
    return -1;
}

fn expression_from_tokens(tokens -> Token[]) -> Expression {
    let trimmed = filter_trivia(tokens);
    if trimmed.length == 0 {
        return Expression.Raw { text: "" };
    }

    if trimmed.length == 1 {
        let token = trimmed[0];
        if token.kind.variant == "NumberLiteral" {
            return Expression.NumberLiteral { value: token.kind.value };
        }
        if token.kind.variant == "BooleanLiteral" {
            return Expression.BooleanLiteral { value: token.kind.value };
        }
        if token.kind.variant == "StringLiteral" {
            return Expression.StringLiteral { value: token.kind.value };
        }
        if token.kind.variant == "Identifier" {
            let value = token.kind.value;
            if value == "true" {
                return Expression.BooleanLiteral { value: true };
            }
            if value == "false" {
                return Expression.BooleanLiteral { value: false };
            }
            if value == "null" {
                return Expression.NullLiteral();
            }
            return Expression.Identifier { name: value };
        }
    }

    let text = trim_text(tokens_to_text(tokens));
    return Expression.Raw { text: text };
}

fn filter_trivia(tokens -> Token[]) -> Token[] {
    let mut index -> number = 0;
    let mut filtered -> Token[] = [];

    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if token.kind.variant != "Whitespace" && token.kind.variant != "Comment" {
            filtered = append_token(filtered, token);
        }
        index += 1;
    }

    return filtered;
}

fn tokens_to_text(tokens -> Token[]) -> string {
    let mut text -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        text = text + tokens[index].lexeme;
        index += 1;
    }
    return text;
}

fn trim_text(value -> string) -> string {
    let mut start -> number = 0;
    let mut end -> number = value.length;

    loop {
        if start >= end {
            break;
        }
        let ch = value[start];
        if is_trim_whitespace(ch) {
            start += 1;
            continue;
        }
        break;
    }

    loop {
        if end <= start {
            break;
        }
        let ch = value[end - 1];
        if is_trim_whitespace(ch) {
            end -= 1;
            continue;
        }
        break;
    }

    return runtime.substring(value, start, end);
}

fn is_trim_whitespace(ch -> string) -> boolean {
    let code = runtime.char_code(ch);
    return code == 32  // space
        || code == 10  // newline
        || code == 9   // tab
        || code == 13; // carriage return
}

fn string_array_contains(values -> string[], target -> string) -> boolean {
    let mut index -> number = 0;
    loop {
        if index >= values.length {
            break;
        }
        if values[index] == target {
            return true;
        }
        index += 1;
    }
    return false;
}

fn is_trivia_token(token -> Token) -> boolean {
    if token.kind.variant == "Whitespace" || token.kind.variant == "Comment" {
        return true;
    }
    if token.kind.variant == "Symbol" {
        if is_whitespace_lexeme(token.lexeme) {
            return true;
        }
    }
    return false;
}

fn is_whitespace_lexeme(text -> string) -> boolean {
    if text.length == 0 {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= text.length {
            break;
        }
        let ch = text[index];
        if !is_trim_whitespace(ch) {
            return false;
        }
        index += 1;
    }
    return true;
}

fn advance_to_symbol(parser -> Parser, symbol -> string) -> Parser {
    let mut current = parser;
    loop {
        current = skip_trivia(current);
        let token = parser_peek_raw(current);
        if token.kind.variant == "Symbol" && token.kind.value == symbol {
            return current;
        }
        if token.kind.variant == "EndOfFile" {
            return current;
        }
        let next = parser_advance_raw(current);
        if next.index == current.index {
            return current;
        }
        current = next;
    }
}

fn skip_struct_member(parser -> Parser) -> Parser {
    let mut current = parser;
    loop {
        let next = parser_advance_raw(current);
        if next.index == current.index {
            return current;
        }
        current = next;
        let token = parser_peek_raw(current);
        if token.kind.variant == "EndOfFile" {
            return current;
        }
        if token.kind.variant == "Symbol" {
            let sym = token.kind.value;
            if sym == ";" {
                current = parser_advance_raw(current);
                return current;
            }
            if sym == "}" {
                return current;
            }
        }
    }
}

fn strip_surrounding_quotes(text -> string) -> string {
    if text.length < 2 {
        return text;
    }
    let first = runtime.char_code(text[0]);
    let last = runtime.char_code(text[text.length - 1]);
    if first == 34 && last == 34 {
        return runtime.substring(text, 1, text.length - 1);
    }
    return text;
}

fn normalize_test_name(text -> string) -> string {
    let trimmed = trim_text(text);
    if trimmed.length >= 2 {
        let first = runtime.char_code(trimmed[0]);
        let last = runtime.char_code(trimmed[trimmed.length - 1]);
        if first == 34 && last == 34 {
            return strip_surrounding_quotes(trimmed);
        }
    }
    return trimmed;
}

fn split_tokens_by_comma(tokens -> Token[]) -> string[] {
    let mut parts -> string[] = [];
    let mut segment -> string = "";
    let mut angle -> number = 0;
    let mut paren -> number = 0;
    let mut brace -> number = 0;
    let mut bracket -> number = 0;

    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if token.kind.variant == "Symbol" {
            let sym = token.kind.value;
            if sym == "<" {
                angle += 1;
            } else if sym == ">" && angle > 0 {
                angle -= 1;
            } else if sym == "(" {
                paren += 1;
            } else if sym == ")" && paren > 0 {
                paren -= 1;
            } else if sym == "{" {
                brace += 1;
            } else if sym == "}" && brace > 0 {
                brace -= 1;
            } else if sym == "[" {
                bracket += 1;
            } else if sym == "]" && bracket > 0 {
                bracket -= 1;
            }

            if sym == "," && angle == 0 && paren == 0 && brace == 0 && bracket == 0 {
                let text = trim_text(segment);
                if text.length > 0 {
                    parts = append_string(parts, text);
                }
                segment = "";
                index += 1;
                continue;
            }
        }
        segment = segment + token.lexeme;
        index += 1;
    }

    let tail = trim_text(segment);
    if tail.length > 0 {
        parts = append_string(parts, tail);
    }
    return parts;
}

fn split_token_slices_by_comma(tokens -> Token[]) -> Token[][] {
    let mut parts -> Token[][] = [];
    let mut segment -> Token[] = [];
    let mut angle -> number = 0;
    let mut paren -> number = 0;
    let mut brace -> number = 0;
    let mut bracket -> number = 0;

    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if token.kind.variant == "Symbol" {
            let sym = token.kind.value;
            if sym == "<" {
                angle += 1;
            } else if sym == ">" && angle > 0 {
                angle -= 1;
            } else if sym == "(" {
                paren += 1;
            } else if sym == ")" && paren > 0 {
                paren -= 1;
            } else if sym == "{" {
                brace += 1;
            } else if sym == "}" && brace > 0 {
                brace -= 1;
            } else if sym == "[" {
                bracket += 1;
            } else if sym == "]" && bracket > 0 {
                bracket -= 1;
            }

            if sym == "," && angle == 0 && paren == 0 && brace == 0 && bracket == 0 {
                parts = append_token_array(parts, segment);
                segment = [];
                index += 1;
                continue;
            }
        }
        segment = append_token(segment, token);
        index += 1;
    }

    if segment.length > 0 {
        parts = append_token_array(parts, segment);
    }
    return parts;
}

fn find_top_level_symbol(tokens -> Token[], symbol -> string) -> number {
    let mut angle -> number = 0;
    let mut paren -> number = 0;
    let mut brace -> number = 0;
    let mut bracket -> number = 0;

    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if token.kind.variant == "Symbol" {
            let sym = token.kind.value;
            if sym == "<" {
                angle += 1;
            } else if sym == ">" && angle > 0 {
                angle -= 1;
            } else if sym == "(" {
                paren += 1;
            } else if sym == ")" && paren > 0 {
                paren -= 1;
            } else if sym == "{" {
                brace += 1;
            } else if sym == "}" && brace > 0 {
                brace -= 1;
            } else if sym == "[" {
                bracket += 1;
            } else if sym == "]" && bracket > 0 {
                bracket -= 1;
            }

            if sym == symbol && angle == 0 && paren == 0 && brace == 0 && bracket == 0 {
                return index;
            }
        }
        index += 1;
    }
    return -1;
}

fn find_top_level_identifier(tokens -> Token[], keyword -> string) -> number {
    let mut angle -> number = 0;
    let mut paren -> number = 0;
    let mut brace -> number = 0;
    let mut bracket -> number = 0;

    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if token.kind.variant == "Symbol" {
            let sym = token.kind.value;
            if sym == "<" {
                angle += 1;
            } else if sym == ">" && angle > 0 {
                angle -= 1;
            } else if sym == "(" {
                paren += 1;
            } else if sym == ")" && paren > 0 {
                paren -= 1;
            } else if sym == "{" {
                brace += 1;
            } else if sym == "}" && brace > 0 {
                brace -= 1;
            } else if sym == "[" {
                bracket += 1;
            } else if sym == "]" && bracket > 0 {
                bracket -= 1;
            }
        }

        if token.kind.variant == "Identifier" {
            if identifier_matches(token, keyword) {
                if angle == 0 && paren == 0 && brace == 0 && bracket == 0 {
                    return index;
                }
            }
        }
        index += 1;
    }
    return -1;
}

fn append_statement(statements -> Statement[], statement -> Statement) -> Statement[] {
    return statements.concat([statement]);
}

fn append_string(values -> string[], value -> string) -> string[] {
    return values.concat([value]);
}

fn append_parameter(parameters -> Parameter[], parameter -> Parameter) -> Parameter[] {
    return parameters.concat([parameter]);
}

fn append_model_property(properties -> ModelProperty[], property -> ModelProperty) -> ModelProperty[] {
    return properties.concat([property]);
}

fn append_field(fields -> FieldDeclaration[], field -> FieldDeclaration) -> FieldDeclaration[] {
    return fields.concat([field]);
}

fn append_method(methods -> MethodDeclaration[], method -> MethodDeclaration) -> MethodDeclaration[] {
    return methods.concat([method]);
}

fn append_signature(signatures -> FunctionSignature[], signature -> FunctionSignature) -> FunctionSignature[] {
    return signatures.concat([signature]);
}

fn append_enum_variant(variants -> EnumVariant[], variant -> EnumVariant) -> EnumVariant[] {
    return variants.concat([variant]);
}

fn append_type_annotation(types -> TypeAnnotation[], item -> TypeAnnotation) -> TypeAnnotation[] {
    return types.concat([item]);
}

fn append_type_parameter(parameters -> TypeParameter[], parameter -> TypeParameter) -> TypeParameter[] {
    return parameters.concat([parameter]);
}

fn append_decorator(decorators -> Decorator[], decorator -> Decorator) -> Decorator[] {
    return decorators.concat([decorator]);
}

fn append_decorator_argument(arguments -> DecoratorArgument[], argument -> DecoratorArgument) -> DecoratorArgument[] {
    return arguments.concat([argument]);
}

fn append_with_clause(clauses -> WithClause[], clause -> WithClause) -> WithClause[] {
    return clauses.concat([clause]);
}

fn append_token(tokens -> Token[], token -> Token) -> Token[] {
    return tokens.concat([token]);
}

fn append_token_array(collection -> Token[][], tokens -> Token[]) -> Token[][] {
    return collection.concat([tokens]);
}
