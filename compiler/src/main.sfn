fn _ms_since(start_ms -> number) -> number {
    let end_ms = monotonic_millis();
    let delta = end_ms - start_ms;
    if delta < 0 {
        return 0;
    }
    return delta;
}

fn _timing_line(module_name -> string, phase -> string, elapsed_ms -> number) -> string {
    // Format is stable and grep/awk-friendly.
    // Emit to stderr via print.warn.
    return "[timing] module=" + module_name + " phase=" + phase + " ms=" + number_to_string(elapsed_ms);
}

fn compile_to_sailfin(source -> string) -> string ![io] {
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        return "";
    }
    return emit_program(program);
}

fn compile_to_native(source -> string) -> EmitNativeResult ![io] {
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        return EmitNativeResult {
            module: empty_native_module(),
            diagnostics: format_typecheck_diagnostics(diagnostics, source),
        };
    }
    return emit_native(program);
}

fn compile_to_native_with_module_name(source -> string, module_name -> string) -> EmitNativeResult ![io] {
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        return EmitNativeResult {
            module: empty_native_module(),
            diagnostics: format_typecheck_diagnostics(diagnostics, source),
        };
    }
    return emit_native_with_module_name(program, module_name);
}

fn module_name_from_path(source_path -> string) -> string {
    if source_path.length == 0 {
        return "main";
    }

    // Normalize path separators so we can reason about prefixes.
    let mut normalized -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= source_path.length {
            break;
        }
        let ch = source_path[index];
        if ch == "\\" {
            normalized = normalized + "/";
        } else {
            normalized = normalized + ch;
        }
        index += 1;
    }

    // Prefer stable module names rooted at compiler/src or runtime.
    // - .../compiler/src/parser/mod.sfn -> parser/mod
    // - .../runtime/prelude.sfn         -> runtime/prelude
    let compiler_prefix = "compiler/src/";
    let runtime_prefix = "runtime/";
    let mut start -> number = 0;

    let mut last_compiler -> number = -1;
    let compiler_search_limit = normalized.length - compiler_prefix.length;
    index = 0;
    loop {
        if index > compiler_search_limit {
            break;
        }
        if substring(normalized, index, index + compiler_prefix.length) == compiler_prefix {
            last_compiler = index;
        }
        index += 1;
    }
    if last_compiler >= 0 {
        start = last_compiler + compiler_prefix.length;
    } else {
        let mut last_runtime -> number = -1;
        let runtime_search_limit = normalized.length - runtime_prefix.length;
        index = 0;
        loop {
            if index > runtime_search_limit {
                break;
            }
            if substring(normalized, index, index + runtime_prefix.length) == runtime_prefix {
                last_runtime = index;
            }
            index += 1;
        }
        if last_runtime >= 0 {
            // Keep the runtime/ prefix in the module name.
            start = last_runtime;
        }
    }

    // Find the end of the module name by stripping the extension from the last
    // path segment.
    let mut last_slash -> number = -1;
    index = start;
    loop {
        if index >= normalized.length {
            break;
        }
        if normalized[index] == "/" {
            last_slash = index;
        }
        index += 1;
    }
    let mut end -> number = normalized.length;
    let mut dot_index -> number = -1;
    index = normalized.length;
    let dot_limit = last_slash + 1;
    loop {
        if index <= dot_limit {
            break;
        }
        index -= 1;
        if normalized[index] == "." {
            dot_index = index;
            break;
        }
    }
    if dot_index >= 0 {
        end = dot_index;
    }

    if end <= start {
        return "main";
    }
    let base = substring(normalized, start, end);
    if base.length == 0 {
        return "main";
    }
    return base;
}

struct LLVMCompilationResult {
    // Note: this struct crosses tool boundaries (stage1 Python + stage2 native).
    // Keep fields `any` so native layout emission doesn't require importing the
    // full layouts for `LoweredLLVMResultAny` / `NativeModule`.
    llvm -> any;
    native_module -> any;
}

// NOTE: This is intentionally defined in this module (instead of importing the
// canonical definition from `./llvm/types`) because stage1's LLVM backend
// currently treats imported structs as opaque when lowering struct literals.
// Keeping these fields as `any` avoids pulling full type layouts across
// tool/runtime boundaries (stage1 Python + stage2 native).
struct LoweredLLVMResultAny {
    ir -> string;
    diagnostics -> string[];
    trait_metadata -> any;
    function_effects -> any;
    lifetime_regions -> any;
    capability_manifest -> any;
    string_constants -> any;
}

fn compile_to_native_llvm(source -> string) -> LoweredLLVMResultAny ![io] {
    let native_result = compile_to_native(source);
    let lowered = lower_to_llvm(native_result.module);
    let mut combined -> string[] = [];
    let mut _ci0 -> number = 0;
    loop {
        if _ci0 >= native_result.diagnostics.length { break; }
        combined.push(native_result.diagnostics[_ci0]);
        _ci0 += 1;
    }
    let mut _ci1 -> number = 0;
    loop {
        if _ci1 >= lowered.diagnostics.length { break; }
        combined.push(lowered.diagnostics[_ci1]);
        _ci1 += 1;
    }
    if combined.length > 0 {
        let mut index -> number = 0;
        loop {
            if index >= combined.length {
                break;
            }
            print("[native-llvm] " + combined[index]);
            index += 1;
        }
    }
    return LoweredLLVMResultAny {
        ir: lowered.ir,
        diagnostics: combined,
        trait_metadata: lowered.trait_metadata,
        function_effects: lowered.function_effects,
        lifetime_regions: lowered.lifetime_regions,
        capability_manifest: lowered.capability_manifest,
        string_constants: lowered.string_constants,
    };
}

fn compile_to_native_llvm_with_module(source -> string, module_name -> string) -> LoweredLLVMResultAny ![io] {
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        let messages = format_typecheck_diagnostics(diagnostics, source);
        return LoweredLLVMResultAny {
            ir: "",
            diagnostics: messages,
            trait_metadata: null,
            function_effects: null,
            lifetime_regions: null,
            capability_manifest: null,
            string_constants: null,
        };
    }

    let native_result = emit_native_with_module_name(program, module_name);
    let lowered = lower_to_llvm(native_result.module);
    let mut combined -> string[] = [];
    let mut _ci0 -> number = 0;
    loop {
        if _ci0 >= native_result.diagnostics.length { break; }
        combined.push(native_result.diagnostics[_ci0]);
        _ci0 += 1;
    }
    let mut _ci1 -> number = 0;
    loop {
        if _ci1 >= lowered.diagnostics.length { break; }
        combined.push(lowered.diagnostics[_ci1]);
        _ci1 += 1;
    }
    if combined.length > 0 {
        let mut index -> number = 0;
        loop {
            if index >= combined.length {
                break;
            }
            print("[native-llvm] " + combined[index]);
            index += 1;
        }
    }
    return LoweredLLVMResultAny {
        ir: lowered.ir,
        diagnostics: combined,
        trait_metadata: lowered.trait_metadata,
        function_effects: lowered.function_effects,
        lifetime_regions: lowered.lifetime_regions,
        capability_manifest: lowered.capability_manifest,
        string_constants: lowered.string_constants,
    };
}

// C-friendly entrypoint for the native stage2 driver.
// Keeps the public ABI as `char* -> char*` while reusing the structured
// `LoweredLLVMResultAny` internally.
fn compile_to_llvm(source -> string) -> string ![io] {
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        return "";
    }
    let trace_emit = fs.exists("build/sailfin/.trace_emit");
    let native_text = emit_native_text_with_module_name(program, "main");
    if trace_emit {
        print.err("emit-llvm: native text bytes=" + number_to_string(native_text.length));
        if native_text.length > 0 {
            fs.writeFile("build/sailfin/debug-emit-native.sfn-asm", native_text);
            print.err("emit-llvm: wrote build/sailfin/debug-emit-native.sfn-asm");
        }
    }
    if native_text.length > 0 {
        let ir = lower_to_llvm_ir_from_text(native_text, "main");
        if trace_emit {
            print.err("emit-llvm: llvm bytes=" + number_to_string(ir.length));
            if ir.length > 0 {
                fs.writeFile("build/sailfin/debug-emit-llvm.ll", ir);
                print.err("emit-llvm: wrote build/sailfin/debug-emit-llvm.ll");
            }
        }
        return ir;
    }
    let native_result = emit_native_with_module_name(program, "main");
    let ir = lower_to_llvm_ir(native_result.module);
    if trace_emit {
        print.err("emit-llvm: llvm bytes=" + number_to_string(ir.length));
        if ir.length > 0 {
            fs.writeFile("build/sailfin/debug-emit-llvm.ll", ir);
            print.err("emit-llvm: wrote build/sailfin/debug-emit-llvm.ll");
        }
    }
    return ir;
}

fn compile_to_llvm_with_module(source -> string, module_name -> string) -> string ![io] {
    let program -> Program = parse_program(source);
    let skip_typecheck = fs.exists("build/sailfin/.skip_typecheck");
    if !skip_typecheck {
        if typecheck_has_errors(program) {
            let diagnostics = typecheck_diagnostics(program);
            report_typecheck_errors(diagnostics, source);
            return "";
        }
    } else {
        print("emit-llvm: skipping typecheck (build/sailfin/.skip_typecheck present)");
    }
    let trace_emit = fs.exists("build/sailfin/.trace_emit");
    let native_text = emit_native_text_with_module_name(program, module_name);
    if trace_emit {
        print("emit-llvm: native text bytes=" + number_to_string(native_text.length));
        if native_text.length > 0 {
            fs.writeFile("build/sailfin/debug-emit-native.sfn-asm", native_text);
            print("emit-llvm: wrote build/sailfin/debug-emit-native.sfn-asm");
        }
    }
    let mut ir -> string = "";
    if native_text.length > 0 {
        ir = lower_to_llvm_ir_from_text(native_text, module_name);
        if ir.length == 0 {
            let native_result = emit_native_with_module_name(program, module_name);
            ir = lower_to_llvm_ir(native_result.module);
        }
    } else {
        let native_result = emit_native_with_module_name(program, module_name);
        ir = lower_to_llvm_ir(native_result.module);
    }
    if trace_emit {
        print("emit-llvm: llvm bytes=" + number_to_string(ir.length));
        if ir.length > 0 {
            fs.writeFile("build/sailfin/debug-emit-llvm.ll", ir);
            print("emit-llvm: wrote build/sailfin/debug-emit-llvm.ll");
        }
    }
    return ir;
}

fn compile_to_llvm_with_module_timed(source -> string, module_name -> string) -> string ![io, clock] {
    let t0 = monotonic_millis();
    let program -> Program = parse_program(source);
    let t_parse = _ms_since(t0);

    let t1 = monotonic_millis();
    let skip_typecheck = fs.exists("build/sailfin/.skip_typecheck");
    let mut t_typecheck -> number = 0;
    if !skip_typecheck {
        t_typecheck = _ms_since(t1);
        if typecheck_has_errors(program) {
            let diagnostics = typecheck_diagnostics(program);
            report_typecheck_errors(diagnostics, source);
            print(_timing_line(module_name, "parse", t_parse));
            print(_timing_line(module_name, "typecheck", t_typecheck));
            return "";
        }
    } else {
        t_typecheck = _ms_since(t1);
        print("emit-llvm: skipping typecheck (build/sailfin/.skip_typecheck present)");
    }

    let t2 = monotonic_millis();
    let trace_emit = fs.exists("build/sailfin/.trace_emit");
    let native_text = emit_native_text_with_module_name(program, module_name);
    if trace_emit {
        print("emit-llvm: native text bytes=" + number_to_string(native_text.length));
        if native_text.length > 0 {
            fs.writeFile("build/sailfin/debug-emit-native.sfn-asm", native_text);
            print("emit-llvm: wrote build/sailfin/debug-emit-native.sfn-asm");
        }
    }
    let t_emit_native = _ms_since(t2);

    let t3 = monotonic_millis();
    let mut ir = "";
    if native_text.length > 0 {
        ir = lower_to_llvm_ir_from_text(native_text, module_name);
    } else {
        let native_result = emit_native_with_module_name(program, module_name);
        ir = lower_to_llvm_ir(native_result.module);
    }
    if trace_emit {
        print("emit-llvm: llvm bytes=" + number_to_string(ir.length));
        if ir.length > 0 {
            fs.writeFile("build/sailfin/debug-emit-llvm.ll", ir);
            print("emit-llvm: wrote build/sailfin/debug-emit-llvm.ll");
        }
    }
    let t_lower_llvm = _ms_since(t3);

    print(_timing_line(module_name, "parse", t_parse));
    print(_timing_line(module_name, "typecheck", t_typecheck));
    print(_timing_line(module_name, "emit_native", t_emit_native));
    print(_timing_line(module_name, "lower_llvm", t_lower_llvm));
    print(_timing_line(module_name, "total", _ms_since(t0)));
    return ir;
}

fn compile_to_llvm_lines_with_module(source -> string, module_name -> string) -> string[] ![io] {
    let program -> Program = parse_program(source);
    let skip_typecheck = fs.exists("build/sailfin/.skip_typecheck");
    if !skip_typecheck {
        if typecheck_has_errors(program) {
            let diagnostics = typecheck_diagnostics(program);
            report_typecheck_errors(diagnostics, source);
            return [];
        }
    } else {
        print("emit-llvm-lines: skipping typecheck (build/sailfin/.skip_typecheck present)");
    }
    let native_result = emit_native_with_module_name(program, module_name);
    return lower_to_llvm_lines_only(native_result.module);
}

fn compile_to_llvm_lines_with_module_timed(source -> string, module_name -> string) -> string[] ![io, clock] {
    let t0 = monotonic_millis();
    let program -> Program = parse_program(source);
    let t_parse = _ms_since(t0);

    let t1 = monotonic_millis();
    let t_typecheck = _ms_since(t1);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        print(_timing_line(module_name, "parse", t_parse));
        print(_timing_line(module_name, "typecheck", t_typecheck));
        return [];
    }

    let t2 = monotonic_millis();
    let native_result = emit_native_with_module_name(program, module_name);
    let t_emit_native = _ms_since(t2);

    let t3 = monotonic_millis();
    let lines = lower_to_llvm_lines_only(native_result.module);
    let t_lower_llvm = _ms_since(t3);

    print(_timing_line(module_name, "parse", t_parse));
    print(_timing_line(module_name, "typecheck", t_typecheck));
    print(_timing_line(module_name, "emit_native", t_emit_native));
    print(_timing_line(module_name, "lower_llvm", t_lower_llvm));
    print(_timing_line(module_name, "total", _ms_since(t0)));
    return lines;
}

// Emit LLVM IR that runs all `test ... {}` declarations in the module.
// Used by the `sailfin test` CLI subcommand.
fn compile_tests_to_llvm(source -> string) -> string ![io] {
    let trace = fs.exists("build/sailfin/.trace_test_runner") && fs.exists("build/sailfin/.test_runner_active");
    if trace {
        print("test compiler: compile_to_native start");
    }
    let native_result = compile_to_native(source);
    if trace {
        print("test compiler: compile_to_native done (diagnostics=" + number_to_string(native_result.diagnostics.length) + ")");
        print("test compiler: lower_to_llvm_for_tests start");
    }
    let ir = lower_to_llvm_ir_for_tests(native_result.module);
    if trace {
        print("test compiler: lower_to_llvm_for_tests done (ir_bytes=" + number_to_string(ir.length) + ")");
    }
    return ir;
}

fn compile_tests_to_llvm_with_module(source -> string, module_name -> string) -> string ![io] {
    let trace = fs.exists("build/sailfin/.trace_test_runner") && fs.exists("build/sailfin/.test_runner_active");
    if trace {
        print("test compiler: parse_program start");
    }
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        return "";
    }
    if trace {
        print("test compiler: emit_native_with_module_name start (module=" + module_name + ")");
    }
    let native_result = emit_native_with_module_name(program, module_name);
    if trace {
        print("test compiler: native artifacts=" + number_to_string(native_result.module.artifacts.length));
        let mut artifact_index -> number = 0;
        loop {
            if artifact_index >= native_result.module.artifacts.length {
                break;
            }
            let artifact = native_result.module.artifacts[artifact_index];
            print(
                "test compiler: artifact[" + number_to_string(artifact_index)
                + "] format=" + artifact.format
                + " bytes=" + number_to_string(artifact.contents.length)
            );
            artifact_index += 1;
        }
        let text_artifact = select_text_artifact(native_result.module.artifacts);
        if text_artifact == null {
            print("test compiler: missing sailfin-native-text artifact");
        } else {
            print("test compiler: native text bytes=" + number_to_string(text_artifact.contents.length));
        }
        print("test compiler: lower_to_llvm_for_tests start");
    }
    let llvm_text = lower_to_llvm_ir_for_tests(native_result.module);
    if trace {
        print("test compiler: lower_to_llvm_for_tests done (ir_bytes=" + number_to_string(llvm_text.length) + ")");
    }
    return llvm_text;
}

// Compile tests and write LLVM IR directly, avoiding large return values.
fn compile_tests_to_llvm_file_with_module(source -> string, module_name -> string, out_path -> string) -> boolean ![io] {
    let trace_file = fs.exists("build/sailfin/.trace_test_runner");
    let active_file = fs.exists("build/sailfin/.test_runner_active");
    let trace = trace_file && active_file;
    if trace_file || active_file {
        if trace {
            print("test compiler: trace enabled (trace_file=true, active_file=true)");
        } else {
            let mut trace_text -> string = "false";
            if trace_file {
                trace_text = "true";
            }
            let mut active_text -> string = "false";
            if active_file {
                active_text = "true";
            }
            print(
                "test compiler: trace disabled (trace_file="
                + trace_text
                + ", active_file="
                + active_text
                + ")"
            );
        }
    }
    if trace {
        print("test compiler: parse_program start");
    }
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        return false;
    }
    if trace {
        print("test compiler: emit_native_with_module_name start (module=" + module_name + ")");
    }
    let native_text = emit_native_text_with_module_name(program, module_name);
    if trace {
        print("test compiler: native text bytes=" + number_to_string(native_text.length));
        print("test compiler: lower_to_llvm_for_tests start");
    }
    if fs.exists(out_path) {
        fs.deleteFile(out_path);
    }
    if trace {
        if native_text.length > 0 {
            fs.writeFile("build/sailfin/debug-test-native.sfn-asm", native_text);
            print("test compiler: wrote build/sailfin/debug-test-native.sfn-asm");
        }
    }

    write_llvm_ir_for_tests_from_text(native_text, module_name, out_path);
    if !fs.exists(out_path) {
        return false;
    }
    let content = fs.readFile(out_path);
    if trace {
        print("test compiler: write_llvm_ir_for_tests bytes=" + number_to_string(content.length));
    }
    if content.length <= 4 {
        if trace {
            print("test compiler: suspiciously short llvm output (len=" + number_to_string(content.length) + ")");
        }
        return false;
    }
    return true;
}

fn compile_tests_to_llvm_lines_with_module(source -> string, module_name -> string) -> string[] ![io] {
    let trace = fs.exists("build/sailfin/.trace_test_runner") && fs.exists("build/sailfin/.test_runner_active");
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        return [];
    }
    let native_result = emit_native_with_module_name(program, module_name);
    if trace {
        print("test compiler: native artifacts=" + number_to_string(native_result.module.artifacts.length));
        let text_artifact = select_text_artifact(native_result.module.artifacts);
        if text_artifact == null {
            print("test compiler: missing sailfin-native-text artifact");
        } else {
            print("test compiler: native text bytes=" + number_to_string(text_artifact.contents.length));
        }
        print("test compiler: lower_to_llvm_ir_for_tests start");
    }
    let llvm_text = lower_to_llvm_ir_for_tests(native_result.module);
    if trace {
        print("test compiler: lower_to_llvm_ir_for_tests done (ir_bytes=" + number_to_string(llvm_text.length) + ")");
    }
    if llvm_text.length == 0 {
        return [];
    }
    return split_lines(llvm_text);
}

fn compile_to_native_text(source -> string) -> string ![io] {
    return compile_to_native_text_with_module(source, "main");
}

fn compile_to_native_text_with_module(source -> string, module_name -> string) -> string ![io] {
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        return "";
    }
    let trace_emit = fs.exists("build/sailfin/.trace_emit");
    let text = emit_native_text_with_module_name(program, module_name);
    if trace_emit {
        print("emit-native: native text bytes=" + number_to_string(text.length));
        if text.length > 0 {
            fs.writeFile("build/sailfin/debug-emit-native.sfn-asm", text);
            print("emit-native: wrote build/sailfin/debug-emit-native.sfn-asm");
        }
    }
    return text;
}

// Write native text directly to a file to avoid returning large strings across ABI boundaries.
fn write_native_text_file_with_module(source -> string, module_name -> string, out_path -> string) -> boolean ![io] {
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        return false;
    }
    return emit_native_text_to_file_with_module_name(program, module_name, out_path);
}

fn _has_prefix(value -> string, prefix -> string) -> boolean {
    if prefix.length > value.length {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= prefix.length {
            break;
        }
        if value[index] != prefix[index] {
            return false;
        }
        index += 1;
    }
    return true;
}

fn _find_first_nonblank_line(text -> string) -> string {
    let lines = split_lines(text);
    let mut index -> number = 0;
    loop {
        if index >= lines.length || index >= 128 {
            break;
        }
        let line = lines[index];
        if line.length > 0 {
            return line;
        }
        index += 1;
    }
    return "";
}

fn _looks_like_llvm_text(text -> string) -> boolean {
    if text.length < 16 {
        return false;
    }
    let lines = split_lines(text);
    let mut index -> number = 0;
    loop {
        if index >= lines.length || index >= 128 {
            break;
        }
        let line = lines[index];
        if line.length == 0 {
            index += 1;
            continue;
        }
        if line[0] == " " || line[0] == "\t" {
            return false;
        }
        if _has_prefix(line, "source_filename =") {
            return true;
        }
        if _has_prefix(line, "; ModuleID =") {
            return true;
        }
        if _has_prefix(line, "target ") || _has_prefix(line, "declare ") || _has_prefix(line, "define ") {
            return true;
        }
        if line[0] == "%" || line[0] == "@" || line[0] == "!" || line[0] == ";" {
            return true;
        }
        return false;
    }
    return false;
}

// Compile and write LLVM IR directly, avoiding large return values.
fn compile_to_llvm_file_with_module(source -> string, module_name -> string, out_path -> string) -> boolean ![io] {
    let program -> Program = parse_program(source);
    let skip_typecheck = fs.exists("build/sailfin/.skip_typecheck");
    if !skip_typecheck {
        if typecheck_has_errors(program) {
            let diagnostics = typecheck_diagnostics(program);
            report_typecheck_errors(diagnostics, source);
            return false;
        }
    } else {
        print("emit-llvm-file: skipping typecheck (build/sailfin/.skip_typecheck present)");
    }

    let native_text_path = "build/sailfin/emit-native.tmp";
    if fs.exists(native_text_path) {
        fs.deleteFile(native_text_path);
    }
    let native_ok = emit_native_text_to_file_with_module_name(program, module_name, native_text_path);
    if !native_ok {
        print("emit-llvm-file: empty native output for module " + module_name);
        let cached_native_path = "build/native/import-context/" + module_name + ".sfn-asm";
        if fs.exists(cached_native_path) {
            let cached_ok = write_llvm_ir_from_native_text_file(cached_native_path, module_name, out_path);
            if cached_ok && fs.exists(out_path) {
                let cached_contents = fs.readFile(out_path);
                if _looks_like_llvm_text(cached_contents) {
                    print("emit-llvm-file: used cached native artifact fallback for module " + module_name);
                    return true;
                }
            }
        }
        let native_result = emit_native_with_module_name(program, module_name);
        let fallback_ok = write_llvm_ir(native_result.module, out_path);
        if fallback_ok && fs.exists(out_path) {
            let contents = fs.readFile(out_path);
            if _looks_like_llvm_text(contents) {
                return true;
            }
        }
        return false;
    }
    if fs.exists(out_path) {
        fs.deleteFile(out_path);
    }
    let ok = write_llvm_ir_from_native_text_file(native_text_path, module_name, out_path);
    let mut output_valid -> boolean = false;
    // Check file content regardless of return value — the boolean return from
    // cross-module calls can be corrupted by ABI issues in the seed compiler.
    let _file_exists = fs.exists(out_path);
    if _file_exists {
        let written = fs.readFile(out_path);
        // _looks_like_llvm_text may be miscompiled by the seed (loop/string
        // comparison bugs).  Trust write_llvm_ir_from_native_text_file: if the
        // file exists and has reasonable length it is valid LLVM IR produced by
        // the lowering pipeline.
        if written.length > 64 {
            output_valid = true;
        }
        if !output_valid {
            // Check if the content starts with a valid LLVM entity (just missing header).
            // If it starts with garbage (e.g. mid-instruction due to array offset corruption),
            // do NOT prepend a header — let the selfhost script's recovery handle it.
            let _first_nonblank = _find_first_nonblank_line(written);
            if _first_nonblank.length > 0 && (_first_nonblank[0] == "%" || _first_nonblank[0] == "@" || _has_prefix(_first_nonblank, "declare ") || _has_prefix(_first_nonblank, "define ") || _has_prefix(_first_nonblank, "target ")) {
                let header = "source_filename = \"" + module_name + ".sfn\"\n\n";
                fs.writeFile(out_path, header + written);
                output_valid = true;
                print("emit-llvm-file: prepended header for module " + module_name);
            }
        }
        if !output_valid {
            print("emit-llvm-file: malformed llvm output for module " + module_name + "; falling back");
        }
    }
    if !output_valid {
        if !ok {
            print("emit-llvm-file: empty llvm output for module " + module_name);
        }
        let llvm_text = compile_to_llvm_with_module(source, module_name);
        if _looks_like_llvm_text(llvm_text) {
            fs.writeFile(out_path, llvm_text);
            if fs.exists(out_path) {
                let contents = fs.readFile(out_path);
                if _looks_like_llvm_text(contents) {
                    return true;
                }
            }
        }
        return false;
    }
    return true;
}

fn compile_to_native_llvm_full(source -> string) -> LLVMCompilationResult ![io] {
    let native_result = compile_to_native(source);
    let lowered = lower_to_llvm(native_result.module);
    let mut combined -> string[] = [];
    let mut _ci0 -> number = 0;
    loop {
        if _ci0 >= native_result.diagnostics.length { break; }
        combined.push(native_result.diagnostics[_ci0]);
        _ci0 += 1;
    }
    let mut _ci1 -> number = 0;
    loop {
        if _ci1 >= lowered.diagnostics.length { break; }
        combined.push(lowered.diagnostics[_ci1]);
        _ci1 += 1;
    }
    if combined.length > 0 {
        let mut index -> number = 0;
        loop {
            if index >= combined.length {
                break;
            }
            print("[native-llvm] " + combined[index]);
            index += 1;
        }
    }
    return LLVMCompilationResult {
        llvm: LoweredLLVMResultAny {
            ir: lowered.ir,
            diagnostics: combined,
            trait_metadata: lowered.trait_metadata,
            function_effects: lowered.function_effects,
            lifetime_regions: lowered.lifetime_regions,
            capability_manifest: lowered.capability_manifest,
            string_constants: lowered.string_constants,
        },
        native_module: native_result.module,
    };
}

