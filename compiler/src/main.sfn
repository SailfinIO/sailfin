fn compile_to_native_llvm_with_context_with_module_and_entry_points(
    source -> string,
    module_name -> string,
    manifest_contents -> string[],
    native_artifacts -> string[],
    entry_points -> string[]
) -> LoweredLLVMResultAny ![io] {
    let program -> Program = parse_program(source);
    if typecheck_has_errors(program) {
        let diagnostics = typecheck_diagnostics(program);
        report_typecheck_errors(diagnostics, source);
        let messages = format_typecheck_diagnostics(diagnostics, source);
        return LoweredLLVMResultAny {
            ir: "",
            diagnostics: messages,
            trait_metadata: null,
            function_effects: null,
            lifetime_regions: null,
            capability_manifest: null,
            string_constants: null,
        };
    }

    let native_result = emit_native_with_module_name(program, module_name);
    let overridden_module = NativeModule {
        module_name: native_result.module.module_name,
        artifacts: native_result.module.artifacts,
        entry_points: entry_points,
        symbol_count: native_result.module.symbol_count,
    };

    let mut manifests -> LayoutManifest[] = [];
    let mut manifest_index -> number = 0;
    loop {
        if manifest_index >= manifest_contents.length {
            break;
        }
        let manifest_text = manifest_contents[manifest_index];
        if manifest_text.length == 0 {
            manifests.push(LayoutManifest { structs: [], enums: [], diagnostics: [] });
        } else {
            let parsed = parse_layout_manifest(manifest_text);
            manifests.push(LayoutManifest {
                structs: parsed.structs,
                enums: parsed.enums,
                diagnostics: [],
            });
        }
        manifest_index += 1;
    }

    let lowered = lower_to_llvm_with_context(overridden_module, manifests, native_artifacts, []);
    let mut combined -> string[] = [];
    let mut _ci0 -> number = 0;
    loop {
        if _ci0 >= native_result.diagnostics.length { break; }
        combined.push(native_result.diagnostics[_ci0]);
        _ci0 += 1;
    }
    let mut _ci1 -> number = 0;
    loop {
        if _ci1 >= lowered.diagnostics.length { break; }
        combined.push(lowered.diagnostics[_ci1]);
        _ci1 += 1;
    }
    if combined.length > 0 {
        let mut index -> number = 0;
        loop {
            if index >= combined.length {
                break;
            }
            print("[native-llvm] " + combined[index]);
            index += 1;
        }
    }

    return LoweredLLVMResultAny {
        ir: lowered.ir,
        diagnostics: combined,
        trait_metadata: lowered.trait_metadata,
        function_effects: lowered.function_effects,
        lifetime_regions: lowered.lifetime_regions,
        capability_manifest: lowered.capability_manifest,
        string_constants: lowered.string_constants,
    };
}

// Backwards-compatible shim that only supplies layout manifests
fn compile_to_native_llvm_with_manifests(source -> string, manifest_contents -> string[]) -> LoweredLLVMResultAny ![io] {
    return compile_to_native_llvm_with_context(source, manifest_contents, []);
}

fn stage2_compiler_main() ![io] {
    print("Sailfin compiler");
}

fn format_typecheck_diagnostics(entries -> Diagnostic[], source -> string) -> string[] {
    let lines = split_source_lines(source);
    let mut padding_width -> number = number_to_string(lines.length).length;
    if padding_width < 1 {
        padding_width = 1;
    }
    let mut messages -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        let formatted = format_typecheck_diagnostic(entries[index], lines, padding_width);
        messages.push(formatted);
        index += 1;
    }
    return messages;
}

fn report_typecheck_errors(entries -> Diagnostic[], source -> string) ![io] {
    let formatted = format_typecheck_diagnostics(entries, source);
    let prefix = "[typecheck] ";
    let padding = repeat_character(" ", prefix.length);
    let mut index -> number = 0;
    loop {
        if index >= formatted.length {
            break;
        }
        let message = formatted[index];
        let lines = split_source_lines(message);
        if lines.length == 0 {
            print.err(prefix);
            index += 1;
            continue;
        }
        let mut line_index -> number = 0;
        loop {
            if line_index >= lines.length {
                break;
            }
            if line_index == 0 {
                print.err(prefix + lines[line_index]);
            } else {
                print.err(padding + lines[line_index]);
            }
            line_index += 1;
        }
        index += 1;
    }
}

fn format_typecheck_diagnostic(entry -> Diagnostic, source_lines -> string[], line_padding -> number) -> string {
    if entry.primary == null {
        return entry.message;
    }
    let mut parts -> string[] = [];
    parts.push(entry.message);
    let token -> Token? = entry.primary;
    let line_number = token.line;
    let column_number = token.column;
    let location = "  --> line " + number_to_string(line_number) + ", column " + number_to_string(column_number);
    parts.push(location);
    if line_number < 1 || line_number > source_lines.length {
        return join_lines(parts);
    }
    let line_text = source_lines[line_number - 1];
    let gutter_spaces = repeat_character(" ", line_padding);
    parts.push(" " + gutter_spaces + " |");
    let line_number_text = number_to_string(line_number);
    let mut prefix_padding -> string = "";
    let mut pad_count -> number = line_padding - line_number_text.length;
    if pad_count < 0 {
        pad_count = 0;
    }
    if pad_count > 0 {
        prefix_padding = repeat_character(" ", pad_count);
    }
    parts.push(" " + prefix_padding + line_number_text + " | " + line_text);
    let pointer = build_pointer_line(column_number, token.lexeme, line_text);
    parts.push(" " + gutter_spaces + " | " + pointer);
    return join_lines(parts);
}

fn split_source_lines(source -> string) -> string[] {
    let mut lines -> string[] = [];
    let mut current -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= source.length {
            break;
        }
        let _ch_next = index + 1;
        let ch = substring(source, index, _ch_next);
        if ch == "\r" {
            lines.push(current);
            current = "";
            if _ch_next < source.length {
                let _ch_next2 = index + 2;
                let next = substring(source, _ch_next, _ch_next2);
                if next == "\n" {
                    index += 2;
                    continue;
                }
            }
            index += 1;
            continue;
        }
        if ch == "\n" {
            lines.push(current);
            current = "";
            index += 1;
            continue;
        }
        current = current + ch;
        index += 1;
    }
    lines.push(current);
    return lines;
}

fn build_pointer_line(column -> number, lexeme -> string, line_text -> string) -> string {
    if line_text.length == 0 {
        return "^";
    }
    let mut start_column -> number = column;
    if start_column < 1 {
        start_column = 1;
    }
    if start_column > line_text.length {
        start_column = line_text.length;
    }
    let mut pointer -> string = "";
    let mut index -> number = 1;
    loop {
        if index >= start_column {
            break;
        }
        if index <= line_text.length {
            let current = substring(line_text, index - 1, index);
            if current == "\t" {
                pointer = pointer + "\t";
            } else {
                pointer = pointer + " ";
            }
        } else {
            pointer = pointer + " ";
        }
        index += 1;
    }
    let mut highlight_length -> number = lexeme.length;
    if highlight_length <= 0 {
        highlight_length = 1;
    }
    let mut remaining -> number = line_text.length - (start_column - 1);
    if remaining <= 0 {
        remaining = 1;
    }
    if highlight_length > remaining {
        highlight_length = remaining;
    }
    let mut highlight_index -> number = 0;
    loop {
        if highlight_index >= highlight_length {
            break;
        }
        pointer = pointer + "^";
        highlight_index += 1;
    }
    return pointer;
}

fn join_lines(lines -> string[]) -> string {
    if lines.length == 0 {
        return "";
    }
    let mut result -> string = lines[0];
    let mut index -> number = 1;
    loop {
        if index >= lines.length {
            break;
        }
        result = result + "\n" + lines[index];
        index += 1;
    }
    return result;
}

fn append_string(values -> string[], value -> string) -> string[] {
    values.push(value);
    return values;
}

fn number_to_string(value -> number) -> string {
    if value == 0 {
        return "0";
    }
    let mut working -> number = value;
    let mut negative -> boolean = false;
    if working < 0 {
        negative = true;
        working = 0 - working;
    }
    let digits = "0123456789";
    let mut remaining -> number = working;
    let mut output -> string = "";
    loop {
        if remaining <= 0 {
            break;
        }
        let mut temp -> number = remaining;
        let mut quotient -> number = 0;
        loop {
            if temp < 10 {
                break;
            }
            temp -= 10;
            quotient += 1;
        }
        let ch = substring(digits, temp, temp + 1);
        output = ch + output;
        remaining = quotient;
    }
    if negative {
        output = "-" + output;
    }
    return output;
}

fn empty_native_module() -> NativeModule {
    return NativeModule {
        module_name: "main",
        artifacts: [],
        entry_points: [],
        symbol_count: 0,
    };
}

fn has_prefix(value -> string, prefix -> string) -> boolean {
    if prefix.length > value.length {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= prefix.length {
            break;
        }
        if value[index] != prefix[index] {
            return false;
        }
        index += 1;
    }
    return true;
}

fn repeat_character(ch -> string, count -> number) -> string {
    if count <= 0 {
        return "";
    }
    let mut index -> number = 0;
    let mut result -> string = "";
    loop {
        if index >= count {
            break;
        }
        result = result + ch;
        index += 1;
    }
    return result;
}

fn find_substring(value -> string, pattern -> string) -> number {
    if pattern.length == 0 {
        return 0;
    }
    if value.length < pattern.length {
        return -1;
    }
    let _search_limit = value.length - pattern.length;
    let mut index -> number = 0;
    loop {
        if index > _search_limit {
            break;
        }
        let mut match_flag -> boolean = true;
        let mut offset -> number = 0;
        loop {
            if offset >= pattern.length {
                break;
            }
            let _cpos = index + offset;
            if value[_cpos] != pattern[offset] {
                match_flag = false;
                break;
            }
            offset += 1;
        }
        if match_flag {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn find_substring_from(value -> string, pattern -> string, start -> number) -> number {
    if start < 0 {
        return find_substring(value, pattern);
    }
    if start >= value.length {
        return -1;
    }
    let _search_limit = value.length - pattern.length;
    let mut index -> number = start;
    loop {
        if index > _search_limit {
            break;
        }
        let mut match_flag -> boolean = true;
        let mut offset -> number = 0;
        loop {
            if offset >= pattern.length {
                break;
            }
            let _cpos2 = index + offset;
            if value[_cpos2] != pattern[offset] {
                match_flag = false;
                break;
            }
            offset += 1;
        }
        if match_flag {
            return index;
        }
        index += 1;
    }
    return -1;
}
