// compiler/src/main.sfn
// Temporary entry point for the Sailfin compiler (self-hosting prototype).

import { parse_program } from "./parser";
import { emit_program } from "./emitter_sailfin";
import { emit_native, EmitNativeResult, NativeModule } from "./emit_native";
import { lower_to_python, LoweredPythonResult } from "./native_lowering";
import { lower_to_llvm, LoweredLLVMResult } from "./native_llvm_lowering";
import { typecheck_program } from "./typecheck";

struct CompiledModule {
    source_path -> string;
    python_source -> string;
}

struct ModuleDiagnostics {
    source_path -> string;
    messages -> string[];
    fatal -> boolean;
}

struct ModuleCompilationResult {
    module -> CompiledModule?;
    diagnostics -> ModuleDiagnostics[];
}

struct ProjectCompilation {
    modules -> CompiledModule[];
    diagnostics -> ModuleDiagnostics[];
}

fn compile_to_sailfin(source -> string) -> string ![io] {
    let program = parse_program(source);
    let analysis_result = typecheck_program(program);
    if analysis_result.diagnostics.length > 0 {
        report_typecheck_errors(analysis_result.diagnostics);
        return "";
    }
    return emit_program(program);
}

fn compile_to_native(source -> string) -> EmitNativeResult ![io] {
    let program = parse_program(source);
    let analysis_result = typecheck_program(program);
    if analysis_result.diagnostics.length > 0 {
        report_typecheck_errors(analysis_result.diagnostics);
        return EmitNativeResult {
            module: empty_native_module(),
            diagnostics: format_typecheck_diagnostics(analysis_result.diagnostics),
        };
    }
    return emit_native(program);
}

fn compile_to_native_python(source -> string) -> LoweredPythonResult ![io] {
    let native_result = compile_to_native(source);
    let lowered = lower_to_python(native_result.module);
    let mut combined -> string[] = [];
    combined = combined.concat(native_result.diagnostics);
    combined = combined.concat(lowered.diagnostics);
    if combined.length > 0 {
        let mut index -> number = 0;
        loop {
            if index >= combined.length {
                break;
            }
            print.warn("[native] " + combined[index]);
            index += 1;
        }
    }
    return LoweredPythonResult {
        source: lowered.source,
        diagnostics: combined,
    };
}

fn compile_to_native_llvm(source -> string) -> LoweredLLVMResult ![io] {
    let native_result = compile_to_native(source);
    let lowered = lower_to_llvm(native_result.module);
    let mut combined -> string[] = [];
    combined = combined.concat(native_result.diagnostics);
    combined = combined.concat(lowered.diagnostics);
    if combined.length > 0 {
        let mut index -> number = 0;
        loop {
            if index >= combined.length {
                break;
            }
            print.warn("[native-llvm] " + combined[index]);
            index += 1;
        }
    }
    return LoweredLLVMResult {
        ir: lowered.ir,
        diagnostics: combined,
        trait_metadata: lowered.trait_metadata,
    };
}

fn main() ![io] {
    print.info("Sailfin compiler (stage 0)");
}

fn compile_project(sources -> string[]) -> ProjectCompilation ![io] {
    let mut modules -> CompiledModule[] = [];
    let mut diagnostics -> ModuleDiagnostics[] = [];

    for source_path in sources {
        let result = compile_source_at_path(source_path);
        if result.module != null {
            modules = modules.concat([result.module]);
        }
        if result.diagnostics.length > 0 {
            diagnostics = diagnostics.concat(result.diagnostics);
        }
    }

    return ProjectCompilation {
        modules: modules,
        diagnostics: diagnostics,
    };
}

fn compile_source_at_path(source_path -> string) -> ModuleCompilationResult ![io] {
    let source = fs.readFile(source_path);
    let program = parse_program(source);
    let analysis = typecheck_program(program);
    if analysis.diagnostics.length > 0 {
        return ModuleCompilationResult {
            module: null,
            diagnostics: [ModuleDiagnostics {
                source_path: source_path,
                messages: format_typecheck_diagnostics(analysis.diagnostics),
                fatal: true,
            }],
        };
    }

    let native_result = emit_native(program);
    let lowered = lower_to_python(native_result.module);
    let mut messages -> string[] = native_result.diagnostics.concat(lowered.diagnostics);
    let python_source = lowered.source;
    let fallback_needed = needs_python_fallback(python_source);
    if fallback_needed {
    messages = messages.concat(["native backend: lowering produced unsupported python output; stage0 fallback disabled"]);
        return ModuleCompilationResult {
            module: null,
            diagnostics: [ModuleDiagnostics {
                source_path: source_path,
                messages: messages,
                fatal: true,
            }],
        };
    }

    let mut entry_list -> ModuleDiagnostics[] = [];
    if messages.length > 0 {
        entry_list = [ModuleDiagnostics {
            source_path: source_path,
            messages: messages,
            fatal: false,
        }];
    }

    return ModuleCompilationResult {
        module: CompiledModule {
            source_path: source_path,
            python_source: python_source,
        },
        diagnostics: entry_list,
    };
}

fn format_typecheck_diagnostics(entries -> Diagnostic[]) -> string[] {
    let mut messages -> string[] = [];
    for entry in entries {
    messages = messages.concat([entry.message]);
    }
    return messages;
}

fn report_typecheck_errors(entries -> Diagnostic[]) ![io] {
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        let diagnostic = entries[index];
        print.error("[typecheck] " + diagnostic.message);
        index += 1;
    }
}

fn empty_native_module() -> NativeModule {
    return NativeModule {
        artifacts: [],
        entry_points: [],
        symbol_count: 0,
    };
}

fn has_prefix(value -> string, prefix -> string) -> boolean {
    if prefix.length > value.length {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= prefix.length {
            break;
        }
        if value[index] != prefix[index] {
            return false;
        }
        index += 1;
    }
    return true;
}

fn needs_python_fallback(source -> string) -> boolean {
    if source.length == 0 {
        return true;
    }
    let sanitized = strip_needs_python_fallback_literals(source);
    let cleaned = strip_python_string_literals(sanitized);
    let mut analysis_target -> string = cleaned;
    if analysis_target.length == 0 {
        analysis_target = sanitized;
    }
    let target = analysis_target;
    if target.length == 0 {
        return true;
    }
    if string_contains(target, "\nlet ") {
        return true;
    }
    if string_contains(target, " let ") {
        return true;
    }
    if string_contains(target, " mut ") {
        return true;
    }
    if string_contains(target, "TokenKind.variant('Identifier', [])") {
        return true;
    }
    if string_contains(target, "TokenKind.variant('NumberLiteral', [])") {
        return true;
    }
    if string_contains(target, "TokenKind.variant('StringLiteral', [])") {
        return true;
    }
    if string_contains(target, "TokenKind.variant('BooleanLiteral', [])") {
        return true;
    }
    if string_contains(target, "TokenKind.variant('Symbol', [])") {
        return true;
    }
    if string_contains(target, "Expression.Identifier()") {
        return true;
    }
    if string_contains(target, "Expression.Raw()") {
        return true;
    }
    if string_contains(target, "ExpressionIdentifier(") {
        return true;
    }
    if string_contains(target, "ExpressionRaw(") {
        return true;
    }
    return false;
}

fn string_contains(value -> string, pattern -> string) -> boolean {
    if pattern.length == 0 {
        return true;
    }
    if value.length < pattern.length {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index + pattern.length > value.length {
            break;
        }
        let mut match_flag -> boolean = true;
        let mut offset -> number = 0;
        loop {
            if offset >= pattern.length {
                break;
            }
            if value[index + offset] != pattern[offset] {
                match_flag = false;
                break;
            }
            offset += 1;
        }
        if match_flag {
            return true;
        }
        index += 1;
    }
    return false;
}

fn strip_needs_python_fallback_literals(source -> string) -> string {
    let marker = "def needs_python_fallback";
    let start = find_substring(source, marker);
    if start < 0 {
        return source;
    }
    let tail_marker = "return False";
    let tail_index = find_substring_from(source, tail_marker, start);
    if tail_index < 0 {
        return source;
    }
    let tail_end = tail_index + tail_marker.length;
    tail_end = advance_to_line_end(source, tail_end);
    let prefix = slice_string(source, 0, start);
    let suffix = slice_string(source, tail_end, source.length);
    return prefix + suffix;
}

fn strip_python_string_literals(value -> string) -> string {
    let mut index -> number = 0;
    let mut result -> string = "";
    loop {
        if index >= value.length {
            break;
        }
        let ch = value[index];
        if ch == "'" {
            let quote_length = python_quote_length(value, index, "'");
            let quotes = repeat_character("'", quote_length);
            result = result + quotes;
            index = skip_python_string_literal(value, index + quote_length, "'", quote_length);
            result = result + quotes;
            continue;
        }
        if ch == "\"" {
            let quote_length = python_quote_length(value, index, "\"");
            let quotes = repeat_character("\"", quote_length);
            result = result + quotes;
            index = skip_python_string_literal(value, index + quote_length, "\"", quote_length);
            result = result + quotes;
            continue;
        }
        result = result + ch;
        index += 1;
    }
    return result;
}

fn python_quote_length(value -> string, start -> number, delimiter -> string) -> number {
    if start + 2 < value.length {
        if value[start + 1] == delimiter {
            if value[start + 2] == delimiter {
                return 3;
            }
        }
    }
    return 1;
}

fn skip_python_string_literal(value -> string, position -> number, delimiter -> string, quote_length -> number) -> number {
    if quote_length == 1 {
        let mut index -> number = position;
        let mut escaped -> boolean = false;
        loop {
            if index >= value.length {
                return index;
            }
            let current = value[index];
            index += 1;
            if escaped {
                escaped = false;
                continue;
            }
            if current == "\\" {
                escaped = true;
                continue;
            }
            if current == delimiter {
                return index;
            }
        }
    }
    let mut search_index -> number = position;
    loop {
        if search_index + quote_length > value.length {
            return value.length;
        }
        let mut matches -> boolean = true;
        let mut offset -> number = 0;
        loop {
            if offset >= quote_length {
                break;
            }
            if value[search_index + offset] != delimiter {
                matches = false;
                break;
            }
            offset += 1;
        }
        if matches {
            return search_index + quote_length;
        }
        search_index += 1;
    }
}

fn repeat_character(ch -> string, count -> number) -> string {
    if count <= 0 {
        return "";
    }
    let mut index -> number = 0;
    let mut result -> string = "";
    loop {
        if index >= count {
            break;
        }
        result = result + ch;
        index += 1;
    }
    return result;
}

fn find_substring(value -> string, pattern -> string) -> number {
    if pattern.length == 0 {
        return 0;
    }
    if value.length < pattern.length {
        return -1;
    }
    let mut index -> number = 0;
    loop {
        if index + pattern.length > value.length {
            break;
        }
        let mut match_flag -> boolean = true;
        let mut offset -> number = 0;
        loop {
            if offset >= pattern.length {
                break;
            }
            if value[index + offset] != pattern[offset] {
                match_flag = false;
                break;
            }
            offset += 1;
        }
        if match_flag {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn find_substring_from(value -> string, pattern -> string, start -> number) -> number {
    if start < 0 {
        return find_substring(value, pattern);
    }
    if start >= value.length {
        return -1;
    }
    let mut index -> number = start;
    loop {
        if index + pattern.length > value.length {
            break;
        }
        let mut match_flag -> boolean = true;
        let mut offset -> number = 0;
        loop {
            if offset >= pattern.length {
                break;
            }
            if value[index + offset] != pattern[offset] {
                match_flag = false;
                break;
            }
            offset += 1;
        }
        if match_flag {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn advance_to_line_end(value -> string, position -> number) -> number {
    let mut index -> number = position;
    loop {
        if index >= value.length {
            break;
        }
        let ch = value[index];
        index += 1;
        if ch == "\n" {
            break;
        }
    }
    return index;
}

fn slice_string(value -> string, start -> number, end -> number) -> string {
    if start < 0 {
        start = 0;
    }
    if end < start {
        end = start;
    }
    if start >= value.length {
        return "";
    }
    if end > value.length {
        end = value.length;
    }
    let mut index -> number = start;
    let mut result -> string = "";
    loop {
        if index >= end {
            break;
        }
        result = result + value[index];
        index += 1;
    }
    return result;
}
