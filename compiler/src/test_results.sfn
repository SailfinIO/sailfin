// compiler/src/test_results.sfn
//
// Typed shape + pure parser for the streamed test-harness record channel
// (SFEP-0050 / SFN-393). The compiled `*_test.sfn` harness
// (`runtime/sfn/assert.sfn`) writes one framed `SFTR` record per test /
// hook / assertion to its own stderr as each completes; the runner reads
// them off the child's captured stderr pipe and classifies inline. This
// replaces the file side-channel (`results.log` + `fail.bin`) SFN-17 used.
//
// Wire format â€” one record per line, tab-separated, sentinel + magic
// prefixed so a record is unambiguously distinguishable from arbitrary
// stderr diagnostics:
//
//     <US>SFTR\t1\t<kind>\t<status>\t<name>\t<hook>\t<file>\t<line>\t<col>\t<message>
//
// where `<US>` is the ASCII Unit Separator byte (0x1F). Fields:
//   - `<US>SFTR` â€” sentinel byte + "Sailfin Test Record" magic (field 0).
//   - `1`       â€” record schema version.
//   - `<kind>`  â€” `test` | `hook` | `assert`. `assert` carries only an
//                 assertion location + message (the retired `fail.bin`
//                 `SFAF` shape folded onto the stream); `test`/`hook`
//                 carry per-test / per-hook classification.
//   - `<status>`â€” `pass` | `fail` | `skip`.
//   - `<name>`  â€” test name (associated test for a hook; empty for
//                 suite-level `before_all`/`after_all` and for `assert`).
//   - `<hook>`  â€” empty for `test`/`assert`; the hook kind for `hook`.
//   - `<file>`/`<line>`/`<col>` â€” assertion location, empty/`0` when none.
//   - `<message>`â€” failure/skip detail; empty for a pass.
//
// The writer replaces `\n`/`\r` in free-text fields with a space, so a
// record is always exactly one line. `<message>` is the final field and
// may itself contain a tab, so it is reassembled from fields[9..].
//
// Lines that are empty, lack the sentinel/magic, carry the wrong arity
// (a truncated final line from a mid-write crash), or have an unknown
// schema/kind/status are treated as passthrough diagnostics and skipped â€”
// never fatal, so a partially-written stream still yields whatever prefix
// of records is well-formed.
import { split_lines, split_text } from "./native_ir_utils_text";
import { char_code_at_text, substring } from "./string_utils";

struct TestResultRecord {
    // Internal kind normalized from the wire tag: "T" (test), "H" (hook),
    // "A" (assert location). Kept as the SFN-17 single-letter form so the
    // runner's existing `kind == "T"` / `kind == "H"` classification is
    // unchanged.
    kind: string;
    status: string;
    name: string;
    hook: string;
    file: string;
    line: int;
    col: int;
    message: string;
}

// ASCII Unit Separator â€” the sentinel byte that marks a candidate record
// line. User diagnostics effectively never emit it.
let _SFTR_US: int = 31;

fn _tr_make_record(kind: string, status: string, name: string, hook: string, file: string, line: int, col: int, message: string) -> TestResultRecord {
    return TestResultRecord {
        kind: kind,
        status: status,
        name: name,
        hook: hook,
        file: file,
        line: line,
        col: col,
        message: message
    };
}

fn _tr_is_known_hook(hook: string) -> boolean {
    if hook == "before_all" { return true; }
    if hook == "before_each" { return true; }
    if hook == "after_each" { return true; }
    if hook == "after_all" { return true; }
    return false;
}

fn _tr_is_valid_status(status: string) -> boolean {
    if status == "pass" { return true; }
    if status == "fail" { return true; }
    if status == "skip" { return true; }
    return false;
}

// Map the wire `<kind>` tag to the internal single-letter form, or "" for
// an unrecognized kind (the line is then treated as passthrough).
fn _tr_map_kind(wire: string) -> string {
    if wire == "test" { return "T"; }
    if wire == "hook" { return "H"; }
    if wire == "assert" { return "A"; }
    return "";
}

// Decimal parser for the `<line>`/`<col>` fields. Any non-digit char
// (including a stray `\r` from a CRLF round-trip) ends the scan; an empty
// or non-numeric field yields 0 rather than aborting the runner.
fn _tr_parse_decimal(text: string) -> int {
    if text.length == 0 { return 0; }
    let mut value: int = 0;
    let mut index: int = 0;
    loop {
        if index >= text.length { break; }
        let c = char_code_at_text(text, index);
        if c < 48 { break; }
        if c > 57 { break; }
        value = value * 10 + (c - 48);
        index += 1;
    }
    return value;
}

// True when `field0` is the sentinel byte followed by the "SFTR" magic.
fn _tr_has_record_prefix(field0: string) -> boolean {
    if field0.length < 5 { return false; }
    if char_code_at_text(field0, 0) != _SFTR_US { return false; }
    return substring(field0, 1, 5) == "SFTR";
}

// Parse ONE line into a `TestResultRecord`, or `null` when the line is not
// a well-formed SFTR record (a passthrough diagnostic, a truncated final
// line, or an unknown schema/kind/status). The runner calls this per
// complete stderr line and forwards the `null` (non-record) lines as
// diagnostics.
fn parse_test_record_line(line: string) -> TestResultRecord? {
    if line.length < 5 { return null; }
    // Fast reject: a record line always begins with the sentinel byte.
    if char_code_at_text(line, 0) != _SFTR_US { return null; }
    let fields = split_text(line, "\t");
    // Ten fixed fields; `<message>` may add more if it contained tabs.
    if fields.length < 10 { return null; }
    if !_tr_has_record_prefix(fields[0]) { return null; }
    if fields[1] != "1" { return null; }
    let kind = _tr_map_kind(fields[2]);
    if kind.length == 0 { return null; }
    let status = fields[3];
    if !_tr_is_valid_status(status) { return null; }
    // A hook record must name a recognized hook kind (matches the SFN-17
    // `H`-record contract); a malformed one is passthrough.
    if kind == "H" && !_tr_is_known_hook(fields[5]) { return null; }
    // Reassemble `<message>` from fields[9..] so a tab inside the message
    // is preserved byte-faithfully (the framing only forbids `\n`/`\r`).
    let mut message = fields[9];
    let mut mi: int = 10;
    loop {
        if mi >= fields.length { break; }
        message = message + "\t" + fields[mi];
        mi += 1;
    }
    return _tr_make_record(kind, status, fields[4], fields[5], fields[6], _tr_parse_decimal(fields[7]), _tr_parse_decimal(fields[8]), message);
}

// Bulk parse: split `bytes` on `\n` and parse each line, skipping
// non-records. Used by the unit tests and any non-streaming caller; the
// streaming runner parses line-by-line via `parse_test_record_line`. A
// truncated final line (mid-crash) simply fails to parse and is dropped,
// so the well-formed prefix of records survives.
fn parse_test_results_log(bytes: string) -> TestResultRecord[] {
    let mut out: TestResultRecord[] = [];
    let lines = split_lines(bytes);
    let mut i: int = 0;
    loop {
        if i >= lines.length { break; }
        let record = parse_test_record_line(lines[i]);
        i += 1;
        if record != null {
            let r: TestResultRecord = record;
            out.push(r);
        }
    }
    return out;
}

export { TestResultRecord, parse_test_record_line, parse_test_results_log };
