// compiler/src/typecheck.sfn
// Foundational semantic analysis pass for the Sailfin self-hosted compiler.
// Duplicate symbol detection now covers top-level declarations, parameters,
// and block-local bindings so future analyses can assume consistent scopes.

import { Program, Statement, FunctionSignature, Block, FieldDeclaration, MethodDeclaration, EnumVariant, ModelProperty, TypeParameter, TypeAnnotation, SourceSpan } from "./ast";
import { Token, TokenKind } from "./token";
import { validate_effects, EffectRequirement, EffectViolation } from "./effect_checker";

struct Diagnostic {
    code -> string;
    message -> string;
    primary -> Token?;
}

struct SymbolEntry {
    name -> string;
    kind -> string;
    span -> SourceSpan?;
}

struct TypecheckResult {
    diagnostics -> Diagnostic[];
    symbols -> SymbolEntry[];
}

struct SymbolCollectionResult {
    symbols -> SymbolEntry[];
    diagnostics -> Diagnostic[];
}

struct ScopeResult {
    bindings -> SymbolEntry[];
    diagnostics -> Diagnostic[];
}

fn typecheck_program(program -> Program) -> TypecheckResult {
    let top_level = collect_top_level_symbols(program);
    let interfaces = collect_interface_definitions(program);
    let scoped_diagnostics = check_program_scopes(program, interfaces);
    let effect_diagnostics = build_effect_diagnostics(program);

    let diagnostics_with_scopes = top_level.diagnostics.concat(scoped_diagnostics);
    let all_diagnostics = diagnostics_with_scopes.concat(effect_diagnostics);

    return TypecheckResult {
        diagnostics: all_diagnostics,
        symbols: top_level.symbols,
    };
}

fn collect_interface_definitions(program -> Program) -> Statement[] {
    let mut interfaces -> Statement[] = [];

    for statement in program.statements {
        if statement.variant == "InterfaceDeclaration" {
            interfaces = interfaces.concat([statement]);
        }
    }
    return interfaces;
}

fn collect_top_level_symbols(program -> Program) -> SymbolCollectionResult {
    let mut symbols -> SymbolEntry[] = [];
    let mut diagnostics -> Diagnostic[] = [];

    for statement in program.statements {
        let result = register_top_level_symbol(statement, symbols);
        symbols = result.symbols;
        diagnostics = diagnostics.concat(result.diagnostics);
    }

    return SymbolCollectionResult {
        symbols: symbols,
        diagnostics: diagnostics,
    };
}

fn register_top_level_symbol(statement -> Statement, existing -> SymbolEntry[]) -> SymbolCollectionResult {
    if statement.variant == "FunctionDeclaration" {
        return register_symbol(statement.signature.name, "function", statement.signature.name_span, existing);
    }
    if statement.variant == "StructDeclaration" {
        return register_symbol(statement.name, "struct", statement.name_span, existing);
    }
    if statement.variant == "EnumDeclaration" {
        return register_symbol(statement.name, "enum", statement.name_span, existing);
    }
    if statement.variant == "InterfaceDeclaration" {
        return register_symbol(statement.name, "interface", statement.name_span, existing);
    }
    if statement.variant == "ModelDeclaration" {
        return register_symbol(statement.name, "model", statement.name_span, existing);
    }
    if statement.variant == "PipelineDeclaration" {
        return register_symbol(statement.signature.name, "pipeline", statement.signature.name_span, existing);
    }
    if statement.variant == "ToolDeclaration" {
        return register_symbol(statement.signature.name, "tool", statement.signature.name_span, existing);
    }
    if statement.variant == "TestDeclaration" {
        return register_symbol(statement.name, "test", statement.name_span, existing);
    }
    if statement.variant == "TypeAliasDeclaration" {
        return register_symbol(statement.name, "type", statement.name_span, existing);
    }
    if statement.variant == "VariableDeclaration" {
        return register_symbol(statement.name, "variable", statement.span, existing);
    }
    return SymbolCollectionResult {
        symbols: existing,
        diagnostics: [],
    };
}

fn check_program_scopes(program -> Program, interfaces -> Statement[]) -> Diagnostic[] {
    let mut bindings -> SymbolEntry[] = [];
    let mut diagnostics -> Diagnostic[] = [];

    for statement in program.statements {
        let result = check_statement(statement, bindings, interfaces);
        bindings = result.bindings;
        diagnostics = diagnostics.concat(result.diagnostics);
    }

    return diagnostics;
}

fn check_statement(statement -> Statement, bindings -> SymbolEntry[], interfaces -> Statement[]) -> ScopeResult {
    if statement.variant == "VariableDeclaration" {
        return register_local_symbol(bindings, statement.name, "variable", statement.span);
    }
    if statement.variant == "FunctionDeclaration" {
        let registration = register_local_symbol(bindings, statement.signature.name, "function", statement.signature.name_span);
        let mut diagnostics = registration.diagnostics;
        diagnostics = diagnostics.concat(check_function_signature(statement.signature));
        let function_diagnostics = check_function_body(statement.signature, statement.body, interfaces);
        return ScopeResult {
            bindings: registration.bindings,
            diagnostics: diagnostics.concat(function_diagnostics),
        };
    }
    if statement.variant == "StructDeclaration" {
        let registration = register_local_symbol(bindings, statement.name, "struct", statement.name_span);
        let mut diagnostics = registration.diagnostics;
        diagnostics = diagnostics.concat(check_type_parameters(statement.type_parameters));
        diagnostics = diagnostics.concat(check_struct_fields(statement.fields));
        diagnostics = diagnostics.concat(check_struct_methods(statement.methods));
        diagnostics = diagnostics.concat(check_struct_implements_interfaces(statement, interfaces));
        let mut index -> number = 0;
        loop {
            if index >= statement.methods.length {
                break;
            }
            let method = statement.methods[index];
            diagnostics = diagnostics.concat(check_function_body(method.signature, method.body, interfaces));
            index += 1;
        }
        return ScopeResult {
            bindings: registration.bindings,
            diagnostics: diagnostics,
        };
    }
    if statement.variant == "EnumDeclaration" {
        let registration = register_local_symbol(bindings, statement.name, "enum", statement.name_span);
        let mut diagnostics = registration.diagnostics;
        diagnostics = diagnostics.concat(check_type_parameters(statement.type_parameters));
        diagnostics = diagnostics.concat(check_enum_variants(statement.variants));
        return ScopeResult {
            bindings: registration.bindings,
            diagnostics: diagnostics,
        };
    }
    if statement.variant == "InterfaceDeclaration" {
        let registration = register_local_symbol(bindings, statement.name, "interface", statement.name_span);
        let mut diagnostics = registration.diagnostics;
        diagnostics = diagnostics.concat(check_type_parameters(statement.type_parameters));
        diagnostics = diagnostics.concat(check_interface_members(statement.members));
        return ScopeResult {
            bindings: registration.bindings,
            diagnostics: diagnostics,
        };
    }
    if statement.variant == "ModelDeclaration" {
        let registration = register_local_symbol(bindings, statement.name, "model", statement.name_span);
        let diagnostics = registration.diagnostics.concat(check_model_properties(statement.properties));
        return ScopeResult {
            bindings: registration.bindings,
            diagnostics: diagnostics,
        };
    }
    if statement.variant == "PipelineDeclaration" {
        let registration = register_local_symbol(bindings, statement.signature.name, "pipeline", statement.signature.name_span);
        let mut diagnostics = registration.diagnostics;
        diagnostics = diagnostics.concat(check_function_signature(statement.signature));
        diagnostics = diagnostics.concat(check_function_body(statement.signature, statement.body, interfaces));
        return ScopeResult {
            bindings: registration.bindings,
            diagnostics: diagnostics,
        };
    }
    if statement.variant == "ToolDeclaration" {
        let registration = register_local_symbol(bindings, statement.signature.name, "tool", statement.signature.name_span);
        let mut diagnostics = registration.diagnostics;
        diagnostics = diagnostics.concat(check_function_signature(statement.signature));
        diagnostics = diagnostics.concat(check_function_body(statement.signature, statement.body, interfaces));
        return ScopeResult {
            bindings: registration.bindings,
            diagnostics: diagnostics,
        };
    }
    if statement.variant == "TestDeclaration" {
        let registration = register_local_symbol(bindings, statement.name, "test", statement.name_span);
        let diagnostics = registration.diagnostics.concat(check_block(statement.body, [], interfaces));
        return ScopeResult {
            bindings: registration.bindings,
            diagnostics: diagnostics,
        };
    }
    if statement.variant == "WithStatement" {
        return ScopeResult {
            bindings: bindings,
            diagnostics: check_block(statement.body, bindings, interfaces),
        };
    }
    if statement.variant == "ForStatement" {
        return ScopeResult {
            bindings: bindings,
            diagnostics: check_block(statement.body, bindings, interfaces),
        };
    }
    if statement.variant == "MatchStatement" {
        let mut diagnostics -> Diagnostic[] = [];
        let mut index -> number = 0;
        loop {
            if index >= statement.cases.length {
                break;
            }
            let case = statement.cases[index];
            diagnostics = diagnostics.concat(check_block(case.body, bindings, interfaces));
            index += 1;
        }
        return ScopeResult {
            bindings: bindings,
            diagnostics: diagnostics,
        };
    }
    if statement.variant == "IfStatement" {
        let mut diagnostics = check_block(statement.then_block, bindings, interfaces);
        if statement.else_branch != null {
            let branch = statement.else_branch;
            if branch.body != null {
                diagnostics = diagnostics.concat(check_block(branch.body, bindings, interfaces));
            }
            if branch.statement != null {
                let result = check_statement(branch.statement, bindings, interfaces);
                diagnostics = diagnostics.concat(result.diagnostics);
            }
        }
        return ScopeResult {
            bindings: bindings,
            diagnostics: diagnostics,
        };
    }
    if statement.variant == "PromptStatement" {
        return ScopeResult {
            bindings: bindings,
            diagnostics: check_block(statement.body, bindings, interfaces),
        };
    }
    if statement.variant == "TypeAliasDeclaration" {
        let registration = register_local_symbol(bindings, statement.name, "type", statement.name_span);
        let diagnostics = registration.diagnostics.concat(check_type_parameters(statement.type_parameters));
        return ScopeResult {
            bindings: registration.bindings,
            diagnostics: diagnostics,
        };
    }
    return ScopeResult {
        bindings: bindings,
        diagnostics: [],
    };
}

fn check_function_body(signature -> FunctionSignature, body -> Block, interfaces -> Statement[]) -> Diagnostic[] {
    let parameter_scope = seed_parameter_scope(signature);
    let body_diagnostics = check_block(body, parameter_scope.bindings, interfaces);
    return parameter_scope.diagnostics.concat(body_diagnostics);
}

fn seed_parameter_scope(signature -> FunctionSignature) -> ScopeResult {
    let mut bindings -> SymbolEntry[] = [];
    let mut diagnostics -> Diagnostic[] = [];

    for parameter in signature.parameters {
        let registration = register_local_symbol(bindings, parameter.name, "parameter", parameter.span);
        bindings = registration.bindings;
        diagnostics = diagnostics.concat(registration.diagnostics);
    }

    return ScopeResult {
        bindings: bindings,
        diagnostics: diagnostics,
    };
}

fn check_block(block -> Block, parent_bindings -> SymbolEntry[], interfaces -> Statement[]) -> Diagnostic[] {
    let mut bindings = clone_bindings(parent_bindings);
    let mut diagnostics -> Diagnostic[] = [];

    for statement in block.statements {
        let result = check_statement(statement, bindings, interfaces);
        bindings = result.bindings;
        diagnostics = diagnostics.concat(result.diagnostics);
    }

    return diagnostics;
}

fn check_struct_implements_interfaces(statement -> Statement, interfaces -> Statement[]) -> Diagnostic[] {
    if statement.implements_types.length == 0 {
        return [];
    }

    let mut method_names -> string[] = [];
    for method in statement.methods {
        method_names = method_names.concat([method.signature.name]);
    }

    let mut diagnostics -> Diagnostic[] = [];
    for annotation in statement.implements_types {
        let interface_definition = resolve_interface_annotation(annotation, interfaces);
        if interface_definition == null {
            continue;
        }
        let interface_name = interface_definition.name;
        diagnostics = diagnostics.concat(
            validate_interface_annotation(statement.name, interface_definition, annotation)
        );
        for member in interface_definition.members {
            if !contains_string(method_names, member.name) {
                diagnostics = diagnostics.concat([
                    make_missing_interface_member_diagnostic(statement.name, interface_name, member.name)
                ]);
            }
        }
    }

    return diagnostics;
}

fn resolve_interface_annotation(annotation -> TypeAnnotation, interfaces -> Statement[]) -> Statement? {
    let text = annotation.text;
    for interface in interfaces {
        let name = interface.name;
        if text == name {
            return interface;
        }
        let generic_prefix = name + "<";
        if starts_with(text, generic_prefix) {
            return interface;
        }
    }
    return null;
}

fn check_struct_fields(fields -> FieldDeclaration[]) -> Diagnostic[] {
    let mut seen -> string[] = [];
    let mut diagnostics -> Diagnostic[] = [];

    for field in fields {
        let name = field.name;
        if contains_string(seen, name) {
            diagnostics = diagnostics.concat([
                make_duplicate_symbol_diagnostic(name, "struct field", token_from_name(name, field.name_span))
            ]);
        } else {
            seen = seen.concat([name]);
        }
    }

    return diagnostics;
}

fn validate_interface_annotation(struct_name -> string, interface_definition -> Statement, annotation -> TypeAnnotation) -> Diagnostic[] {
    let expected_count = interface_definition.type_parameters.length;
    let provided_arguments = parse_type_arguments(annotation.text);
    if expected_count == 0 {
        if provided_arguments.length > 0 {
            return [
                make_interface_no_type_arguments_diagnostic(
                    struct_name,
                    trim_text(annotation.text),
                    interface_definition.name
                )
            ];
        }
        return [];
    }

    if provided_arguments.length == 0 {
        return [
            make_interface_missing_type_arguments_diagnostic(
                struct_name,
                interface_definition.name,
                format_interface_signature(interface_definition)
            )
        ];
    }

    if provided_arguments.length != expected_count {
        return [
            make_interface_type_argument_mismatch_diagnostic(
                struct_name,
                trim_text(annotation.text),
                format_interface_signature(interface_definition)
            )
        ];
    }

    return [];
}

fn format_interface_signature(interface_definition -> Statement) -> string {
    let mut names -> string[] = [];
    for parameter in interface_definition.type_parameters {
        names = names.concat([parameter.name]);
    }
    if names.length == 0 {
        return interface_definition.name;
    }
    return interface_definition.name + "<" + join_with_separator(names, ", ") + ">";
}

fn join_with_separator(items -> string[], separator -> string) -> string {
    if items.length == 0 {
        return "";
    }
    let mut result = items[0];
    let mut index -> number = 1;
    loop {
        if index >= items.length {
            break;
        }
        result = result + separator + items[index];
        index += 1;
    }
    return result;
}

fn parse_type_arguments(annotation_text -> string) -> string[] {
    let block = extract_generic_argument_block(annotation_text);
    if block == null {
        return [];
    }
    return split_generic_argument_list(block);
}

fn extract_generic_argument_block(annotation_text -> string) -> string? {
    let trimmed = trim_text(annotation_text);
    let mut index -> number = 0;
    let mut depth -> number = 0;
    let mut start_index -> number = -1;
    loop {
        if index >= trimmed.length {
            break;
        }
        let ch = trimmed[index];
        if ch == "<" {
            if depth == 0 {
                start_index = index + 1;
            }
            depth += 1;
        } else if ch == ">" {
            if depth == 0 {
                return null;
            }
            depth -= 1;
            if depth == 0 {
                return slice_text(trimmed, start_index, index);
            }
        }
        index += 1;
    }
    return null;
}

fn split_generic_argument_list(block -> string) -> string[] {
    let mut arguments -> string[] = [];
    let mut current -> string = "";
    let mut depth -> number = 0;
    let mut index -> number = 0;
    loop {
        if index >= block.length {
            break;
        }
        let ch = block[index];
        if ch == "<" {
            depth += 1;
            current = current + ch;
        } else if ch == ">" {
            if depth > 0 {
                depth -= 1;
            }
            current = current + ch;
        } else if ch == "," {
            if depth == 0 {
                let trimmed = trim_text(current);
                if trimmed.length > 0 {
                    arguments = arguments.concat([trimmed]);
                }
                current = "";
                index += 1;
                continue;
            }
            current = current + ch;
        } else {
            current = current + ch;
        }
        index += 1;
    }
    let tail = trim_text(current);
    if tail.length > 0 {
        arguments = arguments.concat([tail]);
    }
    return arguments;
}

fn trim_text(value -> string) -> string {
    let mut start -> number = 0;
    let mut end -> number = value.length;
    loop {
        if start >= end {
            break;
        }
        if is_whitespace(value[start]) {
            start += 1;
            continue;
        }
        break;
    }
    loop {
        if end <= start {
            break;
        }
        if is_whitespace(value[end - 1]) {
            end -= 1;
            continue;
        }
        break;
    }
    return slice_text(value, start, end);
}

fn slice_text(value -> string, start -> number, end -> number) -> string {
    if start < 0 {
        start = 0;
    }
    if end > value.length {
        end = value.length;
    }
    if end <= start {
        return "";
    }
    let mut result -> string = "";
    let mut index = start;
    loop {
        if index >= end {
            break;
        }
        result = result + value[index];
        index += 1;
    }
    return result;
}

fn is_whitespace(ch -> string) -> boolean {
    return ch == " " || ch == "\n" || ch == "\t" || ch == "\r";
}

fn check_struct_methods(methods -> MethodDeclaration[]) -> Diagnostic[] {
    let mut seen -> string[] = [];
    let mut diagnostics -> Diagnostic[] = [];

    for method in methods {
        diagnostics = diagnostics.concat(check_function_signature(method.signature));
        let name = method.signature.name;
        if contains_string(seen, name) {
            diagnostics = diagnostics.concat([
                make_duplicate_symbol_diagnostic(name, "method", token_from_name(name, method.signature.name_span))
            ]);
        } else {
            seen = seen.concat([name]);
        }
    }

    return diagnostics;
}

fn check_enum_variants(variants -> EnumVariant[]) -> Diagnostic[] {
    let mut seen -> string[] = [];
    let mut diagnostics -> Diagnostic[] = [];

    for variant in variants {
        let name = variant.name;
        if contains_string(seen, name) {
            diagnostics = diagnostics.concat([
                make_duplicate_symbol_diagnostic(name, "enum variant", token_from_name(name, variant.name_span))
            ]);
        } else {
            seen = seen.concat([name]);
        }
    }

    return diagnostics;
}

fn check_interface_members(members -> FunctionSignature[]) -> Diagnostic[] {
    let mut seen -> string[] = [];
    let mut diagnostics -> Diagnostic[] = [];

    for member in members {
        diagnostics = diagnostics.concat(check_function_signature(member));
        let name = member.name;
        if contains_string(seen, name) {
            diagnostics = diagnostics.concat([
                make_duplicate_symbol_diagnostic(name, "interface member", token_from_name(name, member.name_span))
            ]);
        } else {
            seen = seen.concat([name]);
        }
    }

    return diagnostics;
}

fn check_model_properties(properties -> ModelProperty[]) -> Diagnostic[] {
    let mut seen -> string[] = [];
    let mut diagnostics -> Diagnostic[] = [];

    for property in properties {
        let name = property.name;
        if contains_string(seen, name) {
            diagnostics = diagnostics.concat([
                make_duplicate_symbol_diagnostic(name, "model property", token_from_name(name, property.span))
            ]);
        } else {
            seen = seen.concat([name]);
        }
    }

    return diagnostics;
}

fn check_function_signature(signature -> FunctionSignature) -> Diagnostic[] {
    return check_type_parameters(signature.type_parameters);
}

fn check_type_parameters(type_parameters -> TypeParameter[]) -> Diagnostic[] {
    let mut seen -> string[] = [];
    let mut diagnostics -> Diagnostic[] = [];

    for type_parameter in type_parameters {
        let name = type_parameter.name;
        if contains_string(seen, name) {
            diagnostics = diagnostics.concat([
                make_duplicate_symbol_diagnostic(name, "type parameter", token_from_name(name, type_parameter.span))
            ]);
        } else {
            seen = seen.concat([name]);
        }
    }

    return diagnostics;
}

fn build_effect_diagnostics(program -> Program) -> Diagnostic[] {
    let violations = validate_effects(program);
    let mut diagnostics -> Diagnostic[] = [];
    let mut violation_index -> number = 0;
    loop {
        if violation_index >= violations.length {
            break;
        }
        let violation = violations[violation_index];
        let mut effect_index -> number = 0;
        loop {
            if effect_index >= violation.missing_effects.length {
                break;
            }
            let effect = violation.missing_effects[effect_index];
            let requirement = select_requirement_for_effect(violation.requirements, effect);
            diagnostics = diagnostics.concat([
                Diagnostic {
                    code: "effects.missing",
                    message: format_effect_message(violation.routine_name, effect, requirement),
                    primary: requirement_primary_token(requirement),
                }
            ]);
            effect_index += 1;
        }
        violation_index += 1;
    }
    return diagnostics;
}

fn select_requirement_for_effect(requirements -> EffectRequirement[], effect -> string) -> EffectRequirement? {
    let mut index -> number = 0;
    loop {
        if index >= requirements.length {
            break;
        }
        let requirement = requirements[index];
        if requirement.effect == effect {
            return requirement;
        }
        index += 1;
    }
    return null;
}

fn requirement_primary_token(requirement -> EffectRequirement?) -> Token? {
    if requirement == null {
        return null;
    }
    return requirement.origin;
}

fn format_effect_message(routine_name -> string, effect -> string, requirement -> EffectRequirement?) -> string {
    let mut message = routine_name + " is missing effect '" + effect + "'";
    if requirement != null {
        message = message + "; required by " + requirement.description;
    }
    message = message + ". hint: add ![" + effect + "] to the signature or accept the CLI fix prompt when offered";
    return message;
}

fn contains_string(items -> string[], candidate -> string) -> boolean {
    for item in items {
        if item == candidate {
            return true;
        }
    }
    return false;
}

fn register_local_symbol(bindings -> SymbolEntry[], name -> string, kind -> string, span -> SourceSpan?) -> ScopeResult {
    if has_symbol(bindings, name) {
        return ScopeResult {
            bindings: bindings,
            diagnostics: [make_duplicate_symbol_diagnostic(name, kind, token_from_name(name, span))],
        };
    }

    let updated = append_symbol(bindings, name, kind, span);
    return ScopeResult {
        bindings: updated,
        diagnostics: [],
    };
}

fn register_symbol(name -> string, kind -> string, span -> SourceSpan?, existing -> SymbolEntry[]) -> SymbolCollectionResult {
    if has_symbol(existing, name) {
        return SymbolCollectionResult {
            symbols: existing,
            diagnostics: [make_duplicate_symbol_diagnostic(name, kind, token_from_name(name, span))],
        };
    }

    return SymbolCollectionResult {
        symbols: append_symbol(existing, name, kind, span),
        diagnostics: [],
    };
}

fn append_symbol(symbols -> SymbolEntry[], name -> string, kind -> string, span -> SourceSpan?) -> SymbolEntry[] {
    let mut updated -> SymbolEntry[] = clone_bindings(symbols);
    return updated.concat([SymbolEntry { name: name, kind: kind, span: span }]);
}

fn clone_bindings(source -> SymbolEntry[]) -> SymbolEntry[] {
    let mut copy -> SymbolEntry[] = [];
    for entry in source {
        copy = copy.concat([entry]);
    }
    return copy;
}

fn has_symbol(symbols -> SymbolEntry[], name -> string) -> boolean {
    for entry in symbols {
        if entry.name == name {
            return true;
        }
    }
    return false;
}

fn make_interface_missing_type_arguments_diagnostic(struct_name -> string, interface_name -> string, interface_signature -> string) -> Diagnostic {
    return Diagnostic {
        code: "E0302",
        message: "struct " + struct_name + " implements " + interface_name + " but must specify " + interface_signature + " type arguments",
        primary: null,
    };
}

fn make_interface_type_argument_mismatch_diagnostic(struct_name -> string, annotation_text -> string, interface_signature -> string) -> Diagnostic {
    return Diagnostic {
        code: "E0302",
        message: "struct " + struct_name + " implements " + annotation_text + " but must match " + interface_signature + " type arguments",
        primary: null,
    };
}

fn make_interface_no_type_arguments_diagnostic(struct_name -> string, annotation_text -> string, interface_name -> string) -> Diagnostic {
    return Diagnostic {
        code: "E0302",
        message: "struct " + struct_name + " implements " + annotation_text + " but " + interface_name + " does not take type arguments",
        primary: null,
    };
}

fn token_from_name(name -> string, span -> SourceSpan?) -> Token? {
    if span == null {
        return null;
    }
    return Token {
        kind: TokenKind.Identifier { value: name },
        lexeme: name,
        line: span.start_line,
        column: span.start_column,
    };
}

fn make_duplicate_symbol_diagnostic(name -> string, kind -> string, token -> Token?) -> Diagnostic {
    return Diagnostic {
        code: "E0001",
        message: "duplicate " + kind + " `" + name + "` declared",
        primary: token,
    };
}

fn make_missing_interface_member_diagnostic(struct_name -> string, interface_name -> string, member_name -> string) -> Diagnostic {
    return Diagnostic {
        code: "E0301",
        message: "struct " + struct_name + " implements " + interface_name + " but is missing member `" + member_name + "`",
        primary: null,
    };
}

fn starts_with(value -> string, prefix -> string) -> boolean {
    if prefix.length > value.length {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= prefix.length {
            break;
        }
        if value[index] != prefix[index] {
            return false;
        }
        index += 1;
    }
    return true;
}
