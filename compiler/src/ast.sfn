// compiler/src/ast.sfn
//
// Shared abstract syntax tree definitions for the Sailfin self-hosting effort.
// The structures mirror a pragmatic subset of the bootstrap compiler AST so we
// can progressively port parsing and analysis logic into Sailfin.
import { Token } from "./token";

struct Program {
    statements: Statement[];
}

struct TypeAnnotation {
    text: string;
}

struct TypeParameter {
    name: string;
    bound: TypeAnnotation?;
    span: SourceSpan?;
}

struct Block {
    tokens: Token[];
    text: string;
    statements: Statement[];
}

struct SourceSpan {
    start_line: int;
    start_column: int;
    end_line: int;
    end_column: int;
}

// Inferred lambda capture descriptor populated by the typechecker's
// free-variable walk (issue #458, A1 of #450 M1.5). One entry per
// distinct enclosing-scope name referenced from the lambda body, in
// first-use order â€” deterministic so stage A2 (env-struct emit) and
// stage A3 (call-site dispatch) can index by position. `type_text`
// echoes the enclosing binding's annotation when available
// (parameters and `let x: T = ...`); empty otherwise. `by_value`
// flips false for non-primitive type annotations so the LLVM lowering
// in stage A2 knows to emit a heap-pointer slot. `mutable` records
// whether the enclosing binding was declared `let mut`, so a future
// mutating-capture pass can reject writes to immutable bindings.
struct Capture {
    name: string;
    type_text: string;
    by_value: boolean;
    mutable: boolean;
    span: SourceSpan?;
}

enum Expression {
    // Per-expression source spans land on the variants the effect
    // checker needs for call-site attribution (B1, see
    // docs/proposals/0004-check-architecture.md). Spans are appended as
    // the last field so the seed compiler's positional GEP indexing
    // doesn't shift for existing field reads. Variants without a
    // span field stay layout-stable.
    Identifier { name: string, span: SourceSpan? },
    NumberLiteral { value: string },
    StringLiteral { value: string },
    BooleanLiteral { value: string },
    NullLiteral,
    Unary { operator: string, operand: Expression },
    Binary { operator: string, left: Expression, right: Expression },
    Member { object: Expression, member: string, span: SourceSpan? },
    Call {
        callee: Expression,
        arguments: Expression[],
        span: SourceSpan?,
        // Explicit turbofish type arguments `f<T1, T2>(args)` (SFN-329).
        // Empty for an ordinary or inference-resolved call; the field is
        // appended last so the seed compiler's positional-GEP field
        // indexing for the existing fields stays stable. Carried on the
        // node for faithful parsing; the monomorphizer still resolves the
        // repro forms by unifying argument types, so these are inert until
        // the return-only-position turbofish gap (SFEP-0038) is closed.
        type_arguments: TypeAnnotation[]
    },
    Index { sequence: Expression, index: Expression },
    Array { elements: Expression[] },
    Object { fields: ObjectField[] },
    Struct { type_name: string[], fields: ObjectField[] },
    Lambda {
        parameters: Parameter[],
        body: Block,
        return_type: TypeAnnotation?,
        // Captures are appended last so the seed compiler's positional
        // GEP indexing for the existing fields stays stable. Today the
        // parser always emits an empty list and the inferred capture
        // sets live separately as `LambdaCaptureRecord[]` returned by
        // `analyze_lambda_captures` in `typecheck_captures`. Records
        // are keyed back to a specific Lambda node by the body's
        // opening `{` token (`body.tokens[0]` line/column). A future
        // pass can copy each record's `captures` onto the matching
        // node so this field becomes the single source of truth; for
        // now stage A2 / A3 should look up the record by body span.
        captures: Capture[]
    },
    Range { start: Expression, end: Expression },
    Cast { operand: Expression, target_type: TypeAnnotation },
    // Type-guard operator `x is T` (issue #1753, epic #1180, effect-system
    // hardening). Before #1753 a guard degraded to `Expression.Raw` because
    // the postfix parser had no `is` arm â€” and since #1186 a `Raw` node
    // contributes zero effects, so an effectful operand (`readFile() is T`)
    // reached codegen effect-blind, and the branch bodies saw the operand at
    // its un-narrowed type. Structuring it here lets the effect checker and
    // typecheck walker recurse into `operand` (the target is a static type,
    // effect-free). The formatter serializes it back to `(operand) is <type>`
    // â€” the exact text the lowering shadow re-parser `parse_is_expression`
    // consumes â€” and the if-lowering narrows the guarded operand in the
    // then-branch via the same `narrowed_variant` machinery `if
    // <base>.variant == "<V>"` already uses. Fields `operand`/`target_type`
    // match `Cast`, so they share the enum's per-name field slots (no GEP
    // collision â€” see the `Assignment` note below).
    Is { operand: Expression, target_type: TypeAnnotation },
    // Postfix `?` error-propagation operator (R.1, epic #371). Distinct
    // from the statement-level `TryStatement`. Type rules and emission
    // land in R.3 / R.4 â€” today this is parse-only.
    TryOperator { operand: Expression, span: SourceSpan? },
    // Ternary conditional `cond ? then : else` (issue #1690, epic #1180,
    // effect-system hardening). Before #1690 a ternary degraded to
    // `Expression.Raw` because the expression parser had no ternary form â€”
    // and since #1186 a `Raw` node contributes zero effects, so an
    // effectful branch (`cond ? readFile() : x`) reached codegen
    // effect-free. Structuring it here lets the effect checker, typecheck
    // walker, capture/ownership analysis, and lambda-capture rewrite all
    // recurse into the three children. The formatter serializes it back to
    // `(cond) ? (then) : (else)` â€” the exact text the lowering shadow
    // re-parser (`parse_ternary_expression`) already handles, so no new
    // lowering arm is needed. `span` is the last field per the variant
    // convention so positional GEP indexing for prior variants stays stable.
    Conditional {
        condition: Expression,
        then_value: Expression,
        else_value: Expression,
        span: SourceSpan?
    },
    // Assignment-as-expression `target <op> rhs` (issue #1627/#1741, epic
    // #1180, effect-system hardening). Assignment has no AST node before
    // #1627 â€” `a = b` parsed as `ExpressionStatement { Raw{"a = b"} }` because
    // `=` carried precedence -1 and was never climbed, so the leftover `= b`
    // tokens degraded the whole expression to `Raw`. Since #1186 a `Raw`
    // contributes zero effects, so an effectful target/rhs (`arr[io()] = x`,
    // `a = readFile()`) reached codegen effect-free. Structuring it lets the
    // effect checker, typecheck walker, ownership analysis, and lambda-capture
    // rewrite all recurse into `target` and `rhs` (the capture walk in
    // typecheck_captures.sfn DELIBERATELY does not descend â€” see its #687
    // note). The
    // formatter serializes it back to `<target> <operator> <rhs>` â€” the
    // exact text the lowering `parse_assignment_expression` already consumes
    // (string-scan), so no new lowering arm is needed. `operator` is `"="` or
    // a compound (`"+="`, `"-="`, `"*="`, `"/="`), keeping the node lossless.
    //
    // The rvalue is named `rhs`, NOT `value` (#1741): enum field reads slot by
    // field NAME with a single type per name (the union payload is rendered
    // per-name and read via a variant-filtered select chain). `value` is
    // already `string` in `NumberLiteral`/`StringLiteral`/`BooleanLiteral`, so
    // an `Expression`-typed `value` here collides on that slot and corrupts
    // reads of the existing string `value` reached through a nested operand
    // (`Unary{ -, NumberLiteral }.operand.value` came back empty, dropping
    // negative-int capture type inference â€” the regression that sank the first
    // #1741 attempt). `rhs`/`target` are unique names in this enum, so they
    // take their own slots and the collision is gone. `span` stays last.
    Assignment {
        target: Expression,
        operator: string,
        rhs: Expression,
        span: SourceSpan?
    },
    // Concurrency frontend nodes (M4.0, epic #965, issue #1079). Parse-only
    // targets for the structured-concurrency surface; parsing, type rules,
    // effect-checking, and lowering land in follow-up issues. Runtime
    // semantics are specified in docs/proposals/0025-native-runtime-architecture.md Â§3.7 (`#37-scheduler-and-concurrency`). Spans
    // are appended last per the variant convention above so positional GEP
    // indexing stays stable. `spawn`/`await` are prefix operators over an
    // expression (mirroring Unary/TryOperator's `operand`); `channel`,
    // `parallel`, and `serve` are value-producing constructs.
    //
    // `spawn <expr>` â€” enqueue a task, yields a future (Â§2.6.2). `kind`
    // tags the monomorphized future kind (one of void/number/int/bool/
    // string/ptr; "" when not statically resolvable) so emit-native
    // (#1084) selects the matching `spawn_*` runtime helper. Appended
    // after `span` to keep existing positional GEP reads stable; the
    // parser supplies "" by default (mirroring the `captures` roll-in).
    Spawn { operand: Expression, span: SourceSpan?, kind: string },
    // `await <expr>` â€” block on a future, yields its result (Â§2.6.3).
    // `kind` tags the awaited future's element kind ("" until resolved).
    Await { operand: Expression, span: SourceSpan?, kind: string },
    // `channel<T>(capacity)` â€” construct a channel; both the element type
    // and capacity are optional so the parser can defer to inference and
    // an unbuffered default (Â§2.6.4). `kind` tags the monomorphized
    // element kind (derived from `element_type` when present, else "").
    Channel {
        element_type: TypeAnnotation?,
        capacity: Expression?,
        span: SourceSpan?,
        kind: string
    },
    // `parallel [t1, t2, ...]` â€” fan out tasks, await all, yield results in
    // order (Â§2.6.5). A convenience built on spawn+await.
    Parallel { tasks: Expression[], span: SourceSpan? },
    // `serve(handler, port)` â€” accept loop dispatching to the thread pool;
    // `port` is optional to allow a configured default (Â§2.6.6).
    Serve { handler: Expression, port: Expression?, span: SourceSpan? },
    // A parser-originated diagnostic node (issue #1531). The expression
    // parser has no diagnostic channel of its own â€” a `success: false`
    // result is silently swallowed into `Raw` by `expression_from_tokens`,
    // so a malformed construct never reaches the user as an error. When an
    // arm detects syntax that must fail closed (e.g. the internal-only
    // `spawn:<type>` operator form), it emits this node instead, carrying
    // the human-readable message. The typecheck walk turns it into a real
    // `Diagnostic` (E0816), so `sfn check` exits non-zero. `message` is the
    // full diagnostic text; `span` locates the offending token.
    ParseError { message: string, span: SourceSpan? },
    Raw { text: string, span: SourceSpan? }
}

struct Parameter {
    name: string;
    type_annotation: TypeAnnotation?;
    default_value: Expression?;
    mutable: boolean;
    span: SourceSpan?;
}

struct WithClause {
    expression: Expression;
}

struct ObjectField {
    name: string;
    value: Expression;
}

struct ElseBranch {
    statement: Statement?;
    body: Block?;
}

struct ForClause {
    target: Expression;
    iterable: Expression;
    tokens: Token[];
}

struct MatchCase {
    pattern: Expression;
    guard: Expression?;
    body: Block;
}

struct FieldDeclaration {
    name: string;
    type_annotation: TypeAnnotation;
    mutable: boolean;
    name_span: SourceSpan?;
}

struct MethodDeclaration {
    signature: FunctionSignature;
    body: Block;
    decorators: Decorator[];
}

struct EnumVariant {
    name: string;
    fields: FieldDeclaration[];
    name_span: SourceSpan?;
}

struct FunctionSignature {
    name: string;
    is_async: boolean;
    parameters: Parameter[];
    return_type: TypeAnnotation?;
    effects: string[];
    type_parameters: TypeParameter[];
    name_span: SourceSpan?;
}

// A data-field-shaped interface member (`name: Type`) captured by the
// interface member loop so typecheck can reject it with `E0827`
// (SFEP-0039 Â§3.1). Interfaces are method-only contracts; a field
// belongs on a concrete `struct` that implements the interface, not on
// the interface itself.
struct InterfaceFieldMember {
    name: string;
    name_span: SourceSpan?;
}

struct TestDeclaration {
    name: string;
    body: Block;
    effects: string[];
    decorators: Decorator[];
    hook_kind: string;
}

struct Decorator {
    name: string;
    arguments: DecoratorArgument[];
}

struct DecoratorArgument {
    name: string?;
    expression: Expression;
}

fn decorator_names(decorators: Decorator[]) -> string[] {
    let mut names: string[] = [];
    let mut index: int = 0;
    loop {
        if index >= decorators.length { break; }
        names.push(decorators[index].name);
        index += 1;
    }
    return names;
}

// The compiler-recognized marker name a function declaration carries to
// declare itself decorator-eligible (`@decorator`). It is an ordinary
// decorator on the declaration, not a keyword (SFEP-0023 Â§4.1), so
// recognition is a plain name match rather than a grammar addition.
fn decorator_marker_name() -> string { return "decorator"; }

// True when `decorators` contains the `@decorator` marker, i.e. the
// declaration is an exported decorator definition (SFEP-0023 Â§4.2). Lives
// here beside `decorator_names` because `ast` defines `Decorator`, so the
// `Decorator[]` walk is layout-safe (the seed-opaque hazard the
// `decorator_semantics.sfn` header warns about only applies to modules
// that do not define the struct).
fn has_decorator_marker(decorators: Decorator[]) -> boolean {
    let mut index: int = 0;
    loop {
        if index >= decorators.length { break; }
        if decorators[index].name == decorator_marker_name() { return true; }
        index += 1;
    }
    return false;
}

struct ImportSpecifier {
    name: string;
    alias: string?;
}

struct ExportSpecifier {
    name: string;
    alias: string?;
}

enum Statement {
    ImportDeclaration {
        import_specifiers: ImportSpecifier[];
        source: string;
    },
    ExportDeclaration {
        export_specifiers: ExportSpecifier[];
        source: string;
    },
    VariableDeclaration {
        name: string;
        mutable: boolean;
        is_thread_local: boolean;
        type_annotation: TypeAnnotation?;
        initializer: Expression?;
        span: SourceSpan?;
        initializer_span: SourceSpan?;
    },
    TestDeclaration {
        name: string;
        name_span: SourceSpan?;
        body: Block;
        effects: string[];
        decorators: Decorator[];
        hook_kind: string;
    },
    FunctionDeclaration {
        signature: FunctionSignature;
        body: Block;
        decorators: Decorator[];
        is_unsafe: boolean;
    },
    ExternFunctionDeclaration {
        signature: FunctionSignature;
        unsafe: boolean;
        decorators: Decorator[];
    },
    ExternVarDeclaration {
        name: string;
        type_annotation: TypeAnnotation;
        name_span: SourceSpan?;
        decorators: Decorator[];
        // Defining-global initializer for `extern var NAME: T = init;`
        // (#1436); null for a bare reference declaration (#1313). Named
        // `init_value`, NOT `initializer`, deliberately: `VariableDeclaration`
        // already has a field `initializer: Expression?`, and a same-named
        // field with a *different* type on another `Statement` variant makes
        // enum member-access type resolution mis-infer `statement.initializer`
        // (it resolved to the default `double`, miscompiling unrelated passes).
        init_value: string?;
    },
    StructDeclaration {
        name: string;
        name_span: SourceSpan?;
        type_parameters: TypeParameter[];
        implements_types: TypeAnnotation[];
        fields: FieldDeclaration[];
        methods: MethodDeclaration[];
        decorators: Decorator[];
    },
    TypeAliasDeclaration {
        name: string;
        name_span: SourceSpan?;
        type_parameters: TypeParameter[];
        aliased_type: TypeAnnotation;
        decorators: Decorator[];
    },
    InterfaceDeclaration {
        name: string;
        name_span: SourceSpan?;
        type_parameters: TypeParameter[];
        members: FunctionSignature[];
        decorators: Decorator[];
        field_members: InterfaceFieldMember[];
    },
    EnumDeclaration {
        name: string;
        name_span: SourceSpan?;
        type_parameters: TypeParameter[];
        variants: EnumVariant[];
        decorators: Decorator[];
    },
    WithStatement {
        clauses: WithClause[];
        body: Block;
        decorators: Decorator[];
    },
    ForStatement {
        clause: ForClause;
        body: Block;
        decorators: Decorator[];
    },
    LoopStatement {
        body: Block;
        decorators: Decorator[];
    },
    BreakStatement,
    ContinueStatement,
    MatchStatement {
        expression: Expression;
        cases: MatchCase[];
        decorators: Decorator[];
    },
    IfStatement {
        condition: Expression;
        then_block: Block;
        else_branch: ElseBranch?;
        decorators: Decorator[];
    },
    BlockStatement {
        body: Block;
        is_unsafe: boolean;
    },
    ReturnStatement {
        expression: Expression?;
        span: SourceSpan?;
    },
    ThrowStatement {
        expression: Expression;
        span: SourceSpan?;
    },
    TryStatement {
        try_block: Block;
        catch_name: string?;
        catch_name_token: Token?;
        catch_block: Block?;
        finally_block: Block?;
    },
    ExpressionStatement {
        expression: Expression;
        span: SourceSpan?;
    },
    // `routine { ... }` â€” structured-concurrency block scope (M4.0, epic
    // #965, issue #1079). Parse-only target; the runtime nursery semantics
    // land in follow-up issues (docs/proposals/0025-native-runtime-architecture.md `#37-scheduler-and-concurrency`).
    // Shaped like LoopStatement (block body + decorators) since the v0
    // surface is a bare block scope that yields no value.
    RoutineStatement {
        body: Block;
        decorators: Decorator[];
    },
    // The parser's error-recovery node. `code`/`message` are empty for a
    // genuinely unrecognized top-level construct (rendered as the generic
    // `E0500`), and carry a precise parse code (`E05xx`) + message when a
    // committed declaration production abandons a malformed declaration â€”
    // e.g. a broken parameter list, a `let` with no initializer, or a struct
    // field with no type (SFN-18). `sfn check` mints the diagnostic and the
    // build gate rejects it before lowering.
    Unknown {
        tokens: Token[];
        text: string;
        code: string;
        message: string;
    }
}
