// compiler/src/ast.sfn
//
// Shared abstract syntax tree definitions for the Sailfin self-hosting effort.
// The structures mirror a pragmatic subset of the bootstrap compiler AST so we
// can progressively port parsing and analysis logic into Sailfin.
import { Token } from "./token";

struct Program {
    statements: Statement[];
}

struct TypeAnnotation {
    text: string;
}

struct TypeParameter {
    name: string;
    bound: TypeAnnotation?;
    span: SourceSpan?;
}

struct Block {
    tokens: Token[];
    text: string;
    statements: Statement[];
}

struct SourceSpan {
    start_line: int;
    start_column: int;
    end_line: int;
    end_column: int;
}

// Inferred lambda capture descriptor populated by the typechecker's
// free-variable walk (issue #458, A1 of #450 M1.5). One entry per
// distinct enclosing-scope name referenced from the lambda body, in
// first-use order — deterministic so stage A2 (env-struct emit) and
// stage A3 (call-site dispatch) can index by position. `type_text`
// echoes the enclosing binding's annotation when available
// (parameters and `let x: T = ...`); empty otherwise. `by_value`
// flips false for non-primitive type annotations so the LLVM lowering
// in stage A2 knows to emit a heap-pointer slot. `mutable` records
// whether the enclosing binding was declared `let mut`, so a future
// mutating-capture pass can reject writes to immutable bindings.
struct Capture {
    name: string;
    type_text: string;
    by_value: boolean;
    mutable: boolean;
    span: SourceSpan?;
}

enum Expression {
    // Per-expression source spans land on the variants the effect
    // checker needs for call-site attribution (B1, see
    // docs/proposals/check-architecture.md). Spans are appended as
    // the last field so the seed compiler's positional GEP indexing
    // doesn't shift for existing field reads. Variants without a
    // span field stay layout-stable.
    Identifier { name: string, span: SourceSpan? },
    NumberLiteral { value: string },
    StringLiteral { value: string },
    BooleanLiteral { value: string },
    NullLiteral,
    Unary { operator: string, operand: Expression },
    Binary { operator: string, left: Expression, right: Expression },
    Member { object: Expression, member: string, span: SourceSpan? },
    Call {
        callee: Expression,
        arguments: Expression[],
        span: SourceSpan?
    },
    Index { sequence: Expression, index: Expression },
    Array { elements: Expression[] },
    Object { fields: ObjectField[] },
    Struct { type_name: string[], fields: ObjectField[] },
    Lambda {
        parameters: Parameter[],
        body: Block,
        return_type: TypeAnnotation?,
        // Captures are appended last so the seed compiler's positional
        // GEP indexing for the existing fields stays stable. Today the
        // parser always emits an empty list and the inferred capture
        // sets live separately as `LambdaCaptureRecord[]` returned by
        // `analyze_lambda_captures` in `typecheck_captures`. Records
        // are keyed back to a specific Lambda node by the body's
        // opening `{` token (`body.tokens[0]` line/column). A future
        // pass can copy each record's `captures` onto the matching
        // node so this field becomes the single source of truth; for
        // now stage A2 / A3 should look up the record by body span.
        captures: Capture[]
    },
    Range { start: Expression, end: Expression },
    Cast { operand: Expression, target_type: TypeAnnotation },
    // Postfix `?` error-propagation operator (R.1, epic #371). Distinct
    // from the statement-level `TryStatement`. Type rules and emission
    // land in R.3 / R.4 — today this is parse-only.
    TryOperator { operand: Expression, span: SourceSpan? },
    // Concurrency frontend nodes (M4.0, epic #965, issue #1079). Parse-only
    // targets for the structured-concurrency surface; parsing, type rules,
    // effect-checking, and lowering land in follow-up issues. Runtime
    // semantics are specified in docs/runtime_architecture.md §2.6. Spans
    // are appended last per the variant convention above so positional GEP
    // indexing stays stable. `spawn`/`await` are prefix operators over an
    // expression (mirroring Unary/TryOperator's `operand`); `channel`,
    // `parallel`, and `serve` are value-producing constructs.
    //
    // `spawn <expr>` — enqueue a task, yields a future (§2.6.2). `kind`
    // tags the monomorphized future kind (one of void/number/int/bool/
    // string/ptr; "" when not statically resolvable) so emit-native
    // (#1084) selects the matching `spawn_*` runtime helper. Appended
    // after `span` to keep existing positional GEP reads stable; the
    // parser supplies "" by default (mirroring the `captures` roll-in).
    Spawn { operand: Expression, span: SourceSpan?, kind: string },
    // `await <expr>` — block on a future, yields its result (§2.6.3).
    // `kind` tags the awaited future's element kind ("" until resolved).
    Await { operand: Expression, span: SourceSpan?, kind: string },
    // `channel<T>(capacity)` — construct a channel; both the element type
    // and capacity are optional so the parser can defer to inference and
    // an unbuffered default (§2.6.4). `kind` tags the monomorphized
    // element kind (derived from `element_type` when present, else "").
    Channel {
        element_type: TypeAnnotation?,
        capacity: Expression?,
        span: SourceSpan?,
        kind: string
    },
    // `parallel [t1, t2, ...]` — fan out tasks, await all, yield results in
    // order (§2.6.5). A convenience built on spawn+await.
    Parallel { tasks: Expression[], span: SourceSpan? },
    // `serve(handler, port)` — accept loop dispatching to the thread pool;
    // `port` is optional to allow a configured default (§2.6.6).
    Serve { handler: Expression, port: Expression?, span: SourceSpan? },
    Raw { text: string, span: SourceSpan? }
}

struct Parameter {
    name: string;
    type_annotation: TypeAnnotation?;
    default_value: Expression?;
    mutable: boolean;
    span: SourceSpan?;
}

struct WithClause {
    expression: Expression;
}

struct ObjectField {
    name: string;
    value: Expression;
}

struct ElseBranch {
    statement: Statement?;
    body: Block?;
}

struct ForClause {
    target: Expression;
    iterable: Expression;
    tokens: Token[];
}

struct MatchCase {
    pattern: Expression;
    guard: Expression?;
    body: Block;
}

struct FieldDeclaration {
    name: string;
    type_annotation: TypeAnnotation;
    mutable: boolean;
    name_span: SourceSpan?;
}

struct MethodDeclaration {
    signature: FunctionSignature;
    body: Block;
    decorators: Decorator[];
}

struct EnumVariant {
    name: string;
    fields: FieldDeclaration[];
    name_span: SourceSpan?;
}

struct FunctionSignature {
    name: string;
    is_async: boolean;
    parameters: Parameter[];
    return_type: TypeAnnotation?;
    effects: string[];
    type_parameters: TypeParameter[];
    name_span: SourceSpan?;
}

struct TestDeclaration {
    name: string;
    body: Block;
    effects: string[];
    decorators: Decorator[];
    hook_kind: string;
}

struct Decorator {
    name: string;
    arguments: DecoratorArgument[];
}

struct DecoratorArgument {
    name: string?;
    expression: Expression;
}

fn decorator_names(decorators: Decorator[]) -> string[] {
    let mut names: string[] = [];
    let mut index: int = 0;
    loop {
        if index >= decorators.length { break; }
        names.push(decorators[index].name);
        index += 1;
    }
    return names;
}

struct ImportSpecifier {
    name: string;
    alias: string?;
}

struct ExportSpecifier {
    name: string;
    alias: string?;
}

enum Statement {
    ImportDeclaration {
        import_specifiers: ImportSpecifier[];
        source: string;
    },
    ExportDeclaration {
        export_specifiers: ExportSpecifier[];
        source: string;
    },
    VariableDeclaration {
        name: string;
        mutable: boolean;
        is_thread_local: boolean;
        type_annotation: TypeAnnotation?;
        initializer: Expression?;
        span: SourceSpan?;
        initializer_span: SourceSpan?;
    },
    TestDeclaration {
        name: string;
        name_span: SourceSpan?;
        body: Block;
        effects: string[];
        decorators: Decorator[];
        hook_kind: string;
    },
    FunctionDeclaration {
        signature: FunctionSignature;
        body: Block;
        decorators: Decorator[];
        is_unsafe: boolean;
    },
    ExternFunctionDeclaration {
        signature: FunctionSignature;
        unsafe: boolean;
        decorators: Decorator[];
    },
    ExternVarDeclaration {
        name: string;
        type_annotation: TypeAnnotation;
        initializer: string?;
        name_span: SourceSpan?;
        decorators: Decorator[];
    },
    StructDeclaration {
        name: string;
        name_span: SourceSpan?;
        type_parameters: TypeParameter[];
        implements_types: TypeAnnotation[];
        fields: FieldDeclaration[];
        methods: MethodDeclaration[];
        decorators: Decorator[];
    },
    TypeAliasDeclaration {
        name: string;
        name_span: SourceSpan?;
        type_parameters: TypeParameter[];
        aliased_type: TypeAnnotation;
        decorators: Decorator[];
    },
    InterfaceDeclaration {
        name: string;
        name_span: SourceSpan?;
        type_parameters: TypeParameter[];
        members: FunctionSignature[];
        decorators: Decorator[];
    },
    EnumDeclaration {
        name: string;
        name_span: SourceSpan?;
        type_parameters: TypeParameter[];
        variants: EnumVariant[];
        decorators: Decorator[];
    },
    WithStatement {
        clauses: WithClause[];
        body: Block;
        decorators: Decorator[];
    },
    ForStatement {
        clause: ForClause;
        body: Block;
        decorators: Decorator[];
    },
    LoopStatement {
        body: Block;
        decorators: Decorator[];
    },
    BreakStatement,
    ContinueStatement,
    MatchStatement {
        expression: Expression;
        cases: MatchCase[];
        decorators: Decorator[];
    },
    IfStatement {
        condition: Expression;
        then_block: Block;
        else_branch: ElseBranch?;
        decorators: Decorator[];
    },
    BlockStatement {
        body: Block;
        is_unsafe: boolean;
    },
    ReturnStatement {
        expression: Expression?;
        span: SourceSpan?;
    },
    ThrowStatement {
        expression: Expression;
        span: SourceSpan?;
    },
    TryStatement {
        try_block: Block;
        catch_name: string?;
        catch_name_token: Token?;
        catch_block: Block?;
        finally_block: Block?;
    },
    ExpressionStatement {
        expression: Expression;
        span: SourceSpan?;
    },
    // `routine { ... }` — structured-concurrency block scope (M4.0, epic
    // #965, issue #1079). Parse-only target; the runtime nursery semantics
    // land in follow-up issues (docs/runtime_architecture.md §2.6.7).
    // Shaped like LoopStatement (block body + decorators) since the v0
    // surface is a bare block scope that yields no value.
    RoutineStatement {
        body: Block;
        decorators: Decorator[];
    },
    Unknown {
        tokens: Token[];
        text: string;
    }
}
