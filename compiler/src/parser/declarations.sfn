// compiler/src/parser/declarations.sfn
//
// Top-level declaration parsing - functions, structs, enums, interfaces,
// imports, exports, models, pipelines, tools, tests, and type aliases.
import {
    Block,
    Decorator,
    DecoratorArgument,
    EnumVariant,
    ExportSpecifier,
    Expression,
    FieldDeclaration,
    FunctionSignature,
    ImportSpecifier,
    InterfaceFieldMember,
    MethodDeclaration,
    Parameter,
    Statement,
    TypeAnnotation,
    TypeParameter
} from "../ast";
import {
    char_at,
    char_code,
    normalize_number_literal_value,
    strings_equal,
    substring
} from "../string_utils";
import { Token, TokenKind } from "../token";
import { expression_from_tokens, normalize_expression } from "./expressions";
import { parse_block } from "./statements";
import {
    advance_to_symbol,
    append_token,
    collect_parenthesized,
    collect_type_annotation_until,
    collect_until,
    consume_keyword,
    consume_symbol,
    filter_trivia,
    find_top_level_colon,
    find_top_level_symbol,
    identifier_matches,
    identifier_text,
    is_end_of_file,
    parser_advance_raw,
    parser_peek_raw,
    skip_enum_variant_entry,
    skip_struct_member,
    skip_trailing_comma,
    skip_trivia,
    source_span_from_tokens,
    split_token_slices_by_comma,
    split_tokens_by_comma,
    string_literal_value,
    symbol_matches,
    token_slice,
    tokens_to_text,
    trim_token_edges
} from "./token_utils";
import {
    BlockParseResult,
    DecoratorParseResult,
    EffectParseResult,
    EnumVariantParseResult,
    ImplementsParseResult,
    InterfaceMemberParseResult,
    MethodParseResult,
    NamedSpecifier,
    ParameterListParseResult,
    ParameterParseResult,
    Parser,
    SpecifierListParseResult,
    StatementParseResult,
    StructFieldParseResult,
    TypeParameterParseResult,
    TypeSeparatorParseResult
} from "./types";
import {
    looks_like_number,
    normalize_test_name,
    strip_loose_quotes,
    strip_surrounding_quotes,
    trim_text
} from "./utils";

// ============================================================================
// Type Separator
// ============================================================================
fn consume_annotation_separator(parser: Parser) -> TypeSeparatorParseResult {
    let token = parser_peek_raw(parser);
    if symbol_matches(token, ":") {
        return TypeSeparatorParseResult {
            parser: parser_advance_raw(parser),
            found: true
        };
    }
    return TypeSeparatorParseResult { parser: parser, found: false };
}

fn consume_return_type_separator(parser: Parser) -> TypeSeparatorParseResult {
    let token = parser_peek_raw(parser);
    if symbol_matches(token, "->") {
        return TypeSeparatorParseResult {
            parser: parser_advance_raw(parser),
            found: true
        };
    }
    // Tolerate a lexer/runtime bug where `->` is split into `-` and `>`.
    if symbol_matches(token, "-") {
        let mut current = parser_advance_raw(parser);
        let maybe_gt = parser_peek_raw(current);
        if symbol_matches(maybe_gt, ">") {
            current = parser_advance_raw(current);
        }
        return TypeSeparatorParseResult { parser: current, found: true };
    }
    return TypeSeparatorParseResult { parser: parser, found: false };
}

// ============================================================================
// Decorator Parsing
// ============================================================================
fn parse_decorators(parser: Parser) -> DecoratorParseResult {
    let mut current = parser;
    let mut decorators: Decorator[] = [];

    loop {
        current = skip_trivia(current);
        let token = parser_peek_raw(current);
        if !symbol_matches(token, "@") { break; }

        let decorator_start = current;
        current = parser_advance_raw(current);
        current = skip_trivia(current);

        let name_token = parser_peek_raw(current);
        if name_token.kind.variant != "Identifier" {
            current = decorator_start;
            break;
        }

        let name = identifier_text(name_token);
        current = parser_advance_raw(current);
        current = skip_trivia(current);

        let mut decorator_arguments: DecoratorArgument[] = [];
        let after = parser_peek_raw(current);
        if symbol_matches(after, "(") {
            let paren_result = collect_parenthesized(current);
            if paren_result.success {
                let mut segment_tokens: Token[] = [];
                let mut angle: int = 0;
                let mut paren: int = 0;
                let mut brace: int = 0;
                let mut bracket: int = 0;

                let mut index: int = 0;
                loop {
                    if index >= paren_result.tokens.length { break; }
                    let tok = paren_result.tokens[index];
                    if tok.kind.variant == "Symbol" {
                        let sym = tok.lexeme;
                        if strings_equal(sym, "<") { angle += 1; } else if strings_equal(sym, ">") {
                            if angle > 0 { angle -= 1; }
                        } else if strings_equal(sym, "(") { paren += 1; } else if strings_equal(sym, ")") {
                            if paren > 0 { paren -= 1; }
                        } else if strings_equal(sym, "{") { brace += 1; } else if strings_equal(sym, "}") {
                            if brace > 0 { brace -= 1; }
                        } else if strings_equal(sym, "[") { bracket += 1; } else if strings_equal(sym, "]") {
                            if bracket > 0 { bracket -= 1; }
                        }

                        let mut _let397: boolean = false;
                        if angle == 0 {
                            if paren == 0 {
                                if brace == 0 {
                                    if bracket == 0 { _let397 = true; }
                                }
                            }
                        }
                        let at_top_level = _let397;
                        if strings_equal(sym, ",") {
                            if at_top_level {
                                let trimmed_tokens = trim_token_edges(segment_tokens);
                                let argument = parse_decorator_argument(trimmed_tokens);
                                if argument != null {
                                    decorator_arguments = append_decorator_argument(decorator_arguments, argument);
                                }
                                segment_tokens = [];
                                index += 1;
                                continue;
                            }
                        }
                    }
                    segment_tokens = append_token(segment_tokens, tok);
                    index += 1;
                }

                let final_tokens = trim_token_edges(segment_tokens);
                let trailing_argument = parse_decorator_argument(final_tokens);
                if trailing_argument != null {
                    decorator_arguments = append_decorator_argument(decorator_arguments, trailing_argument);
                }
                current = paren_result.parser;
            } else {
                current = decorator_start;
                break;
            }
        }

        decorators = append_decorator(decorators, Decorator {
            name: name, arguments: decorator_arguments
        });
    }

    return DecoratorParseResult { parser: current, decorators: decorators };
}

fn parse_decorator_argument(tokens: Token[]) -> DecoratorArgument? {
    if tokens.length == 0 { return null; }

    let colon_index = find_top_level_colon(tokens);
    if colon_index == -1 {
        let trimmed_tokens = trim_token_edges(tokens);
        if trimmed_tokens.length == 0 { return null; }
        let expr = normalize_expression(trimmed_tokens, expression_from_tokens(trimmed_tokens));
        return DecoratorArgument { name: null, expression: expr };
    }

    let name_tokens = trim_token_edges(token_slice(tokens, 0, colon_index));
    let value_tokens = trim_token_edges(token_slice(tokens, colon_index + 1, tokens.length));

    if value_tokens.length == 0 { return null; }

    let name_text = trim_text(tokens_to_text(name_tokens));
    if name_text.length == 0 { return null; }

    let mut expr = normalize_expression(value_tokens, expression_from_tokens(value_tokens));
    if expr.variant == "Raw" {
        let raw_text = trim_text(tokens_to_text(value_tokens));
        let mut _if398: boolean = false;
        if raw_text.length >= 2 {
            if char_at(raw_text, 0) == "\"" {
                if char_at(raw_text, raw_text.length - 1) == "\"" {
                    _if398 = true;
                }
            }
        }
        if _if398 {
            let literal = strip_surrounding_quotes(raw_text);
            expr = Expression.StringLiteral { value: literal };
        } else if raw_text == "true" {
            expr = Expression.BooleanLiteral { value: "true" };
        } else if raw_text == "false" {
            expr = Expression.BooleanLiteral { value: "false" };
        } else if looks_like_number(raw_text) {
            expr = Expression.NumberLiteral {
                value: normalize_number_literal_value(raw_text)
            };
        }
    }
    return DecoratorArgument { name: name_text, expression: expr };
}

// ============================================================================
// Effect List Parsing
// ============================================================================
fn parse_effect_list(initial_parser: Parser) -> EffectParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    let token = parser_peek_raw(parser);
    if !symbol_matches(token, "!") {
        return EffectParseResult { parser: parser, effects: [] };
    }

    parser = parser_advance_raw(parser);
    parser = skip_trivia(parser);
    parser = consume_symbol(parser, "[");

    let mut effects: string[] = [];
    parser = skip_trivia(parser);
    loop {
        let current = parser_peek_raw(parser);
        if symbol_matches(current, "]") {
            parser = parser_advance_raw(parser);
            break;
        }
        if current.kind.variant == "Identifier" {
            let mut effect = identifier_text(current);
            parser = parser_advance_raw(parser);
            // Accumulate a dotted sub-effect name (`io.fs`, `io.fs.read`)
            // into ONE effect string (SFEP-0017 D1). A dotted name is
            // contiguous — `io` `.` `fs` with no intervening trivia — so
            // peek raw for the `.` before skipping trivia. Prior behaviour
            // let the generic fallback discard the `.` and split `io.fs`
            // into two atoms `["io","fs"]`; the E0404 root-recognition
            // pass now depends on the whole dotted string reaching it.
            loop {
                let dot = parser_peek_raw(parser);
                if !symbol_matches(dot, ".") { break; }
                let after_dot = parser_advance_raw(parser);
                let segment = parser_peek_raw(after_dot);
                if segment.kind.variant != "Identifier" {
                    // Malformed `io.` with no trailing segment: stop
                    // accumulating past the `.` and let the outer loop
                    // resync on the next `]`/`,` terminator.
                    parser = after_dot;
                    break;
                }
                effect = effect + "." + identifier_text(segment);
                parser = parser_advance_raw(after_dot);
            }
            effects.push(effect);
            parser = skip_trivia(parser);
            let separator = parser_peek_raw(parser);
            if symbol_matches(separator, ",") {
                parser = parser_advance_raw(parser);
                parser = skip_trivia(parser);
                continue;
            }
            continue;
        }
        parser = parser_advance_raw(parser);
        parser = skip_trivia(parser);
    }

    return EffectParseResult { parser: parser, effects: effects };
}

// ============================================================================
// Type Parameter Clause
// ============================================================================
// True when `sym` is a run of one or more `>` characters (`>`, `>>`, `>>>`) —
// the lexer glues adjacent closing angle brackets into a single shift token.
fn _is_gt_run(sym: string) -> boolean {
    if sym.length == 0 { return false; }
    let mut i: int = 0;
    loop {
        if i >= sym.length { break; }
        if sym[i] != ">" { return false; }
        i += 1;
    }
    return true;
}

// A synthetic single `>` symbol token, positioned at `src`, used to unglue a
// `>>` shift token back into the individual angle closes it represents.
fn _gt_token(src: Token) -> Token {
    return Token {
        kind: TokenKind.Symbol(),
        lexeme: ">",
        line: src.line,
        column: src.column
    };
}

fn parse_type_parameter_clause(parser: Parser) -> TypeParameterParseResult {
    let mut current = skip_trivia(parser);
    let token = parser_peek_raw(current);
    if !symbol_matches(token, "<") {
        return TypeParameterParseResult { parser: parser, parameters: [] };
    }

    current = parser_advance_raw(current);
    let mut collected: Token[] = [];
    let mut depth: int = 1;

    loop {
        let tok = parser_peek_raw(current);
        if tok.kind.variant == "EndOfFile" { break; }
        if tok.kind.variant == "Symbol" {
            let sym = tok.lexeme;
            if strings_equal(sym, "<") {
                depth += 1;
                collected = append_token(collected, tok);
                current = parser_advance_raw(current);
                continue;
            }
            if _is_gt_run(sym) {
                // A `>`-run token (`>`, `>>`, …) closes one angle level per
                // `>`. The lexer glues the closing brackets of nested generic
                // bounds like `From<int>>` into a single `>>` shift token; the
                // inner `>` (closing `From<int>`) belongs in the collected
                // bound text, while the `>` that returns depth to 0 closes the
                // type-parameter clause and stops the scan. Ungluing it here
                // keeps a valid `fn f<E: From<int>>(...)` from over-consuming
                // into the parameter list (SFN-18).
                let run = sym.length;
                let mut gi: int = 0;
                let mut clause_closed = false;
                loop {
                    if gi >= run { break; }
                    depth -= 1;
                    if depth == 0 {
                        clause_closed = true;
                        break;
                    }
                    collected = append_token(collected, _gt_token(tok));
                    gi += 1;
                }
                current = parser_advance_raw(current);
                if clause_closed { break; }
                continue;
            }
        }
        collected = append_token(collected, tok);
        current = parser_advance_raw(current);
    }

    let slices = split_token_slices_by_comma(collected);
    let mut parameters: TypeParameter[] = [];
    let mut index: int = 0;
    loop {
        if index >= slices.length { break; }
        let slice_tokens = trim_token_edges(slices[index]);
        if slice_tokens.length > 0 {
            let colon_index = find_top_level_symbol(slice_tokens, ":");
            let mut name_tokens = slice_tokens;
            let mut bound_tokens: Token[] = [];
            if colon_index != -1 {
                name_tokens = token_slice(slice_tokens, 0, colon_index);
                bound_tokens = token_slice(slice_tokens, colon_index + 1, slice_tokens.length);
            }

            let name_text = trim_text(tokens_to_text(name_tokens));
            if name_text.length > 0 {
                let mut bound: TypeAnnotation? = null;
                let bound_text = trim_text(tokens_to_text(bound_tokens));
                if bound_tokens.length > 0 {
                    if bound_text.length > 0 {
                        bound = TypeAnnotation { text: bound_text };
                    }
                }
                let name_span = source_span_from_tokens(name_tokens);
                let parameter = TypeParameter {
                    name: name_text,
                    bound: bound,
                    span: name_span
                };
                parameters.push(parameter);
            }
        }
        index += 1;
    }

    return TypeParameterParseResult {
        parser: current,
        parameters: parameters
    };
}

// ============================================================================
// Implements Clause
// ============================================================================
fn parse_implements_clause(parser: Parser) -> ImplementsParseResult {
    let mut current = skip_trivia(parser);
    if !identifier_matches(parser_peek_raw(current), "implements") {
        return ImplementsParseResult {
            parser: parser,
            types: [],
            found: false
        };
    }

    current = consume_keyword(current, "implements");
    current = skip_trivia(current);

    let capture = collect_until(current, ["{"]);
    current = capture.parser;

    let mut implements_types: TypeAnnotation[] = [];
    let entries = split_tokens_by_comma(capture.tokens);
    let mut index: int = 0;
    loop {
        if index >= entries.length { break; }
        let text = trim_text(entries[index]);
        if text.length > 0 {
            implements_types = append_type_annotation(implements_types, TypeAnnotation {
                text: text
            });
        }
        index += 1;
    }

    return ImplementsParseResult {
        parser: current,
        types: implements_types,
        found: true
    };
}

// ============================================================================
// Parameter Parsing
// ============================================================================
fn parse_parameter_list(initial_parser: Parser) -> ParameterListParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    let mut parameters: Parameter[] = [];
    let mut closed: boolean = false;

    let token = parser_peek_raw(parser);
    if symbol_matches(token, ")") {
        parser = parser_advance_raw(parser);
        return ParameterListParseResult {
            parser: parser,
            parameters: parameters,
            closed: true
        };
    }

    loop {
        let param_result = parse_single_parameter(parser);
        parser = param_result.parser;
        parameters = append_parameter(parameters, param_result.parameter);
        parser = skip_trivia(parser);
        let separator = parser_peek_raw(parser);
        if symbol_matches(separator, ",") {
            parser = parser_advance_raw(parser);
            parser = skip_trivia(parser);
            // A trailing comma before `)` closes the list (parity with call
            // arguments and struct fields); otherwise `parse_single_parameter`
            // would read `)` as a phantom parameter and the malformed-list
            // guard below would mint a misleading E0501. SFN-18.
            if symbol_matches(parser_peek_raw(parser), ")") {
                parser = parser_advance_raw(parser);
                closed = true;
                break;
            }
            continue;
        }
        if symbol_matches(separator, ")") {
            parser = parser_advance_raw(parser);
            closed = true;
            break;
        }
        // Any other separator — a stray token or EOF mid-list — means the
        // list was never closed with `)`. Stop WITHOUT consuming the token so
        // `parse_function` can resync at it and any independent declaration
        // that follows still parses (`fn broken( {\nfn good() {}` must not
        // swallow `fn good` as bogus parameters). SFN-18.
        break;
    }

    return ParameterListParseResult {
        parser: parser,
        parameters: parameters,
        closed: closed
    };
}

fn parse_single_parameter(initial_parser: Parser) -> ParameterParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    let tokens_ref = parser.tokens;
    let start_index = parser.index;

    let mut is_mutable = false;
    let token = parser_peek_raw(parser);
    if identifier_matches(token, "mut") {
        parser = parser_advance_raw(parser);
        is_mutable = true;
    }

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    parser = parser_advance_raw(parser);

    let mut type_annotation: TypeAnnotation? = null;
    parser = skip_trivia(parser);
    let separator_result = consume_annotation_separator(parser);
    if separator_result.found {
        parser = separator_result.parser;
        // Function parameter type annotation — angle-balanced so generic
        // args like `Result<T, E>` capture as one type. The default-value
        // capture below still uses plain `collect_until` because `<` /
        // `>` are comparison operators in expression position.
        let capture = collect_type_annotation_until(skip_trivia(parser), ["=", ",", ")"]);
        parser = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            type_annotation = TypeAnnotation { text: text };
        }
    }

    let mut default_value: Expression? = null;
    parser = skip_trivia(parser);
    let assign = parser_peek_raw(parser);
    if symbol_matches(assign, "=") {
        parser = parser_advance_raw(parser);
        let capture = collect_until(skip_trivia(parser), [",", ")"]);
        parser = capture.parser;
        default_value = expression_from_tokens(capture.tokens);
    }

    let end_index = parser.index;
    let parameter_tokens = token_slice(tokens_ref, start_index, end_index);
    let span = source_span_from_tokens(parameter_tokens);

    let parameter = Parameter {
        name: name,
        type_annotation: type_annotation,
        default_value: default_value,
        mutable: is_mutable,
        span: span
    };
    return ParameterParseResult { parser: parser, parameter: parameter };
}

// ============================================================================
// Import/Export Parsing
// ============================================================================
fn parse_import(initial_parser: Parser) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "import");
    let specifier_result = parse_specifier_list(parser);
    parser = specifier_result.parser;
    let import_specifiers = build_import_specifiers(specifier_result.specifiers);

    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "from");

    parser = skip_trivia(parser);
    let mut source = "";
    let token = parser_peek_raw(parser);
    let text = token.lexeme;
    let mut _if399: boolean = false;
    if text.length > 0 {
        if strings_equal(char_at(text, 0), "\"") { _if399 = true; }
    }
    if _if399 {
        source = string_literal_value(token);
        parser = parser_advance_raw(parser);
    } else {
        let capture = collect_until(parser, [";"]);
        parser = capture.parser;
        source = trim_text(tokens_to_text(capture.tokens));
        source = strip_surrounding_quotes(strip_loose_quotes(source));
    }

    parser = skip_trivia(parser);
    let import_terminator = parser_peek_raw(parser);
    if symbol_matches(import_terminator, ";") {
        parser = parser_advance_raw(parser);
    }

    let statement = Statement.ImportDeclaration {
        import_specifiers: import_specifiers,
        source: source
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_export(initial_parser: Parser) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "export");
    let specifier_result = parse_specifier_list(parser);
    parser = specifier_result.parser;
    let export_specifiers = build_export_specifiers(specifier_result.specifiers);

    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "from");

    parser = skip_trivia(parser);
    let mut source = "";
    let token = parser_peek_raw(parser);
    let text = token.lexeme;
    let mut _if400: boolean = false;
    if text.length > 0 {
        if strings_equal(char_at(text, 0), "\"") { _if400 = true; }
    }
    if _if400 {
        source = string_literal_value(token);
        parser = parser_advance_raw(parser);
    } else {
        let capture = collect_until(parser, [";"]);
        parser = capture.parser;
        source = trim_text(tokens_to_text(capture.tokens));
        source = strip_surrounding_quotes(strip_loose_quotes(source));
    }

    parser = skip_trivia(parser);
    let export_terminator = parser_peek_raw(parser);
    if symbol_matches(export_terminator, ";") {
        parser = parser_advance_raw(parser);
    }

    let statement = Statement.ExportDeclaration {
        export_specifiers: export_specifiers,
        source: source
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_specifier_list(initial_parser: Parser) -> SpecifierListParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    parser = consume_symbol(parser, "{");

    let mut spec_count: int = 0;
    let mut spec_names: string[] = [];
    let mut spec_aliases: string[] = [];
    parser = skip_trivia(parser);
    loop {
        let current = parser_peek_raw(parser);
        if symbol_matches(current, "}") {
            parser = parser_advance_raw(parser);
            break;
        }
        if current.kind.variant != "Identifier" { break; }

        let name = identifier_text(current);
        parser = parser_advance_raw(parser);
        parser = skip_trivia(parser);

        let mut alias: string? = null;
        let potential_alias = parser_peek_raw(parser);
        if identifier_matches(potential_alias, "as") {
            parser = consume_keyword(parser, "as");
            parser = skip_trivia(parser);
            let alias_token = parser_peek_raw(parser);
            if alias_token.kind.variant == "Identifier" {
                alias = identifier_text(alias_token);
                parser = parser_advance_raw(parser);
                parser = skip_trivia(parser);
            }
        }

        spec_names.push(name);
        if alias != null { spec_aliases.push(alias); } else {
            spec_aliases.push("");
        }
        spec_count += 1;

        let separator = parser_peek_raw(parser);
        if symbol_matches(separator, ",") {
            parser = parser_advance_raw(parser);
            parser = skip_trivia(parser);
            continue;
        }
    }

    // Build NamedSpecifier array from parallel string arrays
    // (avoids struct .push() which the first-pass binary can't lower)
    let mut specifiers: NamedSpecifier[] = [];
    let mut _si: int = 0;
    loop {
        if _si >= spec_count { break; }
        let mut _a: string? = null;
        if spec_aliases[_si].length > 0 { _a = spec_aliases[_si]; }
        specifiers = specifiers.concat([NamedSpecifier {
            name: spec_names[_si], alias: _a
        }]);
        _si += 1;
    }

    parser = skip_trivia(parser);
    if symbol_matches(parser_peek_raw(parser), "}") {
        parser = parser_advance_raw(parser);
    }

    return SpecifierListParseResult { parser: parser, specifiers: specifiers };
}

fn build_import_specifiers(values: NamedSpecifier[]) -> ImportSpecifier[] {
    let mut result: ImportSpecifier[] = [];
    let mut index: int = 0;
    loop {
        if index >= values.length { break; }
        let entry = values[index];
        result.push(ImportSpecifier {
            name: entry.name, alias: entry.alias
        });
        index += 1;
    }
    return result;
}

fn build_export_specifiers(values: NamedSpecifier[]) -> ExportSpecifier[] {
    let mut result: ExportSpecifier[] = [];
    let mut index: int = 0;
    loop {
        if index >= values.length { break; }
        let entry = values[index];
        result.push(ExportSpecifier {
            name: entry.name, alias: entry.alias
        });
        index += 1;
    }
    return result;
}

// ============================================================================
// Variable Declaration
// ============================================================================
fn parse_variable(initial_parser: Parser) -> StatementParseResult {
    return parse_variable_with_storage(initial_parser, false);
}

// Top-level `thread_local let mut` declarations dispatch through this entry
// point. The `thread_local` keyword is consumed by the caller; `is_thread_local`
// flips the AST flag so module-global lowering can emit
// `internal thread_local global` instead of `internal global`.
fn parse_variable_with_storage(initial_parser: Parser, is_thread_local: boolean) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    // Span of the whole declaration, for the malformed-declaration recovery
    // node (SFN-18). Anchors at the leading `let`.
    let decl_tokens_ref = parser.tokens;
    let decl_start_index = parser.index;
    let mut statement_tokens: Token[] = [];
    let let_token = parser_peek_raw(parser);
    statement_tokens = append_token(statement_tokens, let_token);
    parser = consume_keyword(parser, "let");

    let mut mutable_flag = false;
    parser = skip_trivia(parser);
    let mut_token = parser_peek_raw(parser);
    if identifier_matches(mut_token, "mut") {
        statement_tokens = append_token(statement_tokens, mut_token);
        parser = consume_keyword(parser, "mut");
        mutable_flag = true;
    }

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    statement_tokens = append_token(statement_tokens, name_token);
    let name = identifier_text(name_token);

    // A `let`/`let mut` binding must be followed by an identifier. When it is
    // not (`let{`, `let =`, `let 3`), the declaration is malformed: abandon it
    // as a precise `E0504` parse error instead of taking the stray token as the
    // binding name and emitting a garbage `VariableDeclaration`. Advancing past
    // the offending token keeps the block/recovery loop making progress
    // (SFN-384) — but never swallow the enclosing block's own closing `}`:
    // consuming it leaves the body unclosed, degrading this precise
    // `let`-anchored `E0504` to a coarser `E0505` on the function (SFN-390).
    // The leading `let` was already consumed, so leaving `}` in place still
    // guarantees forward progress; `parse_block` then closes the body and the
    // `E0504` survives.
    if name_token.kind.variant != "Identifier" {
        if !symbol_matches(name_token, "}") {
            parser = parser_advance_raw(parser);
        }
        let stmt = _malformed_declaration(decl_tokens_ref, decl_start_index, parser.index, "E0504", "parse error: expected an identifier after `let`");
        return StatementParseResult { parser: parser, statement: stmt };
    }

    parser = parser_advance_raw(parser);

    let mut type_annotation: TypeAnnotation? = null;
    parser = skip_trivia(parser);
    let separator_token = parser_peek_raw(parser);
    let separator_result = consume_annotation_separator(parser);
    if separator_result.found {
        statement_tokens = append_token(statement_tokens, separator_token);
        parser = separator_result.parser;
        let capture = collect_until(skip_trivia(parser), ["=", ";"]);
        let mut index: int = 0;
        loop {
            if index >= capture.tokens.length { break; }
            statement_tokens = append_token(statement_tokens, capture.tokens[index]);
            index += 1;
        }
        parser = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            type_annotation = TypeAnnotation { text: text };
        }
    }

    let mut initializer: Expression? = null;
    let mut initializer_span: SourceSpan? = null;
    let mut missing_init: boolean = false;
    parser = skip_trivia(parser);
    let assign = parser_peek_raw(parser);
    if symbol_matches(assign, "=") {
        statement_tokens = append_token(statement_tokens, assign);
        parser = parser_advance_raw(parser);
        let capture = collect_until(skip_trivia(parser), [";"]);
        let mut index: int = 0;
        loop {
            if index >= capture.tokens.length { break; }
            statement_tokens = append_token(statement_tokens, capture.tokens[index]);
            index += 1;
        }
        parser = capture.parser;
        if capture.tokens.length > 0 {
            initializer_span = source_span_from_tokens(capture.tokens);
            initializer = expression_from_tokens(capture.tokens);
        } else {
            // `let x = ;` — the `=` commits to an initializer that is absent.
            // (`let x;` with no `=` is a legal uninitialized binding and is
            // not flagged.) SFN-18.
            missing_init = true;
        }
    }

    parser = skip_trivia(parser);
    let terminator = parser_peek_raw(parser);
    if symbol_matches(terminator, ";") {
        statement_tokens = append_token(statement_tokens, terminator);
        parser = parser_advance_raw(parser);
    }

    if missing_init {
        let stmt = _malformed_declaration(decl_tokens_ref, decl_start_index, parser.index, "E0502", "parse error: expected an initializer expression after `=` in declaration of `"
            + name
            + "`");
        return StatementParseResult { parser: parser, statement: stmt };
    }

    let span = source_span_from_tokens(statement_tokens);

    let statement = Statement.VariableDeclaration {
        name: name,
        mutable: mutable_flag,
        is_thread_local: is_thread_local,
        type_annotation: type_annotation,
        initializer: initializer,
        span: span,
        initializer_span: initializer_span
    };
    return StatementParseResult { parser: parser, statement: statement };
}

// ============================================================================
// Function Declaration
// ============================================================================
fn parse_function(initial_parser: Parser, starts_with_async: boolean, decorators: Decorator[], starts_with_unsafe: boolean) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    // Span of the whole declaration, for the malformed-declaration recovery
    // node (SFN-18). Captured after the leading skip so it anchors at the
    // first keyword (`fn` / `async` / `unsafe`).
    let decl_tokens_ref = parser.tokens;
    let decl_start_index = parser.index;
    let mut is_unsafe = false;
    if starts_with_unsafe {
        parser = consume_keyword(parser, "unsafe");
        parser = skip_trivia(parser);
        is_unsafe = true;
    }
    let mut is_async = false;
    if starts_with_async {
        parser = consume_keyword(parser, "async");
        is_async = true;
    } else {
        let look = parser_peek_raw(parser);
        if identifier_matches(look, "async") {
            let lookahead = skip_trivia(parser_advance_raw(parser));
            let next = parser_peek_raw(lookahead);
            if identifier_matches(next, "fn") {
                parser = consume_keyword(parser, "async");
                parser = skip_trivia(parser);
                is_async = true;
            }
        }
    }

    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "fn");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    let name_span = source_span_from_tokens([name_token]);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    parser = skip_trivia(parser);
    parser = consume_symbol(parser, "(");
    let parameter_result = parse_parameter_list(parser);
    parser = parameter_result.parser;
    let parameters = parameter_result.parameters;

    // A parameter list that never closed with `)` is a malformed declaration
    // (`fn broken( {`). Abandon it as a precise `E0501` parse error instead of
    // emitting a garbage `FunctionDeclaration`; the parser is already
    // positioned for recovery (SFN-18).
    if !parameter_result.closed {
        let stmt = _malformed_declaration(decl_tokens_ref, decl_start_index, parser.index, "E0501", "parse error: expected `)` to close the parameter list of function `"
            + name
            + "`");
        return StatementParseResult { parser: parser, statement: stmt };
    }

    parser = skip_trivia(parser);
    let mut return_type: TypeAnnotation? = null;
    let sep_result = consume_return_type_separator(parser);
    if sep_result.found {
        parser = sep_result.parser;
        let capture = collect_until(skip_trivia(parser), ["!", "{"]);
        parser = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            return_type = TypeAnnotation { text: text };
        }
    }

    let effect_result = parse_effect_list(parser);
    parser = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let inferred_effects = parsed_effects;

    // Allow `fn foo() ![effects] -> T {}` ordering.
    if return_type == null {
        parser = skip_trivia(parser);
        let late_sep = consume_return_type_separator(parser);
        if late_sep.found {
            parser = late_sep.parser;
            let capture = collect_until(skip_trivia(parser), ["{"]);
            parser = capture.parser;
            let text = trim_text(tokens_to_text(capture.tokens));
            if text.length > 0 {
                return_type = TypeAnnotation { text: text };
            }
        }
    }

    let block_result = parse_block(parser);
    parser = block_result.parser;
    let body = block_result.block;

    // A body that opened with `{` but hit EOF before its closing `}` is a
    // truncated declaration. Abandon it as a precise `E0505` parse error rather
    // than emitting a `FunctionDeclaration` whose body silently swallowed the
    // rest of the file (including a valid `main`), which otherwise slips past
    // check and reaches the linker as a missing-`main` ICE (SFN-384).
    if !block_result.closed {
        let stmt = _malformed_declaration(decl_tokens_ref, decl_start_index, parser.index, "E0505", "parse error: expected `}` to close the body of function `"
            + name
            + "`");
        return StatementParseResult { parser: parser, statement: stmt };
    }

    let signature = FunctionSignature {
        name: name,
        is_async: is_async,
        parameters: parameters,
        return_type: return_type,
        effects: inferred_effects,
        type_parameters: type_parameters,
        name_span: name_span
    };

    let statement = Statement.FunctionDeclaration {
        signature: signature,
        body: body,
        decorators: decorators,
        is_unsafe: is_unsafe
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_extern_function(initial_parser: Parser, starts_with_unsafe: boolean, decorators: Decorator[]) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    let mut is_unsafe = false;
    if starts_with_unsafe {
        parser = consume_keyword(parser, "unsafe");
        is_unsafe = true;
    }

    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "extern");

    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "fn");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    let name_span = source_span_from_tokens([name_token]);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let type_parameters = type_param_result.parameters;

    parser = skip_trivia(parser);
    parser = consume_symbol(parser, "(");
    let parameter_result = parse_parameter_list(parser);
    parser = parameter_result.parser;
    let parameters = parameter_result.parameters;

    parser = skip_trivia(parser);
    let mut return_type: TypeAnnotation? = null;
    let sep_result = consume_return_type_separator(parser);
    if sep_result.found {
        parser = sep_result.parser;
        let capture = collect_until(skip_trivia(parser), ["!", ";"]);
        parser = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            return_type = TypeAnnotation { text: text };
        }
    }

    let effect_result = parse_effect_list(parser);
    parser = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let inferred_effects = parsed_effects;

    // Allow `extern fn foo() ![effects] -> T;` ordering.
    if return_type == null {
        parser = skip_trivia(parser);
        let late_sep = consume_return_type_separator(parser);
        if late_sep.found {
            parser = late_sep.parser;
            let capture = collect_until(skip_trivia(parser), [";"]);
            parser = capture.parser;
            let text = trim_text(tokens_to_text(capture.tokens));
            if text.length > 0 {
                return_type = TypeAnnotation { text: text };
            }
        }
    }

    parser = skip_trivia(parser);
    parser = consume_symbol(parser, ";");

    let signature = FunctionSignature {
        name: name,
        is_async: false,
        parameters: parameters,
        return_type: return_type,
        effects: inferred_effects,
        type_parameters: type_parameters,
        name_span: name_span
    };

    let statement = Statement.ExternFunctionDeclaration {
        signature: signature,
        unsafe: is_unsafe,
        decorators: decorators
    };
    return StatementParseResult { parser: parser, statement: statement };
}

// Parse `extern var NAME: TYPE;` (optionally `unsafe extern var ...`).
// Declares a reference to a C-ABI global symbol (e.g. libc `environ`).
// The type annotation is validated against the same accept-list as
// `extern fn` signatures (E0801–E0805) in `check_extern_var`.
fn parse_extern_var(initial_parser: Parser, starts_with_unsafe: boolean, decorators: Decorator[]) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    if starts_with_unsafe { parser = consume_keyword(parser, "unsafe"); }

    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "extern");

    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "var");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    let name_span = source_span_from_tokens([name_token]);
    parser = parser_advance_raw(parser);

    parser = skip_trivia(parser);
    let sep_result = consume_annotation_separator(parser);
    if sep_result.found { parser = sep_result.parser; } else {
        let arrow_result = consume_return_type_separator(parser);
        if arrow_result.found { parser = arrow_result.parser; }
    }

    // Capture the type up to either `=` (defining-global initializer) or
    // `;` (a bare reference declaration). An initializer turns the
    // `extern var` into a single strong *definition* of the C-ABI symbol
    // (`@NAME = global <ty> <init>`) so a Sailfin object can own a runtime
    // global instead of a hand-written `.ll` (#1436); without one it stays
    // an `external global` reference (#1313).
    let capture = collect_until(skip_trivia(parser), ["=", ";"]);
    parser = capture.parser;
    let type_text = trim_text(tokens_to_text(capture.tokens));

    parser = skip_trivia(parser);
    let mut initializer: string? = null;
    if symbol_matches(parser_peek_raw(parser), "=") {
        parser = consume_symbol(parser, "=");
        let init_capture = collect_until(skip_trivia(parser), [";"]);
        parser = init_capture.parser;
        let init_text = trim_text(tokens_to_text(init_capture.tokens));
        if init_text.length > 0 { initializer = init_text; }
    }

    parser = skip_trivia(parser);
    parser = consume_symbol(parser, ";");

    let statement = Statement.ExternVarDeclaration {
        name: name,
        type_annotation: TypeAnnotation { text: type_text },
        name_span: name_span,
        decorators: decorators,
        init_value: initializer
    };
    return StatementParseResult { parser: parser, statement: statement };
}

// ============================================================================
// Struct Declaration
// ============================================================================
fn parse_struct(initial_parser: Parser, decorators: Decorator[]) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    // Span of the whole declaration, for the malformed-declaration recovery
    // node (SFN-18). Anchors at the leading `struct`.
    let decl_tokens_ref = parser.tokens;
    let decl_start_index = parser.index;
    parser = consume_keyword(parser, "struct");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    let name = identifier_text(name_token);
    let name_span = source_span_from_tokens([name_token]);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    let implements_result = parse_implements_clause(parser);
    parser = implements_result.parser;
    let mut implements_types = implements_result.types;

    parser = skip_trivia(parser);
    parser = advance_to_symbol(parser, "{");
    parser = consume_symbol(parser, "{");

    let mut fields: FieldDeclaration[] = [];
    let mut methods: MethodDeclaration[] = [];
    let mut saw_malformed_field: boolean = false;

    loop {
        parser = skip_trivia(parser);
        let member_start = parser;

        let decorator_result = parse_decorators(parser);
        parser = decorator_result.parser;
        let member_decorators = decorator_result.decorators;

        parser = skip_trivia(parser);
        let token = parser_peek_raw(parser);
        if symbol_matches(token, "}") {
            parser = parser_advance_raw(parser);
            break;
        }
        if token.kind.variant == "EndOfFile" { break; }

        let field_result = parse_struct_field(parser);
        if field_result.success {
            if member_decorators.length == 0 {
                if field_result.field != null {
                    fields = append_field(fields, field_result.field);
                }
                parser = field_result.parser;
                continue;
            }
        }

        let method_result = parse_struct_method(parser, member_decorators);
        if method_result.success {
            if method_result.method != null {
                methods = append_method(methods, method_result.method);
            }
            parser = method_result.parser;
            continue;
        }

        // A member with a field prefix (`name:`) but no type is a malformed
        // field, not an unrecognized member — record it so the whole struct
        // is abandoned as an `E0503` parse error. Still `skip_struct_member`
        // to resync past `}` so an independent later declaration parses. SFN-18.
        if field_result.missing_type { saw_malformed_field = true; }
        parser = skip_struct_member(member_start);
    }

    if saw_malformed_field {
        let stmt = _malformed_declaration(decl_tokens_ref, decl_start_index, parser.index, "E0503", "parse error: expected a type after `:` in a field of struct `"
            + name
            + "`");
        return StatementParseResult { parser: parser, statement: stmt };
    }

    let statement = Statement.StructDeclaration {
        name: name,
        name_span: name_span,
        type_parameters: type_parameters,
        implements_types: implements_types,
        fields: fields,
        methods: methods,
        decorators: decorators
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_struct_field(parser: Parser) -> StructFieldParseResult {
    let mut current = skip_trivia(parser);

    let mut is_mutable = false;
    let token = parser_peek_raw(current);
    let mut token_to_use = token;
    if identifier_matches(token_to_use, "mut") {
        current = parser_advance_raw(current);
        is_mutable = true;
        current = skip_trivia(current);
        token_to_use = parser_peek_raw(current);
    }

    if token_to_use.kind.variant != "Identifier" {
        return StructFieldParseResult {
            parser: parser,
            field: null,
            success: false,
            missing_type: false
        };
    }

    let name = identifier_text(token_to_use);
    let name_span = source_span_from_tokens([token_to_use]);
    current = parser_advance_raw(current);

    current = skip_trivia(current);
    let separator_result = consume_annotation_separator(current);
    current = separator_result.parser;
    if !separator_result.found {
        return StructFieldParseResult {
            parser: parser,
            field: null,
            success: false,
            missing_type: false
        };
    }

    // Generic args may contain commas (`Result<T, E>`); use the
    // angle-balancing variant so only a top-level `,`/`;`/`}` ends the
    // capture. See `collect_type_annotation_until` for safety scope.
    let capture = collect_type_annotation_until(skip_trivia(current), [";", ",", "}"]);
    current = capture.parser;
    let type_text = trim_text(tokens_to_text(capture.tokens));
    if type_text.length == 0 {
        // `struct S { x: }` — the `:` commits to a field type that is absent.
        // Flag it so `parse_struct` mints an `E0503` parse error rather than
        // dropping the field via `skip_struct_member` (SFN-18).
        return StructFieldParseResult {
            parser: parser,
            field: null,
            success: false,
            missing_type: true
        };
    }

    current = skip_trivia(current);
    // Accept `;` (spec form), `,` (Rust/TS convention), or `}` (last field
    // omits the terminator). Pre-fix this function only accepted `;`, which
    // caused the outer parser loop to silently swallow the field via
    // `skip_struct_member` — emitting an empty struct (`%T = type {}`) and
    // breaking every downstream pass. See `parse_enum_variant_field` for
    // the precedent. Closes the regression that surfaced on PR #289 as
    // "struct-string-field reads misfire" (#289 follow-up).
    let terminator = parser_peek_raw(current);
    if symbol_matches(terminator, ";") {
        current = parser_advance_raw(current);
    } else if symbol_matches(terminator, ",") {
        current = parser_advance_raw(current);
    } else if !symbol_matches(terminator, "}") {
        return StructFieldParseResult {
            parser: parser,
            field: null,
            success: false,
            missing_type: false
        };
    }

    let field = FieldDeclaration {
        name: name,
        type_annotation: TypeAnnotation { text: type_text },
        mutable: is_mutable,
        name_span: name_span
    };

    return StructFieldParseResult {
        parser: current,
        field: field,
        success: true,
        missing_type: false
    };
}

fn parse_struct_method(parser: Parser, decorators: Decorator[]) -> MethodParseResult {
    let mut current = skip_trivia(parser);

    let mut is_async = false;
    let peek = parser_peek_raw(current);
    if identifier_matches(peek, "async") {
        let lookahead = skip_trivia(parser_advance_raw(current));
        if identifier_matches(parser_peek_raw(lookahead), "fn") {
            current = consume_keyword(current, "async");
            is_async = true;
        }
    }

    current = skip_trivia(current);
    if !identifier_matches(parser_peek_raw(current), "fn") {
        return MethodParseResult {
            parser: parser,
            method: null,
            success: false
        };
    }
    current = consume_keyword(current, "fn");

    current = skip_trivia(current);
    let name_token = parser_peek_raw(current);
    if name_token.kind.variant != "Identifier" {
        return MethodParseResult {
            parser: parser,
            method: null,
            success: false
        };
    }
    let name = identifier_text(name_token);
    let name_span = source_span_from_tokens([name_token]);
    current = parser_advance_raw(current);

    let type_param_result = parse_type_parameter_clause(current);
    current = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    current = skip_trivia(current);
    current = consume_symbol(current, "(");
    let parameter_result = parse_parameter_list(current);
    current = parameter_result.parser;
    let parameters = parameter_result.parameters;

    current = skip_trivia(current);
    let mut return_type: TypeAnnotation? = null;
    let sep_result = consume_return_type_separator(current);
    if sep_result.found {
        current = sep_result.parser;
        let capture = collect_until(skip_trivia(current), ["!", "{"]);
        current = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            return_type = TypeAnnotation { text: text };
        }
    }

    let effect_result = parse_effect_list(current);
    current = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let inferred_effects = parsed_effects;

    let block_result = parse_block(current);
    current = block_result.parser;
    let body = block_result.block;

    let signature = FunctionSignature {
        name: name,
        is_async: is_async,
        parameters: parameters,
        return_type: return_type,
        effects: inferred_effects,
        type_parameters: type_parameters,
        name_span: name_span
    };

    let method = MethodDeclaration {
        signature: signature,
        body: body,
        decorators: decorators
    };

    return MethodParseResult {
        parser: current,
        method: method,
        success: true
    };
}

// ============================================================================
// Enum Declaration
// ============================================================================
fn parse_enum(initial_parser: Parser, decorators: Decorator[]) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    let original = parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "enum");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    if name_token.kind.variant != "Identifier" {
        return parse_unknown(original);
    }
    let name = identifier_text(name_token);
    let name_span = source_span_from_tokens([name_token]);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    parser = skip_trivia(parser);
    parser = advance_to_symbol(parser, "{");
    parser = consume_symbol(parser, "{");

    let mut variants: EnumVariant[] = [];
    loop {
        parser = skip_trivia(parser);
        let token = parser_peek_raw(parser);
        if symbol_matches(token, "}") {
            parser = parser_advance_raw(parser);
            break;
        }
        if token.kind.variant == "EndOfFile" { break; }

        let variant_result = parse_enum_variant(parser);
        if variant_result.success {
            parser = variant_result.parser;
            if variant_result.variant != null {
                variants = append_enum_variant(variants, variant_result.variant);
            }
            parser = skip_trailing_comma(parser);
            continue;
        }

        parser = skip_struct_member(parser);
    }

    let statement = Statement.EnumDeclaration {
        name: name,
        name_span: name_span,
        type_parameters: type_parameters,
        variants: variants,
        decorators: decorators
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_enum_variant(parser: Parser) -> EnumVariantParseResult {
    let original = parser;
    let mut current = skip_trivia(parser);
    let name_token = parser_peek_raw(current);
    if name_token.kind.variant != "Identifier" {
        return EnumVariantParseResult {
            parser: original,
            variant: null,
            success: false
        };
    }
    let name = identifier_text(name_token);
    let name_span = source_span_from_tokens([name_token]);
    current = parser_advance_raw(current);

    let mut fields: FieldDeclaration[] = [];
    current = skip_trivia(current);
    let next = parser_peek_raw(current);
    if symbol_matches(next, "{") {
        current = parser_advance_raw(current);
        loop {
            current = skip_trivia(current);
            let token = parser_peek_raw(current);
            if symbol_matches(token, "}") {
                current = parser_advance_raw(current);
                break;
            }
            if token.kind.variant == "EndOfFile" { break; }

            let field_result = parse_enum_variant_field(current);
            if field_result.success {
                current = field_result.parser;
                if field_result.field != null {
                    fields = append_field(fields, field_result.field);
                }
                continue;
            }

            current = skip_enum_variant_entry(current);
        }
    }

    current = skip_trivia(current);
    let mut terminator = parser_peek_raw(current);
    if symbol_matches(terminator, ";") {
        current = parser_advance_raw(current);
        current = skip_trivia(current);
        terminator = parser_peek_raw(current);
    }

    let variant = EnumVariant {
        name: name,
        fields: fields,
        name_span: name_span
    };

    return EnumVariantParseResult {
        parser: current,
        variant: variant,
        success: true
    };
}

fn parse_enum_variant_field(parser: Parser) -> StructFieldParseResult {
    let mut current = skip_trivia(parser);

    let mut is_mutable: boolean = false;
    let token = parser_peek_raw(current);
    let mut token_to_use = token;
    if identifier_matches(token_to_use, "mut") {
        current = parser_advance_raw(current);
        is_mutable = true;
        current = skip_trivia(current);
        token_to_use = parser_peek_raw(current);
    }

    if token_to_use.kind.variant != "Identifier" {
        return StructFieldParseResult {
            parser: parser,
            field: null,
            success: false,
            missing_type: false
        };
    }

    let name = identifier_text(token_to_use);
    let name_span = source_span_from_tokens([token_to_use]);
    current = parser_advance_raw(current);

    current = skip_trivia(current);
    let sep_result = consume_annotation_separator(current);
    if !sep_result.found {
        return StructFieldParseResult {
            parser: parser,
            field: null,
            success: false,
            missing_type: false
        };
    }
    current = sep_result.parser;

    // Type-annotation context: angle-balanced so `Result<T, E>` parses
    // as one type, not as a `Result<T` prefix + stray `E>` field.
    let capture = collect_type_annotation_until(skip_trivia(current), [",", "}", ";"]);
    current = capture.parser;
    let mut type_text = trim_text(tokens_to_text(capture.tokens));
    loop {
        if type_text.length == 0 { break; }
        let last = char_at(type_text, type_text.length - 1);
        if last != ";" { break; }
        let trimmed = substring(type_text, 0, type_text.length - 1);
        type_text = trim_text(trimmed);
    }
    if type_text.length == 0 {
        return StructFieldParseResult {
            parser: parser,
            field: null,
            success: false,
            missing_type: false
        };
    }

    current = skip_trivia(current);
    let terminator = parser_peek_raw(current);
    if symbol_matches(terminator, ",") {
        current = parser_advance_raw(current);
    } else if symbol_matches(terminator, ";") {
        current = parser_advance_raw(current);
        current = skip_trivia(current);
        let maybe_comma = parser_peek_raw(current);
        if symbol_matches(maybe_comma, ",") {
            current = parser_advance_raw(current);
        }
    }

    let field = FieldDeclaration {
        name: name,
        type_annotation: TypeAnnotation { text: type_text },
        mutable: is_mutable,
        name_span: name_span
    };

    return StructFieldParseResult {
        parser: current,
        field: field,
        success: true,
        missing_type: false
    };
}

// ============================================================================
// Interface Declaration
// ============================================================================
fn parse_interface(initial_parser: Parser, decorators: Decorator[]) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    let original = parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "interface");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    if name_token.kind.variant != "Identifier" {
        return parse_unknown(original);
    }
    let name = identifier_text(name_token);
    let name_span = source_span_from_tokens([name_token]);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    parser = skip_trivia(parser);
    parser = advance_to_symbol(parser, "{");
    parser = consume_symbol(parser, "{");

    let mut members: FunctionSignature[] = [];
    let mut field_members: InterfaceFieldMember[] = [];
    loop {
        parser = skip_trivia(parser);
        let token = parser_peek_raw(parser);
        if symbol_matches(token, "}") {
            parser = parser_advance_raw(parser);
            break;
        }
        if token.kind.variant == "EndOfFile" { break; }

        let member_start = parser;
        let decorator_result = parse_decorators(parser);
        parser = decorator_result.parser;
        let member_decorators = decorator_result.decorators;

        parser = skip_trivia(parser);
        let member_result = parse_interface_member(parser, member_decorators);
        if member_result.success {
            parser = member_result.parser;
            if member_result.signature != null {
                members = append_signature(members, member_result.signature);
            }
            continue;
        }

        // The member did not parse as a method signature. If it has a
        // data-field shape (an identifier followed by a type separator
        // `:` or the legacy `->`), record it so typecheck rejects it
        // with `E0827` (SFEP-0039 §3.1): interfaces are method-only.
        // Genuine garbage (neither `fn` nor a field shape) keeps the
        // existing silent recovery so recovery does not cascade.
        let head = parser_peek_raw(parser);
        if head.kind.variant == "Identifier" && !identifier_matches(head, "fn") {
            let after_name = skip_trivia(parser_advance_raw(parser));
            let colon = consume_annotation_separator(after_name);
            let arrow = consume_return_type_separator(after_name);
            if colon.found || arrow.found {
                field_members.push(InterfaceFieldMember {
                    name: identifier_text(head), name_span: source_span_from_tokens([head])
                });
            }
        }

        parser = skip_struct_member(member_start);
    }

    let statement = Statement.InterfaceDeclaration {
        name: name,
        name_span: name_span,
        type_parameters: type_parameters,
        members: members,
        decorators: decorators,
        field_members: field_members
    };
    return StatementParseResult { parser: parser, statement: statement };
}

fn parse_interface_member(parser: Parser, decorators: Decorator[]) -> InterfaceMemberParseResult {
    let original = parser;
    let mut current = skip_trivia(parser);

    let mut is_async = false;
    let peek = parser_peek_raw(current);
    if identifier_matches(peek, "async") {
        let lookahead = skip_trivia(parser_advance_raw(current));
        if identifier_matches(parser_peek_raw(lookahead), "fn") {
            current = consume_keyword(current, "async");
            is_async = true;
        }
    }

    current = skip_trivia(current);
    if !identifier_matches(parser_peek_raw(current), "fn") {
        return InterfaceMemberParseResult {
            parser: original,
            signature: null,
            success: false
        };
    }
    current = consume_keyword(current, "fn");

    current = skip_trivia(current);
    let name_token = parser_peek_raw(current);
    if name_token.kind.variant != "Identifier" {
        return InterfaceMemberParseResult {
            parser: original,
            signature: null,
            success: false
        };
    }
    let name = identifier_text(name_token);
    let name_span = source_span_from_tokens([name_token]);
    current = parser_advance_raw(current);

    let type_param_result = parse_type_parameter_clause(current);
    current = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    current = skip_trivia(current);
    current = consume_symbol(current, "(");
    let parameter_result = parse_parameter_list(current);
    current = parameter_result.parser;
    let parameters = parameter_result.parameters;

    current = skip_trivia(current);
    let mut return_type: TypeAnnotation? = null;
    let separator_result = consume_return_type_separator(current);
    if separator_result.found {
        current = separator_result.parser;
        let capture = collect_until(skip_trivia(current), ["!", ";", "{"]);
        current = capture.parser;
        let text = trim_text(tokens_to_text(capture.tokens));
        if text.length > 0 {
            return_type = TypeAnnotation { text: text };
        }
    }

    let effect_result = parse_effect_list(current);
    current = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let inferred_effects = parsed_effects;

    current = skip_trivia(current);
    if current.index < current.tokens.length {
        let terminator = parser_peek_raw(current);
        if symbol_matches(terminator, ";") {
            current = parser_advance_raw(current);
        }
    }

    let signature = FunctionSignature {
        name: name,
        is_async: is_async,
        parameters: parameters,
        return_type: return_type,
        effects: inferred_effects,
        type_parameters: type_parameters,
        name_span: name_span
    };

    return InterfaceMemberParseResult {
        parser: current,
        signature: signature,
        success: true
    };
}

// ============================================================================
// Type Alias Declaration
// ============================================================================
fn parse_type_alias(initial_parser: Parser, decorators: Decorator[]) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    let original = parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "type");

    parser = skip_trivia(parser);
    let name_token = parser_peek_raw(parser);
    if name_token.kind.variant != "Identifier" {
        return parse_unknown(original);
    }
    let name = identifier_text(name_token);
    let name_span = source_span_from_tokens([name_token]);
    parser = parser_advance_raw(parser);

    let type_param_result = parse_type_parameter_clause(parser);
    parser = type_param_result.parser;
    let mut type_parameters = type_param_result.parameters;

    parser = skip_trivia(parser);
    let equals = parser_peek_raw(parser);
    if !symbol_matches(equals, "=") { return parse_unknown(original); }
    parser = parser_advance_raw(parser);

    let capture = collect_until(skip_trivia(parser), [";"]);
    parser = capture.parser;
    let aliased_text = trim_text(tokens_to_text(capture.tokens));
    if aliased_text.length == 0 { return parse_unknown(original); }
    let aliased_type = TypeAnnotation { text: aliased_text };

    parser = skip_trivia(parser);
    let alias_terminator = parser_peek_raw(parser);
    if symbol_matches(alias_terminator, ";") {
        parser = parser_advance_raw(parser);
    }

    let statement = Statement.TypeAliasDeclaration {
        name: name,
        name_span: name_span,
        type_parameters: type_parameters,
        aliased_type: aliased_type,
        decorators: decorators
    };
    return StatementParseResult { parser: parser, statement: statement };
}

// ============================================================================
// Test Declaration
// ============================================================================
fn parse_test(initial_parser: Parser, decorators: Decorator[]) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    let original = parser;
    parser = skip_trivia(parser);
    parser = consume_keyword(parser, "test");

    let name_capture = collect_until(skip_trivia(parser), ["!", "{"]);
    parser = name_capture.parser;
    let name_text = trim_text(tokens_to_text(name_capture.tokens));
    if name_text.length == 0 { return parse_unknown(original); }
    let name_span = source_span_from_tokens(name_capture.tokens);
    let name = normalize_test_name(name_text);

    let effect_result = parse_effect_list(parser);
    parser = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let inferred_effects = parsed_effects;

    let block_result = parse_block(parser);
    parser = block_result.parser;
    let body = block_result.block;

    let statement = Statement.TestDeclaration {
        name: name,
        name_span: name_span,
        body: body,
        effects: inferred_effects,
        decorators: decorators,
        hook_kind: ""
    };
    return StatementParseResult { parser: parser, statement: statement };
}

// ============================================================================
// Lifecycle Hook Declaration
// ============================================================================
// Recognizes `before_each`/`after_each`/`before_all`/`after_all` blocks and
// lowers each to a `TestDeclaration` carrying a non-empty `hook_kind`. Hooks
// have no quoted name; a stable synthetic name (`__hook_<kind>`) keeps the
// emitted symbol unique and discoverable by the test-harness synthesizer.
// One hook per kind per file is supported; a second of the same kind produces
// a duplicate-symbol diagnostic from typecheck (documented limitation).
fn parse_lifecycle_hook(initial_parser: Parser, decorators: Decorator[], kind: string) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    // Anchor diagnostics (duplicate-hook, effect errors) at the hook
    // introducer token, since hooks carry no quoted name to span.
    let keyword_token = parser_peek_raw(parser);
    let name_span = source_span_from_tokens([keyword_token]);
    parser = consume_keyword(parser, kind);

    let effect_result = parse_effect_list(parser);
    parser = effect_result.parser;
    let parsed_effects = effect_result.effects;
    let inferred_effects = parsed_effects;

    let block_result = parse_block(parser);
    parser = block_result.parser;
    let body = block_result.block;

    let statement = Statement.TestDeclaration {
        name: "__hook_" + kind,
        name_span: name_span,
        body: body,
        effects: inferred_effects,
        decorators: decorators,
        hook_kind: kind
    };
    return StatementParseResult { parser: parser, statement: statement };
}

// ============================================================================
// Unknown Statement (fallback)
// ============================================================================
// Build a `Statement.Unknown` recovery node carrying a precise parse code
// (`E05xx`) and message for a malformed-but-dispatched declaration (SFN-18).
// The token slice `[start_index, end_index)` spans the abandoned declaration
// so `sfn check` anchors the diagnostic at its first token and the build gate
// (`main.sfn::_reject_parse_errors`) can render it. Unlike `parse_unknown`,
// this scans nothing — the calling production has already positioned the
// parser for recovery.
fn _malformed_declaration(tokens_ref: Token[], start_index: int, end_index: int, code: string, message: string) -> Statement {
    let toks = token_slice(tokens_ref, start_index, end_index);
    return Statement.Unknown {
        tokens: toks,
        text: tokens_to_text(toks),
        code: code,
        message: message
    };
}

fn parse_unknown(initial_parser: Parser) -> StatementParseResult {
    let mut parser: Parser = initial_parser;
    parser = skip_trivia(parser);
    let mut tokens: Token[] = [];
    let mut current = parser;
    let mut depth: int = 0;
    let iteration_limit: int = 16384;
    let mut iteration_count: int = 0;
    let mut truncated: boolean = false;

    loop {
        if iteration_count >= iteration_limit {
            truncated = true;
            current = parser_advance_raw(current);
            break;
        }
        iteration_count += 1;
        let tok = parser_peek_raw(current);
        tokens = append_token(tokens, tok);

        if symbol_matches(tok, "{") { depth += 1; } else if symbol_matches(tok, "}") {
            if depth > 0 { depth -= 1; }
            if depth == 0 {
                current = parser_advance_raw(current);
                break;
            }
        } else {
            let mut _elif401: boolean = false;
            if depth == 0 {
                if symbol_matches(tok, ";") { _elif401 = true; }
            }
            if _elif401 {
                current = parser_advance_raw(current);
                break;
            }
        }

        if is_end_of_file(current, tok) {
            current = parser_advance_raw(current);
            break;
        }

        current = parser_advance_raw(current);
    }

    let mut text: string = tokens_to_text(tokens);
    if truncated { text = text + " /* parse_unknown truncated */"; }
    let block = Statement.Unknown {
        tokens: tokens,
        text: text,
        code: "",
        message: ""
    };
    parser = skip_trivia(current);
    return StatementParseResult { parser: parser, statement: block };
}

// ============================================================================
// Append Helpers
// ============================================================================
fn append_string(values: string[], value: string) -> string[] {
    values.push(value);
    return values;
}

fn append_parameter(parameters: Parameter[], parameter: Parameter) -> Parameter[] {
    parameters.push(parameter);
    return parameters;
}

fn append_field(fields: FieldDeclaration[], field: FieldDeclaration) -> FieldDeclaration[] {
    fields.push(field);
    return fields;
}

fn append_method(methods: MethodDeclaration[], method: MethodDeclaration) -> MethodDeclaration[] {
    methods.push(method);
    return methods;
}

fn append_signature(signatures: FunctionSignature[], signature: FunctionSignature) -> FunctionSignature[] {
    signatures.push(signature);
    return signatures;
}

fn append_enum_variant(variants: EnumVariant[], variant: EnumVariant) -> EnumVariant[] {
    variants.push(variant);
    return variants;
}

fn append_type_annotation(types: TypeAnnotation[], item: TypeAnnotation) -> TypeAnnotation[] {
    types.push(item);
    return types;
}

fn append_decorator(decorators: Decorator[], decorator: Decorator) -> Decorator[] {
    decorators.push(decorator);
    return decorators;
}

fn append_decorator_argument(arguments: DecoratorArgument[], argument: DecoratorArgument) -> DecoratorArgument[] {
    arguments.push(argument);
    return arguments;
}
