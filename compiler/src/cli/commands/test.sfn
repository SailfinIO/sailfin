// compiler/src/cli/commands/test.sfn
//
// `test` subcommand (CLI modularization epic #351, Issue 3.8 — proposal
// §5 Phase 3 item 8, §7). Migrates `sfn test` off the legacy
// `cli_commands` handler onto the per-command `command_def()`/`run()`
// pattern established by Issue 2.4 (`version`) and exercised by the other
// Phase 3 commands (`init`, `login`, `guillermo`, `add`, `publish`, `fmt`).
//
// `test` carries a real flag surface plus a variadic positional:
//   sfn test [--json] [-k NAME] [--tag TAG] [--update-snapshots]
//            [--no-test-cache] [--jobs N] [--shard I/N] <suite...>
// `--json` / `--update-snapshots` / `--no-test-cache` are boolean flags;
// `-k` (name substring), `--tag` (tag filter), and `--shard` (I/N
// partition, issue #1237) are value flags; `--jobs`
// is a `flag_int` (Issue 1.5, #794) so `parse()` rejects a non-integer
// value as a `type_error` before `run` is reached; `suite` is a variadic
// positional (Issue 1.11, #800) collecting one or more suite paths (zero
// defaults to "."). `runtime_root` / `binary_dir` are threaded from the
// driver-parsed `CliContext` (Issue 2.2), replacing the legacy handler's
// extra params.
//
// The `run` body and its `_test_*` / `_clang_link_test_cmd_with_deps`
// private helpers (and the `TestSuite` / `TestGroup` / `TestFileOutcome` /
// `RetryPolicy` types) move verbatim from `cli_commands.sfn` — only the
// flag-parsing preamble changes (the hand-rolled argv walk becomes typed
// `sfn/cli` match accessors). Test discovery, snapshot, caching, and jobs
// semantics are unchanged. Exit codes stay integer literals (the
// `sfn/cli` `EXIT_*` constants lower to 0 in an importing module — see the
// `fmt.sfn` note).
import {
    Command,
    Matches,
    arg_variadic,
    command,
    flag,
    flag_int,
    flag_value,
    flag_value_short,
    get_int,
    get_or,
    has,
    has_flag,
    positionals,
    with_arg,
    with_flag
} from "sfn/cli";

import { AssertFailure, _empty_assert_failure, _parse_assert_failure_record } from "../../assert_failure";
import { Program, Statement } from "../../ast";
import { LinkPlan, LlvmTextBackend } from "../../backend";
import { llvm_assemble } from "../../build/clang_argv";
import {
    _atomic_rename_into_place,
    _dirname_cmd,
    _ends_with_cmd,
    _ensure_dir_cmd,
    _mktemp_sibling_cmd,
    _path_join_cmd,
    _sanitize_filename_cmd,
    _shell_read_cmd,
    _strip_trailing_slashes_cmd,
    _write_text_cmd
} from "../../build/fs";
import { sha256_hex_of_string } from "../../build/hash";
import {
    assemble_runtime_capsule_link_inputs,
    runtime_stamp_identity,
    write_runtime_identity_stamp
} from "../../build/runtime_objs";
import {
    CacheKey,
    cache_copy_artifact_to,
    cache_lookup_artifact,
    cache_store_artifact,
    canonicalize_flags,
    runtime_link_inputs_identity,
    sha256_of_file,
    test_bin_cache_key,
    test_bin_cache_root
} from "../../build_cache";
import { _env_flag, _get_env_cmd, _legacy_flag_file } from "../../build_flags";
import { is_safe_scope_name, parse_scope_name } from "../../capsule_artifact";
import {
    ResolverConsumer,
    TestCapsuleResolution,
    discover_project_root,
    discover_workspace_root,
    load_workspace_default_members,
    prepare_project_capsules_for_test
} from "../../capsule_resolver";
import { ImportSymbolTable, empty_import_symbols } from "../../effect_imports";
import { format_backend_failure_banner } from "../../ice";
import { compile_tests_to_llvm_file_with_module_imports, module_name_from_path } from "../../main";
import { LayoutManifest } from "../../native_ir";
import { number_to_string } from "../../num_format";
import { parse_program } from "../../parser/mod";
