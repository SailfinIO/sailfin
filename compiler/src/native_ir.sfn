// compiler/src/native_ir.sfn
//
// Shared parser utilities for textual `.sfn-asm` artifacts. Both the
// temporary Python lowering layer and the emerging LLVM/WASM backends use
// this module to understand the structure emitted by `emit_native.sfn`.

import { NativeArtifact } from "./emit_native";
import { substring, char_code } from "./string_utils";

enum NativeInstruction {
    Return {
        expression -> string;
        span -> NativeSourceSpan?;
    },
    Expression {
        expression -> string;
        span -> NativeSourceSpan?;
    },
    Let {
        name -> string;
        mutable -> boolean;
        type_annotation -> string;
        value -> string?;
        span -> NativeSourceSpan?;
        value_span -> NativeSourceSpan?;
    },
    If { condition -> string },
    Else,
    EndIf,
    For {
        target -> string;
        iterable -> string;
    },
    EndFor,
    Loop,
    EndLoop,
    Break,
    Continue,
    Match { expression -> string },
    Case {
        pattern -> string;
        guard -> string?;
    },
    EndMatch,
    Try,
    Catch {
        name -> string;
    },
    EndTry,
    Throw {
        expression -> string;
        span -> NativeSourceSpan?;
    },
    Noop,
    Unknown { text -> string },
}

struct NativeSourceSpan {
    start_line -> number;
    start_column -> number;
    end_line -> number;
    end_column -> number;
}

struct NativeParameter {
    name -> string;
    type_annotation -> string;
    mutable -> boolean;
    default_value -> string?;
    span -> NativeSourceSpan?;
}

struct NativeFunction {
    name -> string;
    parameters -> NativeParameter[];
    return_type -> string;
    effects -> string[];
    instructions -> NativeInstruction[];
}

struct NativeImportSpecifier {
    name -> string;
    alias -> string?;
}

struct NativeImport {
    kind -> string;
    module -> string;
    specifiers -> NativeImportSpecifier[];
}

struct NativeStructField {
    name -> string;
    type_annotation -> string;
    mutable -> boolean;
}

struct NativeStructLayoutField {
    name -> string;
    type_annotation -> string;
    offset -> number;
    size -> number;
    align -> number;
}

struct NativeStructLayout {
    size -> number;
    align -> number;
    fields -> NativeStructLayoutField[];
}

struct NativeStruct {
    name -> string;
    fields -> NativeStructField[];
    methods -> NativeFunction[];
    implements -> string[];
    layout -> NativeStructLayout?;
}

struct NativeInterfaceSignature {
    name -> string;
    is_async -> boolean;
    type_parameters -> string[];
    parameters -> NativeParameter[];
    return_type -> string;
    effects -> string[];
}

struct NativeInterface {
    name -> string;
    type_parameters -> string[];
    signatures -> NativeInterfaceSignature[];
}

struct NativeEnumVariantField {
    name -> string;
    type_annotation -> string;
    mutable -> boolean;
}

struct NativeEnumVariant {
    name -> string;
    fields -> NativeEnumVariantField[];
}

struct NativeEnumVariantLayout {
    name -> string;
    tag -> number;
    offset -> number;
    size -> number;
    align -> number;
    fields -> NativeStructLayoutField[];
}

struct NativeEnumLayout {
    size -> number;
    align -> number;
    tag_type -> string;
    tag_size -> number;
    tag_align -> number;
    variants -> NativeEnumVariantLayout[];
}

struct NativeEnum {
    name -> string;
    variants -> NativeEnumVariant[];
    layout -> NativeEnumLayout?;
}

struct NativeBinding {
    name -> string;
    mutable -> boolean;
    type_annotation -> string;
    value -> string?;
}

struct EnumParseResult {
    definition -> NativeEnum?;
    next_index -> number;
    diagnostics -> string[];
}

struct CaseComponents {
    pattern -> string;
    guard -> string?;
}

struct InstructionParseResult {
    instructions -> NativeInstruction[];
    span_consumed -> boolean;
    value_span_consumed -> boolean;
}

struct InstructionGatherResult {
    text -> string;
    lines_consumed -> number;
}

struct InstructionDepthState {
    paren_depth -> number;
    bracket_depth -> number;
    brace_depth -> number;
    in_string -> boolean;
    escaping -> boolean;
}

struct StructParseResult {
    definition -> NativeStruct?;
    next_index -> number;
    diagnostics -> string[];
}

struct InterfaceParseResult {
    definition -> NativeInterface?;
    next_index -> number;
    diagnostics -> string[];
}

struct InterfaceSignatureParse {
    success -> boolean;
    signature -> NativeInterfaceSignature;
    diagnostics -> string[];
}

struct StructHeaderParse {
    name -> string;
    implements -> string[];
    diagnostics -> string[];
}

struct InterfaceHeaderParse {
    name -> string;
    type_parameters -> string[];
    diagnostics -> string[];
}

struct HeaderNameParse {
    name -> string;
    type_parameters -> string[];
    remainder -> string;
    diagnostics -> string[];
}

struct StructLayoutHeaderParse {
    success -> boolean;
    name -> string;
    size -> number;
    align -> number;
    diagnostics -> string[];
}

struct StructLayoutFieldParse {
    success -> boolean;
    field -> NativeStructLayoutField;
    diagnostics -> string[];
}

struct ParseNativeResult {
    functions -> NativeFunction[];
    imports -> NativeImport[];
    structs -> NativeStruct[];
    interfaces -> NativeInterface[];
    enums -> NativeEnum[];
    bindings -> NativeBinding[];
    diagnostics -> string[];
}

struct EnumLayoutHeaderParse {
    success -> boolean;
    name -> string;
    size -> number;
    align -> number;
    tag_type -> string;
    tag_size -> number;
    tag_align -> number;
    diagnostics -> string[];
}

struct EnumLayoutVariantParse {
    success -> boolean;
    variant -> NativeEnumVariantLayout;
    diagnostics -> string[];
}

struct EnumLayoutPayloadParse {
    success -> boolean;
    variant_name -> string;
    field -> NativeStructLayoutField;
    diagnostics -> string[];
}

struct NumberParseResult {
    success -> boolean;
    value -> number;
}

struct LayoutManifest {
    structs -> NativeStruct[];
    enums -> NativeEnum[];
    diagnostics -> string[];
}

fn select_text_artifact(artifacts -> NativeArtifact[]) -> NativeArtifact? {
    let mut index -> number = 0;
    loop {
        if index >= artifacts.length {
            break;
        }
        let artifact = artifacts[index];
        if artifact.format == "sailfin-native-text" {
            return artifact;
        }
        index += 1;
    }
    return null;
}

fn select_layout_manifest_artifact(artifacts -> NativeArtifact[]) -> NativeArtifact? {
    let mut index -> number = 0;
    loop {
        if index >= artifacts.length {
            break;
        }
        let artifact = artifacts[index];
        if artifact.format == "sailfin-layout-manifest" {
            return artifact;
        }
        index += 1;
    }
    return null;
}

fn parse_native_artifact(text -> string) -> ParseNativeResult {
    let lines = split_lines(text);
    let mut diagnostics -> string[] = [];
    let mut functions -> NativeFunction[] = [];
    let mut imports -> NativeImport[] = [];
    let mut structs -> NativeStruct[] = [];
    let mut interfaces -> NativeInterface[] = [];
    let mut enums -> NativeEnum[] = [];
    let mut bindings -> NativeBinding[] = [];
    let mut current -> NativeFunction? = null;
    let mut pending_span -> NativeSourceSpan? = null;
    let mut pending_value_span -> NativeSourceSpan? = null;

    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let raw_line = lines[index];
        let line = trim_text(raw_line);
        if line.length == 0 {
            index += 1;
            continue;
        }
        if starts_with(line, ";") {
            index += 1;
            continue;
        }
        if starts_with(line, ".module ") {
            index += 1;
            continue;
        }
        if starts_with(line, ".import ") {
            let parsed_import = parse_import_entry("import", strip_prefix(line, ".import "));
            if parsed_import == null {
                diagnostics = append_string(diagnostics, "unable to parse import: " + line);
            } else {
                imports = append_import(imports, parsed_import);
            }
            index += 1;
            continue;
        }
        if starts_with(line, ".export ") {
            let parsed_export = parse_import_entry("export", strip_prefix(line, ".export "));
            if parsed_export == null {
                diagnostics = append_string(diagnostics, "unable to parse export: " + line);
            } else {
                imports = append_import(imports, parsed_export);
            }
            index += 1;
            continue;
        }
        if starts_with(line, ".span ") {
            let parsed_span = parse_source_span(strip_prefix(line, ".span "));
            if parsed_span == null {
                diagnostics = append_string(diagnostics, "unable to parse span metadata: " + line);
            } else {
                pending_span = parsed_span;
            }
            index += 1;
            continue;
        }
        if starts_with(line, ".init-span ") {
            let parsed_init_span = parse_source_span(strip_prefix(line, ".init-span "));
            if parsed_init_span == null {
                diagnostics = append_string(diagnostics, "unable to parse initializer span metadata: " + line);
            } else {
                pending_value_span = parsed_init_span;
            }
            index += 1;
            continue;
        }
        if starts_with(line, ".struct ") {
            let struct_result = parse_struct_definition(lines, index);
            diagnostics = diagnostics.concat(struct_result.diagnostics);
            if struct_result.definition != null {
                structs = append_struct(structs, struct_result.definition);
            }
            index = struct_result.next_index;
            continue;
        }
        if starts_with(line, ".interface ") {
            let interface_result = parse_interface_definition(lines, index);
            diagnostics = diagnostics.concat(interface_result.diagnostics);
            if interface_result.definition != null {
                interfaces = append_interface(interfaces, interface_result.definition);
            }
            index = interface_result.next_index;
            continue;
        }
        if starts_with(line, ".enum ") {
            let enum_result = parse_enum_definition(lines, index);
            diagnostics = diagnostics.concat(enum_result.diagnostics);
            if enum_result.definition != null {
                enums = append_enum(enums, enum_result.definition);
            }
            index = enum_result.next_index;
            continue;
        }
        if starts_with(line, ".fn ") {
            if current != null {
                diagnostics = append_string(diagnostics, "encountered nested .fn while previous function still open");
            }
            current = NativeFunction {
                name: parse_function_name(strip_prefix(line, ".fn ")),
                parameters: [],
                return_type: "void",
                effects: [],
                instructions: [],
            };
            index += 1;
            continue;
        }
        if starts_with(line, ".test ") {
            if current != null {
                diagnostics = append_string(diagnostics, "encountered nested .test while previous function still open");
            }

            let header = strip_prefix(line, ".test ");
            let trimmed = trim_text(header);
            if trimmed.length == 0 {
                diagnostics = append_string(diagnostics, "unable to parse test header: " + line);
                index += 1;
                continue;
            }

            let mut raw_name -> string = "";
            if trimmed[0] == "\"" || trimmed[0] == "'" {
                let quote = trimmed[0];
                let mut scan -> number = 1;
                let mut escaping -> boolean = false;
                loop {
                    if scan >= trimmed.length {
                        break;
                    }
                    let ch = trimmed[scan];
                    if escaping {
                        escaping = false;
                        scan += 1;
                        continue;
                    }
                    if ch == "\\" {
                        escaping = true;
                        scan += 1;
                        continue;
                    }
                    if ch == quote {
                        raw_name = substring(trimmed, 0, scan + 1);
                        break;
                    }
                    scan += 1;
                }
            } else {
                let space_index = index_of(trimmed, " ");
                if space_index < 0 {
                    raw_name = trimmed;
                } else {
                    raw_name = trim_text(substring(trimmed, 0, space_index));
                }
            }

            let name = strip_quotes(trim_text(raw_name));
            if name.length == 0 {
                diagnostics = append_string(diagnostics, "unable to parse test header: " + line);
                index += 1;
                continue;
            }

            current = NativeFunction {
                name: "test:" + name,
                parameters: [],
                return_type: "void",
                effects: [],
                instructions: [],
            };
            index += 1;
            continue;
        }
        if starts_with(line, ".endfn") {
            if current == null {
                diagnostics = append_string(diagnostics, "encountered .endfn without active function");
            } else {
                functions = append_function(functions, current);
                current = null;
            }
            index += 1;
            continue;
        }
        if starts_with(line, ".endtest") {
            if current == null {
                diagnostics = append_string(diagnostics, "encountered .endtest without active test");
            } else {
                functions = append_function(functions, current);
                current = null;
            }
            index += 1;
            continue;
        }
        if starts_with(line, ".meta ") {
            if current != null {
                current = apply_meta(current, strip_prefix(line, ".meta "));
            } else {
                diagnostics = append_string(diagnostics, "metadata outside function body: " + line);
            }
            index += 1;
            continue;
        }
        if starts_with(line, ".param ") {
            if current != null {
                let mut combined -> string = strip_prefix(line, ".param ");
                let mut lookahead -> number = index + 1;
                loop {
                    if lookahead >= lines.length {
                        break;
                    }
                    let continuation_raw = lines[lookahead];
                    if continuation_raw.length == 0 {
                        break;
                    }
                    let continuation_trimmed = trim_text(continuation_raw);
                    if continuation_trimmed.length == 0 {
                        lookahead += 1;
                        continue;
                    }
                    if !line_looks_like_parameter_entry(continuation_trimmed) {
                        break;
                    }
                    combined = combined + " " + continuation_trimmed;
                    lookahead += 1;
                }

                let entries = split_parameter_entries(combined);
                if entries.length == 0 {
                    diagnostics = append_string(diagnostics, "unable to parse parameter line: " + line);
                    pending_span = null;
                } else {
                    let mut entry_index -> number = 0;
                    let mut span_consumed -> boolean = false;
                    loop {
                        if entry_index >= entries.length {
                            break;
                        }
                        let entry = entries[entry_index];
                        let mut parameter_span -> NativeSourceSpan? = pending_span;
                        if span_consumed {
                            parameter_span = null;
                        }
                        let parameter = parse_parameter_entry(entry, parameter_span);
                        if parameter == null {
                            diagnostics = append_string(diagnostics, "unable to parse parameter entry: " + entry);
                        } else {
                            current = append_parameter(current, parameter);
                            if parameter.span != null {
                                span_consumed = true;
                            }
                        }
                        entry_index += 1;
                    }
                    pending_span = null;
                }
                index = lookahead - 1;
            } else {
                diagnostics = append_string(diagnostics, "parameter outside function body: " + line);
            }
            index += 1;
            continue;
        }
    let gather = gather_instruction(lines, index);
    line = gather.text;
    index += gather.lines_consumed;
    let instruction_result = parse_instruction(line, pending_span, pending_value_span);
        let instructions = instruction_result.instructions;
        if instruction_result.span_consumed {
            pending_span = null;
        } else if pending_span != null {
            diagnostics = append_string(diagnostics, "unused span metadata before: " + line);
            pending_span = null;
        }
        if instruction_result.value_span_consumed {
            pending_value_span = null;
        } else if pending_value_span != null {
            diagnostics = append_string(diagnostics, "unused initializer span metadata before: " + line);
            pending_value_span = null;
        }

        if current == null {
            let trimmed_line = trim_text(line);
            if starts_with(trimmed_line, ".decorator") {
                // Decorators are currently represented as top-level directives in `.sfn-asm`.
                // The native lowering pipeline does not yet apply decorator semantics, but
                // these directives should not cause warnings (warnings are treated as failures).
                index += 1;
                continue;
            }
            if instructions.length == 1 && instructions[0].variant == "Let" {
                bindings = append_binding(bindings, binding_from_instruction(instructions[0]));
            } else {
                diagnostics = append_string(diagnostics, "top-level directive not supported in lowering: " + line);
            }
            index += 1;
            continue;
        }
        let mut instruction_index -> number = 0;
        loop {
            if instruction_index >= instructions.length {
                break;
            }
            current = append_instruction(current, instructions[instruction_index]);
            instruction_index += 1;
        }
        index += 1;
    }

    if current != null {
        diagnostics = append_string(diagnostics, "unterminated function at end of artifact");
    }

    return ParseNativeResult { functions: functions, imports: imports, structs: structs, interfaces: interfaces, enums: enums, bindings: bindings, diagnostics: diagnostics };
}

fn parse_source_span(text -> string) -> NativeSourceSpan? {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return null;
    }
    let parts = split_whitespace(trimmed);
    if parts.length != 4 {
        return null;
    }
    let start_line = parse_decimal_number(parts[0]);
    if !start_line.success {
        return null;
    }
    let start_column = parse_decimal_number(parts[1]);
    if !start_column.success {
        return null;
    }
    let end_line = parse_decimal_number(parts[2]);
    if !end_line.success {
        return null;
    }
    let end_column = parse_decimal_number(parts[3]);
    if !end_column.success {
        return null;
    }
    return NativeSourceSpan {
        start_line: start_line.value,
        start_column: start_column.value,
        end_line: end_line.value,
        end_column: end_column.value,
    };
}

fn append_function(functions -> NativeFunction[], value -> NativeFunction) -> NativeFunction[] {
    return functions.concat([value]);
}

fn append_binding(bindings -> NativeBinding[], value -> NativeBinding) -> NativeBinding[] {
    return bindings.concat([value]);
}

fn append_import(imports -> NativeImport[], value -> NativeImport) -> NativeImport[] {
    return imports.concat([value]);
}

fn append_struct(structs -> NativeStruct[], value -> NativeStruct) -> NativeStruct[] {
    return structs.concat([value]);
}

fn append_interface(interfaces -> NativeInterface[], value -> NativeInterface) -> NativeInterface[] {
    return interfaces.concat([value]);
}

fn append_enum(enums -> NativeEnum[], value -> NativeEnum) -> NativeEnum[] {
    return enums.concat([value]);
}

fn append_enum_variant(variants -> NativeEnumVariant[], value -> NativeEnumVariant) -> NativeEnumVariant[] {
    return variants.concat([value]);
}

fn append_enum_variant_field(fields -> NativeEnumVariantField[], value -> NativeEnumVariantField) -> NativeEnumVariantField[] {
    return fields.concat([value]);
}

fn append_struct_field(fields -> NativeStructField[], field -> NativeStructField) -> NativeStructField[] {
    return fields.concat([field]);
}

fn append_struct_layout_field(fields -> NativeStructLayoutField[], field -> NativeStructLayoutField) -> NativeStructLayoutField[] {
    return fields.concat([field]);
}

fn append_enum_variant_layout(variants -> NativeEnumVariantLayout[], value -> NativeEnumVariantLayout) -> NativeEnumVariantLayout[] {
    return variants.concat([value]);
}

fn find_enum_variant_layout(variants -> NativeEnumVariantLayout[], name -> string) -> number {
    let mut index -> number = 0;
    loop {
        if index >= variants.length {
            break;
        }
        if variants[index].name == name {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn update_enum_variant_fields(variants -> NativeEnumVariantLayout[], index -> number, field -> NativeStructLayoutField) -> NativeEnumVariantLayout[] {
    let mut result -> NativeEnumVariantLayout[] = [];
    let mut current_index -> number = 0;
    loop {
        if current_index >= variants.length {
            break;
        }
        if current_index == index {
            let variant = variants[current_index];
            let updated = NativeEnumVariantLayout {
                name: variant.name,
                tag: variant.tag,
                offset: variant.offset,
                size: variant.size,
                align: variant.align,
                fields: append_struct_layout_field(variant.fields, field),
            };
            result = append_enum_variant_layout(result, updated);
        } else {
            result = append_enum_variant_layout(result, variants[current_index]);
        }
        current_index += 1;
    }
    return result;
}

fn append_parameter(function -> NativeFunction, parameter -> NativeParameter) -> NativeFunction {
    let parameters = append_parameter_array(function.parameters, parameter);
    return NativeFunction {
        name: function.name,
        parameters: parameters,
        return_type: function.return_type,
        effects: function.effects,
        instructions: function.instructions,
    };
}

fn append_instruction(function -> NativeFunction, instruction -> NativeInstruction) -> NativeFunction {
    let instructions = function.instructions.concat([instruction]);
    return NativeFunction {
        name: function.name,
        parameters: function.parameters,
        return_type: function.return_type,
        effects: function.effects,
        instructions: instructions,
    };
}

fn binding_from_instruction(instruction -> NativeInstruction) -> NativeBinding {
    return NativeBinding {
        name: instruction.name,
        mutable: instruction.mutable,
        type_annotation: instruction.type_annotation,
        value: instruction.value,
    };
}

fn apply_meta(function -> NativeFunction, entry -> string) -> NativeFunction {
    let trimmed = trim_text(entry);
    if starts_with(trimmed, "return ") {
        let return_type = trim_text(strip_prefix(trimmed, "return "));
        return update_function_meta(function, return_type, function.effects);
    }
    if starts_with(trimmed, "effects ") {
        let list = trim_text(strip_prefix(trimmed, "effects "));
        let effects = parse_effect_list(list);
        return update_function_meta(function, function.return_type, effects);
    }
    return function;
}

fn update_function_meta(function -> NativeFunction, return_type -> string, effects -> string[]) -> NativeFunction {
    return NativeFunction {
        name: function.name,
        parameters: function.parameters,
        return_type: return_type,
        effects: effects,
        instructions: function.instructions,
    };
}

fn gather_instruction(lines -> string[], start_index -> number) -> InstructionGatherResult {
    if start_index >= lines.length {
        return InstructionGatherResult { text: "", lines_consumed: 0 };
    }
    let first_line = trim_text(lines[start_index]);
    if first_line.length == 0 {
        return InstructionGatherResult { text: first_line, lines_consumed: 0 };
    }
    if !instruction_supports_multiline(first_line) {
        return InstructionGatherResult { text: first_line, lines_consumed: 0 };
    }

    let mut state = update_instruction_depth_state(initial_instruction_depth_state(), first_line);
    if !instruction_requires_continuation(state) {
        return InstructionGatherResult { text: first_line, lines_consumed: 0 };
    }

    let mut combined -> string = first_line;
    let mut consumed -> number = 0;
    let mut index = start_index + 1;
    loop {
        if index >= lines.length {
            break;
        }
        let continuation = trim_text(lines[index]);
        // Preserve structure for downstream parsing by keeping newline separators.
        if continuation.length == 0 {
            combined = combined + "\n";
        } else {
            combined = combined + "\n" + continuation;
            state = update_instruction_depth_state(state, continuation);
        }
        consumed += 1;
        index += 1;
        if !instruction_requires_continuation(state) {
            break;
        }
    }
    let normalized = trim_text(combined);
    return InstructionGatherResult { text: normalized, lines_consumed: consumed };
}

fn instruction_supports_multiline(line -> string) -> boolean {
    if starts_with(line, "eval ") {
        return true;
    }
    if starts_with(line, "ret ") {
        return true;
    }
    return false;
}

fn instruction_requires_continuation(state -> InstructionDepthState) -> boolean {
    if state.in_string {
        return true;
    }
    if state.paren_depth > 0 {
        return true;
    }
    if state.bracket_depth > 0 {
        return true;
    }
    if state.brace_depth > 0 {
        return true;
    }
    return false;
}

fn initial_instruction_depth_state() -> InstructionDepthState {
    return InstructionDepthState { paren_depth: 0, bracket_depth: 0, brace_depth: 0, in_string: false, escaping: false };
}

fn update_instruction_depth_state(state -> InstructionDepthState, text -> string) -> InstructionDepthState {
    let mut paren_depth = state.paren_depth;
    let mut bracket_depth = state.bracket_depth;
    let mut brace_depth = state.brace_depth;
    let mut in_string = state.in_string;
    let mut escaping = state.escaping;

    let mut index -> number = 0;
    loop {
        if index >= text.length {
            break;
        }
        let ch = text[index];
        if in_string {
            if escaping {
                escaping = false;
                index += 1;
                continue;
            }
            if ch == "\\" {
                escaping = true;
                index += 1;
                continue;
            }
            if ch == "\"" {
                in_string = false;
            }
            index += 1;
            continue;
        }

        if ch == "\"" {
            in_string = true;
            index += 1;
            continue;
        }
        if ch == "(" {
            paren_depth += 1;
            index += 1;
            continue;
        }
        if ch == ")" {
            if paren_depth > 0 {
                paren_depth -= 1;
            }
            index += 1;
            continue;
        }
        if ch == "[" {
            bracket_depth += 1;
            index += 1;
            continue;
        }
        if ch == "]" {
            if bracket_depth > 0 {
                bracket_depth -= 1;
            }
            index += 1;
            continue;
        }
        if ch == "{" {
            brace_depth += 1;
            index += 1;
            continue;
        }
        if ch == "}" {
            if brace_depth > 0 {
                brace_depth -= 1;
            }
            index += 1;
            continue;
        }
        index += 1;
    }

    return InstructionDepthState {
        paren_depth: paren_depth,
        bracket_depth: bracket_depth,
        brace_depth: brace_depth,
        in_string: in_string,
        escaping: escaping,
    };
}

fn parse_instruction(line -> string, span -> NativeSourceSpan?, value_span -> NativeSourceSpan?) -> InstructionParseResult {
    if line == "noop" {
        return InstructionParseResult { instructions: [NativeInstruction.Noop()], span_consumed: false, value_span_consumed: false };
    }
    if starts_with(line, ".if ") {
        let condition = trim_text(strip_prefix(line, ".if "));
        return InstructionParseResult { instructions: [NativeInstruction.If { condition: condition }], span_consumed: false, value_span_consumed: false };
    }
    if line == ".else" {
        return InstructionParseResult { instructions: [NativeInstruction.Else()], span_consumed: false, value_span_consumed: false };
    }
    if line == ".endif" {
        return InstructionParseResult { instructions: [NativeInstruction.EndIf()], span_consumed: false, value_span_consumed: false };
    }
    if starts_with(line, ".for ") {
        let body = trim_text(strip_prefix(line, ".for "));
        let separator = " in ";
        let index = index_of(body, separator);
        if index >= 0 {
            let target = trim_text(substring(body, 0, index));
            let iterable = trim_text(substring(body, index + separator.length, body.length));
            return InstructionParseResult { instructions: [NativeInstruction.For { target: target, iterable: iterable }], span_consumed: false, value_span_consumed: false };
        }
    }
    if line == ".endfor" {
        return InstructionParseResult { instructions: [NativeInstruction.EndFor()], span_consumed: false, value_span_consumed: false };
    }
    if line == ".loop" {
        return InstructionParseResult { instructions: [NativeInstruction.Loop()], span_consumed: false, value_span_consumed: false };
    }
    if line == ".endloop" {
        return InstructionParseResult { instructions: [NativeInstruction.EndLoop()], span_consumed: false, value_span_consumed: false };
    }
    if line == "break" {
        return InstructionParseResult { instructions: [NativeInstruction.Break()], span_consumed: false, value_span_consumed: false };
    }
    if line == "continue" {
        return InstructionParseResult { instructions: [NativeInstruction.Continue()], span_consumed: false, value_span_consumed: false };
    }
    if starts_with(line, ".match ") {
        let expression = trim_text(strip_prefix(line, ".match "));
        return InstructionParseResult { instructions: [NativeInstruction.Match { expression: expression }], span_consumed: false, value_span_consumed: false };
    }
    if starts_with(line, ".case ") {
        return InstructionParseResult { instructions: [parse_case_instruction(line)], span_consumed: false, value_span_consumed: false };
    }
    if line == ".endmatch" {
        return InstructionParseResult { instructions: [NativeInstruction.EndMatch()], span_consumed: false, value_span_consumed: false };
    }
    if line == ".try" {
        return InstructionParseResult { instructions: [NativeInstruction.Try()], span_consumed: false, value_span_consumed: false };
    }
    if starts_with(line, ".catch ") {
        let name = trim_text(strip_prefix(line, ".catch "));
        return InstructionParseResult { instructions: [NativeInstruction.Catch { name: name }], span_consumed: false, value_span_consumed: false };
    }
    if line == ".endtry" {
        return InstructionParseResult { instructions: [NativeInstruction.EndTry()], span_consumed: false, value_span_consumed: false };
    }
    if starts_with(line, "throw ") {
        let expression = trim_trailing_delimiters(trim_text(strip_prefix(line, "throw ")));
        return InstructionParseResult { instructions: [NativeInstruction.Throw { expression: expression, span: span }], span_consumed: true, value_span_consumed: false };
    }
    if starts_with(line, ".let ") {
        return InstructionParseResult {
            instructions: [parse_let_instruction(line, span, value_span)],
            span_consumed: true,
            value_span_consumed: true,
        };
    }
    if starts_with(line, ".return") {
        let remainder = trim_text(strip_prefix(line, ".return"));
        let mut expression -> string = "";
        if remainder.length > 0 {
            expression = trim_trailing_delimiters(remainder);
        }
        return InstructionParseResult {
            instructions: [NativeInstruction.Return { expression: expression, span: span }],
            span_consumed: true,
            value_span_consumed: false,
        };
    }
    if starts_with(line, "ret") {
        if line.length == 3 {
            return InstructionParseResult {
                instructions: [NativeInstruction.Return { expression: "", span: span }],
                span_consumed: true,
                value_span_consumed: false,
            };
        }
        let separator = line[3];
        if separator == " " || separator == "\t" {
            let remainder = trim_text(substring(line, 3, line.length));
            if remainder.length == 0 {
                return InstructionParseResult {
                    instructions: [NativeInstruction.Return { expression: "", span: span }],
                    span_consumed: true,
                    value_span_consumed: false,
                };
            }
            return InstructionParseResult {
                instructions: [NativeInstruction.Return { expression: trim_trailing_delimiters(remainder), span: span }],
                span_consumed: true,
                value_span_consumed: false,
            };
        }
    }
    if starts_with(line, "eval let ") {
        let body = trim_text(strip_prefix(line, "eval let "));
        let mut is_mutable -> boolean = false;
        if starts_with(body, "mut ") {
            is_mutable = true;
            body = trim_text(strip_prefix(body, "mut "));
        }
        let parsed = parse_binding_components(body);
        return InstructionParseResult {
            instructions: [NativeInstruction.Let {
                name: parsed.name,
                mutable: is_mutable,
                type_annotation: parsed.type_annotation,
                value: maybe_trim_trailing(parsed.value),
                span: span,
                value_span: value_span,
            }],
            span_consumed: true,
            value_span_consumed: true,
        };
    }
    if starts_with(line, "eval ") {
        return InstructionParseResult {
            instructions: [NativeInstruction.Expression { expression: trim_trailing_delimiters(trim_text(strip_prefix(line, "eval "))), span: span }],
            span_consumed: true,
            value_span_consumed: false,
        };
    }
    if index_of(line, "=>") >= 0 {
        return InstructionParseResult { instructions: parse_inline_case_instruction(line), span_consumed: false, value_span_consumed: false };
    }
    return InstructionParseResult { instructions: [NativeInstruction.Unknown { text: line }], span_consumed: false, value_span_consumed: false };
}

fn parse_case_instruction(line -> string) -> NativeInstruction {
    let body = trim_text(strip_prefix(line, ".case "));
    let split = split_case_components(body);
    return NativeInstruction.Case { pattern: split.pattern, guard: split.guard };
}

fn parse_inline_case_instruction(line -> string) -> NativeInstruction[] {
    let trimmed = trim_trailing_delimiters(trim_text(line));
    let arrow_index = index_of(trimmed, "=>");
    if arrow_index < 0 {
        return [NativeInstruction.Unknown { text: line }];
    }
    let head = trim_text(substring(trimmed, 0, arrow_index));
    let remainder = trim_trailing_delimiters(trim_text(substring(trimmed, arrow_index + 2, trimmed.length)));
    let split = split_case_components(head);
    let mut instructions -> NativeInstruction[] = [];
    instructions = instructions.concat([NativeInstruction.Case { pattern: split.pattern, guard: split.guard }]);
    if remainder.length == 0 {
        instructions = instructions.concat([NativeInstruction.Noop()]);
        return instructions;
    }
    let body_instruction = parse_inline_case_body_instruction(remainder);
    instructions = instructions.concat([body_instruction]);
    return instructions;
}

fn parse_inline_case_body_instruction(body -> string) -> NativeInstruction {
    let lowered = trim_trailing_delimiters(body);
    if starts_with(lowered, "return ") {
        let value = trim_trailing_delimiters(trim_text(strip_prefix(lowered, "return ")));
        return NativeInstruction.Return { expression: value, span: null };
    }
    if starts_with(lowered, "eval ") {
        return NativeInstruction.Expression { expression: trim_trailing_delimiters(trim_text(strip_prefix(lowered, "eval "))), span: null };
    }
    return NativeInstruction.Expression { expression: lowered, span: null };
}

fn split_case_components(text -> string) -> CaseComponents {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return CaseComponents { pattern: trimmed, guard: null };
    }
    let separator = " if ";
    let index = last_index_of(trimmed, separator);
    if index < 0 {
        return CaseComponents { pattern: trimmed, guard: null };
    }
    let pattern = trim_text(substring(trimmed, 0, index));
    let guard_text = trim_text(substring(trimmed, index + separator.length, trimmed.length));
    if guard_text.length == 0 {
        return CaseComponents { pattern: pattern, guard: null };
    }
    return CaseComponents { pattern: pattern, guard: guard_text };
}

fn parse_import_entry(kind -> string, entry -> string) -> NativeImport? {
    let trimmed = trim_text(entry);
    if trimmed.length == 0 {
        return null;
    }
    let mut module_text -> string = trimmed;
    let mut specifiers -> NativeImportSpecifier[] = [];
    let brace_index = index_of(trimmed, "{");
    if brace_index >= 0 {
        let close_index = last_index_of(trimmed, "}");
        if close_index < 0 || close_index <= brace_index {
            return null;
        }
        module_text = trim_text(substring(trimmed, 0, brace_index));
        let names_segment = substring(trimmed, brace_index + 1, close_index);
        specifiers = parse_import_specifiers(names_segment);
    }
    module_text = strip_quotes(trim_text(module_text));
    return NativeImport { kind: kind, module: module_text, specifiers: specifiers };
}

fn parse_import_specifiers(text -> string) -> NativeImportSpecifier[] {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return [];
    }
    let entries = split_comma_separated(trimmed);
    let mut specifiers -> NativeImportSpecifier[] = [];
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        let parsed = parse_single_specifier(entries[index]);
        if parsed.name.length > 0 {
            specifiers = specifiers.concat([parsed]);
        }
        index += 1;
    }
    return specifiers;
}

fn parse_single_specifier(entry -> string) -> NativeImportSpecifier {
    let trimmed = trim_text(entry);
    if trimmed.length == 0 {
        return NativeImportSpecifier { name: "", alias: null };
    }
    let separator = " as ";
    let index = index_of(trimmed, separator);
    if index < 0 {
        return NativeImportSpecifier { name: trimmed, alias: null };
    }
    let name = trim_text(substring(trimmed, 0, index));
    let alias_text = trim_text(substring(trimmed, index + separator.length, trimmed.length));
    if alias_text.length == 0 {
        return NativeImportSpecifier { name: name, alias: null };
    }
    return NativeImportSpecifier { name: name, alias: alias_text };
}

fn parse_struct_definition(lines -> string[], start_index -> number) -> StructParseResult {
    let mut diagnostics -> string[] = [];
    let header = trim_text(lines[start_index]);
    let name_text = trim_text(strip_prefix(header, ".struct "));
    let header_parse = parse_struct_header(name_text);
    diagnostics = diagnostics.concat(header_parse.diagnostics);
    let struct_name = header_parse.name;
    let mut implements = header_parse.implements;
    if struct_name.length == 0 {
        diagnostics = append_string(diagnostics, "unable to parse struct header: " + header);
        return StructParseResult { definition: null, next_index: start_index + 1, diagnostics: diagnostics };
    }

    let mut fields -> NativeStructField[] = [];
    let mut methods -> NativeFunction[] = [];
    let mut current_method -> NativeFunction? = null;
    let mut method_pending_span -> NativeSourceSpan? = null;
    let mut method_pending_value_span -> NativeSourceSpan? = null;
    let mut struct_layout_fields -> NativeStructLayoutField[] = [];
    let mut struct_layout_size -> number = 0;
    let mut struct_layout_align -> number = 0;
    let mut struct_layout_header_success -> boolean = false;
    let mut struct_layout_reported_missing_header -> boolean = false;
    let mut index = start_index + 1;
    loop {
        if index >= lines.length {
            diagnostics = append_string(diagnostics, "unterminated struct " + struct_name);
            let mut struct_layout_value -> NativeStructLayout? = null;
            if struct_layout_header_success {
                struct_layout_value = NativeStructLayout { size: struct_layout_size, align: struct_layout_align, fields: struct_layout_fields };
            }
            return StructParseResult {
                definition: NativeStruct { name: struct_name, fields: fields, methods: methods, implements: implements, layout: struct_layout_value },
                next_index: index,
                diagnostics: diagnostics,
            };
        }
        let raw_line = trim_text(lines[index]);
        if raw_line.length == 0 || starts_with(raw_line, ";") {
            index += 1;
            continue;
        }
        if raw_line == ".endstruct" {
            if current_method != null {
                diagnostics = append_string(diagnostics, "unterminated method in struct " + struct_name);
                methods = append_function(methods, current_method);
                current_method = null;
                method_pending_span = null;
                method_pending_value_span = null;
            }
            index += 1;
            break;
        }
        if current_method != null {
            if raw_line == ".endmethod" {
                methods = append_function(methods, current_method);
                current_method = null;
                method_pending_span = null;
                method_pending_value_span = null;
                index += 1;
                continue;
            }
            if starts_with(raw_line, ".meta ") {
                current_method = apply_meta(current_method, strip_prefix(raw_line, ".meta "));
                index += 1;
                continue;
            }
            if starts_with(raw_line, ".param ") {
                let parameter = parse_parameter_entry(strip_prefix(raw_line, ".param "), method_pending_span);
                if parameter == null {
                    diagnostics = append_string(diagnostics, "unable to parse method parameter: " + raw_line);
                } else {
                    current_method = append_parameter(current_method, parameter);
                }
                method_pending_span = null;
                index += 1;
                continue;
            }
            if starts_with(raw_line, ".method ") {
                diagnostics = append_string(diagnostics, "nested method declaration in struct " + struct_name);
                index += 1;
                continue;
            }
            if starts_with(raw_line, ".span ") {
                let parsed_method_span = parse_source_span(strip_prefix(raw_line, ".span "));
                if parsed_method_span == null {
                    diagnostics = append_string(diagnostics, "unable to parse span metadata: " + raw_line);
                } else {
                    method_pending_span = parsed_method_span;
                }
                index += 1;
                continue;
            }
            if starts_with(raw_line, ".init-span ") {
                let parsed_method_init_span = parse_source_span(strip_prefix(raw_line, ".init-span "));
                if parsed_method_init_span == null {
                    diagnostics = append_string(diagnostics, "unable to parse initializer span metadata: " + raw_line);
                } else {
                    method_pending_value_span = parsed_method_init_span;
                }
                index += 1;
                continue;
            }
            let method_instruction_result = parse_instruction(raw_line, method_pending_span, method_pending_value_span);
            if method_instruction_result.span_consumed {
                method_pending_span = null;
            } else if method_pending_span != null {
                diagnostics = append_string(diagnostics, "unused span metadata before: " + raw_line);
                method_pending_span = null;
            }
            if method_instruction_result.value_span_consumed {
                method_pending_value_span = null;
            } else if method_pending_value_span != null {
                diagnostics = append_string(diagnostics, "unused initializer span metadata before: " + raw_line);
                method_pending_value_span = null;
            }
            let mut instruction_index -> number = 0;
            loop {
                if instruction_index >= method_instruction_result.instructions.length {
                    break;
                }
                current_method = append_instruction(current_method, method_instruction_result.instructions[instruction_index]);
                instruction_index += 1;
            }
            index += 1;
            continue;
        }
        if starts_with(raw_line, ".layout ") {
            let body = strip_prefix(raw_line, ".layout ");
            if starts_with(body, "struct ") {
                let header_result = parse_struct_layout_header(strip_prefix(body, "struct "));
                diagnostics = diagnostics.concat(header_result.diagnostics);
                if header_result.success {
                    if struct_layout_header_success {
                        diagnostics = append_string(diagnostics, "duplicate struct layout header in " + struct_name);
                    } else {
                        struct_layout_size = header_result.size;
                        struct_layout_align = header_result.align;
                        struct_layout_header_success = true;
                    }
                }
                index += 1;
                continue;
            }
            if starts_with(body, "field ") {
                let tail = trim_text(strip_prefix(body, "field "));
                let mut is_struct_header -> boolean = false;
                if starts_with(tail, "struct") {
                    if tail.length == 6 {
                        is_struct_header = true;
                    } else if tail.length > 6 {
                        let after = tail[6];
                        if is_trim_char(after) {
                            is_struct_header = true;
                        }
                    }
                }
                if is_struct_header {
                    let header_text = trim_text(strip_prefix(tail, "struct"));
                    let header_result = parse_struct_layout_header(header_text);
                    diagnostics = diagnostics.concat(header_result.diagnostics);
                    if header_result.success {
                        if struct_layout_header_success {
                            diagnostics = append_string(diagnostics, "duplicate struct layout header in " + struct_name);
                        } else {
                            struct_layout_size = header_result.size;
                            struct_layout_align = header_result.align;
                            struct_layout_header_success = true;
                        }
                    }
                    index += 1;
                    continue;
                }

                let field_result = parse_struct_layout_field(tail, struct_name);
                diagnostics = diagnostics.concat(field_result.diagnostics);
                if field_result.success {
                    struct_layout_fields = append_struct_layout_field(struct_layout_fields, field_result.field);
                    if !struct_layout_header_success {
                        if !struct_layout_reported_missing_header {
                            diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field encountered before layout header");
                            struct_layout_reported_missing_header = true;
                        }
                    }
                }
                index += 1;
                continue;
            }
            diagnostics = append_string(diagnostics, "unsupported struct layout directive: " + raw_line);
            index += 1;
            continue;
        }
        if raw_line == "noop" {
            index += 1;
            continue;
        }
        if starts_with(raw_line, ".field ") {
            let parsed_field = parse_struct_field_line(strip_prefix(raw_line, ".field "));
            if parsed_field == null {
                diagnostics = append_string(diagnostics, "unable to parse struct field: " + raw_line);
            } else {
                fields = append_struct_field(fields, parsed_field);
            }
            index += 1;
            continue;
        }
        if starts_with(raw_line, ".method ") {
            if current_method != null {
                diagnostics = append_string(diagnostics, "nested method declaration in struct " + struct_name);
            }
            let method_name = parse_function_name(strip_prefix(raw_line, ".method "));
            current_method = NativeFunction {
                name: method_name,
                parameters: [],
                return_type: "void",
                effects: [],
                instructions: [],
            };
            method_pending_span = null;
            method_pending_value_span = null;
            index += 1;
            continue;
        }
        diagnostics = append_string(diagnostics, "unsupported struct directive: " + raw_line);
        index += 1;
    }

    let mut struct_layout_value -> NativeStructLayout? = null;
    if struct_layout_header_success {
        struct_layout_value = NativeStructLayout { size: struct_layout_size, align: struct_layout_align, fields: struct_layout_fields };
    }

    return StructParseResult {
        definition: NativeStruct { name: struct_name, fields: fields, methods: methods, implements: implements, layout: struct_layout_value },
        next_index: index,
        diagnostics: diagnostics,
    };
}

fn parse_interface_definition(lines -> string[], start_index -> number) -> InterfaceParseResult {
    let mut diagnostics -> string[] = [];
    let header = trim_text(lines[start_index]);
    let name_text = trim_text(strip_prefix(header, ".interface "));
    let header_parse = parse_interface_header(name_text);
    diagnostics = diagnostics.concat(header_parse.diagnostics);
    let interface_name = header_parse.name;
    if interface_name.length == 0 {
        diagnostics = append_string(diagnostics, "unable to parse interface header: " + header);
        return InterfaceParseResult { definition: null, next_index: start_index + 1, diagnostics: diagnostics };
    }

    let mut signatures -> NativeInterfaceSignature[] = [];
    let mut index = start_index + 1;
    loop {
        if index >= lines.length {
            diagnostics = append_string(diagnostics, "unterminated interface " + interface_name);
            return InterfaceParseResult {
                definition: NativeInterface { name: interface_name, type_parameters: header_parse.type_parameters, signatures: signatures },
                next_index: index,
                diagnostics: diagnostics,
            };
        }
        let raw_line = trim_text(lines[index]);
        if raw_line.length == 0 || starts_with(raw_line, ";") {
            index += 1;
            continue;
        }
        if raw_line == ".endinterface" {
            index += 1;
            break;
        }
        if raw_line == "noop" {
            index += 1;
            continue;
        }
        if starts_with(raw_line, ".sig ") {
            let signature_parse = parse_interface_signature(strip_prefix(raw_line, ".sig "), interface_name);
            diagnostics = diagnostics.concat(signature_parse.diagnostics);
            if signature_parse.success {
                signatures = signatures.concat([signature_parse.signature]);
            }
            index += 1;
            continue;
        }
        diagnostics = append_string(diagnostics, "unsupported interface directive: " + raw_line);
        index += 1;
    }

    return InterfaceParseResult {
        definition: NativeInterface { name: interface_name, type_parameters: header_parse.type_parameters, signatures: signatures },
        next_index: index,
        diagnostics: diagnostics,
    };
}

fn parse_struct_header(text -> string) -> StructHeaderParse {
    let base = parse_header_name_and_remainder(text);
    let mut diagnostics -> string[] = base.diagnostics;
    let mut implements -> string[] = [];
    if base.remainder.length > 0 {
        if starts_with(base.remainder, "implements ") {
            let list_text = trim_text(strip_prefix(base.remainder, "implements "));
            if list_text.length == 0 {
                diagnostics = append_string(diagnostics, "struct " + base.name + " header missing implements list");
            } else {
                implements = parse_implements_list(list_text);
            }
        } else {
            diagnostics = append_string(diagnostics, "struct " + base.name + " header has unsupported segment `" + base.remainder + "`");
        }
    }
    return StructHeaderParse { name: base.name, implements: implements, diagnostics: diagnostics };
}

fn parse_interface_header(text -> string) -> InterfaceHeaderParse {
    let base = parse_header_name_and_remainder(text);
    let mut diagnostics -> string[] = base.diagnostics;
    if base.remainder.length > 0 {
        diagnostics = append_string(diagnostics, "interface " + base.name + " header has unsupported segment `" + base.remainder + "`");
    }
    return InterfaceHeaderParse { name: base.name, type_parameters: base.type_parameters, diagnostics: diagnostics };
}

fn parse_interface_signature(text -> string, interface_name -> string) -> InterfaceSignatureParse {
    let mut diagnostics -> string[] = [];
    let default_signature = NativeInterfaceSignature {
        name: "",
        is_async: false,
        type_parameters: [],
        parameters: [],
        return_type: "void",
        effects: [],
    };

    let trimmed = trim_trailing_delimiters(trim_text(text));
    if trimmed.length == 0 {
        diagnostics = append_string(diagnostics, "interface " + interface_name + " signature missing content");
        return InterfaceSignatureParse { success: false, signature: default_signature, diagnostics: diagnostics };
    }

    let mut remainder -> string = trimmed;
    let mut is_async -> boolean = false;
    if starts_with(remainder, "async ") {
        is_async = true;
        remainder = trim_text(strip_prefix(remainder, "async "));
    }

    let paren_index = index_of(remainder, "(");
    if paren_index < 0 {
        diagnostics = append_string(diagnostics, "interface " + interface_name + " signature missing parameter list: " + trimmed);
        return InterfaceSignatureParse { success: false, signature: default_signature, diagnostics: diagnostics };
    }

    let close_index = find_matching_paren(remainder, paren_index);
    if close_index < 0 {
        diagnostics = append_string(diagnostics, "interface " + interface_name + " signature has unterminated parameter list: " + trimmed);
        return InterfaceSignatureParse { success: false, signature: default_signature, diagnostics: diagnostics };
    }

    let head = trim_text(substring(remainder, 0, paren_index));
    let name_parse = parse_header_name_and_remainder(head);
    diagnostics = diagnostics.concat(name_parse.diagnostics);
    if name_parse.remainder.length > 0 {
        diagnostics = append_string(diagnostics, "interface " + interface_name + " signature `" + trimmed + "` has unsupported segment `" + name_parse.remainder + "`");
    }
    let method_name = name_parse.name;
    if method_name.length == 0 {
        diagnostics = append_string(diagnostics, "interface " + interface_name + " signature `" + trimmed + "` missing name");
    }

    let parameters_section = substring(remainder, paren_index + 1, close_index);
    let mut parameters -> NativeParameter[] = [];
    let parameter_text = trim_text(parameters_section);
    if parameter_text.length > 0 {
        let entries = split_parameter_entries(parameter_text);
        let mut entry_index -> number = 0;
        loop {
            if entry_index >= entries.length {
                break;
            }
            let parsed = parse_parameter_entry(entries[entry_index], null);
            if parsed == null {
                diagnostics = append_string(diagnostics, "interface " + interface_name + " signature `" + method_name + "` has invalid parameter `" + entries[entry_index] + "`");
            } else {
                parameters = append_parameter_array(parameters, parsed);
            }
            entry_index += 1;
        }
    }

    let mut return_type -> string = "void";
    let mut effects -> string[] = [];
    let mut suffix = trim_text(substring(remainder, close_index + 1, remainder.length));
    if suffix.length > 0 {
        let effect_index = index_of(suffix, "![");
        let mut effect_segment -> string = "";
        if effect_index >= 0 {
            effect_segment = trim_text(substring(suffix, effect_index, suffix.length));
            suffix = trim_text(substring(suffix, 0, effect_index));
        }
        if suffix.length > 0 {
            if starts_with(suffix, "->") {
                let type_text = trim_text(strip_prefix(suffix, "->"));
                if type_text.length > 0 {
                    return_type = type_text;
                }
            } else {
                diagnostics = append_string(diagnostics, "interface " + interface_name + " signature `" + method_name + "` has unsupported suffix `" + suffix + "`");
            }
        }
        if effect_segment.length > 0 {
            if starts_with(effect_segment, "![") && effect_segment[effect_segment.length - 1] == "]" {
                let body = substring(effect_segment, 2, effect_segment.length - 1);
                effects = parse_effect_list(body);
            } else {
                diagnostics = append_string(diagnostics, "interface " + interface_name + " signature `" + method_name + "` has invalid effects annotation `" + effect_segment + "`");
            }
        }
    }

    let signature = NativeInterfaceSignature {
        name: method_name,
        is_async: is_async,
        type_parameters: name_parse.type_parameters,
        parameters: parameters,
        return_type: return_type,
        effects: effects,
    };
    let success = method_name.length > 0 && diagnostics.length == 0;
    return InterfaceSignatureParse { success: success, signature: signature, diagnostics: diagnostics };
}

fn parse_header_name_and_remainder(text -> string) -> HeaderNameParse {
    let mut diagnostics -> string[] = [];
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return HeaderNameParse { name: "", type_parameters: [], remainder: "", diagnostics: diagnostics };
    }
    let mut name -> string = trimmed;
    let mut remainder -> string = "";
    let mut type_parameters -> string[] = [];
    let generics_index = index_of(trimmed, "<");
    if generics_index >= 0 {
        let close_index = find_matching_angle(trimmed, generics_index);
        if close_index < 0 {
            diagnostics = append_string(diagnostics, "header `" + text + "` missing closing `>`");
            name = strip_generics(trimmed);
            return HeaderNameParse { name: name, type_parameters: type_parameters, remainder: remainder, diagnostics: diagnostics };
        }
        name = trim_text(substring(trimmed, 0, generics_index));
        let generics_text = substring(trimmed, generics_index + 1, close_index);
        type_parameters = parse_type_parameter_entries(generics_text);
        remainder = trim_text(substring(trimmed, close_index + 1, trimmed.length));
    } else {
        let space_index = index_of(trimmed, " ");
        if space_index >= 0 {
            name = trim_text(substring(trimmed, 0, space_index));
            remainder = trim_text(substring(trimmed, space_index + 1, trimmed.length));
        }
    }
    name = strip_generics(name);
    return HeaderNameParse { name: name, type_parameters: type_parameters, remainder: remainder, diagnostics: diagnostics };
}

fn parse_type_parameter_entries(text -> string) -> string[] {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return [];
    }
    return split_top_level_commas(trimmed);
}

fn parse_implements_list(text -> string) -> string[] {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return [];
    }
    return split_top_level_commas(trimmed);
}

fn split_top_level_commas(text -> string) -> string[] {
    let mut entries -> string[] = [];
    let mut current -> string = "";
    let mut index -> number = 0;
    let mut quote -> string = "";
    let mut angle_depth -> number = 0;
    let mut paren_depth -> number = 0;
    let mut bracket_depth -> number = 0;
    let mut brace_depth -> number = 0;
    loop {
        if index >= text.length {
            break;
        }
        let ch = text[index];
        if quote.length > 0 {
            current = current + ch;
            if ch == "\\" {
                if index + 1 < text.length {
                    current = current + text[index + 1];
                    index += 2;
                    continue;
                }
            }
            if ch == quote {
                quote = "";
            }
            index += 1;
            continue;
        }
        if ch == "\"" || ch == "'" {
            quote = ch;
            current = current + ch;
            index += 1;
            continue;
        }
        if ch == "<" {
            angle_depth += 1;
            current = current + ch;
            index += 1;
            continue;
        }
        if ch == ">" {
            if angle_depth > 0 {
                angle_depth -= 1;
            }
            current = current + ch;
            index += 1;
            continue;
        }
        if ch == "(" {
            paren_depth += 1;
            current = current + ch;
            index += 1;
            continue;
        }
        if ch == ")" {
            if paren_depth > 0 {
                paren_depth -= 1;
            }
            current = current + ch;
            index += 1;
            continue;
        }
        if ch == "[" {
            bracket_depth += 1;
            current = current + ch;
            index += 1;
            continue;
        }
        if ch == "]" {
            if bracket_depth > 0 {
                bracket_depth -= 1;
            }
            current = current + ch;
            index += 1;
            continue;
        }
        if ch == "{" {
            brace_depth += 1;
            current = current + ch;
            index += 1;
            continue;
        }
        if ch == "}" {
            if brace_depth > 0 {
                brace_depth -= 1;
            }
            current = current + ch;
            index += 1;
            continue;
        }
        if ch == "," {
            if angle_depth == 0 && paren_depth == 0 && bracket_depth == 0 && brace_depth == 0 {
                let segment = trim_text(current);
                if segment.length > 0 {
                    entries = append_string(entries, segment);
                }
                current = "";
                index += 1;
                continue;
            }
        }
        current = current + ch;
        index += 1;
    }
    let segment = trim_text(current);
    if segment.length > 0 {
        entries = append_string(entries, segment);
    }
    return entries;
}

fn find_matching_angle(text -> string, start_index -> number) -> number {
    let mut depth -> number = 0;
    let mut index -> number = start_index;
    loop {
        if index >= text.length {
            break;
        }
        let ch = text[index];
        if ch == "<" {
            depth += 1;
        } else if ch == ">" {
            if depth > 0 {
                depth -= 1;
                if depth == 0 {
                    return index;
                }
            } else {
                return index;
            }
        }
        index += 1;
    }
    return -1;
}

fn find_matching_paren(text -> string, start_index -> number) -> number {
    let mut depth -> number = 0;
    let mut index -> number = start_index;
    loop {
        if index >= text.length {
            break;
        }
        let ch = text[index];
        if ch == "\"" || ch == "'" {
            let mut lookahead = index + 1;
            loop {
                if lookahead >= text.length {
                    return -1;
                }
                let current = text[lookahead];
                if current == "\\" {
                    lookahead += 2;
                    continue;
                }
                if current == ch {
                    index = lookahead;
                    break;
                }
                lookahead += 1;
            }
        } else if ch == "(" {
            depth += 1;
        } else if ch == ")" {
            if depth > 0 {
                depth -= 1;
                if depth == 0 {
                    return index;
                }
            } else {
                return -1;
            }
        }
        index += 1;
    }
    return -1;
}

fn parse_enum_definition(lines -> string[], start_index -> number) -> EnumParseResult {
    let mut diagnostics -> string[] = [];
    let header = trim_text(lines[start_index]);
    let name_text = trim_text(strip_prefix(header, ".enum "));
    let mut enum_name -> string = name_text;
    let space_index = index_of(enum_name, " ");
    if space_index >= 0 {
    enum_name = trim_text(substring(enum_name, 0, space_index));
    }
    enum_name = strip_generics(enum_name);
    if enum_name.length == 0 {
        diagnostics = append_string(diagnostics, "unable to parse enum header: " + header);
        return EnumParseResult { definition: null, next_index: start_index + 1, diagnostics: diagnostics };
    }

    let mut variants -> NativeEnumVariant[] = [];
    let mut enum_layout_variants -> NativeEnumVariantLayout[] = [];
    let mut enum_layout_size -> number = 0;
    let mut enum_layout_align -> number = 0;
    let mut enum_layout_tag_type -> string = "";
    let mut enum_layout_tag_size -> number = 0;
    let mut enum_layout_tag_align -> number = 0;
    let mut enum_layout_header_success -> boolean = false;
    let mut enum_layout_reported_missing_header -> boolean = false;
    let mut index = start_index + 1;
    loop {
        if index >= lines.length {
            diagnostics = append_string(diagnostics, "unterminated enum " + enum_name);
            let mut enum_layout_value -> NativeEnumLayout? = null;
            if enum_layout_header_success {
                enum_layout_value = NativeEnumLayout {
                    size: enum_layout_size,
                    align: enum_layout_align,
                    tag_type: enum_layout_tag_type,
                    tag_size: enum_layout_tag_size,
                    tag_align: enum_layout_tag_align,
                    variants: enum_layout_variants,
                };
            }
            return EnumParseResult {
                definition: NativeEnum { name: enum_name, variants: variants, layout: enum_layout_value },
                next_index: index,
                diagnostics: diagnostics,
            };
        }
        let raw_line = trim_text(lines[index]);
        if raw_line.length == 0 || starts_with(raw_line, ";") {
            index += 1;
            continue;
        }
        if raw_line == "noop" {
            index += 1;
            continue;
        }
        if starts_with(raw_line, ".layout ") {
            let body = strip_prefix(raw_line, ".layout ");
            if starts_with(body, "enum ") {
                let header_result = parse_enum_layout_header(strip_prefix(body, "enum "));
                diagnostics = diagnostics.concat(header_result.diagnostics);
                if header_result.success {
                    if enum_layout_header_success {
                        diagnostics = append_string(diagnostics, "duplicate enum layout header in " + enum_name);
                    } else {
                        enum_layout_size = header_result.size;
                        enum_layout_align = header_result.align;
                        enum_layout_tag_type = header_result.tag_type;
                        enum_layout_tag_size = header_result.tag_size;
                        enum_layout_tag_align = header_result.tag_align;
                        enum_layout_header_success = true;
                    }
                }
                index += 1;
                continue;
            }
            if starts_with(body, "variant ") {
                let variant_text = strip_prefix(body, "variant ");
                // Legacy/buggy emitters sometimes encode enum header metadata as a "variant" named `enum`.
                // Accept it as header metadata (or ignore duplicates) to avoid noisy diagnostics.
                if starts_with(variant_text, "enum ") {
                    let header_result = parse_enum_layout_header(strip_prefix(variant_text, "enum "));
                    // Only apply if it parses cleanly; otherwise fall through to the normal variant parser.
                    if header_result.success {
                        if !enum_layout_header_success {
                            enum_layout_size = header_result.size;
                            enum_layout_align = header_result.align;
                            enum_layout_tag_type = header_result.tag_type;
                            enum_layout_tag_size = header_result.tag_size;
                            enum_layout_tag_align = header_result.tag_align;
                            enum_layout_header_success = true;
                        }
                        index += 1;
                        continue;
                    }
                }

                let variant_result = parse_enum_variant_layout(variant_text, enum_name);
                diagnostics = diagnostics.concat(variant_result.diagnostics);
                if variant_result.success {
                    let existing_index = find_enum_variant_layout(enum_layout_variants, variant_result.variant.name);
                    if existing_index >= 0 {
                        diagnostics = append_string(diagnostics, "duplicate enum layout variant `" + variant_result.variant.name + "` in " + enum_name);
                    } else {
                        enum_layout_variants = append_enum_variant_layout(enum_layout_variants, variant_result.variant);
                    }
                    if !enum_layout_header_success {
                        if !enum_layout_reported_missing_header {
                            diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant encountered before layout header");
                            enum_layout_reported_missing_header = true;
                        }
                    }
                }
                index += 1;
                continue;
            }
            if starts_with(body, "payload ") {
                let payload_result = parse_enum_payload_layout(strip_prefix(body, "payload "), enum_name);
                diagnostics = diagnostics.concat(payload_result.diagnostics);
                if payload_result.success {
                    let target_index = find_enum_variant_layout(enum_layout_variants, payload_result.variant_name);
                    if target_index < 0 {
                        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload references unknown variant `" + payload_result.variant_name + "`");
                    } else {
                        enum_layout_variants = update_enum_variant_fields(enum_layout_variants, target_index, payload_result.field);
                    }
                    if !enum_layout_header_success {
                        if !enum_layout_reported_missing_header {
                            diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload encountered before layout header");
                            enum_layout_reported_missing_header = true;
                        }
                    }
                }
                index += 1;
                continue;
            }
            diagnostics = append_string(diagnostics, "unsupported enum layout directive: " + raw_line);
            index += 1;
            continue;
        }
        if raw_line == ".endenum" {
            index += 1;
            break;
        }
        if starts_with(raw_line, ".variant ") {
            let parsed_variant = parse_enum_variant_line(strip_prefix(raw_line, ".variant "));
            if parsed_variant == null {
                diagnostics = append_string(diagnostics, "unable to parse enum variant: " + raw_line);
            } else {
                variants = append_enum_variant(variants, parsed_variant);
            }
            index += 1;
            continue;
        }
        diagnostics = append_string(diagnostics, "unsupported enum directive: " + raw_line);
        index += 1;
    }

    let mut enum_layout_value -> NativeEnumLayout? = null;
    if enum_layout_header_success {
        enum_layout_value = NativeEnumLayout {
            size: enum_layout_size,
            align: enum_layout_align,
            tag_type: enum_layout_tag_type,
            tag_size: enum_layout_tag_size,
            tag_align: enum_layout_tag_align,
            variants: enum_layout_variants,
        };
    }

    return EnumParseResult {
        definition: NativeEnum { name: enum_name, variants: variants, layout: enum_layout_value },
        next_index: index,
        diagnostics: diagnostics,
    };
}

fn parse_enum_variant_line(text -> string) -> NativeEnumVariant? {
    let trimmed = trim_trailing_delimiters(trim_text(text));
    if trimmed.length == 0 {
        return null;
    }
    let brace_index = index_of(trimmed, "{");
    if brace_index < 0 {
        return NativeEnumVariant { name: strip_generics(trimmed), fields: [] };
    }
    let close_index = last_index_of(trimmed, "}");
    if close_index < 0 || close_index <= brace_index {
        return null;
    }
    let name_text = strip_generics(trim_text(substring(trimmed, 0, brace_index)));
    if name_text.length == 0 {
        return null;
    }
    let fields_segment = substring(trimmed, brace_index + 1, close_index);
    let entries = split_enum_field_entries(fields_segment);
    let mut fields -> NativeEnumVariantField[] = [];
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        let entry = trim_trailing_delimiters(trim_text(entries[index]));
        if entry.length == 0 {
            index += 1;
            continue;
        }
        let parsed_field = parse_enum_variant_field(entry);
        if parsed_field == null {
            return null;
        }
        fields = append_enum_variant_field(fields, parsed_field);
        index += 1;
    }
    return NativeEnumVariant { name: name_text, fields: fields };
}

fn split_enum_field_entries(text -> string) -> string[] {
    let mut entries -> string[] = [];
    let mut current -> string = "";
    let mut depth -> number = 0;
    let mut index -> number = 0;
    loop {
        if index >= text.length {
            break;
        }
        let ch = text[index];
        if ch == "{" || ch == "[" || ch == "(" {
            depth += 1;
        } else if ch == "}" || ch == "]" || ch == ")" {
            if depth > 0 {
                depth -= 1;
            }
        }
        if ch == ";" && depth == 0 {
            entries = append_string(entries, current);
            current = "";
        } else {
            current = current + ch;
        }
        index += 1;
    }
    if current.length > 0 {
        entries = append_string(entries, current);
    }
    return entries;
}

fn parse_enum_variant_field(text -> string) -> NativeEnumVariantField? {
    let mut trimmed = trim_text(text);
    if trimmed.length == 0 {
        return null;
    }
    let mut is_mutable -> boolean = false;
    if starts_with(trimmed, "mut ") {
        is_mutable = true;
        trimmed = trim_text(strip_prefix(trimmed, "mut "));
    }
    let arrow_index = index_of(trimmed, "->");
    if arrow_index < 0 {
        return null;
    }
    let name = trim_text(substring(trimmed, 0, arrow_index));
    if name.length == 0 {
        return null;
    }
    let type_text = trim_text(substring(trimmed, arrow_index + 2, trimmed.length));
    return NativeEnumVariantField { name: name, type_annotation: type_text, mutable: is_mutable };
}

fn text_char_at(value -> string, index -> number) -> string {
    if index < 0 {
        return "";
    }
    if index >= value.length {
        return "";
    }
    return substring(value, index, index + 1);
}

fn trim_trailing_delimiters(text -> string) -> string {
    let mut end -> number = text.length;
    loop {
        if end <= 0 {
            break;
        }
        let ch = text_char_at(text, end - 1);
        if ch == "," || ch == ";" {
            end -= 1;
            continue;
        }
        break;
    }
    if end == text.length {
        return text;
    }
    return substring(text, 0, end);
}

fn maybe_trim_trailing(value -> string?) -> string? {
    if value == null {
        return null;
    }
    let trimmed = trim_trailing_delimiters(value);
    return trimmed;
}

fn parse_struct_field_line(text -> string) -> NativeStructField? {
    let mut trimmed = trim_text(text);
    if trimmed.length == 0 {
        return null;
    }
    let mut is_mutable -> boolean = false;
    if starts_with(trimmed, "mut ") {
        is_mutable = true;
        trimmed = trim_text(strip_prefix(trimmed, "mut "));
    }
    let arrow_index = index_of(trimmed, "->");
    if arrow_index < 0 {
        return null;
    }
    let name = trim_text(substring(trimmed, 0, arrow_index));
    if name.length == 0 {
        return null;
    }
    let type_text = trim_text(substring(trimmed, arrow_index + 2, trimmed.length));
    return NativeStructField { name: name, type_annotation: type_text, mutable: is_mutable };
}

fn parse_struct_layout_header(text -> string) -> StructLayoutHeaderParse {
    let tokens = split_whitespace(trim_text(text));
    let mut diagnostics -> string[] = [];
    if tokens.length == 0 {
        diagnostics = append_string(diagnostics, "struct layout header missing entries");
        return StructLayoutHeaderParse { success: false, name: "", size: 0, align: 0, diagnostics: diagnostics };
    }
    let mut name_found -> boolean = false;
    let mut size_found -> boolean = false;
    let mut align_found -> boolean = false;
    let mut name_value -> string = "";
    let mut size_value -> number = 0;
    let mut align_value -> number = 0;
    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if starts_with(token, "name=") {
            name_value = substring(token, 5, token.length);
            name_found = true;
        } else if starts_with(token, "size=") {
            let value_text = substring(token, 5, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                size_found = true;
                size_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "struct layout header has invalid size `" + value_text + "`");
            }
        } else if starts_with(token, "align=") {
            let value_text = substring(token, 6, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                align_found = true;
                align_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "struct layout header has invalid align `" + value_text + "`");
            }
        } else {
            diagnostics = append_string(diagnostics, "struct layout header unrecognized token `" + token + "`");
        }
        index += 1;
    }
    if !size_found {
        diagnostics = append_string(diagnostics, "struct layout header missing size entry");
    }
    if !align_found {
        diagnostics = append_string(diagnostics, "struct layout header missing align entry");
    }
    let success = size_found && align_found && diagnostics.length == 0;
    return StructLayoutHeaderParse { success: success, name: name_value, size: size_value, align: align_value, diagnostics: diagnostics };
}

fn parse_struct_layout_field(text -> string, struct_name -> string) -> StructLayoutFieldParse {
    let trimmed = trim_text(text);
    let mut diagnostics -> string[] = [];
    let default_field = NativeStructLayoutField { name: "", type_annotation: "", offset: 0, size: 0, align: 0 };
    if trimmed.length == 0 {
        diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field missing content");
        return StructLayoutFieldParse { success: false, field: default_field, diagnostics: diagnostics };
    }
    let tokens = split_whitespace(trimmed);
    if tokens.length == 0 {
        diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field missing entries");
        return StructLayoutFieldParse { success: false, field: default_field, diagnostics: diagnostics };
    }
    let field_name = tokens[0];
    if field_name.length == 0 {
        diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field missing name");
        return StructLayoutFieldParse { success: false, field: default_field, diagnostics: diagnostics };
    }
    let mut type_text -> string = "";
    let mut offset_found -> boolean = false;
    let mut size_found -> boolean = false;
    let mut align_found -> boolean = false;
    let mut offset_value -> number = 0;
    let mut size_value -> number = 0;
    let mut align_value -> number = 0;
    let mut index -> number = 1;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if starts_with(token, "type=") {
            type_text = substring(token, 5, token.length);
        } else if starts_with(token, "offset=") {
            let value_text = substring(token, 7, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                offset_found = true;
                offset_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field `" + field_name + "` has invalid offset `" + value_text + "`");
            }
        } else if starts_with(token, "size=") {
            let value_text = substring(token, 5, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                size_found = true;
                size_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field `" + field_name + "` has invalid size `" + value_text + "`");
            }
        } else if starts_with(token, "align=") {
            let value_text = substring(token, 6, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                align_found = true;
                align_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field `" + field_name + "` has invalid align `" + value_text + "`");
            }
        } else {
            diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field `" + field_name + "` unrecognized token `" + token + "`");
        }
        index += 1;
    }
    if type_text.length == 0 {
        diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field `" + field_name + "` missing type entry");
    }
    if !offset_found {
        diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field `" + field_name + "` missing offset entry");
    }
    if !size_found {
        diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field `" + field_name + "` missing size entry");
    }
    if !align_found {
        diagnostics = append_string(diagnostics, "struct " + struct_name + " layout field `" + field_name + "` missing align entry");
    }
    let success = type_text.length > 0 && offset_found && size_found && align_found && diagnostics.length == 0;
    let field = NativeStructLayoutField { name: field_name, type_annotation: type_text, offset: offset_value, size: size_value, align: align_value };
    return StructLayoutFieldParse { success: success, field: field, diagnostics: diagnostics };
}

fn parse_enum_layout_header(text -> string) -> EnumLayoutHeaderParse {
    let tokens = split_whitespace(trim_text(text));
    let mut diagnostics -> string[] = [];
    if tokens.length == 0 {
        diagnostics = append_string(diagnostics, "enum layout header missing entries");
        return EnumLayoutHeaderParse { success: false, name: "", size: 0, align: 0, tag_type: "", tag_size: 0, tag_align: 0, diagnostics: diagnostics };
    }
    let mut name_found -> boolean = false;
    let mut size_found -> boolean = false;
    let mut align_found -> boolean = false;
    let mut name_value -> string = "";
    let mut tag_type -> string = "";
    let mut tag_size_found -> boolean = false;
    let mut tag_align_found -> boolean = false;
    let mut size_value -> number = 0;
    let mut align_value -> number = 0;
    let mut tag_size_value -> number = 0;
    let mut tag_align_value -> number = 0;
    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if starts_with(token, "name=") {
            name_value = substring(token, 5, token.length);
            name_found = true;
        } else if starts_with(token, "size=") {
            let value_text = substring(token, 5, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                size_found = true;
                size_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum layout header has invalid size `" + value_text + "`");
            }
        } else if starts_with(token, "align=") {
            let value_text = substring(token, 6, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                align_found = true;
                align_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum layout header has invalid align `" + value_text + "`");
            }
        } else if starts_with(token, "tag_type=") {
            tag_type = substring(token, 9, token.length);
        } else if starts_with(token, "tag_size=") {
            let value_text = substring(token, 9, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                tag_size_found = true;
                tag_size_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum layout header has invalid tag_size `" + value_text + "`");
            }
        } else if starts_with(token, "tag_align=") {
            let value_text = substring(token, 10, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                tag_align_found = true;
                tag_align_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum layout header has invalid tag_align `" + value_text + "`");
            }
        } else {
            diagnostics = append_string(diagnostics, "enum layout header unrecognized token `" + token + "`");
        }
        index += 1;
    }
    if !size_found {
        diagnostics = append_string(diagnostics, "enum layout header missing size entry");
    }
    if !align_found {
        diagnostics = append_string(diagnostics, "enum layout header missing align entry");
    }
    if tag_type.length == 0 {
        diagnostics = append_string(diagnostics, "enum layout header missing tag_type entry");
    }
    if !tag_size_found {
        diagnostics = append_string(diagnostics, "enum layout header missing tag_size entry");
    }
    if !tag_align_found {
        diagnostics = append_string(diagnostics, "enum layout header missing tag_align entry");
    }
    let success = size_found && align_found && tag_type.length > 0 && tag_size_found && tag_align_found && diagnostics.length == 0;
    return EnumLayoutHeaderParse {
        success: success,
        name: name_value,
        size: size_value,
        align: align_value,
        tag_type: tag_type,
        tag_size: tag_size_value,
        tag_align: tag_align_value,
        diagnostics: diagnostics,
    };
}

fn parse_enum_variant_layout(text -> string, enum_name -> string) -> EnumLayoutVariantParse {
    let trimmed = trim_text(text);
    let mut diagnostics -> string[] = [];
    let default_variant = NativeEnumVariantLayout { name: "", tag: 0, offset: 0, size: 0, align: 0, fields: [] };
    if trimmed.length == 0 {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant missing content");
        return EnumLayoutVariantParse { success: false, variant: default_variant, diagnostics: diagnostics };
    }
    let tokens = split_whitespace(trimmed);
    if tokens.length == 0 {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant missing entries");
        return EnumLayoutVariantParse { success: false, variant: default_variant, diagnostics: diagnostics };
    }
    let variant_name = tokens[0];
    if variant_name.length == 0 {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant missing name");
        return EnumLayoutVariantParse { success: false, variant: default_variant, diagnostics: diagnostics };
    }
    let mut tag_found -> boolean = false;
    let mut offset_found -> boolean = false;
    let mut size_found -> boolean = false;
    let mut align_found -> boolean = false;
    let mut tag_value -> number = 0;
    let mut offset_value -> number = 0;
    let mut size_value -> number = 0;
    let mut align_value -> number = 0;
    let mut index -> number = 1;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if starts_with(token, "tag=") {
            let value_text = substring(token, 4, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                tag_found = true;
                tag_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant `" + variant_name + "` has invalid tag `" + value_text + "`");
            }
        } else if starts_with(token, "offset=") {
            let value_text = substring(token, 7, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                offset_found = true;
                offset_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant `" + variant_name + "` has invalid offset `" + value_text + "`");
            }
        } else if starts_with(token, "size=") {
            let value_text = substring(token, 5, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                size_found = true;
                size_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant `" + variant_name + "` has invalid size `" + value_text + "`");
            }
        } else if starts_with(token, "align=") {
            let value_text = substring(token, 6, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                align_found = true;
                align_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant `" + variant_name + "` has invalid align `" + value_text + "`");
            }
        } else {
            diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant `" + variant_name + "` unrecognized token `" + token + "`");
        }
        index += 1;
    }
    if !tag_found {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant `" + variant_name + "` missing tag entry");
    }
    if !offset_found {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant `" + variant_name + "` missing offset entry");
    }
    if !size_found {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant `" + variant_name + "` missing size entry");
    }
    if !align_found {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout variant `" + variant_name + "` missing align entry");
    }
    let success = tag_found && offset_found && size_found && align_found && diagnostics.length == 0;
    let variant = NativeEnumVariantLayout { name: variant_name, tag: tag_value, offset: offset_value, size: size_value, align: align_value, fields: [] };
    return EnumLayoutVariantParse { success: success, variant: variant, diagnostics: diagnostics };
}

fn parse_enum_payload_layout(text -> string, enum_name -> string) -> EnumLayoutPayloadParse {
    let trimmed = trim_text(text);
    let mut diagnostics -> string[] = [];
    let default_field = NativeStructLayoutField { name: "", type_annotation: "", offset: 0, size: 0, align: 0 };
    if trimmed.length == 0 {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload missing content");
        return EnumLayoutPayloadParse { success: false, variant_name: "", field: default_field, diagnostics: diagnostics };
    }
    let tokens = split_whitespace(trimmed);
    if tokens.length == 0 {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload missing entries");
        return EnumLayoutPayloadParse { success: false, variant_name: "", field: default_field, diagnostics: diagnostics };
    }
    let identifier = tokens[0];
    let dot_index = index_of(identifier, ".");
    if dot_index <= 0 || dot_index + 1 >= identifier.length {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload identifier `" + identifier + "` invalid");
        return EnumLayoutPayloadParse { success: false, variant_name: "", field: default_field, diagnostics: diagnostics };
    }
    let variant_name = substring(identifier, 0, dot_index);
    let field_name = substring(identifier, dot_index + 1, identifier.length);
    let mut type_text -> string = "";
    let mut offset_found -> boolean = false;
    let mut size_found -> boolean = false;
    let mut align_found -> boolean = false;
    let mut offset_value -> number = 0;
    let mut size_value -> number = 0;
    let mut align_value -> number = 0;
    let mut index -> number = 1;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if starts_with(token, "type=") {
            type_text = substring(token, 5, token.length);
        } else if starts_with(token, "offset=") {
            let value_text = substring(token, 7, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                offset_found = true;
                offset_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload `" + identifier + "` has invalid offset `" + value_text + "`");
            }
        } else if starts_with(token, "size=") {
            let value_text = substring(token, 5, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                size_found = true;
                size_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload `" + identifier + "` has invalid size `" + value_text + "`");
            }
        } else if starts_with(token, "align=") {
            let value_text = substring(token, 6, token.length);
            let parsed = parse_decimal_number(value_text);
            if parsed.success {
                align_found = true;
                align_value = parsed.value;
            } else {
                diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload `" + identifier + "` has invalid align `" + value_text + "`");
            }
        } else {
            diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload `" + identifier + "` unrecognized token `" + token + "`");
        }
        index += 1;
    }
    if type_text.length == 0 {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload `" + identifier + "` missing type entry");
    }
    if !offset_found {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload `" + identifier + "` missing offset entry");
    }
    if !size_found {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload `" + identifier + "` missing size entry");
    }
    if !align_found {
        diagnostics = append_string(diagnostics, "enum " + enum_name + " layout payload `" + identifier + "` missing align entry");
    }
    let success = type_text.length > 0 && offset_found && size_found && align_found && diagnostics.length == 0;
    let field = NativeStructLayoutField { name: field_name, type_annotation: type_text, offset: offset_value, size: size_value, align: align_value };
    return EnumLayoutPayloadParse { success: success, variant_name: variant_name, field: field, diagnostics: diagnostics };
}

fn parse_let_instruction(line -> string, span -> NativeSourceSpan?, value_span -> NativeSourceSpan?) -> NativeInstruction {
    let body = trim_text(strip_prefix(line, ".let "));
    let mut is_mutable -> boolean = false;
    let mut remainder -> string = body;
    if starts_with(remainder, "mut ") {
        is_mutable = true;
        remainder = trim_text(strip_prefix(remainder, "mut "));
    }
    let parsed = parse_binding_components(remainder);
    return NativeInstruction.Let {
        name: parsed.name,
        mutable: is_mutable,
        type_annotation: parsed.type_annotation,
        value: parsed.value,
        span: span,
        value_span: value_span,
    };
}

struct BindingComponents {
    name -> string;
    type_annotation -> string;
    value -> string?;
}

fn parse_binding_components(text -> string) -> BindingComponents {
    let mut name -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= text.length {
            break;
        }
        let ch = text[index];
        if ch == " " || ch == ":" || ch == "=" {
            break;
        }
        name = name + ch;
        index += 1;
    }
    name = trim_text(name);
    let mut type_annotation -> string = "";
    let mut value -> string? = null;
    let mut remainder -> string = trim_text(substring(text, index, text.length));
    if remainder.length > 0 {
        if starts_with(remainder, "->") {
            remainder = trim_text(strip_prefix(remainder, "->"));
            let assign_index = index_of(remainder, "=");
            if assign_index >= 0 {
                type_annotation = trim_text(substring(remainder, 0, assign_index));
                let value_text = trim_text(substring(remainder, assign_index + 1, remainder.length));
                if value_text.length > 0 {
                    value = value_text;
                }
            } else {
                type_annotation = trim_text(remainder);
            }
        } else if starts_with(remainder, ":") {
            remainder = trim_text(strip_prefix(remainder, ":"));
            let assign_index = index_of(remainder, "=");
            if assign_index >= 0 {
                type_annotation = trim_text(substring(remainder, 0, assign_index));
                let value_text = trim_text(substring(remainder, assign_index + 1, remainder.length));
                if value_text.length > 0 {
                    value = value_text;
                }
            } else {
                type_annotation = trim_text(remainder);
            }
        } else if starts_with(remainder, "=") {
            let value_text = trim_text(strip_prefix(remainder, "="));
            if value_text.length > 0 {
                value = value_text;
            }
        } else {
            // Fallback: treat the remainder as an initializer without prefix.
            value = remainder;
        }
    }
    return BindingComponents { name: name, type_annotation: type_annotation, value: value };
}

fn parse_function_name(header -> string) -> string {
    let mut trimmed = trim_text(header);
    if starts_with(trimmed, "async ") {
        trimmed = trim_text(strip_prefix(trimmed, "async "));
    }
    let paren_index = index_of(trimmed, "(");
    let mut name -> string = trimmed;
    if paren_index >= 0 {
        name = trim_text(substring(trimmed, 0, paren_index));
    }
    let separator_index = last_index_of(name, ".");
    if separator_index >= 0 {
        name = trim_text(substring(name, separator_index + 1, name.length));
    }
    return strip_generics(name);
}

fn parse_parameter_entry(body -> string, span -> NativeSourceSpan?) -> NativeParameter? {
    let mut trimmed = trim_text(body);
    if trimmed.length == 0 {
        return null;
    }
    let mut is_mutable -> boolean = false;
    if starts_with(trimmed, "mut ") {
        is_mutable = true;
        trimmed = trim_text(strip_prefix(trimmed, "mut "));
    }
    let mut name -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= trimmed.length {
            break;
        }
        let ch = trimmed[index];
        if ch == " " || ch == "-" || ch == "=" {
            break;
        }
        name = name + ch;
        index += 1;
    }
    name = trim_text(name);
    if name.length == 0 {
        return null;
    }
    let mut type_annotation -> string = "";
    let mut default_value -> string? = null;
    let mut remainder = trim_text(substring(trimmed, index, trimmed.length));
    if remainder.length > 0 {
        if starts_with(remainder, "->") {
            remainder = trim_text(strip_prefix(remainder, "->"));
            let assign_index = index_of(remainder, "=");
            if assign_index >= 0 {
                type_annotation = trim_text(substring(remainder, 0, assign_index));
                let default_text = trim_text(substring(remainder, assign_index + 1, remainder.length));
                if default_text.length > 0 {
                    default_value = default_text;
                }
            } else {
                type_annotation = trim_text(remainder);
            }
        } else if starts_with(remainder, "=") {
            let default_text = trim_text(strip_prefix(remainder, "="));
            if default_text.length > 0 {
                default_value = default_text;
            }
        }
    }
    return NativeParameter {
        name: name,
        type_annotation: type_annotation,
        mutable: is_mutable,
        default_value: default_value,
        span: span,
    };
}

fn line_looks_like_parameter_entry(text -> string) -> boolean {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return false;
    }
    if starts_with(trimmed, ".") {
        return false;
    }
    if starts_with(trimmed, ";") {
        return false;
    }
    let arrow_index = index_of(trimmed, "->");
    if arrow_index >= 0 {
        let mut head = trim_text(substring(trimmed, 0, arrow_index));
        if head.length == 0 {
            return false;
        }
        if starts_with(head, "mut ") {
            head = trim_text(strip_prefix(head, "mut "));
        }
        if head.length == 0 {
            return false;
        }
        if index_of(head, " ") >= 0 {
            return false;
        }
        if index_of(head, "\t") >= 0 {
            return false;
        }
        return true;
    }
    let assign_index = index_of(trimmed, "=");
    if assign_index >= 0 {
        let mut head = trim_text(substring(trimmed, 0, assign_index));
        if head.length == 0 {
            return false;
        }
        if starts_with(head, "mut ") {
            head = trim_text(strip_prefix(head, "mut "));
        }
        if head.length == 0 {
            return false;
        }
        if index_of(head, " ") >= 0 {
            return false;
        }
        if index_of(head, "\t") >= 0 {
            return false;
        }
        return true;
    }
    return false;
}

fn split_parameter_entries(body -> string) -> string[] {
    let mut entries -> string[] = [];
    let mut current -> string = "";
    let mut index -> number = 0;
    let mut depth -> number = 0;
    let mut quote -> string = "";

    loop {
        if index >= body.length {
            break;
        }
        let ch = body[index];

        if quote.length > 0 {
            current = current + ch;
            if ch == "\\" {
                if index + 1 < body.length {
                    current = current + body[index + 1];
                    index += 2;
                    continue;
                }
            }
            if ch == quote {
                quote = "";
            }
            index += 1;
            continue;
        }

        if ch == "\"" || ch == "'" {
            quote = ch;
            current = current + ch;
            index += 1;
            continue;
        }

        if ch == "(" || ch == "[" || ch == "{" {
            depth += 1;
            current = current + ch;
            index += 1;
            continue;
        }

        if ch == ")" || ch == "]" || ch == "}" {
            if depth > 0 {
                depth -= 1;
            }
            current = current + ch;
            index += 1;
            continue;
        }

        if ch == "," {
            if depth == 0 {
                let segment = trim_text(current);
                if segment.length > 0 {
                    entries = append_string(entries, segment);
                }
                current = "";
                index += 1;
                continue;
            }
        }

        current = current + ch;
        index += 1;
    }

    let segment = trim_text(current);
    if segment.length > 0 {
        entries = append_string(entries, segment);
    }

    return entries;
}

fn parse_effect_list(text -> string) -> string[] {
    let trimmed = trim_text(text);
    if trimmed == "none" {
        return [];
    }
    return split_comma_separated(trimmed);
}

fn split_whitespace(value -> string) -> string[] {
    let mut parts -> string[] = [];
    if value.length == 0 {
        return parts;
    }
    let mut start -> number = -1;
    let mut index -> number = 0;
    loop {
        if index >= value.length {
            break;
        }
        let ch = text_char_at(value, index);
        let is_space = ch == " " || ch == "\t" || ch == "\n" || ch == "\r";
        if is_space {
            if start >= 0 {
                parts = append_string(parts, substring(value, start, index));
                start = -1;
            }
        } else if start < 0 {
            start = index;
        }
        index += 1;
    }
    if start >= 0 {
        parts = append_string(parts, substring(value, start, value.length));
    }
    return parts;
}

fn parse_decimal_number(text -> string) -> NumberParseResult {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return NumberParseResult { success: false, value: 0 };
    }
    let zero = char_code("0");
    let nine = char_code("9");
    let mut index -> number = 0;
    let mut value -> number = 0;
    loop {
        if index >= trimmed.length {
            break;
        }
        let ch = trimmed[index];
        let code = char_code(ch);
        if code < zero || code > nine {
            return NumberParseResult { success: false, value: 0 };
        }
        let digit = code - zero;
        value = value * 10 + digit;
        index += 1;
    }
    return NumberParseResult { success: true, value: value };
}

fn split_lines(value -> string) -> string[] {
    let mut lines -> string[] = [];
    let mut current -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= value.length {
            break;
        }
        let ch = value[index];
        if ch == "\n" {
            lines = append_string(lines, current);
            current = "";
        } else {
            current = current + ch;
        }
        index += 1;
    }
    lines = append_string(lines, current);
    return lines;
}

fn split_comma_separated(value -> string) -> string[] {
    let mut results -> string[] = [];
    let mut current -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= value.length {
            break;
        }
        let ch = value[index];
        if ch == "," {
            results = append_string(results, trim_text(current));
            current = "";
        } else {
            current = current + ch;
        }
        index += 1;
    }
    if current.length > 0 {
        results = append_string(results, trim_text(current));
    }
    let mut filtered -> string[] = [];
    index = 0;
    loop {
        if index >= results.length {
            break;
        }
        let entry = results[index];
        if entry.length > 0 {
            filtered = append_string(filtered, entry);
        }
        index += 1;
    }
    return filtered;
}

fn strip_generics(name -> string) -> string {
    let mut result -> string = "";
    let mut depth -> number = 0;
    let mut index -> number = 0;
    loop {
        if index >= name.length {
            break;
        }
        let ch = name[index];
        if ch == "<" {
            depth += 1;
            index += 1;
            continue;
        }
        if ch == ">" {
            if depth > 0 {
                depth -= 1;
            }
            index += 1;
            continue;
        }
        if depth == 0 {
            result = result + ch;
        }
        index += 1;
    }
    return trim_text(result);
}

fn trim_text(value -> string) -> string {
    let mut start -> number = 0;
    let mut end -> number = value.length;
    loop {
        if start >= end {
            break;
        }
        let ch = value[start];
        if is_trim_char(ch) {
            start += 1;
            continue;
        }
        break;
    }
    loop {
        if end <= start {
            break;
        }
        let ch = value[end - 1];
        if is_trim_char(ch) {
            end -= 1;
            continue;
        }
        break;
    }
    if start == 0 && end == value.length {
        return value;
    }
    return substring(value, start, end);
}

fn parse_layout_manifest(text -> string) -> LayoutManifest {
    let lines = split_lines(text);
    let mut diagnostics -> string[] = [];
    let mut structs -> NativeStruct[] = [];
    let mut enums -> NativeEnum[] = [];
    let mut index -> number = 0;
    
    loop {
        if index >= lines.length {
            break;
        }
        let raw_line = lines[index];
        let mut line = trim_text(raw_line);
        if line.length == 0 {
            index += 1;
            continue;
        }
        if starts_with(line, ";") {
            index += 1;
            continue;
        }
        if starts_with(line, ".manifest ") {
            index += 1;
            continue;
        }

        // Legacy/garbled manifests may spell struct headers as `.layout field struct ...` (sometimes with extra whitespace).
        if starts_with(line, ".layout field ") {
            let tail = trim_text(strip_prefix(line, ".layout field "));
            let mut is_struct_header -> boolean = false;
            if starts_with(tail, "struct") {
                if tail.length == 6 {
                    is_struct_header = true;
                } else if tail.length > 6 {
                    let after = tail[6];
                    if is_trim_char(after) {
                        is_struct_header = true;
                    }
                }
            }
            if is_struct_header {
                let header_text = trim_text(strip_prefix(tail, "struct"));
                line = ".layout struct " + header_text;
            }
        }
        
        // Parse struct layouts
        if starts_with(line, ".layout struct ") {
            let body = strip_prefix(line, ".layout ");
            let struct_header = strip_prefix(body, "struct ");
            let header_result = parse_struct_layout_header(struct_header);
            diagnostics = diagnostics.concat(header_result.diagnostics);
            
            if header_result.success {
                let mut fields -> NativeStructLayoutField[] = [];
                let struct_name = header_result.name;
                
                // Advance to next line and collect field layout lines
                index += 1;
                loop {
                    if index >= lines.length {
                        break;
                    }
                    let field_line = trim_text(lines[index]);
                    
                    // Stop if we hit a blank line or non-field line
                    if field_line.length == 0 {
                        index += 1;
                        break;
                    }

                    // If we hit a new header, stop without consuming it.
                    if starts_with(field_line, ".layout struct ") || starts_with(field_line, ".layout enum ") {
                        break;
                    }

                    if !starts_with(field_line, ".layout field ") {
                        break;
                    }

                    let tail = trim_text(strip_prefix(field_line, ".layout field "));
                    // Some inputs incorrectly spell a header as `.layout field struct ...`.
                    // Treat it as a new header and stop without consuming it.
                    let mut is_struct_header -> boolean = false;
                    if starts_with(tail, "struct") {
                        if tail.length == 6 {
                            is_struct_header = true;
                        } else if tail.length > 6 {
                            let after = tail[6];
                            if is_trim_char(after) {
                                is_struct_header = true;
                            }
                        }
                    }
                    if is_struct_header {
                        break;
                    }

                    let field_result = parse_struct_layout_field(tail, struct_name);
                    diagnostics = diagnostics.concat(field_result.diagnostics);

                    if field_result.success {
                        fields = append_struct_layout_field(fields, field_result.field);
                    }
                    index += 1;
                }
                
                // Create minimal struct with layout info
                let struct_def = NativeStruct {
                    name: struct_name,
                    fields: [],
                    methods: [],
                    implements: [],
                    layout: NativeStructLayout {
                        size: header_result.size,
                        align: header_result.align,
                        fields: fields,
                    },
                };
                structs = append_struct(structs, struct_def);
            }
            continue;
        }
        
        // Parse enum layouts
        if starts_with(line, ".layout enum ") {
            let body = strip_prefix(line, ".layout ");
            let enum_header = strip_prefix(body, "enum ");
            let header_result = parse_enum_layout_header(enum_header);
            diagnostics = diagnostics.concat(header_result.diagnostics);
            
            if header_result.success {
                let mut variants -> NativeEnumVariantLayout[] = [];
                let enum_name = header_result.name;
                index += 1;
                
                // Collect variant and payload layouts
                loop {
                    if index >= lines.length {
                        break;
                    }
                    let variant_line = trim_text(lines[index]);
                    if variant_line.length == 0 {
                        index += 1;
                        break;
                    }
                    if !starts_with(variant_line, ".layout variant ") && !starts_with(variant_line, ".layout payload ") {
                        break;
                    }
                    
                    if starts_with(variant_line, ".layout variant ") {
                        let body = strip_prefix(variant_line, ".layout ");
                        let variant_text = strip_prefix(body, "variant ");
                        // Some legacy/buggy manifest emitters include enum header metadata as a "variant" named `enum`.
                        // Ignore these lines; the compiler can synthesize unit-enum variant layouts when needed.
                        if starts_with(variant_text, "enum ") {
                            index += 1;
                            continue;
                        }
                        let variant_result = parse_enum_variant_layout(variant_text, enum_name);
                        diagnostics = diagnostics.concat(variant_result.diagnostics);
                        
                        if variant_result.success {
                            variants = append_enum_variant_layout(variants, variant_result.variant);
                        }
                    } else if starts_with(variant_line, ".layout payload ") {
                        let body = strip_prefix(variant_line, ".layout ");
                        let payload_text = strip_prefix(body, "payload ");
                        let payload_result = parse_enum_payload_layout(payload_text, enum_name);
                        diagnostics = diagnostics.concat(payload_result.diagnostics);
                        
                        if payload_result.success && variants.length > 0 {
                            // Add payload field to last variant
                            let last_index = variants.length - 1;
                            let last_variant = variants[last_index];
                            let updated_fields = append_struct_layout_field(last_variant.fields, payload_result.field);
                            variants[last_index] = NativeEnumVariantLayout {
                                name: last_variant.name,
                                tag: last_variant.tag,
                                offset: last_variant.offset,
                                size: last_variant.size,
                                align: last_variant.align,
                                fields: updated_fields,
                            };
                        }
                    }
                    index += 1;
                }
                
                // Create minimal enum with layout info
                let enum_def = NativeEnum {
                    name: enum_name,
                    variants: [],
                    layout: NativeEnumLayout {
                        size: header_result.size,
                        align: header_result.align,
                        tag_type: header_result.tag_type,
                        tag_size: header_result.tag_size,
                        tag_align: header_result.tag_align,
                        variants: variants,
                    },
                };
                enums = append_enum(enums, enum_def);
            } else {
                index += 1;
            }
            continue;
        }
        
        index += 1;
    }
    
    return LayoutManifest {
        structs: structs,
        enums: enums,
        diagnostics: diagnostics,
    };
}

fn is_trim_char(ch -> string) -> boolean {
    return ch == " " || ch == "\n" || ch == "\r" || ch == "\t";
}

fn starts_with(value -> string, prefix -> string) -> boolean {
    if prefix.length == 0 {
        return true;
    }
    if value.length < prefix.length {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= prefix.length {
            break;
        }
        if value[index] != prefix[index] {
            return false;
        }
        index += 1;
    }
    return true;
}

fn strip_prefix(value -> string, prefix -> string) -> string {
    if !starts_with(value, prefix) {
        return value;
    }
    return substring(value, prefix.length, value.length);
}

fn index_of(value -> string, target -> string) -> number {
    if target.length == 0 {
        return 0;
    }
    let mut index -> number = 0;
    loop {
        if index + target.length > value.length {
            break;
        }
        let mut match_index -> number = 0;
        let mut matches -> boolean = true;
        loop {
            if match_index >= target.length {
                break;
            }
            if value[index + match_index] != target[match_index] {
                matches = false;
                break;
            }
            match_index += 1;
        }
        if matches {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn last_index_of(value -> string, target -> string) -> number {
    if target.length == 0 {
        return value.length;
    }
    let mut index -> number = value.length - target.length;
    loop {
        if index < 0 {
            break;
        }
        let mut match_index -> number = 0;
        let mut matches -> boolean = true;
        loop {
            if match_index >= target.length {
                break;
            }
            if value[index + match_index] != target[match_index] {
                matches = false;
                break;
            }
            match_index += 1;
        }
        if matches {
            return index;
        }
        index -= 1;
    }
    return -1;
}

fn strip_quotes(value -> string) -> string {
    if value.length >= 2 {
        let first = value[0];
        let last = value[value.length - 1];
        let is_double = first == "\"" && last == "\"";
        let is_single = first == "'" && last == "'";
        if is_double || is_single {
            return substring(value, 1, value.length - 1);
        }
    }
    return value;
}

fn append_string(values -> string[], value -> string) -> string[] {
    return values.concat([value]);
}

fn split_text(value -> string, delimiter -> string) -> string[] {
    if delimiter.length == 0 {
        return [value];
    }
    let mut parts -> string[] = [];
    let mut start -> number = 0;
    let mut index -> number = 0;
    
    loop {
        if index >= value.length {
            break;
        }
        let pos = index_of(substring(value, index, value.length), delimiter);
        if pos < 0 {
            break;
        }
        let actual_pos = index + pos;
        parts = append_string(parts, substring(value, start, actual_pos));
        start = actual_pos + delimiter.length;
        index = start;
    }
    
    if start < value.length {
        parts = append_string(parts, substring(value, start, value.length));
    } else if start == value.length {
        parts = append_string(parts, "");
    }
    
    return parts;
}

fn append_parameter_array(values -> NativeParameter[], parameter -> NativeParameter) -> NativeParameter[] {
    return values.concat([parameter]);
}
