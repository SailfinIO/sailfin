// compiler/src/effect_checker.sfn
//
// Minimal effect validation for the Sailfin self-hosted compiler. This mirrors
// the bootstrap checker by scanning routine bodies for constructs that require
// explicit capability declarations.

import {
    Block,
    Decorator,
    ElseBranch,
    Expression,
    MatchCase,
    FunctionSignature,
    MethodDeclaration,
    Program,
    Statement,
} from "./ast";
import { Token } from "./token";
import { evaluate_decorators } from "./decorator_semantics";

struct EffectViolation {
    routine_name -> string;
    missing_effects -> string[];
}

fn validate_effects(program -> Program) -> EffectViolation[] {
    let mut violations -> EffectViolation[] = [];
    let mut index -> number = 0;
    loop {
        if index >= program.statements.length {
            break;
        }
        let statement = program.statements[index];
        violations = append_violations(violations, analyze_statement(statement));
        index += 1;
    }
    return violations;
}

fn analyze_statement(statement -> Statement) -> EffectViolation[] {
    if statement.variant == "FunctionDeclaration" {
        return analyze_routine(statement.signature, statement.body, statement.decorators, statement.signature.name);
    }
    if statement.variant == "PipelineDeclaration" {
        let signature = statement.signature;
        let qualified = "pipeline " + signature.name;
        return analyze_routine(signature, statement.body, statement.decorators, qualified);
    }
    if statement.variant == "ToolDeclaration" {
        let signature = statement.signature;
        let qualified = "tool " + signature.name;
        return analyze_routine(signature, statement.body, statement.decorators, qualified);
    }
    if statement.variant == "TestDeclaration" {
        let signature = FunctionSignature {
            name: statement.name,
            is_async: false,
            parameters: [],
            return_type: null,
            effects: statement.effects,
            type_parameters: [],
        };
        let qualified = "test " + statement.name;
        return analyze_routine(signature, statement.body, statement.decorators, qualified);
    }
    if statement.variant == "StructDeclaration" {
        let mut issues -> EffectViolation[] = [];
        let mut index -> number = 0;
        loop {
            if index >= statement.methods.length {
                break;
            }
            let method = statement.methods[index];
            let qualified = statement.name + "." + method.signature.name;
            issues = append_violations(
                issues,
                analyze_routine(method.signature, method.body, method.decorators, qualified)
            );
            index += 1;
        }
        return issues;
    }
    return [];
}

fn analyze_routine(
    signature -> FunctionSignature,
    body -> Block,
    decorators -> Decorator[],
    name -> string
) -> EffectViolation[] {
    let decorator_info = evaluate_decorators(decorators);
    let mut declared -> string[] = [];
    let mut declared_index -> number = 0;
    loop {
        if declared_index >= signature.effects.length {
            break;
        }
        declared = append_unique_effect(declared, signature.effects[declared_index]);
        declared_index += 1;
    }
    let mut requires_io_from_decorators -> boolean = false;
    let mut decorator_index -> number = 0;
    loop {
        if decorator_index >= decorator_info.length {
            break;
        }
        let decorator_entry = decorator_info[decorator_index];
        if decorator_entry.name == "trace" || decorator_entry.name == "logExecution" || decorator_entry.name == "logexecution" {
            requires_io_from_decorators = true;
            break;
        }
        decorator_index += 1;
    }
    if requires_io_from_decorators {
        declared = append_unique_effect(declared, "io");
    }
    let required = required_effects(body);
    let mut missing -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= required.length {
            break;
        }
        let effect = required[index];
        if effect == "io" && requires_io_from_decorators {
            index += 1;
            continue;
        }
        if !contains_effect(declared, effect) {
            missing = append_unique_effect(missing, effect);
        }
        index += 1;
    }
    if missing.length == 0 {
        return [];
    }
    let mut result -> EffectViolation[] = [];
    result = append_violation(result, EffectViolation { routine_name: name, missing_effects: missing });
    return result;
}

fn required_effects(body -> Block) -> string[] {
    return collect_effects_from_block(body);
}

fn collect_effects_from_block(block -> Block) -> string[] {
    let mut required = collect_effects_from_tokens(block.tokens);
    let mut index -> number = 0;
    loop {
        if index >= block.statements.length {
            break;
        }
        required = merge_effects(required, collect_effects_from_statement(block.statements[index]));
        index += 1;
    }
    return required;
}

fn collect_effects_from_statement(statement -> Statement) -> string[] {
    if statement.variant == "PromptStatement" {
        let mut required = collect_effects_from_block(statement.body);
        required = append_unique_effect(required, "model");
        return required;
    }
    if statement.variant == "WithStatement" {
        let mut required = collect_effects_from_block(statement.body);
        let mut clause_index -> number = 0;
        loop {
            if clause_index >= statement.clauses.length {
                break;
            }
            let clause = statement.clauses[clause_index];
            required = merge_effects(required, collect_effects_from_expression(clause.expression));
            clause_index += 1;
        }
        return required;
    }
    if statement.variant == "ForStatement" {
        let mut required = collect_effects_from_block(statement.body);
        if statement.clause.target != null {
            required = merge_effects(required, collect_effects_from_expression(statement.clause.target));
        }
        required = merge_effects(required, collect_effects_from_expression(statement.clause.iterable));
        return required;
    }
    if statement.variant == "LoopStatement" {
        return collect_effects_from_block(statement.body);
    }
    if statement.variant == "MatchStatement" {
        let mut required = collect_effects_from_expression(statement.expression);
        let mut case_index -> number = 0;
        loop {
            if case_index >= statement.cases.length {
                break;
            }
            required = merge_effects(required, collect_effects_from_match_case(statement.cases[case_index]));
            case_index += 1;
        }
        return required;
    }
    if statement.variant == "IfStatement" {
        let mut required = collect_effects_from_expression(statement.condition);
        required = merge_effects(required, collect_effects_from_block(statement.then_block));
        if statement.else_branch != null {
            required = merge_effects(required, collect_effects_from_else_branch(statement.else_branch));
        }
        return required;
    }
    if statement.variant == "ReturnStatement" {
        return collect_effects_from_expression(statement.expression);
    }
    if statement.variant == "ExpressionStatement" {
        return collect_effects_from_expression(statement.expression);
    }
    if statement.variant == "VariableDeclaration" {
        return collect_effects_from_expression(statement.initializer);
    }
    if statement.variant == "FunctionDeclaration" {
        return collect_effects_from_block(statement.body);
    }
    if statement.variant == "PipelineDeclaration" {
        return collect_effects_from_block(statement.body);
    }
    if statement.variant == "ToolDeclaration" {
        return collect_effects_from_block(statement.body);
    }
    if statement.variant == "TestDeclaration" {
        return collect_effects_from_block(statement.body);
    }
    if statement.variant == "StructDeclaration" {
        let mut required -> string[] = [];
        let mut method_index -> number = 0;
        loop {
            if method_index >= statement.methods.length {
                break;
            }
            required = merge_effects(required, collect_effects_from_block(statement.methods[method_index].body));
            method_index += 1;
        }
        return required;
    }
    if statement.variant == "ModelDeclaration" {
        let mut required -> string[] = [];
        let mut property_index -> number = 0;
        loop {
            if property_index >= statement.properties.length {
                break;
            }
            required = merge_effects(required, collect_effects_from_expression(statement.properties[property_index].value));
            property_index += 1;
        }
        return required;
    }
    if statement.variant == "Unknown" {
        return collect_effects_from_tokens(statement.tokens);
    }
    return [];
}

fn collect_effects_from_else_branch(branch -> ElseBranch) -> string[] {
    let mut required -> string[] = [];
    if branch.body != null {
        required = merge_effects(required, collect_effects_from_block(branch.body));
    }
    if branch.statement != null {
        required = merge_effects(required, collect_effects_from_statement(branch.statement));
    }
    return required;
}

fn collect_effects_from_match_case(case -> MatchCase) -> string[] {
    let mut required = collect_effects_from_expression(case.pattern);
    if case.guard != null {
        required = merge_effects(required, collect_effects_from_expression(case.guard));
    }
    required = merge_effects(required, collect_effects_from_block(case.body));
    return required;
}

fn collect_effects_from_expression(expression -> Expression?) -> string[] {
    if expression == null {
        return [];
    }
    if expression.variant == "Call" {
        let mut required = collect_effects_from_expression(expression.callee);
        let mut argument_index -> number = 0;
        loop {
            if argument_index >= expression.arguments.length {
                break;
            }
            required = merge_effects(required, collect_effects_from_expression(expression.arguments[argument_index]));
            argument_index += 1;
        }
        required = merge_effects(required, effects_for_call(expression.callee));
        return required;
    }
    if expression.variant == "Member" {
        return collect_effects_from_expression(expression.object);
    }
    if expression.variant == "Unary" {
        return collect_effects_from_expression(expression.operand);
    }
    if expression.variant == "Binary" {
        let mut required = collect_effects_from_expression(expression.left);
        required = merge_effects(required, collect_effects_from_expression(expression.right));
        return required;
    }
    if expression.variant == "Array" {
        let mut required -> string[] = [];
        let mut element_index -> number = 0;
        loop {
            if element_index >= expression.elements.length {
                break;
            }
            required = merge_effects(required, collect_effects_from_expression(expression.elements[element_index]));
            element_index += 1;
        }
        return required;
    }
    if expression.variant == "Object" {
        let mut required -> string[] = [];
        let mut field_index -> number = 0;
        loop {
            if field_index >= expression.fields.length {
                break;
            }
            required = merge_effects(required, collect_effects_from_expression(expression.fields[field_index].value));
            field_index += 1;
        }
        return required;
    }
    if expression.variant == "Struct" {
        let mut required -> string[] = [];
        let mut field_index -> number = 0;
        loop {
            if field_index >= expression.fields.length {
                break;
            }
            required = merge_effects(required, collect_effects_from_expression(expression.fields[field_index].value));
            field_index += 1;
        }
        return required;
    }
    if expression.variant == "Lambda" {
        return collect_effects_from_block(expression.body);
    }
    if expression.variant == "Index" {
        let mut required = collect_effects_from_expression(expression.sequence);
        required = merge_effects(required, collect_effects_from_expression(expression.index));
        return required;
    }
    if expression.variant == "Range" {
        let mut required = collect_effects_from_expression(expression.start);
        required = merge_effects(required, collect_effects_from_expression(expression.end));
        return required;
    }
    if expression.variant == "Raw" {
        return [];
    }
    return [];
}

fn effects_for_call(callee -> Expression) -> string[] {
    let path = resolve_member_path(callee);
    if path == null {
        return [];
    }
    let mut required -> string[] = [];
    let root = path[0];
    let last_index = path.length - 1;
    let last = path[last_index];
    if root == "fs" {
        required = append_unique_effect(required, "io");
    }
    if root == "http" || root == "websocket" {
        required = append_unique_effect(required, "net");
    }
    if root == "print" || root == "console" {
        required = append_unique_effect(required, "io");
    }
    if root == "runtime" {
        if path.length >= 2 {
            let helper = path[1];
            if helper == "console" || helper == "fs" {
                required = append_unique_effect(required, "io");
            }
            if helper == "http" || helper == "websocket" {
                required = append_unique_effect(required, "net");
            }
        }
    }
    if last == "spawn" {
        required = append_unique_effect(required, "io");
    }
    if last == "serve" {
        required = append_unique_effect(required, "net");
    }
    if last == "sleep" {
        required = append_unique_effect(required, "clock");
    }
    return required;
}

fn resolve_member_path(expression -> Expression) -> string[]? {
    if expression.variant == "Identifier" {
        return [expression.name];
    }
    if expression.variant == "Member" {
        let base = resolve_member_path(expression.object);
        if base == null {
            return null;
        }
        return base.concat([expression.member]);
    }
    return null;
}

fn collect_effects_from_tokens(tokens -> Token[]) -> string[] {
    let mut required -> string[] = [];
    if block_contains_prompt(tokens) {
        required = append_unique_effect(required, "model");
    }
    if block_contains_fs_usage(tokens) {
        required = append_unique_effect(required, "io");
    }
    if block_contains_spawn_usage(tokens) {
        required = append_unique_effect(required, "io");
    }
    if block_contains_network_usage(tokens) {
        required = append_unique_effect(required, "net");
    }
    if block_contains_console_usage(tokens) {
        required = append_unique_effect(required, "io");
    }
    if block_contains_sleep_usage(tokens) {
        required = append_unique_effect(required, "clock");
    }
    return required;
}

fn block_contains_prompt(tokens -> Token[]) -> boolean {
    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if is_identifier_token(token, "prompt") {
            let channel_index = next_non_trivia(tokens, index + 1);
            if channel_index != -1 {
                let channel_token = tokens[channel_index];
                if channel_token.kind.variant == "Identifier" || channel_token.kind.variant == "StringLiteral" {
                    let brace_index = next_non_trivia(tokens, channel_index + 1);
                    if brace_index != -1 {
                        let brace_token = tokens[brace_index];
                        if is_symbol_token(brace_token, "{") {
                            return true;
                        }
                    }
                }
            }
        }
        index += 1;
    }
    return false;
}

fn block_contains_fs_usage(tokens -> Token[]) -> boolean {
    if contains_identifier_followed_by_symbol(tokens, "fs", ".") {
        return true;
    }
    if contains_member_chain(tokens, ["runtime", "fs"]) {
        return true;
    }
    return false;
}

fn block_contains_network_usage(tokens -> Token[]) -> boolean {
    if contains_identifier_followed_by_symbol(tokens, "http", ".") {
        return true;
    }
    if contains_identifier_followed_by_symbol(tokens, "websocket", ".") {
        return true;
    }
    if contains_identifier_call(tokens, "serve") {
        return true;
    }
    if contains_member_chain(tokens, ["runtime", "http"]) {
        return true;
    }
    if contains_member_chain(tokens, ["runtime", "websocket"]) {
        return true;
    }
    if contains_member_call(tokens, ["runtime", "serve"]) {
        return true;
    }
    return false;
}

fn block_contains_spawn_usage(tokens -> Token[]) -> boolean {
    if contains_identifier_call(tokens, "spawn") {
        return true;
    }
    if contains_member_call(tokens, ["runtime", "spawn"]) {
        return true;
    }
    return false;
}

fn block_contains_console_usage(tokens -> Token[]) -> boolean {
    if contains_identifier_followed_by_symbol(tokens, "print", ".") {
        return true;
    }
    if contains_identifier_followed_by_symbol(tokens, "console", ".") {
        return true;
    }
    if contains_member_chain(tokens, ["runtime", "console"]) {
        return true;
    }
    return false;
}

fn block_contains_sleep_usage(tokens -> Token[]) -> boolean {
    if contains_identifier_call(tokens, "sleep") {
        return true;
    }
    if contains_member_call(tokens, ["runtime", "sleep"]) {
        return true;
    }
    return false;
}

fn contains_identifier_followed_by_symbol(tokens -> Token[], name -> string, symbol -> string) -> boolean {
    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        if is_identifier_token(tokens[index], name) {
            let next_index = next_non_trivia(tokens, index + 1);
            if next_index != -1 && is_symbol_token(tokens[next_index], symbol) {
                return true;
            }
        }
        index += 1;
    }
    return false;
}

fn contains_identifier_call(tokens -> Token[], name -> string) -> boolean {
    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        if is_identifier_token(tokens[index], name) {
            let paren = next_non_trivia(tokens, index + 1);
            if paren != -1 && is_symbol_token(tokens[paren], "(") {
                return true;
            }
        }
        index += 1;
    }
    return false;
}

fn contains_member_chain(tokens -> Token[], chain -> string[]) -> boolean {
    if chain.length == 0 {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        if is_identifier_token(tokens[index], chain[0]) {
            let mut cursor -> number = index;
            let mut chain_index -> number = 1;
            let mut matches -> boolean = true;
            loop {
                if chain_index >= chain.length {
                    break;
                }
                let dot_index = next_non_trivia(tokens, cursor + 1);
                if dot_index == -1 || !is_symbol_token(tokens[dot_index], ".") {
                    matches = false;
                    break;
                }
                let member_index = next_non_trivia(tokens, dot_index + 1);
                if member_index == -1 || !is_identifier_token(tokens[member_index], chain[chain_index]) {
                    matches = false;
                    break;
                }
                cursor = member_index;
                chain_index += 1;
            }
            if matches {
                return true;
            }
        }
        index += 1;
    }
    return false;
}

fn contains_member_call(tokens -> Token[], chain -> string[]) -> boolean {
    if chain.length == 0 {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        if is_identifier_token(tokens[index], chain[0]) {
            let mut cursor -> number = index;
            let mut chain_index -> number = 1;
            let mut matches -> boolean = true;
            loop {
                if chain_index >= chain.length {
                    break;
                }
                let dot_index = next_non_trivia(tokens, cursor + 1);
                if dot_index == -1 || !is_symbol_token(tokens[dot_index], ".") {
                    matches = false;
                    break;
                }
                let member_index = next_non_trivia(tokens, dot_index + 1);
                if member_index == -1 || !is_identifier_token(tokens[member_index], chain[chain_index]) {
                    matches = false;
                    break;
                }
                cursor = member_index;
                chain_index += 1;
            }
            if matches {
                let call_index = next_non_trivia(tokens, cursor + 1);
                if call_index != -1 && is_symbol_token(tokens[call_index], "(") {
                    return true;
                }
            }
        }
        index += 1;
    }
    return false;
}

fn next_non_trivia(tokens -> Token[], start -> number) -> number {
    let mut index = start;
    loop {
        if index >= tokens.length {
            break;
        }
        let token = tokens[index];
        if !is_trivia_token(token) {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn is_trivia_token(token -> Token) -> boolean {
    return token.kind.variant == "Whitespace" || token.kind.variant == "Comment";
}

fn is_identifier_token(token -> Token, expected -> string) -> boolean {
    if token.kind.variant == "Identifier" {
        let value = token.kind.value;
        if value.length > 0 {
            return value == expected;
        }
    }
    return token.lexeme == expected;
}

fn is_symbol_token(token -> Token, expected -> string) -> boolean {
    if token.kind.variant == "Symbol" {
        let value = token.kind.value;
        if value.length > 0 {
            return value == expected;
        }
    }
    return token.lexeme == expected;
}

fn append_violations(violations -> EffectViolation[], new_violations -> EffectViolation[]) -> EffectViolation[] {
    let mut result = violations;
    let mut index -> number = 0;
    loop {
        if index >= new_violations.length {
            break;
        }
        result = result.concat([new_violations[index]]);
        index += 1;
    }
    return result;
}

fn append_violation(collection -> EffectViolation[], item -> EffectViolation) -> EffectViolation[] {
    return collection.concat([item]);
}

fn append_unique_effect(effects -> string[], effect -> string) -> string[] {
    if contains_effect(effects, effect) {
        return effects;
    }
    return effects.concat([effect]);
}

fn contains_effect(effects -> string[], effect -> string) -> boolean {
    let mut index -> number = 0;
    loop {
        if index >= effects.length {
            break;
        }
        if effects[index] == effect {
            return true;
        }
        index += 1;
    }
    return false;
}

fn merge_effects(base -> string[], additions -> string[]) -> string[] {
    let mut result = base;
    let mut index -> number = 0;
    loop {
        if index >= additions.length {
            break;
        }
        result = append_unique_effect(result, additions[index]);
        index += 1;
    }
    return result;
}
