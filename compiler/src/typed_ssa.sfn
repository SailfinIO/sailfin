    updated.next_value_id = vid + 1;
    updated = _push_value_type(updated, result_type);
    let instr: Instr = Instr {
        kind: InstrKind.Binary(),
        result: vid,
        result_type: result_type,
        bool_value: false,
        int_value: 0,
        float_bits: 0,
        unary_op: UnaryOp.Negate(),
        binary_op: op,
        compare_pred: ComparePredicate.Equal(),
        operand_a: left,
        operand_b: right,
        call_function: -1,
        call_args: [],
        call_effects: -1,
        call_capabilities: -1
    };
    updated = _push_instr(updated, instr);
    return ValueAddResult { builder: updated, value_id: vid };
}

fn emit_compare(builder: FnBuilder, pred: ComparePredicate, left: int, right: int, bool_type: int) -> ValueAddResult {
    let mut updated: FnBuilder = builder;
    let vid: int = updated.next_value_id;
    updated.next_value_id = vid + 1;
    updated = _push_value_type(updated, bool_type);
    let instr: Instr = Instr {
        kind: InstrKind.Compare(),
        result: vid,
        result_type: bool_type,
        bool_value: false,
        int_value: 0,
        float_bits: 0,
        unary_op: UnaryOp.Negate(),
        binary_op: BinaryOp.Add(),
        compare_pred: pred,
        operand_a: left,
        operand_b: right,
        call_function: -1,
        call_args: [],
        call_effects: -1,
        call_capabilities: -1
    };
    updated = _push_instr(updated, instr);
    return ValueAddResult { builder: updated, value_id: vid };
}

// emit_call produces one result for a non-Unit callee (produces_value=true)
// or none for a Unit callee (produces_value=false, value_id=-1).
fn emit_call(builder: FnBuilder, function: int, args: int[], effects: int, capabilities: int, result_type: int, produces_value: boolean) -> ValueAddResult {
    let mut updated: FnBuilder = builder;
    let mut vid: int = -1;
    let mut rtype: int = -1;
    if produces_value {
        vid = updated.next_value_id;
        updated.next_value_id = vid + 1;
        rtype = result_type;
        updated = _push_value_type(updated, result_type);
    }
    let instr: Instr = Instr {
        kind: InstrKind.Call(),
        result: vid,
        result_type: rtype,
        bool_value: false,
        int_value: 0,
        float_bits: 0,
        unary_op: UnaryOp.Negate(),
        binary_op: BinaryOp.Add(),
        compare_pred: ComparePredicate.Equal(),
        operand_a: -1,
        operand_b: -1,
        call_function: function,
        call_args: args,
        call_effects: effects,
        call_capabilities: capabilities
    };
    updated = _push_instr(updated, instr);
    return ValueAddResult { builder: updated, value_id: vid };
}

// end_block finalizes the current block with its terminator and appends it to
// the completed block sequence.
fn end_block(builder: FnBuilder, terminator: Terminator) -> FnBuilder {
    let mut updated: FnBuilder = builder;
    let block: SsaBlock = SsaBlock {
        id: updated.cur_id,
        params: updated.cur_params,
        param_types: updated.cur_param_types,
        instrs: updated.cur_instrs,
        terminator: terminator,
        has_terminator: true
    };
    let mut list: SsaBlock[] = updated.blocks;
    list.push(block);
    updated.blocks = list;
    updated.cur_active = false;
    updated.cur_instrs = [];
    updated.cur_params = [];
    updated.cur_param_types = [];
    return updated;
}

// begin_block opens the next block, minting its id and parameter ValueIds.
fn begin_block(builder: FnBuilder, param_types: int[]) -> BlockAddResult {
    let mut updated: FnBuilder = builder;
    let bid: int = updated.next_block_id;
    updated.next_block_id = bid + 1;
    let mut params: int[] = [];
    let mut i: int = 0;
    loop {
        if i >= param_types.length { break; }
        let vid: int = updated.next_value_id;
        updated.next_value_id = vid + 1;
        updated = _push_value_type(updated, param_types[i]);
        params.push(vid);
        i += 1;
    }
    updated.cur_active = true;
    updated.cur_id = bid;
    updated.cur_params = params;
    updated.cur_param_types = param_types;
    updated.cur_instrs = [];
    return BlockAddResult {
        builder: updated,
        block_id: bid,
        param_values: params
    };
}

// finish_function assembles the built function and appends it to the module.
fn finish_function(module: Module, builder: FnBuilder) -> FunctionAddResult {
    let mut updated: Module = module;
    let fid: int = updated.functions.length;
    let func: SsaFunction = SsaFunction {
        id: fid,
        symbol: builder.symbol,
        parameters: builder.parameters,
        result: builder.result,
        effects: builder.effects,
        capabilities: builder.capabilities,
        linkage: builder.linkage,
        is_defined: true,
        blocks: builder.blocks,
        value_types: builder.value_types
    };
    let mut list: SsaFunction[] = updated.functions;
    list.push(func);
    updated.functions = list;
    return FunctionAddResult { module: updated, id: fid };
}

// declare_function appends an external declaration (no body).
fn declare_function(module: Module, symbol: int, parameters: int[], result: int, effects: int, capabilities: int, linkage: Linkage) -> FunctionAddResult {
    let mut updated: Module = module;
    let fid: int = updated.functions.length;
    let func: SsaFunction = SsaFunction {
        id: fid,
        symbol: symbol,
        parameters: parameters,
        result: result,
        effects: effects,
        capabilities: capabilities,
        linkage: linkage,
        is_defined: false,
        blocks: [],
        value_types: []
    };
    let mut list: SsaFunction[] = updated.functions;
    list.push(func);
    updated.functions = list;
    return FunctionAddResult { module: updated, id: fid };
}

// set_manifest records the optional module capability manifest (§9.1).
fn set_manifest(module: Module, entry_points: int[], effects: int, capabilities: int) -> Module {
    let mut updated: Module = module;
    updated.manifest = SsaManifest {
        present: true,
        entry_points: entry_points,
        effects: effects,
        capabilities: capabilities
    };
    return updated;
}
