import { Decorator, Statement, Expression } from "./ast";
import {
    char_at,
    index_of,
    substring,
    strings_equal
} from "./string_utils";

// compiler/src/test_runner_state.sfn
//
// In-process test-runner state shared between the orchestrator
// (`cli/commands/test.sfn:run`) and the LLVM lowering
// pipeline. Replaces two flag files that issue #311 retired:
//
//   build/sailfin/.test_runner_active   — was: written by
//                                          the `sfn test` runner at
//                                          entry, deleted on each of
//                                          the 6 return paths,
//                                          read in 2 LLVM lowering
//                                          sites + 1 main.sfn site
//   build/sailfin/.trace_test_runner    — was: env-var or legacy
//                                          file, paired-read in 6
//                                          lowering trace gates
//
// Both were intra-process state masquerading as cross-process IPC.
// The test runner invokes `compile_tests_to_llvm_file_with_module_-
// imports` via direct in-process function calls, never via a
// spawned child compiler — `process.run([exe_path])` runs the
// compiled test binary, not a nested `sfn`. Each `fs.exists()`
// probe was a popen-shaped syscall on hot paths inside per-
// statement / per-function loops.
//
// Lifetime contract:
//
//   `enter_test_runner_mode(trace)` — called once at the top of
//   `cli/commands/test.sfn:run` after the env-flag is resolved.
//
//   `exit_test_runner_mode()` — called at every return path of
//   `cli/commands/test.sfn:run`, including early exits on resolver
//   failure, compile failure, link failure, and run failure.
//
// Probes (`test_runner_active()` / `test_runner_trace()`) are
// pure reads of process-local state — no IO, no effect.
let mut _active: boolean = false;
let mut _trace: boolean = false;

// Mark the running compile as part of a `sfn test` invocation.
// `trace` is the resolved value of the `SAILFIN_TRACE_TEST_RUNNER`
// env-var (with one-release back-compat for the legacy
// `build/sailfin/.trace_test_runner` flag file). The orchestrator
// resolves it once at entry; every downstream probe reads from
// the cached state instead of re-popening the env.
fn enter_test_runner_mode(trace: boolean) {
    _active = true;
    _trace = trace;
}

// Clear the markers. Called from every return path of
// `cli/commands/test.sfn:run`. Idempotent: safe to call when the
// markers are already cleared (e.g. defensive cleanup in a
// future refactor).
fn exit_test_runner_mode() {
    _active = false;
    _trace = false;
}

// True when the running compile was invoked via `sfn test`. Read
// in 10+ LLVM lowering sites — including the behavior-changing
// `is_test_module` gate in `lowering_core.sfn` — and in
// `compile_tests_to_llvm_file_with_module_imports` in `main.sfn`.
fn test_runner_active() -> boolean { return _active; }

// True only when the runner is active AND the user requested
// trace output. Replaces the paired
//
//   if fs.exists("build/sailfin/.trace_test_runner") {
//       if fs.exists("build/sailfin/.test_runner_active") { ... }
//   }
//
// pattern in 6 lowering sites. Short-circuits via `_active` so
// the `_trace` read is skipped when the runner isn't engaged.
fn test_runner_trace() -> boolean {
    if !_active { return false; }
    return _trace;
}

// ── Test discovery filters (`-k` / `--tag`, issue #849) ──────────────
//
// Process-local filter state set once by `cli/commands/test.sfn:run` after
// flag parsing and read on two sites: the file-level pre-filter in
// `cli_commands.sfn` (drops files with no matching test so no empty
// harness is ever linked) and the per-test cut in `main.sfn`'s
// `compile_tests_to_llvm_file_with_module_imports` (drops non-matching
// `TestDeclaration`s before emit so the synthesized harness only calls
// the surviving `test:` symbols). Both call `test_decl_matches_filters`
// so the two passes agree on exactly which tests survive.
//
// The multi-file subprocess path re-passes `-k`/`--tag` on each child
// argv, so each child re-establishes this state for its own leaf
// compile. An empty filter string means "no constraint on this axis".
let mut _filter_name: string = "";
let mut _filter_tag: string = "";

// Record the `-k` (name substring) and `--tag` (decorator value)
// filters for the running `sfn test` invocation. Empty strings clear
// the corresponding axis.
fn set_test_filters(name_filter: string, tag_filter: string) {
    _filter_name = name_filter;
    _filter_tag = tag_filter;
}

// True when at least one discovery filter is in effect. Callers gate
// the (parse-heavy) pre-filter and the program cut on this so an
// unfiltered `sfn test` run keeps its existing behavior byte-for-byte.
fn test_filters_active() -> boolean {
    if _filter_name.length > 0 { return true; }
    if _filter_tag.length > 0 { return true; }
    return false;
}

// Unwrap a decorator argument's value to its bare string. `@tag("slow")`
// normally parses its argument to a `StringLiteral` (already unquoted)
// via `expression_from_single_token`. The `Raw` branch is a defensive
// fallback for the case where expression normalization bails to a raw
// node carrying the literal source with its surrounding quotes. Both
// shapes resolve to the bare string; non-string arguments yield "".
fn _decorator_arg_string(expr: Expression) -> string {
    if expr.variant == "StringLiteral" { return expr.value; }
    if expr.variant == "Raw" {
        let text = expr.text;
        if text.length >= 2 {
            if char_at(text, 0) == "\"" {
                if char_at(text, text.length - 1) == "\"" {
                    return substring(text, 1, text.length - 1);
                }
            }
        }
        return text;
    }
    return "";
}

// True when `decorators` carries a `@tag("<tag>")` whose string value
// equals `tag`.
fn _decorators_have_tag(decorators: Decorator[], tag: string) -> boolean {
    let mut i: int = 0;
    loop {
        if i >= decorators.length { break; }
        let decorator = decorators[i];
        if strings_equal(decorator.name, "tag") {
            let mut j: int = 0;
            loop {
                if j >= decorator.arguments.length { break; }
                if strings_equal(_decorator_arg_string(decorator.arguments[j].expression), tag) {
                    return true;
                }
                j += 1;
            }
        }
        i += 1;
    }
    return false;
}

// True when `statement` is a `TestDeclaration` that satisfies every
// active filter. A non-test statement never matches (callers retain
// non-test statements unconditionally). With no filters active this is
// only reached behind a `test_filters_active()` guard, so it always
// sees at least one constraint.
fn test_decl_matches_filters(statement: Statement) -> boolean {
    if statement.variant != "TestDeclaration" { return false; }
    // Lifecycle hooks (#975) are not tests; they must survive `-k`/`--tag`
    // filtering so the surviving tests still get their setup/teardown.
    if statement.hook_kind != "" { return true; }
    if _filter_name.length > 0 {
        if index_of(statement.name, _filter_name) < 0 { return false; }
    }
    if _filter_tag.length > 0 {
        if !_decorators_have_tag(statement.decorators, _filter_tag) {
            return false;
        }
    }
    return true;
}

// True when `statement` is a runnable (non-hook) test matching the active
// filters. `test_decl_matches_filters` keeps lifecycle hooks alive for the
// program-trim path, but the "does this file have any test to run?" and
// "how many tests?" paths must NOT count hooks: a file whose only matches
// are hooks has nothing to run (and would synthesize an empty, main-less
// harness), and hooks must not inflate the JSON `total`. Use this predicate
// for those paths instead (#975).
fn test_decl_is_matching_test(statement: Statement) -> boolean {
    if statement.variant != "TestDeclaration" { return false; }
    if statement.hook_kind != "" { return false; }
    return test_decl_matches_filters(statement);
}
