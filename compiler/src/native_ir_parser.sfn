fn find_matching_angle(text -> string, start_index -> number) -> number {
    let mut depth -> number = 0;
    let mut index -> number = start_index;
    loop {
        if index >= text.length {
            break;
        }
        let ch = text[index];
        if ch == "<" {
            depth += 1;
        } else if ch == ">" {
            if depth > 0 {
                depth -= 1;
                if depth == 0 {
                    return index;
                }
            } else {
                return index;
            }
        }
        index += 1;
    }
    return -1;
}

fn find_matching_paren(text -> string, start_index -> number) -> number {
    let mut depth -> number = 0;
    let mut index -> number = start_index;
