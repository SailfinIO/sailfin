            if assign_index >= 0 {
                type_annotation = trim_text(substring(remainder, 0, assign_index));
                let value_text = trim_text(substring(remainder, assign_index + 1, remainder.length));
                if value_text.length > 0 {
                    value = value_text;
                }
            } else {
                type_annotation = trim_text(remainder);
            }
        } else if starts_with(remainder, ":") {
            remainder = trim_text(strip_prefix(remainder, ":"));
            let assign_index = index_of(remainder, "=");
            if assign_index >= 0 {
                type_annotation = trim_text(substring(remainder, 0, assign_index));
                let value_text = trim_text(substring(remainder, assign_index + 1, remainder.length));
                if value_text.length > 0 {
                    value = value_text;
                }
            } else {
                type_annotation = trim_text(remainder);
            }
        } else if starts_with(remainder, "=") {
            let value_text = trim_text(strip_prefix(remainder, "="));
            if value_text.length > 0 {
                value = value_text;
            }
        } else {
            // Fallback: treat the remainder as an initializer without prefix.
            value = remainder;
        }
    }
    return BindingComponents { name: name, type_annotation: type_annotation, value: value };
}

fn parse_function_name(header -> string) -> string {
    let mut trimmed = trim_text(header);
    if starts_with(trimmed, "async ") {
        trimmed = trim_text(strip_prefix(trimmed, "async "));
    }
    let paren_index = index_of(trimmed, "(");
    let mut name -> string = trimmed;
    if paren_index >= 0 {
        name = trim_text(substring(trimmed, 0, paren_index));
    }
    let separator_index = last_index_of(name, ".");
    if separator_index >= 0 {
        name = trim_text(substring(name, separator_index + 1, name.length));
    }
    return strip_generics(name);
}

fn parse_parameter_entry(body -> string, span -> NativeSourceSpan?) -> NativeParameter? {
    let mut trimmed = trim_text(body);
    if trimmed.length == 0 {
        return null;
    }
    let mut is_mutable -> boolean = false;
    if starts_with(trimmed, "mut ") {
        is_mutable = true;
        trimmed = trim_text(strip_prefix(trimmed, "mut "));
    }
    let mut name -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= trimmed.length {
            break;
        }
        let ch = trimmed[index];
        let mut _if381 -> boolean = false;
        if ch == " " { _if381 = true; }
        if ch == "-" { _if381 = true; }
        if ch == "=" { _if381 = true; }
        if _if381 {
            break;
        }
        name = name + ch;
        index += 1;
    }
    name = trim_text(name);
    if name.length == 0 {
        return null;
    }
    let mut type_annotation -> string = "";
    let mut default_value -> string? = null;
    let mut remainder = trim_text(substring(trimmed, index, trimmed.length));
    if remainder.length > 0 {
        if starts_with(remainder, "->") {
            remainder = trim_text(strip_prefix(remainder, "->"));
            let assign_index = index_of(remainder, "=");
            if assign_index >= 0 {
                type_annotation = trim_text(substring(remainder, 0, assign_index));
                let default_text = trim_text(substring(remainder, assign_index + 1, remainder.length));
                if default_text.length > 0 {
                    default_value = default_text;
                }
            } else {
                type_annotation = trim_text(remainder);
            }
        } else if starts_with(remainder, "=") {
            let default_text = trim_text(strip_prefix(remainder, "="));
            if default_text.length > 0 {
                default_value = default_text;
            }
        }
    }
    return NativeParameter {
        name: name,
        type_annotation: type_annotation,
        mutable: is_mutable,
        default_value: default_value,
        span: span,
    };
}

fn line_looks_like_parameter_entry(text -> string) -> boolean {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return false;
    }
    if starts_with(trimmed, ".") {
        return false;
    }
    if starts_with(trimmed, ";") {
        return false;
    }
    let arrow_index = index_of(trimmed, "->");
    if arrow_index >= 0 {
        let mut head = trim_text(substring(trimmed, 0, arrow_index));
        if head.length == 0 {
            return false;
        }
        if starts_with(head, "mut ") {
            head = trim_text(strip_prefix(head, "mut "));
        }
        if head.length == 0 {
            return false;
        }
        if index_of(head, " ") >= 0 {
            return false;
        }
        if index_of(head, "\t") >= 0 {
            return false;
        }
        return true;
    }
    let assign_index = index_of(trimmed, "=");
    if assign_index >= 0 {
        let mut head = trim_text(substring(trimmed, 0, assign_index));
        if head.length == 0 {
            return false;
        }
        if starts_with(head, "mut ") {
            head = trim_text(strip_prefix(head, "mut "));
        }
        if head.length == 0 {
            return false;
        }
        if index_of(head, " ") >= 0 {
            return false;
        }
        if index_of(head, "\t") >= 0 {
            return false;
        }
        return true;
    }
    return false;
}

fn split_parameter_entries(body -> string) -> string[] {
    let mut entries -> string[] = [];
    let mut current -> string = "";
    let mut index -> number = 0;
    let mut depth -> number = 0;
    let mut quote -> string = "";

    loop {
        if index >= body.length {
            break;
        }
        let ch = body[index];

        if quote.length > 0 {
            current = current + ch;
            if ch == "\\" {
                let _esc_next2 = index + 1;
                if _esc_next2 < body.length {
                    current = current + body[_esc_next2];
                    index += 2;
                    continue;
                }
            }
            if ch == quote {
                quote = "";
            }
            index += 1;
            continue;
        }

        let mut _if382 -> boolean = false;
        if ch == "\"" { _if382 = true; }
        if ch == "'" { _if382 = true; }
        if _if382 {
            quote = ch;
            current = current + ch;
            index += 1;
            continue;
        }

        let mut _if383 -> boolean = false;
        if ch == "(" { _if383 = true; }
        if ch == "[" { _if383 = true; }
        if ch == "{" { _if383 = true; }
        if _if383 {
            depth += 1;
            current = current + ch;
            index += 1;
            continue;
        }

        let mut _if384 -> boolean = false;
        if ch == ")" { _if384 = true; }
        if ch == "]" { _if384 = true; }
        if ch == "}" { _if384 = true; }
        if _if384 {
            if depth > 0 {
                depth -= 1;
            }
            current = current + ch;
            index += 1;
            continue;
        }

        if ch == "," {
            if depth == 0 {
                let segment = trim_text(current);
                if segment.length > 0 {
                    entries.push(segment);
                }
                current = "";
                index += 1;
                continue;
            }
        }

        current = current + ch;
        index += 1;
    }

    let segment = trim_text(current);
    if segment.length > 0 {
        entries.push(segment);
    }

    return entries;
}

fn parse_effect_list(text -> string) -> string[] {
    let trimmed = trim_text(text);
    if trimmed == "none" {
        return [];
    }
    return split_comma_separated(trimmed);
}

fn split_whitespace(value -> string) -> string[] {
    let mut parts -> string[] = [];
    if value.length == 0 {
        return parts;
    }
    let mut start -> number = -1;
    let mut index -> number = 0;
    loop {
        if index >= value.length {
            break;
        }
        let ch = text_char_at(value, index);
        let mut _let385 -> boolean = false;
        if ch == " " { _let385 = true; }
        if ch == "\t" { _let385 = true; }
        if ch == "\n" { _let385 = true; }
        if ch == "\r" { _let385 = true; }
        let is_space = _let385;
        if is_space {
            if start >= 0 {
                parts.push(substring(value, start, index));
                start = -1;
            }
        } else if start < 0 {
            start = index;
        }
        index += 1;
    }
    if start >= 0 {
        parts.push(substring(value, start, value.length));
    }
    return parts;
}
