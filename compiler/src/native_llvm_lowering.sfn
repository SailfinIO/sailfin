// compiler/src/native_llvm_lowering.sfn
//
// Initial LLVM lowering prototype. Converts textual `.sfn-asm` artifacts into
// a skeletal LLVM IR module so we can begin validating instruction selection
// without relying on the Python runtime scaffold.

import { NativeModule } from "./emit_native";
import { select_text_artifact, parse_native_artifact, NativeFunction, NativeInstruction, NativeParameter, NativeInterface, NativeInterfaceSignature, NativeStruct, NativeSourceSpan } from "./native_ir";
import { substring, char_code } from "./string_utils";

struct TraitImplementationDescriptor {
    struct_name -> string;
    interfaces -> string[];
}

struct TraitDescriptor {
    name -> string;
    type_parameters -> string[];
    signatures -> NativeInterfaceSignature[];
}

struct TraitMetadata {
    interfaces -> TraitDescriptor[];
    implementations -> TraitImplementationDescriptor[];
}

struct FunctionEffectEntry {
    name -> string;
    effects -> string[];
}

struct CapabilityManifestEntry {
    symbol -> string;
    effects -> string[];
}

struct CapabilityManifest {
    entries -> CapabilityManifestEntry[];
}

struct FunctionCallEntry {
    name -> string;
    callees -> string[];
}

struct LoweredLLVMResult {
    ir -> string;
    diagnostics -> string[];
    trait_metadata -> TraitMetadata;
    function_effects -> FunctionEffectEntry[];
    lifetime_regions -> LifetimeRegionMetadata[];
    capability_manifest -> CapabilityManifest;
}

struct LoweredLLVMFunction {
    lines -> string[];
    diagnostics -> string[];
    lifetime_regions -> LifetimeRegionMetadata[];
}

struct BodyResult {
    lines -> string[];
    diagnostics -> string[];
    lifetime_regions -> LifetimeRegionMetadata[];
}

struct ParameterBinding {
    name -> string;
    llvm_name -> string;
    llvm_type -> string;
    type_annotation -> string;
    consumed -> boolean;
    span -> NativeSourceSpan?;
}

struct ParameterPreparation {
    signature -> string[];
    bindings -> ParameterBinding[];
    diagnostics -> string[];
}

struct LLVMOperand {
    llvm_type -> string;
    value -> string;
}

struct ExpressionResult {
    lines -> string[];
    temp_index -> number;
    operand -> LLVMOperand?;
    diagnostics -> string[];
}

struct ArrayLiteralMetadata {
    element_type -> string;
    start_index -> number;
}

struct OwnershipInfo {
    variant -> string;
    base -> string;
    mutable -> boolean;
    span -> NativeSourceSpan?;
}

struct OwnershipConsumption {
    kind -> string;
    name -> string;
}

struct LifetimeRegionMetadata {
    binding -> string;
    base -> string;
    mutable -> boolean;
    start_span -> NativeSourceSpan?;
    scope_id -> string;
    scope_depth -> number;
}

struct StructFieldInfo {
    name -> string;
    llvm_type -> string;
    index -> number;
}

struct StructTypeInfo {
    name -> string;
    llvm_name -> string;
    fields -> StructFieldInfo[];
    align -> number;
}

struct TypeContext {
    structs -> StructTypeInfo[];
}

struct TypeContextBuild {
    context -> TypeContext;
    diagnostics -> string[];
}

struct StructLiteralField {
    name -> string;
    value -> string;
}

struct StructLiteralParse {
    recognized -> boolean;
    success -> boolean;
    type_name -> string;
    fields -> StructLiteralField[];
    diagnostics -> string[];
}

struct MemberAccessParse {
    success -> boolean;
    base -> string;
    field -> string;
}

struct LocalBinding {
    name -> string;
    pointer -> string;
    llvm_type -> string;
    type_annotation -> string;
    ownership -> OwnershipInfo?;
    consumed -> boolean;
}

struct OwnershipAnalysis {
    ownership -> OwnershipInfo?;
    consumption -> OwnershipConsumption?;
    diagnostics -> string[];
}

struct OperatorMatch {
    index -> number;
    symbol -> string;
    success -> boolean;
}

struct AssignmentParseResult {
    success -> boolean;
    target -> string;
    value -> string;
}

struct BorrowParseResult {
    recognized -> boolean;
    success -> boolean;
    target -> string;
    mutable -> boolean;
    diagnostics -> string[];
}

struct BorrowArgumentParse {
    success -> boolean;
