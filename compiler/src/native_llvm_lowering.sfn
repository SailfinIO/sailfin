fn empty_trait_metadata() -> TraitMetadata {
    return TraitMetadata { interfaces: [], implementations: [] };
}

fn empty_capability_manifest() -> CapabilityManifest {
    return CapabilityManifest { entries: [] };
}

fn build_trait_metadata(interfaces -> NativeInterface[], structs -> NativeStruct[]) -> TraitMetadata {
    let mut interface_descriptors -> TraitDescriptor[] = [];
    let mut index -> number = 0;
    loop {
        if index >= interfaces.length {
            break;
        }
        let interface = interfaces[index];
        interface_descriptors = interface_descriptors.concat([
            TraitDescriptor {
                name: interface.name,
                type_parameters: interface.type_parameters,
                signatures: interface.signatures,
            }
        ]);
        index += 1;
    }

    let mut implementation_descriptors -> TraitImplementationDescriptor[] = [];
    index = 0;
    loop {
        if index >= structs.length {
            break;
        }
        let definition = structs[index];
        if definition.implements.length > 0 {
            implementation_descriptors = implementation_descriptors.concat([
                TraitImplementationDescriptor { struct_name: definition.name, interfaces: definition.implements }
            ]);
        }
        index += 1;
    }

    return TraitMetadata { interfaces: interface_descriptors, implementations: implementation_descriptors };
}

fn append_native_function(values -> NativeFunction[], value -> NativeFunction) -> NativeFunction[] {
    return values.concat([value]);
}

fn concat_native_functions(first -> NativeFunction[], second -> NativeFunction[]) -> NativeFunction[] {
    let mut result -> NativeFunction[] = first;
    let mut index -> number = 0;
    loop {
        if index >= second.length {
            break;
        }
        result = append_native_function(result, second[index]);
        index += 1;
    }
    return result;
}

fn flatten_struct_methods(structs -> NativeStruct[]) -> NativeFunction[] {
    let mut result -> NativeFunction[] = [];
    let mut index -> number = 0;
    loop {
        if index >= structs.length {
            break;
        }
        let definition = structs[index];
        let mut method_index -> number = 0;
        loop {
            if method_index >= definition.methods.length {
                break;
            }
            let method = definition.methods[method_index];
            let qualified_name = definition.name + "::" + method.name;
            let qualified = NativeFunction {
                name: qualified_name,
                is_async: method.is_async,
                parameters: method.parameters,
                return_type: method.return_type,
                effects: method.effects,
                decorators: method.decorators,
                instructions: method.instructions,
                is_extern: false,
            };
            result = append_native_function(result, qualified);
            method_index += 1;
        }
        index += 1;
    }
    return result;
}

fn lower_to_llvm(native_module -> NativeModule) -> LoweredLLVMResult ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return lower_to_llvm_with_context(native_module, [], [], []);
    }
    let parse = parse_native_artifact(artifact.contents);
    let import_context = collect_imported_module_context(parse.imports);
    return lower_to_llvm_with_context(native_module, import_context.manifests, import_context.native_texts, import_context.diagnostics);
}

fn lower_to_llvm_for_tests(native_module -> NativeModule) -> LoweredLLVMResult ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return lower_to_llvm_with_context_for_tests(native_module, [], [], []);
    }
    let parse = parse_native_artifact(artifact.contents);
    let import_context = collect_imported_module_context(parse.imports);
    return lower_to_llvm_with_context_for_tests(native_module, import_context.manifests, import_context.native_texts, import_context.diagnostics);
}

fn lower_to_llvm_with_manifests(native_module -> NativeModule, imported_manifests -> LayoutManifest[]) -> LoweredLLVMResult {
    return lower_to_llvm_with_context(native_module, imported_manifests, [], []);
}

fn lower_to_llvm_with_context_for_tests(native_module -> NativeModule, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let base = lower_to_llvm_with_context(native_module, imported_manifests, imported_native_texts, imported_diagnostics);
    if base.ir.length == 0 {
        return base;
    }

    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return base;
    }

    let parse = parse_native_artifact(artifact.contents);
    let mut tests -> NativeFunction[] = [];
    let mut has_main -> boolean = false;

    let mut index -> number = 0;
    loop {
        if index >= parse.functions.length {
            break;
        }
        let fun = parse.functions[index];
        if fun.name == "main" {
            has_main = true;
        }
        if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
            tests = tests.concat([fun]);
        }
        index += 1;
    }

    if tests.length == 0 {
        return base;
    }

    // For now we only synthesize `main` when no user-provided `main` exists.
    if has_main {
        let mut updated = base;
        updated.diagnostics = updated.diagnostics.concat([
            "llvm lowering (test): module defines `main`; skipping synthesized test harness",
        ]);
        return updated;
    }

    let harness = render_test_harness_main(tests);
    let mut updated = base;
    if updated.ir.length > 0 {
        updated.ir = updated.ir + "\n";
    }
    updated.ir = updated.ir + join_with_separator(harness, "\n") + "\n";
    return updated;
}

fn module_global_symbol(name -> string) -> string {
    return "@global." + sanitize_symbol(name);
}

fn module_init_symbol(module_name -> string) -> string {
    return "@sailfin_module_init__" + sanitize_symbol(module_name);
}

fn module_user_main_symbol(module_name -> string) -> string {
    return "sailfin_user_main__" + sanitize_symbol(module_name);
}

fn lower_module_bindings_to_globals(bindings -> NativeBinding[], context -> TypeContext, module_name -> string) -> ModuleGlobalLoweringResult {
    let mut diagnostics -> string[] = [];
    let mut preamble_lines -> string[] = [];
    let mut init_lines -> string[] = [];
    let mut locals -> LocalBinding[] = [];
    let mut collected_string_constants -> StringConstant[] = empty_string_constant_set();
    let init_symbol = module_init_symbol(module_name);
    let mut needs_init -> boolean = false;

    if bindings.length == 0 {
        return ModuleGlobalLoweringResult {
            preamble_lines: [],
            init_function_lines: [],
            init_function_symbol: init_symbol,
            needs_init_call: false,
            locals: [],
            string_constants: collected_string_constants,
            diagnostics: [],
        };
    }

    let scope_id = format_root_scope_id("module");
    let scope_depth = 0;

    let mut index -> number = 0;
    loop {
        if index >= bindings.length {
            break;
        }
        let binding = bindings[index];
        let mut type_annotation = trim_text(binding.type_annotation);
        let mut effective_type_annotation = binding.type_annotation;
        if type_annotation.length == 0 && binding.value != null {
            let init_expr = trim_text(binding.value);
            if is_string_literal(init_expr) {
                type_annotation = "string";
                effective_type_annotation = "string";
            }
        }
        if type_annotation.length == 0 {
            index += 1;
            continue;
        }
        let name = binding.name;
        let global_name = module_global_symbol(name);
        let mut llvm_type -> string = "";
        if type_annotation.length > 0 {
            llvm_type = map_local_type(context, type_annotation);
        }
        if llvm_type.length == 0 {
            diagnostics = append_string(diagnostics, "llvm lowering: module binding `" + name + "` has unsupported type annotation `" + effective_type_annotation + "`");
            llvm_type = "double";
        }

        if llvm_type == "i8*" {
            preamble_lines = append_string(preamble_lines, global_name + " = global i8* null");
            if binding.value != null {
                needs_init = true;
            }
        } else {
            let mut initializer_text -> string = default_return_literal(llvm_type);
            if binding.value != null {
                let init_expr = trim_text(binding.value);
                if llvm_type == "double" && is_number_literal(init_expr) {
                    initializer_text = normalise_number_literal(init_expr);
                } else if llvm_type == "i64" && is_integer_literal(init_expr) {
                    initializer_text = init_expr;
                } else if llvm_type == "i32" && is_integer_literal(init_expr) {
                    initializer_text = init_expr;
                } else if llvm_type == "i1" && is_boolean_literal(init_expr) {
                    initializer_text = "0";
                    if matches_case_insensitive(init_expr, "true") {
                        initializer_text = "1";
                    }
                } else {
                    needs_init = true;
                }
            }
            preamble_lines = append_string(preamble_lines, global_name + " = global " + llvm_type + " " + initializer_text);
        }

        locals = append_local_binding(locals, LocalBinding {
            name: name,
            pointer: global_name,
            llvm_type: llvm_type,
            type_annotation: effective_type_annotation,
            ownership: null,
            consumed: false,
            scope_id: scope_id,
            scope_depth: scope_depth,
        });

        index += 1;
    }

    if !needs_init {
        return ModuleGlobalLoweringResult {
            preamble_lines: preamble_lines,
            init_function_lines: [],
            init_function_symbol: init_symbol,
            needs_init_call: false,
            locals: locals,
            string_constants: collected_string_constants,
            diagnostics: diagnostics,
        };
    }

    init_lines = init_lines.concat([
        "define internal void " + init_symbol + "() {",
        "block.entry:",
    ]);

    let mut init_index -> number = 0;
    let mut current_temp -> number = 0;
    let mut current_lines -> string[] = init_lines;
    loop {
        if init_index >= bindings.length {
            break;
        }
        let binding = bindings[init_index];
        let mut type_annotation = trim_text(binding.type_annotation);
        if type_annotation.length == 0 && binding.value != null {
            let init_expr = trim_text(binding.value);
            if is_string_literal(init_expr) {
                type_annotation = "string";
            }
        }
        if type_annotation.length == 0 {
            init_index += 1;
            continue;
        }
        if binding.value == null {
            init_index += 1;
            continue;
        }
        let name = binding.name;
        let global_name = module_global_symbol(name);
        let local = find_local_binding(locals, name);
        if local == null {
            init_index += 1;
            continue;
        }
        let llvm_type = local.llvm_type;
        let init_expr = trim_text(binding.value);

        if llvm_type == "i8*" {
            let lowered = lower_expression(init_expr, [], locals, current_temp, current_lines, [], context, llvm_type);
            diagnostics = diagnostics.concat(lowered.diagnostics);
            current_lines = lowered.lines;
            current_temp = lowered.temp_index;
            collected_string_constants = merge_string_constants(collected_string_constants, lowered.string_constants);
            if lowered.operand != null {
                current_lines = append_string(current_lines, "  store i8* " + lowered.operand.value + ", i8** " + global_name);
            } else {
                diagnostics = append_string(diagnostics, "llvm lowering: failed to initialize module string binding `" + name + "`");
            }
        } else {
            let mut should_store -> boolean = true;
            if llvm_type == "double" && is_number_literal(init_expr) {
                should_store = false;
            }
            if llvm_type == "i64" && is_integer_literal(init_expr) {
                should_store = false;
            }
            if llvm_type == "i32" && is_integer_literal(init_expr) {
                should_store = false;
            }
            if llvm_type == "i1" && is_boolean_literal(init_expr) {
                should_store = false;
            }
            if should_store {
                let lowered = lower_expression(init_expr, [], locals, current_temp, current_lines, [], context, llvm_type);
                diagnostics = diagnostics.concat(lowered.diagnostics);
                current_lines = lowered.lines;
                current_temp = lowered.temp_index;
                collected_string_constants = merge_string_constants(collected_string_constants, lowered.string_constants);
                if lowered.operand != null {
                    let coerced = coerce_operand_to_type(lowered.operand, llvm_type, current_temp, current_lines);
                    diagnostics = diagnostics.concat(coerced.diagnostics);
                    current_lines = coerced.lines;
                    current_temp = coerced.temp_index;
                    if coerced.operand != null {
                        current_lines = append_string(current_lines, "  store " + llvm_type + " " + coerced.operand.value + ", " + llvm_type + "* " + global_name);
                    }
                }
            }
        }

        init_index += 1;
    }

    current_lines = append_string(current_lines, "  ret void");
    current_lines = append_string(current_lines, "}");

    return ModuleGlobalLoweringResult {
        preamble_lines: preamble_lines,
        init_function_lines: current_lines,
        init_function_symbol: init_symbol,
        needs_init_call: true,
        locals: locals,
        string_constants: collected_string_constants,
        diagnostics: diagnostics,
    };
}

fn lower_to_llvm_with_context(native_module -> NativeModule, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let mut diagnostics -> string[] = [];
    if imported_diagnostics.length > 0 {
        diagnostics = diagnostics.concat(imported_diagnostics);
    }
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        diagnostics = append_string(diagnostics, "no sailfin-native-text artifact present");
        let empty_constants = empty_string_constant_set();
        return LoweredLLVMResult {
            ir: "",
            diagnostics: diagnostics,
            trait_metadata: empty_trait_metadata(),
            function_effects: [],
            lifetime_regions: [],
            capability_manifest: empty_capability_manifest(),
            string_constants: empty_constants,
        };
    }

    let parse = parse_native_artifact(artifact.contents);
    diagnostics = diagnostics.concat(parse.diagnostics);

    // Only exported symbols should keep external linkage across modules.
    let exported_symbols = collect_exported_symbol_names(parse.imports);

    let manifest_artifact = select_layout_manifest_artifact(native_module.artifacts);
    let mut module_manifest -> LayoutManifest? = null;
    if manifest_artifact != null {
        let parsed_manifest = parse_layout_manifest(manifest_artifact.contents);
        diagnostics = diagnostics.concat(parsed_manifest.diagnostics);
        module_manifest = parsed_manifest;
    }

    let manifest_application = apply_layout_manifest_to_module(parse.structs, parse.enums, module_manifest);
    diagnostics = diagnostics.concat(manifest_application.diagnostics);
    let module_structs = manifest_application.structs;
    let module_enums = manifest_application.enums;

    // Gather imported module context (layout + signatures) to improve lowering fidelity
    let mut imported_structs -> NativeStruct[] = [];
    let mut imported_enums -> NativeEnum[] = [];
    let mut imported_interfaces -> NativeInterface[] = [];
    let mut imported_functions -> NativeFunction[] = [];
    let mut imported_struct_methods -> NativeFunction[] = [];

    let manifest_count = imported_manifests.length;
    let mut text_index -> number = 0;
    loop {
        if text_index >= imported_native_texts.length {
            break;
        }
        let native_text = imported_native_texts[text_index];
        let mut manifest_for_module -> LayoutManifest? = null;
        if text_index < manifest_count {
            let candidate_manifest = imported_manifests[text_index];
            manifest_for_module = candidate_manifest;
        }
        if native_text.length == 0 {
            if manifest_for_module != null {
                let manifest_only = manifest_for_module;
                imported_structs = imported_structs.concat(manifest_only.structs);
                imported_enums = imported_enums.concat(manifest_only.enums);
            }
            text_index += 1;
            continue;
        }

        let imported_parse = parse_native_artifact(native_text);
        let applied_import = apply_layout_manifest_to_module(imported_parse.structs, imported_parse.enums, manifest_for_module);

        imported_structs = imported_structs.concat(applied_import.structs);
        imported_enums = imported_enums.concat(applied_import.enums);
        imported_interfaces = imported_interfaces.concat(imported_parse.interfaces);
        imported_functions = imported_functions.concat(imported_parse.functions);
        let imported_methods = flatten_struct_methods(applied_import.structs);
        imported_struct_methods = imported_struct_methods.concat(imported_methods);
        text_index += 1;
    }

    if imported_native_texts.length < manifest_count {
        let mut manifest_index -> number = imported_native_texts.length;
        loop {
            if manifest_index >= manifest_count {
                break;
            }
            let leftover_manifest = imported_manifests[manifest_index];
            imported_structs = imported_structs.concat(leftover_manifest.structs);
            imported_enums = imported_enums.concat(leftover_manifest.enums);
            manifest_index += 1;
        }
    }

    let combined_structs = module_structs.concat(imported_structs);
    let combined_enums = module_enums.concat(imported_enums);
    let combined_interfaces = parse.interfaces.concat(imported_interfaces);

    let trait_metadata = build_trait_metadata(combined_interfaces, combined_structs);
    let fixed_enums = fixup_enum_layouts(combined_enums);
    diagnostics = diagnostics.concat(fixed_enums.diagnostics);
    let type_build = build_type_context(combined_structs, fixed_enums.enums, combined_interfaces);
    diagnostics = diagnostics.concat(type_build.diagnostics);
    let type_context = type_build.context;

    let module_struct_methods = flatten_struct_methods(module_structs);
    let local_functions = concat_native_functions(parse.functions, module_struct_methods);
    let mut context_functions = concat_native_functions(local_functions, imported_functions);
    context_functions = concat_native_functions(context_functions, imported_struct_methods);

    let mut runtime_helpers = collect_runtime_helper_targets(local_functions);
    runtime_helpers = append_unique_effect(runtime_helpers, "get_field");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.concat");
    runtime_helpers = append_unique_effect(runtime_helpers, "number.to_string");
    runtime_helpers = append_unique_effect(runtime_helpers, "strings_equal");
    runtime_helpers = append_unique_effect(runtime_helpers, "runtime.bounds_check");
    runtime_helpers = append_unique_effect(runtime_helpers, "mark_persistent");
    let direct_effects = collect_direct_function_effects(context_functions);
    let call_graph = collect_function_call_graph(context_functions);
    let aggregated_effects = propagate_function_effects(direct_effects, call_graph);

    let mut function_effects -> FunctionEffectEntry[] = [];
    let mut lifetime_regions -> LifetimeRegionMetadata[] = [];
    let mut lines -> string[] = [];
    lines = append_string(lines, "source_filename = \"" + module_source_filename(native_module.module_name) + "\"");
    lines = append_string(lines, "");

    let trait_lines = render_trait_metadata_comments(trait_metadata);
    if trait_lines.length > 0 {
        lines = lines.concat(trait_lines);
        lines = append_string(lines, "");
    }

    let struct_type_lines = render_struct_type_definitions(type_context, context_functions);
    if struct_type_lines.length > 0 {
        lines = lines.concat(struct_type_lines);
        lines = append_string(lines, "");
    }

    let enum_type_lines = render_enum_type_definitions(type_context);
    if enum_type_lines.length > 0 {
        lines = lines.concat(enum_type_lines);
        lines = append_string(lines, "");
    }

    let interface_type_lines = render_interface_type_definitions(type_context);
    if interface_type_lines.length > 0 {
        lines = lines.concat(interface_type_lines);
        lines = append_string(lines, "");
    }

    // Async/future runtime types (opaque in LLVM; implemented by the native runtime).
    lines = lines.concat([
        "%SailfinFutureNumber = type opaque",
        "%SailfinFutureBool = type opaque",
        "%SailfinFuturePtr = type opaque",
        "%SailfinFutureVoid = type opaque",
        "%SailfinFutureString = type opaque",
        "",
        "declare %SailfinFutureNumber* @sailfin_runtime_spawn_number(double ()*)",
        "declare %SailfinFutureNumber* @sailfin_runtime_spawn_number_ctx(double (i8*)*, i8*)",
        "declare double @sailfin_runtime_await_number(%SailfinFutureNumber*)",
        "declare %SailfinFutureBool* @sailfin_runtime_spawn_bool(i1 ()*)",
        "declare %SailfinFutureBool* @sailfin_runtime_spawn_bool_ctx(i1 (i8*)*, i8*)",
        "declare i1 @sailfin_runtime_await_bool(%SailfinFutureBool*)",
        "declare %SailfinFuturePtr* @sailfin_runtime_spawn_ptr(i8* ()*)",
        "declare %SailfinFuturePtr* @sailfin_runtime_spawn_ptr_ctx(i8* (i8*)*, i8*)",
        "declare i8* @sailfin_runtime_await_ptr(%SailfinFuturePtr*)",
        "declare %SailfinFutureVoid* @sailfin_runtime_spawn_void(void ()*)",
        "declare %SailfinFutureVoid* @sailfin_runtime_spawn_void_ctx(void (i8*)*, i8*)",
        "declare void @sailfin_runtime_await_void(%SailfinFutureVoid*)",
        "declare %SailfinFutureString* @sailfin_runtime_spawn_string(i8* ()*)",
        "declare %SailfinFutureString* @sailfin_runtime_spawn_string_ctx(i8* (i8*)*, i8*)",
        "declare i8* @sailfin_runtime_await_string(%SailfinFutureString*)",
        "",
    ]);

    let vtable_type_lines = render_vtable_type_definitions(type_context);
    if vtable_type_lines.length > 0 {
        lines = lines.concat(vtable_type_lines);
        lines = append_string(lines, "");
    }

    let vtable_const_lines = render_vtable_constants(type_context);
    if vtable_const_lines.length > 0 {
        lines = lines.concat(vtable_const_lines);
        lines = append_string(lines, "");
    }

    let helper_declarations = render_runtime_helper_declarations(runtime_helpers, local_functions);
    if helper_declarations.length > 0 {
        lines = lines.concat(helper_declarations);
        lines = append_string(lines, "");
    }

    // Declare imported functions from other modules (excluding local functions)
    let imported_declarations = render_imported_function_declarations(imported_functions, local_functions, type_context);
    if imported_declarations.length > 0 {
        lines = lines.concat(imported_declarations);
        lines = append_string(lines, "");
    }

    // Provide libc declarations for common helpers when not declared in the module.
    if find_function_by_name(context_functions, "malloc") == null {
        lines = append_string(lines, "declare noalias i8* @malloc(i64)");
    }
    if find_function_by_name(context_functions, "free") == null {
        lines = append_string(lines, "declare void @free(i8*)");
    }
    lines = append_string(lines, "");

    // Declare the runtime global (provided by the Python bootstrap runtime)
    lines = append_string(lines, "@runtime = external global i8**");
    lines = append_string(lines, "");

    // Lower module-level `let` bindings into LLVM globals (and an optional init function).
    let module_globals = lower_module_bindings_to_globals(parse.bindings, type_context, native_module.module_name);
    diagnostics = diagnostics.concat(module_globals.diagnostics);
    if module_globals.preamble_lines.length > 0 {
        lines = lines.concat(module_globals.preamble_lines);
        lines = append_string(lines, "");
    }

    let mut preamble_lines -> string[] = lines;
    let mut function_lines -> string[] = [];

    if module_globals.init_function_lines.length > 0 {
        function_lines = function_lines.concat(module_globals.init_function_lines);
        function_lines = append_string(function_lines, "");
    }

    let mut index -> number = 0;
    let mut has_add_function -> boolean = false;
    let mut all_string_constants -> StringConstant[] = module_globals.string_constants;
    loop {
        if index >= local_functions.length {
            break;
        }
        let current_function = local_functions[index];
        let aggregated_entry = find_function_effect_entry(aggregated_effects, current_function.name);
        let mut effective_effects -> string[] = [];
        if aggregated_entry != null {
            effective_effects = aggregated_entry.effects;
        }
        function_effects = append_function_effect_entry(function_effects, FunctionEffectEntry {
            name: current_function.name,
            effects: effective_effects,
        });
        let lowered = emit_function(current_function, context_functions, effective_effects, type_context, native_module.module_name, native_module.entry_points, exported_symbols, imported_functions, module_globals.locals, module_globals.init_function_symbol, module_globals.needs_init_call);
        if sanitize_symbol(current_function.name) == "add" {
            has_add_function = true;
        }
        diagnostics = diagnostics.concat(lowered.diagnostics);
        lifetime_regions = lifetime_regions.concat(lowered.lifetime_regions);
        all_string_constants = merge_string_constants(all_string_constants, lowered.string_constants);
        if lowered.lines.length > 0 {
            function_lines = function_lines.concat(lowered.lines);
            if index + 1 < local_functions.length {
                function_lines = append_string(function_lines, "");
            }
        }
        index += 1;
    }

    if !has_add_function {
        if function_lines.length > 0 {
            function_lines = append_string(function_lines, "");
        }
        function_lines = function_lines.concat([
            "define internal double @add(double %a, double %b) {",
            "entry:",
            "  %t0 = fadd double %a, %b",
            "  ret double %t0",
            "}"
        ]);
    }

    let string_constant_lines = render_string_constants(all_string_constants);
    let mut final_lines -> string[] = preamble_lines;
    if string_constant_lines.length > 0 {
        final_lines = final_lines.concat(string_constant_lines);
        final_lines = append_string(final_lines, "");
    }
    final_lines = final_lines.concat(function_lines);
    final_lines = ensure_intrinsic_declarations(final_lines);

    let ir = join_with_separator(final_lines, "\n");
    let manifest = build_capability_manifest(native_module.entry_points, function_effects);
    let mut output -> string = ir;
    if output.length > 0 {
        output = output + "\n";
    }
    return LoweredLLVMResult {
        ir: output,
        diagnostics: diagnostics,
        trait_metadata: trait_metadata,
        function_effects: function_effects,
        lifetime_regions: lifetime_regions,
        capability_manifest: manifest,
        string_constants: all_string_constants,
    };
}

fn module_source_filename(module_name -> string) -> string {
    if module_name.length == 0 {
        return "sailfin";
    }
    // Avoid appending twice.
    if module_name.length >= 4 {
        let suffix = substring(module_name, module_name.length - 4, module_name.length);
        if suffix == ".sfn" {
            return module_name;
        }
    }
    return module_name + ".sfn";
}

fn ensure_intrinsic_declarations(lines -> string[]) -> string[] {
    let mut uses_round -> boolean = false;
    let mut has_round_decl -> boolean = false;
    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let line = lines[index];
        if index_of(line, "call double @round(") >= 0 {
            uses_round = true;
        }
        let trimmed = trim_text(line);
        if starts_with(trimmed, "declare double @round(double)") {
            has_round_decl = true;
        }
        index += 1;
    }

    if !uses_round || has_round_decl {
        return lines;
    }

    // Insert right after source_filename, preserving the existing blank line.
    return insert_string_at(lines, 1, "declare double @round(double)");
}

fn insert_string_at(values -> string[], insert_index -> number, value -> string) -> string[] {
    let mut out -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= values.length {
            break;
        }
        if index == insert_index {
            out = append_string(out, value);
        }
        out = append_string(out, values[index]);
        index += 1;
    }
    if insert_index >= values.length {
        out = append_string(out, value);
    }
    return out;
}

fn extract_all_call_targets(expression -> string) -> string[] {
    let mut results -> string[] = [];
    let expression_len = expression.length;
    if expression_len == 0 {
        return results;
    }
    let mut index -> number = 0;
    loop {
        if index >= expression_len {
            break;
        }
        let ch = expression[index];
        if ch == "\"" {
            index = skip_string_literal(expression, index + 1);
            continue;
        }
        if is_identifier_start_char(ch) {
            let start_index = index;
            index += 1;
            loop {
                if index >= expression_len {
                    break;
                }
                let current = expression[index];
                if is_identifier_part_char(current) {
                    index += 1;
                    continue;
                }
                if current == "." || current == ":" {
                    index += 1;
                    continue;
                }
                break;
            }
            let candidate = substring(expression, start_index, index);
            if candidate.length > 0 {
                let mut cursor -> number = index;
                loop {
                    if cursor >= expression_len {
                        break;
                    }
                    let next = expression[cursor];
                    if is_trim_char(next) {
                        cursor += 1;
                        continue;
                    }
                    if next == "(" {
                        results = append_unique_effect(results, candidate);
                    }
                    break;
                }
            }
            continue;
        }
        index += 1;
    }
    return results;
}

fn filter_runtime_helper_targets(targets -> string[]) -> string[] {
    let mut results -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= targets.length {
            break;
        }
        let trimmed = trim_text(targets[index]);
        let mut helper = find_runtime_helper(trimmed);
        if helper == null {
            let dot_index = find_last_index_of_char(trimmed, ".");
            if dot_index >= 0 && dot_index + 1 < trimmed.length {
                let suffix = substring(trimmed, dot_index + 1, trimmed.length);
                helper = find_runtime_helper(suffix);
            }
        }
        if helper == null {
            let colon_index = find_last_index_of_char(trimmed, ":");
            if colon_index >= 0 && colon_index + 1 < trimmed.length {
                let suffix = substring(trimmed, colon_index + 1, trimmed.length);
                helper = find_runtime_helper(suffix);
            }
        }
        if helper == null {
            let length_suffix = ".length";
            if trimmed.length >= length_suffix.length {
                let maybe_length = substring(trimmed, trimmed.length - length_suffix.length, trimmed.length);
                if maybe_length == length_suffix {
                    helper = find_runtime_helper("string.length");
                    if helper == null {
                        helper = find_runtime_helper("len(string)");
                    }
                }
            }
            if helper == null {
                let concat_suffix = ".concat";
                if trimmed.length >= concat_suffix.length {
                    let maybe_concat = substring(trimmed, trimmed.length - concat_suffix.length, trimmed.length);
                    if maybe_concat == concat_suffix {
                        helper = find_runtime_helper("concat");
                    }
                }
            }
        }
        if helper != null {
            results = append_unique_effect(results, helper.target);
        }
        index += 1;
    }
    return results;
}

fn collect_runtime_property_targets(expression -> string) -> string[] {
    let trimmed = trim_text(expression);
    if trimmed.length == 0 {
        return [];
    }
    let mut results -> string[] = [];
    if contains_dot_property(trimmed, "length") {
        results = append_unique_effect(results, "string.length");
    }
    return results;
}

fn contains_dot_property(expression -> string, name -> string) -> boolean {
    let suffix = "." + name;
    let suffix_length = suffix.length;
    if suffix_length == 0 || expression.length < suffix_length {
        return false;
    }
    let mut index -> number = 0;
    let mut in_single -> boolean = false;
    let mut in_double -> boolean = false;
    let mut escape_next -> boolean = false;
    loop {
        if index >= expression.length {
            break;
        }
        let ch = expression[index];
        if in_double {
            if escape_next {
                escape_next = false;
            } else if ch == "\\" {
                escape_next = true;
            } else if ch == "\"" {
                in_double = false;
            }
            index += 1;
            continue;
        }
        if in_single {
            if escape_next {
                escape_next = false;
            } else if ch == "\\" {
                escape_next = true;
            } else if ch == "'" {
                in_single = false;
            }
            index += 1;
            continue;
        }
        if ch == "\"" {
            in_double = true;
            index += 1;
            continue;
        }
        if ch == "'" {
            in_single = true;
            index += 1;
            continue;
        }
        if index + suffix_length <= expression.length {
            let mut match_index -> number = 0;
            let mut matches -> boolean = true;
            loop {
                if match_index >= suffix_length {
                    break;
                }
                let expr_char = char_at(expression, index + match_index);
                let suffix_char = char_at(suffix, match_index);
                if expr_char.length == 0 || suffix_char.length == 0 || expr_char != suffix_char {
                    matches = false;
                    break;
                }
                match_index += 1;
            }
            if matches {
                let after_index = index + suffix_length;
                let after_char = char_at(expression, after_index);
                if after_char.length == 0 {
                    return true;
                }
                if !is_identifier_part_char(after_char) {
                    return true;
                }
            }
        }
        index += 1;
    }
    return false;
}

fn append_function_call_entry(entries -> FunctionCallEntry[], entry -> FunctionCallEntry) -> FunctionCallEntry[] {
    return entries.concat([entry]);
}

fn replace_function_effect_entry(entries -> FunctionEffectEntry[], position -> number, entry -> FunctionEffectEntry) -> FunctionEffectEntry[] {
    let mut result -> FunctionEffectEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        if index == position {
            result = result.concat([entry]);
        } else {
            result = result.concat([entries[index]]);
        }
        index += 1;
    }
    return result;
}

fn find_function_effect_entry_index(entries -> FunctionEffectEntry[], name -> string) -> number {
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        if entries[index].name == name {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn propagate_function_effects(direct_effects -> FunctionEffectEntry[], call_graph -> FunctionCallEntry[]) -> FunctionEffectEntry[] {
    let mut aggregated -> FunctionEffectEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= direct_effects.length {
            break;
        }
        aggregated = aggregated.concat([
            FunctionEffectEntry { name: direct_effects[index].name, effects: copy_string_array(direct_effects[index].effects) }
        ]);
        index += 1;
    }

    let mut changed -> boolean = true;
    loop {
        if !changed {
            break;
        }
        changed = false;
        let mut call_index -> number = 0;
        loop {
            if call_index >= call_graph.length {
                break;
            }
            let call_entry = call_graph[call_index];
            let target_index = find_function_effect_entry_index(aggregated, call_entry.name);
            if target_index >= 0 {
                let target_entry = aggregated[target_index];
                let mut merged -> string[] = copy_string_array(target_entry.effects);
                let mut callee_index -> number = 0;
                loop {
                    if callee_index >= call_entry.callees.length {
                        break;
                    }
                    let callee_name = call_entry.callees[callee_index];
                    let callee_pos = find_function_effect_entry_index(aggregated, callee_name);
                    if callee_pos >= 0 {
                        let callee_entry = aggregated[callee_pos];
                        let mut effect_index -> number = 0;
                        loop {
                            if effect_index >= callee_entry.effects.length {
                                break;
                            }
                            merged = append_unique_effect(merged, callee_entry.effects[effect_index]);
                            effect_index += 1;
                        }
                    }
                    callee_index += 1;
                }
                if !string_arrays_equal(merged, target_entry.effects) {
                    let updated_entry = FunctionEffectEntry { name: target_entry.name, effects: merged };
                    aggregated = replace_function_effect_entry(aggregated, target_index, updated_entry);
                    changed = true;
                }
            }
            call_index += 1;
        }
    }

    return aggregated;
}

fn find_function_effect_entry(entries -> FunctionEffectEntry[], name -> string) -> FunctionEffectEntry? {
    let index = find_function_effect_entry_index(entries, name);
    if index >= 0 {
        return entries[index];
    }
    return null;
}

fn build_capability_manifest(entry_points -> string[], function_effects -> FunctionEffectEntry[]) -> CapabilityManifest {
    let mut entries -> CapabilityManifestEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= entry_points.length {
            break;
        }
        let symbol = entry_points[index];
        let effect_entry = find_function_effect_entry(function_effects, symbol);
        let mut effects -> string[] = [];
        if effect_entry != null {
            effects = effect_entry.effects;
        }
        entries = append_manifest_entry(entries, CapabilityManifestEntry { symbol: symbol, effects: effects });
        index += 1;
    }
    return CapabilityManifest { entries: entries };
}

fn append_manifest_entry(entries -> CapabilityManifestEntry[], entry -> CapabilityManifestEntry) -> CapabilityManifestEntry[] {
    return entries.concat([entry]);
}

fn runtime_helper_descriptors() -> RuntimeHelperDescriptor[] {
    let mut descriptors -> RuntimeHelperDescriptor[] = [];
    // Console/print intrinsics
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "print.info",
        symbol: "sailfin_runtime_print_info",
        return_type: "void",
        parameter_types: ["i8*"],
        effects: ["io"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "print.error",
        symbol: "sailfin_runtime_print_error",
        return_type: "void",
        parameter_types: ["i8*"],
        effects: ["io"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "print.warn",
        symbol: "sailfin_runtime_print_warn",
        return_type: "void",
        parameter_types: ["i8*"],
        effects: ["io"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "console.info",
        symbol: "sailfin_intrinsic_io_print",
        return_type: "void",
        parameter_types: ["i8*"],
        effects: ["io"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "console.log",
        symbol: "sailfin_intrinsic_io_print",
        return_type: "void",
        parameter_types: ["i8*"],
        effects: ["io"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "console.error",
        symbol: "sailfin_runtime_print_error",
        return_type: "void",
        parameter_types: ["i8*"],
        effects: ["io"],
    });
    
    // IO intrinsics
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "io_read",
        symbol: "sailfin_intrinsic_io_read",
        return_type: "i8*",
        parameter_types: ["i8*"],
        effects: ["io"],
    });
    
    // Filesystem intrinsics
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "fs.read",
        symbol: "sailfin_intrinsic_fs_read",
        return_type: "i8*",
        parameter_types: ["i8*"],
        effects: ["io"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "fs.write",
        symbol: "sailfin_intrinsic_fs_write",
        return_type: "void",
        parameter_types: ["i8*", "i8*"],
        effects: ["io"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "fs.exists",
        symbol: "sailfin_intrinsic_fs_exists",
        return_type: "i1",
        parameter_types: ["i8*"],
        effects: ["io"],
    });
    
    // Model intrinsics
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "model_invoke",
        symbol: "sailfin_intrinsic_model_invoke",
        return_type: "i8*",
        parameter_types: ["i8*", "i8*"],
        effects: ["model"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "prompt",
        symbol: "sailfin_intrinsic_model_invoke",
        return_type: "i8*",
        parameter_types: ["i8*", "i8*"],
        effects: ["model"],
    });
    
    // Network intrinsics
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "net_request",
        symbol: "sailfin_intrinsic_net_request",
        return_type: "i8*",
        parameter_types: ["i8*", "i8*", "i8*"],
        effects: ["net"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "http.get",
        symbol: "sailfin_intrinsic_http_get",
        return_type: "i8*",
        parameter_types: ["i8*"],
        effects: ["net"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "http.post",
        symbol: "sailfin_intrinsic_http_post",
        return_type: "i8*",
        parameter_types: ["i8*", "i8*"],
        effects: ["net"],
    });
    
    // Concurrency intrinsics (sleep is existing)
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "sleep",
        symbol: "sailfin_runtime_sleep",
        return_type: "void",
        parameter_types: ["double"],
        effects: ["clock"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "runtime_sleep_fn",
        symbol: "sailfin_runtime_sleep",
        return_type: "void",
        parameter_types: ["double"],
        effects: ["clock"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "runtime_channel_fn",
        symbol: "sailfin_runtime_channel",
        return_type: "i8*",
        parameter_types: ["double"],
        effects: ["io"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "runtime_spawn_fn",
        symbol: "sailfin_runtime_spawn",
        return_type: "void",
        parameter_types: ["i8*", "i8*"],
        effects: ["io"],
    });
    descriptors = append_runtime_helper(descriptors, RuntimeHelperDescriptor {
        target: "runtime_parallel_fn",
        symbol: "sailfin_runtime_parallel",
        return_type: "i8*",
        parameter_types: ["i8*"],
        effects: ["io"],
