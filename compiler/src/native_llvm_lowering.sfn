// compiler/src/native_llvm_lowering.sfn
//
// Compatibility shim.
//
// The native LLVM lowering implementation was split into smaller modules under
// compiler/src/llvm/lowering/ to reduce file size and improve modularity.

export {
    lower_to_llvm,
    lower_to_llvm_for_tests,
    lower_to_llvm_with_manifests,
    lower_to_llvm_with_context,
} from "./llvm/lowering/entrypoints";

// Stage1/Stage2 bootstrap scripts still import these symbols from the
// historical `native_llvm_lowering` module name.
export {
    runtime_helper_descriptors,
    find_runtime_helper,
    append_runtime_helper,
} from "./llvm/runtime_helpers";

export {
    coerce_operand_to_type,
    detect_suspension_conflicts,
    analyze_value_ownership,
} from "./llvm/expression_lowering_stage2";

export {
    mark_local_consumed,
    mark_parameter_consumed,
    reset_local_consumption,
    find_parameter_binding,
} from "./llvm/expressions";

export {
    update_local_ownership,
} from "./llvm/lifetime";

export {
    unescape_string_literal,
    make_string_constant_name,
} from "./llvm/expression_lowering_stage2";

export {
    escape_string_for_llvm,
} from "./llvm/strings";

export {
    StringConstant,
} from "./llvm/types";