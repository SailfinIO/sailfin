fn empty_trait_metadata() -> TraitMetadata {
    return TraitMetadata { interfaces: [], implementations: [] };
}

fn empty_capability_manifest() -> CapabilityManifest {
    return CapabilityManifest { entries: [] };
}

fn build_trait_metadata(interfaces -> NativeInterface[], structs -> NativeStruct[]) -> TraitMetadata {
    let mut interface_descriptors -> TraitDescriptor[] = [];
    let mut index -> number = 0;
    loop {
        if index >= interfaces.length {
            break;
        }
        let interface = interfaces[index];
        interface_descriptors = interface_descriptors.concat([
            TraitDescriptor {
                name: interface.name,
                type_parameters: interface.type_parameters,
                signatures: interface.signatures,
            }
        ]);
        index += 1;
    }

    let mut implementation_descriptors -> TraitImplementationDescriptor[] = [];
    index = 0;
    loop {
        if index >= structs.length {
            break;
        }
        let definition = structs[index];
        if definition.implements.length > 0 {
            implementation_descriptors = implementation_descriptors.concat([
                TraitImplementationDescriptor { struct_name: definition.name, interfaces: definition.implements }
            ]);
        }
        index += 1;
    }

    return TraitMetadata { interfaces: interface_descriptors, implementations: implementation_descriptors };
}

fn render_trait_metadata_comments(metadata -> TraitMetadata) -> string[] {
    let mut interface_lines -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= metadata.interfaces.length {
            break;
        }
        let interface = metadata.interfaces[index];
        let mut header -> string = "; interface " + interface.name;
        if interface.type_parameters.length > 0 {
            header = header + "<" + join_with_separator(interface.type_parameters, ", ") + ">";
        }
        interface_lines = append_string(interface_lines, header);

        let mut signature_index -> number = 0;
        loop {
            if signature_index >= interface.signatures.length {
                break;
            }
            let signature = interface.signatures[signature_index];
            let rendered = render_interface_signature(signature);
            interface_lines = append_string(interface_lines, ";   " + rendered);
            signature_index += 1;
        }
        if interface.signatures.length == 0 {
            interface_lines = append_string(interface_lines, ";   ; no signatures recorded");
        }
        index += 1;
    }

    let mut struct_lines -> string[] = [];
    index = 0;
    loop {
        if index >= metadata.implementations.length {
            break;
        }
        let implementation = metadata.implementations[index];
        let mut line -> string = "; struct " + implementation.struct_name + " implements " + join_with_separator(implementation.interfaces, ", ");
        struct_lines = append_string(struct_lines, line);
        index += 1;
    }

    if interface_lines.length == 0 && struct_lines.length == 0 {
        return [];
    }

    let mut lines -> string[] = [];
    lines = append_string(lines, "; -- Trait Metadata --------------------------------");
    lines = lines.concat(interface_lines);
    if interface_lines.length > 0 && struct_lines.length > 0 {
        lines = append_string(lines, ";");
    }
    lines = lines.concat(struct_lines);
    lines = append_string(lines, "; -----------------------------------------------");
    return lines;
}

fn render_runtime_helper_declarations(used_targets -> string[], local_functions -> NativeFunction[]) -> string[] {
    if used_targets.length == 0 {
        return [];
    }
    // Build list of local function symbols to avoid declaring helpers that are defined locally
    let mut local_symbols -> string[] = [];
    let mut local_index -> number = 0;
    loop {
        if local_index >= local_functions.length {
            break;
        }
        local_symbols = append_string(local_symbols, sanitize_symbol(local_functions[local_index].name));
        local_index += 1;
    }

    let mut lines -> string[] = [];
    let descriptors = runtime_helper_descriptors();
    let mut index -> number = 0;
    loop {
        if index >= descriptors.length {
            break;
        }
        let descriptor = descriptors[index];
        if string_array_contains(used_targets, descriptor.target) {
            // Skip if this helper is actually defined locally (not just a runtime intrinsic)
            if string_array_contains(local_symbols, descriptor.symbol) {
                index += 1;
                continue;
            }
            // Emit capability metadata comment if the intrinsic has effects
            if descriptor.effects.length > 0 {
                let effects_text = join_with_separator(descriptor.effects, ", ");
                lines = append_string(lines, "; intrinsic " + descriptor.symbol + " requires capabilities: ![" + effects_text + "]");
            }
            let mut parameter_text -> string = "";
            if descriptor.parameter_types.length > 0 {
                parameter_text = join_with_separator(descriptor.parameter_types, ", ");
            }
            let line = "declare " + descriptor.return_type + " @" + descriptor.symbol + "(" + parameter_text + ")";
            lines = append_string(lines, line);
        }
        index += 1;
    }
    return lines;
}

fn render_imported_function_declarations(imported_functions -> NativeFunction[], local_functions -> NativeFunction[], context -> TypeContext) -> string[] {
    if imported_functions.length == 0 {
        return [];
    }
    // Get all runtime helper symbols to avoid duplicates
    let helper_descriptors = runtime_helper_descriptors();
    let mut helper_symbols -> string[] = [];
    let mut helper_index -> number = 0;
    loop {
        if helper_index >= helper_descriptors.length {
            break;
        }
        helper_symbols = append_string(helper_symbols, helper_descriptors[helper_index].symbol);
        helper_index += 1;
    }

    // Get all local function symbols to avoid redefinitions
    let mut local_symbols -> string[] = [];
    let mut local_index -> number = 0;
    loop {
        if local_index >= local_functions.length {
            break;
        }
        local_symbols = append_string(local_symbols, sanitize_symbol(local_functions[local_index].name));
        local_index += 1;
    }

    let mut lines -> string[] = [];
    let mut emitted_declarations -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= imported_functions.length {
            break;
        }
        let function = imported_functions[index];
        let sanitized_name = sanitize_symbol(function.name);
        // Skip if this function is already declared as a runtime helper or defined locally
        if string_array_contains(helper_symbols, sanitized_name) || string_array_contains(local_symbols, sanitized_name) {
            index += 1;
            continue;
        }
        // Skip if we've already emitted a declaration for this function
        if string_array_contains(emitted_declarations, sanitized_name) {
            index += 1;
            continue;
        }
        emitted_declarations = append_string(emitted_declarations, sanitized_name);
        let return_type = map_return_type(context, function.return_type);
        let param_types = collect_parameter_types(context, function.parameters, function.name);
        let param_text = join_with_separator(param_types, ", ");
        let line = "declare " + return_type + " @" + sanitized_name + "(" + param_text + ")";
        lines = append_string(lines, line);
        index += 1;
    }
    return lines;
}

fn empty_type_context() -> TypeContext {
    return TypeContext { structs: [], enums: [], interfaces: [], vtables: [] };
}

fn build_type_context(structs -> NativeStruct[], enums -> NativeEnum[], interfaces -> NativeInterface[]) -> TypeContextBuild {
    let mut diagnostics -> string[] = [];
    let mut struct_entries -> StructTypeInfo[] = [];
    let mut index -> number = 0;
    loop {
        if index >= structs.length {
            break;
        }
        let definition = structs[index];
        if definition.layout == null {
            diagnostics = append_string(diagnostics, "llvm lowering: struct `" + definition.name + "` missing layout metadata; skipping type emission");
            index += 1;
            continue;
        }
        let layout = definition.layout;
        let sanitized = sanitize_symbol(definition.name);
        let llvm_name = "%" + sanitized;
        let mut fields -> StructFieldInfo[] = [];
        let mut field_index -> number = 0;
        loop {
            if field_index >= layout.fields.length {
                break;
            }
            let layout_field = layout.fields[field_index];
            let mapped = map_struct_field_annotation(layout_field.type_annotation);
            let mut llvm_field_type -> string = mapped;
            if llvm_field_type.length == 0 {
                diagnostics = append_string(diagnostics, "llvm lowering: struct `" + definition.name + "` field `" + layout_field.name + "` uses unsupported type `" + layout_field.type_annotation + "`; lowering as `i8*`");
                llvm_field_type = "i8*";
            } else if ends_with_pointer_suffix(llvm_field_type) {
                let layout_base_type = layout_annotation_base_type(layout_field.type_annotation);
                let references_self_type = layout_base_type == definition.name;
                if layout_annotation_represents_user_value(layout_field.type_annotation) && !references_self_type {
                    let stripped = strip_pointer_suffix(llvm_field_type);
                    if stripped.length > 0 {
                        llvm_field_type = stripped;
                    }
                }
            }
            fields = append_struct_field_info(fields, StructFieldInfo { name: layout_field.name, llvm_type: llvm_field_type, type_annotation: layout_field.type_annotation, index: field_index, offset: layout_field.offset });
            field_index += 1;
        }
        let mut align_value -> number = layout.align;
        if align_value <= 0 {
            align_value = 1;
        }
        struct_entries = append_struct_type_info(struct_entries, StructTypeInfo { name: definition.name, llvm_name: llvm_name, fields: fields, size: layout.size, align: align_value });
        index += 1;
    }

    let mut enum_entries -> EnumTypeInfo[] = [];
    let mut enum_index -> number = 0;
    loop {
        if enum_index >= enums.length {
            break;
        }
        let enum_def = enums[enum_index];
        if enum_def.layout == null {
            diagnostics = append_string(diagnostics, "llvm lowering: enum `" + enum_def.name + "` missing layout metadata; skipping type emission");
            enum_index += 1;
            continue;
        }
        let enum_layout = enum_def.layout;
        let sanitized_enum = sanitize_symbol(enum_def.name);
        let llvm_enum_name = "%" + sanitized_enum;
        let mut variants -> EnumVariantInfo[] = [];
        let mut variant_index -> number = 0;
        loop {
            if variant_index >= enum_layout.variants.length {
                break;
            }
            let variant_layout = enum_layout.variants[variant_index];
            let mut variant_fields -> StructFieldInfo[] = [];
            let mut variant_field_index -> number = 0;
            loop {
                if variant_field_index >= variant_layout.fields.length {
                    break;
                }
                let variant_field = variant_layout.fields[variant_field_index];
                let mapped_variant_type = map_struct_field_annotation(variant_field.type_annotation);
                let mut llvm_variant_field_type -> string = mapped_variant_type;
                if llvm_variant_field_type.length == 0 {
                    diagnostics = append_string(diagnostics, "llvm lowering: enum `" + enum_def.name + "` variant `" + variant_layout.name + "` field `" + variant_field.name + "` uses unsupported type `" + variant_field.type_annotation + "`; lowering as `i8*`");
                    llvm_variant_field_type = "i8*";
                } else if ends_with_pointer_suffix(llvm_variant_field_type) {
                    let variant_base_type = layout_annotation_base_type(variant_field.type_annotation);
                    let references_declaring_enum = variant_base_type == enum_def.name;
                    if layout_annotation_represents_user_value(variant_field.type_annotation) && !references_declaring_enum {
                        let stripped_variant = strip_pointer_suffix(llvm_variant_field_type);
                        if stripped_variant.length > 0 {
                            llvm_variant_field_type = stripped_variant;
                        }
                    }
                }
                variant_fields = append_struct_field_info(variant_fields, StructFieldInfo { name: variant_field.name, llvm_type: llvm_variant_field_type, type_annotation: variant_field.type_annotation, index: variant_field_index, offset: variant_field.offset });
                variant_field_index += 1;
            }
            variants = append_enum_variant_info(variants, EnumVariantInfo {
                name: variant_layout.name,
                tag: variant_layout.tag,
                offset: variant_layout.offset,
                size: variant_layout.size,
                align: variant_layout.align,
                fields: variant_fields,
            });
            variant_index += 1;
        }
        let mut enum_align_value -> number = enum_layout.align;
        if enum_align_value <= 0 {
            enum_align_value = 1;
        }
        let mut max_payload_size -> number = 0;
        let mut payload_scan -> number = 0;
        loop {
            if payload_scan >= variants.length {
                break;
            }
            let variant = variants[payload_scan];
            if variant.size > max_payload_size {
                max_payload_size = variant.size;
            }
            payload_scan += 1;
        }
        enum_entries = append_enum_type_info(enum_entries, EnumTypeInfo {
            name: enum_def.name,
            llvm_name: llvm_enum_name,
            tag_type: enum_layout.tag_type,
            tag_size: enum_layout.tag_size,
            tag_align: enum_layout.tag_align,
            max_payload_size: max_payload_size,
            size: enum_layout.size,
            align: enum_align_value,
            variants: variants,
        });
        enum_index += 1;
    }

    // Build interface type information
    let mut interface_entries -> InterfaceTypeInfo[] = [];
    let mut interface_index -> number = 0;
    loop {
        if interface_index >= interfaces.length {
            break;
        }
        let interface_def = interfaces[interface_index];
        let sanitized_interface = sanitize_symbol(interface_def.name);
        let llvm_interface_name = "%trait." + sanitized_interface;
        interface_entries = append_interface_type_info(interface_entries, InterfaceTypeInfo {
            name: interface_def.name,
            llvm_name: llvm_interface_name,
            type_parameters: interface_def.type_parameters,
            signatures: interface_def.signatures,
        });
        interface_index += 1;
    }

    // Build vtable information for each struct-interface pair
    let mut vtable_entries -> VTableInfo[] = [];
    let mut struct_vtable_index -> number = 0;
    loop {
        if struct_vtable_index >= structs.length {
            break;
        }
        let struct_def = structs[struct_vtable_index];
        let mut implements_index -> number = 0;
        loop {
            if implements_index >= struct_def.implements.length {
                break;
            }
            let interface_name = struct_def.implements[implements_index];
            // Find the interface definition
            let mut interface_def_opt -> NativeInterface? = null;
            let mut search_idx -> number = 0;
            loop {
                if search_idx >= interfaces.length {
                    break;
                }
                if interfaces[search_idx].name == interface_name {
                    interface_def_opt = interfaces[search_idx];
                    break;
                }
                search_idx += 1;
            }
            
            if interface_def_opt == null {
                diagnostics = append_string(diagnostics, "llvm lowering: struct `" + struct_def.name + "` implements unknown interface `" + interface_name + "`");
                implements_index += 1;
                continue;
            }
            
            let interface_def = interface_def_opt;
            let sanitized_struct = sanitize_symbol(struct_def.name);
            let sanitized_iface = sanitize_symbol(interface_name);
            let vtable_type_name = "%vtable." + sanitized_struct + "." + sanitized_iface;
            let vtable_global_name = "@vtable." + sanitized_struct + "." + sanitized_iface + ".const";
            
            // Build vtable entries for each method
            let mut vtable_method_entries -> VTableEntry[] = [];
            let mut sig_index -> number = 0;
            loop {
                if sig_index >= interface_def.signatures.length {
                    break;
                }
                let signature = interface_def.signatures[sig_index];
                // Build function pointer type: return_type (param_types...)*
                let mut param_types -> string[] = ["i8*"];  // First param is always self as i8*
                let mut param_idx -> number = 1;  // Skip self since we already added it
                loop {
                    if param_idx >= signature.parameters.length {
                        break;
                    }
                    let param = signature.parameters[param_idx];
                    let mapped_type = map_type_annotation(param.type_annotation);
                    param_types = append_string(param_types, mapped_type);
                    param_idx += 1;
                }
                let return_type = map_type_annotation(signature.return_type);
                let func_ptr_type = return_type + " (" + join_with_separator(param_types, ", ") + ")*";
                
                vtable_method_entries = append_vtable_entry(vtable_method_entries, VTableEntry {
                    method_name: struct_def.name + "::" + signature.name,
                    interface_method_name: signature.name,
                    function_pointer_type: func_ptr_type,
                });
                sig_index += 1;
            }
            
            vtable_entries = append_vtable_info(vtable_entries, VTableInfo {
                struct_name: struct_def.name,
                interface_name: interface_name,
                llvm_type_name: vtable_type_name,
                llvm_global_name: vtable_global_name,
                entries: vtable_method_entries,
            });
            implements_index += 1;
        }

        // Structural conformance: if the struct doesn't explicitly declare `implements`,
        // but does provide compatible methods, synthesize a vtable anyway.
        // This matches the behavior relied upon by `examples/basics/struct-composition.sfn`.
        let mut interface_scan -> number = 0;
        loop {
            if interface_scan >= interfaces.length {
                break;
            }
            let interface_def = interfaces[interface_scan];
            if !struct_declares_interface(struct_def, interface_def.name) {
                if struct_satisfies_interface_structurally(struct_def, interface_def) {
                    let interface_name = interface_def.name;
                    let sanitized_struct = sanitize_symbol(struct_def.name);
                    let sanitized_iface = sanitize_symbol(interface_name);
                    let vtable_type_name = "%vtable." + sanitized_struct + "." + sanitized_iface;
                    let vtable_global_name = "@vtable." + sanitized_struct + "." + sanitized_iface + ".const";

                    let mut vtable_method_entries -> VTableEntry[] = [];
                    let mut sig_index -> number = 0;
                    loop {
                        if sig_index >= interface_def.signatures.length {
                            break;
                        }
                        let signature = interface_def.signatures[sig_index];
                        let mut param_types -> string[] = ["i8*"];
                        let mut param_idx -> number = 1;
                        loop {
                            if param_idx >= signature.parameters.length {
                                break;
                            }
                            let param = signature.parameters[param_idx];
                            let mapped_type = map_type_annotation(param.type_annotation);
                            param_types = append_string(param_types, mapped_type);
                            param_idx += 1;
                        }
                        let return_type = map_type_annotation(signature.return_type);
                        let func_ptr_type = return_type + " (" + join_with_separator(param_types, ", ") + ")*";
                        vtable_method_entries = append_vtable_entry(vtable_method_entries, VTableEntry {
                            method_name: struct_def.name + "::" + signature.name,
                            interface_method_name: signature.name,
                            function_pointer_type: func_ptr_type,
                        });
                        sig_index += 1;
                    }

                    vtable_entries = append_vtable_info(vtable_entries, VTableInfo {
                        struct_name: struct_def.name,
                        interface_name: interface_name,
                        llvm_type_name: vtable_type_name,
                        llvm_global_name: vtable_global_name,
                        entries: vtable_method_entries,
                    });
                }
            }
            interface_scan += 1;
        }
        struct_vtable_index += 1;
    }

    return TypeContextBuild { context: TypeContext { structs: struct_entries, enums: enum_entries, interfaces: interface_entries, vtables: vtable_entries }, diagnostics: diagnostics };
}

fn append_struct_type_info(values -> StructTypeInfo[], value -> StructTypeInfo) -> StructTypeInfo[] {
    return values.concat([value]);
}

fn append_struct_field_info(values -> StructFieldInfo[], value -> StructFieldInfo) -> StructFieldInfo[] {
    return values.concat([value]);
}

fn append_enum_variant_info(values -> EnumVariantInfo[], value -> EnumVariantInfo) -> EnumVariantInfo[] {
    return values.concat([value]);
}

fn append_enum_type_info(values -> EnumTypeInfo[], value -> EnumTypeInfo) -> EnumTypeInfo[] {
    return values.concat([value]);
}

fn append_interface_type_info(values -> InterfaceTypeInfo[], value -> InterfaceTypeInfo) -> InterfaceTypeInfo[] {
    return values.concat([value]);
}

fn append_vtable_info(values -> VTableInfo[], value -> VTableInfo) -> VTableInfo[] {
    return values.concat([value]);
}

fn append_vtable_entry(values -> VTableEntry[], value -> VTableEntry) -> VTableEntry[] {
    return values.concat([value]);
}

fn struct_declares_interface(struct_def -> NativeStruct, interface_name -> string) -> boolean {
    let mut index -> number = 0;
    loop {
        if index >= struct_def.implements.length {
            break;
        }
        if struct_def.implements[index] == interface_name {
            return true;
        }
        index += 1;
    }
    return false;
}

fn find_struct_method(struct_def -> NativeStruct, method_name -> string) -> NativeFunction? {
    let mut index -> number = 0;
    loop {
        if index >= struct_def.methods.length {
            break;
        }
        let method = struct_def.methods[index];
        if method.name == method_name {
            return method;
        }
        index += 1;
    }
    return null;
}

fn struct_satisfies_interface_structurally(struct_def -> NativeStruct, interface_def -> NativeInterface) -> boolean {
    let mut sig_index -> number = 0;
    loop {
        if sig_index >= interface_def.signatures.length {
            break;
        }
        let signature = interface_def.signatures[sig_index];
        let method = find_struct_method(struct_def, signature.name);
        if method == null {
            return false;
        }
        if method.parameters.length != signature.parameters.length {
            return false;
        }

        let sig_return = map_type_annotation(signature.return_type);
        let method_return = map_type_annotation(method.return_type);
        if sig_return != method_return {
            return false;
        }

        // Skip the first parameter (`self`) which is always passed as `i8*` in trait calls.
        let mut param_index -> number = 1;
        loop {
            if param_index >= signature.parameters.length {
                break;
            }
            let sig_param = signature.parameters[param_index];
            let method_param = method.parameters[param_index];
            let sig_ty = map_type_annotation(sig_param.type_annotation);
            let method_ty = map_type_annotation(method_param.type_annotation);
            if sig_ty != method_ty {
                return false;
            }
            param_index += 1;
        }

        sig_index += 1;
    }
    return true;
}

fn append_native_function(values -> NativeFunction[], value -> NativeFunction) -> NativeFunction[] {
    return values.concat([value]);
}

fn concat_native_functions(first -> NativeFunction[], second -> NativeFunction[]) -> NativeFunction[] {
    let mut result -> NativeFunction[] = first;
    let mut index -> number = 0;
    loop {
        if index >= second.length {
            break;
        }
        result = append_native_function(result, second[index]);
        index += 1;
    }
    return result;
}

fn flatten_struct_methods(structs -> NativeStruct[]) -> NativeFunction[] {
    let mut result -> NativeFunction[] = [];
    let mut index -> number = 0;
    loop {
        if index >= structs.length {
            break;
        }
        let definition = structs[index];
        let mut method_index -> number = 0;
        loop {
            if method_index >= definition.methods.length {
                break;
            }
            let method = definition.methods[method_index];
            let qualified_name = definition.name + "::" + method.name;
            let qualified = NativeFunction {
                name: qualified_name,
                is_async: method.is_async,
                parameters: method.parameters,
                return_type: method.return_type,
                effects: method.effects,
                decorators: method.decorators,
                instructions: method.instructions,
                is_extern: false,
            };
            result = append_native_function(result, qualified);
            method_index += 1;
        }
        index += 1;
    }
    return result;
}

fn load_imported_layout_manifests(imports -> NativeImport[]) -> LayoutManifest[] ![io] {
    let context = collect_imported_module_context(imports);
    return context.manifests;
}

fn collect_imported_module_context(imports -> NativeImport[]) -> ImportedModuleContext ![io] {
    let mut manifests -> LayoutManifest[] = [];
    let mut native_texts -> string[] = [];
    let mut diagnostics -> string[] = [];
    let mut seen -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= imports.length {
            break;
        }
        let module_path = imports[index].module;
        let slug = resolve_import_module_slug(module_path);
        if slug.length == 0 {
            index += 1;
            continue;
        }
        if string_array_contains(seen, slug) {
            index += 1;
            continue;
        }
        seen = append_string(seen, slug);

        let manifest_path = layout_manifest_path_for_slug(slug);
        let native_text_path = native_text_path_for_slug(slug);

        let mut manifest_structs -> NativeStruct[] = [];
        let mut manifest_enums -> NativeEnum[] = [];
        if fs.exists(manifest_path) {
            let manifest_contents = fs.readFile(manifest_path);
            let parsed_manifest = parse_layout_manifest(manifest_contents);
            manifest_structs = parsed_manifest.structs;
            manifest_enums = parsed_manifest.enums;
        } else {
            diagnostics = diagnostics.concat(["layout manifest: missing artifact for import `" + module_path + "` (expected " + manifest_path + ")"]);
        }

        let mut native_text -> string = "";
        if fs.exists(native_text_path) {
            native_text = fs.readFile(native_text_path);
        } else {
            diagnostics = diagnostics.concat(["native lowering: missing native text artifact for import `" + module_path + "` (expected " + native_text_path + ")"]);
        }

        manifests = manifests.concat([LayoutManifest {
            structs: manifest_structs,
            enums: manifest_enums,
            diagnostics: [],
        }]);
        native_texts = native_texts.concat([native_text]);
        index += 1;
    }

    return ImportedModuleContext { manifests: manifests, native_texts: native_texts, diagnostics: diagnostics };
}

fn resolve_import_module_slug(module -> string) -> string {
    let trimmed = trim_text(module);
    if trimmed.length == 0 {
        return "";
    }
    let normalized = normalize_import_module_path(trimmed);

    // Normalize relative module specifiers (./foo, ../bar, foo/../baz) into
    // a stable slug that matches our build artifact layout under build/stage2.
    // Examples:
    // - "./llvm/type_context" -> "llvm/type_context"
    // - "../native_ir" -> "native_ir"
    let mut parts -> string[] = [];
    let mut segment -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= normalized.length {
            break;
        }
        let ch = normalized[index];
        if ch == "/" {
            if segment.length > 0 {
                parts = append_string(parts, segment);
            }
            segment = "";
        } else {
            segment = segment + ch;
        }
        index += 1;
    }
    if segment.length > 0 {
        parts = append_string(parts, segment);
    }

    let mut resolved -> string[] = [];
    index = 0;
    loop {
        if index >= parts.length {
            break;
        }
        let part = parts[index];
        if part.length == 0 || part == "." {
            index += 1;
            continue;
        }
        if part == ".." {
            if resolved.length > 0 {
                let mut shortened -> string[] = [];
                let mut drop_index -> number = 0;
                let limit = resolved.length - 1;
                loop {
                    if drop_index >= limit {
                        break;
                    }
                    shortened = append_string(shortened, resolved[drop_index]);
                    drop_index += 1;
                }
                resolved = shortened;
            }
            index += 1;
            continue;
        }
        resolved = append_string(resolved, part);
        index += 1;
    }

    let mut slug = join_with_separator(resolved, "/");

    // compiler/tests often import compiler sources via "../../src/<name>".
    // Our stage2 artifacts are rooted at build/stage2/<name>.* (no "src/" dir),
    // so strip that prefix to keep imports and artifact layout consistent.
    if starts_with(slug, "src/") {
        slug = substring(slug, 4, slug.length);
    }
    if starts_with(slug, "compiler/src/") {
        slug = substring(slug, 13, slug.length);
    }
    return slug;
}

fn layout_manifest_path_for_slug(slug -> string) -> string {
    return "build/stage2/" + slug + ".layout-manifest";
}

fn native_text_path_for_slug(slug -> string) -> string {
    return "build/stage2/" + slug + ".sfn-asm";
}

fn normalize_import_module_path(value -> string) -> string {
    let mut result -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= value.length {
            break;
        }
        let ch = value[index];
        if ch == "\\" {
            result = result + "/";
        } else {
            result = result + ch;
        }
        index += 1;
    }
    return result;
}

fn replace_native_struct(values -> NativeStruct[], index -> number, value -> NativeStruct) -> NativeStruct[] {
    let mut result -> NativeStruct[] = [];
    let mut current -> number = 0;
    loop {
        if current >= values.length {
            break;
        }
        if current == index {
            result = append_native_struct(result, value);
        } else {
            result = append_native_struct(result, values[current]);
        }
        current += 1;
    }
    return result;
}

fn replace_native_enum(values -> NativeEnum[], index -> number, value -> NativeEnum) -> NativeEnum[] {
    let mut result -> NativeEnum[] = [];
    let mut current -> number = 0;
    loop {
        if current >= values.length {
            break;
        }
        if current == index {
            result = append_native_enum(result, value);
        } else {
            result = append_native_enum(result, values[current]);
        }
        current += 1;
    }
    return result;
}

fn find_struct_index(structs -> NativeStruct[], name -> string) -> number {
    let mut index -> number = 0;
    loop {
        if index >= structs.length {
            break;
        }
        if structs[index].name == name {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn find_enum_index(enums -> NativeEnum[], name -> string) -> number {
    let mut index -> number = 0;
    loop {
        if index >= enums.length {
            break;
        }
        if enums[index].name == name {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn apply_layout_manifest_to_module(structs -> NativeStruct[], enums -> NativeEnum[], manifest -> LayoutManifest?) -> LayoutManifestApplication {
    if manifest == null {
        return LayoutManifestApplication { structs: structs, enums: enums, diagnostics: [] };
    }
    return apply_layout_manifest_entries(structs, enums, manifest);
}

fn apply_layout_manifest_entries(structs -> NativeStruct[], enums -> NativeEnum[], manifest -> LayoutManifest) -> LayoutManifestApplication {
    let mut diagnostics -> string[] = [];

    let mut updated_structs -> NativeStruct[] = structs;
    let mut struct_index -> number = 0;
    loop {
        if struct_index >= manifest.structs.length {
            break;
        }
        let layout_struct = manifest.structs[struct_index];
        let target_index = find_struct_index(updated_structs, layout_struct.name);
        if target_index < 0 {
            diagnostics = append_string(diagnostics, "layout manifest: struct `" + layout_struct.name + "` missing from native module");
        } else {
            let target = updated_structs[target_index];
            let replaced = NativeStruct {
                name: target.name,
                fields: target.fields,
                methods: target.methods,
                implements: target.implements,
                layout: layout_struct.layout,
            };
            updated_structs = replace_native_struct(updated_structs, target_index, replaced);
        }
        struct_index += 1;
    }

    let mut updated_enums -> NativeEnum[] = enums;
    let mut enum_index -> number = 0;
    loop {
        if enum_index >= manifest.enums.length {
            break;
        }
        let layout_enum = manifest.enums[enum_index];
        let target_index = find_enum_index(updated_enums, layout_enum.name);
        if target_index < 0 {
            diagnostics = append_string(diagnostics, "layout manifest: enum `" + layout_enum.name + "` missing from native module");
        } else {
            let target = updated_enums[target_index];
            let replaced = NativeEnum {
                name: target.name,
                variants: target.variants,
                layout: layout_enum.layout,
            };
            updated_enums = replace_native_enum(updated_enums, target_index, replaced);
        }
        enum_index += 1;
    }

    return LayoutManifestApplication {
        structs: updated_structs,
        enums: updated_enums,
        diagnostics: diagnostics,
    };
}

fn lower_to_llvm(native_module -> NativeModule) -> LoweredLLVMResult ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return lower_to_llvm_with_context(native_module, [], [], []);
    }
    let parse = parse_native_artifact(artifact.contents);
    let import_context = collect_imported_module_context(parse.imports);
    return lower_to_llvm_with_context(native_module, import_context.manifests, import_context.native_texts, import_context.diagnostics);
}

fn lower_to_llvm_for_tests(native_module -> NativeModule) -> LoweredLLVMResult ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return lower_to_llvm_with_context_for_tests(native_module, [], [], []);
    }
    let parse = parse_native_artifact(artifact.contents);
    let import_context = collect_imported_module_context(parse.imports);
    return lower_to_llvm_with_context_for_tests(native_module, import_context.manifests, import_context.native_texts, import_context.diagnostics);
}

fn lower_to_llvm_with_manifests(native_module -> NativeModule, imported_manifests -> LayoutManifest[]) -> LoweredLLVMResult {
    return lower_to_llvm_with_context(native_module, imported_manifests, [], []);
}

fn lower_to_llvm_with_context_for_tests(native_module -> NativeModule, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let base = lower_to_llvm_with_context(native_module, imported_manifests, imported_native_texts, imported_diagnostics);
    if base.ir.length == 0 {
        return base;
    }

    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return base;
    }

    let parse = parse_native_artifact(artifact.contents);
    let mut tests -> NativeFunction[] = [];
    let mut has_main -> boolean = false;

    let mut index -> number = 0;
    loop {
        if index >= parse.functions.length {
            break;
        }
        let fun = parse.functions[index];
        if fun.name == "main" {
            has_main = true;
        }
        if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
            tests = tests.concat([fun]);
        }
        index += 1;
    }

    if tests.length == 0 {
        return base;
    }

    // For now we only synthesize `main` when no user-provided `main` exists.
    if has_main {
        let mut updated = base;
        updated.diagnostics = updated.diagnostics.concat([
            "llvm lowering (test): module defines `main`; skipping synthesized test harness",
        ]);
        return updated;
    }

    let harness = render_test_harness_main(tests);
    let mut updated = base;
    if updated.ir.length > 0 {
        updated.ir = updated.ir + "\n";
    }
    updated.ir = updated.ir + join_with_separator(harness, "\n") + "\n";
    return updated;
}

fn module_global_symbol(name -> string) -> string {
    return "@global." + sanitize_symbol(name);
}

fn module_init_symbol(module_name -> string) -> string {
    return "@sailfin_module_init__" + sanitize_symbol(module_name);
}

fn module_user_main_symbol(module_name -> string) -> string {
    return "sailfin_user_main__" + sanitize_symbol(module_name);
}

fn lower_module_bindings_to_globals(bindings -> NativeBinding[], context -> TypeContext, module_name -> string) -> ModuleGlobalLoweringResult {
    let mut diagnostics -> string[] = [];
    let mut preamble_lines -> string[] = [];
    let mut init_lines -> string[] = [];
    let mut locals -> LocalBinding[] = [];
    let mut collected_string_constants -> StringConstant[] = empty_string_constant_set();
    let init_symbol = module_init_symbol(module_name);
    let mut needs_init -> boolean = false;

    if bindings.length == 0 {
        return ModuleGlobalLoweringResult {
            preamble_lines: [],
            init_function_lines: [],
            init_function_symbol: init_symbol,
            needs_init_call: false,
            locals: [],
            string_constants: collected_string_constants,
            diagnostics: [],
        };
    }

    let scope_id = format_root_scope_id("module");
    let scope_depth = 0;

    let mut index -> number = 0;
    loop {
        if index >= bindings.length {
            break;
        }
        let binding = bindings[index];
        let mut type_annotation = trim_text(binding.type_annotation);
        let mut effective_type_annotation = binding.type_annotation;
        if type_annotation.length == 0 && binding.value != null {
            let init_expr = trim_text(binding.value);
            if is_string_literal(init_expr) {
                type_annotation = "string";
                effective_type_annotation = "string";
            }
        }
        if type_annotation.length == 0 {
            index += 1;
            continue;
        }
        let name = binding.name;
        let global_name = module_global_symbol(name);
        let mut llvm_type -> string = "";
        if type_annotation.length > 0 {
            llvm_type = map_local_type(context, type_annotation);
        }
        if llvm_type.length == 0 {
            diagnostics = append_string(diagnostics, "llvm lowering: module binding `" + name + "` has unsupported type annotation `" + effective_type_annotation + "`");
            llvm_type = "double";
        }

        if llvm_type == "i8*" {
            preamble_lines = append_string(preamble_lines, global_name + " = global i8* null");
            if binding.value != null {
                needs_init = true;
            }
        } else {
            let mut initializer_text -> string = default_return_literal(llvm_type);
            if binding.value != null {
                let init_expr = trim_text(binding.value);
                if llvm_type == "double" && is_number_literal(init_expr) {
                    initializer_text = normalise_number_literal(init_expr);
                } else if llvm_type == "i64" && is_integer_literal(init_expr) {
                    initializer_text = init_expr;
                } else if llvm_type == "i32" && is_integer_literal(init_expr) {
                    initializer_text = init_expr;
                } else if llvm_type == "i1" && is_boolean_literal(init_expr) {
                    initializer_text = "0";
                    if matches_case_insensitive(init_expr, "true") {
                        initializer_text = "1";
                    }
                } else {
                    needs_init = true;
                }
            }
            preamble_lines = append_string(preamble_lines, global_name + " = global " + llvm_type + " " + initializer_text);
        }

        locals = append_local_binding(locals, LocalBinding {
            name: name,
            pointer: global_name,
            llvm_type: llvm_type,
            type_annotation: effective_type_annotation,
            ownership: null,
            consumed: false,
            scope_id: scope_id,
            scope_depth: scope_depth,
        });

        index += 1;
    }

    if !needs_init {
        return ModuleGlobalLoweringResult {
            preamble_lines: preamble_lines,
            init_function_lines: [],
            init_function_symbol: init_symbol,
            needs_init_call: false,
            locals: locals,
            string_constants: collected_string_constants,
            diagnostics: diagnostics,
        };
    }

    init_lines = init_lines.concat([
        "define internal void " + init_symbol + "() {",
        "block.entry:",
    ]);

    let mut init_index -> number = 0;
    let mut current_temp -> number = 0;
    let mut current_lines -> string[] = init_lines;
    loop {
        if init_index >= bindings.length {
            break;
        }
        let binding = bindings[init_index];
        let mut type_annotation = trim_text(binding.type_annotation);
        if type_annotation.length == 0 && binding.value != null {
            let init_expr = trim_text(binding.value);
            if is_string_literal(init_expr) {
                type_annotation = "string";
            }
        }
        if type_annotation.length == 0 {
            init_index += 1;
            continue;
        }
        if binding.value == null {
            init_index += 1;
            continue;
        }
        let name = binding.name;
        let global_name = module_global_symbol(name);
        let local = find_local_binding(locals, name);
        if local == null {
            init_index += 1;
            continue;
        }
        let llvm_type = local.llvm_type;
        let init_expr = trim_text(binding.value);

        if llvm_type == "i8*" {
            let lowered = lower_expression(init_expr, [], locals, current_temp, current_lines, [], context, llvm_type);
            diagnostics = diagnostics.concat(lowered.diagnostics);
            current_lines = lowered.lines;
            current_temp = lowered.temp_index;
            collected_string_constants = merge_string_constants(collected_string_constants, lowered.string_constants);
            if lowered.operand != null {
                current_lines = append_string(current_lines, "  store i8* " + lowered.operand.value + ", i8** " + global_name);
            } else {
                diagnostics = append_string(diagnostics, "llvm lowering: failed to initialize module string binding `" + name + "`");
            }
        } else {
            let mut should_store -> boolean = true;
            if llvm_type == "double" && is_number_literal(init_expr) {
                should_store = false;
            }
            if llvm_type == "i64" && is_integer_literal(init_expr) {
                should_store = false;
            }
            if llvm_type == "i32" && is_integer_literal(init_expr) {
                should_store = false;
            }
            if llvm_type == "i1" && is_boolean_literal(init_expr) {
                should_store = false;
            }
            if should_store {
                let lowered = lower_expression(init_expr, [], locals, current_temp, current_lines, [], context, llvm_type);
                diagnostics = diagnostics.concat(lowered.diagnostics);
                current_lines = lowered.lines;
                current_temp = lowered.temp_index;
                collected_string_constants = merge_string_constants(collected_string_constants, lowered.string_constants);
                if lowered.operand != null {
                    let coerced = coerce_operand_to_type(lowered.operand, llvm_type, current_temp, current_lines);
                    diagnostics = diagnostics.concat(coerced.diagnostics);
                    current_lines = coerced.lines;
                    current_temp = coerced.temp_index;
                    if coerced.operand != null {
                        current_lines = append_string(current_lines, "  store " + llvm_type + " " + coerced.operand.value + ", " + llvm_type + "* " + global_name);
                    }
                }
            }
        }

        init_index += 1;
    }

    current_lines = append_string(current_lines, "  ret void");
    current_lines = append_string(current_lines, "}");

    return ModuleGlobalLoweringResult {
        preamble_lines: preamble_lines,
        init_function_lines: current_lines,
        init_function_symbol: init_symbol,
        needs_init_call: true,
        locals: locals,
        string_constants: collected_string_constants,
        diagnostics: diagnostics,
    };
}

fn lower_to_llvm_with_context(native_module -> NativeModule, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let mut diagnostics -> string[] = [];
    if imported_diagnostics.length > 0 {
        diagnostics = diagnostics.concat(imported_diagnostics);
    }
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        diagnostics = append_string(diagnostics, "no sailfin-native-text artifact present");
        let empty_constants = empty_string_constant_set();
        return LoweredLLVMResult {
            ir: "",
            diagnostics: diagnostics,
            trait_metadata: empty_trait_metadata(),
            function_effects: [],
            lifetime_regions: [],
            capability_manifest: empty_capability_manifest(),
            string_constants: empty_constants,
        };
    }

    let parse = parse_native_artifact(artifact.contents);
    diagnostics = diagnostics.concat(parse.diagnostics);

    // Only exported symbols should keep external linkage across modules.
    let exported_symbols = collect_exported_symbol_names(parse.imports);

    let manifest_artifact = select_layout_manifest_artifact(native_module.artifacts);
    let mut module_manifest -> LayoutManifest? = null;
    if manifest_artifact != null {
        let parsed_manifest = parse_layout_manifest(manifest_artifact.contents);
        diagnostics = diagnostics.concat(parsed_manifest.diagnostics);
        module_manifest = parsed_manifest;
    }

    let manifest_application = apply_layout_manifest_to_module(parse.structs, parse.enums, module_manifest);
    diagnostics = diagnostics.concat(manifest_application.diagnostics);
    let module_structs = manifest_application.structs;
    let module_enums = manifest_application.enums;

    // Gather imported module context (layout + signatures) to improve lowering fidelity
    let mut imported_structs -> NativeStruct[] = [];
    let mut imported_enums -> NativeEnum[] = [];
    let mut imported_interfaces -> NativeInterface[] = [];
    let mut imported_functions -> NativeFunction[] = [];
    let mut imported_struct_methods -> NativeFunction[] = [];

    let manifest_count = imported_manifests.length;
    let mut text_index -> number = 0;
    loop {
        if text_index >= imported_native_texts.length {
            break;
        }
        let native_text = imported_native_texts[text_index];
        let mut manifest_for_module -> LayoutManifest? = null;
        if text_index < manifest_count {
            let candidate_manifest = imported_manifests[text_index];
            manifest_for_module = candidate_manifest;
        }
        if native_text.length == 0 {
            if manifest_for_module != null {
                let manifest_only = manifest_for_module;
                imported_structs = imported_structs.concat(manifest_only.structs);
                imported_enums = imported_enums.concat(manifest_only.enums);
            }
            text_index += 1;
            continue;
        }

        let imported_parse = parse_native_artifact(native_text);
        let applied_import = apply_layout_manifest_to_module(imported_parse.structs, imported_parse.enums, manifest_for_module);

        imported_structs = imported_structs.concat(applied_import.structs);
        imported_enums = imported_enums.concat(applied_import.enums);
        imported_interfaces = imported_interfaces.concat(imported_parse.interfaces);
        imported_functions = imported_functions.concat(imported_parse.functions);
        let imported_methods = flatten_struct_methods(applied_import.structs);
        imported_struct_methods = imported_struct_methods.concat(imported_methods);
        text_index += 1;
    }

    if imported_native_texts.length < manifest_count {
        let mut manifest_index -> number = imported_native_texts.length;
        loop {
            if manifest_index >= manifest_count {
                break;
            }
            let leftover_manifest = imported_manifests[manifest_index];
            imported_structs = imported_structs.concat(leftover_manifest.structs);
            imported_enums = imported_enums.concat(leftover_manifest.enums);
            manifest_index += 1;
        }
    }

    let combined_structs = module_structs.concat(imported_structs);
    let combined_enums = module_enums.concat(imported_enums);
    let combined_interfaces = parse.interfaces.concat(imported_interfaces);

    let trait_metadata = build_trait_metadata(combined_interfaces, combined_structs);
    let fixed_enums = fixup_enum_layouts(combined_enums);
    diagnostics = diagnostics.concat(fixed_enums.diagnostics);
    let type_build = build_type_context(combined_structs, fixed_enums.enums, combined_interfaces);
    diagnostics = diagnostics.concat(type_build.diagnostics);
    let type_context = type_build.context;

    let module_struct_methods = flatten_struct_methods(module_structs);
    let local_functions = concat_native_functions(parse.functions, module_struct_methods);
    let mut context_functions = concat_native_functions(local_functions, imported_functions);
    context_functions = concat_native_functions(context_functions, imported_struct_methods);

    let mut runtime_helpers = collect_runtime_helper_targets(local_functions);
    runtime_helpers = append_unique_effect(runtime_helpers, "get_field");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.concat");
    runtime_helpers = append_unique_effect(runtime_helpers, "number.to_string");
    runtime_helpers = append_unique_effect(runtime_helpers, "strings_equal");
    runtime_helpers = append_unique_effect(runtime_helpers, "runtime.bounds_check");
    runtime_helpers = append_unique_effect(runtime_helpers, "mark_persistent");
    let direct_effects = collect_direct_function_effects(context_functions);
    let call_graph = collect_function_call_graph(context_functions);
    let aggregated_effects = propagate_function_effects(direct_effects, call_graph);

    let mut function_effects -> FunctionEffectEntry[] = [];
    let mut lifetime_regions -> LifetimeRegionMetadata[] = [];
    let mut lines -> string[] = [];
    lines = append_string(lines, "source_filename = \"" + module_source_filename(native_module.module_name) + "\"");
    lines = append_string(lines, "");

    let trait_lines = render_trait_metadata_comments(trait_metadata);
    if trait_lines.length > 0 {
        lines = lines.concat(trait_lines);
        lines = append_string(lines, "");
    }

    let struct_type_lines = render_struct_type_definitions(type_context, context_functions);
    if struct_type_lines.length > 0 {
        lines = lines.concat(struct_type_lines);
        lines = append_string(lines, "");
    }

    let enum_type_lines = render_enum_type_definitions(type_context);
    if enum_type_lines.length > 0 {
        lines = lines.concat(enum_type_lines);
        lines = append_string(lines, "");
    }

    let interface_type_lines = render_interface_type_definitions(type_context);
    if interface_type_lines.length > 0 {
        lines = lines.concat(interface_type_lines);
        lines = append_string(lines, "");
    }

    // Async/future runtime types (opaque in LLVM; implemented by the native runtime).
    lines = lines.concat([
        "%SailfinFutureNumber = type opaque",
        "%SailfinFutureBool = type opaque",
        "%SailfinFuturePtr = type opaque",
        "%SailfinFutureVoid = type opaque",
        "%SailfinFutureString = type opaque",
        "",
        "declare %SailfinFutureNumber* @sailfin_runtime_spawn_number(double ()*)",
        "declare %SailfinFutureNumber* @sailfin_runtime_spawn_number_ctx(double (i8*)*, i8*)",
        "declare double @sailfin_runtime_await_number(%SailfinFutureNumber*)",
        "declare %SailfinFutureBool* @sailfin_runtime_spawn_bool(i1 ()*)",
        "declare %SailfinFutureBool* @sailfin_runtime_spawn_bool_ctx(i1 (i8*)*, i8*)",
        "declare i1 @sailfin_runtime_await_bool(%SailfinFutureBool*)",
        "declare %SailfinFuturePtr* @sailfin_runtime_spawn_ptr(i8* ()*)",
        "declare %SailfinFuturePtr* @sailfin_runtime_spawn_ptr_ctx(i8* (i8*)*, i8*)",
        "declare i8* @sailfin_runtime_await_ptr(%SailfinFuturePtr*)",
        "declare %SailfinFutureVoid* @sailfin_runtime_spawn_void(void ()*)",
        "declare %SailfinFutureVoid* @sailfin_runtime_spawn_void_ctx(void (i8*)*, i8*)",
        "declare void @sailfin_runtime_await_void(%SailfinFutureVoid*)",
        "declare %SailfinFutureString* @sailfin_runtime_spawn_string(i8* ()*)",
        "declare %SailfinFutureString* @sailfin_runtime_spawn_string_ctx(i8* (i8*)*, i8*)",
        "declare i8* @sailfin_runtime_await_string(%SailfinFutureString*)",
        "",
    ]);

    let vtable_type_lines = render_vtable_type_definitions(type_context);
    if vtable_type_lines.length > 0 {
        lines = lines.concat(vtable_type_lines);
        lines = append_string(lines, "");
    }

    let vtable_const_lines = render_vtable_constants(type_context);
    if vtable_const_lines.length > 0 {
        lines = lines.concat(vtable_const_lines);
        lines = append_string(lines, "");
    }

    let helper_declarations = render_runtime_helper_declarations(runtime_helpers, local_functions);
    if helper_declarations.length > 0 {
        lines = lines.concat(helper_declarations);
        lines = append_string(lines, "");
    }

    // Declare imported functions from other modules (excluding local functions)
    let imported_declarations = render_imported_function_declarations(imported_functions, local_functions, type_context);
    if imported_declarations.length > 0 {
        lines = lines.concat(imported_declarations);
        lines = append_string(lines, "");
    }

    // Provide libc declarations for common helpers when not declared in the module.
    if find_function_by_name(context_functions, "malloc") == null {
        lines = append_string(lines, "declare noalias i8* @malloc(i64)");
    }
    if find_function_by_name(context_functions, "free") == null {
        lines = append_string(lines, "declare void @free(i8*)");
    }
    lines = append_string(lines, "");

    // Declare the runtime global (provided by the Python bootstrap runtime)
    lines = append_string(lines, "@runtime = external global i8**");
    lines = append_string(lines, "");

    // Lower module-level `let` bindings into LLVM globals (and an optional init function).
    let module_globals = lower_module_bindings_to_globals(parse.bindings, type_context, native_module.module_name);
    diagnostics = diagnostics.concat(module_globals.diagnostics);
    if module_globals.preamble_lines.length > 0 {
        lines = lines.concat(module_globals.preamble_lines);
        lines = append_string(lines, "");
    }

    let mut preamble_lines -> string[] = lines;
    let mut function_lines -> string[] = [];

    if module_globals.init_function_lines.length > 0 {
        function_lines = function_lines.concat(module_globals.init_function_lines);
        function_lines = append_string(function_lines, "");
    }

    let mut index -> number = 0;
    let mut has_add_function -> boolean = false;
    let mut all_string_constants -> StringConstant[] = module_globals.string_constants;
    loop {
        if index >= local_functions.length {
            break;
        }
        let current_function = local_functions[index];
        let aggregated_entry = find_function_effect_entry(aggregated_effects, current_function.name);
        let mut effective_effects -> string[] = [];
        if aggregated_entry != null {
            effective_effects = aggregated_entry.effects;
        }
        function_effects = append_function_effect_entry(function_effects, FunctionEffectEntry {
            name: current_function.name,
            effects: effective_effects,
        });
        let lowered = emit_function(current_function, context_functions, effective_effects, type_context, native_module.module_name, native_module.entry_points, exported_symbols, imported_functions, module_globals.locals, module_globals.init_function_symbol, module_globals.needs_init_call);
        if sanitize_symbol(current_function.name) == "add" {
            has_add_function = true;
        }
        diagnostics = diagnostics.concat(lowered.diagnostics);
        lifetime_regions = lifetime_regions.concat(lowered.lifetime_regions);
        all_string_constants = merge_string_constants(all_string_constants, lowered.string_constants);
        if lowered.lines.length > 0 {
            function_lines = function_lines.concat(lowered.lines);
            if index + 1 < local_functions.length {
                function_lines = append_string(function_lines, "");
            }
        }
        index += 1;
    }

    if !has_add_function {
        if function_lines.length > 0 {
            function_lines = append_string(function_lines, "");
        }
        function_lines = function_lines.concat([
            "define internal double @add(double %a, double %b) {",
            "entry:",
            "  %t0 = fadd double %a, %b",
            "  ret double %t0",
            "}"
        ]);
    }

    let string_constant_lines = render_string_constants(all_string_constants);
    let mut final_lines -> string[] = preamble_lines;
    if string_constant_lines.length > 0 {
        final_lines = final_lines.concat(string_constant_lines);
        final_lines = append_string(final_lines, "");
    }
    final_lines = final_lines.concat(function_lines);
    final_lines = ensure_intrinsic_declarations(final_lines);

    let ir = join_with_separator(final_lines, "\n");
    let manifest = build_capability_manifest(native_module.entry_points, function_effects);
    let mut output -> string = ir;
    if output.length > 0 {
        output = output + "\n";
    }
    return LoweredLLVMResult {
        ir: output,
        diagnostics: diagnostics,
        trait_metadata: trait_metadata,
        function_effects: function_effects,
        lifetime_regions: lifetime_regions,
        capability_manifest: manifest,
        string_constants: all_string_constants,
    };
}

fn module_source_filename(module_name -> string) -> string {
    if module_name.length == 0 {
        return "sailfin";
    }
    // Avoid appending twice.
    if module_name.length >= 4 {
        let suffix = substring(module_name, module_name.length - 4, module_name.length);
        if suffix == ".sfn" {
            return module_name;
        }
    }
    return module_name + ".sfn";
}

fn ensure_intrinsic_declarations(lines -> string[]) -> string[] {
    let mut uses_round -> boolean = false;
    let mut has_round_decl -> boolean = false;
    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let line = lines[index];
        if index_of(line, "call double @round(") >= 0 {
            uses_round = true;
        }
        let trimmed = trim_text(line);
        if starts_with(trimmed, "declare double @round(double)") {
            has_round_decl = true;
        }
        index += 1;
    }

    if !uses_round || has_round_decl {
        return lines;
    }

    // Insert right after source_filename, preserving the existing blank line.
    return insert_string_at(lines, 1, "declare double @round(double)");
}

fn insert_string_at(values -> string[], insert_index -> number, value -> string) -> string[] {
    let mut out -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= values.length {
            break;
        }
        if index == insert_index {
            out = append_string(out, value);
        }
        out = append_string(out, values[index]);
        index += 1;
    }
    if insert_index >= values.length {
        out = append_string(out, value);
    }
    return out;
}

fn collect_direct_function_effects(functions -> NativeFunction[]) -> FunctionEffectEntry[] {
    let mut entries -> FunctionEffectEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= functions.length {
            break;
        }
        let entry = collect_function_effect_entry(functions[index]);
        entries = append_function_effect_entry(entries, entry);
        index += 1;
    }
    return entries;
}

fn collect_function_call_graph(functions -> NativeFunction[]) -> FunctionCallEntry[] {
    let mut entries -> FunctionCallEntry[] = [];
    let function_names = collect_function_names(functions);
    let mut index -> number = 0;
    loop {
        if index >= functions.length {
            break;
        }
        let call_entry = collect_function_call_entry(functions[index], function_names);
        entries = append_function_call_entry(entries, call_entry);
        index += 1;
    }
    return entries;
}

fn collect_function_call_entry(function -> NativeFunction, function_names -> string[]) -> FunctionCallEntry {
    let mut callees -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= function.instructions.length {
            break;
        }
        let instruction = function.instructions[index];
        callees = merge_effect_lists(callees, collect_instruction_calls(instruction, function_names));
        index += 1;
    }
    return FunctionCallEntry { name: function.name, callees: callees };
}

fn collect_runtime_helper_targets(functions -> NativeFunction[]) -> string[] {
    let mut used -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= functions.length {
            break;
        }
        let helpers = collect_function_runtime_helper_targets(functions[index]);
        used = merge_effect_lists(used, helpers);
        index += 1;
    }
    return used;
}

fn collect_function_runtime_helper_targets(function -> NativeFunction) -> string[] {
    let mut used -> string[] = [];

    // Decorator-driven runtime hooks.
    let mut decorator_index -> number = 0;
    loop {
        if decorator_index >= function.decorators.length {
            break;
        }
        let decorator_name = function.decorators[decorator_index];
        if matches_case_insensitive(decorator_name, "logExecution") || matches_case_insensitive(decorator_name, "logexecution") || matches_case_insensitive(decorator_name, "trace") {
            used = append_unique_effect(used, "runtime_log_execution_fn");
        }
        decorator_index += 1;
    }

    let mut index -> number = 0;
    loop {
        if index >= function.instructions.length {
            break;
        }
        let instruction = function.instructions[index];
        let instruction_helpers = collect_instruction_runtime_helper_targets(instruction);
        used = merge_effect_lists(used, instruction_helpers);
        index += 1;
    }
    return used;
}

fn collect_instruction_runtime_helper_targets(instruction -> NativeInstruction) -> string[] {
    if instruction.variant == "Let" {
        if instruction.value != null {
            let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.value));
            helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.value));
            return helpers;
        }
        return [];
    }
    if instruction.variant == "Expression" {
        let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.expression));
        helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.expression));
        return helpers;
    }
    if instruction.variant == "Return" {
        let trimmed = trim_text(instruction.expression);
        if trimmed.length > 0 {
            let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(trimmed));
            helpers = merge_effect_lists(helpers, collect_runtime_property_targets(trimmed));
            return helpers;
        }
        return [];
    }
    if instruction.variant == "If" {
        let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.condition));
        helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.condition));
        return helpers;
    }
    if instruction.variant == "For" {
        let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.iterable));
        helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.iterable));
        return helpers;
    }
    if instruction.variant == "Match" {
        let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.expression));
        helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.expression));
        return helpers;
    }
    if instruction.variant == "Case" {
        let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.pattern));
        helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.pattern));
        if instruction.guard != null {
            let guard_targets = filter_runtime_helper_targets(extract_all_call_targets(instruction.guard));
            let mut combined -> string[] = merge_effect_lists(helpers, guard_targets);
            combined = merge_effect_lists(combined, collect_runtime_property_targets(instruction.guard));
            return combined;
        }
        return helpers;
    }
    if instruction.variant == "Try" {
        return ["clear_exception", "has_exception", "take_exception"];
    }
    if instruction.variant == "Throw" {
        return ["set_exception"];
    }
    return [];
}

fn collect_instruction_calls(instruction -> NativeInstruction, function_names -> string[]) -> string[] {
    let mut callees -> string[] = [];
    if instruction.variant == "Let" {
        if instruction.value != null {
            callees = merge_effect_lists(callees, extract_call_targets(instruction.value, function_names));
        }
        return callees;
    }
    if instruction.variant == "Expression" {
        callees = merge_effect_lists(callees, extract_call_targets(instruction.expression, function_names));
        return callees;
    }
    if instruction.variant == "Return" {
        let trimmed = trim_text(instruction.expression);
        if trimmed.length > 0 {
            callees = merge_effect_lists(callees, extract_call_targets(trimmed, function_names));
        }
        return callees;
    }
    if instruction.variant == "If" {
        callees = merge_effect_lists(callees, extract_call_targets(instruction.condition, function_names));
        return callees;
    }
    if instruction.variant == "For" {
        callees = merge_effect_lists(callees, extract_call_targets(instruction.iterable, function_names));
        return callees;
    }
    if instruction.variant == "Match" {
        callees = merge_effect_lists(callees, extract_call_targets(instruction.expression, function_names));
        return callees;
    }
    if instruction.variant == "Case" {
        callees = merge_effect_lists(callees, extract_call_targets(instruction.pattern, function_names));
        if instruction.guard != null {
            callees = merge_effect_lists(callees, extract_call_targets(instruction.guard, function_names));
        }
        return callees;
    }
    return callees;
}

fn collect_function_names(functions -> NativeFunction[]) -> string[] {
    let mut names -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= functions.length {
            break;
        }
        names = append_string(names, functions[index].name);
        index += 1;
    }
    return names;
}

fn extract_call_targets(expression -> string, function_names -> string[]) -> string[] {
    let mut results -> string[] = [];
    let expression_len = expression.length;
    if expression_len == 0 {
        return results;
    }
    let mut index -> number = 0;
    loop {
        if index >= expression_len {
            break;
        }
        let ch = expression[index];
        if ch == "\"" {
            index = skip_string_literal(expression, index + 1);
            continue;
        }
        if is_identifier_start_char(ch) {
            let start_index = index;
            index += 1;
            loop {
                if index >= expression_len {
                    break;
                }
                let current = expression[index];
                if is_identifier_part_char(current) {
                    index += 1;
                    continue;
                }
                if current == "." {
                    index += 1;
                    continue;
                }
                break;
            }
            let mut candidate = substring(expression, start_index, index);
            if candidate.length > 0 {
                loop {
                    let dot_index = index_of(candidate, ".");
                    if dot_index == -1 {
                        break;
                    }
                    candidate = substring(candidate, dot_index + 1, candidate.length);
                }
                let mut cursor -> number = index;
                loop {
                    if cursor >= expression_len {
                        break;
                    }
                    let next = expression[cursor];
                    if is_trim_char(next) {
                        cursor += 1;
                        continue;
                    }
                    if next == "(" {
                        if string_array_contains(function_names, candidate) {
                            results = append_unique_effect(results, candidate);
                        }
                    }
                    break;
                }
            }
            continue;
        }
        index += 1;
    }
    return results;
}

fn extract_all_call_targets(expression -> string) -> string[] {
    let mut results -> string[] = [];
    let expression_len = expression.length;
    if expression_len == 0 {
        return results;
    }
    let mut index -> number = 0;
    loop {
        if index >= expression_len {
            break;
        }
        let ch = expression[index];
        if ch == "\"" {
            index = skip_string_literal(expression, index + 1);
            continue;
        }
        if is_identifier_start_char(ch) {
            let start_index = index;
            index += 1;
            loop {
                if index >= expression_len {
                    break;
                }
                let current = expression[index];
                if is_identifier_part_char(current) {
                    index += 1;
                    continue;
                }
                if current == "." || current == ":" {
                    index += 1;
                    continue;
                }
                break;
            }
            let candidate = substring(expression, start_index, index);
            if candidate.length > 0 {
                let mut cursor -> number = index;
                loop {
                    if cursor >= expression_len {
                        break;
                    }
                    let next = expression[cursor];
                    if is_trim_char(next) {
                        cursor += 1;
                        continue;
                    }
                    if next == "(" {
                        results = append_unique_effect(results, candidate);
                    }
                    break;
                }
            }
            continue;
        }
        index += 1;
    }
    return results;
}

fn filter_runtime_helper_targets(targets -> string[]) -> string[] {
    let mut results -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= targets.length {
            break;
        }
        let trimmed = trim_text(targets[index]);
        let mut helper = find_runtime_helper(trimmed);
        if helper == null {
            let dot_index = find_last_index_of_char(trimmed, ".");
            if dot_index >= 0 && dot_index + 1 < trimmed.length {
                let suffix = substring(trimmed, dot_index + 1, trimmed.length);
                helper = find_runtime_helper(suffix);
            }
        }
        if helper == null {
            let colon_index = find_last_index_of_char(trimmed, ":");
            if colon_index >= 0 && colon_index + 1 < trimmed.length {
                let suffix = substring(trimmed, colon_index + 1, trimmed.length);
                helper = find_runtime_helper(suffix);
            }
        }
        if helper == null {
            let length_suffix = ".length";
            if trimmed.length >= length_suffix.length {
                let maybe_length = substring(trimmed, trimmed.length - length_suffix.length, trimmed.length);
                if maybe_length == length_suffix {
                    helper = find_runtime_helper("string.length");
                    if helper == null {
                        helper = find_runtime_helper("len(string)");
                    }
                }
            }
            if helper == null {
                let concat_suffix = ".concat";
                if trimmed.length >= concat_suffix.length {
                    let maybe_concat = substring(trimmed, trimmed.length - concat_suffix.length, trimmed.length);
                    if maybe_concat == concat_suffix {
                        helper = find_runtime_helper("concat");
                    }
                }
            }
        }
        if helper != null {
            results = append_unique_effect(results, helper.target);
        }
        index += 1;
    }
    return results;
}

fn collect_runtime_property_targets(expression -> string) -> string[] {
    let trimmed = trim_text(expression);
    if trimmed.length == 0 {
        return [];
    }
    let mut results -> string[] = [];
    if contains_dot_property(trimmed, "length") {
        results = append_unique_effect(results, "string.length");
    }
    return results;
}

fn contains_dot_property(expression -> string, name -> string) -> boolean {
    let suffix = "." + name;
    let suffix_length = suffix.length;
    if suffix_length == 0 || expression.length < suffix_length {
        return false;
    }
    let mut index -> number = 0;
    let mut in_single -> boolean = false;
    let mut in_double -> boolean = false;
    let mut escape_next -> boolean = false;
    loop {
        if index >= expression.length {
            break;
        }
        let ch = expression[index];
        if in_double {
            if escape_next {
                escape_next = false;
            } else if ch == "\\" {
                escape_next = true;
            } else if ch == "\"" {
                in_double = false;
            }
            index += 1;
            continue;
        }
        if in_single {
            if escape_next {
                escape_next = false;
            } else if ch == "\\" {
                escape_next = true;
            } else if ch == "'" {
                in_single = false;
            }
            index += 1;
            continue;
        }
        if ch == "\"" {
            in_double = true;
            index += 1;
            continue;
        }
        if ch == "'" {
            in_single = true;
            index += 1;
            continue;
        }
        if index + suffix_length <= expression.length {
            let mut match_index -> number = 0;
            let mut matches -> boolean = true;
            loop {
                if match_index >= suffix_length {
                    break;
                }
                let expr_char = char_at(expression, index + match_index);
                let suffix_char = char_at(suffix, match_index);
                if expr_char.length == 0 || suffix_char.length == 0 || expr_char != suffix_char {
                    matches = false;
                    break;
                }
                match_index += 1;
            }
            if matches {
                let after_index = index + suffix_length;
                let after_char = char_at(expression, after_index);
                if after_char.length == 0 {
                    return true;
                }
                if !is_identifier_part_char(after_char) {
                    return true;
                }
            }
        }
        index += 1;
    }
    return false;
}

fn append_function_call_entry(entries -> FunctionCallEntry[], entry -> FunctionCallEntry) -> FunctionCallEntry[] {
    return entries.concat([entry]);
}

fn replace_function_effect_entry(entries -> FunctionEffectEntry[], position -> number, entry -> FunctionEffectEntry) -> FunctionEffectEntry[] {
    let mut result -> FunctionEffectEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        if index == position {
            result = result.concat([entry]);
        } else {
            result = result.concat([entries[index]]);
        }
        index += 1;
    }
    return result;
}

fn find_function_effect_entry_index(entries -> FunctionEffectEntry[], name -> string) -> number {
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        if entries[index].name == name {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn propagate_function_effects(direct_effects -> FunctionEffectEntry[], call_graph -> FunctionCallEntry[]) -> FunctionEffectEntry[] {
    let mut aggregated -> FunctionEffectEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= direct_effects.length {
            break;
        }
        aggregated = aggregated.concat([
            FunctionEffectEntry { name: direct_effects[index].name, effects: copy_string_array(direct_effects[index].effects) }
        ]);
        index += 1;
    }

    let mut changed -> boolean = true;
    loop {
        if !changed {
            break;
        }
        changed = false;
        let mut call_index -> number = 0;
        loop {
            if call_index >= call_graph.length {
                break;
            }
            let call_entry = call_graph[call_index];
            let target_index = find_function_effect_entry_index(aggregated, call_entry.name);
            if target_index >= 0 {
                let target_entry = aggregated[target_index];
                let mut merged -> string[] = copy_string_array(target_entry.effects);
                let mut callee_index -> number = 0;
                loop {
                    if callee_index >= call_entry.callees.length {
                        break;
                    }
                    let callee_name = call_entry.callees[callee_index];
                    let callee_pos = find_function_effect_entry_index(aggregated, callee_name);
                    if callee_pos >= 0 {
                        let callee_entry = aggregated[callee_pos];
                        let mut effect_index -> number = 0;
                        loop {
                            if effect_index >= callee_entry.effects.length {
                                break;
                            }
                            merged = append_unique_effect(merged, callee_entry.effects[effect_index]);
                            effect_index += 1;
                        }
                    }
                    callee_index += 1;
                }
                if !string_arrays_equal(merged, target_entry.effects) {
                    let updated_entry = FunctionEffectEntry { name: target_entry.name, effects: merged };
                    aggregated = replace_function_effect_entry(aggregated, target_index, updated_entry);
                    changed = true;
                }
            }
            call_index += 1;
        }
    }

    return aggregated;
}

fn find_function_effect_entry(entries -> FunctionEffectEntry[], name -> string) -> FunctionEffectEntry? {
    let index = find_function_effect_entry_index(entries, name);
    if index >= 0 {
        return entries[index];
    }
    return null;
}

fn build_capability_manifest(entry_points -> string[], function_effects -> FunctionEffectEntry[]) -> CapabilityManifest {
    let mut entries -> CapabilityManifestEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= entry_points.length {
            break;
        }
        let symbol = entry_points[index];
        let effect_entry = find_function_effect_entry(function_effects, symbol);
        let mut effects -> string[] = [];
        if effect_entry != null {
            effects = effect_entry.effects;
        }
        entries = append_manifest_entry(entries, CapabilityManifestEntry { symbol: symbol, effects: effects });
        index += 1;
    }
    return CapabilityManifest { entries: entries };
}

fn append_manifest_entry(entries -> CapabilityManifestEntry[], entry -> CapabilityManifestEntry) -> CapabilityManifestEntry[] {
    return entries.concat([entry]);
}

