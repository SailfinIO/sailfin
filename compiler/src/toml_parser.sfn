// compiler/src/toml_parser.sfn
//
// Minimal TOML parser for capsule.toml manifests. Provides a string-based API
// so callers never need to allocate the SailToml struct across modules.
import { find_char_local } from "./string_utils";

struct SailToml {
    name: string;
    version: string;
    description: string;
    entry: string;
    dependencies: TomlDependency[];
    dev_dependencies: TomlDependency[];
    capabilities: string[];
    // Stage A additions (parse-only; no consumers yet — see
    // docs/proposals/0006-build-architecture.md, Part 5, Stage A).
    build_kind: string;  // "binary" | "library" | "runtime" | ""
    build_implicit: boolean;  // [build] implicit = true
    workspace_members: string[];  // [workspace] members = [...]
    exports: string[];  // [exports] modules = [...]
    // Toolchain pin (SFEP-0046 Phase 1). `[toolchain] sfn`/`channel`.
    // Empty when the manifest is unpinned.
    toolchain_sfn: string;
    toolchain_channel: string;
}

struct TomlDependency {
    capsule: string;
    version: string;
}

fn _toml_trim(text: string) -> string {
    let mut start: int = 0;
    let mut end: int = text.length;
    loop {
        if start >= end { break; }
        let ch = text[start];
        let mut _if434: boolean = false;
        if ch == " " { _if434 = true; }
        if ch == "\t" { _if434 = true; }
        if ch == "\r" { _if434 = true; }
        if _if434 { start += 1; } else { break; }
    }
    loop {
        if end <= start { break; }
        let ch = text[end - 1];
        let mut _if435: boolean = false;
        if ch == " " { _if435 = true; }
        if ch == "\t" { _if435 = true; }
        if ch == "\r" { _if435 = true; }
        if _if435 { end -= 1; } else { break; }
    }
    return substring(text, start, end);
}

fn _toml_strip_quotes(text: string) -> string {
    if text.length >= 2 {
        let first = text[0];
        let last = text[text.length - 1];
        let mut _if436: boolean = false;
        if first == "\"" {
            if last == "\"" { _if436 = true; }
        }
        if first == "'" {
            if last == "'" { _if436 = true; }
        }
        if _if436 { return substring(text, 1, text.length - 1); }
    }
    return text;
}

fn _toml_split_lines(text: string) -> string[] {
    let mut lines: string[] = [];
    let mut start: int = 0;
    let len = text.length;
    let mut i: int = 0;
    loop {
        if i >= len { break; }
        if text[i] == "\n" {
            lines.push(substring(text, start, i));
            start = i + 1;
        }
        i += 1;
    }
    if start <= len { lines.push(substring(text, start, len)); }
    return lines;
}

fn _toml_parse_string_array(value: string) -> string[] {
    let mut items: string[] = [];
    let trimmed = _toml_trim(value);
    if trimmed.length < 2 { return items; }
    let mut _if437: boolean = false;
    if trimmed[0] != "[" { _if437 = true; }
    if trimmed[trimmed.length - 1] != "]" { _if437 = true; }
    if _if437 { return items; }
    let inner = _toml_trim(substring(trimmed, 1, trimmed.length - 1));
    if inner.length == 0 { return items; }
    let mut start: int = 0;
    let mut i: int = 0;
    let len = inner.length;
    loop {
        if i >= len { break; }
        if inner[i] == "," {
            let item = _toml_trim(substring(inner, start, i));
            if item.length > 0 { items.push(_toml_strip_quotes(item)); }
            start = i + 1;
        }
        i += 1;
    }
    let last_item = _toml_trim(substring(inner, start, len));
    if last_item.length > 0 {
        items.push(_toml_strip_quotes(last_item));
    }
    return items;
}

// ---- Stdlib resolution ----
// Standard capsules can be referenced by bare name ("http") or full
// registry name ("sfn/http"). These functions handle the mapping.
fn _is_stdlib(name: string) -> boolean {
    if strings_equal(name, "http") { return true; }
    if strings_equal(name, "fs") { return true; }
    if strings_equal(name, "os") { return true; }
    if strings_equal(name, "sync") { return true; }
    if strings_equal(name, "json") { return true; }
    if strings_equal(name, "crypto") { return true; }
    if strings_equal(name, "strings") { return true; }
    if strings_equal(name, "log") { return true; }
    if strings_equal(name, "time") { return true; }
    if strings_equal(name, "math") { return true; }
    if strings_equal(name, "path") { return true; }
    if strings_equal(name, "tensor") { return true; }
    if strings_equal(name, "layers") { return true; }
    if strings_equal(name, "nn") { return true; }
    if strings_equal(name, "losses") { return true; }
    if strings_equal(name, "toml") { return true; }
    if strings_equal(name, "net") { return true; }
    return false;
}

fn resolve_capsule_name(name: string) -> string {
    // "http" → "sfn/http", "sfn/http" → "sfn/http", "acme/router" → "acme/router"
    // Check if it already has a scope (contains "/")
    let mut i: int = 0;
    loop {
        if i >= name.length { break; }
        if name[i] == "/" { return name; }
        i += 1;
    }
    // Bare name — check if it's a stdlib capsule
    if _is_stdlib(name) { return "sfn/" + name; }
    // Unknown bare name — return as-is (will fail at download if not found)
    return name;
}

fn display_capsule_name(name: string) -> string {
    // "sfn/http" → "http" for stdlib, "acme/router" → "acme/router" for third-party
    if string_starts_with(name, "sfn/") {
        let short = substring(name, 4, name.length);
        if _is_stdlib(short) { return short; }
    }
    return name;
}

// True when a `key =` value begins an array (`[`) whose closing `]` is not on
// the same physical line, so the caller must fold in continuation lines.
fn _toml_opens_unclosed_array(value: string) -> boolean {
    if value.length == 0 { return false; }
    if value[0] != "[" { return false; }
    return find_char_local(value, "]", 0) < 0;
}

// Drop a `#` line comment from a continuation line inside a multi-line array.
// Cutting at the first `#` is safe for the values we fold — member paths,
// source lists, and capability names, none of which contain `#`. The known
// unsupported case is a quoted array element that itself contains `#` split
// across lines (`"a#b"`): it would truncate. Single-line arrays never reach
// this stripper, so they parse such an element correctly.
fn _toml_strip_line_comment(line: string) -> string {
    let hash = find_char_local(line, "#", 0);
    if hash < 0 { return line; }
    return _toml_trim(substring(line, 0, hash));
}

// ---- Internal parse ----
fn _parse_toml_internal(text: string) -> SailToml {
    let mut toml = SailToml {
        name: "",
        version: "0.1.0",
        description: "",
        entry: "src/main.sfn",
        dependencies: [],
        dev_dependencies: [],
        capabilities: [],
        build_kind: "",
        build_implicit: false,
        workspace_members: [],
        exports: [],
        toolchain_sfn: "",
        toolchain_channel: ""
    };
    let lines = _toml_split_lines(text);
    let mut section: string = "";
    let mut i: int = 0;
    loop {
        if i >= lines.length { break; }
        let raw_line = lines[i];
        i += 1;
        let line = _toml_trim(raw_line);
        if line.length == 0 { continue; }
        if line[0] == "#" { continue; }
        if line[0] == "[" {
            let close = find_char_local(line, "]", 0);
            if close > 0 {
                section = _toml_trim(substring(line, 1, close));
            }
            continue;
        }
        let eq_pos = find_char_local(line, "=", 0);
        if eq_pos < 0 { continue; }
        let key = _toml_trim(substring(line, 0, eq_pos));
        let mut value = _toml_trim(substring(line, eq_pos + 1, line.length));
        // A `key = [` whose `]` closer is on a later physical line: fold the
        // continuation lines into one logical value so multi-line arrays parse
        // the same as single-line ones (`_toml_parse_string_array` splits on
        // commas). Without this the reader saw only `[` and returned an empty
        // array — the reason `[workspace].members` had to be one long line.
        if _toml_opens_unclosed_array(value) {
            loop {
                if i >= lines.length { break; }
                let cont = _toml_strip_line_comment(_toml_trim(lines[i]));
                i += 1;
                if cont.length > 0 { value = value + " " + cont; }
                if find_char_local(cont, "]", 0) >= 0 { break; }
            }
        }
        let stripped_key = _toml_strip_quotes(key);
        let stripped_value = _toml_strip_quotes(value);
        if strings_equal(section, "capsule") {
            if strings_equal(stripped_key, "name") {
                toml.name = stripped_value;
            }
            if strings_equal(stripped_key, "version") {
                toml.version = stripped_value;
            }
            if strings_equal(stripped_key, "description") {
                toml.description = stripped_value;
            }
        }
        if strings_equal(section, "toolchain") {
            if strings_equal(stripped_key, "sfn") {
                toml.toolchain_sfn = stripped_value;
            }
            if strings_equal(stripped_key, "channel") {
                toml.toolchain_channel = stripped_value;
            }
        }
        if strings_equal(section, "build") {
            if strings_equal(stripped_key, "entry") {
                toml.entry = stripped_value;
            }
            if strings_equal(stripped_key, "kind") {
                toml.build_kind = stripped_value;
            }
            if strings_equal(stripped_key, "implicit") {
                toml.build_implicit = strings_equal(stripped_value, "true");
            }
        }
        if strings_equal(section, "workspace") {
            if strings_equal(stripped_key, "members") {
                toml.workspace_members = _toml_parse_string_array(value);
            }
        }
        if strings_equal(section, "exports") {
            if strings_equal(stripped_key, "modules") {
                toml.exports = _toml_parse_string_array(value);
            }
        }
        if strings_equal(section, "dependencies") {
            toml.dependencies.push(TomlDependency {
                capsule: stripped_key, version: stripped_value
            });
        }
        if strings_equal(section, "dev-dependencies") {
            toml.dev_dependencies.push(TomlDependency {
                capsule: stripped_key, version: stripped_value
            });
        }
        if strings_equal(section, "capabilities") {
            if strings_equal(stripped_key, "required") {
                toml.capabilities = _toml_parse_string_array(value);
            }
        }
    }
    return toml;
}

// ---- String-based public API (safe for cross-module use) ----
fn toml_get_name(text: string) -> string {
    let t = _parse_toml_internal(text);
    return t.name;
}

fn toml_get_version(text: string) -> string {
    let t = _parse_toml_internal(text);
    return t.version;
}

fn toml_get_entry(text: string) -> string {
    let t = _parse_toml_internal(text);
    return t.entry;
}

fn toml_get_description(text: string) -> string {
    let t = _parse_toml_internal(text);
    return t.description;
}

fn toml_get_toolchain_sfn(text: string) -> string {
    let t = _parse_toml_internal(text);
    return t.toolchain_sfn;
}

fn toml_get_toolchain_channel(text: string) -> string {
    let t = _parse_toml_internal(text);
    return t.toolchain_channel;
}

// ---- Stage A getters (parse-only; no consumers yet) ----
// These getters expose manifest fields the unified-build proposal
// (docs/proposals/0006-build-architecture.md, Stage A) adds to the schema.
// Stage B will start consuming them; Stage A only verifies round-trip.
fn toml_get_build_kind(text: string) -> string {
    let t = _parse_toml_internal(text);
    return t.build_kind;
}

fn toml_get_build_implicit(text: string) -> boolean {
    let t = _parse_toml_internal(text);
    return t.build_implicit;
}

// ---- Stage D PR1 getters: kind = "runtime" capsule schema ----
//
// `kind = "runtime"` capsules ship declarative C / LL source lists
// rather than walking `src/**/*.sfn` like a `kind = "library"`
// capsule. The driver compiles each `c-sources` entry with clang,
// assembles each `ll-sources` entry with clang, propagates
// `include-dirs` to downstream C compiles, and appends `link-libs`
// to the final link.
//
// All getters return `string[]` (or `""` for the prelude-entry
// scalar) so callers can plumb them straight into
// `process.run([...])` argv arrays. An absent field returns the
// empty array, which is also the correct default for any
// `kind != "runtime"` capsule (where these fields don't apply).
//
// Same shape as `toml_get_capabilities_required`: delegate to the
// section/key string-array helper, then split lines.
fn _toml_split_lines_into_array(joined: string) -> string[] {
    if joined.length == 0 { return []; }
    let lines = _toml_split_lines(joined);
    let mut out: string[] = [];
    let mut i: int = 0;
    loop {
        if i >= lines.length { break; }
        let trimmed = _toml_trim(lines[i]);
        if trimmed.length > 0 { out.push(trimmed); }
        i += 1;
    }
    return out;
}

fn toml_get_c_sources(text: string) -> string[] {
    return _toml_split_lines_into_array(toml_get_string_array(text, "build", "c-sources"));
}

fn toml_get_ll_sources(text: string) -> string[] {
    return _toml_split_lines_into_array(toml_get_string_array(text, "build", "ll-sources"));
}

fn toml_get_include_dirs(text: string) -> string[] {
    return _toml_split_lines_into_array(toml_get_string_array(text, "build", "include-dirs"));
}

fn toml_get_link_libs(text: string) -> string[] {
    return _toml_split_lines_into_array(toml_get_string_array(text, "build", "link-libs"));
}

// Sailfin sources compiled and linked alongside the runtime
// capsule's C sources. Each entry is a path (relative to the
// manifest dir) to a `.sfn` module the resolver hands the
// driver, which then spawns the compiler subprocess to emit
// `.ll` then `clang -c` to produce a `.o`. This is the
// production-ready replacement for the Makefile-staged
// `prelude.o` pattern: any `runtime/sfn/*.sfn` module a
// runtime capsule wants linked into every consumer ships
// declaratively here, and `sfn build -p compiler` picks it
// up automatically — no Makefile changes per file.
//
// Returns `[]` when unset.
fn toml_get_sfn_sources(text: string) -> string[] {
    return _toml_split_lines_into_array(toml_get_string_array(text, "build", "sfn-sources"));
}

// Transitional Stage D field — the entry path for the Sailfin
// prelude lowered alongside the runtime capsule's C sources.
// Returns `""` when unset. Stage F retires this field once
// `runtime/prelude.sfn` moves under `capsules/sfn/prelude/src/`.
fn toml_get_prelude_entry(text: string) -> string {
    return toml_get_string(text, "build", "prelude-entry");
}

// Returns workspace members as a newline-separated string. Matches the
// shape of toml_get_dependencies so callers split on "\n" without a
// SailToml struct crossing module boundaries.
fn toml_get_workspace_members(text: string) -> string {
    let t = _parse_toml_internal(text);
    let mut out: string = "";
    let mut i: int = 0;
    loop {
        if i >= t.workspace_members.length { break; }
        if i > 0 { out = out + "\n"; }
        out = out + t.workspace_members[i];
        i += 1;
    }
    return out;
}

// Returns [exports] modules as a newline-separated string.
fn toml_get_exports(text: string) -> string {
    let t = _parse_toml_internal(text);
    let mut out: string = "";
    let mut i: int = 0;
    loop {
        if i >= t.exports.length { break; }
        if i > 0 { out = out + "\n"; }
        out = out + t.exports[i];
        i += 1;
    }
    return out;
}

// Enumerate every section header of the form `[targets.<triple>]` and
// return the triples as a newline-separated string. Section bodies are
// reachable via toml_get_string / toml_get_string_array with section
// name "targets.<triple>".
fn toml_get_target_triples(text: string) -> string {
    let lines = _toml_split_lines(text);
    let prefix = "targets.";
    let mut out: string = "";
    let mut found: int = 0;
    let mut i: int = 0;
    loop {
        if i >= lines.length { break; }
        let line = _toml_trim(lines[i]);
        i += 1;
        if line.length == 0 { continue; }
        if line[0] != "[" { continue; }
        let close = find_char_local(line, "]", 0);
        if close <= 0 { continue; }
        let section = _toml_trim(substring(line, 1, close));
        if section.length <= prefix.length { continue; }
        let mut matches: boolean = true;
        let mut pi: int = 0;
        loop {
            if pi >= prefix.length { break; }
            if section[pi] != prefix[pi] {
                matches = false;
                break;
            }
            pi += 1;
        }
        if !matches { continue; }
        let triple = substring(section, prefix.length, section.length);
        if triple.length == 0 { continue; }
        if found > 0 { out = out + "\n"; }
        out = out + triple;
        found += 1;
    }
    return out;
}

// Read a string-array value at `[section] key = [ ... ]`. Returns "" if
// absent. Items are returned newline-separated. Generalises the Stage A
// getters above so callers can read [targets.<triple>].cc-flags without
// adding a dedicated function per key.
fn toml_get_string_array(text: string, section: string, key: string) -> string {
    let lines = _toml_split_lines(text);
    let mut current_section: string = "";
    let mut i: int = 0;
    loop {
        if i >= lines.length { break; }
        let line = _toml_trim(lines[i]);
        i += 1;
        if line.length == 0 { continue; }
        if line[0] == "#" { continue; }
        if line[0] == "[" {
            let close = find_char_local(line, "]", 0);
            if close > 0 {
                current_section = _toml_trim(substring(line, 1, close));
            }
            continue;
        }
        if !strings_equal(current_section, section) { continue; }
        let eq_pos = find_char_local(line, "=", 0);
        if eq_pos < 0 { continue; }
        let line_key = _toml_trim(substring(line, 0, eq_pos));
        let stripped_key = _toml_strip_quotes(line_key);
        if !strings_equal(stripped_key, key) { continue; }
        let mut value = _toml_trim(substring(line, eq_pos + 1, line.length));
        if _toml_opens_unclosed_array(value) {
            loop {
                if i >= lines.length { break; }
                let cont = _toml_strip_line_comment(_toml_trim(lines[i]));
                i += 1;
                if cont.length > 0 { value = value + " " + cont; }
                if find_char_local(cont, "]", 0) >= 0 { break; }
            }
        }
        let arr = _toml_parse_string_array(value);
        let mut out: string = "";
        let mut ai: int = 0;
        loop {
            if ai >= arr.length { break; }
            if ai > 0 { out = out + "\n"; }
            out = out + arr[ai];
            ai += 1;
        }
        return out;
    }
    return "";
}

// Phase F: read `[capabilities] required = [...]` from a capsule
// manifest. Returns the parsed list of capability names as a real
// `string[]` (not newline-joined like `toml_get_string_array`) so
// downstream consumers can pass it straight into the effect-checker
// `validate_capsule_capabilities` call without round-tripping
// through `_split_lines`. An empty list means either:
//   - the manifest declares `required = []` (no capabilities granted)
//   - the manifest has no `[capabilities]` section at all
//   - the input text isn't a capsule manifest (e.g. caller passed
//     "" because the file wasn't on disk)
// All three resolve to the same caller behaviour: skip the
// capability cross-check, since there's no surface to compare
// against. The effect-checker treats "no capabilities declared"
// as "all capabilities allowed" — `compiler/capsule.toml` and the
// stdlib capsules opt in by listing their required set explicitly.
fn toml_get_capabilities_required(text: string) -> string[] {
    return _toml_split_lines_into_array(toml_get_string_array(text, "capabilities", "required"));
}

// SFEP-0051 Phase 4a: workspace capability-envelope getters. Read the
// `[workspace.capabilities]` effect lists from a workspace.toml. Parsing
// only — envelope validation (canonical-effect membership, alphabetical
// order) and diagnostics live in the resolver's `workspace_capability_audit`
// (capsule_resolver.sfn), because this module is deliberately
// Diagnostic-free: every getter returns a bare value with an empty-list
// absent sentinel.
fn toml_get_workspace_capabilities_allow(text: string) -> string[] {
    return _toml_split_lines_into_array(toml_get_string_array(text, "workspace.capabilities", "allow"));
}

fn toml_get_workspace_capabilities_deny(text: string) -> string[] {
    return _toml_split_lines_into_array(toml_get_string_array(text, "workspace.capabilities", "deny"));
}

// Per-member grant lookup: the effects granted to `member` above the base
// envelope, from `[workspace.capabilities.grants]` (whose keys are member
// names, e.g. `"sfn/net" = ["net"]`). Absent member → empty list. Member
// keys are quoted in TOML; `toml_get_string_array` strips key quotes, so the
// raw member name (e.g. "sfn/net") is the correct lookup key.
fn toml_get_workspace_capabilities_grant(text: string, member: string) -> string[] {
    return _toml_split_lines_into_array(toml_get_string_array(text, "workspace.capabilities.grants", member));
}

// SFEP-0051 Phase 3: recognize the `{ workspace = true }` inline-table marker
// a member uses to opt into workspace inheritance (Cargo's spelling). The
// minimal parser stores such a value verbatim — `_toml_strip_quotes` leaves
// braces untouched and it never opens an array — so inheritance detection is a
// predicate on the raw value string a getter returns (e.g. `toml_get_version`).
// Accepts only the single-key `workspace = true` form; any other inline-table
// content is not an inherit marker. Diagnostic-free like the rest of this
// module; the resolver performs the substitution.
fn toml_value_is_workspace_inherit(value: string) -> boolean {
    let trimmed = _toml_trim(value);
    if trimmed.length < 2 { return false; }
    if trimmed[0] != "{" { return false; }
    if trimmed[trimmed.length - 1] != "}" { return false; }
    let inner = _toml_trim(substring(trimmed, 1, trimmed.length - 1));
    let eq_pos = find_char_local(inner, "=", 0);
    if eq_pos < 0 { return false; }
    let k = _toml_strip_quotes(_toml_trim(substring(inner, 0, eq_pos)));
    let v = _toml_strip_quotes(_toml_trim(substring(inner, eq_pos + 1, inner.length)));
    if !strings_equal(k, "workspace") { return false; }
    return strings_equal(v, "true");
}

// SFEP-0051 Phase 3: inheritable defaults a member picks up from the workspace
// root's `[workspace.package]` block when it opts in with `= { workspace = true }`.
// Parse-only round-trip getters — the resolver (`resolve_inherited_version`)
// performs the substitution against the member's own value. Absent → "".
fn toml_get_workspace_package_version(text: string) -> string {
    return toml_get_string(text, "workspace.package", "version");
}

fn toml_get_workspace_package_license(text: string) -> string {
    return toml_get_string(text, "workspace.package", "license");
}

// SFEP-0051 Phase 3: read `[workspace.dependencies]` — the canonical version
// each member resolves against when it opts in with `= { workspace = true }`.
// Returns "capsule=version" pairs newline-separated, matching the shape of
// `toml_get_dependencies` so callers recover entries by splitting on "\n"/"="
// without the SailToml struct crossing a module boundary. Inheritance sets the
// range; the root lockfile still records the exact pin (SFEP-0006 §4.12).
fn toml_get_workspace_dependencies(text: string) -> string {
    let lines = _toml_split_lines(text);
    let mut current_section: string = "";
    let mut out: string = "";
    let mut found: int = 0;
    let mut i: int = 0;
    loop {
        if i >= lines.length { break; }
        let line = _toml_trim(lines[i]);
        i += 1;
        if line.length == 0 { continue; }
        if line[0] == "#" { continue; }
        if line[0] == "[" {
            let close = find_char_local(line, "]", 0);
            if close > 0 {
                current_section = _toml_trim(substring(line, 1, close));
            }
            continue;
        }
        if !strings_equal(current_section, "workspace.dependencies") {
            continue;
        }
        let eq_pos = find_char_local(line, "=", 0);
        if eq_pos < 0 { continue; }
        let dep_key = _toml_strip_quotes(_toml_trim(substring(line, 0, eq_pos)));
        let dep_val = _toml_strip_quotes(_toml_trim(substring(line, eq_pos + 1, line.length)));
        if dep_key.length == 0 { continue; }
        if found > 0 { out = out + "\n"; }
        out = out + dep_key + "=" + dep_val;
        found += 1;
    }
    return out;
}

// Read a string value at `[section] key = "value"`. Returns "" if absent.
// Lets callers read ad-hoc config (e.g. ~/.sfn/config.toml) without the
// manifest-shaped SailToml struct.
fn toml_get_string(text: string, section: string, key: string) -> string {
    let lines = _toml_split_lines(text);
    let mut current_section: string = "";
    let mut i: int = 0;
    loop {
        if i >= lines.length { break; }
        let line = _toml_trim(lines[i]);
        i += 1;
        if line.length == 0 { continue; }
        if line[0] == "#" { continue; }
        if line[0] == "[" {
            let close = find_char_local(line, "]", 0);
            if close > 0 {
                current_section = _toml_trim(substring(line, 1, close));
            }
            continue;
        }
        if !strings_equal(current_section, section) { continue; }
        let eq_pos = find_char_local(line, "=", 0);
        if eq_pos < 0 { continue; }
        let line_key = _toml_trim(substring(line, 0, eq_pos));
        let stripped_key = _toml_strip_quotes(line_key);
        if !strings_equal(stripped_key, key) { continue; }
        let value = _toml_trim(substring(line, eq_pos + 1, line.length));
        return _toml_strip_quotes(value);
    }
    return "";
}

// Return dependencies as a newline-separated string of "capsule=version" pairs.
// Callers can split on "\n" and "=" to recover individual entries without
// needing the SailToml struct across module boundaries.
fn toml_get_dependencies(text: string) -> string {
    let t = _parse_toml_internal(text);
    let mut out: string = "";
    let mut i: int = 0;
    loop {
        if i >= t.dependencies.length { break; }
        if i > 0 { out = out + "\n"; }
        out = out + t.dependencies[i].capsule + "=" + t.dependencies[i].version;
        i += 1;
    }
    return out;
}

// Generate a capsule.toml string from individual fields
fn toml_generate(name: string, version: string, description: string, entry: string, toolchain_sfn: string) -> string {
    let mut out: string = "[capsule]\n";
    out = out + "name = \"" + name + "\"\n";
    out = out + "version = \"" + version + "\"\n";
    if description.length > 0 {
        out = out + "description = \"" + description + "\"\n";
    }
    if toolchain_sfn.length > 0 {
        out = out + "\n[toolchain]\n";
        out = out + "sfn = \"" + toolchain_sfn + "\"\n";
    }
    out = out + "\n[dependencies]\n";
    out = out + "\n[capabilities]\n";
    out = out + "required = []\n";
    out = out + "\n[build]\n";
    out = out + "entry = \"" + entry + "\"\n";
    return out;
}

// Add a dependency to an existing capsule.toml text and return the updated text.
// If the dependency already exists, update its version.
fn toml_add_dependency(toml_text: string, capsule: string, version: string) -> string {
    let t = _parse_toml_internal(toml_text);
    let mut found: boolean = false;
    let mut di: int = 0;
    loop {
        if di >= t.dependencies.length { break; }
        if strings_equal(t.dependencies[di].capsule, capsule) {
            t.dependencies[di].version = version;
            found = true;
        }
        di += 1;
    }
    if !found {
        t.dependencies.push(TomlDependency {
            capsule: capsule, version: version
        });
    }
    return _write_toml(t);
}

// Add a dev dependency to an existing capsule.toml text and return the updated text.
fn toml_add_dev_dependency(toml_text: string, capsule: string, version: string) -> string {
    let t = _parse_toml_internal(toml_text);
    let mut found: boolean = false;
    let mut di: int = 0;
    loop {
        if di >= t.dev_dependencies.length { break; }
        if strings_equal(t.dev_dependencies[di].capsule, capsule) {
            t.dev_dependencies[di].version = version;
            found = true;
        }
        di += 1;
    }
    if !found {
        t.dev_dependencies.push(TomlDependency {
            capsule: capsule, version: version
        });
    }
    return _write_toml(t);
}

// Merge a list of required capabilities into an existing capsule.toml
// text's `[capabilities] required = [...]` set and return the updated
// text. Used by `sfn add` to propagate a dependency's required
// capability surface into the consumer manifest (#1395). Existing
// capabilities are preserved and duplicates are not re-added, so the
// result is the order-stable union (consumer's existing caps first,
// then any new caps from `caps` in argument order). Empty entries are
// ignored; an empty `caps` list returns the text unchanged modulo
// manifest normalization.
fn toml_merge_capabilities_required(toml_text: string, caps: string[]) -> string {
    let t = _parse_toml_internal(toml_text);
    let mut ci: int = 0;
    loop {
        if ci >= caps.length { break; }
        let cap = caps[ci];
        ci += 1;
        if cap.length == 0 { continue; }
        let mut exists: boolean = false;
        let mut ei: int = 0;
        loop {
            if ei >= t.capabilities.length { break; }
            if strings_equal(t.capabilities[ei], cap) { exists = true; }
            ei += 1;
        }
        if !exists { t.capabilities.push(cap); }
    }
    return _write_toml(t);
}

// Write a SailToml back to string (internal)
fn _write_toml(toml: SailToml) -> string {
    let mut out: string = "[capsule]\n";
    out = out + "name = \"" + toml.name + "\"\n";
    out = out + "version = \"" + toml.version + "\"\n";
    if toml.description.length > 0 {
        out = out + "description = \"" + toml.description + "\"\n";
    }
    if toml.toolchain_sfn.length > 0 || toml.toolchain_channel.length > 0 {
        out = out + "\n[toolchain]\n";
        if toml.toolchain_sfn.length > 0 {
            out = out + "sfn = \"" + toml.toolchain_sfn + "\"\n";
        }
        if toml.toolchain_channel.length > 0 {
            out = out + "channel = \"" + toml.toolchain_channel + "\"\n";
        }
    }
    out = out + "\n[dependencies]\n";
    let mut i: int = 0;
    loop {
        if i >= toml.dependencies.length { break; }
        let dep = toml.dependencies[i];
        out = out + "\"" + dep.capsule + "\" = \"" + dep.version + "\"\n";
        i += 1;
    }
    if toml.dev_dependencies.length > 0 {
        out = out + "\n[dev-dependencies]\n";
        let mut j: int = 0;
        loop {
            if j >= toml.dev_dependencies.length { break; }
            let dep = toml.dev_dependencies[j];
            out = out + "\"" + dep.capsule + "\" = \"" + dep.version + "\"\n";
            j += 1;
        }
    }
    out = out + "\n[capabilities]\n";
    out = out + "required = [";
    let mut k: int = 0;
    loop {
        if k >= toml.capabilities.length { break; }
        if k > 0 { out = out + ", "; }
        out = out + "\"" + toml.capabilities[k] + "\"";
        k += 1;
    }
    out = out + "]\n";
    out = out + "\n[build]\n";
    out = out + "entry = \"" + toml.entry + "\"\n";
    if toml.build_kind.length > 0 {
        out = out + "kind = \"" + toml.build_kind + "\"\n";
    }
    if toml.build_implicit { out = out + "implicit = true\n"; }
    if toml.workspace_members.length > 0 {
        out = out + "\n[workspace]\n";
        out = out + "members = [";
        let mut wi: int = 0;
        loop {
            if wi >= toml.workspace_members.length { break; }
            if wi > 0 { out = out + ", "; }
            out = out + "\"" + toml.workspace_members[wi] + "\"";
            wi += 1;
        }
        out = out + "]\n";
    }
    if toml.exports.length > 0 {
        out = out + "\n[exports]\n";
        out = out + "modules = [";
        let mut ei: int = 0;
        loop {
            if ei >= toml.exports.length { break; }
            if ei > 0 { out = out + ", "; }
            out = out + "\"" + toml.exports[ei] + "\"";
            ei += 1;
        }
        out = out + "]\n";
    }
    return out;
}
