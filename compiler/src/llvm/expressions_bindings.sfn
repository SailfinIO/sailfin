// compiler/src/llvm/expressions_bindings.sfn
//
// Local and parameter binding lookup and mutation helpers.

import {
    LocalBinding, ParameterBinding,
} from "./types";

// =============================================================================
// Local and Parameter Binding Lookup
// =============================================================================

fn find_local_binding(locals -> LocalBinding[], name -> string) -> LocalBinding? {
    let mut index -> number = locals.length;
    loop {
        if index <= 0 {
            break;
        }
        index -= 1;
        let entry = locals[index];
        if entry.name == name {
            return entry;
        }
    }
    return null;
}

fn find_parameter_binding(bindings -> ParameterBinding[], name -> string) -> ParameterBinding? {
    let mut index -> number = 0;
    loop {
        if index >= bindings.length {
            break;
        }
        let binding = bindings[index];
        if binding.name == name {
            return binding;
        }
        index += 1;
    }
    return null;
}

fn mark_parameter_consumed(bindings -> ParameterBinding[], name -> string) -> ParameterBinding[] {
    let mut result -> ParameterBinding[] = [];
    let mut index -> number = 0;
    loop {
        if index >= bindings.length {
            break;
        }
        let binding = bindings[index];
        if binding.name == name {
            let updated = ParameterBinding {
                name: binding.name,
                llvm_name: binding.llvm_name,
                llvm_type: binding.llvm_type,
                type_annotation: binding.type_annotation,
                consumed: true,
                span: binding.span,
            };
            result.push(updated);
        } else {
            result.push(binding);
        }
        index += 1;
    }
    return result;
}

fn mark_local_consumed(locals -> LocalBinding[], name -> string) -> LocalBinding[] {
    let mut result -> LocalBinding[] = [];
    let mut index -> number = 0;
    loop {
        if index >= locals.length {
            break;
        }
        let entry = locals[index];
        if entry.name == name {
            let updated = LocalBinding {
                name: entry.name,
                pointer: entry.pointer,
                llvm_type: entry.llvm_type,
                type_annotation: entry.type_annotation,
                ownership: entry.ownership,
                consumed: true,
                scope_id: entry.scope_id,
                scope_depth: entry.scope_depth,
            };
            result.push(updated);
        } else {
            result.push(entry);
        }
        index += 1;
    }
    return result;
}

fn reset_local_consumption(locals -> LocalBinding[], name -> string) -> LocalBinding[] {
    let mut result -> LocalBinding[] = [];
    let mut index -> number = 0;
    loop {
        if index >= locals.length {
            break;
        }
        let entry = locals[index];
        if entry.name == name {
            let updated = LocalBinding {
                name: entry.name,
                pointer: entry.pointer,
                llvm_type: entry.llvm_type,
                type_annotation: entry.type_annotation,
                ownership: entry.ownership,
                consumed: false,
                scope_id: entry.scope_id,
                scope_depth: entry.scope_depth,
            };
            result.push(updated);
        } else {
            result.push(entry);
        }
        index += 1;
    }
    return result;
}
