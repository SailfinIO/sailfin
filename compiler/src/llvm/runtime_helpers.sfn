        target: "websocket.serve_tls", symbol: "sfn_websocket_serve_tls", return_type: "void", parameter_types: ["i32", "i8*", "i8*"], effects: ["net"], native_signature: "sfn_websocket_serve_tls", c_abi_return_type: null
    });
