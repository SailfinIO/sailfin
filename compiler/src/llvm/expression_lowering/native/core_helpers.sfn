// compiler/src/llvm/expression_lowering/native/core_helpers.sfn
//
// Small helper utilities extracted from core.sfn to reduce file size.
import { NativeParameter } from "../../../native_ir";
import { find_last_index_of_char, substring } from "../../../string_utils";
import { TypeContext } from "../../types";
import { append_string } from "../../utils";
import { map_parameter_type, map_struct_type_annotation_ctx } from "./core_type_mapping";

fn collect_parameter_types(context: TypeContext, parameters: NativeParameter[], function_name: string) -> string[] {
    let mut types: string[] = [];
    let mut index: number = 0;
    loop {
        if index >= parameters.length { break; }
        let parameter = parameters[index];
        let mut llvm_type = map_parameter_type(context, parameter.type_annotation);

        // Method receiver type inference: the self parameter type is set by
        // flatten_struct_methods in lowering_helpers_mangling.sfn. Fused method
        // names (e.g. Counteris_zero) cannot be split back into struct + method.
        if parameter.type_annotation.length == 0 {
            if parameter.name == "self" {
                if index == 0 {
                    // Type already set in flatten_struct_methods; no split possible.
                }
            }
        }
        if llvm_type.length == 0 { types.push("double"); } else {
            types.push(llvm_type);
        }
        index += 1;
    }
    return types;
}

fn operation_name_for_symbol(symbol: string, llvm_type: string) -> string {
    if llvm_type == "double" {
        if symbol == "+" { return "fadd"; }
        if symbol == "-" { return "fsub"; }
        if symbol == "*" { return "fmul"; }
        if symbol == "/" { return "fdiv"; }
        if symbol == "%" { return "frem"; }
        // Bitwise + shift operators are not valid on floating-
        // point in LLVM IR. Returning empty triggers the
        // binary-op caller's diagnostic path; Slice D's `as`
        // casts plus the planned typecheck rejection will
        // surface a clean error before lowering reaches here
        // (L2/L3/L4 in `docs/runtime_architecture.md` §3.7).
        if symbol == "&" { return ""; }
        if symbol == "|" { return ""; }
        if symbol == "^" { return ""; }
        if symbol == "<<" { return ""; }
        if symbol == ">>" { return ""; }
    }
    if symbol == "+" { return "add"; }
    if symbol == "-" { return "sub"; }
    if symbol == "*" { return "mul"; }
    if symbol == "/" { return "sdiv"; }
    if symbol == "%" { return "srem"; }
    // Slice B (2026-05-02): bitwise + shift on integer operands.
    // `>>` lowers to `ashr` (arithmetic right shift) by default —
    // preserves the sign of the value, matching what `signed`
    // numeric types want. Logical right shift (`lshr`, zero-fill)
    // waits on Slice D's `as` casts so unsigned-typed values get
    // an explicit type the lowering can branch on.
    if symbol == "&" { return "and"; }
    if symbol == "|" { return "or"; }
    if symbol == "^" { return "xor"; }
    if symbol == "<<" { return "shl"; }
    if symbol == ">>" { return "ashr"; }
    return "add";
}

export { collect_parameter_types, operation_name_for_symbol };
