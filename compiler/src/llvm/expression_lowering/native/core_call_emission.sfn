// compiler/src/llvm/expression_lowering/native/core_call_emission.sfn
//
// Call emission extracted from core_call_lowering.sfn to keep
// each function under ~500 .sfn-asm instructions (avoids seed OOM).
import { NativeFunction, NativeParameter } from "../../../native_ir";
import { find_last_index_of_char, substring } from "../../../string_utils";
import { format_temp_name, format_typed_operand } from "../../expressions_helpers";
import {
    clock_monotonic_id_value,
    errno_locator_symbol,
    exe_path_locator,
    fs_platform_leg,
    sc_nprocessors_onln_value,
    stat_buf_size_value,
    stat_st_mode_offset_value,
    trace_lowering
} from "../../lowering_debug_state";
import {
    append_string_constant,
    find_string_constant_by_name,
    merge_string_constants
} from "../../strings";
import { find_interface_info_by_name } from "../../type_context_queries";
import { ends_with_pointer_suffix, strip_pointer_suffix } from "../../type_mapping";
import {
    ExpressionResult,
    LLVMOperand,
    LocalBinding,
    MemberAccessParse,
    ParameterBinding,
    RuntimeHelperDescriptor,
    StringConstant,
    TypeContext
} from "../../types";
import {
    extend_string_array,
    join_with_separator,
    number_to_string,
    starts_with,
    trim_text
} from "../../utils";
import {
    array_pointer_element_type,
    lower_array_push_in_place,
    lower_struct_array_concat
} from "../arrays";
import { coerce_operand_to_type } from "./core_operands";
import { parse_member_access } from "./core_parse";
import { find_local_binding } from "./core_scopes";
import { find_substring_from, sanitize_symbol } from "./core_text";

// Slice E.1.5 (#528): if the wrapped diagnostics list contains the ABI
// primitive mismatch sentinel, return the `llvm lowering [fatal]: ` prefix
// so the location-aware follow-up message also escalates to fatal (the
// emit-level entrypoint scans for `[fatal]` and refuses to write IR).
// Returns the plain `llvm lowering: ` prefix otherwise so non-ABI coercion
// failures keep their existing tier.
fn _abi_mismatch_diagnostic_prefix(diagnostics: string[]) -> string {
    let mut idx: int = 0;
    loop {
        if idx >= diagnostics.length { break; }
        let diag = diagnostics[idx];
        if find_substring_from(diag, "ABI primitive mismatch", 0) >= 0 {
            return "llvm lowering [fatal]: ";
        }
        idx += 1;
    }
    return "llvm lowering: ";
}

// Coerce operands to expected types and emit the final call instruction.
// Handles array concat/push, trait dispatch, closure dispatch, and normal function calls.
fn coerce_and_emit_call(trimmed_target: string, operands: LLVMOperand[], expected_params: string[], llvm_return: string, is_trait_dispatch: boolean, is_closure_dispatch: boolean, is_array_concat: boolean, array_concat_element_type: string, is_array_push: boolean, array_push_element_type: string, method_operand: LLVMOperand?, helper_descriptor: RuntimeHelperDescriptor?, function_entry: NativeFunction?, current_temp: int, current_lines: string[], diagnostics: string[], collected_string_constants: StringConstant[], bindings: ParameterBinding[], locals: LocalBinding[], context: TypeContext) -> ExpressionResult ![io] {
    let mut result_lines = current_lines;
    let mut result_temp: int = current_temp;
    let mut result_diagnostics = diagnostics;
    let _trace_ccl = trace_lowering();

    // Coerce operands to expected parameter types
    if _trace_ccl {
        print.err("call_lowering: pre-coerce operands=" + number_to_string(operands.length)
            + " expected_params="
            + number_to_string(expected_params.length)
            + " llvm_return="
            + llvm_return);
    }
    let mut coerced_operands: LLVMOperand[] = [];
    let mut index: int = 0;
    loop {
        if index >= operands.length { break; }
        let operand = operands[index];
        if _trace_ccl {
            print.err("call_lowering: coerce-loop idx=" + number_to_string(index)
                + " operand_type="
                + operand.llvm_type
                + " operand_value="
                + operand.value);
        }
        let mut target_type: string = "";
        if expected_params.length > index {
            target_type = expected_params[index];
        }
        let mut _if55: boolean = false;
        if is_trait_dispatch {
            if index == 0 { _if55 = true; }
        }
        // Issue #689: like trait dispatch, the closure-pair operand at
        // slot 0 is a self-shaped aggregate that bypasses coercion;
        // `coerce_and_emit_call`'s closure-dispatch branch consumes it
        // directly via `extractvalue`.
        if is_closure_dispatch {
            if index == 0 { _if55 = true; }
        }
        if _if55 { coerced_operands.push(operand); } else if target_type.length == 0 {
            coerced_operands.push(operand);
        } else {
            // Slice E.1.5 (#528) + #550: function call argument coercion is
            // the primary ABI boundary. Strict mode (`allow_widen=false`)
            // emits a `[warning] ABI primitive mismatch` for `float → int`
            // mismatches and falls through to `coerce_numeric_primitive`
            // (still emitting `round + fptosi`) — the original `[fatal]`
            // refusal was downgraded in #550. The fatal re-promotes
            // symmetrically in #490 once E.2 completes.
            let coerced = coerce_operand_to_type(operand, target_type, result_temp, result_lines, false, null);
            result_diagnostics = extend_string_array(result_diagnostics, coerced.diagnostics);
            result_lines = coerced.lines;
            result_temp = coerced.temp_index;
            if coerced.operand == null {
                // Slice E.1.5 (#528): if the underlying refusal was an ABI
                // primitive mismatch, escalate the location-aware message
                // to `[fatal]` too so partial-migration breakage is
                // self-locating in the build log. The mismatch detail
                // (callee/caller LLVM types + kinds) was already pushed by
                // `coerce_operand_to_type`; this adds the callee symbol +
                // argument index that only the call site can name.
                let _arg_diagnostic_prefix = _abi_mismatch_diagnostic_prefix(coerced.diagnostics);
                let _arg_diag = _arg_diagnostic_prefix
                    + "unable to coerce argument "
                    + number_to_string(index)
                    + " (expected `"
                    + target_type
                    + "`, got `"
                    + operand.llvm_type
                    + "`) for call to `"
                    + trimmed_target
                    + "`: passing original operand";
                // Slice E.1.5 (#528): mirror the ABI-shape detail's stderr
                // emission so the location-aware follow-up surfaces even
                // when the build refuses to write IR (and the diagnostics
                // list never reaches the renderer).
                if _arg_diagnostic_prefix == "llvm lowering [fatal]: " {
                    print.err(_arg_diag);
                }
                result_diagnostics.push(_arg_diag);
                coerced_operands.push(operand);
            } else { coerced_operands.push(coerced.operand); }
        }
        index += 1;
    }
    let final_operands = coerced_operands;
    if _trace_ccl {
        print.err("call_lowering: post-coerce operands=" + number_to_string(final_operands.length));
    }

    if _trace_ccl {
        print.err("call_lowering: checkpoint-A is_concat=" + number_to_string(0)
            + " is_push="
            + number_to_string(0));
    }

    // Array concat inline lowering
    if is_array_concat {
        if array_concat_element_type.length > 0 {
            if !ends_with_pointer_suffix(array_concat_element_type) {
                if final_operands.length >= 2 {
                    let concat_result = lower_struct_array_concat(final_operands[0], final_operands[1], array_concat_element_type, result_lines, result_temp);
                    let mut _ci7: int = 0;
                    loop {
                        if _ci7 >= concat_result.diagnostics.length { break; }
                        result_diagnostics.push(concat_result.diagnostics[_ci7]);
                        _ci7 += 1;
                    }
                    result_lines = concat_result.lines;
                    result_temp = concat_result.temp_index;
                    if concat_result.operand == null {
                        return ExpressionResult {
                            lines: result_lines,
                            temp_index: result_temp,
                            operand: null,
                            diagnostics: result_diagnostics,
                            string_constants: collected_string_constants
                        };
                    }
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: concat_result.operand,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                } else {
                    result_diagnostics.push("llvm lowering: concat requires two operands");
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: null,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                }
            }
        }
    }

    // Array push inline lowering
    if is_array_push {
        if array_push_element_type.length > 0 {
            if final_operands.length >= 2 {
                // Slice E.1 (#488): coerce the push value to the array's
                // element type before delegating to `lower_array_push_in_place`.
                // Pre-E.1 the bare-integer-literal default was `double`, so
                // `arr.push(10)` against a `double[]` (== `number[]`) array
                // produced a matching `value.llvm_type == "double"` operand
                // that flowed through the in-place store unchanged. After E.1
                // the same literal lowers to `i64`, and the in-place store
                // emits invalid `store double 10, double*` IR unless we coerce
                // here. `coerce_operand_to_type` is a no-op when the operand
                // already matches; for integer-literal-vs-double mixes it
                // routes through the `sitofp` widening path that Slice D
                // wired up, preserving the pre-E.1 semantics.
                // `arr.push(...)` is a value-shape coercion that legitimately
                // widens i64 literals to double[] receivers (see Slice E.1
                // comment above). Slice E.1.5 (#528) leaves this site exempt
                // from the ABI primitive kind check.
                let push_value_coerced = coerce_operand_to_type(final_operands[1], array_push_element_type, result_temp, result_lines, true, null);
                let mut _ci_apc: int = 0;
                loop {
                    if _ci_apc >= push_value_coerced.diagnostics.length {
                        break;
                    }
                    result_diagnostics.push(push_value_coerced.diagnostics[_ci_apc]);
                    _ci_apc += 1;
                }
                result_lines = push_value_coerced.lines;
                result_temp = push_value_coerced.temp_index;
                if push_value_coerced.operand == null {
                    // Coercion failed — bail out instead of forwarding
                    // the original mismatched operand into
                    // `lower_array_push_in_place`, which would emit a
                    // malformed `store <element_type> <value>` line.
                    // The diagnostics from `coerce_operand_to_type`
                    // (already propagated above) describe the failure.
                    result_diagnostics.push("llvm lowering: unable to coerce push argument to `"
                        + array_push_element_type
                        + "` for `"
                        + trimmed_target
                        + "`");
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: null,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                }
                let push_value_operand = push_value_coerced.operand;
                let push_result = lower_array_push_in_place(final_operands[0], push_value_operand, array_push_element_type, result_lines, result_temp);
                let mut _ci8: int = 0;
                loop {
                    if _ci8 >= push_result.diagnostics.length { break; }
                    result_diagnostics.push(push_result.diagnostics[_ci8]);
                    _ci8 += 1;
                }
                result_lines = push_result.lines;
                result_temp = push_result.temp_index;
                if push_result.operand == null {
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: null,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                }
                if array_push_element_type == "i8*" {
                    let method_parse = parse_member_access(trimmed_target);
                    if method_parse.success {
                        let push_receiver_name = trim_text(method_parse.base);
                        let push_receiver_local = find_local_binding(locals, push_receiver_name);
                        if push_receiver_local != null {
                            result_lines.push("  store " + push_result.operand.llvm_type
                                + " "
                                + push_result.operand.value
                                + ", "
                                + push_result.operand.llvm_type
                                + "* "
                                + push_receiver_local.pointer);
                        }
                    }
                }
                return ExpressionResult {
                    lines: result_lines,
                    temp_index: result_temp,
                    operand: push_result.operand,
                    diagnostics: result_diagnostics,
                    string_constants: collected_string_constants
                };
            } else {
                result_diagnostics.push("llvm lowering: push requires two operands");
                return ExpressionResult {
                    lines: result_lines,
                    temp_index: result_temp,
                    operand: null,
                    diagnostics: result_diagnostics,
                    string_constants: collected_string_constants
                };
            }
        }
    }

    if _trace_ccl {
        print.err("call_lowering: checkpoint-B fn_entry_null="
            + number_to_string(0));
    }
    let mut _if56: boolean = false;
    if function_entry != null { _if56 = true; }
    if helper_descriptor != null { _if56 = true; }
    if _trace_ccl {
        print.err("call_lowering: checkpoint-C _if56=" + number_to_string(0));
    }
    if _if56 {
        if expected_params.length != final_operands.length {
            result_diagnostics.push("llvm lowering: call to `" + trimmed_target
                + "` expected "
                + number_to_string(expected_params.length)
                + " arguments but received "
                + number_to_string(final_operands.length));
        }
    }

    if _trace_ccl {
        print.err("call_lowering: checkpoint-D rendering args");
    }
    let mut rendered_args: string[] = [];
    index = 0;
    loop {
        if index >= final_operands.length { break; }
        if _trace_ccl {
            print.err("call_lowering: render-arg idx=" + number_to_string(index));
        }
        rendered_args.push(format_typed_operand(final_operands[index]));
        index += 1;
    }
    if _trace_ccl {
        print.err("call_lowering: checkpoint-E args rendered");
    }
    let argument_text = join_with_separator(rendered_args, ", ");

    // Hard-fail when the signature resolver could not determine the
    // callee's return type. Emitting `call i8*` against a `declare void`
    // (or vice versa) produces structurally invalid LLVM IR; clang
    // tolerates it for unused returns but the IR is malformed and the
    // bug eventually surfaces as a verifier error or a miscompile.
    // See issue #306 — this replaces the previous silent `i8*` default.
    //
    // The diagnostic carries a `[fatal]` sentinel that the emit-level
    // entrypoints (`compile_native_text_to_llvm_file`, `write_llvm_ir`)
    // scan for and return `false` on, so the CLI exits non-zero rather
    // than writing a partial IR file with the side-effecting call
    // silently dropped.
    if llvm_return.length == 0 {
        let unresolved_diag = "llvm lowering [fatal]: cannot resolve return type for call to `"
            + trimmed_target
            + "` — callee signature is not known to the compiler";
        print.err(unresolved_diag);
        result_diagnostics.push(unresolved_diag);
        return ExpressionResult {
            lines: result_lines,
            temp_index: result_temp,
            operand: null,
            diagnostics: result_diagnostics,
            string_constants: collected_string_constants
        };
    }

    // Issue #689: closure-callee dispatch. `final_operands[0]` is the
    // `{i8*, i8*}` closure-pair aggregate loaded by
    // `try_resolve_closure_callee`; the remaining operands are the
    // user-supplied call arguments (already coerced against the
    // closure's parameter types in the coerce loop above). The
    // dispatch sequence mirrors trait dispatch: extract `fn_ptr` and
    // `env*`, bitcast `fn_ptr` to the typed function-pointer type,
    // and emit the call with `env*` as the hidden first argument.
    if is_closure_dispatch {
        if final_operands.length == 0 {
            result_diagnostics.push("llvm lowering: closure dispatch requires a closure-pair operand");
            return ExpressionResult {
                lines: result_lines,
                temp_index: result_temp,
                operand: null,
                diagnostics: result_diagnostics,
                string_constants: collected_string_constants
            };
        }
        // Validate arity against the closure's declared parameter
        // shape (`expected_params[0]` is the `{i8*, i8*}` self slot
        // injected by `resolve_call_signature`; the remainder is the
        // user-visible signature). Without this guard, a wrong arg
        // count would silently bitcast the function pointer to a
        // signature derived from the provided operand types and emit
        // a call that mismatches the callee's real ABI — exactly the
        // UB the `[fatal]` sentinel is meant to refuse IR over.
        if final_operands.length != expected_params.length {
            let arity_diag = "llvm lowering [fatal]: closure dispatch arity mismatch for `"
                + trimmed_target
                + "`: expected "
                + number_to_string(expected_params.length - 1)
                + " user argument(s), got "
                + number_to_string(final_operands.length - 1);
            print.err(arity_diag);
            result_diagnostics.push(arity_diag);
            return ExpressionResult {
                lines: result_lines,
                temp_index: result_temp,
                operand: null,
                diagnostics: result_diagnostics,
                string_constants: collected_string_constants
            };
        }
        let closure_pair = final_operands[0];

        let fn_ptr_temp = "%t" + number_to_string(result_temp);
        result_temp += 1;
        result_lines.push("  " + fn_ptr_temp + " = extractvalue " + closure_pair.llvm_type
            + " "
            + closure_pair.value
            + ", 0");

        let env_ptr_temp = "%t" + number_to_string(result_temp);
        result_temp += 1;
        result_lines.push("  " + env_ptr_temp + " = extractvalue "
            + closure_pair.llvm_type
            + " "
            + closure_pair.value
            + ", 1");

        let mut closure_fp_param_types: string[] = ["i8*"];
        let mut closure_arg_idx: int = 1;
        loop {
            if closure_arg_idx >= final_operands.length { break; }
            closure_fp_param_types.push(final_operands[closure_arg_idx].llvm_type);
            closure_arg_idx += 1;
        }
        let closure_fp_params = join_with_separator(closure_fp_param_types, ", ");
        let closure_function_type = llvm_return + " (" + closure_fp_params
            + ")*";

        let typed_fn_temp = "%t" + number_to_string(result_temp);
        result_temp += 1;
        result_lines.push("  " + typed_fn_temp + " = bitcast i8* " + fn_ptr_temp
            + " to "
            + closure_function_type);

        let mut closure_call_args: string[] = ["i8* " + env_ptr_temp];
        closure_arg_idx = 1;
        loop {
            if closure_arg_idx >= rendered_args.length { break; }
            closure_call_args.push(rendered_args[closure_arg_idx]);
            closure_arg_idx += 1;
        }
        let closure_arg_text = join_with_separator(closure_call_args, ", ");

        if llvm_return == "void" {
            result_lines.push("  call void " + typed_fn_temp + "("
                + closure_arg_text
                + ")");
            return ExpressionResult {
                lines: result_lines,
                temp_index: result_temp,
                operand: null,
                diagnostics: result_diagnostics,
                string_constants: collected_string_constants
            };
        }
        let closure_result_temp_name = format_temp_name(result_temp);
        result_lines.push("  " + closure_result_temp_name + " = call "
            + llvm_return
            + " "
            + typed_fn_temp
            + "("
            + closure_arg_text
            + ")");
        let closure_result_operand = LLVMOperand {
            llvm_type: llvm_return,
            value: closure_result_temp_name
        };
        return ExpressionResult {
            lines: result_lines,
            temp_index: result_temp + 1,
            operand: closure_result_operand,
            diagnostics: result_diagnostics,
            string_constants: collected_string_constants
        };
    }

    // Trait dispatch call
    if substring(trimmed_target, 0, 16) == "trait_dispatch__" {
        let after_prefix = substring(trimmed_target, 16, trimmed_target.length);
        // Find the last "__" separator to split interface name from method name
        let mut _td_split: int = -1;
        let mut _td_i: int = 0;
        loop {
            if _td_i >= after_prefix.length { break; }
            if substring(after_prefix, _td_i, _td_i + 2) == "__" {
                _td_split = _td_i;
            }
            _td_i += 1;
        }
        if _td_split > 0 {
            let interface_name = substring(after_prefix, 0, _td_split);
            let method_name = substring(after_prefix, _td_split + 2, after_prefix.length);

            if final_operands.length > 0 {
                let trait_object = final_operands[0];

                let data_ptr_temp = "%t" + number_to_string(result_temp);
                result_temp += 1;
                result_lines.push("  " + data_ptr_temp + " = extractvalue "
                    + trait_object.llvm_type
                    + " "
                    + trait_object.value
                    + ", 0");

                let vtable_ptr_temp = "%t" + number_to_string(result_temp);
                result_temp += 1;
                result_lines.push("  " + vtable_ptr_temp + " = extractvalue "
                    + trait_object.llvm_type
                    + " "
                    + trait_object.value
                    + ", 1");

                let interface_info3 = find_interface_info_by_name(context, interface_name);
                if interface_info3 != null {
                    let mut method_index: int = -1;
                    let mut sig_idx: int = 0;
                    loop {
                        if sig_idx >= interface_info3.signatures.length {
                            break;
                        }
                        if interface_info3.signatures[sig_idx].name == method_name {
                            method_index = sig_idx;
                            break;
                        }
                        sig_idx += 1;
                    }

                    if method_index >= 0 {
                        let mut fp_param_types: string[] = ["i8*"];
                        let mut arg_idx: int = 1;
                        loop {
                            if arg_idx >= final_operands.length { break; }
                            fp_param_types.push(final_operands[arg_idx].llvm_type);
                            arg_idx += 1;
                        }
                        let fp_params = join_with_separator(fp_param_types, ", ");
                        let function_type = llvm_return + " (" + fp_params
                            + ")*";

                        let vtable_slots_temp = "%t" + number_to_string(result_temp);
                        result_temp += 1;
                        result_lines.push("  " + vtable_slots_temp
                            + " = bitcast i8* "
                            + vtable_ptr_temp
                            + " to i8**");

                        let slot_ptr_temp = "%t" + number_to_string(result_temp);
                        result_temp += 1;
                        result_lines.push("  " + slot_ptr_temp
                            + " = getelementptr i8*, i8** "
                            + vtable_slots_temp
                            + ", i64 "
                            + number_to_string(method_index));

                        let raw_ptr_temp = "%t" + number_to_string(result_temp);
                        result_temp += 1;
                        result_lines.push("  " + raw_ptr_temp
                            + " = load i8*, i8** "
                            + slot_ptr_temp);

                        let method_ptr_temp = "%t" + number_to_string(result_temp);
                        result_temp += 1;
                        result_lines.push("  " + method_ptr_temp
                            + " = bitcast i8* "
                            + raw_ptr_temp
                            + " to "
                            + function_type);

                        let mut call_args: string[] = ["i8* " + data_ptr_temp];
                        arg_idx = 1;
                        loop {
                            if arg_idx >= rendered_args.length { break; }
                            call_args.push(rendered_args[arg_idx]);
                            arg_idx += 1;
                        }
                        let call_arg_text = join_with_separator(call_args, ", ");

                        if llvm_return == "void" {
                            result_lines.push("  call void " + method_ptr_temp
                                + "("
                                + call_arg_text
                                + ")");
                            return ExpressionResult {
                                lines: result_lines,
                                temp_index: result_temp,
                                operand: null,
                                diagnostics: result_diagnostics,
                                string_constants: collected_string_constants
                            };
                        } else {
                            let result_temp_name = format_temp_name(result_temp);
                            result_lines.push("  " + result_temp_name
                                + " = call "
                                + llvm_return
                                + " "
                                + method_ptr_temp
                                + "("
                                + call_arg_text
                                + ")");
                            let result_operand = LLVMOperand {
                                llvm_type: llvm_return,
                                value: result_temp_name
                            };
                            return ExpressionResult {
                                lines: result_lines,
                                temp_index: result_temp + 1,
                                operand: result_operand,
                                diagnostics: result_diagnostics,
                                string_constants: collected_string_constants
                            };
                        }
                    } else {
                        result_diagnostics.push("llvm lowering: method `"
                            + method_name
                            + "` not found in interface `"
                            + interface_name
                            + "`");
                    }
                } else {
                    result_diagnostics.push("llvm lowering: interface `"
                        + interface_name
                        + "` not found for trait dispatch");
                }
            } else {
                result_diagnostics.push("llvm lowering: trait dispatch requires at least one argument (the trait object)");
            }
        } else {
            result_diagnostics.push("llvm lowering: malformed trait dispatch target `"
                + trimmed_target
                + "`");
        }
    }

    // errno-location sentinel (#877, epic #763): emit a `call` to the
    // host's concrete locator symbol — `@__errno_location` on Linux/glibc,
    // `@__error` on Darwin/macOS — chosen at emit time. The same compiler
    // source thus links on both platforms when built natively (the IR is
    // target-neutral; the host clang resolves the symbol). The result is an
    // `i32*` that feeds straight into `sailfin_intrinsic_pointer_read_i32`.
    // The concrete symbol's `declare` is emitted via its registry descriptor
    // when the post-lowering call-target scan sees this call line.
    if helper_descriptor != null {
        if helper_descriptor.symbol == "sailfin_intrinsic_errno_location" {
            let _en_symbol = errno_locator_symbol();
            let _en_tmp = format_temp_name(result_temp);
            result_lines.push("  " + _en_tmp + " = call i32* @" + _en_symbol
                + "()");
            result_temp = result_temp + 1;
            let _en_operand = LLVMOperand {
                llvm_type: "i32*",
                value: _en_tmp
            };
            return ExpressionResult {
                lines: result_lines,
                temp_index: result_temp,
                operand: _en_operand,
                diagnostics: result_diagnostics,
                string_constants: collected_string_constants
            };
        }
    }

    // clock-monotonic clk_id sentinel (#908, epic #763): lower to a bare
    // `i32` immediate — `1` on Linux/glibc, `6` on Darwin/macOS — chosen
    // at emit time via `clock_monotonic_id_value`. Unlike the errno
    // sentinel (a `call`) and the pointer-read sentinel (a `load`), this
    // is a pure inline constant: no line is pushed and `temp_index` is
    // unchanged, so the value flows straight into the consuming call
    // (e.g. `clock_gettime(i32 1, …)`). No symbol is emitted, so the
    // declare loop in `rendering.sfn` has nothing to declare.
    if helper_descriptor != null {
        if helper_descriptor.symbol == "sailfin_intrinsic_clock_monotonic_id" {
            let _cm_operand = LLVMOperand {
                llvm_type: "i32",
                value: number_to_string(clock_monotonic_id_value())
            };
            return ExpressionResult {
                lines: result_lines,
                temp_index: result_temp,
                operand: _cm_operand,
                diagnostics: result_diagnostics,
                string_constants: collected_string_constants
            };
        }
    }

    // `_SC_NPROCESSORS_ONLN` request-number sentinel (#1480, epic #763):
    // lower to a bare `i32` immediate — `84` on Linux/glibc, `58` on
    // Darwin/macOS — chosen at emit time via `sc_nprocessors_onln_value`.
    // Like the clk_id sentinel above (and unlike the errno `call` and the
    // pointer-read `load`), this is a pure inline constant: no line is
    // pushed and `temp_index` is unchanged, so the value flows straight
    // into the consuming `sysconf` call. No symbol is emitted, so the
    // declare loop in `rendering.sfn` has nothing to declare.
    if helper_descriptor != null {
        if helper_descriptor.symbol == "sailfin_intrinsic_sc_nprocessors_onln" {
            let _np_operand = LLVMOperand {
                llvm_type: "i32",
                value: number_to_string(sc_nprocessors_onln_value())
            };
            return ExpressionResult {
                lines: result_lines,
                temp_index: result_temp,
                operand: _np_operand,
                diagnostics: result_diagnostics,
                string_constants: collected_string_constants
            };
        }
    }

    // executable-path sentinel (#967, epic #390): lower to a per-target
    // emission *sequence* (not a symbol swap) chosen at emit time via
    // `exe_path_locator`. Only the host's leg is emitted, so only one of
    // `readlink` (Linux), `_NSGetExecutablePath`+`strlen` (Darwin), or
    // `GetModuleFileNameA` (Windows) ever appears in the IR — the same
    // cross-platform link guarantee the errno sentinel provides. The uniform
    // sentinel signature is the Linux shape `(i8* buf, i64 size) -> i64`
    // (byte count written, -1 on failure); the Darwin/Windows legs normalize
    // their differing primitives to it. `final_operands[0]` is `buf` (`i8*`),
    // `final_operands[1]` is `size` (`i64`). The concrete symbol's `declare`
    // is emitted via its registry descriptor when the post-lowering
    // call-target scan sees the emitted call line.
    if helper_descriptor != null {
        if helper_descriptor.symbol == "sailfin_intrinsic_exe_path" {
            if final_operands.length < 2 {
                result_diagnostics.push("llvm lowering: sailfin_intrinsic_exe_path requires (buf: i8*, size: i64) operands");
            } else {
                let _ep_leg = exe_path_locator();
                let _ep_buf = final_operands[0].value;
                let _ep_size = final_operands[1].value;
                let mut _ep_constants = collected_string_constants;
                if _ep_leg == "darwin" {
                    // _NSGetExecutablePath(i8* buf, i32* size_inout); rc==0 ok.
                    // `strlen` is computed ONLY on the success path — on
                    // failure `buf` contents are unspecified, so scanning it
                    // would read undefined memory.
                    let _ep_id = number_to_string(result_temp);
                    let _ep_slot = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _ep_sz32 = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _ep_rc = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _ep_ok = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _ep_len = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _ep_out = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _ep_ok_lbl = "exe_path_ok_" + _ep_id;
                    let _ep_fail_lbl = "exe_path_fail_" + _ep_id;
                    let _ep_done_lbl = "exe_path_done_" + _ep_id;
                    result_lines.push("  " + _ep_slot + " = alloca i32");
                    result_lines.push("  " + _ep_sz32 + " = trunc i64 "
                        + _ep_size
                        + " to i32");
                    result_lines.push("  store i32 " + _ep_sz32 + ", i32* "
                        + _ep_slot);
                    result_lines.push("  " + _ep_rc
                        + " = call i32 @_NSGetExecutablePath(i8* "
                        + _ep_buf
                        + ", i32* "
                        + _ep_slot
                        + ")");
                    result_lines.push("  " + _ep_ok + " = icmp eq i32 " + _ep_rc
                        + ", 0");
                    result_lines.push("  br i1 " + _ep_ok + ", label %"
                        + _ep_ok_lbl
                        + ", label %"
                        + _ep_fail_lbl);
                    result_lines.push("");
                    result_lines.push(_ep_ok_lbl + ":");
                    result_lines.push("  " + _ep_len
                        + " = call i64 @strlen(i8* "
                        + _ep_buf
                        + ")");
                    result_lines.push("  br label %" + _ep_done_lbl);
                    result_lines.push("");
                    result_lines.push(_ep_fail_lbl + ":");
                    result_lines.push("  br label %" + _ep_done_lbl);
                    result_lines.push("");
                    result_lines.push(_ep_done_lbl + ":");
                    result_lines.push("  " + _ep_out + " = phi i64 [ " + _ep_len
                        + ", %"
                        + _ep_ok_lbl
                        + " ], [ -1, %"
                        + _ep_fail_lbl
                        + " ]");
                    let _ep_operand = LLVMOperand {
                        llvm_type: "i64",
                        value: _ep_out
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _ep_operand,
                        diagnostics: result_diagnostics,
                        string_constants: _ep_constants
                    };
                } else if _ep_leg == "mingw" {
                    // GetModuleFileNameA(NULL, buf, size); n==0 => failure.
                    let _ep_sz32 = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _ep_n = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _ep_fail = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _ep_n64 = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _ep_out = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _ep_sz32 + " = trunc i64 "
                        + _ep_size
                        + " to i32");
                    result_lines.push("  " + _ep_n
                        + " = call i32 @GetModuleFileNameA(i8* null, i8* "
                        + _ep_buf
                        + ", i32 "
                        + _ep_sz32
                        + ")");
                    result_lines.push("  " + _ep_fail + " = icmp eq i32 "
                        + _ep_n
                        + ", 0");
                    result_lines.push("  " + _ep_n64 + " = sext i32 " + _ep_n
                        + " to i64");
                    result_lines.push("  " + _ep_out + " = select i1 "
                        + _ep_fail
                        + ", i64 -1, i64 "
                        + _ep_n64);
                    let _ep_operand = LLVMOperand {
                        llvm_type: "i64",
                        value: _ep_out
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _ep_operand,
                        diagnostics: result_diagnostics,
                        string_constants: _ep_constants
                    };
                } else {
                    // Linux (default): readlink("/proc/self/exe", buf, size).
                    // Intern the `/proc/self/exe` literal as a private global
                    // and pass its `i8*` as the first arg, keeping the
                    // sentinel signature uniform (2-arg) across targets. Build
                    // the `@.`-prefixed name in two parts so the selfhost
                    // text scan never sees the full global name as one literal
                    // (same guard as `lower_dynamic_member_access`).
                    let _ep_name = "@.str" + ".exe_path_proc_self_exe";
                    let _ep_content = "/proc/self/exe";
                    let mut _ep_const = StringConstant {
                        name: _ep_name,
                        content: _ep_content,
                        byte_count: _ep_content.length
                    };
                    let _ep_existing = find_string_constant_by_name(_ep_constants, _ep_name);
                    if _ep_existing != null { _ep_const = _ep_existing; } else {
                        _ep_constants = append_string_constant(_ep_constants, _ep_const);
                    }
                    let _ep_arr = "[" + number_to_string(_ep_const.byte_count
                        + 1)
                        + " x i8]";
                    let _ep_ptr = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _ep_ptr
                        + " = getelementptr inbounds "
                        + _ep_arr
                        + ", "
                        + _ep_arr
                        + "* "
                        + _ep_name
                        + ", i32 0, i32 0");
                    let _ep_n = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _ep_n
                        + " = call i64 @readlink(i8* "
                        + _ep_ptr
                        + ", i8* "
                        + _ep_buf
                        + ", i64 "
                        + _ep_size
                        + ")");
                    let _ep_operand = LLVMOperand {
                        llvm_type: "i64",
                        value: _ep_n
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _ep_operand,
                        diagnostics: result_diagnostics,
                        string_constants: _ep_constants
                    };
                }
            }
        }
    }

    // Filesystem sentinels (#1308): retire the last platform-divergent C fs
    // symbols by lowering each to a per-target sequence (modeled on
    // `exe_path` above), choosing the host leg via `fs_platform_leg`. Only
    // the host leg's symbol enters the IR, so the Windows cross-build never
    // references a POSIX-only `symlink`/`mkdtemp` it has no symbol for.
    if helper_descriptor != null {
        if helper_descriptor.symbol == "sailfin_intrinsic_fs_symlink" {
            if final_operands.length < 2 {
                result_diagnostics.push("llvm lowering: sailfin_intrinsic_fs_symlink requires (target: i8*, link: i8*) operands");
            } else {
                let _fs_leg = fs_platform_leg();
                if _fs_leg == "mingw" {
                    // Windows stub: no `symlink` symbol in the IR; always fail.
                    let _fs_stub = LLVMOperand {
                        llvm_type: "i1",
                        value: "false"
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _fs_stub,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                } else {
                    // POSIX (linux/darwin): symlink(target, link) == 0 => true.
                    let _fs_target = final_operands[0].value;
                    let _fs_link = final_operands[1].value;
                    let _fs_rc = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_ok = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _fs_rc
                        + " = call i32 @symlink(i8* "
                        + _fs_target
                        + ", i8* "
                        + _fs_link
                        + ")");
                    result_lines.push("  " + _fs_ok + " = icmp eq i32 " + _fs_rc
                        + ", 0");
                    let _fs_operand = LLVMOperand {
                        llvm_type: "i1",
                        value: _fs_ok
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _fs_operand,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                }
            }
        }
    }

    // `read_link(path, buf, size) -> i64` sentinel (SFN-46): the single-hop
    // `readlink(2)` byte count. POSIX legs emit `call i64 @readlink(...)`;
    // the Windows leg is a bare `i64 -1` stub so the MinGW-absent `readlink`
    // symbol never enters the IR. The caller (`sfn_fs_read_link`) owns the
    // buffer and turns a `<= 0` return into `""`.
    if helper_descriptor != null {
        if helper_descriptor.symbol == "sailfin_intrinsic_fs_read_link" {
            if final_operands.length < 3 {
                result_diagnostics.push("llvm lowering: sailfin_intrinsic_fs_read_link requires (path: i8*, buf: i8*, size: i64) operands");
            } else {
                let _fs_leg = fs_platform_leg();
                if _fs_leg == "mingw" {
                    // Windows stub: no `readlink` symbol in the IR; always fail.
                    let _fs_stub = LLVMOperand {
                        llvm_type: "i64",
                        value: "-1"
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _fs_stub,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                } else {
                    // POSIX (linux/darwin): readlink(path, buf, size).
                    let _fs_path = final_operands[0].value;
                    let _fs_buf = final_operands[1].value;
                    let _fs_size = final_operands[2].value;
                    let _fs_n = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _fs_n
                        + " = call i64 @readlink(i8* "
                        + _fs_path
                        + ", i8* "
                        + _fs_buf
                        + ", i64 "
                        + _fs_size
                        + ")");
                    let _fs_operand = LLVMOperand {
                        llvm_type: "i64",
                        value: _fs_n
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _fs_operand,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                }
            }
        }
    }

    // `mkdtemp(template) -> bool` sentinel (#1308): POSIX legs call
    // `mkdtemp(3)` (returns the mutated template buffer or NULL); the
    // Windows leg is a bare `false` stub so the MinGW-absent symbol never
    // enters the IR.
    if helper_descriptor != null {
        if helper_descriptor.symbol == "sailfin_intrinsic_fs_mkdtemp" {
            if final_operands.length < 1 {
                result_diagnostics.push("llvm lowering: sailfin_intrinsic_fs_mkdtemp requires (template: i8*) operand");
            } else {
                let _fs_leg = fs_platform_leg();
                if _fs_leg == "mingw" {
                    let _fs_stub = LLVMOperand {
                        llvm_type: "i1",
                        value: "false"
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _fs_stub,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                } else {
                    let _fs_tmpl = final_operands[0].value;
                    let _fs_rc = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_ok = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _fs_rc
                        + " = call i8* @mkdtemp(i8* "
                        + _fs_tmpl
                        + ")");
                    result_lines.push("  " + _fs_ok + " = icmp ne i8* " + _fs_rc
                        + ", null");
                    let _fs_operand = LLVMOperand {
                        llvm_type: "i1",
                        value: _fs_ok
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _fs_operand,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                }
            }
        }
    }

    // `fs_exists(path) -> bool` sentinel (#1308): POSIX legs `stat(path,
    // &buf) == 0` over a stack `struct stat` buffer (over-allocated via
    // `stat_buf_size_value`); the Windows leg `GetFileAttributesA(path) !=
    // -1` (INVALID_FILE_ATTRIBUTES). Only the host leg's symbol enters the IR.
    if helper_descriptor != null {
        if helper_descriptor.symbol == "sailfin_intrinsic_fs_exists" {
            if final_operands.length < 1 {
                result_diagnostics.push("llvm lowering: sailfin_intrinsic_fs_exists requires (path: i8*) operand");
            } else {
                let _fs_leg = fs_platform_leg();
                let _fs_path = final_operands[0].value;
                if _fs_leg == "mingw" {
                    let _fs_attr = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_ok = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _fs_attr
                        + " = call i32 @GetFileAttributesA(i8* "
                        + _fs_path
                        + ")");
                    result_lines.push("  " + _fs_ok + " = icmp ne i32 "
                        + _fs_attr
                        + ", -1");
                    let _fs_operand = LLVMOperand {
                        llvm_type: "i1",
                        value: _fs_ok
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _fs_operand,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                } else {
                    let _fs_bufsz = number_to_string(stat_buf_size_value());
                    let _fs_buf = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_bufp = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_rc = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_ok = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _fs_buf + " = alloca [" + _fs_bufsz
                        + " x i8]");
                    result_lines.push("  " + _fs_bufp + " = getelementptr ["
                        + _fs_bufsz
                        + " x i8], ["
                        + _fs_bufsz
                        + " x i8]* "
                        + _fs_buf
                        + ", i32 0, i32 0");
                    result_lines.push("  " + _fs_rc + " = call i32 @stat(i8* "
                        + _fs_path
                        + ", i8* "
                        + _fs_bufp
                        + ")");
                    result_lines.push("  " + _fs_ok + " = icmp eq i32 " + _fs_rc
                        + ", 0");
                    let _fs_operand = LLVMOperand {
                        llvm_type: "i1",
                        value: _fs_ok
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _fs_operand,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                }
            }
        }
    }

    // `get_perms(path) -> i64` sentinel (#1308): POSIX legs `stat` the path,
    // and on success load `st_mode` at the per-target byte offset
    // (`stat_st_mode_offset_value`), mask the low 12 bits (`& 0o7777`), and
    // zext to i64; a `stat` failure yields -1 via a phi. The Windows leg is
    // a bare `i64 -1` stub. The stat buffer is `align 8` (struct stat's
    // alignment) so the `st_mode` load is naturally aligned.
    if helper_descriptor != null {
        if helper_descriptor.symbol == "sailfin_intrinsic_fs_get_perms" {
            if final_operands.length < 1 {
                result_diagnostics.push("llvm lowering: sailfin_intrinsic_fs_get_perms requires (path: i8*) operand");
            } else {
                let _fs_leg = fs_platform_leg();
                if _fs_leg == "mingw" {
                    let _fs_stub = LLVMOperand {
                        llvm_type: "i64",
                        value: "-1"
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _fs_stub,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                } else {
                    let _fs_path = final_operands[0].value;
                    let _fs_id = number_to_string(result_temp);
                    let _fs_bufsz = number_to_string(stat_buf_size_value());
                    let _fs_off = number_to_string(stat_st_mode_offset_value());
                    let _fs_buf = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_bufp = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_rc = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_okc = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_modep = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_modepi = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_mode = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_masked = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_mode64 = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_out = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _fs_ok_lbl = "get_perms_ok_" + _fs_id;
                    let _fs_fail_lbl = "get_perms_fail_" + _fs_id;
                    let _fs_done_lbl = "get_perms_done_" + _fs_id;
                    result_lines.push("  " + _fs_buf + " = alloca [" + _fs_bufsz
                        + " x i8], align 8");
                    result_lines.push("  " + _fs_bufp + " = getelementptr ["
                        + _fs_bufsz
                        + " x i8], ["
                        + _fs_bufsz
                        + " x i8]* "
                        + _fs_buf
                        + ", i32 0, i32 0");
                    result_lines.push("  " + _fs_rc + " = call i32 @stat(i8* "
                        + _fs_path
                        + ", i8* "
                        + _fs_bufp
                        + ")");
                    result_lines.push("  " + _fs_okc + " = icmp eq i32 "
                        + _fs_rc
                        + ", 0");
                    result_lines.push("  br i1 " + _fs_okc + ", label %"
                        + _fs_ok_lbl
                        + ", label %"
                        + _fs_fail_lbl);
                    result_lines.push("");
                    result_lines.push(_fs_ok_lbl + ":");
                    result_lines.push("  " + _fs_modep
                        + " = getelementptr i8, i8* "
                        + _fs_bufp
                        + ", i64 "
                        + _fs_off);
                    result_lines.push("  " + _fs_modepi + " = bitcast i8* "
                        + _fs_modep
                        + " to i32*");
                    result_lines.push("  " + _fs_mode + " = load i32, i32* "
                        + _fs_modepi);
                    result_lines.push("  " + _fs_masked + " = and i32 "
                        + _fs_mode
                        + ", 4095");
                    result_lines.push("  " + _fs_mode64 + " = zext i32 "
                        + _fs_masked
                        + " to i64");
                    result_lines.push("  br label %" + _fs_done_lbl);
                    result_lines.push("");
                    result_lines.push(_fs_fail_lbl + ":");
                    result_lines.push("  br label %" + _fs_done_lbl);
                    result_lines.push("");
                    result_lines.push(_fs_done_lbl + ":");
                    result_lines.push("  " + _fs_out + " = phi i64 [ "
                        + _fs_mode64
                        + ", %"
                        + _fs_ok_lbl
                        + " ], [ -1, %"
                        + _fs_fail_lbl
                        + " ]");
                    let _fs_operand = LLVMOperand {
                        llvm_type: "i64",
                        value: _fs_out
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _fs_operand,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                }
            }
        }
    }

    // `list_dir(path) -> i8*` sentinel (SFN-51, epic #1485,
    // `docs/proposals/0021-windows-native-selfhost.md` §4.2(B)): enumerate a
    // directory into a sorted `SfnArray` (`{ i8**, i64, i64 }*`, spelled i8*)
    // that omits `.`/`..`. The POSIX leg walks `opendir`/`readdir`/`closedir`
    // and reads each entry name at `dirent + _fs_dirent_dname_offset()` — the
    // exact loop `sfn_fs_list_dir`'s body previously emitted, now behind the
    // sentinel so the libc `opendir` family is never *called* on native
    // Windows (where those POSIX symbols do not link). The Windows leg walks
    // `FindFirstFileA`/`FindNextFileA`/`FindClose`, reading `cFileName` at
    // `WIN32_FIND_DATAA` byte offset 44. Both legs delegate the portable
    // per-entry work — dot filter, name dup, array new/append — to the
    // module's bare `_fs_*` helpers (`_fs_name_is_dot`, `_fs_dup_cstr`,
    // `_fs_new_str_array`, `_fs_append_str`), which link on every target and
    // keep the volatile `@sailfin_runtime_*` array symbols out of the lowering
    // (#727 emission audit); the wrapper sorts the result. The loop-carried
    // accumulator lives in a single
    // `alloca i8*` cell with a back-edge (no hand-authored phi) so the emitted
    // SSA is trivially dominated. Only the host leg's directory-iteration
    // symbols enter the IR — the point of the sentinel.
    if helper_descriptor != null {
        if helper_descriptor.symbol == "sailfin_intrinsic_fs_list_dir" {
            if final_operands.length < 1 {
                result_diagnostics.push("llvm lowering: sailfin_intrinsic_fs_list_dir requires (path: i8*) operand");
            } else {
                let _ld_leg = fs_platform_leg();
                let _ld_path = final_operands[0].value;
                let _ld_id = number_to_string(result_temp);
                if _ld_leg == "mingw" {
                    let _w_empty = "fs_list_dir_empty_" + _ld_id;
                    let _w_init = "fs_list_dir_init_" + _ld_id;
                    let _w_body = "fs_list_dir_body_" + _ld_id;
                    let _w_keep = "fs_list_dir_keep_" + _ld_id;
                    let _w_app = "fs_list_dir_append_" + _ld_id;
                    let _w_adv = "fs_list_dir_advance_" + _ld_id;
                    let _w_close = "fs_list_dir_close_" + _ld_id;
                    let _w_done = "fs_list_dir_done_" + _ld_id;
                    // WIN32_FIND_DATAA buffer (over-allocated; the ANSI struct
                    // is ~320 bytes with `cFileName` at offset 44).
                    let _w_buf = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_bufp = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_plen = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_psz = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_pat = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_cp = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_pati = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_s0 = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_s0p = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_s1 = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_s1p = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_s2 = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_s2p = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_h = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_hi = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_hbad = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_slot = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _w_buf
                        + " = alloca [592 x i8], align 8");
                    result_lines.push("  " + _w_bufp
                        + " = getelementptr [592 x i8], [592 x i8]* "
                        + _w_buf
                        + ", i32 0, i32 0");
                    // Search pattern = path + "\\*" + NUL (92='\\', 42='*').
                    result_lines.push("  " + _w_plen
                        + " = call i64 @strlen(i8* "
                        + _ld_path
                        + ")");
                    result_lines.push("  " + _w_psz + " = add i64 " + _w_plen
                        + ", 3");
                    result_lines.push("  " + _w_pat + " = call i8* @malloc(i64 "
                        + _w_psz
                        + ")");
                    result_lines.push("  " + _w_cp + " = call i8* @memcpy(i8* "
                        + _w_pat
                        + ", i8* "
                        + _ld_path
                        + ", i64 "
                        + _w_plen
                        + ")");
                    result_lines.push("  " + _w_pati + " = ptrtoint i8* "
                        + _w_pat
                        + " to i64");
                    result_lines.push("  " + _w_s0 + " = add i64 " + _w_pati
                        + ", "
                        + _w_plen);
                    result_lines.push("  " + _w_s0p + " = inttoptr i64 " + _w_s0
                        + " to i8*");
                    result_lines.push("  store i8 92, i8* " + _w_s0p);
                    result_lines.push("  " + _w_s1 + " = add i64 " + _w_s0
                        + ", 1");
                    result_lines.push("  " + _w_s1p + " = inttoptr i64 " + _w_s1
                        + " to i8*");
                    result_lines.push("  store i8 42, i8* " + _w_s1p);
                    result_lines.push("  " + _w_s2 + " = add i64 " + _w_s0
                        + ", 2");
                    result_lines.push("  " + _w_s2p + " = inttoptr i64 " + _w_s2
                        + " to i8*");
                    result_lines.push("  store i8 0, i8* " + _w_s2p);
                    result_lines.push("  " + _w_h
                        + " = call i8* @FindFirstFileA(i8* "
                        + _w_pat
                        + ", i8* "
                        + _w_bufp
                        + ")");
                    result_lines.push("  call void @free(i8* " + _w_pat + ")");
                    // INVALID_HANDLE_VALUE == (HANDLE)-1.
                    result_lines.push("  " + _w_hi + " = ptrtoint i8* " + _w_h
                        + " to i64");
                    result_lines.push("  " + _w_hbad + " = icmp eq i64 " + _w_hi
                        + ", -1");
                    result_lines.push("  " + _w_slot + " = alloca i8*");
                    result_lines.push("  br i1 " + _w_hbad + ", label %"
                        + _w_empty
                        + ", label %"
                        + _w_init);
                    result_lines.push("");
                    result_lines.push(_w_empty + ":");
                    let _w_ae = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _w_ae
                        + " = call i8* @_fs_new_str_array()");
                    result_lines.push("  store i8* " + _w_ae + ", i8** "
                        + _w_slot);
                    result_lines.push("  br label %" + _w_done);
                    result_lines.push("");
                    result_lines.push(_w_init + ":");
                    let _w_a0 = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _w_a0
                        + " = call i8* @_fs_new_str_array()");
                    result_lines.push("  store i8* " + _w_a0 + ", i8** "
                        + _w_slot);
                    result_lines.push("  br label %" + _w_body);
                    result_lines.push("");
                    // FindFirstFileA already loaded the first entry; process the
                    // current buffer, then advance with FindNextFileA.
                    result_lines.push(_w_body + ":");
                    let _w_n = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_isdot = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _w_n + " = getelementptr i8, i8* "
                        + _w_bufp
                        + ", i64 44");
                    result_lines.push("  " + _w_isdot
                        + " = call i1 @_fs_name_is_dot(i8* "
                        + _w_n
                        + ")");
                    result_lines.push("  br i1 " + _w_isdot + ", label %"
                        + _w_adv
                        + ", label %"
                        + _w_keep);
                    result_lines.push("");
                    result_lines.push(_w_keep + ":");
                    let _w_c = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_ci = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_cn = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _w_c
                        + " = call i8* @_fs_dup_cstr(i8* "
                        + _w_n
                        + ")");
                    result_lines.push("  " + _w_ci + " = ptrtoint i8* " + _w_c
                        + " to i64");
                    result_lines.push("  " + _w_cn + " = icmp eq i64 " + _w_ci
                        + ", 0");
                    result_lines.push("  br i1 " + _w_cn + ", label %" + _w_adv
                        + ", label %"
                        + _w_app);
                    result_lines.push("");
                    result_lines.push(_w_app + ":");
                    let _w_cur = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_nx = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _w_cur + " = load i8*, i8** "
                        + _w_slot);
                    result_lines.push("  " + _w_nx
                        + " = call i8* @_fs_append_str(i8* "
                        + _w_cur
                        + ", i8* "
                        + _w_c
                        + ")");
                    result_lines.push("  store i8* " + _w_nx + ", i8** "
                        + _w_slot);
                    result_lines.push("  br label %" + _w_adv);
                    result_lines.push("");
                    result_lines.push(_w_adv + ":");
                    let _w_more = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _w_morenz = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _w_more
                        + " = call i32 @FindNextFileA(i8* "
                        + _w_h
                        + ", i8* "
                        + _w_bufp
                        + ")");
                    result_lines.push("  " + _w_morenz + " = icmp ne i32 "
                        + _w_more
                        + ", 0");
                    result_lines.push("  br i1 " + _w_morenz + ", label %"
                        + _w_body
                        + ", label %"
                        + _w_close);
                    result_lines.push("");
                    result_lines.push(_w_close + ":");
                    let _w_fc = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _w_fc
                        + " = call i32 @FindClose(i8* "
                        + _w_h
                        + ")");
                    result_lines.push("  br label %" + _w_done);
                    result_lines.push("");
                    result_lines.push(_w_done + ":");
                    let _w_res = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _w_res + " = load i8*, i8** "
                        + _w_slot);
                    let _w_operand = LLVMOperand {
                        llvm_type: "i8*",
                        value: _w_res
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _w_operand,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                } else {
                    let _p_empty = "fs_list_dir_empty_" + _ld_id;
                    let _p_init = "fs_list_dir_init_" + _ld_id;
                    let _p_loop = "fs_list_dir_loop_" + _ld_id;
                    let _p_body = "fs_list_dir_body_" + _ld_id;
                    let _p_keep = "fs_list_dir_keep_" + _ld_id;
                    let _p_app = "fs_list_dir_append_" + _ld_id;
                    let _p_close = "fs_list_dir_close_" + _ld_id;
                    let _p_done = "fs_list_dir_done_" + _ld_id;
                    let _p_dir = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_diri = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_bad = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_slot = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _p_dir
                        + " = call i8* @opendir(i8* "
                        + _ld_path
                        + ")");
                    result_lines.push("  " + _p_diri + " = ptrtoint i8* "
                        + _p_dir
                        + " to i64");
                    result_lines.push("  " + _p_bad + " = icmp eq i64 "
                        + _p_diri
                        + ", 0");
                    result_lines.push("  " + _p_slot + " = alloca i8*");
                    result_lines.push("  br i1 " + _p_bad + ", label %"
                        + _p_empty
                        + ", label %"
                        + _p_init);
                    result_lines.push("");
                    result_lines.push(_p_empty + ":");
                    let _p_ae = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _p_ae
                        + " = call i8* @_fs_new_str_array()");
                    result_lines.push("  store i8* " + _p_ae + ", i8** "
                        + _p_slot);
                    result_lines.push("  br label %" + _p_done);
                    result_lines.push("");
                    result_lines.push(_p_init + ":");
                    let _p_off = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_a0 = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _p_off
                        + " = call i64 @_fs_dirent_dname_offset()");
                    result_lines.push("  " + _p_a0
                        + " = call i8* @_fs_new_str_array()");
                    result_lines.push("  store i8* " + _p_a0 + ", i8** "
                        + _p_slot);
                    result_lines.push("  br label %" + _p_loop);
                    result_lines.push("");
                    result_lines.push(_p_loop + ":");
                    let _p_e = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_ei = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_en = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _p_e + " = call i8* @readdir(i8* "
                        + _p_dir
                        + ")");
                    result_lines.push("  " + _p_ei + " = ptrtoint i8* " + _p_e
                        + " to i64");
                    result_lines.push("  " + _p_en + " = icmp eq i64 " + _p_ei
                        + ", 0");
                    result_lines.push("  br i1 " + _p_en + ", label %"
                        + _p_close
                        + ", label %"
                        + _p_body);
                    result_lines.push("");
                    result_lines.push(_p_body + ":");
                    let _p_ni = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_n = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_isdot = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _p_ni + " = add i64 " + _p_ei
                        + ", "
                        + _p_off);
                    result_lines.push("  " + _p_n + " = inttoptr i64 " + _p_ni
                        + " to i8*");
                    result_lines.push("  " + _p_isdot
                        + " = call i1 @_fs_name_is_dot(i8* "
                        + _p_n
                        + ")");
                    result_lines.push("  br i1 " + _p_isdot + ", label %"
                        + _p_loop
                        + ", label %"
                        + _p_keep);
                    result_lines.push("");
                    result_lines.push(_p_keep + ":");
                    let _p_c = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_ci = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_cn = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _p_c
                        + " = call i8* @_fs_dup_cstr(i8* "
                        + _p_n
                        + ")");
                    result_lines.push("  " + _p_ci + " = ptrtoint i8* " + _p_c
                        + " to i64");
                    result_lines.push("  " + _p_cn + " = icmp eq i64 " + _p_ci
                        + ", 0");
                    result_lines.push("  br i1 " + _p_cn + ", label %" + _p_loop
                        + ", label %"
                        + _p_app);
                    result_lines.push("");
                    result_lines.push(_p_app + ":");
                    let _p_cur = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    let _p_nx = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _p_cur + " = load i8*, i8** "
                        + _p_slot);
                    result_lines.push("  " + _p_nx
                        + " = call i8* @_fs_append_str(i8* "
                        + _p_cur
                        + ", i8* "
                        + _p_c
                        + ")");
                    result_lines.push("  store i8* " + _p_nx + ", i8** "
                        + _p_slot);
                    result_lines.push("  br label %" + _p_loop);
                    result_lines.push("");
                    result_lines.push(_p_close + ":");
                    let _p_rc = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _p_rc
                        + " = call i32 @closedir(i8* "
                        + _p_dir
                        + ")");
                    result_lines.push("  br label %" + _p_done);
                    result_lines.push("");
                    result_lines.push(_p_done + ":");
                    let _p_res = format_temp_name(result_temp);
                    result_temp = result_temp + 1;
                    result_lines.push("  " + _p_res + " = load i8*, i8** "
                        + _p_slot);
                    let _p_operand = LLVMOperand {
                        llvm_type: "i8*",
                        value: _p_res
                    };
                    return ExpressionResult {
                        lines: result_lines,
                        temp_index: result_temp,
                        operand: _p_operand,
                        diagnostics: result_diagnostics,
                        string_constants: collected_string_constants
                    };
                }
            }
        }
    }

    // Pointer-read intrinsics (#875, epic #763): lower directly to an LLVM
    // `load` of the descriptor's width instead of a `call`. The load element
    // type is driven by `return_type` ("i32"/"i64"/"double"), not by parsing
    // the operand's pointee. An `i8*` (or otherwise mismatched) operand gets a
    // leading `bitcast` to the matching pointer type; an already-typed
    // `i32*`/`i64*`/`double*` operand loads directly with no redundant bitcast.
    if helper_descriptor != null {
        let _pr_symbol = helper_descriptor.symbol;
        if _pr_symbol == "sailfin_intrinsic_pointer_read_i32" || _pr_symbol == "sailfin_intrinsic_pointer_read_i64"
            || _pr_symbol == "sailfin_intrinsic_pointer_read_f64" {
            if final_operands.length < 1 {
                result_diagnostics.push("llvm lowering: " + _pr_symbol
                    + " requires one pointer operand");
            } else {
                let _pr_elem = helper_descriptor.return_type;
                let _pr_ptr_type = _pr_elem + "*";
                let _pr_src = final_operands[0];
                let mut _pr_ptr_value = _pr_src.value;
                if _pr_src.llvm_type != _pr_ptr_type {
                    let _pr_cast = format_temp_name(result_temp);
                    result_lines.push("  " + _pr_cast + " = bitcast " + _pr_src.llvm_type
                        + " "
                        + _pr_src.value
                        + " to "
                        + _pr_ptr_type);
                    _pr_ptr_value = _pr_cast;
                    result_temp = result_temp + 1;
                }
                let _pr_loaded = format_temp_name(result_temp);
                result_lines.push("  " + _pr_loaded + " = load " + _pr_elem
                    + ", "
                    + _pr_ptr_type
                    + " "
                    + _pr_ptr_value);
                result_temp = result_temp + 1;
                let _pr_operand = LLVMOperand {
                    llvm_type: _pr_elem,
                    value: _pr_loaded
                };
                return ExpressionResult {
                    lines: result_lines,
                    temp_index: result_temp,
                    operand: _pr_operand,
                    diagnostics: result_diagnostics,
                    string_constants: collected_string_constants
                };
            }
        }
    }

    // Standard function call
    if _trace_ccl {
        print.err("call_lowering: checkpoint-F call_symbol target="
            + trimmed_target);
    }
    let mut call_symbol = sanitize_symbol(trimmed_target);
    if helper_descriptor != null {
        // M2 helper migration: when `native_signature` is set, the helper
        // has been flipped from the C ABI (`sailfin_runtime_*`) to its
        // Sailfin-native counterpart (`sfn_*`). Prefer it over the C
        // symbol so individual helpers can migrate without rewriting
        // their `parameter_types` / `return_type`. See issue #392.
        let mut _native_sig: string? = helper_descriptor.native_signature;
        let mut _have_native: boolean = false;
        if _native_sig != null {
            if _native_sig.length > 0 { _have_native = true; }
        }
        if _have_native { call_symbol = _native_sig; } else {
            call_symbol = helper_descriptor.symbol;
        }
    }
    // When concat resolves with no helper_descriptor (common for method
    // dispatch paths that set helper_descriptor: null), fall back to the
    // canonical runtime symbol so we don't emit a bare @concat.
    if trimmed_target == "concat" {
        if call_symbol == "concat" { call_symbol = "sailfin_runtime_concat"; }
    }
    if _trace_ccl {
        print.err("call_lowering: checkpoint-G llvm_return=" + llvm_return
            + " call_symbol="
            + call_symbol);
    }
    if llvm_return == "void" {
        let call_line = "  call void @" + call_symbol + "(" + argument_text
            + ")";
        result_lines.push(call_line);
        if _trace_ccl {
            print.err("call_lowering: checkpoint-H void return");
        }
        return ExpressionResult {
            lines: result_lines,
            temp_index: result_temp,
            operand: null,
            diagnostics: result_diagnostics,
            string_constants: collected_string_constants
        };
    }

    let temp_name = format_temp_name(result_temp);
    if _trace_ccl {
        print.err("call_lowering: checkpoint-I temp_name=" + temp_name);
    }
    // Issue #639: honor the descriptor's `c_abi_return_type` when it
    // differs from the caller-visible `return_type`. This mirrors the
    // mechanism `emit_runtime_call` already implements (#638), but is
    // also needed here because user-written calls to helpers like
    // `monotonic_millis()` flow through this legacy path rather than
    // `emit_runtime_call`. Without this, a registry entry with
    // `return_type: "i64", c_abi_return_type: "double"` would emit
    // `call i64 @sym(...)` against a `double`-returning C function —
    // the exact register-class mismatch (%rax vs %xmm0) that
    // crashed PR #637.
    let mut abi_return_type: string = llvm_return;
    if helper_descriptor != null {
        let mut abi: string? = helper_descriptor.c_abi_return_type;
        if abi != null {
            if abi.length > 0 { abi_return_type = abi; }
        }
    }
    let call_line = "  " + temp_name + " = call " + abi_return_type + " @"
        + call_symbol
        + "("
        + argument_text
        + ")";
    result_lines.push(call_line);
    let mut result_operand: LLVMOperand = LLVMOperand {
        llvm_type: abi_return_type,
        value: temp_name
    };
    let mut next_temp: int = result_temp + 1;
    if abi_return_type != llvm_return {
        let coercion = coerce_operand_to_type(result_operand, llvm_return, next_temp, result_lines, true, null);
        result_diagnostics = extend_string_array(result_diagnostics, coercion.diagnostics);
        result_lines = coercion.lines;
        next_temp = coercion.temp_index;
        if coercion.operand != null { result_operand = coercion.operand; }
    }
    if _trace_ccl { print.err("call_lowering: checkpoint-K returning"); }
    return ExpressionResult {
        lines: result_lines,
        temp_index: next_temp,
        operand: result_operand,
        diagnostics: result_diagnostics,
        string_constants: collected_string_constants
    };
}

export { coerce_and_emit_call };
