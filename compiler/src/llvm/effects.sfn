// compiler/src/llvm/effects.sfn
//
// Effect system analysis for LLVM lowering. Collects and propagates effects
// through the function call graph to build capability manifests.

import { NativeFunction, NativeInstruction } from "../native_ir";
import { substring, char_at } from "../string_utils";
import { FunctionEffectEntry, FunctionCallEntry, CapabilityManifest, CapabilityManifestEntry, RuntimeHelperDescriptor } from "./types";
import {
    trim_text,
    append_string,
    copy_string_array,
    string_array_contains,
    string_arrays_equal,
    number_to_string,
    is_identifier_start_char,
    is_identifier_part_char,
    is_trim_char,
    is_effect_prefix_char,
    is_effect_delimiter,
    index_of,
    find_last_index_of_char,
    matches_case_insensitive,
    matches_keyword,
    skip_string_literal
} from "./utils";
import { find_runtime_helper } from "./runtime_helpers";

// =============================================================================
// Effect Collection
// =============================================================================

fn collect_direct_function_effects(functions -> NativeFunction[]) -> FunctionEffectEntry[] {
    let mut entries -> FunctionEffectEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= functions.length {
            break;
        }
        let fun = functions[index];
        if fun != null {
            let entry = collect_function_effect_entry(fun);
            entries = append_function_effect_entry(entries, entry);
        }
        index += 1;
    }
    return entries;
}

fn collect_function_effect_entry(function -> NativeFunction) -> FunctionEffectEntry {
    let mut combined -> string[] = [];
    if function == null {
        return FunctionEffectEntry { name: "", effects: combined };
    }
    // Inline field access to avoid stage2 lowering issue
    combined = merge_effect_lists(combined, function.effects);
    // Inline to avoid lowering issues
    combined = merge_effect_lists(combined, collect_function_borrow_effects(function));
    return FunctionEffectEntry { name: function.name, effects: combined };
}

fn append_function_effect_entry(values -> FunctionEffectEntry[], entry -> FunctionEffectEntry) -> FunctionEffectEntry[] {
    values.push(entry);
    return values;
}

fn merge_effect_lists(base -> string[], extras -> string[]) -> string[] {
    if base == null && extras == null {
        return [];
    }
    if base == null {
        return copy_string_array(extras);
    }
    if extras == null {
        return copy_string_array(base);
    }
    let mut result -> string[] = [];

    // Copy existing effects first so we preserve order before appending extras.
    let mut index -> number = 0;
    loop {
        if index >= base.length {
            break;
        }
        result = append_unique_effect(result, base[index]);
        index += 1;
    }

    index = 0;
    loop {
        if index >= extras.length {
            break;
        }
        result = append_unique_effect(result, extras[index]);
        index += 1;
    }

    return result;
}

fn append_unique_effect(effects -> string[], effect -> string) -> string[] {
    if effect == null {
        return effects;
    }
    if effect.length == 0 {
        return effects;
    }
    if string_array_contains(effects, effect) {
        return effects;
    }
    effects.push(effect);
    return effects;
}

// =============================================================================
// Borrow Effect Collection
// =============================================================================

fn collect_function_borrow_effects(function -> NativeFunction) -> string[] {
    let mut effects -> string[] = [];
    let mut instructions = function.instructions;
    if instructions == null {
        return effects;
    }
    if instructions.length > 1000000 {
        return effects;
    }
    let mut index -> number = 0;
    loop {
        if index >= instructions.length {
            break;
        }
        let instruction = instructions[index];
        if instruction == null {
            index += 1;
            continue;
        }
        if instruction.variant == "Let" {
            if instruction.value != null {
                effects = merge_effect_lists(effects, collect_expression_borrow_effects(instruction.value));
            }
        } else if instruction.variant == "Expression" {
            if instruction.expression != null {
                effects = merge_effect_lists(effects, collect_expression_borrow_effects(instruction.expression));
            }
        } else if instruction.variant == "Return" {
            if instruction.expression != null {
                let trimmed = trim_text(instruction.expression);
                if trimmed.length > 0 {
                    effects = merge_effect_lists(effects, collect_expression_borrow_effects(trimmed));
                }
            }
        }
        index += 1;
    }
    return effects;
}

fn collect_expression_borrow_effects(expression -> string) -> string[] {
    let trimmed = trim_text(expression);
    if trimmed.length == 0 {
        return [];
    }
    let mut effects -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= trimmed.length {
            break;
        }
        let ch = substring(trimmed, index, index + 1);
        if ch == "\"" {
            index = skip_string_literal(trimmed, index + 1);
            continue;
        }
        if ch == "&" {
            let _amp_next = index + 1;
            let _amp_next2 = index + 2;
            if _amp_next < trimmed.length && substring(trimmed, _amp_next, _amp_next2) == "&" {
                index += 2;
                continue;
            }
            if index > 0 {
                let prefix = substring(trimmed, index - 1, index);
                if is_identifier_part_char(prefix) {
                    index += 1;
                    continue;
                }
            }
            let mut cursor -> number = _amp_next;
            let mut mutable_flag -> boolean = false;
            let _cursor_plus3 = cursor + 3;
            if _cursor_plus3 <= trimmed.length {
                let maybe_mut = substring(trimmed, cursor, _cursor_plus3);
                if maybe_mut == "mut" {
                    let after_mut_index = _cursor_plus3;
                    let _after_mut_next = after_mut_index + 1;
                    if after_mut_index >= trimmed.length || is_effect_delimiter(substring(trimmed, after_mut_index, _after_mut_next)) {
                        mutable_flag = true;
                        cursor = after_mut_index;
                    }
                }
            }
            loop {
                if cursor >= trimmed.length {
                    break;
                }
                let current = substring(trimmed, cursor, cursor + 1);
                if !is_trim_char(current) {
                    break;
                }
                cursor += 1;
            }
            if cursor < trimmed.length {
                let target_start = substring(trimmed, cursor, cursor + 1);
                if is_identifier_start_char(target_start) {
                    if mutable_flag {
                        effects = append_unique_effect(effects, "mut");
                    } else {
                        effects = append_unique_effect(effects, "read");
                    }
                }
            }
            index += 1;
            continue;
        }
        if ch == "b" {
            if matches_keyword(trimmed, index, "borrow") {
                let before_index = index - 1;
                let _before_next = before_index + 1;
                if before_index < 0 || is_effect_prefix_char(substring(trimmed, before_index, _before_next)) {
                    effects = append_unique_effect(effects, "read");
                    index += 6;
                    continue;
                }
            }
        }
        index += 1;
    }
    return effects;
}

// =============================================================================
// Call Graph Construction
// =============================================================================

fn collect_function_call_graph(functions -> NativeFunction[]) -> FunctionCallEntry[] {
    let mut entries -> FunctionCallEntry[] = [];
    let function_names = collect_function_names(functions);
    let mut index -> number = 0;
    loop {
        if index >= functions.length {
            break;
        }
        let call_entry = collect_function_call_entry(functions[index], function_names);
        entries = append_function_call_entry(entries, call_entry);
        index += 1;
    }
    return entries;
}

fn collect_function_call_entry(function -> NativeFunction, function_names -> string[]) -> FunctionCallEntry {
    let mut callees -> string[] = [];
    let mut instructions = function.instructions;
    if instructions == null {
        return FunctionCallEntry { name: function.name, callees: callees };
    }
    if instructions.length > 1000000 {
        return FunctionCallEntry { name: function.name, callees: callees };
    }
    let mut index -> number = 0;
    loop {
        if index >= instructions.length {
            break;
        }
        let instruction = instructions[index];
        if instruction == null {
            index += 1;
            continue;
        }
        callees = merge_effect_lists(callees, collect_instruction_calls(instruction, function_names));
        index += 1;
    }
    return FunctionCallEntry { name: function.name, callees: callees };
}

fn collect_function_names(functions -> NativeFunction[]) -> string[] {
    let mut names -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= functions.length {
            break;
        }
        let mut name = functions[index].name;
        if name == null {
            name = "";
        }
        names.push(name);
        index += 1;
    }
    return names;
}

fn append_function_call_entry(entries -> FunctionCallEntry[], entry -> FunctionCallEntry) -> FunctionCallEntry[] {
    entries.push(entry);
    return entries;
}

// =============================================================================
// Instruction Call Collection
// =============================================================================

fn collect_instruction_calls(instruction -> NativeInstruction, function_names -> string[]) -> string[] {
    let mut callees -> string[] = [];
    if instruction.variant == "Let" {
        if instruction.value != null {
            callees = merge_effect_lists(callees, extract_call_targets(instruction.value, function_names));
        }
        return callees;
    }
    if instruction.variant == "Expression" {
        if instruction.expression != null {
            callees = merge_effect_lists(callees, extract_call_targets(instruction.expression, function_names));
        }
        return callees;
    }
    if instruction.variant == "Return" {
        if instruction.expression != null {
            let trimmed = trim_text(instruction.expression);
            if trimmed.length > 0 {
                callees = merge_effect_lists(callees, extract_call_targets(trimmed, function_names));
            }
        }
        return callees;
    }
    if instruction.variant == "If" {
        callees = merge_effect_lists(callees, extract_call_targets(instruction.condition, function_names));
        return callees;
    }
    if instruction.variant == "For" {
        callees = merge_effect_lists(callees, extract_call_targets(instruction.iterable, function_names));
        return callees;
    }
    if instruction.variant == "Match" {
        callees = merge_effect_lists(callees, extract_call_targets(instruction.expression, function_names));
        return callees;
    }
    if instruction.variant == "Case" {
        callees = merge_effect_lists(callees, extract_call_targets(instruction.pattern, function_names));
        if instruction.guard != null {
            callees = merge_effect_lists(callees, extract_call_targets(instruction.guard, function_names));
        }
        return callees;
    }
    return callees;
}

fn extract_call_targets(expression -> string, function_names -> string[]) -> string[] {
    let mut results -> string[] = [];
    let expression_len = expression.length;
    if expression_len == 0 {
        return results;
    }
    let mut index -> number = 0;
    loop {
        if index >= expression_len {
            break;
        }
        let ch = substring(expression, index, index + 1);
        if ch == "\"" {
            index = skip_string_literal(expression, index + 1);
            continue;
        }
        if is_identifier_start_char(ch) {
            let start_index = index;
            index += 1;
            loop {
                if index >= expression_len {
                    break;
                }
                let current = substring(expression, index, index + 1);
                if is_identifier_part_char(current) {
                    index += 1;
                    continue;
                }
                if current == "." {
                    index += 1;
                    continue;
                }
                break;
            }
            let mut candidate = substring(expression, start_index, index);
            if candidate.length > 0 {
                loop {
                    let dot_index = index_of(candidate, ".");
                    if dot_index == -1 {
                        break;
                    }
                    candidate = substring(candidate, dot_index + 1, candidate.length);
                }
                let mut cursor -> number = index;
                loop {
                    if cursor >= expression_len {
                        break;
                    }
                    let next = substring(expression, cursor, cursor + 1);
                    if is_trim_char(next) {
                        cursor += 1;
                        continue;
                    }
                    if next == "(" {
                        if string_array_contains(function_names, candidate) {
                            results = append_unique_effect(results, candidate);
                        }
                    }
                    break;
                }
            }
            continue;
        }
        index += 1;
    }
    return results;
}

fn extract_all_call_targets(expression -> string) -> string[] {
    let mut results -> string[] = [];
    let expression_len = expression.length;
    if expression_len == 0 {
        return results;
    }
    let mut index -> number = 0;
    loop {
        if index >= expression_len {
            break;
        }
        let ch = substring(expression, index, index + 1);
        if ch == "\"" {
            index = skip_string_literal(expression, index + 1);
            continue;
        }
        if is_identifier_start_char(ch) {
            let start_index = index;
            index += 1;
            loop {
                if index >= expression_len {
                    break;
                }
                let current = substring(expression, index, index + 1);
                if is_identifier_part_char(current) {
                    index += 1;
                    continue;
                }
                if current == "." || current == ":" {
                    index += 1;
                    continue;
                }
                break;
            }
            let candidate = substring(expression, start_index, index);
            if candidate.length > 0 {
                let mut cursor -> number = index;
                loop {
                    if cursor >= expression_len {
                        break;
                    }
                    let next = substring(expression, cursor, cursor + 1);
                    if is_trim_char(next) {
                        cursor += 1;
                        continue;
                    }
                    if next == "(" {
                        results = append_unique_effect(results, candidate);
                    }
                    break;
                }
            }
            continue;
        }
        index += 1;
    }
    return results;
}

// =============================================================================
// Runtime Helper Target Collection
// =============================================================================

fn collect_runtime_helper_targets(functions -> NativeFunction[]) -> string[] {
    if functions.length > 100000 {
        return [];
    }
    let mut used -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= functions.length {
            break;
        }
        let helpers = collect_function_runtime_helper_targets(functions[index]);
        used = merge_effect_lists(used, helpers);
        index += 1;
    }
    return used;
}

fn collect_function_runtime_helper_targets(function -> NativeFunction) -> string[] {
    let mut used -> string[] = [];

    // Decorator-driven runtime hooks.
    let mut decorators = function.decorators;
    if decorators == null {
        decorators = [];
    }
    if decorators.length > 100000 {
        return used;
    }
    let mut decorator_index -> number = 0;
    loop {
        if decorator_index >= decorators.length {
            break;
        }
        let decorator_name = decorators[decorator_index];
        if matches_case_insensitive(decorator_name, "logExecution") || matches_case_insensitive(decorator_name, "logexecution") || matches_case_insensitive(decorator_name, "trace") {
            used = append_unique_effect(used, "runtime_log_execution_fn");
        }
        decorator_index += 1;
    }

    let mut instructions = function.instructions;
    if instructions == null {
        instructions = [];
    }
    if instructions.length > 1000000 {
        return used;
    }
    let mut index -> number = 0;
    loop {
        if index >= instructions.length {
            break;
        }
        let instruction = instructions[index];
        let instruction_helpers = collect_instruction_runtime_helper_targets(instruction);
        used = merge_effect_lists(used, instruction_helpers);
        index += 1;
    }
    return used;
}

fn collect_instruction_runtime_helper_targets(instruction -> NativeInstruction) -> string[] {
    if instruction.variant == "Let" {
        if instruction.value != null {
            let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.value));
            helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.value));
            return helpers;
        }
        return [];
    }
    if instruction.variant == "Expression" {
        let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.expression));
        helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.expression));
        return helpers;
    }
    if instruction.variant == "Return" {
        let trimmed = trim_text(instruction.expression);
        if trimmed.length > 0 {
            let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(trimmed));
            helpers = merge_effect_lists(helpers, collect_runtime_property_targets(trimmed));
            return helpers;
        }
        return [];
    }
    if instruction.variant == "If" {
        let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.condition));
        helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.condition));
        return helpers;
    }
    if instruction.variant == "For" {
        let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.iterable));
        helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.iterable));
        return helpers;
    }
    if instruction.variant == "Match" {
        let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.expression));
        helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.expression));
        return helpers;
    }
    if instruction.variant == "Case" {
        let mut helpers -> string[] = filter_runtime_helper_targets(extract_all_call_targets(instruction.pattern));
        helpers = merge_effect_lists(helpers, collect_runtime_property_targets(instruction.pattern));
        if instruction.guard != null {
            let guard_targets = filter_runtime_helper_targets(extract_all_call_targets(instruction.guard));
            let mut combined -> string[] = merge_effect_lists(helpers, guard_targets);
            combined = merge_effect_lists(combined, collect_runtime_property_targets(instruction.guard));
            return combined;
        }
        return helpers;
    }
    if instruction.variant == "Try" {
        return ["clear_exception", "has_exception", "take_exception"];
    }
    if instruction.variant == "Throw" {
        return ["set_exception"];
    }
    return [];
}

fn filter_runtime_helper_targets(targets -> string[]) -> string[] {
    let mut results -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= targets.length {
            break;
        }
        let trimmed = trim_text(targets[index]);
        let mut helper = find_runtime_helper(trimmed);
        if helper == null {
            let dot_index = find_last_index_of_char(trimmed, ".");
            let _dot_after = dot_index + 1;
            if dot_index >= 0 && _dot_after < trimmed.length {
                let suffix = substring(trimmed, _dot_after, trimmed.length);
                helper = find_runtime_helper(suffix);
            }
        }
        if helper == null {
            let colon_index = find_last_index_of_char(trimmed, ":");
            let _colon_after = colon_index + 1;
            if colon_index >= 0 && _colon_after < trimmed.length {
                let suffix = substring(trimmed, _colon_after, trimmed.length);
                helper = find_runtime_helper(suffix);
            }
        }
        if helper == null {
            let length_suffix = ".length";
            if trimmed.length >= length_suffix.length {
                let maybe_length = substring(trimmed, trimmed.length - length_suffix.length, trimmed.length);
                if maybe_length == length_suffix {
                    helper = find_runtime_helper("string.length");
                    if helper == null {
                        helper = find_runtime_helper("len(string)");
                    }
                }
            }
            if helper == null {
                let concat_suffix = ".concat";
                if trimmed.length >= concat_suffix.length {
                    let maybe_concat = substring(trimmed, trimmed.length - concat_suffix.length, trimmed.length);
                    if maybe_concat == concat_suffix {
                        helper = find_runtime_helper("concat");
                    }
                }
            }
        }
        if helper != null {
            results = append_unique_effect(results, helper.target);
        }
        index += 1;
    }
    return results;
}

fn collect_runtime_property_targets(expression -> string) -> string[] {
    let trimmed = trim_text(expression);
    if trimmed.length == 0 {
        return [];
    }
    let mut results -> string[] = [];
    if contains_dot_property(trimmed, "length") {
        results = append_unique_effect(results, "string.length");
    }
    return results;
}

fn contains_dot_property(expression -> string, name -> string) -> boolean {
    let suffix = "." + name;
    let suffix_length = suffix.length;
    if suffix_length == 0 || expression.length < suffix_length {
        return false;
    }
    let mut index -> number = 0;
    let mut in_single -> boolean = false;
    let mut in_double -> boolean = false;
    let mut escape_next -> boolean = false;
    loop {
        if index >= expression.length {
            break;
        }
        let ch = substring(expression, index, index + 1);
        if in_double {
            if escape_next {
                escape_next = false;
            } else if ch == "\\" {
                escape_next = true;
            } else if ch == "\"" {
                in_double = false;
            }
            index += 1;
            continue;
        }
        if in_single {
            if escape_next {
                escape_next = false;
            } else if ch == "\\" {
                escape_next = true;
            } else if ch == "'" {
                in_single = false;
            }
            index += 1;
            continue;
        }
        if ch == "\"" {
            in_double = true;
            index += 1;
            continue;
        }
        if ch == "'" {
            in_single = true;
            index += 1;
            continue;
        }
        let _sfx_end = index + suffix_length;
        if _sfx_end <= expression.length {
            let mut match_index -> number = 0;
            let mut matches -> boolean = true;
            loop {
                if match_index >= suffix_length {
                    break;
                }
                let _expr_pos = index + match_index;
                let expr_char = char_at(expression, _expr_pos);
                let suffix_char = char_at(suffix, match_index);
                if expr_char.length == 0 || suffix_char.length == 0 || expr_char != suffix_char {
                    matches = false;
                    break;
                }
                match_index += 1;
            }
            if matches {
                let after_index = _sfx_end;
                let after_char = char_at(expression, after_index);
                if after_char.length == 0 {
                    return true;
                }
                if !is_identifier_part_char(after_char) {
                    return true;
                }
            }
        }
        index += 1;
    }
    return false;
}

// =============================================================================
// Effect Propagation
// =============================================================================

fn propagate_function_effects(direct_effects -> FunctionEffectEntry[], call_graph -> FunctionCallEntry[]) -> FunctionEffectEntry[] {
    let mut aggregated -> FunctionEffectEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= direct_effects.length {
            break;
        }
        aggregated.push(FunctionEffectEntry { name: direct_effects[index].name, effects: copy_string_array(direct_effects[index].effects) });
        index += 1;
    }

    let trace = fs.exists("build/sailfin/.trace_test_runner") && fs.exists("build/sailfin/.test_runner_active");
    let mut iteration -> number = 0;
    let max_iterations = call_graph.length * 8 + 16;

    // Pre-compute call graph indices once so the fixed-point propagation loop
    // avoids repeated O(n) string lookups.
    let mut call_targets -> number[] = [];
    let mut call_callee_indices -> number[][] = [];
    let mut call_index -> number = 0;
    loop {
        if call_index >= call_graph.length {
            break;
        }
        let call_entry = call_graph[call_index];
        call_targets.push(find_function_effect_entry_index(aggregated, call_entry.name));

        let mut callees -> number[] = [];
        let mut callee_index -> number = 0;
        loop {
            if callee_index >= call_entry.callees.length {
                break;
            }
            callees.push(find_function_effect_entry_index(aggregated, call_entry.callees[callee_index]));
            callee_index += 1;
        }
        call_callee_indices.push(callees);
        call_index += 1;
    }

    let mut changed -> boolean = true;
    loop {
        if !changed {
            break;
        }
        if iteration > max_iterations {
            if trace {
                print.warn("llvm effects: propagation cap reached (max=" + number_to_string(max_iterations) + ")");
            }
            break;
        }
        iteration += 1;
        changed = false;
        call_index = 0;
        loop {
            if call_index >= call_graph.length {
                break;
            }
            let target_index = call_targets[call_index];
            if target_index >= 0 {
                let target_entry = aggregated[target_index];
                let mut merged -> string[] = copy_string_array(target_entry.effects);

                let callees = call_callee_indices[call_index];
                let mut callee_index -> number = 0;
                loop {
                    if callee_index >= callees.length {
                        break;
                    }
                    let callee_pos = callees[callee_index];
                    if callee_pos >= 0 {
                        let callee_entry = aggregated[callee_pos];
                        let mut effect_index -> number = 0;
                        loop {
                            if effect_index >= callee_entry.effects.length {
                                break;
                            }
                            merged = append_unique_effect(merged, callee_entry.effects[effect_index]);
                            effect_index += 1;
                        }
                    }
                    callee_index += 1;
                }

                if !string_arrays_equal(merged, target_entry.effects) {
                    aggregated[target_index] = FunctionEffectEntry { name: target_entry.name, effects: merged };
                    changed = true;
                }
            }
            call_index += 1;
        }
    }

    return aggregated;
}

fn find_function_effect_entry_index(entries -> FunctionEffectEntry[], name -> string) -> number {
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        if entries[index].name == name {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn find_function_effect_entry(entries -> FunctionEffectEntry[], name -> string) -> FunctionEffectEntry? {
    let index = find_function_effect_entry_index(entries, name);
    if index >= 0 {
        return entries[index];
    }
    return null;
}

fn replace_function_effect_entry(entries -> FunctionEffectEntry[], position -> number, entry -> FunctionEffectEntry) -> FunctionEffectEntry[] {
    let mut result -> FunctionEffectEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= entries.length {
            break;
        }
        if index == position {
            result.push(entry);
        } else {
            result.push(entries[index]);
        }
        index += 1;
    }
    return result;
}

// =============================================================================
// Capability Manifest Building
// =============================================================================

fn build_capability_manifest(entry_points -> string[], function_effects -> FunctionEffectEntry[]) -> CapabilityManifest {
    let mut entries -> CapabilityManifestEntry[] = [];
    let mut index -> number = 0;
    loop {
        if index >= entry_points.length {
            break;
        }
        let symbol = entry_points[index];
        let effect_entry = find_function_effect_entry(function_effects, symbol);
        let mut effects -> string[] = [];
        if effect_entry != null {
            effects = effect_entry.effects;
        }
        entries = append_manifest_entry(entries, CapabilityManifestEntry { symbol: symbol, effects: effects });
        index += 1;
    }
    return CapabilityManifest { entries: entries };
}

fn append_manifest_entry(entries -> CapabilityManifestEntry[], entry -> CapabilityManifestEntry) -> CapabilityManifestEntry[] {
    entries.push(entry);
    return entries;
}
