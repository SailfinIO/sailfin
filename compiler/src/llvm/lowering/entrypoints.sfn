}

fn is_test_module_slug(module_name -> string) -> boolean {
    if module_name.length == 0 {
        return false;
    }
    if index_of(module_name, "build/sailfin/test") >= 0 {
        return true;
    }
    if index_of(module_name, "compiler/tests/") >= 0 {
        return true;
    }
    if index_of(module_name, "/compiler/tests/") >= 0 {
        return true;
    }
    return false;
}

fn render_test_harness_main_for_module(tests -> NativeFunction[], module_slug -> string, mangle_symbols -> boolean) -> string[] {
    let mut lines -> string[] = [];
    lines = lines.concat([
        "define i32 @main(i32 %argc, i8** %argv) {",
        "entry:",
    ]);

    let should_mangle = mangle_symbols && !starts_with(module_slug, "runtime/");
    let module_suffix = sanitize_module_suffix(module_slug);

    let mut index -> number = 0;
    loop {
        if index >= tests.length {
            break;
        }
        let mut sym = sanitize_symbol(tests[index].name);
        if should_mangle {
            if index_of(sym, "__") < 0 {
                sym = sym + "__" + module_suffix;
            }
        }
        lines = append_string(lines, "  call void @" + sym + "()");
        index += 1;
    }
    lines = lines.concat([
        "  ret i32 0",
        "}",
    ]);
    return lines;
}

struct MangledModuleResult {
    lines -> string[];
    diagnostics -> string[];
}

struct DeclareSignature {
    return_type -> string;
    param_types -> string[];
}

fn is_llvm_symbol_char(ch -> string) -> boolean {
    if ch.length == 0 {
        return false;
    }
    if ch == "_" {
        return true;
    }
    let code = char_code(ch);
    let lower_a = char_code("a");
    let lower_z = char_code("z");
    if code >= lower_a && code <= lower_z {
        return true;
    }
    let upper_a = char_code("A");
    let upper_z = char_code("Z");
    if code >= upper_a && code <= upper_z {
        return true;
    }
    let zero = char_code("0");
    let nine = char_code("9");
    if code >= zero && code <= nine {
        return true;
    }
    return false;
}

fn sanitize_module_suffix(module_name -> string) -> string {
    if module_name.length == 0 {
        return "module";
    }
    let mut out -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= module_name.length {
            break;
        }
        let ch = module_name[index];
        if is_llvm_symbol_char(ch) {
            out = out + ch;
        } else {
            if ch == "/" {
                out = out + "__";
            } else {
                out = out + "_";
            }
        }
        index += 1;
    }
    if out.length == 0 {
        return "module";
    }
    return out;
}

fn should_keep_unmangled_abi_symbol(symbol -> string) -> boolean {
    if symbol == "native_cli_main" {
        return true;
    }
    if symbol == "compile_to_sailfin" {
        return true;
    }
    if symbol == "compile_to_llvm" {
        return true;
    }
    if symbol == "main" {
        return true;
    }
    return false;
}

fn extract_module_name_from_native_text(native_text -> string) -> string {
    if native_text.length == 0 {
        return "";
    }

    let module_index = index_of(native_text, ".module ");
    if module_index < 0 {
        return "";
    }

    let mut start = module_index + 8;
    loop {
        if start >= native_text.length {
            break;
        }
        let ch = native_text[start];
        if ch == " " || ch == "\t" {
            start += 1;
            continue;
        }
        break;
    }

    let mut end = start;
    loop {
        if end >= native_text.length {
            break;
        }
        if native_text[end] == "\n" {
            break;
        }
        end += 1;
    }

    return trim_text(substring(native_text, start, end));
}

fn collect_available_import_module_names(imported_native_texts -> string[]) -> string[] {
    let mut names -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= imported_native_texts.length {
            break;
        }
        let text = imported_native_texts[index];
        if text == null || text.length == 0 {
            index += 1;
            continue;
        }
        let name = extract_module_name_from_native_text(text);
        if name.length > 0 && !string_array_contains(names, name) {
            names = append_string(names, name);
        }
        index += 1;
    }
    return names;
}

fn resolve_import_provider_module_name(import_path -> string, current_module_slug -> string, available_module_names -> string[]) -> string {
    let base = resolve_import_module_slug_for_module(import_path, current_module_slug);
    if base.length == 0 {
        return base;
    }
    let resolved = resolve_import_artifact_slug(base);
    if resolved.length > 0 {
        return resolved;
    }
    if string_array_contains(available_module_names, base) {
        return base;
    }
    let mod_slug = base + "/mod";
    if string_array_contains(available_module_names, mod_slug) {
        return mod_slug;
    }
    return base;
}

fn collect_defined_function_symbols(lines -> string[]) -> string[] {
    let mut symbols -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let trimmed = trim_text(lines[index]);
        if starts_with(trimmed, "define ") {
            let mut at_index -> number = index_of(trimmed, "@");
            if at_index >= 0 {
                let mut start = at_index + 1;
                let mut end = start;
                loop {
                    if end >= trimmed.length {
                        break;
                    }
                    if !is_llvm_symbol_char(trimmed[end]) {
                        break;
                    }
                    end += 1;
                }
                if end > start {
                    let sym = substring(trimmed, start, end);
                    if !string_array_contains(symbols, sym) {
                        symbols = append_string(symbols, sym);
                    }
                }
            }
        }
        index += 1;
    }
    return symbols;
}

fn find_substitution_index(olds -> string[], news -> string[], symbol -> string) -> number {
    let mut index -> number = 0;
    loop {
        if index >= olds.length || index >= news.length {
            break;
        }
        if olds[index] == symbol {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn replace_symbol_refs_in_line(line -> string, olds -> string[], news -> string[]) -> string {
    if olds.length == 0 {
        return line;
    }
    if line.length == 0 {
        return line;
    }
    let mut out -> string = "";
    let mut index -> number = 0;
    let mut in_string -> boolean = false;
    loop {
        if index >= line.length {
            break;
        }
        let ch = line[index];
        if ch == "\"" {
            in_string = !in_string;
            out = out + ch;
            index += 1;
            continue;
        }
        if in_string {
            out = out + ch;
            index += 1;
            continue;
        }
        if ch != "@" {
            out = out + ch;
            index += 1;
            continue;
        }

        let start = index + 1;
        if start >= line.length {
            out = out + ch;
            index += 1;
            continue;
        }

        let mut end = start;
        loop {
            if end >= line.length {
                break;
            }
            if !is_llvm_symbol_char(line[end]) {
                break;
            }
            end += 1;
        }
        if end == start {
            // Not a function symbol (e.g. @.str), leave it untouched.
            out = out + ch;
            index += 1;
            continue;
        }

        let sym = substring(line, start, end);
        let replacement_index = find_substitution_index(olds, news, sym);
        if replacement_index >= 0 {
            out = out + "@" + news[replacement_index];
        } else {
            out = out + "@" + sym;
        }
        index = end;
    }
    return out;
}

fn apply_symbol_substitutions(lines -> string[], olds -> string[], news -> string[]) -> string[] {
    if olds.length == 0 {
        return lines;
    }
    let mut out = lines;
    let mut index -> number = 0;
    loop {
        if index >= out.length {
            break;
        }
        out[index] = replace_symbol_refs_in_line(out[index], olds, news);
        index += 1;
    }
    return out;
}

fn find_declare_signature(lines -> string[], symbol -> string) -> DeclareSignature? {
    if symbol.length == 0 {
        return null;
    }
    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let trimmed = trim_text(lines[index]);
        if starts_with(trimmed, "declare ") {
            let at_index = index_of(trimmed, "@");
            if at_index >= 0 {
                let start = at_index + 1;
                let mut end = start;
                loop {
                    if end >= trimmed.length {
                        break;
                    }
                    if !is_llvm_symbol_char(trimmed[end]) {
                        break;
                    }
                    end += 1;
                }
                if end > start {
                    let sym = substring(trimmed, start, end);
                    if sym == symbol {
                        let open_index = index_of(trimmed, "(");
                        let close_index = index_of(trimmed, ")");
                        if open_index < 0 || close_index < 0 || close_index <= open_index {
                            return null;
                        }
                        let ret_type = trim_text(substring(trimmed, 8, at_index));
                        let params_text = trim_text(substring(trimmed, open_index + 1, close_index));
                        if params_text.length == 0 || params_text == "void" {
                            return DeclareSignature { return_type: ret_type, param_types: [] };
                        }

                        // Split parameters on top-level commas only (struct types include commas).
                        let mut parts -> string[] = [];
                        let mut start_index -> number = 0;
                        let mut scan -> number = 0;
                        let mut curly_depth -> number = 0;
                        let mut angle_depth -> number = 0;
                        loop {
                            if scan >= params_text.length {
                                break;
                            }
                            let ch = params_text[scan];
                            if ch == "{" {
                                curly_depth += 1;
                            } else if ch == "}" {
                                if curly_depth > 0 {
                                    curly_depth -= 1;
                                }
                            } else if ch == "<" {
                                angle_depth += 1;
                            } else if ch == ">" {
                                if angle_depth > 0 {
                                    angle_depth -= 1;
                                }
                            }
                            if ch == "," && curly_depth == 0 && angle_depth == 0 {
                                let part = trim_text(substring(params_text, start_index, scan));
                                if part.length > 0 {
                                    parts = append_string(parts, part);
                                }
                                start_index = scan + 1;
                            }
                            scan += 1;
                        }
                        let final_part = trim_text(substring(params_text, start_index, params_text.length));
                        if final_part.length > 0 {
                            parts = append_string(parts, final_part);
                        }
                        return DeclareSignature { return_type: ret_type, param_types: parts };
                    }
                }
            }
        }
        index += 1;
    }
    return null;
}

fn render_function_shim(export_symbol -> string, target_symbol -> string, signature -> DeclareSignature) -> string[] {
    let mut param_decls -> string[] = [];
    let mut call_args -> string[] = [];
    let mut idx -> number = 0;
    loop {
        if idx >= signature.param_types.length {
            break;
        }
        let ty = trim_text(signature.param_types[idx]);
        if ty == "..." {
            param_decls = append_string(param_decls, "...");
            // Varargs shims are not supported; omit forwarding.
            idx += 1;
            continue;
        }
        let name = "%a" + number_to_string(idx);
        param_decls = append_string(param_decls, ty + " " + name);
        call_args = append_string(call_args, ty + " " + name);
        idx += 1;
    }

    let header = "define " + signature.return_type + " @" + export_symbol + "(" + join_with_separator(param_decls, ", ") + ") {";
    if signature.return_type == "void" {
        return [
            header,
            "entry:",
            "  call void @" + target_symbol + "(" + join_with_separator(call_args, ", ") + ")",
            "  ret void",
            "}",
        ];
    }
    return [
        header,
        "entry:",
        "  %t0 = call " + signature.return_type + " @" + target_symbol + "(" + join_with_separator(call_args, ", ") + ")",
        "  ret " + signature.return_type + " %t0",
        "}",
    ];
}

fn insert_before_llvm_footer(lines -> string[], inserted -> string[]) -> string[] {
    if inserted.length == 0 {
        return lines;
    }
    let mut footer_index = lines.length;
    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let trimmed = trim_text(lines[index]);
        if starts_with(trimmed, "attributes ") || starts_with(trimmed, "!") {
            footer_index = index;
            break;
        }
        index += 1;
    }
    let mut out -> string[] = [];
    let mut i -> number = 0;
    loop {
        if i >= lines.length {
            break;
        }
        if i == footer_index {
            let mut j -> number = 0;
            loop {
                if j >= inserted.length {
                    break;
                }
                out = append_string(out, inserted[j]);
                j += 1;
            }
        }
        out = append_string(out, lines[i]);
        i += 1;
    }
    if footer_index == lines.length {
        let mut j -> number = 0;
        loop {
            if j >= inserted.length {
                break;
            }
            out = append_string(out, inserted[j]);
            j += 1;
        }
    }
    return out;
}

fn apply_module_symbol_mangling(
    lines -> string[],
    imports -> NativeImport[],
    current_module_slug -> string,
    imported_native_texts -> string[]
) -> MangledModuleResult {
    let mut diagnostics -> string[] = [];
    let debug_lowering = fs.exists("build/sailfin/.trace_lowering");
    if debug_lowering {
        print.warn("emit-llvm: mangle start module=" + current_module_slug);
    }
    let mut safe_imports = imports;
    if safe_imports == null {
        safe_imports = [];
    }
    if safe_imports.length > 100000 {
        diagnostics = append_string(diagnostics, "llvm lowering: import list too large for mangling; dropping");
        safe_imports = [];
        if debug_lowering {
            print.warn("emit-llvm: mangle import list too large; dropping");
        }
    }

    // Keep runtime modules unmangled: they can be referenced implicitly
    // (without explicit imports) and effectively act as a stable ABI.
    if starts_with(current_module_slug, "runtime/") {
        return MangledModuleResult { lines: lines, diagnostics: diagnostics };
    }

    let module_suffix = sanitize_module_suffix(current_module_slug);

    let available_modules = collect_available_import_module_names(imported_native_texts);
    if debug_lowering {
        print.warn("emit-llvm: mangle available_modules=" + number_to_string(available_modules.length));
    }

    // 1) Mangle every function defined in this module to a module-qualified symbol.
    let defined = collect_defined_function_symbols(lines);
    if debug_lowering {
        print.warn("emit-llvm: mangle defined_symbols=" + number_to_string(defined.length));
    }
    let mut local_olds -> string[] = [];
    let mut local_news -> string[] = [];
    let mut def_index -> number = 0;
    loop {
        if def_index >= defined.length {
            break;
        }
        let sym = defined[def_index];
        if should_keep_unmangled_abi_symbol(sym) {
            def_index += 1;
            continue;
        }
        // Avoid double-mangling if already qualified.
        if index_of(sym, "__") >= 0 {
            def_index += 1;
            continue;
        }
        local_olds = append_string(local_olds, sym);
        local_news = append_string(local_news, sym + "__" + module_suffix);
        def_index += 1;
    }

    let mut rewritten = apply_symbol_substitutions(lines, local_olds, local_news);
    if debug_lowering {
        print.warn("emit-llvm: mangle local_subs=" + number_to_string(local_olds.length));
    }

    // 2) Rewrite imported symbol references to the provider's qualified symbol,
    // and generate re-export shims so downstream modules can import symbols
    // from this module even if they're transitively provided.
    let mut import_olds -> string[] = [];
    let mut import_news -> string[] = [];
    let mut shim_exports -> string[] = [];
    let mut shim_targets -> string[] = [];
    let mut import_index -> number = 0;
    loop {
        if import_index >= safe_imports.length {
            break;
        }
        let entry = safe_imports[import_index];
        if entry == null {
            import_index += 1;
            continue;
        }
        if entry.kind == null || entry.kind != "import" {
            import_index += 1;
            continue;
        }
        if entry.module == null || entry.module.length == 0 {
            import_index += 1;
            continue;
        }
        let provider_module = resolve_import_provider_module_name(entry.module, current_module_slug, available_modules);
        let provider_is_runtime = starts_with(provider_module, "runtime/");
        let provider_suffix = sanitize_module_suffix(provider_module);
        let mut specifiers = entry.specifiers;
        if specifiers == null {
            specifiers = [];
        }
        let mut spec_index -> number = 0;
        loop {
            if spec_index >= specifiers.length {
                break;
            }
            let spec -> NativeImportSpecifier = specifiers[spec_index];
            if spec == null {
                spec_index += 1;
                continue;
            }
            if spec.name == null || spec.name.length == 0 {
                spec_index += 1;
                continue;
            }
            let imported_name = sanitize_symbol(spec.name);
            let mut local_name = spec.name;
            if spec.alias != null && spec.alias.length > 0 {
                local_name = spec.alias;
            }
            let local_symbol = sanitize_symbol(local_name);
            if should_keep_unmangled_abi_symbol(local_symbol) {
                spec_index += 1;
                continue;
            }
            if string_array_contains(defined, local_symbol) {
                diagnostics = append_string(diagnostics, "llvm lowering: import `" + local_symbol + "` shadows local function in module `" + current_module_slug + "`");
                spec_index += 1;
                continue;
            }
            // Don't rewrite if already qualified.
            if index_of(local_symbol, "__") >= 0 {
                spec_index += 1;
                continue;
            }
            import_olds = append_string(import_olds, local_symbol);
            let mut target_symbol = imported_name;
            if !provider_is_runtime {
                target_symbol = imported_name + "__" + provider_suffix;
            }
            import_news = append_string(import_news, target_symbol);

            // Re-export shim: provide `local_symbol__<this_module>` as a thin
            // wrapper forwarding to the provider's symbol.
            let export_sym = local_symbol + "__" + module_suffix;
            if !string_array_contains(shim_exports, export_sym) {
                shim_exports = append_string(shim_exports, export_sym);
                shim_targets = append_string(shim_targets, target_symbol);
            }
            spec_index += 1;
        }
        import_index += 1;
    }

    rewritten = apply_symbol_substitutions(rewritten, import_olds, import_news);
    if debug_lowering {
        print.warn("emit-llvm: mangle import_subs=" + number_to_string(import_olds.length));
    }

    // 3) Append shims before the LLVM footer (attributes/metadata).
    let mut shim_lines -> string[] = [];
    let mut shim_index -> number = 0;
    loop {
        if shim_index >= shim_exports.length || shim_index >= shim_targets.length {
            break;
        }
        let export_sym = shim_exports[shim_index];
        let target_sym = shim_targets[shim_index];
        let signature = find_declare_signature(rewritten, target_sym);
        if signature == null {
            // Not a function import (e.g. struct/enum type), or declaration not emitted.
            shim_index += 1;
            continue;
        }
        shim_lines = shim_lines.concat(render_function_shim(export_sym, target_sym, signature));
        shim_lines = append_string(shim_lines, "");
        shim_index += 1;
    }
    rewritten = insert_before_llvm_footer(rewritten, shim_lines);
    if debug_lowering {
        print.warn("emit-llvm: mangle shims=" + number_to_string(shim_exports.length));
    }

    return MangledModuleResult { lines: rewritten, diagnostics: diagnostics };
}

fn empty_capability_manifest() -> CapabilityManifest {
    return CapabilityManifest { entries: [] };
}

fn build_trait_metadata(interfaces -> NativeInterface[], structs -> NativeStruct[]) -> TraitMetadata {
    if interfaces.length > 10000 || structs.length > 10000 {
        return TraitMetadata { interfaces: [], implementations: [] };
    }
    let mut interface_descriptors -> TraitDescriptor[] = [];
    let mut index -> number = 0;
    loop {
        if index >= interfaces.length {
            break;
        }
        let interface = interfaces[index];
        let mut updated_interfaces = interface_descriptors;
        updated_interfaces = updated_interfaces.push(
            TraitDescriptor {
                name: interface.name,
                type_parameters: interface.type_parameters,
                signatures: interface.signatures,
            }
        );
        interface_descriptors = updated_interfaces;
        index += 1;
    }

    let mut implementation_descriptors -> TraitImplementationDescriptor[] = [];
    index = 0;
    loop {
        if index >= structs.length {
            break;
        }
        let definition = structs[index];
        let mut impls = definition.implements;
        if impls == null {
            impls = [];
        }
        if impls.length > 0 {
            let mut updated_impls = implementation_descriptors;
            updated_impls = updated_impls.push(
                TraitImplementationDescriptor { struct_name: definition.name, interfaces: impls }
            );
            implementation_descriptors = updated_impls;
        }
        index += 1;
    }

    return TraitMetadata { interfaces: interface_descriptors, implementations: implementation_descriptors };
}

fn append_native_function(values -> NativeFunction[], value -> NativeFunction) -> NativeFunction[] {
    let mut out = values;
    if out == null {
        out = [];
    }
    out = out.push(value);
    return out;
}

fn concat_native_functions(first -> NativeFunction[], second -> NativeFunction[]) -> NativeFunction[] {
    let mut result -> NativeFunction[] = [];
    let mut safe_first = first;
    if safe_first == null {
        safe_first = [];
    }
    if safe_first.length > 200000 {
        return result;
    }
    let mut safe_second = second;
    if safe_second == null {
        safe_second = [];
    }
    if safe_second.length > 200000 {
        return result;
    }
    let mut index -> number = 0;
    loop {
        if index >= safe_first.length {
            break;
        }
        result = append_native_function(result, safe_first[index]);
        index += 1;
    }
    index = 0;
    loop {
        if index >= safe_second.length {
            break;
        }
        result = append_native_function(result, safe_second[index]);
        index += 1;
    }
    return result;
}

fn flatten_struct_methods(structs -> NativeStruct[]) -> NativeFunction[] {
    if structs.length > 100000 {
        return [];
    }
    let mut result -> NativeFunction[] = [];
    let mut index -> number = 0;
    loop {
        if index >= structs.length {
            break;
        }
        let definition = structs[index];
        let mut methods = definition.methods;
        if methods == null {
            index += 1;
            continue;
        }
        if methods.length > 100000 {
            index += 1;
            continue;
        }
        let mut method_index -> number = 0;
        loop {
            if method_index >= methods.length {
                break;
            }
            let method = methods[method_index];
            let qualified_name = definition.name + "::" + method.name;
            let qualified = NativeFunction {
                name: qualified_name,
                is_async: method.is_async,
                parameters: method.parameters,
                return_type: method.return_type,
                effects: method.effects,
                decorators: method.decorators,
                instructions: method.instructions,
                is_extern: false,
            };
            result = append_native_function(result, qualified);
            method_index += 1;
        }
        index += 1;
    }
    return result;
}

fn parse_native_artifact_with_retry(text -> string, attempts -> number) -> ParseNativeResult {
    let mut remaining = attempts;
    if remaining <= 0 {
        remaining = 1;
    }
    let mut best = parse_native_artifact(text);
    let mut best_count -> number = 0;
    if best.functions != null {
        best_count = best.functions.length;
    }

    let mut index -> number = 1;
    loop {
        if index >= remaining {
            break;
        }
        if best_count > 0 {
            break;
        }
        let candidate = parse_native_artifact(text);
        let mut candidate_count -> number = 0;
        if candidate.functions != null {
            candidate_count = candidate.functions.length;
        }
        if candidate_count > best_count {
            best = candidate;
            best_count = candidate_count;
        }
        index += 1;
    }

    return best;
}

fn recover_function_name_from_header(line -> string) -> string {
    if !starts_with_local(line, ".fn ") {
        return "";
    }
    let header = trim_text_local(substring(line, 4, line.length));
    let open_paren = index_of_char_local(header, "(");
    if open_paren < 0 {
        return header;
    }
    return trim_text_local(substring(header, 0, open_paren));
}

fn is_trim_char_local(ch -> string) -> boolean {
    let code = char_code(ch);
    return code == char_code(" ") || code == char_code("\n") || code == char_code("\r") || code == char_code("\t");
}

fn trim_text_local(value -> string) -> string {
    if value.length == 0 {
        return "";
    }
    let mut start -> number = 0;
    let mut end = value.length;
    loop {
        if start >= end {
            break;
        }
        if !is_trim_char_local(value[start]) {
            break;
        }
        start += 1;
    }
    loop {
        if end <= start {
            break;
        }
        if !is_trim_char_local(value[end - 1]) {
            break;
        }
        end -= 1;
    }
    if end <= start {
        return "";
    }
    return substring(value, start, end);
}

fn starts_with_local(value -> string, prefix -> string) -> boolean {
    if prefix.length == 0 {
        return true;
    }
    if value.length < prefix.length {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= prefix.length {
            break;
        }
        if value[index] != prefix[index] {
            return false;
        }
        index += 1;
    }
    return true;
}

fn index_of_char_local(value -> string, needle -> string) -> number {
    if needle.length == 0 {
        return 0;
    }
    let mut index -> number = 0;
    loop {
        if index >= value.length {
            break;
        }
        if value[index] == needle {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn split_lines_local(value -> string) -> string[] {
    let value_len = value.length;
    let mut lines -> string[] = [];
    let mut start -> number = 0;
    let mut index -> number = 0;
    loop {
        if index >= value_len {
            break;
        }
        let ch = value[index];
        if ch == "\n" {
            lines = lines.push(substring(value, start, index));
            start = index + 1;
        }
        index += 1;
    }
    lines = lines.push(substring(value, start, value_len));
    return lines;
}

fn recover_native_functions_light(native_text -> string) -> NativeFunction[] {
    let lines = split_lines_local(native_text);
    let mut functions -> NativeFunction[] = [];
    let mut current -> NativeFunction? = null;
    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let line = trim_text_local(lines[index]);
        if line.length == 0 || starts_with_local(line, ";") || starts_with_local(line, ".module ") {
            index += 1;
            continue;
        }
        if starts_with_local(line, ".fn ") {
            if current != null {
                functions = append_native_function(functions, current);
            }
            let name = recover_function_name_from_header(line);
            current = NativeFunction {
                name: name,
                is_async: false,
                parameters: [],
                return_type: "void",
                effects: [],
                decorators: [],
                is_extern: false,
                instructions: [],
            };
            index += 1;
            continue;
        }
        if starts_with_local(line, ".endfn") || starts_with_local(line, ".endtest") {
            if current != null {
                functions = append_native_function(functions, current);
                current = null;
            }
            index += 1;
            continue;
        }
        if current == null {
            index += 1;
            continue;
        }
        if starts_with_local(line, ".meta ") || starts_with_local(line, ".param ") || starts_with_local(line, ".span ") || starts_with_local(line, ".init-span ") {
            index += 1;
            continue;
        }

        let mut next_instruction -> NativeInstruction = NativeInstruction.Unknown { text: line };
        if starts_with_local(line, "eval ") {
            next_instruction = NativeInstruction.Expression { expression: trim_text_local(substring(line, 5, line.length)), span: null };
        } else if starts_with_local(line, ".return") {
            next_instruction = NativeInstruction.Return { expression: trim_text_local(substring(line, 7, line.length)), span: null };
        } else if starts_with_local(line, "ret ") {
            next_instruction = NativeInstruction.Return { expression: trim_text_local(substring(line, 4, line.length)), span: null };
        } else if line == "ret" {
            next_instruction = NativeInstruction.Return { expression: "", span: null };
        } else if line == ".else" {
            next_instruction = NativeInstruction.Else();
        } else if line == ".endif" {
            next_instruction = NativeInstruction.EndIf();
        } else if starts_with_local(line, ".if ") {
            next_instruction = NativeInstruction.If { condition: trim_text_local(substring(line, 4, line.length)) };
        } else if line == ".loop" {
            next_instruction = NativeInstruction.Loop();
        } else if line == ".endloop" {
            next_instruction = NativeInstruction.EndLoop();
        } else if line == "break" {
            next_instruction = NativeInstruction.Break();
        } else if line == "continue" {
            next_instruction = NativeInstruction.Continue();
        }

        let mut updated_instructions = current.instructions;
        updated_instructions = updated_instructions.push(next_instruction);
        current = NativeFunction {
            name: current.name,
            is_async: current.is_async,
            parameters: current.parameters,
            return_type: current.return_type,
            effects: current.effects,
            decorators: current.decorators,
            is_extern: current.is_extern,
            instructions: updated_instructions,
        };
        index += 1;
    }
    if current != null {
        functions = append_native_function(functions, current);
    }
    return functions;
}

fn recover_functions_for_lowering(current_functions -> NativeFunction[], native_text_override_path -> string, artifact_text -> string, debug_lowering -> boolean) -> NativeFunction[] ![io] {
    let mut safe_functions = current_functions;
    if safe_functions == null {
        safe_functions = [];
    }
    let initial_function_count = sanitize_collection_length(safe_functions.length, 200000);
    if safe_functions.length != initial_function_count {
        if debug_lowering {
            print.warn("emit-llvm: invalid function list length; dropping current parsed functions");
        }
        safe_functions = [];
    }
    if safe_functions.length > 0 {
        let mut expected_source_text = artifact_text;
        if expected_source_text.length == 0 && native_text_override_path.length > 0 {
            expected_source_text = native_text_override_path;
        }
        if expected_source_text.length == 0 && fs.exists("build/sailfin/emit-native.tmp") {
            expected_source_text = fs.readFile("build/sailfin/emit-native.tmp");
        }

        if expected_source_text.length > 0 {
            let expected_functions = parse_native_functions_from_text(expected_source_text);
            let expected_count = sanitize_collection_length(expected_functions.length, 200000);
            if expected_count > 0 {
                let mut use_expected = false;
                if safe_functions.length != expected_count {
                    use_expected = true;
                }

                let mut has_body_instructions = false;
                let mut body_index -> number = 0;
                loop {
                    if body_index >= initial_function_count {
                        break;
                    }
                    let function = safe_functions[body_index];
                    if !function.is_extern && function.instructions != null && function.instructions.length > 0 {
                        has_body_instructions = true;
                        break;
                    }
                    body_index += 1;
                }
                if !has_body_instructions {
                    use_expected = true;
                }

                let mut index -> number = 0;
                loop {
                    if index >= initial_function_count || index >= expected_count {
                        break;
                    }
                    let safe_name = trim_text_local(safe_functions[index].name);
                    let expected_name = trim_text_local(expected_functions[index].name);
                    if safe_name.length == 0 || safe_name == "_" {
                        use_expected = true;
                        break;
                    }
                    if expected_name.length == 0 {
                        use_expected = true;
                        break;
                    }
                    if safe_name != expected_name {
                        use_expected = true;
                        break;
                    }
                    index += 1;
                }

                if use_expected {
                    let mut replacement_functions = expected_functions;
                    let light_functions = recover_native_functions_light(expected_source_text);
                    let light_count = sanitize_collection_length(light_functions.length, 200000);
                    let mut light_has_body = false;
                    let mut light_index -> number = 0;
                    loop {
                        if light_index >= light_count {
                            break;
                        }
                        let function = light_functions[light_index];
                        if !function.is_extern && function.instructions != null && function.instructions.length > 0 {
                            light_has_body = true;
                            break;
                        }
                        light_index += 1;
                    }
                    if light_has_body {
                        replacement_functions = light_functions;
                    }
                    if debug_lowering {
                        print.warn(
                            "emit-llvm: replacing suspicious parsed functions with stable function parse"
                        );
                    }
                    safe_functions = replacement_functions;
                }
            }
        }
        return safe_functions;
    }

    let mut recovery_text = "";
    if native_text_override_path.length > 0 {
        recovery_text = native_text_override_path;
    }
    if recovery_text.length == 0 && artifact_text.length > 0 {
        recovery_text = artifact_text;
    }
    if recovery_text.length == 0 && fs.exists("build/sailfin/emit-native.tmp") {
        recovery_text = fs.readFile("build/sailfin/emit-native.tmp");
    }

    let direct_count = parse_native_function_count_from_text(recovery_text);
    if debug_lowering {
        print.warn("emit-llvm: recovery source direct count=" + number_to_string(direct_count));
    }
    if direct_count == 0 && fs.exists("build/sailfin/emit-native.tmp") {
        recovery_text = fs.readFile("build/sailfin/emit-native.tmp");
    }

    safe_functions = parse_native_functions_from_text(recovery_text);
    let recovered_count = sanitize_collection_length(safe_functions.length, 200000);
    if safe_functions.length != recovered_count {
        safe_functions = [];
    }
    if debug_lowering {
        print.warn("emit-llvm: recovered functions via parse_native_functions_from_text=" + number_to_string(safe_functions.length));
    }
    if safe_functions.length > 0 {
        if debug_lowering {
            print.warn("emit-llvm: recovered functions via stable function parse=" + number_to_string(safe_functions.length));
        }
        return safe_functions;
    }

    safe_functions = recover_native_functions_light(recovery_text);
    let light_recovered_count = sanitize_collection_length(safe_functions.length, 200000);
    if safe_functions.length != light_recovered_count {
        safe_functions = [];
    }
    if debug_lowering {
        print.warn("emit-llvm: recovered functions via light parser=" + number_to_string(safe_functions.length));
    }
    if safe_functions.length > 0 {
        return safe_functions;
    }

    if fs.exists("build/sailfin/emit-native.tmp") {
        let disk_recovery_text = fs.readFile("build/sailfin/emit-native.tmp");
        safe_functions = recover_native_functions_light(disk_recovery_text);
    }
    return safe_functions;
}

fn lower_to_llvm(native_module -> NativeModule) -> LoweredLLVMResult ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
        if artifact == null || artifact.contents.length == 0 {
            return lower_to_llvm_with_context(native_module, [], [], []);
        }
        let parse = parse_native_artifact(artifact.contents);
        let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
        return lower_to_llvm_with_parsed_context(
            native_module,
            parse,
            import_context.manifests,
            import_context.native_texts,
            import_context.diagnostics
        );
}

fn lower_to_llvm_lines(native_module -> NativeModule) -> LoweredLLVMLinesResult ![io] {
    let ir = lower_to_llvm_ir(native_module);
        if ir == null || ir.length == 0 {
            return LoweredLLVMLinesResult { lines: [], diagnostics: [], trait_metadata: empty_trait_metadata(), function_effects: [], lifetime_regions: [], capability_manifest: empty_capability_manifest(), string_constants: empty_string_constant_set() };
        }
    let lines = split_lines(ir);
    return LoweredLLVMLinesResult {
        lines: lines,
        diagnostics: [],
        trait_metadata: empty_trait_metadata(),
        function_effects: [],
        lifetime_regions: [],
        capability_manifest: empty_capability_manifest(),
        string_constants: empty_string_constant_set(),
    };
}

fn lower_to_llvm_lines_only(native_module -> NativeModule) -> string[] ![io] {
    let ir = lower_to_llvm_ir(native_module);
    if ir == null || ir.length == 0 {
        return [];
    }
    return split_lines(ir);
}

// Convenience wrapper for tool/driver entrypoints that only need the emitted
// LLVM text. Returning a plain string avoids carrying the full `LoweredLLVMResult`
// struct across compilation boundaries (stage1 Python + stage2 native), which
// has historically caused layout/ABI mismatches and nondeterministic output.
fn lower_to_llvm_ir(native_module -> NativeModule) -> string ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null || artifact.contents.length == 0 {
        let lowered = lower_to_llvm_with_context(native_module, [], [], []);
        return lowered.ir;
    }
    // Parse once and reuse throughout lowering; parsing the native artifact is expensive.
    let parse = parse_native_artifact(artifact.contents);
    let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
    let lowered = lower_to_llvm_with_parsed_context(
        native_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics
    );
    return lowered.ir;
}

fn lower_to_llvm_for_tests(native_module -> NativeModule) -> LoweredLLVMResult ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return lower_to_llvm_with_context_for_tests(native_module, [], [], []);
    }
    // Parse once and reuse throughout lowering; parsing the native artifact is expensive.
    let parse = parse_native_artifact(artifact.contents);
    let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
    return lower_to_llvm_with_parsed_context_for_tests(
        native_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics
    );
}

fn lower_to_llvm_lines_for_tests(native_module -> NativeModule) -> LoweredLLVMLinesResult ![io] {
    let ir = lower_to_llvm_ir_for_tests_direct(native_module);
    if ir.length == 0 {
        return LoweredLLVMLinesResult {
            lines: [],
            diagnostics: [],
            trait_metadata: empty_trait_metadata(),
            function_effects: [],
            lifetime_regions: [],
            capability_manifest: empty_capability_manifest(),
            string_constants: empty_string_constant_set(),
        };
    }
    let lines = split_lines(ir);
    return LoweredLLVMLinesResult {
        lines: lines,
        diagnostics: [],
        trait_metadata: empty_trait_metadata(),
        function_effects: [],
        lifetime_regions: [],
        capability_manifest: empty_capability_manifest(),
        string_constants: empty_string_constant_set(),
    };
}

fn lower_to_llvm_ir_for_tests(native_module -> NativeModule) -> string ![io] {
    let lowered = lower_to_llvm_for_tests(native_module);
    return lowered.ir;
}

// Direct text lowering for tests to avoid returning large structs across call
// boundaries (can trigger ABI corruption in stage2-native).
fn lower_to_llvm_ir_for_tests_direct(native_module -> NativeModule) -> string ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return "";
    }
    let trace = fs.exists("build/sailfin/.trace_test_runner") && fs.exists("build/sailfin/.test_runner_active");
    if trace {
        print.info("test llvm: direct parse start (bytes=" + number_to_string(artifact.contents.length) + ")");
    }
    let parse = parse_native_artifact(artifact.contents);
    if trace {
        print.info("test llvm: direct parse done (imports=" + number_to_string(parse.imports.length) + ")");
    }
    if trace {
        print.info("test llvm: direct import-context start");
    }
    let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
    if trace {
        print.info("test llvm: direct import-context done (texts=" + number_to_string(import_context.native_texts.length) + ")");
        print.info("test llvm: direct lowering start");
    }
    let lowered_lines = lower_to_llvm_lines_with_parsed_context_for_tests(
        native_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics
    );
    if trace {
        print.info("test llvm: direct lines=" + number_to_string(lowered_lines.lines.length));
        let mut preview -> number = 0;
        loop {
            if preview >= lowered_lines.lines.length || preview >= 3 {
                break;
            }
            print.info("test llvm: direct line " + number_to_string(preview) + " -> " + lowered_lines.lines[preview]);
            preview += 1;
        }
    }
    if lowered_lines.lines == null || lowered_lines.lines.length == 0 {
        return "";
    }
    let ir = _join_llvm_lines_linear(lowered_lines.lines);
    if ir.length <= 4 {
        let mut first_line -> string = "";
        if lowered_lines.lines.length > 0 {
            first_line = lowered_lines.lines[0];
        }
        print.warn(
            "test llvm: suspiciously short IR (len=" + number_to_string(ir.length)
            + " lines=" + number_to_string(lowered_lines.lines.length)
            + " first='" + first_line + "')"
        );
    }
    if ir.length == 0 {
        return "";
    }
    return ir + "\n";
}

// Build and write LLVM IR for tests without returning large structs/arrays.
// This keeps `LoweredLLVMLinesResult` within this module to avoid ABI issues.
fn write_llvm_ir_for_tests(native_module -> NativeModule, out_path -> string) -> boolean ![io] {
    let trace = fs.exists("build/sailfin/.trace_test_runner") && fs.exists("build/sailfin/.test_runner_active");
    let timing = fs.exists("build/sailfin/.test_runner_active");
    let start_ms = monotonic_millis();
    let mut is_test_module = is_test_module_slug(native_module.module_name);
    if !is_test_module && fs.exists("build/sailfin/.test_runner_active") {
        is_test_module = true;
    }
    if trace {
        print.info("test llvm: write_llvm_ir_for_tests start");
    }
    if native_module.artifacts == null || native_module.artifacts.length == 0 {
        print.warn("test llvm: native module missing artifacts");
        return false;
    }
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        print.warn("test llvm: missing sailfin-native-text artifact");
        return false;
    }
    if trace {
        print.info("test llvm: native artifact bytes=" + number_to_string(artifact.contents.length));
    }
    let parse = parse_native_artifact(artifact.contents);
    if trace {
        print.info("test llvm: parsed native artifact (imports=" + number_to_string(parse.imports.length) + ")");
    }
    if timing {
        print.info("test llvm: phase=parse ms=" + number_to_string(monotonic_millis() - start_ms));
    }
    if trace {
        print.info("test llvm: stage=after-parse");
    }

    if !is_test_module && parse.functions != null {
        let mut scan_index -> number = 0;
        loop {
            if scan_index >= parse.functions.length {
                break;
            }
            let fun = parse.functions[scan_index];
            if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
                is_test_module = true;
                break;
            }
            scan_index += 1;
        }
    }

    let mut imported_manifests -> LayoutManifest[] = [];
    let mut imported_native_texts -> string[] = [];
    let mut imported_diagnostics -> string[] = [];
    if parse.imports != null && parse.imports.length > 0 {
        let skip_imports = is_test_module;
        if !skip_imports {
            let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
            imported_manifests = import_context.manifests;
            imported_native_texts = import_context.native_texts;
            imported_diagnostics = import_context.diagnostics;
            if trace {
                print.info("test llvm: collected import context (texts=" + number_to_string(imported_native_texts.length) + ")");
            }
        } else if trace {
            print.info("test llvm: skipping import context for inlined test module");
        }
    }
    if timing {
        print.info("test llvm: phase=imports ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let mut diagnostics = extend_string_lines_checked(imported_diagnostics, parse.diagnostics, "parse");
    if trace {
        print.info("test llvm: lower_to_llvm_lines_with_parsed_context start");
    }

    // Bootstrap guard: skip exported symbol collection to avoid crashes.
    let exported_symbols -> string[] = [];

    let mut module_manifest -> LayoutManifest? = null;

    let manifest_application = apply_layout_manifest_to_module(parse.structs, parse.enums, module_manifest);
    diagnostics = extend_string_lines_checked(diagnostics, manifest_application.diagnostics, "layout application");
    let module_structs = manifest_application.structs;
    let module_enums = manifest_application.enums;
    if trace {
        print.info(
            "test llvm: manifest applied (structs="
            + number_to_string(module_structs.length)
            + " enums="
            + number_to_string(module_enums.length)
            + ")"
        );
    }
    if timing {
        print.info("test llvm: phase=manifest ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let mut imported_structs -> NativeStruct[] = [];
    let mut imported_enums -> NativeEnum[] = [];
    let mut imported_interfaces -> NativeInterface[] = [];
    let mut imported_functions -> NativeFunction[] = [];
    let mut imported_struct_methods -> NativeFunction[] = [];

    let manifest_count = imported_manifests.length;
    let mut text_index -> number = 0;
    loop {
        if text_index >= imported_native_texts.length {
            break;
        }
        let native_text = imported_native_texts[text_index];
        let mut manifest_for_module -> LayoutManifest? = null;
        if text_index < manifest_count {
            let candidate_manifest = imported_manifests[text_index];
            manifest_for_module = candidate_manifest;
        }
        if native_text.length == 0 {
            if manifest_for_module != null {
                let manifest_only = manifest_for_module;
                imported_structs = extend_native_structs(imported_structs, manifest_only.structs);
                imported_enums = extend_native_enums(imported_enums, manifest_only.enums);
            }
            text_index += 1;
            continue;
        }

        let imported_parse = parse_native_artifact_for_import_context(native_text);
        let applied_import = apply_layout_manifest_to_module(imported_parse.structs, imported_parse.enums, manifest_for_module);

        imported_structs = extend_native_structs(imported_structs, applied_import.structs);
        imported_enums = extend_native_enums(imported_enums, applied_import.enums);
        imported_interfaces = extend_native_interfaces(imported_interfaces, imported_parse.interfaces);
        imported_functions = extend_native_functions(imported_functions, imported_parse.functions);
        let imported_methods = flatten_struct_methods(applied_import.structs);
        imported_struct_methods = extend_native_functions(imported_struct_methods, imported_methods);
        text_index += 1;
    }

    if imported_native_texts.length < manifest_count {
        let mut manifest_index -> number = imported_native_texts.length;
        loop {
            if manifest_index >= manifest_count {
                break;
            }
            let leftover_manifest = imported_manifests[manifest_index];
            imported_structs = extend_native_structs(imported_structs, leftover_manifest.structs);
            imported_enums = extend_native_enums(imported_enums, leftover_manifest.enums);
            manifest_index += 1;
        }
    }

    let combined_structs = extend_native_structs(module_structs, imported_structs);
    let combined_enums = extend_native_enums(module_enums, imported_enums);
    let mut combined_interfaces = extend_native_interfaces(parse.interfaces, imported_interfaces);
    if is_test_module {
        combined_interfaces = [];
        if trace {
            print.info("test llvm: skipping interface metadata for inlined tests");
        }
    }
    if trace {
        print.info(
            "test llvm: combined types (structs="
            + number_to_string(combined_structs.length)
            + " enums="
            + number_to_string(combined_enums.length)
            + " interfaces="
            + number_to_string(combined_interfaces.length)
            + ")"
        );
    }

    let trait_metadata = build_trait_metadata(combined_interfaces, combined_structs);
    if trace {
        print.info("test llvm: enum layout fixup start");
    }
    let fixed_enums = fixup_enum_layouts(combined_enums);
    diagnostics = extend_string_lines_checked(diagnostics, fixed_enums.diagnostics, "enum layout");
    if trace {
        print.info("test llvm: type context build start");
    }
    let type_build = build_type_context(combined_structs, fixed_enums.enums, combined_interfaces);
    diagnostics = extend_string_lines_checked(diagnostics, type_build.diagnostics, "type context");
    let type_context = type_build.context;
    if trace {
        print.info("test llvm: type context built");
    }
    if timing {
        print.info("test llvm: phase=type_context ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let module_struct_methods = flatten_struct_methods(module_structs);
    let local_functions = concat_native_functions(safe_functions, module_struct_methods);
    let mut context_functions = concat_native_functions(local_functions, imported_functions);
    context_functions = concat_native_functions(context_functions, imported_struct_methods);
    if debug_lowering {
        let mut imported_index -> number = 0;
        loop {
            if imported_index >= imported_functions.length {
                break;
            }
            let imported_function = imported_functions[imported_index];
            if index_of(imported_function.name, "parse_native_artifact") >= 0 || index_of(imported_function.name, "parse_native_function_count_from_text") >= 0 {
                print.warn("emit-llvm: imported fn sig " + imported_function.name + " -> " + imported_function.return_type);
            }
            imported_index += 1;
        }
    }

    // Bootstrap guard: effect analysis currently introduces instability in
    // selfhost/native lowering for some modules. Keep disabled by default.
    let skip_effects = true;
    let mut runtime_helpers -> string[] = [];
    if !is_test_module && !skip_effects {
        if debug_lowering {
            print.warn("emit-llvm: phase=helpers_start");
        }
        runtime_helpers = collect_runtime_helper_targets(local_functions);
        if debug_lowering {
            print.warn("emit-llvm: phase=helpers_done");
        }
    } else if trace {
        print.info("test llvm: skipping runtime helper collection for inlined tests");
    }
    if !string_array_contains(runtime_helpers, "copy_bytes") {
        runtime_helpers = append_string(runtime_helpers, "copy_bytes");
    }
    if !string_array_contains(runtime_helpers, "array_push_slot") {
        runtime_helpers = append_string(runtime_helpers, "array_push_slot");
    }
    if !string_array_contains(runtime_helpers, "append_string") {
        runtime_helpers = append_string(runtime_helpers, "append_string");
    }
    runtime_helpers = append_unique_effect(runtime_helpers, "get_field");
    runtime_helpers = append_unique_effect(runtime_helpers, "print.info");
    runtime_helpers = append_unique_effect(runtime_helpers, "print.warn");
    runtime_helpers = append_unique_effect(runtime_helpers, "print.error");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.length");
    runtime_helpers = append_unique_effect(runtime_helpers, "substring");
    runtime_helpers = append_unique_effect(runtime_helpers, "substring_unchecked");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.to_number");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.length");
    runtime_helpers = append_unique_effect(runtime_helpers, "substring");
    runtime_helpers = append_unique_effect(runtime_helpers, "substring_unchecked");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.concat");
    runtime_helpers = append_unique_effect(runtime_helpers, "grapheme_at");
    runtime_helpers = append_unique_effect(runtime_helpers, "number.to_string");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.to_number");
    runtime_helpers = append_unique_effect(runtime_helpers, "strings_equal");
    runtime_helpers = append_unique_effect(runtime_helpers, "runtime_raise_value_error_fn");
    runtime_helpers = append_unique_effect(runtime_helpers, "runtime.bounds_check");
    runtime_helpers = append_unique_effect(runtime_helpers, "mark_persistent");
    let mut direct_effects -> FunctionEffectEntry[] = [];
    let mut aggregated_effects -> FunctionEffectEntry[] = [];
    if !skip_effects {
        if debug_lowering {
            print.warn("emit-llvm: phase=direct_effects");
        }
        direct_effects = collect_direct_function_effects(context_functions);
        aggregated_effects = direct_effects;
        if !is_test_module {
            let call_graph = collect_function_call_graph(context_functions);
            aggregated_effects = propagate_function_effects(direct_effects, call_graph);
        } else if trace {
            print.info("test llvm: skipping effect propagation for inlined tests");
        }
    }
    if trace {
        print.info("test llvm: runtime helpers collected");
    }
    if timing {
        print.info("test llvm: phase=effects ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let mut function_effects -> FunctionEffectEntry[] = [];
    let mut lifetime_regions -> LifetimeRegionMetadata[] = [];
    let mut lines -> string[] = [];
    lines = append_string(lines, "source_filename = \"" + module_source_filename(native_module.module_name) + "\"");
    lines = append_string(lines, "");

    let trait_lines = render_trait_metadata_comments(trait_metadata);
    if trait_lines != null {
        if trait_lines.length > 0 {
        lines = extend_string_lines(lines, trait_lines);
        lines = append_string(lines, "");
        }
    }

    let struct_type_lines = render_struct_type_definitions(type_context, context_functions);
    if struct_type_lines != null {
        if struct_type_lines.length > 0 {
        lines = extend_string_lines(lines, struct_type_lines);
        lines = append_string(lines, "");
        }
    }

    let mut enum_type_lines -> string[] = [];
    if type_context.enums != null && type_context.enums.length > 0 {
        enum_type_lines = render_enum_type_definitions(type_context);
    }
    if enum_type_lines != null {
        if enum_type_lines.length > 0 {
        lines = extend_string_lines(lines, enum_type_lines);
        lines = append_string(lines, "");
        }
    }

    let mut interface_type_lines -> string[] = [];
    if type_context.interfaces != null && type_context.interfaces.length > 0 {
        interface_type_lines = render_interface_type_definitions(type_context);
    }
    if interface_type_lines != null {
        if interface_type_lines.length > 0 {
        lines = extend_string_lines(lines, interface_type_lines);
        lines = append_string(lines, "");
        }
    }

    lines = extend_string_lines(lines, [
        "%SailfinFutureNumber = type opaque",
        "%SailfinFutureBool = type opaque",
        "%SailfinFuturePtr = type opaque",
        "%SailfinFutureVoid = type opaque",
        "%SailfinFutureString = type opaque",
        "",
        "declare %SailfinFutureNumber* @sailfin_runtime_spawn_number(double ()*)",
        "declare %SailfinFutureNumber* @sailfin_runtime_spawn_number_ctx(double (i8*)*, i8*)",
        "declare double @sailfin_runtime_await_number(%SailfinFutureNumber*)",
        "declare %SailfinFutureBool* @sailfin_runtime_spawn_bool(i1 ()*)",
        "declare %SailfinFutureBool* @sailfin_runtime_spawn_bool_ctx(i1 (i8*)*, i8*)",
        "declare i1 @sailfin_runtime_await_bool(%SailfinFutureBool*)",
        "declare %SailfinFuturePtr* @sailfin_runtime_spawn_ptr(i8* ()*)",
        "declare %SailfinFuturePtr* @sailfin_runtime_spawn_ptr_ctx(i8* (i8*)*, i8*)",
        "declare i8* @sailfin_runtime_await_ptr(%SailfinFuturePtr*)",
        "declare %SailfinFutureVoid* @sailfin_runtime_spawn_void(void ()*)",
        "declare %SailfinFutureVoid* @sailfin_runtime_spawn_void_ctx(void (i8*)*, i8*)",
        "declare void @sailfin_runtime_await_void(%SailfinFutureVoid*)",
        "declare %SailfinFutureString* @sailfin_runtime_spawn_string(i8* ()*)",
        "declare %SailfinFutureString* @sailfin_runtime_spawn_string_ctx(i8* (i8*)*, i8*)",
        "declare i8* @sailfin_runtime_await_string(%SailfinFutureString*)",
        "",
    ]);

    let vtable_type_lines = render_vtable_type_definitions(type_context);
    if vtable_type_lines.length > 0 {
        lines = extend_string_lines(lines, vtable_type_lines);
        lines = append_string(lines, "");
    }

    let vtable_const_lines = render_vtable_constants(type_context);
    if vtable_const_lines.length > 0 {
        lines = extend_string_lines(lines, vtable_const_lines);
        lines = append_string(lines, "");
    }

    let helper_declarations = render_runtime_helper_declarations(runtime_helpers, local_functions);
    if helper_declarations.length > 0 {
        lines = extend_string_lines(lines, helper_declarations);
        lines = append_string(lines, "");
    }

    let imported_declarations = render_imported_function_declarations(imported_functions, local_functions, type_context);
    if imported_declarations.length > 0 {
        lines = extend_string_lines(lines, imported_declarations);
        lines = append_string(lines, "");
    }

    if find_function_by_name(context_functions, "malloc") == null {
        lines = append_string(lines, "declare noalias i8* @malloc(i64)");
    }
    if find_function_by_name(context_functions, "free") == null {
        lines = append_string(lines, "declare void @free(i8*)");
    }
    lines = append_string(lines, "");

    lines = append_string(lines, "@runtime = external global i8**");
    lines = append_string(lines, "");

    let module_globals = lower_module_bindings_to_globals(parse.bindings, type_context, native_module.module_name);
    diagnostics = extend_string_lines_checked(diagnostics, module_globals.diagnostics, "module globals");
    if module_globals.preamble_lines.length > 0 {
        lines = extend_string_lines(lines, module_globals.preamble_lines);
        lines = append_string(lines, "");
    }

    if module_globals.init_function_lines.length > 0 {
        lines = extend_string_lines(lines, module_globals.init_function_lines);
        lines = append_string(lines, "");
    }
    if trace {
        print.info("test llvm: module globals lowered");
    }
    if timing {
        print.info("test llvm: phase=globals ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let mut index -> number = 0;
    let mut has_add_function -> boolean = false;
    let mut all_string_constants -> StringConstant[] = module_globals.string_constants;
    if trace {
        print.info("test llvm: lowering functions start (count=" + number_to_string(local_functions.length) + ")");
    }
    loop {
        if index >= local_functions.length {
            break;
        }
        let current_function = local_functions[index];
        let aggregated_entry = find_function_effect_entry(aggregated_effects, current_function.name);
        let mut effective_effects -> string[] = [];
        if aggregated_entry != null {
            effective_effects = aggregated_entry.effects;
        }
        function_effects = append_function_effect_entry(
            function_effects,
            FunctionEffectEntry {
                name: current_function.name,
                effects: effective_effects,
            }
        );
        let lowered = emit_llvm_function(
            current_function,
            context_functions,
            effective_effects,
            type_context,
            native_module.module_name,
            native_module.entry_points,
            exported_symbols,
            imported_functions,
            module_globals.locals,
            module_globals.init_function_symbol,
            module_globals.needs_init_call
        );
        if sanitize_symbol(current_function.name) == "add" {
            has_add_function = true;
        }
        diagnostics = extend_string_lines_checked(diagnostics, lowered.diagnostics, "function lowering");
        if lowered.lines.length > 0 {
            lines = append_string_lines(lines, lowered.lines);
            if index + 1 < local_functions.length {
                lines = append_string(lines, "");
            }
        }
        if lowered.string_constants.length > 0 {
            let existing_constants = all_string_constants;
            all_string_constants = merge_string_constants(existing_constants, lowered.string_constants);
        }
        index += 1;
    }

    if !has_add_function {
        lines = append_string(lines, "");
        lines = extend_string_lines(lines, [
            "define internal double @add(double %a, double %b) {",
            "entry:",
            "  %t0 = fadd double %a, %b",
            "  ret double %t0",
            "}"
        ]);
    }

    let string_constant_lines = render_string_constants(all_string_constants);
    if string_constant_lines.length > 0 {
        lines = append_string(lines, "");
        lines = append_string_lines(lines, string_constant_lines);
        lines = append_string(lines, "");
    }

    lines = ensure_intrinsic_declarations(lines);

    // Apply test harness when appropriate (no user main).
    let mut tests -> NativeFunction[] = [];
    let mut has_main -> boolean = false;
    let mut t_index -> number = 0;
    loop {
        if t_index >= parse.functions.length {
            break;
        }
        let fun = parse.functions[t_index];
        if fun.name == "main" {
            has_main = true;
        }
        if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
            tests = tests.push(fun);
        }
        t_index += 1;
    }
    if tests.length > 0 && !has_main {
        let harness = render_test_harness_main_for_module(tests, native_module.module_name, false);
        if lines.length > 0 {
            lines = append_string(lines, "");
        }
        lines = extend_string_lines(lines, harness);
    }

    if trace {
        print.info("test llvm: final lines=" + number_to_string(lines.length));
    }
    if lines.length == 0 {
        print.warn("test llvm: no lines emitted (functions=" + number_to_string(parse.functions.length) + ")");
        return false;
    }
    let mut ir = join_with_separator(lines, "\n");
    if trace {
        print.info("test llvm: joined ir bytes=" + number_to_string(ir.length));
    }
    if ir.length == 0 {
        print.warn("test llvm: empty ir after join (lines=" + number_to_string(lines.length) + ")");
        return false;
    }
    ir = ir + "\n";
    let mut target_path -> string = out_path;
    if target_path.length == 0 || index_of(target_path, ".ll") < 0 {
        target_path = "build/sailfin/test.ll";
    }
    fs.writeFile(target_path, ir);
    return true;
}

// Build and write LLVM IR for tests from raw native text, avoiding NativeModule ABI issues.
fn write_llvm_ir_for_tests_from_text(native_text -> string, module_name -> string, out_path -> string) -> boolean ![io] {
    if native_text.length == 0 {
        print.warn("test llvm: empty native text");
        return false;
    }
    let parse = parse_native_artifact_with_retry(native_text, 3);
    let dummy_module = NativeModule {
        module_name: module_name,
        artifacts: [NativeArtifact { name: module_name, format: "sailfin-native-text", contents: native_text }],
        entry_points: [],
        symbol_count: 0,
    };
    let lowered_lines = lower_to_llvm_lines_with_parsed_context_for_tests(
        dummy_module,
        parse,
        [],
        [],
        []
    );
    if lowered_lines.lines.length == 0 {
        print.warn("test llvm: no lines emitted from native text");
        return false;
    }
    let ir = _join_llvm_lines_linear(lowered_lines.lines);
    if ir.length == 0 {
        print.warn("test llvm: empty IR after join from native text");
        return false;
    }
    fs.writeFile(out_path, ir + "\n");
    return true;
}

// Build LLVM IR from raw native text (non-test path), avoiding NativeModule ABI issues.
fn lower_to_llvm_ir_from_text(native_text -> string, module_name -> string) -> string ![io] {
    if native_text.length == 0 {
        return "";
    }
    let parse = parse_native_artifact(native_text);
    let import_context = collect_imported_module_context_for_module(parse.imports, module_name);
    let dummy_module = NativeModule {
        module_name: module_name,
        artifacts: [NativeArtifact { name: module_name, format: "sailfin-native-text", contents: native_text }],
        entry_points: [],
        symbol_count: 0,
    };
    let lowered_lines = lower_to_llvm_lines_with_parsed_context(
        dummy_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics,
        true,
        native_text
    );
    if lowered_lines.lines == null || lowered_lines.lines.length == 0 {
        print.warn(
            "emit-llvm: no lines from native text (functions="
            + number_to_string(parse.functions.length)
            + " structs="
            + number_to_string(parse.structs.length)
            + " enums="
            + number_to_string(parse.enums.length)
            + " diagnostics="
            + number_to_string(parse.diagnostics.length)
            + ")"
        );
        return "";
    }
    return _join_llvm_lines_linear(lowered_lines.lines);
}

// Build and write LLVM IR with module symbol mangling for non-test usage.
// Avoids returning large structs/arrays across boundaries.
fn write_llvm_ir(native_module -> NativeModule, out_path -> string) -> boolean ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return false;
    }
    let parse = parse_native_artifact(artifact.contents);
    let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
    let lowered_lines = lower_to_llvm_lines_with_parsed_context(
        native_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics,
        true,
        ""
    );
    let lines = lowered_lines.lines;
    if lines.length == 0 {
        print.warn(
            "emit-llvm: no lines from module (module="
            + native_module.module_name
            + " functions="
            + number_to_string(parse.functions.length)
            + " imports="
            + number_to_string(parse.imports.length)
            + " diagnostics="
            + number_to_string(lowered_lines.diagnostics.length)
            + ")"
        );
        if lowered_lines.diagnostics.length > 0 {
            print.warn("emit-llvm: diagnostic " + lowered_lines.diagnostics[0]);
        }
        return false;
    }
    return write_llvm_lines_chunked(out_path, lines);
}

// Build and write LLVM IR from a native text file, avoiding large string returns.
fn write_llvm_ir_from_native_text_file(native_text_path -> string, module_name -> string, out_path -> string) -> boolean ![io] {
    if !fs.exists(native_text_path) {
        print.warn("emit-llvm: native text file missing at " + native_text_path);
        return false;
    }
    let native_text = fs.readFile(native_text_path);
    if native_text.length == 0 {
        print.warn("emit-llvm: native text file empty at " + native_text_path);
        return false;
    }
    print.warn(
        "emit-llvm: write_llvm_ir_from_native_text_file module="
        + module_name
        + " bytes="
        + number_to_string(native_text.length)
    );
    print.warn("emit-llvm: before parse");
    let mut parse = parse_native_artifact(native_text);
    print.warn("emit-llvm: after parse");
    let direct_function_count = parse_native_function_count_from_text(native_text);
    let mut parsed_function_count = parse.functions.length;
    if parsed_function_count != parsed_function_count || parsed_function_count < 0 {
        parsed_function_count = 0;
    }
    if parsed_function_count == 0 || (direct_function_count > 0 && parsed_function_count != direct_function_count) {
        let mut fallback_functions = parse_native_functions_from_text(native_text);
        if fallback_functions.length == 0 {
            fallback_functions = recover_native_functions_light(native_text);
        }
        if fallback_functions.length > 0 {
            parse = ParseNativeResult {
                functions: fallback_functions,
                imports: parse.imports,
                structs: parse.structs,
                interfaces: parse.interfaces,
                enums: parse.enums,
                bindings: parse.bindings,
                diagnostics: parse.diagnostics,
            };
        }
    }
    print.warn("emit-llvm: parsed function array len=" + number_to_string(parse.functions.length));
    print.warn("emit-llvm: direct function count=" + number_to_string(direct_function_count));
    print.warn(
        "emit-llvm: parse counts immediate (functions="
        + number_to_string(parse.functions.length)
        + " imports="
        + number_to_string(parse.imports.length)
        + " structs="
        + number_to_string(parse.structs.length)
        + " enums="
        + number_to_string(parse.enums.length)
        + ")"
    );
    if fs.exists("build/sailfin/.trace_emit") || fs.exists("build/sailfin/.trace_lowering") {
        print.warn(
            "emit-llvm: parsed native text (functions="
            + number_to_string(parse.functions.length)
            + " imports="
            + number_to_string(parse.imports.length)
            + " structs="
            + number_to_string(parse.structs.length)
            + " enums="
            + number_to_string(parse.enums.length)
            + ")"
        );
    }
    if parse.functions.length == 0 {
        print.warn(
            "emit-llvm: native parse produced no functions (structs="
            + number_to_string(parse.structs.length)
            + " enums="
            + number_to_string(parse.enums.length)
            + " diagnostics="
            + number_to_string(parse.diagnostics.length)
            + ")"
        );
        if parse.diagnostics.length > 0 {
            print.warn("emit-llvm: parse diagnostic " + parse.diagnostics[0]);
        }
    }

    if parse.functions.length == 0 && direct_function_count > 0 {
        let recovered_functions = recover_native_functions_light(native_text);
        if recovered_functions.length > 0 {
            print.warn("emit-llvm: using light recovery fallback functions=" + number_to_string(recovered_functions.length));
            let synthetic_parse = ParseNativeResult {
                functions: recovered_functions,
                imports: [],
                structs: [],
                interfaces: [],
                enums: [],
                bindings: [],
                diagnostics: parse.diagnostics,
            };
            let synthetic_module = NativeModule {
                module_name: module_name,
                artifacts: [],
                entry_points: [],
                symbol_count: 0,
            };
            let lowered_light = lower_to_llvm_lines_with_parsed_context(
                synthetic_module,
                synthetic_parse,
                [],
                [],
                [],
                true,
                ""
            );
            if lowered_light.lines != null && lowered_light.lines.length > 0 {
                return write_llvm_lines_chunked(out_path, lowered_light.lines);
            }
        }
    }
    if fs.exists("build/sailfin/.trace_lowering") {
        print.warn(
            "emit-llvm: parsed counts before lowering (functions="
            + number_to_string(parse.functions.length)
            + " imports="
            + number_to_string(parse.imports.length)
            + " structs="
            + number_to_string(parse.structs.length)
            + ")"
        );
    }
    print.warn("emit-llvm: before import context");
    let mut import_context -> ImportedModuleContext = ImportedModuleContext { manifests: [], native_texts: [], diagnostics: [] };
    if fs.exists("build/sailfin/.skip_import_context") {
        print.warn("emit-llvm: skipping import context collection");
    } else {
        import_context = collect_imported_module_context_for_module(parse.imports, module_name);
    }
    print.warn("emit-llvm: after import context");
    let dummy_module = NativeModule {
        module_name: module_name,
        artifacts: [NativeArtifact { name: module_name, format: "sailfin-native-text", contents: native_text }],
        entry_points: [],
        symbol_count: 0,
    };
    let lowered_lines = lower_to_llvm_lines_with_parsed_context(
        dummy_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics,
        true,
        ""
    );
    if lowered_lines.lines == null {
        print.warn("emit-llvm: lowered lines null");
        return false;
    }
    if parse.functions.length > 0 {
        let defined = collect_defined_function_symbols(lowered_lines.lines);
        if defined.length < parse.functions.length {
            print.warn(
                "emit-llvm: lowered function count mismatch (parsed="
                + number_to_string(parse.functions.length)
                + " defined="
                + number_to_string(defined.length)
                + ")"
            );
            if defined.length == 0 {
                return false;
            }
        }
    }
    print.warn("emit-llvm: lowered lines count=" + number_to_string(lowered_lines.lines.length));
    if lowered_lines.lines.length > 0 {
        print.warn("emit-llvm: first line len=" + number_to_string(lowered_lines.lines[0].length));
    }
    if fs.exists("build/sailfin/.trace_lowering") {
        let mut nonempty -> number = 0;
        let mut idx -> number = 0;
        loop {
            if idx >= lowered_lines.lines.length {
                break;
            }
            if lowered_lines.lines[idx].length > 0 {
                nonempty += 1;
            }
            idx += 1;
        }
        print.warn("emit-llvm: nonempty lines=" + number_to_string(nonempty));
        if lowered_lines.lines.length > 1 {
            print.warn("emit-llvm: second line len=" + number_to_string(lowered_lines.lines[1].length));
        }
        if lowered_lines.lines.length > 0 {
            let last_index = lowered_lines.lines.length - 1;
            print.warn("emit-llvm: last line len=" + number_to_string(lowered_lines.lines[last_index].length));
        }
    }
    let lines = lowered_lines.lines;
    if lines == null || lines.length == 0 {
        print.warn(
            "emit-llvm: lowering produced no lines (functions="
            + number_to_string(parse.functions.length)
            + " structs="
            + number_to_string(parse.structs.length)
            + " enums="
            + number_to_string(parse.enums.length)
            + " diagnostics="
            + number_to_string(lowered_lines.diagnostics.length)
            + ")"
        );
        if lowered_lines.diagnostics.length > 0 {
            print.warn("emit-llvm: lowering diagnostic " + lowered_lines.diagnostics[0]);
        }
        return false;
    }
    if fs.exists(out_path) {
        fs.deleteFile(out_path);
    }
    return write_llvm_lines_chunked(out_path, lines);
}

fn lower_to_llvm_with_manifests(native_module -> NativeModule, imported_manifests -> LayoutManifest[]) -> LoweredLLVMResult {
    return lower_to_llvm_with_context(native_module, imported_manifests, [], []);
}

fn lower_to_llvm_with_context_for_tests(native_module -> NativeModule, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let base = lower_to_llvm_with_context(native_module, imported_manifests, imported_native_texts, imported_diagnostics);
    if base.ir.length == 0 {
        return base;
    }

    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return base;
    }

    let parse = parse_native_artifact(artifact.contents);
    let mut tests -> NativeFunction[] = [];
    let mut has_main -> boolean = false;

    let mut index -> number = 0;
    loop {
        if index >= parse.functions.length {
            break;
        }
        let fun = parse.functions[index];
        if fun.name == "main" {
            has_main = true;
        }
        if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
            tests = tests.push(fun);
        }
        index += 1;
    }

    if tests.length == 0 {
        return base;
    }

    // For now we only synthesize `main` when no user-provided `main` exists.
    if has_main {
        let mut updated = base;
        updated.diagnostics = updated.diagnostics.concat([
            "llvm lowering (test): module defines `main`; skipping synthesized test harness",
        ]);
        return updated;
    }

    let harness = render_test_harness_main_for_module(tests, native_module.module_name, false);
    let mut updated = base;
    if updated.ir.length > 0 {
        updated.ir = updated.ir + "\n";
    }
    updated.ir = updated.ir + join_with_separator(harness, "\n") + "\n";
    return updated;
}

fn lower_to_llvm_with_parsed_context(native_module -> NativeModule, parse -> ParseNativeResult, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let lowered = lower_to_llvm_lines_with_parsed_context(native_module, parse, imported_manifests, imported_native_texts, imported_diagnostics, true, "");
    if lowered.lines == null {
        return LoweredLLVMResult {
            ir: "",
            diagnostics: append_string(lowered.diagnostics, "llvm lowering: emitted null line list"),
            trait_metadata: lowered.trait_metadata,
            function_effects: lowered.function_effects,
            lifetime_regions: lowered.lifetime_regions,
            capability_manifest: lowered.capability_manifest,
            string_constants: lowered.string_constants,
        };
    }
    let ir = _join_llvm_lines_linear(lowered.lines);
    let mut output -> string = ir;
    if output.length > 0 {
        output = output + "\n";
    }
    return LoweredLLVMResult {
        ir: output,
        diagnostics: lowered.diagnostics,
        trait_metadata: lowered.trait_metadata,
        function_effects: lowered.function_effects,
        lifetime_regions: lowered.lifetime_regions,
        capability_manifest: lowered.capability_manifest,
        string_constants: lowered.string_constants,
    };
}

fn lower_to_llvm_with_parsed_context_for_tests(native_module -> NativeModule, parse -> ParseNativeResult, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let base = lower_to_llvm_with_parsed_context(native_module, parse, imported_manifests, imported_native_texts, imported_diagnostics);
    if base.ir.length == 0 {
        print.warn(
            "test llvm: base IR empty (functions=" + number_to_string(parse.functions.length)
            + " imports=" + number_to_string(parse.imports.length)
            + " structs=" + number_to_string(parse.structs.length)
            + " diagnostics=" + number_to_string(base.diagnostics.length)
            + ")"
        );
        if base.diagnostics.length > 0 {
            print.warn("test llvm: diagnostic " + base.diagnostics[0]);
        }
        return base;
    }

    let mut tests -> NativeFunction[] = [];
    let mut has_main -> boolean = false;

    let mut index -> number = 0;
    loop {
        if index >= parse.functions.length {
            break;
        }
        let fun = parse.functions[index];
        if fun.name == "main" {
            has_main = true;
        }
        if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
            tests = tests.push(fun);
        }
        index += 1;
    }

    if tests.length == 0 {
        return base;
    }

    // For now we only synthesize `main` when no user-provided `main` exists.
    if has_main {
        let mut updated = base;
        updated.diagnostics = updated.diagnostics.concat([
            "llvm lowering (test): module defines `main`; skipping synthesized test harness",
        ]);
        return updated;
    }

    let harness = render_test_harness_main_for_module(tests, native_module.module_name, false);
    let mut updated = base;
    if updated.ir.length > 0 {
        updated.ir = updated.ir + "\n";
    }
    updated.ir = updated.ir + join_with_separator(harness, "\n") + "\n";
    return updated;
}

fn lower_to_llvm_lines_with_parsed_context_for_tests(native_module -> NativeModule, parse -> ParseNativeResult, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMLinesResult {
    let base = lower_to_llvm_lines_with_parsed_context(native_module, parse, imported_manifests, imported_native_texts, imported_diagnostics, false, "");
    if base.lines.length == 0 {
        return base;
    }

    let mut tests -> NativeFunction[] = [];
    let mut has_main -> boolean = false;

    let mut index -> number = 0;
    loop {
        if index >= parse.functions.length {
            break;
        }
        let fun = parse.functions[index];
        if fun.name == "main" {
            has_main = true;
        }
        if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
            tests = tests.push(fun);
        }
        index += 1;
    }

    if tests.length == 0 {
        return base;
    }

    if has_main {
        let mut updated = base;
        updated.diagnostics = updated.diagnostics.concat([
            "llvm lowering (test): module defines `main`; skipping synthesized test harness",
        ]);
        return updated;
    }

    let harness = render_test_harness_main_for_module(tests, native_module.module_name, false);
    let mut updated = base;
    if updated.lines.length > 0 {
        updated.lines = append_string(updated.lines, "");
    }
    updated.lines = extend_string_lines(updated.lines, harness);
    return updated;
}

fn lower_to_llvm_with_context(native_module -> NativeModule, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let lowered = lower_to_llvm_lines_with_context(native_module, imported_manifests, imported_native_texts, imported_diagnostics);
    let ir = _join_llvm_lines_linear(lowered.lines);
    let mut output -> string = ir;
    if output.length > 0 {
        output = output + "\n";
    }
    return LoweredLLVMResult {
        ir: output,
        diagnostics: lowered.diagnostics,
        trait_metadata: lowered.trait_metadata,
        function_effects: lowered.function_effects,
        lifetime_regions: lowered.lifetime_regions,
        capability_manifest: lowered.capability_manifest,
        string_constants: lowered.string_constants,
    };
}

fn _join_llvm_lines_linear(lines -> string[]) -> string {
    if lines == null {
        return "";
    }
    if lines.length == 0 {
        return "";
    }
    let mut out -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        if index > 0 {
            out = out + "\n";
        }
        out = out + lines[index];
        index += 1;
    }
    return out;
}

fn lower_to_llvm_lines_with_context(native_module -> NativeModule, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMLinesResult {
    let mut diagnostics -> string[] = [];
    if imported_diagnostics.length > 0 {
        diagnostics = diagnostics.concat(imported_diagnostics);
    }
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        diagnostics = append_string(diagnostics, "no sailfin-native-text artifact present");
        let empty_constants = empty_string_constant_set();
        return LoweredLLVMLinesResult {
            lines: [],
            diagnostics: diagnostics,
            trait_metadata: empty_trait_metadata(),
            function_effects: [],
            lifetime_regions: [],
            capability_manifest: empty_capability_manifest(),
            string_constants: empty_constants,
        };
    }

    let parse = parse_native_artifact(artifact.contents);
    return lower_to_llvm_lines_with_parsed_context(native_module, parse, imported_manifests, imported_native_texts, diagnostics, true, "");
}

fn lower_to_llvm_lines_with_parsed_context(native_module -> NativeModule, parse_in -> ParseNativeResult, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], diagnostics_in -> string[], mangle_symbols -> boolean, native_text_override_path -> string) -> LoweredLLVMLinesResult ![io] {
    let debug_lowering = fs.exists("build/sailfin/.trace_lowering");
    if debug_lowering {
        print.warn("emit-llvm: phase=start");
    }
    if debug_lowering {
        let mut artifact_count -> number = 0;
        if native_module.artifacts != null {
            artifact_count = native_module.artifacts.length;
        }
        print.warn("emit-llvm: native artifacts=" + number_to_string(artifact_count));
    }
    let mut parse = parse_in;
    // Keep this lowering path dependent on explicit parsed context and optional
    // override text only. Accessing `native_module.artifacts` here has caused
    // stage2 instability on some selfhost paths.
    let artifact_for_stable_parse -> NativeArtifact? = null;
    if native_text_override_path.length > 0 {
        let reparsed = parse_native_artifact(native_text_override_path);
        if reparsed.functions.length >= parse.functions.length {
            parse = reparsed;
        }
        if debug_lowering {
            print.warn("emit-llvm: reparsed from override text functions=" + number_to_string(parse.functions.length));
            print.warn("emit-llvm: reparsed from override diagnostics=" + number_to_string(parse.diagnostics.length));
            if parse.diagnostics.length > 0 {
                print.warn("emit-llvm: reparsed diagnostic " + parse.diagnostics[0]);
            }
        }
    } else if artifact_for_stable_parse != null && artifact_for_stable_parse.contents.length > 0 {
        if debug_lowering {
            print.warn("emit-llvm: artifact text bytes=" + number_to_string(artifact_for_stable_parse.contents.length));
            print.warn("emit-llvm: artifact direct function count=" + number_to_string(parse_native_function_count_from_text(artifact_for_stable_parse.contents)));
        }
        let reparsed = parse_native_artifact(artifact_for_stable_parse.contents);
        if reparsed.functions.length >= parse.functions.length {
            parse = reparsed;
        }
        if debug_lowering {
            print.warn("emit-llvm: reparsed from artifact text functions=" + number_to_string(parse.functions.length));
            print.warn("emit-llvm: reparsed from artifact diagnostics=" + number_to_string(parse.diagnostics.length));
            if parse.diagnostics.length > 0 {
                print.warn("emit-llvm: reparsed diagnostic " + parse.diagnostics[0]);
            }
        }
    }
    let mut safe_imported_manifests = imported_manifests;
    if safe_imported_manifests == null {
        safe_imported_manifests = [];
    }
    if safe_imported_manifests.length != sanitize_collection_length(safe_imported_manifests.length, 100000) {
        safe_imported_manifests = [];
    }
    let mut safe_imported_native_texts = imported_native_texts;
    if safe_imported_native_texts == null {
        safe_imported_native_texts = [];
    }
    if safe_imported_native_texts.length != sanitize_collection_length(safe_imported_native_texts.length, 100000) {
        safe_imported_native_texts = [];
    }
    let mut safe_imported_diagnostics = diagnostics_in;
    if safe_imported_diagnostics == null {
        safe_imported_diagnostics = [];
    }
    if safe_imported_diagnostics.length != sanitize_collection_length(safe_imported_diagnostics.length, 1000000) {
        safe_imported_diagnostics = [];
    }
    let mut diagnostics = safe_imported_diagnostics;
    let mut safe_entry_points = native_module.entry_points;
    if safe_entry_points == null {
        safe_entry_points = [];
    }
    if safe_entry_points.length != sanitize_collection_length(safe_entry_points.length, 100000) {
        safe_entry_points = [];
    }
    let mut safe_imports = parse.imports;
    if safe_imports == null {
        safe_imports = [];
    }
    if safe_imports.length != sanitize_collection_length(safe_imports.length, 100000) {
        safe_imports = [];
    }
    if safe_imports.length > 100000 {
        if debug_lowering {
            print.warn("emit-llvm: import list too large; dropping");
        }
        safe_imports = [];
    }
    let mut safe_structs = parse.structs;
    if safe_structs == null {
        safe_structs = [];
    }
    if safe_structs.length != sanitize_collection_length(safe_structs.length, 100000) {
        safe_structs = [];
    }
    if safe_structs.length > 100000 {
        diagnostics = append_string(diagnostics, "llvm lowering: struct list too large (" + number_to_string(safe_structs.length) + "); dropping");
        safe_structs = [];
    }
    let mut safe_enums = parse.enums;
    if safe_enums == null {
        safe_enums = [];
    }
    if safe_enums.length != sanitize_collection_length(safe_enums.length, 100000) {
        safe_enums = [];
    }
    if safe_enums.length > 100000 {
        diagnostics = append_string(diagnostics, "llvm lowering: enum list too large (" + number_to_string(safe_enums.length) + "); dropping");
        safe_enums = [];
    }
    let mut safe_interfaces = parse.interfaces;
    if safe_interfaces == null {
        safe_interfaces = [];
    }
    if safe_interfaces.length != sanitize_collection_length(safe_interfaces.length, 100000) {
        safe_interfaces = [];
    }
    if safe_interfaces.length > 100000 {
        diagnostics = append_string(diagnostics, "llvm lowering: interface list too large (" + number_to_string(safe_interfaces.length) + "); dropping");
        safe_interfaces = [];
    }
    let mut safe_functions = parse.functions;
    if debug_lowering && safe_functions == null {
        print.warn("emit-llvm: parse.functions is null");
    }
    if safe_functions == null {
        safe_functions = [];
    }
    if safe_functions.length != sanitize_collection_length(safe_functions.length, 200000) {
        if debug_lowering {
            print.warn("emit-llvm: parse.functions has invalid length; dropping");
        }
        safe_functions = [];
    }
    if safe_functions.length == 0 {
        let mut recovery_text = "";
        if native_text_override_path.length > 0 {
            recovery_text = native_text_override_path;
        } else if artifact_for_stable_parse != null {
            recovery_text = artifact_for_stable_parse.contents;
        }
        if recovery_text.length == 0 && fs.exists("build/sailfin/emit-native.tmp") {
            recovery_text = fs.readFile("build/sailfin/emit-native.tmp");
        }
        if recovery_text.length > 0 {
            let mut recovered_functions = parse_native_functions_from_text(recovery_text);
            let mut recovered_has_body = false;
            let mut recovered_index -> number = 0;
            loop {
                if recovered_index >= recovered_functions.length {
                    break;
                }
                let recovered_function = recovered_functions[recovered_index];
                if !recovered_function.is_extern && recovered_function.instructions != null && recovered_function.instructions.length > 0 {
                    recovered_has_body = true;
                    break;
                }
                recovered_index += 1;
            }
            if recovered_functions.length == 0 || !recovered_has_body {
                let light_recovered = recover_native_functions_light(recovery_text);
                let mut light_has_body = false;
                recovered_index = 0;
                loop {
                    if recovered_index >= light_recovered.length {
                        break;
                    }
                    let recovered_function = light_recovered[recovered_index];
                    if !recovered_function.is_extern && recovered_function.instructions != null && recovered_function.instructions.length > 0 {
                        light_has_body = true;
                        break;
                    }
                    recovered_index += 1;
                }
                if light_has_body || recovered_functions.length == 0 {
                    recovered_functions = light_recovered;
                }
            }
            if recovered_functions.length > 0 {
                safe_functions = recovered_functions;
                if debug_lowering {
                    print.warn("emit-llvm: recovered empty parse.functions from artifact text count=" + number_to_string(safe_functions.length));
                }
            }
        }
    }
    if safe_functions.length > 200000 {
        diagnostics = append_string(diagnostics, "llvm lowering: function list too large (" + number_to_string(safe_functions.length) + "); dropping");
        safe_functions = [];
    }
    if debug_lowering {
        print.warn("emit-llvm: phase=recover_functions_start current=" + number_to_string(safe_functions.length));
    }
    let mut artifact_text = "";
    if artifact_for_stable_parse != null {
        artifact_text = artifact_for_stable_parse.contents;
    }
    safe_functions = recover_functions_for_lowering(safe_functions, native_text_override_path, artifact_text, debug_lowering);
    if debug_lowering {
        print.warn("emit-llvm: phase=recover_functions_done current=" + number_to_string(safe_functions.length));
    }
    if debug_lowering {
        let mut has_artifact_text = "false";
        if artifact_for_stable_parse != null {
            has_artifact_text = "true";
        }
        print.warn("emit-llvm: fallback precheck has_artifact=" + has_artifact_text + " safe_len=" + number_to_string(safe_functions.length));
        print.warn("emit-llvm: functions parsed=" + number_to_string(parse.functions.length) + " safe=" + number_to_string(safe_functions.length));
        if parse.functions.length == 0 && parse.diagnostics.length > 0 {
            print.warn("emit-llvm: parse diagnostic " + parse.diagnostics[0]);
        }
    }
    let mut safe_bindings = parse.bindings;
    if safe_bindings == null {
        safe_bindings = [];
    }
    if safe_bindings.length != sanitize_collection_length(safe_bindings.length, 200000) {
        safe_bindings = [];
    }
    if safe_bindings.length > 200000 {
        diagnostics = append_string(diagnostics, "llvm lowering: binding list too large (" + number_to_string(safe_bindings.length) + "); dropping");
        safe_bindings = [];
    }
    let mut safe_parse_diagnostics = parse.diagnostics;
    if safe_parse_diagnostics == null {
        safe_parse_diagnostics = [];
    }
    if safe_parse_diagnostics.length != sanitize_collection_length(safe_parse_diagnostics.length, 1000000) {
        safe_parse_diagnostics = [];
    }
    diagnostics = extend_string_lines_checked(diagnostics, safe_parse_diagnostics, "parse");
    let trace = fs.exists("build/sailfin/.trace_test_runner") && fs.exists("build/sailfin/.test_runner_active");
    let timing = fs.exists("build/sailfin/.test_runner_active");
    let start_ms = monotonic_millis();
    let mut is_test_module = is_test_module_slug(native_module.module_name);
    if !is_test_module && fs.exists("build/sailfin/.test_runner_active") {
        is_test_module = true;
    }
    if is_test_module {
        safe_imports = [];
    }
    if trace {
        print.info("test llvm: lower_to_llvm_lines_with_parsed_context start");
    }
    if timing {
        print.info("test llvm: phase=parse ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    // Bootstrap guard: skip exported symbol collection to avoid crashes from
    // corrupted import arrays in stage2.
    let exported_symbols -> string[] = [];

    let mut module_structs = safe_structs;
    let mut module_enums = safe_enums;
    if !is_test_module {
        let mut module_manifest -> LayoutManifest? = null;

        let manifest_application = apply_layout_manifest_to_module(safe_structs, safe_enums, module_manifest);
        diagnostics = extend_string_lines_checked(diagnostics, manifest_application.diagnostics, "layout application");
        module_structs = manifest_application.structs;
        if module_structs == null {
            module_structs = [];
        }
        module_enums = manifest_application.enums;
        if module_enums == null {
            module_enums = [];
        }
        if debug_lowering {
            print.warn("emit-llvm: phase=manifest");
        }
    }
    if timing {
        print.info("test llvm: phase=manifest ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    // Gather imported module context (layout + signatures) to improve lowering fidelity
    let mut imported_structs -> NativeStruct[] = [];
    let mut imported_enums -> NativeEnum[] = [];
    let mut imported_interfaces -> NativeInterface[] = [];
    let mut imported_functions -> NativeFunction[] = [];
    let mut imported_struct_methods -> NativeFunction[] = [];

    let manifest_count = safe_imported_manifests.length;
    let mut text_index -> number = 0;
    loop {
        if text_index >= safe_imported_native_texts.length {
            break;
        }
        let native_text = safe_imported_native_texts[text_index];
        let mut manifest_for_module -> LayoutManifest? = null;
        if text_index < manifest_count {
            let candidate_manifest = safe_imported_manifests[text_index];
            manifest_for_module = candidate_manifest;
        }
        if native_text.length == 0 {
            if manifest_for_module != null {
                let manifest_only = manifest_for_module;
                imported_structs = extend_native_structs(imported_structs, manifest_only.structs);
                imported_enums = extend_native_enums(imported_enums, manifest_only.enums);
            }
            text_index += 1;
            continue;
        }

        let imported_parse = parse_native_artifact_for_import_context(native_text);
        let mut imported_structs_safe = imported_parse.structs;
        if imported_structs_safe == null {
            imported_structs_safe = [];
        }
        let mut imported_enums_safe = imported_parse.enums;
        if imported_enums_safe == null {
            imported_enums_safe = [];
        }
        let mut imported_interfaces_safe = imported_parse.interfaces;
        if imported_interfaces_safe == null {
            imported_interfaces_safe = [];
        }
        let mut imported_functions_safe = imported_parse.functions;
        if imported_functions_safe == null {
            imported_functions_safe = [];
        }
        let applied_import = apply_layout_manifest_to_module(imported_structs_safe, imported_enums_safe, manifest_for_module);

        let mut applied_structs = applied_import.structs;
        if applied_structs == null {
            applied_structs = [];
        }
        let mut applied_enums = applied_import.enums;
        if applied_enums == null {
            applied_enums = [];
        }

        imported_structs = extend_native_structs(imported_structs, applied_structs);
        imported_enums = extend_native_enums(imported_enums, applied_enums);
        imported_interfaces = extend_native_interfaces(imported_interfaces, imported_interfaces_safe);
        imported_functions = extend_native_functions(imported_functions, imported_functions_safe);
        let imported_methods = flatten_struct_methods(applied_structs);
        imported_struct_methods = extend_native_functions(imported_struct_methods, imported_methods);
        text_index += 1;
    }

    if safe_imported_native_texts.length < manifest_count {
        let mut manifest_index -> number = safe_imported_native_texts.length;
        loop {
            if manifest_index >= manifest_count {
                break;
            }
            let leftover_manifest = safe_imported_manifests[manifest_index];
            imported_structs = extend_native_structs(imported_structs, leftover_manifest.structs);
            imported_enums = extend_native_enums(imported_enums, leftover_manifest.enums);
            manifest_index += 1;
        }
    }

    if debug_lowering {
        print.warn("emit-llvm: phase=imports");
    }

    let combined_structs = extend_native_structs(module_structs, imported_structs);
    let combined_enums = extend_native_enums(module_enums, imported_enums);
    let mut combined_interfaces = extend_native_interfaces(safe_interfaces, imported_interfaces);
    if is_test_module {
        combined_interfaces = [];
        if trace {
            print.info("test llvm: skipping interface metadata for inlined tests");
        }
    }

    if trace {
        print.info("test llvm: trait metadata start");
    }
    let trait_metadata = build_trait_metadata(combined_interfaces, combined_structs);
    if debug_lowering {
        print.warn("emit-llvm: phase=trait_metadata");
    }
    if trace {
        print.info("test llvm: enum layout fixup start");
    }
    let fixed_enums = fixup_enum_layouts(combined_enums);
    diagnostics = extend_string_lines_checked(diagnostics, fixed_enums.diagnostics, "enum layout");
    if debug_lowering {
        print.warn("emit-llvm: phase=enum_fixup");
    }
    if trace {
        print.info("test llvm: type context build start");
    }
    let type_build = build_type_context(combined_structs, fixed_enums.enums, combined_interfaces);
    diagnostics = extend_string_lines_checked(diagnostics, type_build.diagnostics, "type context");
    let type_context = type_build.context;
    if trace {
        print.info("test llvm: type context built");
    }
    if debug_lowering {
        print.warn("emit-llvm: phase=type_context");
    }
    if timing {
        print.info("test llvm: phase=type_context ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    if debug_lowering {
        print.warn("emit-llvm: phase=struct_methods_start");
    }
    let module_struct_methods = flatten_struct_methods(module_structs);
    if debug_lowering {
        print.warn("emit-llvm: phase=struct_methods_done");
    }
    let local_functions = concat_native_functions(safe_functions, module_struct_methods);
    if debug_lowering {
        print.warn("emit-llvm: phase=local_functions");
    }
    let mut context_functions = concat_native_functions(local_functions, imported_functions);
    context_functions = concat_native_functions(context_functions, imported_struct_methods);
    if debug_lowering {
        print.warn("emit-llvm: phase=context_functions");
    }

    // Bootstrap guard: effect analysis currently introduces instability in
    // selfhost/native lowering for some modules. Keep disabled by default.
    let skip_effects = true;
    let mut runtime_helpers -> string[] = [];
    if !is_test_module && !skip_effects {
        if debug_lowering {
            print.warn("emit-llvm: phase=helpers_start");
        }
        runtime_helpers = collect_runtime_helper_targets(local_functions);
        if debug_lowering {
            print.warn("emit-llvm: phase=helpers_done");
        }
    } else if trace {
        print.info("test llvm: skipping runtime helper collection for inlined tests");
    }
    // Some lowering paths (e.g. array lowering) emit direct calls to
    // `@sailfin_runtime_copy_bytes` that do not appear in Native IR call targets.
    // Ensure the declaration is always present to keep per-module clang compiles valid.
    if !string_array_contains(runtime_helpers, "copy_bytes") {
        runtime_helpers = append_string(runtime_helpers, "copy_bytes");
    }
    // `lower_array_push_in_place` emits a direct call to `@sailfin_runtime_array_push_slot`.
    // This helper target must be present so we emit the corresponding declaration.
    if !string_array_contains(runtime_helpers, "array_push_slot") {
        runtime_helpers = append_string(runtime_helpers, "array_push_slot");
    }
    // `lower_array_push_in_place` uses `@sailfin_runtime_append_string` for `i8*` arrays.
    // This helper target must be present so we emit the corresponding declaration.
    if !string_array_contains(runtime_helpers, "append_string") {
        runtime_helpers = append_string(runtime_helpers, "append_string");
    }
    runtime_helpers = append_unique_effect(runtime_helpers, "get_field");
    runtime_helpers = append_unique_effect(runtime_helpers, "print.info");
    runtime_helpers = append_unique_effect(runtime_helpers, "print.warn");
    runtime_helpers = append_unique_effect(runtime_helpers, "print.error");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.length");
    runtime_helpers = append_unique_effect(runtime_helpers, "substring");
    runtime_helpers = append_unique_effect(runtime_helpers, "substring_unchecked");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.concat");
    runtime_helpers = append_unique_effect(runtime_helpers, "grapheme_at");
    runtime_helpers = append_unique_effect(runtime_helpers, "number.to_string");
    runtime_helpers = append_unique_effect(runtime_helpers, "strings_equal");
    runtime_helpers = append_unique_effect(runtime_helpers, "runtime_raise_value_error_fn");
    runtime_helpers = append_unique_effect(runtime_helpers, "runtime.bounds_check");
    runtime_helpers = append_unique_effect(runtime_helpers, "mark_persistent");
    let mut direct_effects -> FunctionEffectEntry[] = [];
    let mut aggregated_effects -> FunctionEffectEntry[] = [];
    if !skip_effects {
        if debug_lowering {
            print.warn("emit-llvm: phase=direct_effects");
        }
        direct_effects = collect_direct_function_effects(context_functions);
        aggregated_effects = direct_effects;
        if !is_test_module {
            let call_graph = collect_function_call_graph(context_functions);
            aggregated_effects = propagate_function_effects(direct_effects, call_graph);
        } else if trace {
            print.info("test llvm: skipping effect propagation for inlined tests");
        }
    }
    if trace {
        print.info("test llvm: runtime helpers collected");
    }
    if timing {
        print.info("test llvm: phase=effects ms=" + number_to_string(monotonic_millis() - start_ms));
    }
    if debug_lowering {
        print.warn("emit-llvm: phase=effects");
    }

    let mut function_effects -> FunctionEffectEntry[] = [];
    let mut lifetime_regions -> LifetimeRegionMetadata[] = [];
    let mut lines -> string[] = [];
    lines = append_string(lines, "source_filename = \"" + module_source_filename(native_module.module_name) + "\"");
    lines = append_string(lines, "");

    if debug_lowering {
        print.warn("emit-llvm: phase=render_traits");
    }
    let trait_lines = render_trait_metadata_comments(trait_metadata);
    if trait_lines.length > 0 {
        lines = extend_string_lines(lines, trait_lines);
        lines = append_string(lines, "");
    }

    if debug_lowering {
        print.warn("emit-llvm: phase=render_structs");
        print.warn(
            "emit-llvm: render_structs counts structs="
            + number_to_string(type_context.structs.length)
            + " enums="
            + number_to_string(type_context.enums.length)
            + " functions="
            + number_to_string(context_functions.length)
        );
    }
    let struct_type_lines = render_struct_type_definitions(type_context, context_functions);
    if struct_type_lines.length > 0 {
        lines = extend_string_lines(lines, struct_type_lines);
        lines = append_string(lines, "");
    }

    if debug_lowering {
        print.warn("emit-llvm: phase=render_enums");
    }
    let enum_type_lines = render_enum_type_definitions(type_context);
    if enum_type_lines.length > 0 {
        lines = extend_string_lines(lines, enum_type_lines);
        lines = append_string(lines, "");
    }

    if debug_lowering {
        print.warn("emit-llvm: phase=render_interfaces");
    }
    let interface_type_lines = render_interface_type_definitions(type_context);
    if interface_type_lines.length > 0 {
        lines = extend_string_lines(lines, interface_type_lines);
        lines = append_string(lines, "");
    }

    // Async/future runtime types (opaque in LLVM; implemented by the native runtime).
    lines = extend_string_lines(lines, [
        "%SailfinFutureNumber = type opaque",
        "%SailfinFutureBool = type opaque",
        "%SailfinFuturePtr = type opaque",
        "%SailfinFutureVoid = type opaque",
        "%SailfinFutureString = type opaque",
        "",
        "declare %SailfinFutureNumber* @sailfin_runtime_spawn_number(double ()*)",
        "declare %SailfinFutureNumber* @sailfin_runtime_spawn_number_ctx(double (i8*)*, i8*)",
        "declare double @sailfin_runtime_await_number(%SailfinFutureNumber*)",
        "declare %SailfinFutureBool* @sailfin_runtime_spawn_bool(i1 ()*)",
        "declare %SailfinFutureBool* @sailfin_runtime_spawn_bool_ctx(i1 (i8*)*, i8*)",
        "declare i1 @sailfin_runtime_await_bool(%SailfinFutureBool*)",
        "declare %SailfinFuturePtr* @sailfin_runtime_spawn_ptr(i8* ()*)",
        "declare %SailfinFuturePtr* @sailfin_runtime_spawn_ptr_ctx(i8* (i8*)*, i8*)",
        "declare i8* @sailfin_runtime_await_ptr(%SailfinFuturePtr*)",
        "declare %SailfinFutureVoid* @sailfin_runtime_spawn_void(void ()*)",
        "declare %SailfinFutureVoid* @sailfin_runtime_spawn_void_ctx(void (i8*)*, i8*)",
        "declare void @sailfin_runtime_await_void(%SailfinFutureVoid*)",
        "declare %SailfinFutureString* @sailfin_runtime_spawn_string(i8* ()*)",
        "declare %SailfinFutureString* @sailfin_runtime_spawn_string_ctx(i8* (i8*)*, i8*)",
        "declare i8* @sailfin_runtime_await_string(%SailfinFutureString*)",
        "",
    ]);

    let vtable_type_lines = render_vtable_type_definitions(type_context);
    if vtable_type_lines != null {
        if vtable_type_lines.length > 0 {
        lines = extend_string_lines(lines, vtable_type_lines);
        lines = append_string(lines, "");
        }
    }

    let vtable_const_lines = render_vtable_constants(type_context);
    if vtable_const_lines != null {
        if vtable_const_lines.length > 0 {
        lines = extend_string_lines(lines, vtable_const_lines);
        lines = append_string(lines, "");
        }
    }

    if debug_lowering {
        print.warn("emit-llvm: phase=render_helpers");
    }
    let helper_declarations = render_runtime_helper_declarations(runtime_helpers, local_functions);
    if helper_declarations != null {
        if helper_declarations.length > 0 {
        lines = extend_string_lines(lines, helper_declarations);
        lines = append_string(lines, "");
        }
    }

    // Declare imported functions from other modules (excluding local functions)
    if debug_lowering {
        print.warn("emit-llvm: phase=render_imports");
    }
    let imported_declarations = render_imported_function_declarations(imported_functions, local_functions, type_context);
    if imported_declarations != null {
        if imported_declarations.length > 0 {
        lines = extend_string_lines(lines, imported_declarations);
        lines = append_string(lines, "");
        }
    }

    // Provide libc declarations for common helpers when not declared in the module.
    if find_function_by_name(context_functions, "malloc") == null {
        lines = append_string(lines, "declare noalias i8* @malloc(i64)");
    }
    if find_function_by_name(context_functions, "free") == null {
        lines = append_string(lines, "declare void @free(i8*)");
    }
    lines = append_string(lines, "");

    // Declare the runtime global (provided by the Python bootstrap runtime)
    lines = append_string(lines, "@runtime = external global i8**");
    lines = append_string(lines, "");

    // Lower module-level `let` bindings into LLVM globals (and an optional init function).
    if debug_lowering {
        print.warn("emit-llvm: phase=module_globals");
    }
    if debug_lowering {
        print.warn("emit-llvm: module bindings count=" + number_to_string(safe_bindings.length));
    }
    let mut module_globals = ModuleGlobalLoweringResult {
        preamble_lines: [],
        init_function_lines: [],
        init_function_symbol: "",
        needs_init_call: false,
        locals: [],
        string_constants: empty_string_constant_set(),
        diagnostics: [],
    };
    if safe_bindings.length == 0 {
        if debug_lowering {
            print.warn("emit-llvm: module bindings empty; skipping module globals");
        }
    } else if fs.exists("build/sailfin/.skip_module_globals") {
        if debug_lowering {
            print.warn("emit-llvm: skipping module globals");
        }
    } else {
        module_globals = lower_module_bindings_to_globals(safe_bindings, type_context, native_module.module_name);
        if module_globals == null {
            diagnostics = append_string(diagnostics, "llvm lowering: module globals returned null; using empty defaults");
            module_globals = ModuleGlobalLoweringResult {
                preamble_lines: [],
                init_function_lines: [],
                init_function_symbol: "",
                needs_init_call: false,
                locals: [],
                string_constants: empty_string_constant_set(),
                diagnostics: [],
            };
        }
    }
    let mut module_global_locals = module_globals.locals;
    if module_global_locals == null {
        module_global_locals = [];
    }
    let mut module_preamble_lines = module_globals.preamble_lines;
    if module_preamble_lines == null {
        module_preamble_lines = [];
    }
    let mut module_init_lines = module_globals.init_function_lines;
    if module_init_lines == null {
        module_init_lines = [];
    }
    let mut module_string_constants = module_globals.string_constants;
    if module_string_constants == null {
        module_string_constants = empty_string_constant_set();
    }
    diagnostics = extend_string_lines_checked(diagnostics, module_globals.diagnostics, "module globals");
    if module_preamble_lines.length > 0 {
        lines = extend_string_lines(lines, module_preamble_lines);
        lines = append_string(lines, "");
    }

    if module_init_lines.length > 0 {
        lines = extend_string_lines(lines, module_init_lines);
        lines = append_string(lines, "");
    }
    if trace {
        print.info("test llvm: module globals lowered");
    }
    if timing {
        print.info("test llvm: phase=globals ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let mut index -> number = 0;
    let mut has_add_function -> boolean = false;
    let mut all_string_constants -> StringConstant[] = module_string_constants;
    if trace {
        print.info("test llvm: lowering functions start (count=" + number_to_string(local_functions.length) + ")");
    }
    if debug_lowering {
        print.warn("emit-llvm: phase=functions");
    }
    loop {
        if index >= local_functions.length {
            break;
        }
        let current_function = local_functions[index];
        let mut safe_function_name = current_function.name;
        if safe_function_name == null {
            safe_function_name = "";
        }
        let mut safe_parameters = current_function.parameters;
        if safe_parameters == null {
            safe_parameters = [];
        }
        let mut safe_effects = current_function.effects;
        if safe_effects == null {
            safe_effects = [];
        }
        let mut safe_decorators = current_function.decorators;
        if safe_decorators == null {
            safe_decorators = [];
        }
        let mut safe_instructions = current_function.instructions;
        if safe_instructions == null {
            safe_instructions = [];
        }
        let mut safe_return_type = current_function.return_type;
        if safe_return_type == null {
            safe_return_type = "";
        }
        let mut effective_function = current_function;
        if current_function.parameters == null || current_function.effects == null || current_function.decorators == null || current_function.instructions == null || current_function.name == null || current_function.return_type == null {
            effective_function = NativeFunction {
                name: safe_function_name,
                is_async: current_function.is_async,
                parameters: safe_parameters,
                return_type: safe_return_type,
                effects: safe_effects,
                decorators: safe_decorators,
                instructions: safe_instructions,
                is_extern: current_function.is_extern,
            };
        }
        if trace {
            let mut return_count -> number = 0;
            let mut instr_index -> number = 0;
            loop {
                if instr_index >= safe_instructions.length {
                    break;
                }
                if safe_instructions[instr_index].variant == "Return" {
                    return_count += 1;
                }
                instr_index += 1;
            }
            print.info(
                "test llvm: function "
                + number_to_string(index)
                + "/"
                + number_to_string(local_functions.length)
                + " "
                + safe_function_name
                + " instrs="
                + number_to_string(safe_instructions.length)
                + " returns="
                + number_to_string(return_count)
            );
        }
        let aggregated_entry = find_function_effect_entry(aggregated_effects, safe_function_name);
        let mut effective_effects -> string[] = [];
        if aggregated_entry != null {
            effective_effects = aggregated_entry.effects;
        }
        function_effects = append_function_effect_entry(
            function_effects,
            FunctionEffectEntry {
                name: safe_function_name,
                effects: effective_effects,
            }
        );
        if debug_lowering {
            print.warn("emit-llvm: function-start " + safe_function_name + " idx=" + number_to_string(index));
        }
        let lowered = emit_llvm_function(
            effective_function,
            context_functions,
            effective_effects,
            type_context,
            native_module.module_name,
            safe_entry_points,
            exported_symbols,
            imported_functions,
            module_global_locals,
            module_globals.init_function_symbol,
            module_globals.needs_init_call
        );
        if debug_lowering {
            print.warn("emit-llvm: function-done " + safe_function_name + " lines=" + number_to_string(lowered.lines.length));
        }
        if trace {
            print.info("test llvm: function lowered " + safe_function_name + " lines=" + number_to_string(lowered.lines.length) + " diagnostics=" + number_to_string(lowered.diagnostics.length));
            if lowered.lines.length > 0 {
                print.info("test llvm: function first line " + lowered.lines[0]);
                print.info("test llvm: function last line " + lowered.lines[lowered.lines.length - 1]);
                let mut ret_lines -> number = 0;
                let mut scan_index -> number = 0;
                loop {
                    if scan_index >= lowered.lines.length {
                        break;
                    }
                    let line = lowered.lines[scan_index];
                    if starts_with(trim_text(line), "ret ") || trim_text(line) == "ret void" {
                        ret_lines += 1;
                    }
                    scan_index += 1;
                }
                print.info("test llvm: function ret_lines " + number_to_string(ret_lines));
            }
        }
        if sanitize_symbol(current_function.name) == "add" {
            has_add_function = true;
        }
        diagnostics = extend_string_lines_checked(diagnostics, lowered.diagnostics, "function lowering");
        if trace {
            print.info("test llvm: function diagnostics merged " + safe_function_name);
        }
        let normalized_lowered_lines = lowered.lines;
        // TODO: Re-enable lifetime region aggregation once native array ABI is fully stable.
        if normalized_lowered_lines != null {
            if normalized_lowered_lines.length > 0 {
            // NOTE: Stage2-native has exhibited corruption when concatenating
            // large `string[]` buffers (dropping the module preamble/header).
            // Append line-by-line to avoid large array copies.
            lines = append_string_lines(lines, normalized_lowered_lines);
            if trace {
                print.info("test llvm: function lines merged " + safe_function_name);
            }
            if trace {
                print.info("test llvm: function post-merge check " + safe_function_name);
            }
            if index + 1 < local_functions.length {
                lines = append_string(lines, "");
            }
            if trace {
                print.info("test llvm: function post-merge blank " + safe_function_name);
            }
            }
        }
        if lowered.string_constants != null {
            if lowered.string_constants.length > 0 {
                if trace {
                    print.info("test llvm: merging string constants " + safe_function_name + " count=" + number_to_string(lowered.string_constants.length));
                }
                let existing_constants = all_string_constants;
                all_string_constants = merge_string_constants(existing_constants, lowered.string_constants);
                if trace {
                    print.info("test llvm: merged string constants " + safe_function_name);
                }
            }
        }
        index += 1;
    }
    if trace {
        print.info("test llvm: lowering functions done");
    }
    if debug_lowering {
        print.warn("emit-llvm: phase=functions_done");
    }
    if timing {
        print.info("test llvm: phase=functions ms=" + number_to_string(monotonic_millis() - start_ms));
    }
    if timing {
        print.info("test llvm: phase=functions ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    if !has_add_function {
        // Keep the generated helper separated from prior output.
        lines = append_string(lines, "");
        lines = extend_string_lines(lines, [
            "define internal double @add(double %a, double %b) {",
            "entry:",
            "  %t0 = fadd double %a, %b",
            "  ret double %t0",
            "}"
        ]);
    }

    let string_constant_lines = render_string_constants(all_string_constants);
    if string_constant_lines != null {
        if string_constant_lines.length > 0 {
        lines = append_string(lines, "");
        lines = append_string_lines(lines, string_constant_lines);
        lines = append_string(lines, "");
        }
    }
    if trace {
        print.info("test llvm: string constants emitted");
    }
    if debug_lowering {
        print.warn("emit-llvm: phase=string_constants");
    }

    lines = ensure_intrinsic_declarations(lines);
    if trace {
        print.info("test llvm: intrinsics ensured");
    }
    if debug_lowering {
        print.warn("emit-llvm: phase=intrinsics");
    }

    let mut effective_mangle_symbols = false;
    if debug_lowering {
        print.warn("emit-llvm: skipping mangling (stability fallback)");
    }
    if effective_mangle_symbols {
        let mangled = apply_module_symbol_mangling(lines, safe_imports, native_module.module_name, safe_imported_native_texts);
        diagnostics = diagnostics.concat(mangled.diagnostics);
        lines = mangled.lines;
    }
    if debug_lowering {
        print.warn("emit-llvm: phase=mangle");
    }
    if trace {
        print.info("test llvm: mangling stage done");
    }
    if timing {
        print.info("test llvm: phase=finalize ms=" + number_to_string(monotonic_millis() - start_ms));
    }
    if timing {
        print.info("test llvm: phase=finalize ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let manifest = empty_capability_manifest();
    if trace {
        let mut nonempty -> number = 0;
        let mut first_len -> number = 0;
        let mut i -> number = 0;
        loop {
            if i >= lines.length {
                break;
            }
            if lines[i].length > 0 {
                nonempty += 1;
                if first_len == 0 {
                    first_len = lines[i].length;
                }
            }
            i += 1;
        }
        print.info(
            "test llvm: lowered lines=" + number_to_string(lines.length)
            + " nonempty=" + number_to_string(nonempty)
            + " first_len=" + number_to_string(first_len)
            + " diagnostics=" + number_to_string(diagnostics.length)
        );
        let mut diag_index -> number = 0;
        loop {
            if diag_index >= diagnostics.length {
                break;
            }
            print.info("test llvm: diagnostic " + diagnostics[diag_index]);
            diag_index += 1;
        }
    }
    if lines.length == 0 {
        print.warn(
            "emit-llvm: lowering produced no lines (functions="
            + number_to_string(local_functions.length)
            + " structs="
            + number_to_string(module_structs.length)
            + " enums="
            + number_to_string(module_enums.length)
            + " diagnostics="
            + number_to_string(diagnostics.length)
            + ")"
        );
    }
    print.warn("emit-llvm: exit lower_to_llvm_lines_with_parsed_context lines=" + number_to_string(lines.length));
    if debug_lowering {
        print.warn("emit-llvm: phase=end lines=" + number_to_string(lines.length));
    }
    return LoweredLLVMLinesResult {
        lines: lines,
        diagnostics: diagnostics,
        trait_metadata: trait_metadata,
        function_effects: function_effects,
        lifetime_regions: lifetime_regions,
        capability_manifest: manifest,
        string_constants: all_string_constants,
    };
}

fn extend_string_lines(values -> string[], extras -> string[]) -> string[] {
    let mut out -> string[] = [];
    let mut safe_values = values;
    if safe_values == null {
        safe_values = [];
    }
    let mut safe_extras = extras;
    if safe_extras == null {
        safe_extras = [];
    }
    let mut index -> number = 0;
    loop {
        if index >= safe_values.length {
            break;
        }
        out = append_string(out, safe_values[index]);
        index += 1;
    }
    index = 0;
    loop {
        if index >= safe_extras.length {
            break;
        }
        out = append_string(out, safe_extras[index]);
        index += 1;
    }
    return out;
}

fn write_llvm_lines_chunked(path -> string, lines -> string[]) -> boolean ![io] {
    if lines == null || lines.length == 0 {
        fs.writeFile(path, "");
        return fs.exists(path);
    }

    let chunk_limit = 65536;
    let mut buffer -> string = "";
    let mut buffered -> number = 0;
    let mut wrote -> boolean = false;

    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let line = lines[index] + "\n";
        let next_len = buffered + line.length;
        if next_len > chunk_limit && buffer.length > 0 {
            if wrote {
                fs.appendFile(path, buffer);
            } else {
                fs.writeFile(path, buffer);
                wrote = true;
            }
            buffer = "";
            buffered = 0;
        }
        buffer = buffer + line;
        buffered += line.length;
        index += 1;
    }

    if buffer.length > 0 {
        if wrote {
            fs.appendFile(path, buffer);
        } else {
            fs.writeFile(path, buffer);
        }
    }
    return fs.exists(path);
}

fn append_string_lines(values -> string[], extras -> string[]) -> string[] {
    let mut out = values;
    if out == null {
        out = [];
    }
    let mut safe_extras = extras;
    if safe_extras == null {
        safe_extras = [];
    }
    let mut index -> number = 0;
    loop {
        if index >= safe_extras.length {
            break;
        }
        out = out.push(safe_extras[index]);
        index += 1;
    }
    return out;
}

fn extend_string_lines_checked(values -> string[], extras -> string[], label -> string) -> string[] {
    let mut safe_values = values;
    if safe_values == null {
        safe_values = [];
    }
    let mut safe_extras = extras;
    if safe_extras == null {
        safe_extras = [];
    }
    if safe_extras.length == 0 {
        return safe_values;
    }
    if safe_extras.length > 1000000 {
        let mut out = safe_values;
        out = append_string(out, "llvm lowering: skipped oversized " + label + " diagnostics (len=" + number_to_string(extras.length) + ")");
        return out;
    }
    return extend_string_lines(safe_values, safe_extras);
}

fn extend_lifetime_regions_checked(values -> LifetimeRegionMetadata[], extras -> LifetimeRegionMetadata[]) -> LifetimeRegionMetadata[] {
    if extras.length == 0 {
        return values;
    }
    if extras.length > 1000000 {
        return values;
    }
    let mut out = values;
    let mut index -> number = 0;
    loop {
        if index >= extras.length {
            break;
        }
        out = out.push(extras[index]);
        index += 1;
    }
    return out;
}

fn module_source_filename(module_name -> string) -> string {
    if module_name.length == 0 {
        return "sailfin";
    }
    // Avoid appending twice.
    if module_name.length >= 4 {
        let suffix = substring(module_name, module_name.length - 4, module_name.length);
        if suffix == ".sfn" {
            return module_name;
        }
    }
    return module_name + ".sfn";
}

fn ensure_intrinsic_declarations(lines -> string[]) -> string[] {
    let mut uses_round -> boolean = false;
    let mut has_round_decl -> boolean = false;
    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let line = lines[index];
        if index_of(line, "call double @round(") >= 0 {
            uses_round = true;
        }
        let trimmed = trim_text(line);
        if starts_with(trimmed, "declare double @round(double)") {
            has_round_decl = true;
        }
        index += 1;
    }

    if !uses_round || has_round_decl {
        return lines;
    }

    // NOTE: LLVM allows `declare` statements anywhere at top-level. Append
    // instead of inserting near the header to avoid rebuilding large `string[]`
    // buffers, which has exhibited stage2-native corruption in some modules.
    let mut out = lines;
    out = append_string(out, "");
    out = append_string(out, "declare double @round(double)");
    return out;
}

fn insert_string_at(values -> string[], insert_index -> number, value -> string) -> string[] {
    let mut out -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= values.length {
            break;
        }
        if index == insert_index {
            out = append_string(out, value);
        }
        out = append_string(out, values[index]);
        index += 1;
    }
    if insert_index >= values.length {
        out = append_string(out, value);
    }
    return out;
}
