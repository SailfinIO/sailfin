fn lower_to_llvm(native_module -> NativeModule) -> LoweredLLVMResult ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
        if artifact == null || artifact.contents.length == 0 {
            return lower_to_llvm_with_context(native_module, [], [], []);
        }
        let parse = parse_native_artifact_safe(artifact.contents);
        let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
        return lower_to_llvm_with_parsed_context(
            native_module,
            parse,
            import_context.manifests,
            import_context.native_texts,
            import_context.diagnostics
        );
}

fn lower_to_llvm_lines(native_module -> NativeModule) -> LoweredLLVMLinesResult ![io] {
    let ir = lower_to_llvm_ir(native_module);
        if ir == null || ir.length == 0 {
            return LoweredLLVMLinesResult { lines: [], diagnostics: [], trait_metadata: empty_trait_metadata(), function_effects: [], lifetime_regions: [], capability_manifest: empty_capability_manifest(), string_constants: empty_string_constant_set() };
        }
    let lines = split_lines(ir);
    return LoweredLLVMLinesResult {
        lines: lines,
        diagnostics: [],
        trait_metadata: empty_trait_metadata(),
        function_effects: [],
        lifetime_regions: [],
        capability_manifest: empty_capability_manifest(),
        string_constants: empty_string_constant_set(),
    };
}

fn lower_to_llvm_lines_only(native_module -> NativeModule) -> string[] ![io] {
    let ir = lower_to_llvm_ir(native_module);
    if ir == null || ir.length == 0 {
        return [];
    }
    return split_lines(ir);
}

// Convenience wrapper for tool/driver entrypoints that only need the emitted
// LLVM text. Returning a plain string avoids carrying the full `LoweredLLVMResult`
// struct across compilation boundaries (stage1 Python + stage2 native), which
// has historically caused layout/ABI mismatches and nondeterministic output.
fn lower_to_llvm_ir(native_module -> NativeModule) -> string ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null || artifact.contents.length == 0 {
        let lowered = lower_to_llvm_with_context(native_module, [], [], []);
        return lowered.ir;
    }
    // Parse once and reuse throughout lowering; parsing the native artifact is expensive.
    let parse = parse_native_artifact_safe(artifact.contents);
    let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
    let lowered = lower_to_llvm_with_parsed_context(
        native_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics
    );
    return lowered.ir;
}

fn lower_to_llvm_for_tests(native_module -> NativeModule) -> LoweredLLVMResult ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return lower_to_llvm_with_context_for_tests(native_module, [], [], []);
    }
    // Parse once and reuse throughout lowering; parsing the native artifact is expensive.
    let parse = parse_native_artifact_safe(artifact.contents);
    let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
    return lower_to_llvm_with_parsed_context_for_tests(
        native_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics
    );
}

fn lower_to_llvm_lines_for_tests(native_module -> NativeModule) -> LoweredLLVMLinesResult ![io] {
    let ir = lower_to_llvm_ir_for_tests_direct(native_module);
    if ir.length == 0 {
        return LoweredLLVMLinesResult {
            lines: [],
            diagnostics: [],
            trait_metadata: empty_trait_metadata(),
            function_effects: [],
            lifetime_regions: [],
            capability_manifest: empty_capability_manifest(),
            string_constants: empty_string_constant_set(),
        };
    }
    let lines = split_lines(ir);
    return LoweredLLVMLinesResult {
        lines: lines,
        diagnostics: [],
        trait_metadata: empty_trait_metadata(),
        function_effects: [],
        lifetime_regions: [],
        capability_manifest: empty_capability_manifest(),
        string_constants: empty_string_constant_set(),
    };
}

fn lower_to_llvm_ir_for_tests(native_module -> NativeModule) -> string ![io] {
    let lowered = lower_to_llvm_for_tests(native_module);
    return lowered.ir;
}

// Direct text lowering for tests to avoid returning large structs across call
// boundaries (can trigger ABI corruption in stage2-native).
fn lower_to_llvm_ir_for_tests_direct(native_module -> NativeModule) -> string ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return "";
    }
    let trace = fs.exists("build/sailfin/.trace_test_runner") && fs.exists("build/sailfin/.test_runner_active");
    if trace {
        print.info("test llvm: direct parse start (bytes=" + number_to_string(artifact.contents.length) + ")");
    }
    let parse = parse_native_artifact_safe(artifact.contents);
    if trace {
        print.info("test llvm: direct parse done (imports=" + number_to_string(parse.imports.length) + ")");
    }
    if trace {
        print.info("test llvm: direct import-context start");
    }
    let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
    if trace {
        print.info("test llvm: direct import-context done (texts=" + number_to_string(import_context.native_texts.length) + ")");
        print.info("test llvm: direct lowering start");
    }
    let lowered_lines = lower_to_llvm_lines_with_parsed_context_for_tests(
        native_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics
    );
    if trace {
        print.info("test llvm: direct lines=" + number_to_string(lowered_lines.lines.length));
        let mut preview -> number = 0;
        loop {
            if preview >= lowered_lines.lines.length || preview >= 3 {
                break;
            }
            print.info("test llvm: direct line " + number_to_string(preview) + " -> " + lowered_lines.lines[preview]);
            preview += 1;
        }
    }
    if lowered_lines.lines == null || lowered_lines.lines.length == 0 {
        return "";
    }
    let ir = _join_llvm_lines_linear(lowered_lines.lines);
    if ir.length <= 4 {
        let mut first_line -> string = "";
        if lowered_lines.lines.length > 0 {
            first_line = lowered_lines.lines[0];
        }
        print.warn(
            "test llvm: suspiciously short IR (len=" + number_to_string(ir.length)
            + " lines=" + number_to_string(lowered_lines.lines.length)
            + " first='" + first_line + "')"
        );
    }
    if ir.length == 0 {
        return "";
    }
    return ir + "\n";
}

// Build and write LLVM IR for tests without returning large structs/arrays.
// This keeps `LoweredLLVMLinesResult` within this module to avoid ABI issues.
fn write_llvm_ir_for_tests(native_module -> NativeModule, out_path -> string) -> boolean ![io] {
    let trace = fs.exists("build/sailfin/.trace_test_runner") && fs.exists("build/sailfin/.test_runner_active");
    let timing = fs.exists("build/sailfin/.test_runner_active");
    let start_ms = monotonic_millis();
    let mut is_test_module = is_test_module_slug(native_module.module_name);
    if !is_test_module && fs.exists("build/sailfin/.test_runner_active") {
        is_test_module = true;
    }
    if trace {
        print.info("test llvm: write_llvm_ir_for_tests start");
    }
    if native_module.artifacts == null || native_module.artifacts.length == 0 {
        print.warn("test llvm: native module missing artifacts");
        return false;
    }
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        print.warn("test llvm: missing sailfin-native-text artifact");
        return false;
    }
    if trace {
        print.info("test llvm: native artifact bytes=" + number_to_string(artifact.contents.length));
    }
    let parse = parse_native_artifact_safe(artifact.contents);
    if trace {
        print.info("test llvm: parsed native artifact (imports=" + number_to_string(parse.imports.length) + ")");
    }
    if timing {
        print.info("test llvm: phase=parse ms=" + number_to_string(monotonic_millis() - start_ms));
    }
    if trace {
        print.info("test llvm: stage=after-parse");
    }

    if !is_test_module && parse.functions != null {
        let mut scan_index -> number = 0;
        loop {
            if scan_index >= parse.functions.length {
                break;
            }
            let fun = parse.functions[scan_index];
            if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
                is_test_module = true;
                break;
            }
            scan_index += 1;
        }
    }

    let mut imported_manifests -> LayoutManifest[] = [];
    let mut imported_native_texts -> string[] = [];
    let mut imported_diagnostics -> string[] = [];
    if parse.imports != null && parse.imports.length > 0 {
        let skip_imports = is_test_module;
        if !skip_imports {
            let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
            imported_manifests = import_context.manifests;
            imported_native_texts = import_context.native_texts;
            imported_diagnostics = import_context.diagnostics;
            if trace {
                print.info("test llvm: collected import context (texts=" + number_to_string(imported_native_texts.length) + ")");
            }
        } else if trace {
            print.info("test llvm: skipping import context for inlined test module");
        }
    }
    if timing {
        print.info("test llvm: phase=imports ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let mut diagnostics = extend_string_lines_checked(imported_diagnostics, parse.diagnostics, "parse");
    if trace {
        print.info("test llvm: lower_to_llvm_lines_with_parsed_context start");
    }

    let exported_symbols = collect_exported_symbol_names(parse.imports);

    let mut module_manifest -> LayoutManifest? = null;

    let manifest_application = apply_layout_manifest_to_module(parse.structs, parse.enums, module_manifest);
    diagnostics = extend_string_lines_checked(diagnostics, manifest_application.diagnostics, "layout application");
    let module_structs = manifest_application.structs;
    let module_enums = manifest_application.enums;
    if trace {
        print.info(
            "test llvm: manifest applied (structs="
            + number_to_string(module_structs.length)
            + " enums="
            + number_to_string(module_enums.length)
            + ")"
        );
    }
    if timing {
        print.info("test llvm: phase=manifest ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let mut imported_structs -> NativeStruct[] = [];
    let mut imported_enums -> NativeEnum[] = [];
    let mut imported_interfaces -> NativeInterface[] = [];
    let mut imported_functions -> NativeFunction[] = [];
    let mut imported_struct_methods -> NativeFunction[] = [];

    let manifest_count = imported_manifests.length;
    let mut text_index -> number = 0;
    loop {
        if text_index >= imported_native_texts.length {
            break;
        }
        let native_text = imported_native_texts[text_index];
        let mut manifest_for_module -> LayoutManifest? = null;
        if text_index < manifest_count {
            let candidate_manifest = imported_manifests[text_index];
            manifest_for_module = candidate_manifest;
        }
        if native_text.length == 0 {
            if manifest_for_module != null {
                let manifest_only = manifest_for_module;
                imported_structs = extend_native_structs(imported_structs, manifest_only.structs);
                imported_enums = extend_native_enums(imported_enums, manifest_only.enums);
            }
            text_index += 1;
            continue;
        }

        // Use individual import-context extractors to avoid struct-return ABI bug
        let imported_structs_ctx = parse_native_structs_for_import(native_text);
        let imported_enums_ctx = parse_native_enums_for_import(native_text);
        let imported_interfaces_ctx = parse_native_interfaces_for_import(native_text);
        let imported_functions_ctx = parse_native_functions_for_import(native_text);
        let applied_import = apply_layout_manifest_to_module(imported_structs_ctx, imported_enums_ctx, manifest_for_module);

        imported_structs = extend_native_structs(imported_structs, applied_import.structs);
        imported_enums = extend_native_enums(imported_enums, applied_import.enums);
        imported_interfaces = extend_native_interfaces(imported_interfaces, imported_interfaces_ctx);
        imported_functions = extend_native_functions(imported_functions, imported_functions_ctx);
        let imported_methods = flatten_struct_methods(applied_import.structs);
        imported_struct_methods = extend_native_functions(imported_struct_methods, imported_methods);
        text_index += 1;
    }

    if imported_native_texts.length < manifest_count {
        let mut manifest_index -> number = imported_native_texts.length;
        loop {
            if manifest_index >= manifest_count {
                break;
            }
            let leftover_manifest = imported_manifests[manifest_index];
            imported_structs = extend_native_structs(imported_structs, leftover_manifest.structs);
            imported_enums = extend_native_enums(imported_enums, leftover_manifest.enums);
            manifest_index += 1;
        }
    }

    let combined_structs = extend_native_structs(module_structs, imported_structs);
    let combined_enums = extend_native_enums(module_enums, imported_enums);
    let mut combined_interfaces = extend_native_interfaces(parse.interfaces, imported_interfaces);
    if is_test_module {
        combined_interfaces = [];
        if trace {
            print.info("test llvm: skipping interface metadata for inlined tests");
        }
    }
    if trace {
        print.info(
            "test llvm: combined types (structs="
            + number_to_string(combined_structs.length)
            + " enums="
            + number_to_string(combined_enums.length)
            + " interfaces="
            + number_to_string(combined_interfaces.length)
            + ")"
        );
    }

    let trait_metadata = build_trait_metadata(combined_interfaces, combined_structs);
    if trace {
        print.info("test llvm: enum layout fixup start");
    }
    let fixed_enums = fixup_enum_layouts(combined_enums);
    diagnostics = extend_string_lines_checked(diagnostics, fixed_enums.diagnostics, "enum layout");
    if trace {
        print.info("test llvm: type context build start");
    }
    // Write struct info BEFORE the cross-module build_type_context call.
    let mut _si1_content -> string = "";
    let mut _si1_idx -> number = 0;
    loop {
        if _si1_idx >= combined_structs.length { break; }
        let _si1_s = combined_structs[_si1_idx];
        if _si1_s.name == null || _si1_s.name.length == 0 {
            _si1_idx += 1;
            continue;
        }
        if _si1_idx > 0 && _si1_content.length > 0 { _si1_content = _si1_content + "\n"; }
        let _si1_llvm = "%" + sanitize_symbol(_si1_s.name);
        _si1_content = _si1_content + _si1_s.name + "\t" + _si1_llvm + "\t";
        let mut _fi1 -> number = 0;
        let _si1_fields = _si1_s.fields;
        if _si1_fields != null {
            loop {
                if _fi1 >= _si1_fields.length { break; }
                let _sf1 = _si1_fields[_fi1];
                if _fi1 > 0 { _si1_content = _si1_content + ","; }
                let mut _fn1 = _sf1.name;
                if _fn1 == null { _fn1 = ""; }
                let mut _ft1 = "i8*";
                let _ann1 = _sf1.type_annotation;
                if _ann1 == "number" { _ft1 = "double"; }
                else if _ann1 == "boolean" || _ann1 == "bool" { _ft1 = "i1"; }
                else if _ann1 == "i64" || _ann1 == "int" || _ann1 == "usize" { _ft1 = "i64"; }
                else if _ann1 == "i32" { _ft1 = "i32"; }
                else if _ann1 == "u8" { _ft1 = "i8"; }
                _si1_content = _si1_content + _fn1 + ":" + _ft1;
                _fi1 += 1;
            }
        }
        _si1_idx += 1;
    }
    fs.writeFile("build/sailfin/.struct_info", _si1_content);
    let type_build = build_type_context(combined_structs, fixed_enums.enums, combined_interfaces);
    diagnostics = extend_string_lines_checked(diagnostics, type_build.diagnostics, "type context");
    let type_context = type_build.context;
    if trace {
        print.info("test llvm: type context built");
    }
    if timing {
        print.info("test llvm: phase=type_context ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let module_struct_methods = flatten_struct_methods(module_structs);
    let local_functions = concat_native_functions(safe_functions, module_struct_methods);
    let mut context_functions = concat_native_functions(local_functions, imported_functions);
    context_functions = concat_native_functions(context_functions, imported_struct_methods);
    if debug_lowering {
        let mut imported_index -> number = 0;
        loop {
            if imported_index >= imported_functions.length {
                break;
            }
            let imported_function = imported_functions[imported_index];
            if index_of(imported_function.name, "parse_native_artifact") >= 0 || index_of(imported_function.name, "parse_native_function_count_from_text") >= 0 {
                print.warn("emit-llvm: imported fn sig " + imported_function.name + " -> " + imported_function.return_type);
            }
            imported_index += 1;
        }
    }

    // Bootstrap guard: effect analysis currently introduces instability in
    // selfhost/native lowering for some modules. Keep disabled by default.
    let skip_effects = true;
    let mut runtime_helpers -> string[] = [];
    if !is_test_module && !skip_effects {
        if debug_lowering {
            print.warn("emit-llvm: phase=helpers_start");
        }
        runtime_helpers = collect_runtime_helper_targets(local_functions);
        if debug_lowering {
            print.warn("emit-llvm: phase=helpers_done");
        }
    } else if trace {
        print.info("test llvm: skipping runtime helper collection for inlined tests");
    }
    if !string_array_contains(runtime_helpers, "copy_bytes") {
        runtime_helpers.push("copy_bytes");
    }
    if !string_array_contains(runtime_helpers, "array_push_slot") {
        runtime_helpers.push("array_push_slot");
    }
    if !string_array_contains(runtime_helpers, "append_string") {
        runtime_helpers.push("append_string");
    }
    runtime_helpers = append_unique_effect(runtime_helpers, "get_field");
    runtime_helpers = append_unique_effect(runtime_helpers, "print.info");
    runtime_helpers = append_unique_effect(runtime_helpers, "print.warn");
    runtime_helpers = append_unique_effect(runtime_helpers, "print.error");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.length");
    runtime_helpers = append_unique_effect(runtime_helpers, "substring");
    runtime_helpers = append_unique_effect(runtime_helpers, "substring_unchecked");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.to_number");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.length");
    runtime_helpers = append_unique_effect(runtime_helpers, "substring");
    runtime_helpers = append_unique_effect(runtime_helpers, "substring_unchecked");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.concat");
    runtime_helpers = append_unique_effect(runtime_helpers, "grapheme_at");
    runtime_helpers = append_unique_effect(runtime_helpers, "number.to_string");
    runtime_helpers = append_unique_effect(runtime_helpers, "string.to_number");
    runtime_helpers = append_unique_effect(runtime_helpers, "strings_equal");
    runtime_helpers = append_unique_effect(runtime_helpers, "runtime_raise_value_error_fn");
    runtime_helpers = append_unique_effect(runtime_helpers, "runtime.bounds_check");
    runtime_helpers = append_unique_effect(runtime_helpers, "mark_persistent");
    let mut direct_effects -> FunctionEffectEntry[] = [];
    let mut aggregated_effects -> FunctionEffectEntry[] = [];
    if !skip_effects {
        if debug_lowering {
            print.warn("emit-llvm: phase=direct_effects");
        }
        direct_effects = collect_direct_function_effects(context_functions);
        aggregated_effects = direct_effects;
        if !is_test_module {
            let call_graph = collect_function_call_graph(context_functions);
            aggregated_effects = propagate_function_effects(direct_effects, call_graph);
        } else if trace {
            print.info("test llvm: skipping effect propagation for inlined tests");
        }
    }
    if trace {
        print.info("test llvm: runtime helpers collected");
    }
    if timing {
        print.info("test llvm: phase=effects ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let mut function_effects -> FunctionEffectEntry[] = [];
    let mut lifetime_regions -> LifetimeRegionMetadata[] = [];
    let mut lines -> string[] = [];
    lines.push("source_filename = \"" + module_source_filename(native_module.module_name) + "\"");
    lines.push("");

    let trait_lines = render_trait_metadata_comments(trait_metadata);
    if trait_lines != null {
        if trait_lines.length > 0 {
        lines = extend_string_lines(lines, trait_lines);
        lines.push("");
        }
    }

    let struct_type_lines = render_struct_type_definitions(type_context, context_functions);
    if struct_type_lines != null {
        if struct_type_lines.length > 0 {
        lines = extend_string_lines(lines, struct_type_lines);
        lines.push("");
        }
    }

    let mut enum_type_lines -> string[] = [];
    if type_context.enums != null && type_context.enums.length > 0 {
        enum_type_lines = render_enum_type_definitions(type_context);
    }
    if enum_type_lines != null {
        if enum_type_lines.length > 0 {
        lines = extend_string_lines(lines, enum_type_lines);
        lines.push("");
        }
    }

    let mut interface_type_lines -> string[] = [];
    if type_context.interfaces != null && type_context.interfaces.length > 0 {
        interface_type_lines = render_interface_type_definitions(type_context);
    }
    if interface_type_lines != null {
        if interface_type_lines.length > 0 {
        lines = extend_string_lines(lines, interface_type_lines);
        lines.push("");
        }
    }

    lines = extend_string_lines(lines, [
        "%SailfinFutureNumber = type opaque",
        "%SailfinFutureBool = type opaque",
        "%SailfinFuturePtr = type opaque",
        "%SailfinFutureVoid = type opaque",
        "%SailfinFutureString = type opaque",
        "",
        "declare %SailfinFutureNumber* @sailfin_runtime_spawn_number(double ()*)",
        "declare %SailfinFutureNumber* @sailfin_runtime_spawn_number_ctx(double (i8*)*, i8*)",
        "declare double @sailfin_runtime_await_number(%SailfinFutureNumber*)",
        "declare %SailfinFutureBool* @sailfin_runtime_spawn_bool(i1 ()*)",
        "declare %SailfinFutureBool* @sailfin_runtime_spawn_bool_ctx(i1 (i8*)*, i8*)",
        "declare i1 @sailfin_runtime_await_bool(%SailfinFutureBool*)",
        "declare %SailfinFuturePtr* @sailfin_runtime_spawn_ptr(i8* ()*)",
        "declare %SailfinFuturePtr* @sailfin_runtime_spawn_ptr_ctx(i8* (i8*)*, i8*)",
        "declare i8* @sailfin_runtime_await_ptr(%SailfinFuturePtr*)",
        "declare %SailfinFutureVoid* @sailfin_runtime_spawn_void(void ()*)",
        "declare %SailfinFutureVoid* @sailfin_runtime_spawn_void_ctx(void (i8*)*, i8*)",
        "declare void @sailfin_runtime_await_void(%SailfinFutureVoid*)",
        "declare %SailfinFutureString* @sailfin_runtime_spawn_string(i8* ()*)",
        "declare %SailfinFutureString* @sailfin_runtime_spawn_string_ctx(i8* (i8*)*, i8*)",
        "declare i8* @sailfin_runtime_await_string(%SailfinFutureString*)",
        "",
    ]);

    let vtable_type_lines = render_vtable_type_definitions(type_context);
    if vtable_type_lines.length > 0 {
        lines = extend_string_lines(lines, vtable_type_lines);
        lines.push("");
    }

    let vtable_const_lines = render_vtable_constants(type_context);
    if vtable_const_lines.length > 0 {
        lines = extend_string_lines(lines, vtable_const_lines);
        lines.push("");
    }

    let helper_declarations = render_runtime_helper_declarations(runtime_helpers, local_functions);
    if helper_declarations.length > 0 {
        lines = extend_string_lines(lines, helper_declarations);
        lines.push("");
    }

    let imported_declarations = render_imported_function_declarations(imported_functions, local_functions, type_context);
    if imported_declarations.length > 0 {
        lines = extend_string_lines(lines, imported_declarations);
        lines.push("");
    }

    if find_function_by_name(context_functions, "malloc") == null {
        lines.push("declare noalias i8* @malloc(i64)");
    }
    if find_function_by_name(context_functions, "free") == null {
        lines.push("declare void @free(i8*)");
    }
    lines.push("");

    lines.push("@runtime = external global i8**");
    lines.push("");

    let module_globals = lower_module_bindings_to_globals(parse.bindings, type_context, native_module.module_name);
    diagnostics = extend_string_lines_checked(diagnostics, module_globals.diagnostics, "module globals");
    if module_globals.preamble_lines.length > 0 {
        lines = extend_string_lines(lines, module_globals.preamble_lines);
        lines.push("");
    }

    if module_globals.init_function_lines.length > 0 {
        lines = extend_string_lines(lines, module_globals.init_function_lines);
        lines.push("");
    }
    if trace {
        print.info("test llvm: module globals lowered");
    }
    if timing {
        print.info("test llvm: phase=globals ms=" + number_to_string(monotonic_millis() - start_ms));
    }

    let mut index -> number = 0;
    let mut has_add_function -> boolean = false;
    let mut all_string_constants -> StringConstant[] = module_globals.string_constants;
    if trace {
        print.info("test llvm: lowering functions start (count=" + number_to_string(local_functions.length) + ")");
    }
    loop {
        if index >= local_functions.length {
            break;
        }
        let current_function = local_functions[index];
        let aggregated_entry = find_function_effect_entry(aggregated_effects, current_function.name);
        let mut effective_effects -> string[] = [];
        if aggregated_entry != null {
            effective_effects = aggregated_entry.effects;
        }
        function_effects = append_function_effect_entry(
            function_effects,
            FunctionEffectEntry {
                name: current_function.name,
                effects: effective_effects,
            }
        );
        let lowered = emit_llvm_function(
            current_function.name,
            context_functions,
            effective_effects,
            type_context,
            native_module.module_name,
            native_module.entry_points,
            exported_symbols,
            imported_functions,
            module_globals.locals,
            module_globals.init_function_symbol,
            module_globals.needs_init_call
        );
        if sanitize_symbol(current_function.name) == "add" {
            has_add_function = true;
        }
        diagnostics = extend_string_lines_checked(diagnostics, lowered.diagnostics, "function lowering");
        if lowered.lines.length > 0 {
            let mut _asl_i -> number = 0;
            loop {
                if _asl_i >= lowered.lines.length { break; }
                lines.push(lowered.lines[_asl_i]);
                _asl_i += 1;
            }
            let _ep_next = index + 1;
            if _ep_next < local_functions.length {
                lines.push("");
            }
        }
        if lowered.string_constants.length > 0 {
            let existing_constants = all_string_constants;
            all_string_constants = merge_string_constants(existing_constants, lowered.string_constants);
        }
        index += 1;
    }

    if !has_add_function {
        lines.push("");
        lines = extend_string_lines(lines, [
            "define internal double @add(double %a, double %b) {",
            "entry:",
            "  %t0 = fadd double %a, %b",
            "  ret double %t0",
            "}"
        ]);
    }

    let string_constant_lines = render_string_constants(all_string_constants);
    if string_constant_lines.length > 0 {
        lines.push("");
        let mut _asl2_i -> number = 0;
        loop {
            if _asl2_i >= string_constant_lines.length { break; }
            lines.push(string_constant_lines[_asl2_i]);
            _asl2_i += 1;
        }
        lines.push("");
    }

    lines = ensure_intrinsic_declarations(lines);

    // Apply test harness when appropriate (no user main).
    let mut tests -> NativeFunction[] = [];
    let mut has_main -> boolean = false;
    let mut t_index -> number = 0;
    loop {
        if t_index >= parse.functions.length {
            break;
        }
        let fun = parse.functions[t_index];
        if fun.name == "main" {
            has_main = true;
        }
        if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
            tests = tests.push(fun);
        }
        t_index += 1;
    }
    if tests.length > 0 && !has_main {
        let harness = render_test_harness_main_for_module(tests, native_module.module_name, false);
        if lines.length > 0 {
            lines.push("");
        }
        lines = extend_string_lines(lines, harness);
    }

    if trace {
        print.info("test llvm: final lines=" + number_to_string(lines.length));
    }
    if lines.length == 0 {
        print.warn("test llvm: no lines emitted (functions=" + number_to_string(parse.functions.length) + ")");
        return false;
    }
    let mut ir = join_with_separator(lines, "\n");
    if trace {
        print.info("test llvm: joined ir bytes=" + number_to_string(ir.length));
    }
    if ir.length == 0 {
        print.warn("test llvm: empty ir after join (lines=" + number_to_string(lines.length) + ")");
        return false;
    }
    ir = ir + "\n";
    let mut target_path -> string = out_path;
    if target_path.length == 0 || index_of(target_path, ".ll") < 0 {
        target_path = "build/sailfin/test.ll";
    }
    fs.writeFile(target_path, ir);
    return true;
}

// Build and write LLVM IR for tests from raw native text, avoiding NativeModule ABI issues.
fn write_llvm_ir_for_tests_from_text(native_text -> string, module_name -> string, out_path -> string) -> boolean ![io] {
    if native_text.length == 0 {
        print.warn("test llvm: empty native text");
        return false;
    }
    // Write the native text to emit-native.tmp so that the recovery path
    // in lower_to_llvm_lines_with_parsed_context reads the correct module
    // rather than stale data from a previous `run` invocation.
    fs.writeFile("build/sailfin/emit-native.tmp", native_text);
    let parse = parse_native_artifact_with_retry(native_text, 3);
    let dummy_module = NativeModule {
        module_name: module_name,
        artifacts: [NativeArtifact { name: module_name, format: "sailfin-native-text", contents: native_text }],
        entry_points: [],
        symbol_count: 0,
    };
    let lowered_lines = lower_to_llvm_lines_with_parsed_context_for_tests(
        dummy_module,
        parse,
        [],
        [],
        []
    );
    if lowered_lines.lines.length == 0 {
        print.warn("test llvm: no lines emitted from native text");
        return false;
    }
    let ir = _join_llvm_lines_linear(lowered_lines.lines);
    if ir.length == 0 {
        print.warn("test llvm: empty IR after join from native text");
        return false;
    }
    fs.writeFile(out_path, ir + "\n");
    return true;
}

// Build LLVM IR from raw native text (non-test path), avoiding NativeModule ABI issues.
fn lower_to_llvm_ir_from_text(native_text -> string, module_name -> string) -> string ![io] {
    if native_text.length == 0 {
        return "";
    }
    let parse = parse_native_artifact_safe(native_text);
    let import_context = collect_imported_module_context_for_module(parse.imports, module_name);
    let dummy_module = NativeModule {
        module_name: module_name,
        artifacts: [NativeArtifact { name: module_name, format: "sailfin-native-text", contents: native_text }],
        entry_points: [],
        symbol_count: 0,
    };
    let lowered_lines = lower_to_llvm_lines_with_parsed_context(
        dummy_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics,
        true,
        native_text
    );
    if lowered_lines.lines == null || lowered_lines.lines.length == 0 {
        print.warn(
            "emit-llvm: no lines from native text (functions="
            + number_to_string(parse.functions.length)
            + " structs="
            + number_to_string(parse.structs.length)
            + " enums="
            + number_to_string(parse.enums.length)
            + " diagnostics="
            + number_to_string(parse.diagnostics.length)
            + ")"
        );
        return "";
    }
    return _join_llvm_lines_linear(lowered_lines.lines);
}

// Build and write LLVM IR with module symbol mangling for non-test usage.
// Avoids returning large structs/arrays across boundaries.
fn write_llvm_ir(native_module -> NativeModule, out_path -> string) -> boolean ![io] {
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return false;
    }
    let parse = parse_native_artifact_safe(artifact.contents);
    let import_context = collect_imported_module_context_for_module(parse.imports, native_module.module_name);
    let lowered_lines = lower_to_llvm_lines_with_parsed_context(
        native_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics,
        true,
        ""
    );
    let lines = lowered_lines.lines;
    if lines.length == 0 {
        print.warn(
            "emit-llvm: no lines from module (module="
            + native_module.module_name
            + " functions="
            + number_to_string(parse.functions.length)
            + " imports="
            + number_to_string(parse.imports.length)
            + " diagnostics="
            + number_to_string(lowered_lines.diagnostics.length)
            + ")"
        );
        if lowered_lines.diagnostics.length > 0 {
            print.warn("emit-llvm: diagnostic " + lowered_lines.diagnostics[0]);
        }
        return false;
    }
    return write_llvm_lines_chunked(out_path, lines);
}

// Build and write LLVM IR from a native text file, avoiding large string returns.
fn write_llvm_ir_from_native_text_file(native_text_path -> string, module_name -> string, out_path -> string) -> boolean ![io] {
    // Delegate to lowering_core where all calls are intra-module (avoiding
    // cross-module ABI bugs and struct literal drops in the seed).
    return compile_native_text_to_llvm_file(native_text_path, module_name, out_path);
}

fn lower_to_llvm_with_manifests(native_module -> NativeModule, imported_manifests -> LayoutManifest[]) -> LoweredLLVMResult {
    return lower_to_llvm_with_context(native_module, imported_manifests, [], []);
}

fn lower_to_llvm_with_context_for_tests(native_module -> NativeModule, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let base = lower_to_llvm_with_context(native_module, imported_manifests, imported_native_texts, imported_diagnostics);
    if base.ir.length == 0 {
        return base;
    }

    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        return base;
    }

    let parse = parse_native_artifact_safe(artifact.contents);
    let mut tests -> NativeFunction[] = [];
    let mut has_main -> boolean = false;

    let mut index -> number = 0;
    loop {
        if index >= parse.functions.length {
            break;
        }
        let fun = parse.functions[index];
        if fun.name == "main" {
            has_main = true;
        }
        if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
            tests = tests.push(fun);
        }
        index += 1;
    }

    if tests.length == 0 {
        return base;
    }

    // For now we only synthesize `main` when no user-provided `main` exists.
    if has_main {
        let mut updated = base;
        updated.diagnostics.push("llvm lowering (test): module defines `main`; skipping synthesized test harness");
        return updated;
    }

    let harness = render_test_harness_main_for_module(tests, native_module.module_name, false);
    let mut updated = base;
    if updated.ir.length > 0 {
        updated.ir = updated.ir + "\n";
    }
    updated.ir = updated.ir + join_with_separator(harness, "\n") + "\n";
    return updated;
}

fn lower_to_llvm_with_parsed_context(native_module -> NativeModule, parse -> ParseNativeResult, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let lowered = lower_to_llvm_lines_with_parsed_context(native_module, parse, imported_manifests, imported_native_texts, imported_diagnostics, true, "");
    if lowered.lines == null {
        return LoweredLLVMResult {
            ir: "",
            diagnostics: append_string(lowered.diagnostics, "llvm lowering: emitted null line list"),
            trait_metadata: lowered.trait_metadata,
            function_effects: lowered.function_effects,
            lifetime_regions: lowered.lifetime_regions,
            capability_manifest: lowered.capability_manifest,
            string_constants: lowered.string_constants,
        };
    }
    let ir = _join_llvm_lines_linear(lowered.lines);
    let mut output -> string = ir;
    if output.length > 0 {
        output = output + "\n";
    }
    return LoweredLLVMResult {
        ir: output,
        diagnostics: lowered.diagnostics,
        trait_metadata: lowered.trait_metadata,
        function_effects: lowered.function_effects,
        lifetime_regions: lowered.lifetime_regions,
        capability_manifest: lowered.capability_manifest,
        string_constants: lowered.string_constants,
    };
}

fn lower_to_llvm_with_parsed_context_for_tests(native_module -> NativeModule, parse -> ParseNativeResult, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let base = lower_to_llvm_with_parsed_context(native_module, parse, imported_manifests, imported_native_texts, imported_diagnostics);
    if base.ir.length == 0 {
        print.warn(
            "test llvm: base IR empty (functions=" + number_to_string(parse.functions.length)
            + " imports=" + number_to_string(parse.imports.length)
            + " structs=" + number_to_string(parse.structs.length)
            + " diagnostics=" + number_to_string(base.diagnostics.length)
            + ")"
        );
        if base.diagnostics.length > 0 {
            print.warn("test llvm: diagnostic " + base.diagnostics[0]);
        }
        return base;
    }

    let mut tests -> NativeFunction[] = [];
    let mut has_main -> boolean = false;

    let mut index -> number = 0;
    loop {
        if index >= parse.functions.length {
            break;
        }
        let fun = parse.functions[index];
        if fun.name == "main" {
            has_main = true;
        }
        if fun.name.length >= 5 && substring(fun.name, 0, 5) == "test:" {
            tests = tests.push(fun);
        }
        index += 1;
    }

    if tests.length == 0 {
        return base;
    }

    // For now we only synthesize `main` when no user-provided `main` exists.
    if has_main {
        let mut updated = base;
        updated.diagnostics.push("llvm lowering (test): module defines `main`; skipping synthesized test harness");
        return updated;
    }

    let harness = render_test_harness_main_for_module(tests, native_module.module_name, false);
    let mut updated = base;
    if updated.ir.length > 0 {
        updated.ir = updated.ir + "\n";
    }
    updated.ir = updated.ir + join_with_separator(harness, "\n") + "\n";
    return updated;
}


fn lower_to_llvm_with_context(native_module -> NativeModule, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMResult {
    let lowered = lower_to_llvm_lines_with_context(native_module, imported_manifests, imported_native_texts, imported_diagnostics);
    let ir = _join_llvm_lines_linear(lowered.lines);
    let mut output -> string = ir;
    if output.length > 0 {
        output = output + "\n";
    }
    return LoweredLLVMResult {
        ir: output,
        diagnostics: lowered.diagnostics,
        trait_metadata: lowered.trait_metadata,
        function_effects: lowered.function_effects,
        lifetime_regions: lowered.lifetime_regions,
        capability_manifest: lowered.capability_manifest,
        string_constants: lowered.string_constants,
    };
}


fn lower_to_llvm_lines_with_context(native_module -> NativeModule, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMLinesResult {
    let mut diagnostics -> string[] = [];
    if imported_diagnostics.length > 0 {
        let mut _ci0 -> number = 0;
        loop {
            if _ci0 >= imported_diagnostics.length { break; }
            diagnostics.push(imported_diagnostics[_ci0]);
            _ci0 += 1;
        }
    }
    let artifact = select_text_artifact(native_module.artifacts);
    if artifact == null {
        diagnostics.push("no sailfin-native-text artifact present");
        let empty_constants = empty_string_constant_set();
        return LoweredLLVMLinesResult {
            lines: [],
            diagnostics: diagnostics,
            trait_metadata: empty_trait_metadata(),
            function_effects: [],
            lifetime_regions: [],
            capability_manifest: empty_capability_manifest(),
            string_constants: empty_constants,
        };
    }

    let parse = parse_native_artifact_safe(artifact.contents);
    return lower_to_llvm_lines_with_parsed_context(native_module, parse, imported_manifests, imported_native_texts, diagnostics, true, "");
}

