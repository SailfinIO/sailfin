// Construct a ParseNativeResult from individual field-extraction calls.
// This avoids the seed v0.1.1 struct-return ABI bug: each extractor returns
// an array (works through double→pointer shim), then we assemble locally.
fn parse_native_artifact_with_retry(text -> string, attempts -> number) -> ParseNativeResult {
    let functions = parse_native_functions_from_text(text);
    let imports = parse_native_imports_from_text(text);
    let structs = parse_native_structs_from_text(text);
    let interfaces = parse_native_interfaces_from_text(text);
    let enums = parse_native_enums_from_text(text);
    let bindings = parse_native_bindings_from_text(text);
    let diagnostics = parse_native_diagnostics_from_text(text);
    let result = ParseNativeResult {
        functions: functions,
        imports: imports,
        structs: structs,
        interfaces: interfaces,
        enums: enums,
        bindings: bindings,
        diagnostics: diagnostics,
    };
    return result;
}

// Safe replacement for parse_native_artifact that avoids struct-return ABI bug.
// Calls individual field extractors and assembles the result locally.
fn parse_native_artifact_safe(text -> string) -> ParseNativeResult {
    let functions = parse_native_functions_from_text(text);
    let imports = parse_native_imports_from_text(text);
    let structs = parse_native_structs_from_text(text);
    let interfaces = parse_native_interfaces_from_text(text);
    let enums = parse_native_enums_from_text(text);
    let bindings = parse_native_bindings_from_text(text);
    let diagnostics = parse_native_diagnostics_from_text(text);
    let result = ParseNativeResult {
        functions: functions,
        imports: imports,
        structs: structs,
        interfaces: interfaces,
        enums: enums,
        bindings: bindings,
        diagnostics: diagnostics,
    };
    return result;
}

fn recover_function_name_from_header(line -> string) -> string {
    if !starts_with_local(line, ".fn ") {
        return "";
    }
    let mut header = trim_text_local(substring(line, 4, line.length));
    // Strip "async " prefix if present.
    if starts_with_local(header, "async ") {
        header = trim_text_local(substring(header, 6, header.length));
    }
    let open_paren = index_of_char_local(header, "(");
    if open_paren < 0 {
        return header;
    }
    return trim_text_local(substring(header, 0, open_paren));
}

fn recover_function_is_async_from_header(line -> string) -> boolean {
    if !starts_with_local(line, ".fn ") {
        return false;
    }
    let header = trim_text_local(substring(line, 4, line.length));
    return starts_with_local(header, "async ");
}

// Helper: construct NativeFunction outside of if blocks.
// The seed v0.1.1 drops struct literal constructions inside if blocks,
// so we extract construction into standalone functions that get called.
fn make_native_function_basic(name -> string, is_async -> boolean) -> NativeFunction {
    return NativeFunction { name: name, is_async: is_async, parameters: [], return_type: "void", effects: [], decorators: [], is_extern: false, instructions: [] };
}

fn make_native_function_with_return(name -> string, is_async -> boolean, ret_type -> string) -> NativeFunction {
    return NativeFunction { name: name, is_async: is_async, parameters: [], return_type: ret_type, effects: [], decorators: [], is_extern: false, instructions: [] };
}

fn make_native_function_method(name -> string, self_type -> string, ret_type -> string) -> NativeFunction {
    let self_param = NativeParameter { name: "self", type_annotation: self_type, mutable: false, default_value: null, span: null };
    return NativeFunction { name: name, is_async: false, parameters: [self_param], return_type: ret_type, effects: [], decorators: [], is_extern: false, instructions: [] };
}

fn make_native_parameter(pname -> string, ptype -> string) -> NativeParameter {
    return NativeParameter { name: pname, type_annotation: ptype, mutable: false, default_value: null, span: null };
}

fn make_native_import(module_path -> string) -> NativeImport {
    return NativeImport { kind: "named", module: module_path, specifiers: [] };
}

fn make_native_struct_layout(sz -> number, al -> number, flds -> NativeStructLayoutField[]) -> NativeStructLayout {
    return NativeStructLayout { size: sz, align: al, fields: flds };
}

fn make_native_struct(sname -> string, sfields -> NativeStructField[], smethods -> NativeFunction[], slayout -> NativeStructLayout?) -> NativeStruct {
    return NativeStruct { name: sname, fields: sfields, methods: smethods, implements: [], layout: slayout };
}

fn make_native_struct_field(fname -> string, ftype -> string) -> NativeStructField {
    return NativeStructField { name: fname, type_annotation: ftype, mutable: false };
}

fn make_native_struct_layout_field(lf_name -> string, lf_type -> string, lf_offset -> number, lf_size -> number, lf_align -> number) -> NativeStructLayoutField {
    return NativeStructLayoutField { name: lf_name, type_annotation: lf_type, offset: lf_offset, size: lf_size, align: lf_align };
}

fn update_function_return_type(fn_val -> NativeFunction, ret_type -> string) -> NativeFunction {
    return NativeFunction { name: fn_val.name, is_async: fn_val.is_async, parameters: fn_val.parameters, return_type: ret_type, effects: fn_val.effects, decorators: fn_val.decorators, is_extern: fn_val.is_extern, instructions: fn_val.instructions };
}

fn update_function_effects(fn_val -> NativeFunction, effects -> string[]) -> NativeFunction {
    return NativeFunction { name: fn_val.name, is_async: fn_val.is_async, parameters: fn_val.parameters, return_type: fn_val.return_type, effects: effects, decorators: fn_val.decorators, is_extern: fn_val.is_extern, instructions: fn_val.instructions };
}

fn update_function_params(fn_val -> NativeFunction, params -> NativeParameter[]) -> NativeFunction {
    return NativeFunction { name: fn_val.name, is_async: fn_val.is_async, parameters: params, return_type: fn_val.return_type, effects: fn_val.effects, decorators: fn_val.decorators, is_extern: fn_val.is_extern, instructions: fn_val.instructions };
}

fn update_function_instructions(fn_val -> NativeFunction, instrs -> NativeInstruction[]) -> NativeFunction {
    return NativeFunction { name: fn_val.name, is_async: fn_val.is_async, parameters: fn_val.parameters, return_type: fn_val.return_type, effects: fn_val.effects, decorators: fn_val.decorators, is_extern: fn_val.is_extern, instructions: instrs };
}

fn append_param_to_function(func -> NativeFunction, param -> NativeParameter) -> NativeFunction {
    let mut params = func.parameters;
    params = params.push(param);
    return update_function_params(func, params);
}

fn append_instruction_to_function(func -> NativeFunction, instr -> NativeInstruction) -> NativeFunction {
    let mut instrs = func.instructions;
    instrs = instrs.push(instr);
    return update_function_instructions(func, instrs);
}

// NativeInstruction construction helpers (seed v0.1.1 drops enum variant constructors)
// Tags: Return=0, Expression=1, If=3, Else=4, EndIf=5, Loop=8, EndLoop=9, Break=10, Continue=11, Unknown=21
fn make_instruction_text(tag_val -> number, text -> string) -> NativeInstruction {
    // Seed drops this; fixup pass replaces body
    if tag_val == 0 {
        return NativeInstruction.Return { expression: text, span: null };
    }
    if tag_val == 1 {
        return NativeInstruction.Expression { expression: text, span: null };
    }
    if tag_val == 3 {
        return NativeInstruction.If { condition: text };
    }
    return NativeInstruction.Unknown { text: text };
}

fn make_instruction_simple(tag_val -> number) -> NativeInstruction {
    // Seed drops this; fixup pass replaces body
    if tag_val == 4 { return NativeInstruction.Else(); }
    if tag_val == 5 { return NativeInstruction.EndIf(); }
    if tag_val == 8 { return NativeInstruction.Loop(); }
    if tag_val == 9 { return NativeInstruction.EndLoop(); }
    if tag_val == 10 { return NativeInstruction.Break(); }
    return NativeInstruction.Continue();
}

// NativeEnum field accessors: same get_field stub issue.
// NativeEnum = { i8* name[0], {NativeEnumVariant*,i64}* variants[1], NativeEnumLayout* layout[2] }
fn get_enum_name_at(enums -> NativeEnum[], idx -> number) -> string {
    let e = enums[idx];
    return e.name;
}

// NativeInstruction field accessors: the seed v0.1.1 compiles enum field access
// (.variant, .expression, .condition) as sailfin_runtime_get_field which is a
// runtime stub returning empty data.  These helpers use explicit array indexing
// and field access; the fixup pass replaces their bodies with correct GEP+load IR.
// Tags: Return=0, Expression=1, Let=2, If=3, Else=4, EndIf=5, For=6, EndFor=7,
//        Loop=8, EndLoop=9, Break=10, Continue=11, Match=12, ... Unknown=21
fn get_instruction_tag(instructions -> NativeInstruction[], idx -> number) -> number {
    // Seed drops this; fixup pass replaces with tag read
    let instr = instructions[idx];
    return 21;  // fallback: Unknown
}
fn get_instruction_text(instructions -> NativeInstruction[], idx -> number) -> string {
    // Seed drops this; fixup pass replaces with payload[0] read
    let instr = instructions[idx];
    return instr.expression;
}
fn get_instruction_condition(instructions -> NativeInstruction[], idx -> number) -> string {
    // Seed drops this; fixup pass replaces with payload[0] read
    let instr = instructions[idx];
    return instr.condition;
}
fn get_instruction_let_name(instructions -> NativeInstruction[], idx -> number) -> string {
    // Seed drops this; fixup pass replaces with payload[0] (name) read
    let instr = instructions[idx];
    return instr.name;
}
fn get_instruction_let_mutable(instructions -> NativeInstruction[], idx -> number) -> boolean {
    // Seed drops this; fixup pass replaces with payload[1] read as i1
    let instr = instructions[idx];
    return instr.mutable;
}
fn get_instruction_let_type(instructions -> NativeInstruction[], idx -> number) -> string {
    // Seed drops this; fixup pass replaces with payload[2] read
    let instr = instructions[idx];
    return instr.type_annotation;
}
fn get_instruction_let_value(instructions -> NativeInstruction[], idx -> number) -> string? {
    // Seed drops this; fixup pass replaces with payload[3] read
    let instr = instructions[idx];
    return instr.value;
}

// NativeFunction field accessors: the seed v0.1.1 compiles by-value struct
// field access as 0.0.  These helpers take the functions array + index and
// return individual fields.  The fixup pass replaces their bodies with correct
// GEP + extractvalue LLVM IR.
fn get_function_name_at(functions -> NativeFunction[], idx -> number) -> string {
    let f = functions[idx];
    return f.name;
}
fn get_function_return_type_at(functions -> NativeFunction[], idx -> number) -> string {
    let f = functions[idx];
    return f.return_type;
}
fn get_function_is_async_at(functions -> NativeFunction[], idx -> number) -> boolean {
    let f = functions[idx];
    return f.is_async;
}
fn get_function_is_extern_at(functions -> NativeFunction[], idx -> number) -> boolean {
    let f = functions[idx];
    return f.is_extern;
}
fn get_function_parameters_at(functions -> NativeFunction[], idx -> number) -> NativeParameter[] {
    let f = functions[idx];
    return f.parameters;
}
fn get_function_instructions_at(functions -> NativeFunction[], idx -> number) -> NativeInstruction[] {
    let f = functions[idx];
    return f.instructions;
}
fn get_function_effects_at(functions -> NativeFunction[], idx -> number) -> string[] {
    let f = functions[idx];
    return f.effects;
}
fn get_function_decorators_at(functions -> NativeFunction[], idx -> number) -> string[] {
    let f = functions[idx];
    return f.decorators;
}

// NativeStruct field accessors (same pattern as NativeFunction above).
fn get_struct_name_at(structs -> NativeStruct[], idx -> number) -> string {
    let s = structs[idx];
    return s.name;
}
fn get_struct_fields_at(structs -> NativeStruct[], idx -> number) -> NativeStructField[] {
    let s = structs[idx];
    return s.fields;
}

// NativeStructField field accessors.
fn get_struct_field_name_at(fields -> NativeStructField[], idx -> number) -> string {
    let f = fields[idx];
    return f.name;
}
fn get_struct_field_type_at(fields -> NativeStructField[], idx -> number) -> string {
    let f = fields[idx];
    return f.type_annotation;
}

fn is_trim_char_local(ch -> string) -> boolean {
    let code = char_code(ch);
    let mut _ret236 -> boolean = false;
    if code == char_code(" ") { _ret236 = true; }
    if code == char_code("\n") { _ret236 = true; }
    if code == char_code("\r") { _ret236 = true; }
    if code == char_code("\t") { _ret236 = true; }
    return _ret236;
}

fn trim_text_local(value -> string) -> string {
    if value.length == 0 {
        return "";
    }
    let mut start -> number = 0;
    let mut end = value.length;
    loop {
        if start >= end {
            break;
        }
        if !is_trim_char_local(value[start]) {
            break;
        }
        start += 1;
    }
    loop {
        if end <= start {
            break;
        }
        if !is_trim_char_local(value[end - 1]) {
            break;
        }
        end -= 1;
    }
    if end <= start {
        return "";
    }
    return substring(value, start, end);
}

fn starts_with_local(value -> string, prefix -> string) -> boolean {
    if prefix.length == 0 {
        return true;
    }
    if value.length < prefix.length {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= prefix.length {
            break;
        }
        if value[index] != prefix[index] {
            return false;
        }
        index += 1;
    }
    return true;
}

fn index_of_char_local(value -> string, needle -> string) -> number {
    if needle.length == 0 {
        return 0;
    }
    let mut index -> number = 0;
    loop {
        if index >= value.length {
            break;
        }
        if value[index] == needle {
            return index;
        }
        index += 1;
    }
    return -1;
}

fn split_lines_local(value -> string) -> string[] {
    let value_len = value.length;
    let mut lines -> string[] = [];
    let mut start -> number = 0;
    let mut index -> number = 0;
    loop {
        if index >= value_len {
            break;
        }
        let ch = value[index];
        if ch == "\n" {
            lines = lines.push(substring(value, start, index));
            start = index + 1;
        }
        index += 1;
    }
    lines = lines.push(substring(value, start, value_len));
    return lines;
}

// Parse the tab-separated string constants file written by _write_lowered_function_files.
// Format: one constant per line as "name\tcontent\tbyte_count".
fn _parse_lowered_fn_string_constants(raw -> string) -> StringConstant[] {
    let mut result -> StringConstant[] = [];
    if raw.length == 0 {
        return result;
    }
    let file_lines = split_lines_local(raw);
    let mut i -> number = 0;
    loop {
        if i >= file_lines.length {
            break;
        }
        let line = file_lines[i];
        if line.length == 0 {
            i += 1;
            continue;
        }
        let tab1 = index_of_char_local(line, "\t");
        if tab1 < 0 {
            i += 1;
            continue;
        }
        let name = substring(line, 0, tab1);
        let rest = substring(line, tab1 + 1, line.length);
        let tab2 = index_of_char_local(rest, "\t");
        if tab2 < 0 {
            i += 1;
            continue;
        }
        let content = substring(rest, 0, tab2);
        let byte_text = substring(rest, tab2 + 1, rest.length);
        let byte_count = parse_number_local(byte_text);
        result = result.push(StringConstant { name: name, content: content, byte_count: byte_count });
        i += 1;
    }
    return result;
}

// Parse the tab-separated locals file written by _write_module_globals_files.
// Format: name\tpointer\tllvm_type\ttype_annotation\tscope_id
fn _parse_module_globals_locals(raw -> string) -> LocalBinding[] {
    let mut result -> LocalBinding[] = [];
    if raw.length == 0 {
        return result;
    }
    let file_lines = split_lines_local(raw);
    let mut i -> number = 0;
    loop {
        if i >= file_lines.length {
            break;
        }
        let line = file_lines[i];
        i += 1;
        if line.length == 0 {
            continue;
        }
        let tab1 = index_of_char_local(line, "\t");
        if tab1 < 0 {
            continue;
        }
        let name = substring(line, 0, tab1);
        let rest1 = substring(line, tab1 + 1, line.length);
        let tab2 = index_of_char_local(rest1, "\t");
        if tab2 < 0 {
            continue;
        }
        let pointer = substring(rest1, 0, tab2);
        let rest2 = substring(rest1, tab2 + 1, rest1.length);
        let tab3 = index_of_char_local(rest2, "\t");
        if tab3 < 0 {
            continue;
        }
        let llvm_type = substring(rest2, 0, tab3);
        let rest3 = substring(rest2, tab3 + 1, rest2.length);
        let tab4 = index_of_char_local(rest3, "\t");
        if tab4 < 0 {
            continue;
        }
        let type_annotation = substring(rest3, 0, tab4);
        let scope_id = substring(rest3, tab4 + 1, rest3.length);
        let binding = LocalBinding {
            name: name,
            pointer: pointer,
            llvm_type: llvm_type,
            type_annotation: type_annotation,
            ownership: null,
            consumed: false,
            scope_id: scope_id,
            scope_depth: 0,
        };
        result = result.push(binding);
    }
    return result;
}

fn recover_native_functions_light(native_text -> string) -> NativeFunction[] {
    // FLAT: no nested ifs, no else-if chains.
    // Seed degenerate-if bug drops ALL nested conditions and else-if branches.
    // Every condition check must be a top-level if in the loop body.
    print("DIAG: recover_native_functions_light input length=" + number_to_string(native_text.length));
    let lines = split_lines_local(native_text);
    print("DIAG: split_lines_local returned lines=" + number_to_string(lines.length));
    let mut functions -> NativeFunction[] = [];
    let mut current -> NativeFunction? = null;
    let mut current_struct_name -> string = "";
    let mut index -> number = 0;
    let mut fn_count -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let line = trim_text_local(lines[index]);
        let mut _if237 -> boolean = false;
        if line.length == 0 { _if237 = true; }
        if starts_with_local(line, ";") { _if237 = true; }
        if starts_with_local(line, ".module ") { _if237 = true; }
        if _if237 {
            index += 1;
            continue;
        }
        // --- Pre-compute all branch flags at the top level ---
        let is_struct_start = starts_with_local(line, ".struct ");
        let is_struct_end = line == ".endstruct";
        let is_method_start = starts_with_local(line, ".method ");
        let is_method_end = starts_with_local(line, ".endmethod");
        let is_fn_start = starts_with_local(line, ".fn ");
        let mut _let238 -> boolean = false;
        if starts_with_local(line, ".endfn") { _let238 = true; }
        if starts_with_local(line, ".endtest") { _let238 = true; }
        let is_fn_end = _let238;
        let is_meta_return = starts_with_local(line, ".meta return ");
        let is_meta_effects = starts_with_local(line, ".meta effects ");
        let is_meta_other = starts_with_local(line, ".meta ");
        let is_param = starts_with_local(line, ".param ");
        let mut _let239 -> boolean = false;
        if starts_with_local(line, ".span ") { _let239 = true; }
        if starts_with_local(line, ".init-span ") { _let239 = true; }
        let is_span = _let239;
        let is_eval = starts_with_local(line, "eval ");
        let is_dotreturn = starts_with_local(line, ".return");
        let is_ret_space = starts_with_local(line, "ret ");
        let is_ret_bare = line == "ret";
        let is_else_kw = line == ".else";
        let is_endif_kw = line == ".endif";
        let is_if_kw = starts_with_local(line, ".if ");
        let is_loop_kw = line == ".loop";
        let is_endloop_kw = line == ".endloop";
        let is_break_kw = line == "break";
        let is_continue_kw = line == "continue";

        // --- Pre-compute values needed by multiple branches ---
        // Method parsing (safe even on non-method lines — values unused if is_method_start is false)
        let method_header = trim_text_local(substring(line, 8, line.length));
        let method_paren_idx = index_of(method_header, "(");
        let method_name_from_paren = trim_text_local(substring(method_header, 0, method_paren_idx));
        let method_arrow_idx = index_of(method_header, " -> ");
        let method_ret_from_arrow = trim_text_local(substring(method_header, method_arrow_idx + 4, method_header.length));
        // .meta return parsing
        let ret_type_raw = trim_text_local(substring(line, 13, line.length));
        // .meta effects parsing
        let effects_text_raw = trim_text_local(substring(line, 14, line.length));
        // .param parsing
        let param_text_raw = trim_text_local(substring(line, 7, line.length));
        let param_arrow_idx = index_of(param_text_raw, " -> ");
        let param_name_raw = trim_text_local(substring(param_text_raw, 0, param_arrow_idx));
        let param_type_raw = trim_text_local(substring(param_text_raw, param_arrow_idx + 4, param_text_raw.length));

        // --- Struct tracking ---
        if is_struct_start {
            current_struct_name = trim_text_local(substring(line, 8, line.length));
            index += 1;
            continue;
        }
        if is_struct_end {
            current_struct_name = "";
            index += 1;
            continue;
        }

        // --- Flush current on function/method boundaries (FLAT — no nesting) ---
        if is_fn_start {
            if current != null {
                print("DIAG: flush fn-start current=" + current.name + " functions.len=" + number_to_string(functions.length));
                functions = append_native_function(functions, current);
                print("DIAG: after append functions.len=" + number_to_string(functions.length));
                current = null;
            }
        }
        if is_method_start {
            if current_struct_name.length > 0 {
                if current != null {
                    functions = append_native_function(functions, current);
                    current = null;
                }
            }
        }
        if is_fn_end {
            if current != null {
                print("DIAG: flush fn-end current=" + current.name + " functions.len=" + number_to_string(functions.length));
                functions = append_native_function(functions, current);
                print("DIAG: after append functions.len=" + number_to_string(functions.length));
                current = null;
                index += 1;
                continue;
            }
        }
        if is_fn_end {
            index += 1;
            continue;
        }
        if is_method_end {
            if current != null {
                functions = append_native_function(functions, current);
                current = null;
                index += 1;
                continue;
            }
        }
        if is_method_end {
            index += 1;
            continue;
        }

        // --- Method start with paren and arrow (full parse) ---
        if is_method_start {
            if current_struct_name.length > 0 {
                if method_paren_idx >= 0 {
                    if method_arrow_idx >= 0 {
                        let full_name = current_struct_name + method_name_from_paren;
                        current = make_native_function_method(full_name, current_struct_name, method_ret_from_arrow);
                        index += 1;
                        continue;
                    }
                }
            }
        }
        // --- Method start with paren but no arrow ---
        if is_method_start {
            if current_struct_name.length > 0 {
                if method_paren_idx >= 0 {
                    let full_name = current_struct_name + method_name_from_paren;
                    current = make_native_function_method(full_name, current_struct_name, "void");
                    index += 1;
                    continue;
                }
            }
        }
        // --- Method start without paren ---
        if is_method_start {
            if current_struct_name.length > 0 {
                let full_name = current_struct_name + method_header;
                current = make_native_function_method(full_name, current_struct_name, "void");
                index += 1;
                continue;
            }
        }

        // --- .fn start ---
        if is_fn_start {
            let name = recover_function_name_from_header(line);
            let fn_is_async = recover_function_is_async_from_header(line);
            current = make_native_function_basic(name, fn_is_async);
            fn_count += 1;
            print("DIAG: found .fn #" + number_to_string(fn_count) + " name=" + name);
            index += 1;
            continue;
        }

        // --- Skip lines when not inside a function ---
        if current == null {
            index += 1;
            continue;
        }

        // --- .meta return (FLAT — combined condition) ---
        if is_meta_return {
            if ret_type_raw.length > 0 {
                current = update_function_return_type(current, ret_type_raw);
                index += 1;
                continue;
            }
        }

        // --- .meta effects (FLAT — combined condition) ---
        if is_meta_effects {
            if effects_text_raw != "none" {
                if effects_text_raw.length > 0 {
                    let mut parsed_effects -> string[] = [];
                    parsed_effects.push(effects_text_raw);
                    current = update_function_effects(current, parsed_effects);
                    index += 1;
                    continue;
                }
            }
        }

        // --- Other .meta lines ---
        if is_meta_other {
            index += 1;
            continue;
        }

        // --- .param (FLAT — all conditions combined) ---
        if is_param {
            if param_arrow_idx >= 0 {
                if param_name_raw.length > 0 {
                    if param_type_raw.length > 0 {
                        let new_param = make_native_parameter(param_name_raw, param_type_raw);
                        current = append_param_to_function(current, new_param);
                        index += 1;
                        continue;
                    }
                }
            }
        }
        if is_param {
            index += 1;
            continue;
        }

        // --- .span lines ---
        if is_span {
            index += 1;
            continue;
        }

        // --- Instruction parsing (FLAT — independent ifs, no else-if chain) ---
        // Default to Unknown; each matching if overwrites. Conditions are mutually exclusive.
        // Tags: Return=0, Expression=1, If=3, Else=4, EndIf=5, Loop=8, EndLoop=9, Break=10, Continue=11, Unknown=21
        let mut next_instruction -> NativeInstruction = make_instruction_text(21, line);
        if is_eval {
            next_instruction = make_instruction_text(1, trim_text_local(substring(line, 5, line.length)));
        }
        if is_dotreturn {
            next_instruction = make_instruction_text(0, trim_text_local(substring(line, 7, line.length)));
        }
        if is_ret_space {
            next_instruction = make_instruction_text(0, trim_text_local(substring(line, 4, line.length)));
        }
        if is_ret_bare {
            next_instruction = make_instruction_text(0, "");
        }
        if is_else_kw {
            next_instruction = make_instruction_simple(4);
        }
        if is_endif_kw {
            next_instruction = make_instruction_simple(5);
        }
        if is_if_kw {
            next_instruction = make_instruction_text(3, trim_text_local(substring(line, 4, line.length)));
        }
        if is_loop_kw {
            next_instruction = make_instruction_simple(8);
        }
        if is_endloop_kw {
            next_instruction = make_instruction_simple(9);
        }
        if is_break_kw {
            next_instruction = make_instruction_simple(10);
        }
        if is_continue_kw {
            next_instruction = make_instruction_simple(11);
        }

        current = append_instruction_to_function(current, next_instruction);
        index += 1;
    }
    if current != null {
        functions = append_native_function(functions, current);
    }
    print("DIAG: recover_native_functions_light returning " + number_to_string(functions.length) + " functions");
    return functions;
}

// Light import recovery: parse .import lines from native text.
// Returns NativeImport[] with module paths (specifiers are empty).
fn recover_native_imports_light(native_text -> string) -> NativeImport[] {
    // FLAT: no nested ifs — seed degenerate-if bug drops nested conditions.
    // Compute all values unconditionally; single combined guard at the end.
    let lines = split_lines_local(native_text);
    let mut imports -> NativeImport[] = [];
    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let line = trim_text_local(lines[index]);
        let is_import = starts_with_local(line, ".import ");
        // .import "../../ast" { ... }
        let rest = trim_text_local(substring(line, 8, line.length));
        let quote1 = index_of_char_local(rest, "\"");
        let after_quote = substring(rest, quote1 + 1, rest.length);
        let quote2 = index_of_char_local(after_quote, "\"");
        let module_path = substring(after_quote, 0, quote2);
        if is_import {
            if quote1 >= 0 {
                if quote2 > 0 {
                    let imp = make_native_import(module_path);
                    imports = append_native_import(imports, imp);
                }
            }
        }
        index += 1;
    }
    return imports;
}

fn append_native_import(arr -> NativeImport[], item -> NativeImport) -> NativeImport[] {
    let mut result -> NativeImport[] = [];
    let mut i -> number = 0;
    loop {
        if i >= arr.length {
            break;
        }
        result = result.push(arr[i]);
        i += 1;
    }
    result = result.push(item);
    return result;
}

fn recover_native_structs_light(native_text -> string) -> NativeStruct[] {
    // FLAT: no nested ifs, no else-if chains.
    // Seed degenerate-if bug drops ALL nested conditions.
    let lines = split_lines_local(native_text);
    let mut structs -> NativeStruct[] = [];
    let mut in_struct -> boolean = false;
    let mut struct_name -> string = "";
    let mut struct_fields -> NativeStructField[] = [];
    let mut struct_methods -> NativeFunction[] = [];
    let mut struct_layout -> NativeStructLayout? = null;
    let mut layout_fields -> NativeStructLayoutField[] = [];
    let mut layout_size -> number = 0;
    let mut layout_align -> number = 0;

    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let line = trim_text_local(lines[index]);
        let mut _if240 -> boolean = false;
        if line.length == 0 { _if240 = true; }
        if starts_with_local(line, ";") { _if240 = true; }
        if _if240 {
            index += 1;
            continue;
        }
        // --- Pre-compute branch flags ---
        let is_struct_start = starts_with_local(line, ".struct ");
        let is_struct_end = line == ".endstruct";
        let is_field = starts_with_local(line, ".field ");
        let is_layout_struct = starts_with_local(line, ".layout struct ");
        let is_layout_field = starts_with_local(line, ".layout field ");
        let mut _let241 -> boolean = false;
        if starts_with_local(line, ".method ") { _let241 = true; }
        if starts_with_local(line, ".endmethod") { _let241 = true; }
        let is_method_line = _let241;

        // --- Pre-compute field parsing values ---
        let field_text = trim_text_local(substring(line, 7, line.length));
        let field_arrow_idx = index_of(field_text, " -> ");
        let f_name = trim_text_local(substring(field_text, 0, field_arrow_idx));
        let f_type = trim_text_local(substring(field_text, field_arrow_idx + 4, field_text.length));

        // --- Pre-compute layout struct values ---
        let ls_text = trim_text_local(substring(line, 15, line.length));
        let ls_size_idx = index_of(ls_text, "size=");
        let ls_align_idx = index_of(ls_text, "align=");
        // Parse size value using helper
        let ls_size_val = extract_kv_number(ls_text, "size=", 5);
        let ls_align_val = extract_kv_number(ls_text, "align=", 6);

        // --- Pre-compute layout field values ---
        let lf_text = trim_text_local(substring(line, 14, line.length));
        let lf_name_end = index_of(lf_text, " ");
        let lf_name_val = substring(lf_text, 0, lf_name_end);
        let lf_type_val = extract_kv_string(lf_text, "type=", 5);
        let lf_offset_val = extract_kv_number(lf_text, "offset=", 7);
        let lf_size_val = extract_kv_number(lf_text, "size=", 5);
        let lf_align_val = extract_kv_number(lf_text, "align=", 6);

        // --- .struct start ---
        if is_struct_start {
            in_struct = true;
            struct_name = trim_text_local(substring(line, 8, line.length));
            struct_fields = [];
            struct_methods = [];
            layout_fields = [];
            layout_size = 0;
            layout_align = 0;
            struct_layout = null;
            index += 1;
            continue;
        }

        // --- .endstruct with layout (FLAT — combined condition) ---
        let mut _if242 -> boolean = false;
        if is_struct_end {
            if in_struct {
                let mut _if259 -> boolean = false;
                if layout_size > 0 { _if259 = true; }
                if layout_fields.length > 0 { _if259 = true; }
                if _if259 {
                    _if242 = true;
                }
            }
        }
        if _if242 {
            struct_layout = make_native_struct_layout(layout_size, layout_align, layout_fields);
            structs = structs.push(make_native_struct(struct_name, struct_fields, struct_methods, struct_layout));
            in_struct = false;
            index += 1;
            continue;
        }
        // --- .endstruct without layout ---
        if is_struct_end {
            if in_struct {
                structs = structs.push(make_native_struct(struct_name, struct_fields, struct_methods, null));
                in_struct = false;
                index += 1;
                continue;
            }
        }
        if is_struct_end {
            index += 1;
            continue;
        }

        // --- Skip non-struct lines ---
        if !in_struct {
            index += 1;
            continue;
        }

        // --- .field (FLAT — combined condition) ---
        if is_field {
            if field_arrow_idx >= 0 {
                struct_fields = struct_fields.push(make_native_struct_field(f_name, f_type));
                index += 1;
                continue;
            }
        }
        if is_field {
            index += 1;
            continue;
        }

        // --- .layout struct (FLAT — separate top-level ifs) ---
        if is_layout_struct {
            if ls_size_idx >= 0 {
                layout_size = ls_size_val;
            }
        }
        if is_layout_struct {
            if ls_align_idx >= 0 {
                layout_align = ls_align_val;
            }
        }
        if is_layout_struct {
            index += 1;
            continue;
        }

        // --- .layout field (FLAT — all pre-computed) ---
        if is_layout_field {
            if lf_name_end >= 0 {
                layout_fields = layout_fields.push(make_native_struct_layout_field(lf_name_val, lf_type_val, lf_offset_val, lf_size_val, lf_align_val));
                index += 1;
                continue;
            }
        }
        if is_layout_field {
            layout_fields = layout_fields.push(make_native_struct_layout_field("", lf_type_val, lf_offset_val, lf_size_val, lf_align_val));
            index += 1;
            continue;
        }

        // --- .method / .endmethod ---
        if is_method_line {
            index += 1;
            continue;
        }
        index += 1;
    }
    // Final flush (FLAT — two separate checks)
    let mut _if243 -> boolean = false;
    if in_struct {
        let mut _if260 -> boolean = false;
        if layout_size > 0 { _if260 = true; }
        if layout_fields.length > 0 { _if260 = true; }
        if _if260 {
            _if243 = true;
        }
    }
    if _if243 {
        struct_layout = make_native_struct_layout(layout_size, layout_align, layout_fields);
        structs = structs.push(make_native_struct(struct_name, struct_fields, struct_methods, struct_layout));
    }
    if in_struct {
        if layout_size == 0 {
            if layout_fields.length == 0 {
                structs = structs.push(make_native_struct(struct_name, struct_fields, struct_methods, null));
            }
        }
    }
    return structs;
}

fn parse_number_local(text -> string) -> number {
    let trimmed = trim_text_local(text);
    if trimmed.length == 0 {
        return 0;
    }
    let mut result -> number = 0;
    let mut i -> number = 0;
    loop {
        if i >= trimmed.length {
            break;
        }
        let ch = trimmed[i];
        let code = char_code(ch);
        let digit = code - char_code("0");
        let mut _if244 -> boolean = false;
        if digit < 0 { _if244 = true; }
        if digit > 9 { _if244 = true; }
        if _if244 {
            break;
        }
        result = result * 10 + digit;
        i += 1;
    }
    return result;
}

// Extract a numeric value from "key=value" pattern in text.
// key_prefix is e.g. "size=", prefix_len is its length (e.g. 5).
// FLAT: no nested ifs — uses conditional computation without nesting.
fn extract_kv_number(text -> string, key_prefix -> string, prefix_len -> number) -> number {
    let key_idx = index_of(text, key_prefix);
    if key_idx < 0 {
        return 0;
    }
    let val_start = key_idx + prefix_len;
    let rest = substring(text, val_start, text.length);
    let space_idx = index_of(rest, " ");
    // If no space, value goes to end of string
    let val_text_no_space = substring(text, val_start, text.length);
    let val_text_with_space = substring(text, val_start, val_start + space_idx);
    if space_idx < 0 {
        return parse_number_local(val_text_no_space);
    }
    return parse_number_local(val_text_with_space);
}

// Extract a string value from "key=value" pattern in text.
fn extract_kv_string(text -> string, key_prefix -> string, prefix_len -> number) -> string {
    let key_idx = index_of(text, key_prefix);
    if key_idx < 0 {
        return "";
    }
    let val_start = key_idx + prefix_len;
    let rest = substring(text, val_start, text.length);
    let space_idx = index_of(rest, " ");
    if space_idx < 0 {
        return substring(text, val_start, text.length);
    }
    return substring(text, val_start, val_start + space_idx);
}

fn recover_functions_for_lowering(current_functions -> NativeFunction[], native_text_override_path -> string, artifact_text -> string, debug_lowering -> boolean) -> NativeFunction[] ![io] {
    let mut safe_functions = current_functions;
    if safe_functions == null {
        safe_functions = [];
    }
    let initial_function_count = sanitize_collection_length(safe_functions.length, 200000);
    if safe_functions.length != initial_function_count {
        if debug_lowering {
            print("emit-llvm: invalid function list length; dropping current parsed functions");
        }
        safe_functions = [];
    }
    if safe_functions.length > 0 {
        let mut expected_source_text = artifact_text;
        if expected_source_text.length == 0 {
            if native_text_override_path.length > 0 {
                expected_source_text = native_text_override_path;
            }
        }
        if expected_source_text.length == 0 {
            if fs.exists("build/sailfin/emit-native.tmp") {
                expected_source_text = fs.readFile("build/sailfin/emit-native.tmp");
            }
        }

        if expected_source_text.length > 0 {
            let expected_functions = parse_native_functions_from_text(expected_source_text);
            let expected_count = sanitize_collection_length(expected_functions.length, 200000);
            if expected_count > 0 {
                let mut use_expected = false;
                if safe_functions.length != expected_count {
                    use_expected = true;
                }

                let mut has_body_instructions = false;
                let mut body_index -> number = 0;
                loop {
                    if body_index >= initial_function_count {
                        break;
                    }
                    let function = safe_functions[body_index];
                    if !function.is_extern {
                        if function.instructions != null {
                            if function.instructions.length > 0 {
                                has_body_instructions = true;
                                break;
                            }
                        }
                    }
                    body_index += 1;
                }
                if !has_body_instructions {
                    use_expected = true;
                }

                let mut index -> number = 0;
                loop {
                    let mut _if245 -> boolean = false;
                    if index >= initial_function_count { _if245 = true; }
                    if index >= expected_count { _if245 = true; }
                    if _if245 {
                        break;
                    }
                    let safe_name = trim_text_local(safe_functions[index].name);
                    let expected_name = trim_text_local(expected_functions[index].name);
                    let mut _if246 -> boolean = false;
                    if safe_name.length == 0 { _if246 = true; }
                    if safe_name == "_" { _if246 = true; }
                    if _if246 {
                        use_expected = true;
                        break;
                    }
                    if expected_name.length == 0 {
                        use_expected = true;
                        break;
                    }
                    if safe_name != expected_name {
                        use_expected = true;
                        break;
                    }
                    index += 1;
                }

                if use_expected {
                    let mut replacement_functions = expected_functions;
                    let light_functions = recover_native_functions_light(expected_source_text);
                    let light_count = sanitize_collection_length(light_functions.length, 200000);
                    let mut light_has_body = false;
                    let mut light_index -> number = 0;
                    loop {
                        if light_index >= light_count {
                            break;
                        }
                        let function = light_functions[light_index];
                        if !function.is_extern {
                            if function.instructions != null {
                                if function.instructions.length > 0 {
                                    light_has_body = true;
                                    break;
                                }
                            }
                        }
                        light_index += 1;
                    }
                    if light_has_body {
                        replacement_functions = light_functions;
                    }
                    if debug_lowering {
                        print(
                            "emit-llvm: replacing suspicious parsed functions with stable function parse"
                        );
                    }
                    safe_functions = replacement_functions;
                }
            }
        }
        return safe_functions;
    }

    let mut recovery_text = "";
    if native_text_override_path.length > 0 {
        recovery_text = native_text_override_path;
    }
    if recovery_text.length == 0 {
        if artifact_text.length > 0 {
            recovery_text = artifact_text;
        }
    }
    if recovery_text.length == 0 {
        if fs.exists("build/sailfin/emit-native.tmp") {
            recovery_text = fs.readFile("build/sailfin/emit-native.tmp");
        }
    }

    let direct_count = parse_native_function_count_from_text(recovery_text);
    if debug_lowering {
        print("emit-llvm: recovery source direct count=" + number_to_string(direct_count));
    }
    if direct_count == 0 {
        if fs.exists("build/sailfin/emit-native.tmp") {
            recovery_text = fs.readFile("build/sailfin/emit-native.tmp");
        }
    }

    let parsed_recovery = parse_native_functions_from_text(recovery_text);
    let recovered_count = sanitize_collection_length(parsed_recovery.length, 200000);
    if parsed_recovery.length == recovered_count {
        if parsed_recovery.length > 0 {
            if debug_lowering {
                print("emit-llvm: recovered functions via parse_native_functions_from_text=" + number_to_string(parsed_recovery.length));
            }
            return parsed_recovery;
        }
    }

    let light_recovery = recover_native_functions_light(recovery_text);
    let light_recovered_count = sanitize_collection_length(light_recovery.length, 200000);
    if light_recovery.length == light_recovered_count {
        if light_recovery.length > 0 {
            if debug_lowering {
                print("emit-llvm: recovered functions via light parser=" + number_to_string(light_recovery.length));
            }
            return light_recovery;
        }
    }

    if fs.exists("build/sailfin/emit-native.tmp") {
        let disk_recovery_text = fs.readFile("build/sailfin/emit-native.tmp");
        let disk_recovery = recover_native_functions_light(disk_recovery_text);
        if disk_recovery.length > 0 {
            return disk_recovery;
        }
    }
    return [];
}


fn lower_to_llvm_lines_with_parsed_context_for_tests(native_module -> NativeModule, parse -> ParseNativeResult, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], imported_diagnostics -> string[]) -> LoweredLLVMLinesResult {
    let base = lower_to_llvm_lines_with_parsed_context(native_module, parse, imported_manifests, imported_native_texts, imported_diagnostics, false, "");
    if base.lines.length == 0 {
        return base;
    }

    let mut tests -> NativeFunction[] = [];
    let mut has_main -> boolean = false;

    let mut index -> number = 0;
    loop {
        if index >= parse.functions.length {
            break;
        }
        let fun = parse.functions[index];
        if fun.name == "main" {
            has_main = true;
        }
        if fun.name.length >= 5 {
            if substring(fun.name, 0, 5) == "test:" {
                tests = tests.push(fun);
            }
        }
        index += 1;
    }

    if tests.length == 0 {
        return base;
    }

    if has_main {
        let mut updated = base;
        updated.diagnostics.push("llvm lowering (test): module defines `main`; skipping synthesized test harness");
        return updated;
    }

    let harness = render_test_harness_main_for_module(tests, native_module.module_name, false);
    let mut updated = base;
    if updated.lines.length > 0 {
        updated.lines.push("");
    }
    updated.lines = extend_string_lines(updated.lines, harness);
    return updated;
}

// Consolidated compilation entry point — keeps all complex logic intra-module
// so the seed's cross-module ABI bugs and struct literal drops don't affect it.
fn build_parse_result_from_text(native_text -> string) -> ParseNativeResult {
    let recovered_functions = recover_native_functions_light(native_text);
    let recovered_structs = recover_native_structs_light(native_text);
    let recovered_imports = recover_native_imports_light(native_text);
    return ParseNativeResult {
        functions: recovered_functions,
        imports: recovered_imports,
        structs: recovered_structs,
        interfaces: [],
        enums: [],
        bindings: [],
        diagnostics: [],
    };
}

fn make_native_module_for_emit(module_name -> string, native_text -> string) -> NativeModule {
    return NativeModule {
        module_name: module_name,
        artifacts: [NativeArtifact { name: module_name, format: "sailfin-native-text", contents: native_text }],
        entry_points: [],
        symbol_count: 0,
    };
}

fn compile_native_text_to_llvm_file(native_text_path -> string, module_name -> string, out_path -> string) -> boolean ![io] {
    if !fs.exists(native_text_path) {
        print("emit-llvm: native text file missing at " + native_text_path);
        return false;
    }
    let native_text = fs.readFile(native_text_path);
    if native_text.length == 0 {
        print("emit-llvm: native text file empty at " + native_text_path);
        return false;
    }
    print("emit-llvm: compile_native_text_to_llvm_file module=" + module_name + " bytes=" + number_to_string(native_text.length));
    let parse = build_parse_result_from_text(native_text);
    // Recover imports separately — field access on parse uses sailfin_runtime_get_field
    // which does not work on plain C structs built by the fixup pass.
    let raw_imports = recover_native_imports_light(native_text);
    fs.writeFile("build/sailfin/emit-native.tmp", native_text);
    let import_context = collect_imported_module_context_for_module(raw_imports, module_name);
    print("emit-llvm: import context collected");
    let dummy_module = make_native_module_for_emit(module_name, native_text);
    print("emit-llvm: module created, entering lowering");
    let lowered_lines = lower_to_llvm_lines_with_parsed_context(
        dummy_module,
        parse,
        import_context.manifests,
        import_context.native_texts,
        import_context.diagnostics,
        true,
        native_text
    );
    if lowered_lines.lines == null {
        print("emit-llvm: lowered lines null");
        return false;
    }
    let lowered_count = lowered_lines.lines.length;
    if lowered_count > 0 {
        let defined = collect_defined_function_symbols(lowered_lines.lines);
        print("emit-llvm: lowered (defined=" + number_to_string(defined.length) + ")");
        if defined.length == 0 {
            return false;
        }
    }
    let lines = lowered_lines.lines;
    let mut _if247 -> boolean = false;
    if lines == null { _if247 = true; }
    if lines.length == 0 { _if247 = true; }
    if _if247 {
        print("emit-llvm: lowering produced no output lines");
        return false;
    }
    if fs.exists(out_path) {
        fs.deleteFile(out_path);
    }
    return write_llvm_lines_chunked(out_path, lines);
}

fn lower_to_llvm_lines_with_parsed_context(native_module -> NativeModule, parse_in -> ParseNativeResult, imported_manifests -> LayoutManifest[], imported_native_texts -> string[], diagnostics_in -> string[], mangle_symbols -> boolean, native_text_override_path -> string) -> LoweredLLVMLinesResult ![io] {
