            diagnostics.push(else_result.diagnostics[_ci15]);
            _ci15 += 1;
        }
        lifetime_regions = extend_lifetime_regions(lifetime_regions, else_result.lifetime_regions);
        current_allocas = else_result.allocas;
        current_locals = else_result.locals;
        current_temp = _br_else_temp;
        current_block_counter = _br_else_blkctr;
        current_next_local = _br_else_nextloc;
        else_bindings = else_result.bindings;
        current_next_region = _br_else_nextreg;
        current_lines = extend_string_array(current_lines, else_result.lines);
        else_terminated = _br_else_term;
        let exit_label = find_last_label(current_lines, else_label);
        else_exit_label = exit_label;
        let mut branch_mutations = retarget_recent_mutations(else_result.mutations, 0, exit_label);
        else_mutations = branch_mutations;
        collected_mutations = extend_mutations(collected_mutations, else_mutations);
        collected_string_constants = merge_string_constants(collected_string_constants, else_result.string_constants);
        if !else_terminated {
