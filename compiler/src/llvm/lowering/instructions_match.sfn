        }
    }

    let mut merged_lines -> string[] = current_lines;
    if merged_lines.length < base_lines_snapshot.length {
        merged_lines = extend_string_array(base_lines_snapshot, merged_lines);
    }

    _write_block_result_files(merged_lines, current_allocas, terminated, diagnostics, collected_string_constants, current_locals, merged_bindings, current_temp, current_block_counter, current_next_local, current_next_region, structure.next_index + 1, collected_mutations, lifetime_regions);
    return BlockLoweringResult {
        lines: merged_lines,
        allocas: current_allocas,
        locals: current_locals,
        bindings: merged_bindings,
        temp_index: current_temp,
        block_counter: current_block_counter,
        diagnostics: diagnostics,
        terminated: terminated,
        next_local_id: current_next_local,
        lifetime_regions: lifetime_regions,
        next_lifetime_region_id: current_next_region,
        next_index: structure.next_index + 1,
    mutations: collected_mutations, string_constants: collected_string_constants,
    };
}

fn sanitize_if_condition_text(condition -> string) -> string {
    let trimmed = trim_text(condition);
    if trimmed.length == 0 {
        return trimmed;
    }

    // If the condition starts with a brace, it's likely an expression (e.g. struct literal)
    // rather than an if-block opener.
    if starts_with(trimmed, "{") {
        return trimmed;
    }

    // Scan for a top-level `{` that appears after some expression content; treat it as the
    // start of the if body and truncate.
    let mut paren_depth -> number = 0;
    let mut bracket_depth -> number = 0;
    let mut brace_depth -> number = 0;
    let mut in_string -> boolean = false;
    let mut escape_next -> boolean = false;
    let mut index -> number = 0;

    loop {
        if index >= trimmed.length {
            break;
        }
        let ch = substring(trimmed, index, index + 1);
        if in_string {
            if escape_next {
                escape_next = false;
                index += 1;
                continue;
            }
            if ch == "\\" {
                escape_next = true;
                index += 1;
                continue;
            }
            if ch == "\"" {
                in_string = false;
            }
            index += 1;
            continue;
        }

        if ch == "\"" {
            in_string = true;
            index += 1;
            continue;
        }

        if ch == "(" {
            paren_depth += 1;
            index += 1;
            continue;
        }
        if ch == ")" {
            if paren_depth > 0 {
                paren_depth -= 1;
            }
            index += 1;
            continue;
        }
        if ch == "[" {
            bracket_depth += 1;
            index += 1;
            continue;
        }
        if ch == "]" {
            if bracket_depth > 0 {
                bracket_depth -= 1;
            }
            index += 1;
            continue;
        }
        if ch == "{" {
            if paren_depth == 0 {
                if bracket_depth == 0 {
                    if brace_depth == 0 {
                        if index > 0 {
                            // Truncate at the body opener.
                            return trim_text(substring(trimmed, 0, index));
                        }
                    }
                }
            }
            brace_depth += 1;
            index += 1;
            continue;
        }
        if ch == "}" {
            if brace_depth > 0 {
                brace_depth -= 1;
            }
            index += 1;
            continue;
        }

        index += 1;
    }

    return trimmed;
}

