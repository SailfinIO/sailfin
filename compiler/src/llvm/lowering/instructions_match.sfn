                name_idx += 1;
            }
            if then_exit_loads.length > 0 {
                if then_merge_insert_index >= 0 {
                    current_lines = insert_lines_before_index(current_lines, then_merge_insert_index, then_exit_loads);
                    then_mutations = extend_mutations(then_mutations, then_added);
                    collected_mutations = extend_mutations(collected_mutations, then_added);
                }
