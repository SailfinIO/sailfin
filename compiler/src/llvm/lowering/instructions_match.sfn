                            inserted_then = true;

                            current_lines = insert_lines_before_index(current_lines, else_merge_insert_index, else_exit_loads);
                            else_mutations = extend_mutations(else_mutations, else_added);
                            collected_mutations = extend_mutations(collected_mutations, else_added);
                            inserted_else = true;
                        } else {
                            current_lines = insert_lines_before_index(current_lines, else_merge_insert_index, else_exit_loads);
                            else_mutations = extend_mutations(else_mutations, else_added);
                            collected_mutations = extend_mutations(collected_mutations, else_added);
                            inserted_else = true;

                            current_lines = insert_lines_before_index(current_lines, then_merge_insert_index, then_exit_loads);
                            then_mutations = extend_mutations(then_mutations, then_added);
                            collected_mutations = extend_mutations(collected_mutations, then_added);
                            inserted_then = true;
                        }
                    }
                }
            }
        }

        if !inserted_then {
            if then_exit_loads.length > 0 {
                if then_merge_insert_index >= 0 {
                    current_lines = insert_lines_before_index(current_lines, then_merge_insert_index, then_exit_loads);
                    then_mutations = extend_mutations(then_mutations, then_added);
                    collected_mutations = extend_mutations(collected_mutations, then_added);
                }
            }
        }

        if !inserted_else {
            if else_exit_loads.length > 0 {
                if else_merge_insert_index >= 0 {
                    current_lines = insert_lines_before_index(current_lines, else_merge_insert_index, else_exit_loads);
                    else_mutations = extend_mutations(else_mutations, else_added);
                    collected_mutations = extend_mutations(collected_mutations, else_added);
