                            let _lines_count_str = fs.readFile("build/sailfin/.let_result_lines_count");
                            let _lines_count = _parse_int_from_string(_lines_count_str);
                            let mut _new_lines2 -> string[] = [];
                            let mut _li2 -> number = 0;
                            loop {
