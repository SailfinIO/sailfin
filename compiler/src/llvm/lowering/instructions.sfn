                        if _tab1 < 0 { continue; }
                        let _sc_name = substring(_sc_line, 0, _tab1);
                        let _sc_rest = substring(_sc_line, _tab1 + 1, _sc_line.length);
                        let _tab2 = index_of(_sc_rest, "\t");
                        if _tab2 < 0 { continue; }
                        let _sc_content = substring(_sc_rest, 0, _tab2);
                        let _sc_bc_text = substring(_sc_rest, _tab2 + 1, _sc_rest.length);
                        let _sc_bc = _parse_int_from_string(_sc_bc_text);
                        collected_string_constants = _instr_append_string_constant(collected_string_constants, _sc_name, _sc_content, _sc_bc);
                    }
