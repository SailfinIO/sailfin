                function,
                index,
                llvm_return,
                current_bindings,
                current_locals,
                current_allocas,
                current_lines,
                current_temp,
                current_block_counter,
                current_next_local,
                current_next_region,
                functions,
                current_loop_stack,
                end,
                context,
                scope_id,
                scope_depth,
                active_label
            );
