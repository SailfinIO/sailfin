                    fs.deleteFile(elc_prefix + "_llvm_type");
                    fs.deleteFile(elc_prefix + "_type_annotation");
                    fs.deleteFile(elc_prefix + "_scope_id");
                    fs.deleteFile(elc_prefix + "_scope_depth");
