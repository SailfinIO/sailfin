                            current_temp = _parse_int_from_string(fs.readFile("build/sailfin/.let_result_temp_index"));
                            current_next_local = _parse_int_from_string(fs.readFile("build/sailfin/.let_result_next_local_id"));
                            current_next_region = _parse_int_from_string(fs.readFile("build/sailfin/.let_result_next_region_id"));
                            if fs.exists("build/sailfin/.let_result_local_name") {
                                let _new_local_name = fs.readFile("build/sailfin/.let_result_local_name");
                                let _new_local_pointer = fs.readFile("build/sailfin/.let_result_local_pointer");
                                let _new_local_type = fs.readFile("build/sailfin/.let_result_local_llvm_type");
                                let _new_local_ann = fs.readFile("build/sailfin/.let_result_local_type_ann");
                                current_locals = append_local_binding(current_locals, LocalBinding { name: _new_local_name, pointer: _new_local_pointer, llvm_type: _new_local_type, type_annotation: _new_local_ann, ownership: null, consumed: false, scope_id: scope_id, scope_depth: scope_depth });
                            }
