            // them to current_lines via pass-by-reference (arrays are shared).
            let _ret_temp_str = fs.readFile("build/sailfin/.expr_stmt_temp_index");
            current_temp = _parse_int_from_string(_ret_temp_str);
            let _ret_region_str = fs.readFile("build/sailfin/.expr_stmt_next_region_id");
            current_next_region = _parse_int_from_string(_ret_region_str);
