                    if !fs.exists(ebc_prefix + "_name") { break; }
                    fs.deleteFile(ebc_prefix + "_name");
                    fs.deleteFile(ebc_prefix + "_llvm_name");
                    fs.deleteFile(ebc_prefix + "_llvm_type");
                    fs.deleteFile(ebc_prefix + "_type_annotation");
                    ebc_i += 1;
                }
                let mut ebw_i -> number = 0;
                loop {
                    if ebw_i >= current_bindings.length { break; }
                    let ebw_prefix = "build/sailfin/.instr_binding_" + number_to_string(ebw_i);
                    fs.writeFile(ebw_prefix + "_name", current_bindings[ebw_i].name);
                    fs.writeFile(ebw_prefix + "_llvm_name", current_bindings[ebw_i].llvm_name);
                    fs.writeFile(ebw_prefix + "_llvm_type", current_bindings[ebw_i].llvm_type);
                    fs.writeFile(ebw_prefix + "_type_annotation", current_bindings[ebw_i].type_annotation);
