fn _write_block_result_files(
    lines -> string[],
    allocas -> string[],
    terminated -> boolean,
    diagnostics -> string[],
    string_constants -> StringConstant[],
    temp_index -> number,
    block_counter -> number,
    next_local_id -> number,
    next_lifetime_region_id -> number,
    next_index -> number
) ![io] {
    let mut joined_lines -> string = "";
    let mut li -> number = 0;
    loop {
        if li >= lines.length { break; }
        if li > 0 {
            joined_lines = joined_lines + "\n";
        }
        joined_lines = joined_lines + lines[li];
        li = li + 1;
    }
    fs.writeFile("build/sailfin/.block_result_lines", joined_lines);

    let mut joined_allocas -> string = "";
    let mut ai -> number = 0;
    loop {
        if ai >= allocas.length { break; }
        if ai > 0 {
            joined_allocas = joined_allocas + "\n";
        }
        joined_allocas = joined_allocas + allocas[ai];
        ai = ai + 1;
    }
    fs.writeFile("build/sailfin/.block_result_allocas", joined_allocas);

    let mut term_val -> string = "0";
    if terminated {
        term_val = "1";
    }
    fs.writeFile("build/sailfin/.block_result_terminated", term_val);

    let mut joined_diags -> string = "";
    let mut di -> number = 0;
    loop {
        if di >= diagnostics.length { break; }
        if di > 0 {
            joined_diags = joined_diags + "\n";
        }
        joined_diags = joined_diags + diagnostics[di];
        di = di + 1;
    }
    fs.writeFile("build/sailfin/.block_result_diagnostics", joined_diags);

    // Serialize string constants so emit_body can read them back.
    // Format: one constant per line as "name\tcontent\tbyte_count".
    let mut joined_sc -> string = "";
    let mut si -> number = 0;
    loop {
        if si >= string_constants.length { break; }
        if si > 0 {
            joined_sc = joined_sc + "\n";
        }
        joined_sc = joined_sc + string_constants[si].name + "\t" + string_constants[si].content + "\t" + number_to_string(string_constants[si].byte_count);
        si = si + 1;
    }
    fs.writeFile("build/sailfin/.block_result_string_constants", joined_sc);

    // Scalar state fields needed by callers in other modules (instructions_match, instructions_loops).
    fs.writeFile("build/sailfin/.block_result_temp_index", number_to_string(temp_index));
    fs.writeFile("build/sailfin/.block_result_block_counter", number_to_string(block_counter));
    fs.writeFile("build/sailfin/.block_result_next_local_id", number_to_string(next_local_id));
    fs.writeFile("build/sailfin/.block_result_next_lifetime_region_id", number_to_string(next_lifetime_region_id));
    fs.writeFile("build/sailfin/.block_result_next_index", number_to_string(next_index));
    // Note: array fields (locals, bindings, mutations, lifetime_regions) are NOT written here
    // because callers access them directly via the returned BlockLoweringResult pointer fields,
    // which survive cross-module ABI corruption intact. Only scalar fields are corrupted.
}

fn _parse_int_from_string(text -> string) -> number {
    let len = text.length;
    if len == 0 { return 0; }
    let mut result -> number = 0;
    let mut i -> number = 0;
    let first_ch = grapheme_at(text, 0);
    if first_ch == "-" {
        i = 1;
    }
    loop {
        if i >= len { break; }
        let ch = grapheme_at(text, i);
        if ch == "." { break; }
        let code = char_code(ch);
        if code >= 48 {
            if code <= 57 {
                result = result * 10 + (code - 48);
            }
        }
        i = i + 1;
    }
    if first_ch == "-" {
        return 0 - result;
    }
    return result;
}

fn _instr_append_mutation(mutations -> LocalMutation[], name -> string, llvm_type -> string, value_name -> string, originating_label -> string) -> LocalMutation[] {
    let new_entry -> LocalMutation[] = [LocalMutation {
        name: name,
        llvm_type: llvm_type,
        value_name: value_name,
        span: null,
        originating_label: originating_label,
    }];
    return extend_mutations(mutations, new_entry);
}

fn _instr_append_string_constant(constants -> StringConstant[], name -> string, content -> string, byte_count -> number) -> StringConstant[] {
    let new_entry -> StringConstant[] = [StringConstant { name: name, content: content, byte_count: byte_count }];
    return merge_string_constants(constants, new_entry);
}

fn lower_instruction_range(
    function -> NativeFunction,
    start_index -> number,
    end -> number,
    llvm_return -> string,
    bindings -> ParameterBinding[],
    locals -> LocalBinding[],
    allocas -> string[],
    lines -> string[],
    temp_index -> number,
    block_counter -> number,
    next_local_id -> number,
    next_region_id -> number,
    functions -> NativeFunction[],
    loop_stack -> LoopContext[],
    context -> TypeContext,
    scope_id -> string,
    scope_depth -> number,
    current_label -> string
) -> BlockLoweringResult ![io] {
    let mut diagnostics -> string[] = [];
    let mut current_lines -> string[] = lines;
    let mut current_allocas -> string[] = allocas;
    let mut current_locals -> LocalBinding[] = locals;
    let mut current_bindings -> ParameterBinding[] = bindings;
    let mut current_temp -> number = temp_index;
    let mut current_block_counter -> number = block_counter;
    let mut current_next_local -> number = next_local_id;
    let mut current_next_region -> number = next_region_id;
    let mut terminated -> boolean = false;
    let mut current_loop_stack -> LoopContext[] = loop_stack;
    let mut index -> number = start_index;
    let mut collected_lifetime_regions -> LifetimeRegionMetadata[] = [];
    let mut current_mutations -> LocalMutation[] = [];
    let mut collected_string_constants -> StringConstant[] = empty_string_constant_set();
    let mut active_label -> string = current_label;
    let mut guard -> number = 0;
    let max_guard = (end - start_index) * 16 + 1024;
    let debug_lowering = fs.exists("build/sailfin/.trace_lowering");
    if debug_lowering {
        print("emit-llvm: lower_instruction_range name=" + function.name + " start=" + number_to_string(start_index) + " end=" + number_to_string(end) + " depth=" + number_to_string(scope_depth));
        print("emit-llvm: lower_instruction_range bindings_len=" + number_to_string(bindings.length) + " current_bindings_len=" + number_to_string(current_bindings.length));
    }
    let mut _let220 -> boolean = false;
    if fs.exists("build/sailfin/.trace_test_runner") {
        if fs.exists("build/sailfin/.test_runner_active") {
            _let220 = true;
        }
    }
    let trace = _let220;
    if trace {
        if start_index == 0 {
            if scope_depth == 0 {
                print(
                    "test llvm: lower_instruction_range start "
                    + function.name
                    + " end="
                    + number_to_string(end)
                );
                let mut preview_index -> number = start_index;
                let mut preview_limit -> number = start_index + 5;
                if preview_limit > end {
                    preview_limit = end;
                }
                loop {
                    if preview_index >= preview_limit {
                        break;
                    }
                    let _preview_tag = get_instruction_tag(function.instructions, preview_index);
                    print(
                        "test llvm: instr "
                        + number_to_string(preview_index)
                        + " tag="
                        + number_to_string(_preview_tag)
                    );
                    preview_index += 1;
                }
            }
        }
    }

    loop {
        if index >= end {
            if debug_lowering {
                print("emit-llvm: loop-exit index=" + number_to_string(index) + " end=" + number_to_string(end) + " fn=" + function.name);
            }
            // Write block results and return directly from inside the loop.
            // The v0.1.1 seed generates unconditional `br label %loop.body` for
            // loop.header20, meaning `break` never actually exits. Using `return`
            // instead bypasses the broken loop header entirely.
            _write_block_result_files(current_lines, current_allocas, terminated, diagnostics, collected_string_constants, current_temp, current_block_counter, current_next_local, current_next_region, index);
            return BlockLoweringResult {
                lines: current_lines,
                allocas: current_allocas,
                locals: current_locals,
                bindings: current_bindings,
                temp_index: current_temp,
                block_counter: current_block_counter,
                diagnostics: diagnostics,
                terminated: terminated,
                next_local_id: current_next_local,
                lifetime_regions: collected_lifetime_regions,
                next_lifetime_region_id: current_next_region,
                next_index: index,
                mutations: current_mutations,
                string_constants: collected_string_constants,
            };
        }
        if guard > max_guard {
            diagnostics = append_string(
                diagnostics,
                "llvm lowering: instruction loop exceeded limit in `" + function.name + "` (index=" + number_to_string(index) + ")"
            );
            if trace {
                print(
                    "test llvm: instruction loop exceeded limit in " + function.name
                    + " index=" + number_to_string(index)
                    + " end=" + number_to_string(end)
                );
            }
            // Return directly (same loop-break workaround as index>=end case)
            _write_block_result_files(current_lines, current_allocas, terminated, diagnostics, collected_string_constants, current_temp, current_block_counter, current_next_local, current_next_region, index);
            return BlockLoweringResult {
                lines: current_lines,
                allocas: current_allocas,
                locals: current_locals,
                bindings: current_bindings,
                temp_index: current_temp,
                block_counter: current_block_counter,
                diagnostics: diagnostics,
                terminated: terminated,
                next_local_id: current_next_local,
                lifetime_regions: collected_lifetime_regions,
                next_lifetime_region_id: current_next_region,
                next_index: index,
                mutations: current_mutations,
                string_constants: collected_string_constants,
            };
        }
        guard += 1;

        let instruction = function.instructions[index];
        // Use numeric tag accessor instead of .variant (which returns empty via get_field stub)
        let _instr_tag = get_instruction_tag(function.instructions, index);
        if debug_lowering {
            print("emit-llvm: lir guard=" + number_to_string(guard) + " index=" + number_to_string(index) + " tag=" + number_to_string(_instr_tag) + " fn=" + function.name + " depth=" + number_to_string(scope_depth));
        }
        if trace {
            if index == start_index {
                print("test llvm: lower_instruction_range first_tag " + number_to_string(_instr_tag));
            }
        }
        // Tag constants: Return=0, Expression=1, Let=2, If=3, Else=4, EndIf=5,
        //   For=6, EndFor=7, Loop=8, EndLoop=9, Break=10, Continue=11,
        //   Match=12, Case=13, EndMatch=14, Try=15, Catch=16, Finally=17,
        //   EndTry=18, Throw=19, Noop=20, Unknown=21
        if _instr_tag == 2 {
            let lowered = lower_let_instruction(function, instruction, current_bindings, current_locals, current_allocas, current_lines, current_temp, current_next_local, current_next_region, functions, context, scope_id, scope_depth, active_label);
            // LetLoweringResult struct fields may be corrupted crossing module
            // boundaries. Read key results from files written by lower_let_instruction.
            if fs.exists("build/sailfin/.let_result_temp_index") {
                // Read diagnostics from files
                let _diag_count_str = fs.readFile("build/sailfin/.let_result_diag_count");
                let _diag_count = _parse_int_from_string(_diag_count_str);
                let mut _di -> number = 0;
                loop {
                    if _di >= _diag_count { break; }
                    let _diag_path = "build/sailfin/.let_result_diag_" + number_to_string(_di);
                    if fs.exists(_diag_path) {
                        diagnostics.push(fs.readFile(_diag_path));
                    }
                    _di += 1;
                }
                // Read lines from files
                let _lines_count_str = fs.readFile("build/sailfin/.let_result_lines_count");
                let _lines_count = _parse_int_from_string(_lines_count_str);
                let mut _new_lines -> string[] = [];
                let mut _li -> number = 0;
                loop {
                    if _li >= _lines_count { break; }
                    let _line_path = "build/sailfin/.let_result_line_" + number_to_string(_li);
                    if fs.exists(_line_path) {
                        _new_lines.push(fs.readFile(_line_path));
                    }
                    _li += 1;
                }
                current_lines = _new_lines;
                // Read allocas from files
                let _allocas_count_str = fs.readFile("build/sailfin/.let_result_allocas_count");
                let _allocas_count = _parse_int_from_string(_allocas_count_str);
                let mut _new_allocas -> string[] = [];
                let mut _ai -> number = 0;
                loop {
                    if _ai >= _allocas_count { break; }
                    let _alloca_path = "build/sailfin/.let_result_alloca_" + number_to_string(_ai);
                    if fs.exists(_alloca_path) {
                        _new_allocas.push(fs.readFile(_alloca_path));
                    }
                    _ai += 1;
                }
                current_allocas = _new_allocas;
                // Read scalar results
                current_temp = _parse_int_from_string(fs.readFile("build/sailfin/.let_result_temp_index"));
                current_next_local = _parse_int_from_string(fs.readFile("build/sailfin/.let_result_next_local_id"));
                current_next_region = _parse_int_from_string(fs.readFile("build/sailfin/.let_result_next_region_id"));
                // Read the new local binding
                if fs.exists("build/sailfin/.let_result_local_name") {
                    let _new_local_name = fs.readFile("build/sailfin/.let_result_local_name");
                    let _new_local_pointer = fs.readFile("build/sailfin/.let_result_local_pointer");
                    let _new_local_type = fs.readFile("build/sailfin/.let_result_local_llvm_type");
                    let _new_local_ann = fs.readFile("build/sailfin/.let_result_local_type_ann");
                    current_locals = append_local_binding(current_locals, LocalBinding { name: _new_local_name, pointer: _new_local_pointer, llvm_type: _new_local_type, type_annotation: _new_local_ann, ownership: null, consumed: false, scope_id: scope_id, scope_depth: scope_depth });
                }
                // Note: bindings, lifetime_regions, lifetime_releases, mutations,
                // string_constants are not serialized — they rarely change in let lowering
                // and the corruption is tolerable for now.
                // Clean up sentinel to prevent stale data on next iteration
                fs.deleteFile("build/sailfin/.let_result_temp_index");
                if fs.exists("build/sailfin/.let_result_local_name") {
                    fs.deleteFile("build/sailfin/.let_result_local_name");
                }
            } else {
                // Fallback: try struct fields (may crash if corrupted)
                diagnostics = extend_string_array(diagnostics, lowered.diagnostics);
                collected_lifetime_regions = extend_lifetime_regions(collected_lifetime_regions, lowered.lifetime_regions);
                collected_lifetime_regions = apply_lifetime_release_events(collected_lifetime_regions, lowered.lifetime_releases);
                current_lines = lowered.lines;
                current_allocas = lowered.allocas;
                current_locals = lowered.locals;
                current_bindings = lowered.bindings;
                current_temp = lowered.temp_index;
                current_next_local = lowered.next_local_id;
                current_next_region = lowered.next_region_id;
                current_mutations = extend_mutations(current_mutations, lowered.mutations);
                let temp_constants = collected_string_constants;
                collected_string_constants = merge_string_constants(temp_constants, lowered.string_constants);
            }
            active_label = find_last_label(current_lines, active_label);
            if trace {
                if function.name == "infer_effects" {
                    print("test llvm: infer_effects after Let lines=" + number_to_string(current_lines.length));
                }
            }
            index += 1;
            continue;
        } else if _instr_tag == 1 {
            if debug_lowering {
