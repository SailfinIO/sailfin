                    fs.writeFile(elw_prefix + "_name", current_locals[elw_i].name);
                    fs.writeFile(elw_prefix + "_pointer", current_locals[elw_i].pointer);
                    fs.writeFile(elw_prefix + "_llvm_type", current_locals[elw_i].llvm_type);
