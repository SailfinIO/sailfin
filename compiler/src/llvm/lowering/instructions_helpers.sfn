// compiler/src/llvm/lowering/instructions_helpers.sfn
//
// Shared helper utilities extracted from instructions.sfn so that
// lower_instruction_range occupies position 1 in its module -- within
// the v0.1.1 seed's per-module streaming emission limit.

import { NativeFunction, NativeInstruction, NativeSourceSpan } from "../../native_ir";
import { substring, char_code, grapheme_at } from "../../string_utils";

import {
    TypeContext,
    LocalBinding,
    ParameterBinding,
    LLVMOperand,
    BlockLoweringResult,
    LetLoweringResult,
    LoopContext,
    LifetimeRegionMetadata,
    LifetimeReleaseEvent,
    OwnershipInfo,
    OwnershipConsumption,
    ScopeMetadata,
    LocalMutation,
    StringConstant,
} from "../types";

import {
    trim_text,
    append_string,
    extend_string_array,
    number_to_string,
    index_of,
    starts_with,
} from "../utils";

import {
    merge_string_constants,
} from "../strings";

import {
    append_local_binding,
} from "../expression_lowering/native/core_scopes";

fn clone_local_bindings(values -> LocalBinding[]) -> LocalBinding[] {
    let mut result -> LocalBinding[] = [];
    let mut index -> number = 0;
    loop {
        if index >= values.length {
            break;
        }
        result.push(values[index]);
        index += 1;
    }
    return result;
}

fn extend_lifetime_regions(values -> LifetimeRegionMetadata[], extras -> LifetimeRegionMetadata[]) -> LifetimeRegionMetadata[] {
    if extras.length == 0 {
        return values;
    }
    let mut out = values;
    let mut index -> number = 0;
    loop {
        if index >= extras.length {
            break;
        }
        out = out.push(extras[index]);
        index += 1;
    }
    return out;
}

fn extend_mutations(values -> LocalMutation[], extras -> LocalMutation[]) -> LocalMutation[] {
    if extras.length == 0 {
        return values;
    }
    let mut out = values;
    let mut index -> number = 0;
    loop {
        if index >= extras.length {
            break;
        }
        out = out.push(extras[index]);
        index += 1;
    }
    return out;
}

fn insert_lines_before_index(lines -> string[], index -> number, insert_lines -> string[]) -> string[] {
    if insert_lines.length == 0 {
        return lines;
    }

    let mut result -> string[] = [];
    let mut line_idx -> number = 0;
    let mut inserted -> boolean = false;
    loop {
        if line_idx >= lines.length {
            break;
        }
        if !inserted {
            if line_idx == index {
                result = extend_string_array(result, insert_lines);
                inserted = true;
            }
        }
        result.push(lines[line_idx]);
        line_idx += 1;
    }

    if !inserted {
        result = extend_string_array(result, insert_lines);
    }

    return result;
}

fn _write_block_result_files(
    lines -> string[],
    allocas -> string[],
    terminated -> boolean,
    diagnostics -> string[],
    string_constants -> StringConstant[],
    temp_index -> number,
    block_counter -> number,
    next_local_id -> number,
    next_lifetime_region_id -> number,
    next_index -> number
) ![io] {
    let mut joined_lines -> string = "";
    let mut li -> number = 0;
    loop {
        if li >= lines.length { break; }
        if li > 0 {
            joined_lines = joined_lines + "\n";
        }
        joined_lines = joined_lines + lines[li];
        li = li + 1;
    }
    fs.writeFile("build/sailfin/.block_result_lines", joined_lines);

    let mut joined_allocas -> string = "";
    let mut ai -> number = 0;
    loop {
        if ai >= allocas.length { break; }
        if ai > 0 {
            joined_allocas = joined_allocas + "\n";
        }
        joined_allocas = joined_allocas + allocas[ai];
        ai = ai + 1;
    }
    fs.writeFile("build/sailfin/.block_result_allocas", joined_allocas);

    let mut term_val -> string = "0";
    if terminated {
        term_val = "1";
    }
    fs.writeFile("build/sailfin/.block_result_terminated", term_val);

    let mut joined_diags -> string = "";
    let mut di -> number = 0;
    loop {
        if di >= diagnostics.length { break; }
        if di > 0 {
            joined_diags = joined_diags + "\n";
        }
        joined_diags = joined_diags + diagnostics[di];
        di = di + 1;
    }
    fs.writeFile("build/sailfin/.block_result_diagnostics", joined_diags);

    // Serialize string constants so emit_body can read them back.
    // Format: one constant per line as "name\tcontent\tbyte_count".
    let mut joined_sc -> string = "";
    let mut si -> number = 0;
    loop {
        if si >= string_constants.length { break; }
        if si > 0 {
            joined_sc = joined_sc + "\n";
        }
        joined_sc = joined_sc + string_constants[si].name + "\t" + string_constants[si].content + "\t" + number_to_string(string_constants[si].byte_count);
        si = si + 1;
    }
    fs.writeFile("build/sailfin/.block_result_string_constants", joined_sc);

    // Scalar state fields needed by callers in other modules (instructions_match, instructions_loops).
    fs.writeFile("build/sailfin/.block_result_temp_index", number_to_string(temp_index));
    fs.writeFile("build/sailfin/.block_result_block_counter", number_to_string(block_counter));
    fs.writeFile("build/sailfin/.block_result_next_local_id", number_to_string(next_local_id));
    fs.writeFile("build/sailfin/.block_result_next_lifetime_region_id", number_to_string(next_lifetime_region_id));
    fs.writeFile("build/sailfin/.block_result_next_index", number_to_string(next_index));
    // Note: array fields (locals, bindings, mutations, lifetime_regions) are NOT written here
    // because callers access them directly via the returned BlockLoweringResult pointer fields,
    // which survive cross-module ABI corruption intact. Only scalar fields are corrupted.
}

fn _parse_int_from_string(text -> string) -> number {
    let len = text.length;
    if len == 0 { return 0; }
    let mut result -> number = 0;
    let mut i -> number = 0;
    let first_ch = grapheme_at(text, 0);
    if first_ch == "-" {
        i = 1;
    }
    loop {
        if i >= len { break; }
        let ch = grapheme_at(text, i);
        if ch == "." { break; }
        let code = char_code(ch);
        if code >= 48 {
            if code <= 57 {
                result = result * 10 + (code - 48);
            }
        }
        i = i + 1;
    }
    if first_ch == "-" {
        return 0 - result;
    }
    return result;
}

// Write parameter bindings to files for statement.sfn to read.
// Avoids ABI corruption of struct params across module boundaries.
fn write_bindings_to_files(bindings -> ParameterBinding[]) ![io] {
    let mut bc_i -> number = 0;
    loop {
        let bc_prefix = "build/sailfin/.instr_binding_" + number_to_string(bc_i);
        if !fs.exists(bc_prefix + "_name") { break; }
        fs.deleteFile(bc_prefix + "_name");
        fs.deleteFile(bc_prefix + "_llvm_name");
        fs.deleteFile(bc_prefix + "_llvm_type");
        fs.deleteFile(bc_prefix + "_type_annotation");
        bc_i += 1;
    }
    let mut bw_i -> number = 0;
    loop {
        if bw_i >= bindings.length { break; }
        let bw_prefix = "build/sailfin/.instr_binding_" + number_to_string(bw_i);
        fs.writeFile(bw_prefix + "_name", bindings[bw_i].name);
        fs.writeFile(bw_prefix + "_llvm_name", bindings[bw_i].llvm_name);
        fs.writeFile(bw_prefix + "_llvm_type", bindings[bw_i].llvm_type);
        fs.writeFile(bw_prefix + "_type_annotation", bindings[bw_i].type_annotation);
        bw_i += 1;
    }
}

// Write local bindings to files for statement.sfn to read.
fn write_locals_to_files(locals -> LocalBinding[]) ![io] {
    let mut lc_i -> number = 0;
    loop {
        let lc_prefix = "build/sailfin/.instr_local_" + number_to_string(lc_i);
        if !fs.exists(lc_prefix + "_name") { break; }
        fs.deleteFile(lc_prefix + "_name");
        fs.deleteFile(lc_prefix + "_pointer");
        fs.deleteFile(lc_prefix + "_llvm_type");
        fs.deleteFile(lc_prefix + "_type_annotation");
        fs.deleteFile(lc_prefix + "_scope_id");
        fs.deleteFile(lc_prefix + "_scope_depth");
        lc_i += 1;
    }
    let mut lw_i -> number = 0;
    loop {
        if lw_i >= locals.length { break; }
        let lw_prefix = "build/sailfin/.instr_local_" + number_to_string(lw_i);
        fs.writeFile(lw_prefix + "_name", locals[lw_i].name);
        fs.writeFile(lw_prefix + "_pointer", locals[lw_i].pointer);
        fs.writeFile(lw_prefix + "_llvm_type", locals[lw_i].llvm_type);
        fs.writeFile(lw_prefix + "_type_annotation", locals[lw_i].type_annotation);
        fs.writeFile(lw_prefix + "_scope_id", locals[lw_i].scope_id);
        fs.writeFile(lw_prefix + "_scope_depth", number_to_string(locals[lw_i].scope_depth));
        lw_i += 1;
    }
}

// Read string constants from the expr_stmt_string_constants file,
// merging into existing. Clears the file after reading.
fn read_expr_string_constants(existing -> StringConstant[]) -> StringConstant[] ![io] {
    let mut result = existing;
    if fs.exists("build/sailfin/.expr_stmt_string_constants") {
        let _raw = fs.readFile("build/sailfin/.expr_stmt_string_constants");
        if _raw.length > 0 {
            let mut _pos -> number = 0;
            loop {
                if _pos >= _raw.length { break; }
                let _nl = index_of(substring(_raw, _pos, _raw.length), "\n");
                let mut _line -> string = "";
                if _nl < 0 {
                    _line = substring(_raw, _pos, _raw.length);
                    _pos = _raw.length;
                } else {
                    _line = substring(_raw, _pos, _pos + _nl);
                    _pos = _pos + _nl + 1;
                }
                if _line.length == 0 { continue; }
                let _t1 = index_of(_line, "\t");
                if _t1 < 0 { continue; }
                let _nm = substring(_line, 0, _t1);
                let _r2 = substring(_line, _t1 + 1, _line.length);
                let _t2 = index_of(_r2, "\t");
                if _t2 < 0 { continue; }
                let _ct = substring(_r2, 0, _t2);
                let _bct = substring(_r2, _t2 + 1, _r2.length);
                let _bc = _parse_int_from_string(_bct);
                result = merge_string_constants(result, [StringConstant { name: _nm, content: _ct, byte_count: _bc }]);
            }
        }
        fs.writeFile("build/sailfin/.expr_stmt_string_constants", "");
    }
    return result;
}

// Read let-lowering result from file IPC and update state.
// Returns updated locals array.
// Writes lines/allocas/scalar results to .let_ipc_* files for caller.
fn read_let_result_from_files(
    diagnostics -> string[],
    current_locals -> LocalBinding[],
    current_lines -> string[],
    current_allocas -> string[],
    scope_id -> string,
    scope_depth -> number
) -> LocalBinding[] ![io] {
    let mut result_locals = current_locals;
    if fs.exists("build/sailfin/.let_result_temp_index") {
        let _diag_count = _parse_int_from_string(fs.readFile("build/sailfin/.let_result_diag_count"));
        let mut _di -> number = 0;
        loop {
            if _di >= _diag_count { break; }
            let _diag_path = "build/sailfin/.let_result_diag_" + number_to_string(_di);
            if fs.exists(_diag_path) {
                diagnostics.push(fs.readFile(_diag_path));
            }
            _di += 1;
        }
        let _lines_count = _parse_int_from_string(fs.readFile("build/sailfin/.let_result_lines_count"));
        let mut _new_lines -> string[] = [];
        let mut _li -> number = 0;
        loop {
            if _li >= _lines_count { break; }
            let _line_path = "build/sailfin/.let_result_line_" + number_to_string(_li);
            if fs.exists(_line_path) {
                _new_lines.push(fs.readFile(_line_path));
            }
            _li += 1;
        }
        // Write lines for caller to read
        let mut _joined -> string = "";
        let mut _ji -> number = 0;
        loop {
            if _ji >= _new_lines.length { break; }
            if _ji > 0 { _joined = _joined + "\n"; }
            _joined = _joined + _new_lines[_ji];
            _ji += 1;
        }
        fs.writeFile("build/sailfin/.let_ipc_lines", _joined);
        let _allocas_count = _parse_int_from_string(fs.readFile("build/sailfin/.let_result_allocas_count"));
        let mut _new_allocas -> string[] = [];
        let mut _ai -> number = 0;
        loop {
            if _ai >= _allocas_count { break; }
            let _alloca_path = "build/sailfin/.let_result_alloca_" + number_to_string(_ai);
            if fs.exists(_alloca_path) {
                _new_allocas.push(fs.readFile(_alloca_path));
            }
            _ai += 1;
        }
        let mut _joined_a -> string = "";
        let mut _jai -> number = 0;
        loop {
            if _jai >= _new_allocas.length { break; }
            if _jai > 0 { _joined_a = _joined_a + "\n"; }
            _joined_a = _joined_a + _new_allocas[_jai];
            _jai += 1;
        }
        fs.writeFile("build/sailfin/.let_ipc_allocas", _joined_a);
        fs.writeFile("build/sailfin/.let_ipc_temp", fs.readFile("build/sailfin/.let_result_temp_index"));
        fs.writeFile("build/sailfin/.let_ipc_next_local", fs.readFile("build/sailfin/.let_result_next_local_id"));
        fs.writeFile("build/sailfin/.let_ipc_next_region", fs.readFile("build/sailfin/.let_result_next_region_id"));
        fs.writeFile("build/sailfin/.let_ipc_used", "1");
        if fs.exists("build/sailfin/.let_result_local_name") {
            let _name = fs.readFile("build/sailfin/.let_result_local_name");
            let _pointer = fs.readFile("build/sailfin/.let_result_local_pointer");
            let _type = fs.readFile("build/sailfin/.let_result_local_llvm_type");
            let _ann = fs.readFile("build/sailfin/.let_result_local_type_ann");
            result_locals = append_local_binding(result_locals, LocalBinding { name: _name, pointer: _pointer, llvm_type: _type, type_annotation: _ann, ownership: null, consumed: false, scope_id: scope_id, scope_depth: scope_depth });
        }
        fs.deleteFile("build/sailfin/.let_result_temp_index");
        if fs.exists("build/sailfin/.let_result_local_name") {
            fs.deleteFile("build/sailfin/.let_result_local_name");
        }
    } else {
        fs.writeFile("build/sailfin/.let_ipc_used", "0");
    }
    return result_locals;
}

// Read mutations from expr_stmt file IPC.
fn read_expr_mutations(existing -> LocalMutation[]) -> LocalMutation[] ![io] {
    let mut result = existing;
    let _mut_count = _parse_int_from_string(fs.readFile("build/sailfin/.expr_stmt_mut_count"));
    let mut _mi -> number = 0;
    loop {
        if _mi >= _mut_count { break; }
        let _mp = "build/sailfin/.expr_stmt_mut_" + number_to_string(_mi);
        let _mn = fs.readFile(_mp + "_name");
        let _mt = fs.readFile(_mp + "_type");
        let _mv = fs.readFile(_mp + "_value");
        let _ml = fs.readFile(_mp + "_label");
        result = extend_mutations(result, [LocalMutation {
            name: _mn, llvm_type: _mt, value_name: _mv, span: null, originating_label: _ml,
        }]);
        _mi += 1;
    }
    return result;
}
