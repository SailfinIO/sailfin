// compiler/src/llvm/expressions.sfn
//
// Expression parsing and lowering helpers for LLVM IR generation.
// Contains literal detection, identifier handling, operand coercion, and operator matching.

import { NativeFunction, NativeSourceSpan } from "../native_ir";
import { substring, char_code, char_at, index_of } from "../string_utils";
import {
    TypeContext, LocalBinding, ParameterBinding, LLVMOperand, ExpressionResult,
    OperatorMatch, CoercionResult, StringConstant,
    AssignmentParseResult, InlineLetParseResult, TernaryParseResult,
    MemberAccessParse, IndexExpressionParse, RawAddressParseResult, CastParseResult
} from "./types";
import { trim_text, append_string, starts_with, ends_with, sanitize_symbol, number_to_string, join_with_separator, is_identifier_start_char, is_identifier_part_char } from "./utils";
import { empty_string_constant_set, append_string_constant, find_string_constant } from "./strings";

// =============================================================================
// Local and Parameter Binding Lookup
// =============================================================================

fn find_local_binding(locals -> LocalBinding[], name -> string) -> LocalBinding? {
    let mut index -> number = locals.length;
    loop {
        if index <= 0 {
            break;
        }
        index -= 1;
        let entry = locals[index];
        if entry.name == name {
            return entry;
        }
    }
    return null;
}

fn find_parameter_binding(bindings -> ParameterBinding[], name -> string) -> ParameterBinding? {
    let mut index -> number = 0;
    loop {
        if index >= bindings.length {
            break;
        }
        let binding = bindings[index];
        if binding.name == name {
            return binding;
        }
        index += 1;
    }
    return null;
}

fn mark_parameter_consumed(bindings -> ParameterBinding[], name -> string) -> ParameterBinding[] {
    let mut result -> ParameterBinding[] = [];
    let mut index -> number = 0;
    loop {
        if index >= bindings.length {
            break;
        }
        let binding = bindings[index];
        if binding.name == name {
            let updated = ParameterBinding {
                name: binding.name,
                llvm_name: binding.llvm_name,
                llvm_type: binding.llvm_type,
                type_annotation: binding.type_annotation,
                consumed: true,
                span: binding.span,
            };
            result.push(updated);
        } else {
            result.push(binding);
        }
        index += 1;
    }
    return result;
}

fn mark_local_consumed(locals -> LocalBinding[], name -> string) -> LocalBinding[] {
    let mut result -> LocalBinding[] = [];
    let mut index -> number = 0;
    loop {
        if index >= locals.length {
            break;
        }
        let entry = locals[index];
        if entry.name == name {
            let updated = LocalBinding {
                name: entry.name,
                pointer: entry.pointer,
                llvm_type: entry.llvm_type,
                type_annotation: entry.type_annotation,
                ownership: entry.ownership,
                consumed: true,
                scope_id: entry.scope_id,
                scope_depth: entry.scope_depth,
            };
            result.push(updated);
        } else {
            result.push(entry);
        }
        index += 1;
    }
    return result;
}

fn reset_local_consumption(locals -> LocalBinding[], name -> string) -> LocalBinding[] {
    let mut result -> LocalBinding[] = [];
    let mut index -> number = 0;
    loop {
        if index >= locals.length {
            break;
        }
        let entry = locals[index];
        if entry.name == name {
            let updated = LocalBinding {
                name: entry.name,
                pointer: entry.pointer,
                llvm_type: entry.llvm_type,
                type_annotation: entry.type_annotation,
                ownership: entry.ownership,
                consumed: false,
                scope_id: entry.scope_id,
                scope_depth: entry.scope_depth,
            };
            result.push(updated);
        } else {
            result.push(entry);
        }
        index += 1;
    }
    return result;
}

// =============================================================================
// Literal Detection
// =============================================================================

fn is_boolean_literal(text -> string) -> boolean {
    let trimmed = trim_text(text);
    if matches_case_insensitive(trimmed, "true") {
        return true;
    }
    if matches_case_insensitive(trimmed, "false") {
        return true;
    }
    return false;
}

fn is_null_literal(text -> string) -> boolean {
    let trimmed = trim_text(text);
    if matches_case_insensitive(trimmed, "null") {
        return true;
    }
    return false;
}

fn is_digit_char(ch -> string) -> boolean {
    let code = char_code(ch);
    let zero = char_code("0");
    let nine = char_code("9");
    let mut _ret167 -> boolean = false;
    if code >= zero {
        if code <= nine {
            _ret167 = true;
        }
    }
    return _ret167;
}

fn char_code_at_text(text -> string, index -> number) -> number {
    return char_code(char_at(text, index));
}

fn is_integer_literal(text -> string) -> boolean {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return false;
    }
    let mut index -> number = 0;
    if substring(trimmed, 0, 1) == "-" {
        if trimmed.length == 1 {
            return false;
        }
        index = 1;
    }
    let mut has_digit -> boolean = false;
    loop {
        if index >= trimmed.length {
            break;
        }
        let ch = substring(trimmed, index, index + 1);
        let mut _if168 -> boolean = false;
        if ch == "0" { _if168 = true; }
        if ch == "1" { _if168 = true; }
        if ch == "2" { _if168 = true; }
        if ch == "3" { _if168 = true; }
        if ch == "4" { _if168 = true; }
        if ch == "5" { _if168 = true; }
        if ch == "6" { _if168 = true; }
        if ch == "7" { _if168 = true; }
        if ch == "8" { _if168 = true; }
        if ch == "9" { _if168 = true; }
        if _if168 {
            has_digit = true;
            index += 1;
            continue;
        }
        return false;
    }
    return has_digit;
}

fn is_number_literal(text -> string) -> boolean {
    let mut index -> number = 0;
    let mut has_digit -> boolean = false;
    let mut has_decimal -> boolean = false;
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return false;
    }
    if substring(trimmed, 0, 1) == "-" {
        if trimmed.length == 1 {
            return false;
        }
        index = 1;
    }
    loop {
        if index >= trimmed.length {
            break;
        }
        let ch = substring(trimmed, index, index + 1);
        let mut _if169 -> boolean = false;
        if ch == "0" { _if169 = true; }
        if ch == "1" { _if169 = true; }
        if ch == "2" { _if169 = true; }
        if ch == "3" { _if169 = true; }
        if ch == "4" { _if169 = true; }
        if ch == "5" { _if169 = true; }
        if ch == "6" { _if169 = true; }
        if ch == "7" { _if169 = true; }
        if ch == "8" { _if169 = true; }
        if ch == "9" { _if169 = true; }
        if _if169 {
            has_digit = true;
            index += 1;
            continue;
        }
        if ch == "." {
            if has_decimal {
                return false;
            }
            has_decimal = true;
            index += 1;
            continue;
        }
        return false;
    }
    return has_digit;
}

fn normalise_number_literal(text -> string) -> string {
    let trimmed = trim_text(text);
    if index_of(trimmed, ".") >= 0 {
        return trimmed;
    }
    return trimmed + ".0";
}

fn is_string_literal(text -> string) -> boolean {
    let trimmed = trim_text(text);
    if trimmed.length < 2 {
        return false;
    }
    if substring(trimmed, 0, 1) != "\"" {
        return false;
    }
    if substring(trimmed, trimmed.length - 1, trimmed.length) != "\"" {
        return false;
    }

    // Avoid treating concatenation expressions like `"a" + "b"` as a single
    // string literal. Require all interior quotes to be escaped.
    let mut escape -> boolean = false;
    let mut index -> number = 1;
    loop {
        if index >= trimmed.length - 1 {
            break;
        }
        let ch = char_at(trimmed, index);
        if escape {
            escape = false;
            index += 1;
            continue;
        }
        if ch == "\\" {
            escape = true;
            index += 1;
            continue;
        }
        if ch == "\"" {
            return false;
        }
        index += 1;
    }
    if escape {
        return false;
    }
    return true;
}

fn is_character_literal(text -> string) -> boolean {
    // Check if this is a single-character string literal like "a", "t", "\n"
    if text.length < 2 {
        return false;
    }
    let mut _if170 -> boolean = false;
    if substring(text, 0, 1) != "\"" { _if170 = true; }
    if substring(text, text.length - 1, text.length) != "\"" { _if170 = true; }
    if _if170 {
        return false;
    }
    let inner = substring(text, 1, text.length - 1);
    // Handle escape sequences
    if inner.length == 2 {
        if substring(inner, 0, 1) == "\\" {
            return true;
        }
    }
    // Single character
    return inner.length == 1;
}

fn get_character_literal_value(text -> string) -> number {
    let inner = substring(text, 1, text.length - 1);
    if inner.length == 0 {
        return 0;
    }
    // Handle escape sequences
    if inner.length == 2 {
        if substring(inner, 0, 1) == "\\" {
            let escape = char_at(inner, 1);
            let escape_code = char_code(escape);
            if escape_code == char_code("n") {
                return char_code("\n");
            } else if escape_code == char_code("r") {
                return char_code("\r");
            } else if escape_code == char_code("t") {
                return char_code("\t");
            } else if escape_code == char_code("\"") {
                return char_code("\"");
            } else if escape_code == char_code("\\") {
                return char_code("\\");
            } else if escape_code == char_code("0") {
                return 0;
            }
            return escape_code;
        }
    }
    // Single character
    return char_code(char_at(inner, 0));
}

fn matches_case_insensitive(text -> string, target -> string) -> boolean {
    if text.length != target.length {
        return false;
    }
    let mut index -> number = 0;
    loop {
        if index >= text.length {
            break;
        }
        let ch = char_code(char_at(text, index));
        let target_ch = char_code(char_at(target, index));
        let mut text_lower = ch;
        let mut target_lower = target_ch;
        if ch >= 65 {
            if ch <= 90 {
                text_lower = ch + 32;
            }
        }
        if target_ch >= 65 {
            if target_ch <= 90 {
                target_lower = target_ch + 32;
            }
        }
        if text_lower != target_lower {
            return false;
        }
        index += 1;
    }
    return true;
}

// =============================================================================
// Identifier and Expression Helpers
// =============================================================================

fn is_simple_identifier(value -> string) -> boolean {
    let trimmed = trim_text(value);
    if trimmed.length == 0 {
        return false;
    }
    let first = substring(trimmed, 0, 1);
    if first >= "0" {
        if first <= "9" {
            return false;
        }
    }
    let sanitized = sanitize_symbol(trimmed);
    if sanitized != trimmed {
        return false;
    }
    return true;
}

fn is_effect_delimiter(ch -> string) -> boolean {
    let mut _if171 -> boolean = false;
    if ch == "!" { _if171 = true; }
    if ch == "?" { _if171 = true; }
    if _if171 {
        return true;
    }
    return false;
}

fn strip_enclosing_parentheses(expression -> string) -> string {
    let trimmed = trim_text(expression);
    if trimmed.length < 2 {
        return trimmed;
    }
    let mut _if172 -> boolean = false;
    if substring(trimmed, 0, 1) != "(" { _if172 = true; }
    if substring(trimmed, trimmed.length - 1, trimmed.length) != ")" { _if172 = true; }
    if _if172 {
        return trimmed;
    }
    let mut depth -> number = 0;
    let mut index -> number = 0;
    loop {
        if index >= trimmed.length {
            break;
        }
        let ch = char_at(trimmed, index);
        if ch == "(" {
            depth += 1;
        } else if ch == ")" {
            depth -= 1;
            if depth == 0 {
                if index == trimmed.length - 1 {
                    let inner = substring(trimmed, 1, trimmed.length - 1);
                    return strip_enclosing_parentheses(inner);
                }
                return trimmed;
            }
        }
        index += 1;
    }
    return trimmed;
}

fn strip_mut_prefix(value -> string) -> string {
    let trimmed = trim_text(value);
    if trimmed.length < 4 {
        return trimmed;
    }
    let prefix = substring(trimmed, 0, 4);
    if prefix == "mut " {
        return trim_text(substring(trimmed, 4, trimmed.length));
    }
    return trimmed;
}

fn contains_text(haystack -> string, needle -> string) -> boolean {
    if needle.length == 0 {
        return true;
    }
    if haystack.length < needle.length {
        return false;
    }
    let _search_limit = haystack.length - needle.length;
    let mut index -> number = 0;
    loop {
        if index > _search_limit {
            break;
        }
        let candidate = substring(haystack, index, index + needle.length);
        if candidate == needle {
            return true;
        }
        index += 1;
    }
    return false;
}

// =============================================================================
// Type Helpers
// =============================================================================

fn is_copy_type(type_annotation -> string, llvm_type -> string) -> boolean {
    let trimmed = trim_text(type_annotation);
    let mut _if173 -> boolean = false;
    if starts_with(trimmed, "Affine<") { _if173 = true; }
    if starts_with(trimmed, "Linear<") { _if173 = true; }
    if _if173 {
        return false;
    }
    let mut _if174 -> boolean = false;
    if trimmed == "Affine" { _if174 = true; }
    if trimmed == "Linear" { _if174 = true; }
    if _if174 {
        return false;
    }
    if llvm_type == "double" {
        return true;
    }
    if llvm_type == "i32" {
        return true;
    }
    if llvm_type == "i64" {
        return true;
    }
    if llvm_type == "i1" {
        return true;
    }
    if ends_with_pointer_suffix(llvm_type) {
        return true;
    }
    if trimmed.length == 0 {
        return true;
    }
    if substring(trimmed, 0, 1) == "&" {
        return true;
    }
    if starts_with(trimmed, "mut ") {
        let stripped = strip_mut_prefix(trimmed);
        if stripped.length > 0 {
            if substring(stripped, 0, 1) == "&" {
                return true;
            }
        }
    }
    return false;
}

fn ends_with_pointer_suffix(value -> string) -> boolean {
    let trimmed = trim_text(value);
    if trimmed.length == 0 {
        return false;
    }
    // Fast-path: well-known primitives that are never pointers.
    // Avoids character-level indexing which is miscompiled by older seeds.
    let mut _if175 -> boolean = false;
    if trimmed == "double" { _if175 = true; }
    if trimmed == "i1" { _if175 = true; }
    if trimmed == "i8" { _if175 = true; }
    if trimmed == "i16" { _if175 = true; }
    if trimmed == "i32" { _if175 = true; }
    if trimmed == "i64" { _if175 = true; }
    if trimmed == "void" { _if175 = true; }
    if trimmed == "float" { _if175 = true; }
    if _if175 {
        return false;
    }
    // Fast-path: well-known pointer types.
    let mut _if176 -> boolean = false;
    if trimmed == "i8*" { _if176 = true; }
    if trimmed == "i8**" { _if176 = true; }
    if trimmed == "i32*" { _if176 = true; }
    if trimmed == "i64*" { _if176 = true; }
    if trimmed == "double*" { _if176 = true; }
    if trimmed == "i1*" { _if176 = true; }
    if _if176 {
        return true;
    }
    // Fast-path: aggregate pointer types starting with { or % and ending with *.
    // Use starts_with (safe) instead of character indexing.
    let mut _if177 -> boolean = false;
    if starts_with(trimmed, "{") { _if177 = true; }
    if starts_with(trimmed, "%") { _if177 = true; }
    if _if177 {
        let without_star = substring(trimmed, 0, trimmed.length - 1);
        if without_star + "*" == trimmed {
            return true;
        }
        return false;
    }
    return substring(trimmed, trimmed.length - 1, trimmed.length) == "*";
}

fn default_return_literal(llvm_type -> string) -> string {
    if llvm_type == "void" {
        return "";
    }
    if llvm_type == "double" {
        return "0.0";
    }
    if llvm_type == "i32" {
        return "0";
    }
    if llvm_type == "i64" {
        return "0";
    }
    if llvm_type == "i1" {
        return "false";
    }
    if ends_with_pointer_suffix(llvm_type) {
        return "null";
    }
    return "zeroinitializer";
}

// =============================================================================
// LLVM Temp and Operand Formatting
// =============================================================================

fn format_temp_name(index -> number) -> string {
    return "%t" + number_to_string(index);
}

fn format_local_pointer_name(index -> number) -> string {
    return "%l" + number_to_string(index);
}

fn format_typed_operand(operand -> LLVMOperand) -> string {
    return operand.llvm_type + " " + operand.value;
}

// =============================================================================
// Operator Finding
// =============================================================================

fn find_top_level_operator(expression -> string, operators -> string) -> OperatorMatch {
    let mut paren_depth -> number = 0;
    let mut bracket_depth -> number = 0;
    let mut brace_depth -> number = 0;
    let mut angle_depth -> number = 0;
    let mut in_single -> boolean = false;
    let mut in_double -> boolean = false;
    let mut escape_next -> boolean = false;
    let mut candidate_index -> number = -1;
    let mut candidate_symbol -> string = "";
    let mut index -> number = 0;
    loop {
        if index >= expression.length {
            break;
        }
        let ch = char_at(expression, index);
        if in_double {
            if escape_next {
                escape_next = false;
                index += 1;
                continue;
            }
            if ch == "\\" {
                escape_next = true;
                index += 1;
                continue;
            }
            if ch == "\"" {
                in_double = false;
            }
            index += 1;
            continue;
        }
        if in_single {
            if escape_next {
                escape_next = false;
                index += 1;
                continue;
            }
            if ch == "\\" {
                escape_next = true;
                index += 1;
                continue;
            }
            if ch == "'" {
                in_single = false;
            }
            index += 1;
            continue;
        }
        if ch == "\"" {
            in_double = true;
            index += 1;
            continue;
        }
        if ch == "'" {
            in_single = true;
            index += 1;
            continue;
        }
        if ch == "(" {
            paren_depth += 1;
            index += 1;
            continue;
        }
        if ch == ")" {
            if paren_depth > 0 {
                paren_depth -= 1;
            }
            index += 1;
            continue;
        }
        if ch == "[" {
            bracket_depth += 1;
            index += 1;
            continue;
        }
        if ch == "]" {
            if bracket_depth > 0 {
                bracket_depth -= 1;
            }
            index += 1;
            continue;
        }
        if ch == "{" {
            brace_depth += 1;
            index += 1;
            continue;
        }
        if ch == "}" {
            if brace_depth > 0 {
                brace_depth -= 1;
            }
            index += 1;
            continue;
        }
        if ch == "<" {
            angle_depth += 1;
            index += 1;
            continue;
        }
        if ch == ">" {
            if angle_depth > 0 {
                angle_depth -= 1;
            }
            index += 1;
            continue;
        }
        if paren_depth == 0 {
            if bracket_depth == 0 {
                if brace_depth == 0 {
                    if angle_depth == 0 {
                        // Check for multi-character operators first
                        let _op_next2 = index + 2;
                        if _op_next2 <= expression.length {
                            let two_char = substring(expression, index, _op_next2);
                            if contains_text(operators, two_char) {
                                // Prefer rightmost occurrence for left-associativity
                                candidate_index = index;
                                candidate_symbol = two_char;
                                index += 2;
                                continue;
                            }
                        }
                        // Check single character
                        if contains_text(operators, ch) {
                            candidate_index = index;
                            candidate_symbol = ch;
                        }
                    }
                }
            }
        }
        index += 1;
    }
    // Keep struct literal values simple; our stage2 LLVM lowering has a
    // lightweight struct-literal parser that can get confused by comparisons.
    let success = candidate_index >= 0;
    return OperatorMatch { success: success, index: candidate_index, symbol: candidate_symbol };
}

fn is_binary_minus(expression -> string, index -> number) -> boolean {
    if index == 0 {
        return false;
    }
    let prev_char = char_at(expression, index - 1);
    let mut _if178 -> boolean = false;
    if prev_char == " " { _if178 = true; }
    if prev_char == "\t" { _if178 = true; }
    if _if178 {
        return true;
    }
    if is_identifier_part_char(prev_char) {
        return true;
    }
    let mut _if179 -> boolean = false;
    if prev_char == ")" { _if179 = true; }
    if prev_char == "]" { _if179 = true; }
    if _if179 {
        return true;
    }
    return false;
}

fn is_binary_star(expression -> string, index -> number) -> boolean {
    if index == 0 {
        return false;
    }
    let prev_char = char_at(expression, index - 1);
    let mut _if180 -> boolean = false;
    if prev_char == " " { _if180 = true; }
    if prev_char == "\t" { _if180 = true; }
    if _if180 {
        return true;
    }
    if is_identifier_part_char(prev_char) {
        return true;
    }
    let mut _if181 -> boolean = false;
    if prev_char == ")" { _if181 = true; }
    if prev_char == "]" { _if181 = true; }
    if _if181 {
        return true;
    }
    return false;
}

// =============================================================================
// Range and Separator Finding
// =============================================================================

fn find_top_level_range_separator(value -> string) -> number {
    let mut paren_depth -> number = 0;
    let mut bracket_depth -> number = 0;
    let mut brace_depth -> number = 0;
    let mut index -> number = 0;
    loop {
        if index >= value.length {
            break;
        }
        let ch = substring(value, index, index + 1);
        if ch == "(" {
            paren_depth += 1;
            index += 1;
            continue;
        }
        if ch == ")" {
            if paren_depth > 0 {
                paren_depth -= 1;
            }
            index += 1;
            continue;
        }
        if ch == "[" {
            bracket_depth += 1;
            index += 1;
            continue;
        }
        if ch == "]" {
            if bracket_depth > 0 {
                bracket_depth -= 1;
            }
            index += 1;
            continue;
        }
        if ch == "{" {
            brace_depth += 1;
            index += 1;
            continue;
        }
        if ch == "}" {
            if brace_depth > 0 {
                brace_depth -= 1;
            }
            index += 1;
            continue;
        }
        if ch == "." {
            let _dot_next = index + 1;
            if _dot_next < value.length {
                let _dot_next2 = index + 2;
                if substring(value, _dot_next, _dot_next2) == "." {
                    if paren_depth == 0 {
                        if bracket_depth == 0 {
                            if brace_depth == 0 {
                                return index;
                            }
                        }
                    }
                }
            }
        }
        index += 1;
    }
    return -1;
}

fn find_top_level_union_separator(text -> string) -> number {
    let mut paren_depth -> number = 0;
    let mut brace_depth -> number = 0;
    let mut bracket_depth -> number = 0;
    let mut angle_depth -> number = 0;
    let mut in_single -> boolean = false;
    let mut in_double -> boolean = false;
    let mut escape -> boolean = false;
    let mut index -> number = 0;
    loop {
        if index >= text.length {
            break;
        }
        let ch = substring(text, index, index + 1);
        if in_double {
            if escape {
                escape = false;
            } else {
                if ch == "\\" {
                    escape = true;
                } else if ch == "\"" {
                    in_double = false;
                }
            }
            index += 1;
            continue;
        }
        if in_single {
            if escape {
                escape = false;
            } else {
                if ch == "\\" {
                    escape = true;
                } else if ch == "'" {
                    in_single = false;
                }
            }
            index += 1;
            continue;
        }
        if ch == "\"" {
            in_double = true;
            index += 1;
            continue;
        }
        if ch == "'" {
            in_single = true;
            index += 1;
            continue;
        }
        if ch == "(" {
            paren_depth += 1;
        } else if ch == ")" {
            if paren_depth > 0 {
                paren_depth -= 1;
            }
        } else if ch == "[" {
            bracket_depth += 1;
        } else if ch == "]" {
            if bracket_depth > 0 {
                bracket_depth -= 1;
            }
        } else if ch == "{" {
            brace_depth += 1;
        } else if ch == "}" {
            if brace_depth > 0 {
                brace_depth -= 1;
            }
        } else if ch == "<" {
            angle_depth += 1;
        } else if ch == ">" {
            if angle_depth > 0 {
                angle_depth -= 1;
            }
        } else if ch == "|" {
            if paren_depth == 0 {
                if brace_depth == 0 {
                    if bracket_depth == 0 {
                        if angle_depth == 0 {
                            return index;
                        }
                    }
                }
            }
        }
        index += 1;
    }
    return -1;
}

