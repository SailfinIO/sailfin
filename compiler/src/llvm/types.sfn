    temp_index: int;
    diagnostics: string[];
    terminated: boolean;
    string_constants: StringConstant[];
}

// =============================================================================
// PHI Node Merging
// =============================================================================
struct PhiMergeResult {
    lines: string[];
    temp_index: int;
}

struct PhiInputEntry {
    label: string;
    value_name: string;
}

struct MutationMaterializationResult {
    lines: string[];
    mutations: LocalMutation[];
    temp_index: int;
}

struct PhiStoreEntry {
    phi_line: string;
    store_line: string;
}

struct MatchArmMutations {
