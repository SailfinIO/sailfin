// compiler/src/emitter_sailfin.sfn
//
// Sailfin-to-Sailfin code emitter. This module consumes the high-level AST
// produced by the Sailfin-native parser and renders canonical Sailfin source
// code. The intent is to make the self-hosted compiler capable of emitting
// Sailfin that can be re-ingested by the bootstrap stage0 toolchain while we
// close the bootstrap loop.

import {
    Block,
    Decorator,
    DecoratorArgument,
    EnumVariant,
    Expression,
    FieldDeclaration,
    ForClause,
    FunctionSignature,
    MatchCase,
    MethodDeclaration,
    ModelProperty,
    Parameter,
    Program,
    Statement,
    ImportSpecifier,
    ExportSpecifier,
    TypeAnnotation,
    TypeParameter,
    WithClause,
    ElseBranch,
} from "./ast";
import { Token } from "./token";
import { substring, char_code } from "./string_utils";

struct TextBuilder {
    lines -> string[];
    indent -> number;
}

fn emit_program(program -> Program) -> string {
    let mut builder -> TextBuilder = builder_new();
    builder = builder_emit_line(builder, "// Generated by Sailfin self-hosted emitter");
    builder = builder_emit_blank(builder);
    builder = builder_emit_line(
        builder,
        "import { sleep, channel, parallel, spawn, fs, serve, http, websocket, logExecution, array_map, array_filter, array_reduce } from \"sailfin/runtime\";"
    );
    builder = builder_emit_blank(builder);

    let mut index -> number = 0;
    loop {
        if index >= program.statements.length {
            break;
        }
        builder = emit_statement(builder, program.statements[index]);
        if index + 1 < program.statements.length {
            builder = builder_emit_blank(builder);
        }
        index += 1;
    }

    return builder_to_string(builder);
}

fn emit_statement(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    if statement.variant == "ImportDeclaration" {
        return emit_import(builder, statement.specifiers, statement.source);
    }
    if statement.variant == "ExportDeclaration" {
        return emit_export(builder, statement.specifiers, statement.source);
    }
    if statement.variant == "VariableDeclaration" {
        return emit_variable(builder, statement);
    }
    if statement.variant == "FunctionDeclaration" {
        return emit_function(builder, statement.signature, statement.body, statement.decorators);
    }
    if statement.variant == "StructDeclaration" {
        return emit_struct(builder, statement);
    }
    if statement.variant == "PipelineDeclaration" {
        return emit_callable(builder, "pipeline", statement.signature, statement.body, statement.decorators);
    }
    if statement.variant == "ToolDeclaration" {
        return emit_callable(builder, "tool", statement.signature, statement.body, statement.decorators);
    }
    if statement.variant == "TestDeclaration" {
        return emit_test(builder, statement);
    }
    if statement.variant == "ModelDeclaration" {
        return emit_model(builder, statement);
    }
    if statement.variant == "TypeAliasDeclaration" {
        return emit_type_alias(builder, statement);
    }
    if statement.variant == "InterfaceDeclaration" {
        return emit_interface(builder, statement);
    }
    if statement.variant == "EnumDeclaration" {
        return emit_enum(builder, statement);
    }
    if statement.variant == "Unknown" {
        let comment = "// original: " + collapse_whitespace(statement.text);
        return builder_emit_line(builder, comment);
    }
    return builder_emit_line(builder, "// TODO: unsupported statement: " + statement.variant);
}

fn emit_import(builder -> TextBuilder, specifiers -> ImportSpecifier[], source -> string) -> TextBuilder {
    let list = format_import_specifiers(specifiers);
    let line = "import { " + list + " } from \"" + source + "\";";
    return builder_emit_line(builder, line);
}

fn emit_export(builder -> TextBuilder, specifiers -> ExportSpecifier[], source -> string) -> TextBuilder {
    let list = format_export_specifiers(specifiers);
    let line = "export { " + list + " } from \"" + source + "\";";
    return builder_emit_line(builder, line);
}

fn emit_variable(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut prefix -> string = "let ";
    if statement.mutable {
        prefix = prefix + "mut ";
    }
    prefix = prefix + statement.name;
    prefix = prefix + format_type_annotation(statement.type_annotation);
    prefix = prefix + format_initializer(statement.initializer);
    return builder_emit_line(builder, prefix + ";");
}

fn emit_function(
    builder -> TextBuilder,
    signature -> FunctionSignature,
    body -> Block,
    decorators -> Decorator[]
) -> TextBuilder {
    let mut current = emit_decorators(builder, decorators);
    let header = format_function_header(signature);
    current = builder_emit_line(current, header);
    current = emit_block(current, body);
    return current;
}

fn emit_callable(
    builder -> TextBuilder,
    keyword -> string,
    signature -> FunctionSignature,
    body -> Block,
    decorators -> Decorator[]
) -> TextBuilder {
    let mut current = emit_decorators(builder, decorators);
    let header = format_callable_header(keyword, signature);
    current = builder_emit_line(current, header);
    current = emit_block(current, body);
    return current;
}

fn emit_test(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut current = emit_decorators(builder, statement.decorators);
    let name = format_test_name(statement.name);
    let effects = format_effects(statement.effects);
    let mut header -> string = "test " + name;
    if effects.length > 0 {
        header = header + " " + effects;
    }
    current = builder_emit_line(current, header);
    current = emit_block(current, statement.body);
    return current;
}

fn emit_model(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut current = emit_decorators(builder, statement.decorators);
    let mut header -> string = "model " + statement.name + " : " + statement.model_type.text;
    let effects = format_effects(statement.effects);
    if effects.length > 0 {
        header = header + " " + effects;
    }
    current = builder_emit_line(current, header);
    current = builder_emit_line(current, "{");
    current = builder_push_indent(current);
    let mut index -> number = 0;
    loop {
        if index >= statement.properties.length {
            break;
        }
        let property = statement.properties[index];
        let line = property.name + " = " + format_expression(property.value) + ";";
        current = builder_emit_line(current, line);
        index += 1;
    }
    if statement.properties.length == 0 {
        current = builder_emit_line(current, "// empty model body");
    }
    current = builder_pop_indent(current);
    current = builder_emit_line(current, "}");
    return current;
}

fn format_import_specifiers(specifiers -> ImportSpecifier[]) -> string {
    let mut parts -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= specifiers.length {
            break;
        }
        let entry = format_specifier_entry(specifiers[index].name, specifiers[index].alias);
        parts = append_string(parts, entry);
        index += 1;
    }
    return join_with_separator(parts, ", ");
}

fn format_export_specifiers(specifiers -> ExportSpecifier[]) -> string {
    let mut parts -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= specifiers.length {
            break;
        }
        let entry = format_specifier_entry(specifiers[index].name, specifiers[index].alias);
        parts = append_string(parts, entry);
        index += 1;
    }
    return join_with_separator(parts, ", ");
}

fn format_specifier_entry(name -> string, alias -> string?) -> string {
    if alias == null || alias.length == 0 {
        return name;
    }
    return name + " as " + alias;
}

fn emit_type_alias(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut line -> string = "type " + statement.name;
    line = line + format_type_parameters(statement.type_parameters);
    line = line + " = " + statement.aliased_type.text + ";";
    return emit_decorators_then_line(builder, statement.decorators, line);
}

fn emit_interface(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut current = emit_decorators(builder, statement.decorators);
    let mut header -> string = "interface " + statement.name;
    header = header + format_type_parameters(statement.type_parameters);
    current = builder_emit_line(current, header);
    current = emit_block_start(current);
    let mut index -> number = 0;
    loop {
        if index >= statement.members.length {
            break;
        }
        let signature = statement.members[index];
        let line = format_signature_line("fn", signature) + ";";
        current = builder_emit_line(current, line);
        index += 1;
    }
    current = emit_block_end(current);
    return current;
}

fn emit_enum(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut current = emit_decorators(builder, statement.decorators);
    let mut header -> string = "enum " + statement.name;
    header = header + format_type_parameters(statement.type_parameters);
    current = builder_emit_line(current, header);
    current = emit_block_start(current);
    let mut index -> number = 0;
    loop {
        if index >= statement.variants.length {
            break;
        }
        let variant = statement.variants[index];
        current = builder_emit_line(current, format_enum_variant(variant) + ";");
        index += 1;
    }
    current = emit_block_end(current);
    return current;
}

fn emit_struct(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut current = emit_decorators(builder, statement.decorators);
    let mut header -> string = "struct " + statement.name;
    header = header + format_type_parameters(statement.type_parameters);
    if statement.implements_types.length > 0 {
        header = header + " implements " + join_type_annotations(statement.implements_types);
    }
    current = builder_emit_line(current, header);
    current = emit_block_start(current);

    let mut field_index -> number = 0;
    loop {
        if field_index >= statement.fields.length {
            break;
        }
        current = builder_emit_line(current, format_field(statement.fields[field_index]) + ";");
        field_index += 1;
    }

    let mut method_index -> number = 0;
    loop {
        if method_index >= statement.methods.length {
            break;
        }
        let method = statement.methods[method_index];
        current = emit_decorators(current, method.decorators);
        current = builder_emit_line(current, format_method_header(method.signature));
        current = emit_block(current, method.body);
        if method_index + 1 < statement.methods.length {
            current = builder_emit_blank(current);
        }
        method_index += 1;
    }

    if statement.fields.length == 0 && statement.methods.length == 0 {
        current = builder_emit_line(current, "// empty struct");
    }

    current = emit_block_end(current);
    return current;
}

fn emit_block(builder -> TextBuilder, block -> Block) -> TextBuilder {
    let mut current = emit_block_start(builder);
    current = emit_block_body(current, block);
    current = emit_block_end(current);
    return current;
}

fn emit_block_body(builder -> TextBuilder, block -> Block) -> TextBuilder {
    if block.statements.length == 0 {
        let trimmed = trim_block_body(block.text);
        if trimmed.length > 0 {
            return builder_emit_line(builder, trimmed);
        }
        return builder_emit_line(builder, "// empty body");
    }

    let mut current = builder;
    let mut index -> number = 0;
    loop {
        if index >= block.statements.length {
            break;
        }
        current = emit_block_statement(current, block.statements[index]);
        index += 1;
    }
    return current;
}

fn emit_block_statement(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    if statement.variant == "ReturnStatement" {
        if statement.expression == null {
            return builder_emit_line(builder, "return;");
        }
        return builder_emit_line(builder, "return " + format_expression(statement.expression) + ";");
    }
    if statement.variant == "ExpressionStatement" {
        return builder_emit_line(builder, format_expression(statement.expression) + ";");
    }
    if statement.variant == "VariableDeclaration" {
        return emit_variable(builder, statement);
    }
    if statement.variant == "PromptStatement" {
        return emit_prompt(builder, statement);
    }
    if statement.variant == "WithStatement" {
        return emit_with(builder, statement);
    }
    if statement.variant == "IfStatement" {
        return emit_if(builder, statement);
    }
    if statement.variant == "ForStatement" {
        return emit_for(builder, statement);
    }
    if statement.variant == "TestDeclaration" {
        return emit_test(builder, statement);
    }
    if statement.variant == "Unknown" {
        let line = "// original: " + collapse_whitespace(statement.text);
        return builder_emit_line(builder, line);
    }
    if statement.variant == "FunctionDeclaration" {
        return emit_function(builder, statement.signature, statement.body, statement.decorators);
    }
    if statement.variant == "MatchStatement" {
        return emit_match(builder, statement);
    }
    return builder_emit_line(builder, "// TODO: unsupported block statement: " + statement.variant);
}

fn emit_prompt(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut current = emit_decorators(builder, statement.decorators);
    let header = "prompt " + statement.channel;
    current = builder_emit_line(current, header);
    current = emit_block(current, statement.body);
    return builder_emit_line(current, ";");
}

fn emit_with(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut current = emit_decorators(builder, statement.decorators);
    let mut line -> string = "with ";
    let mut index -> number = 0;
    loop {
        if index >= statement.clauses.length {
            break;
        }
        if index > 0 {
            line = line + ", ";
        }
        line = line + format_expression(statement.clauses[index].expression);
        index += 1;
    }
    current = builder_emit_line(current, line);
    current = emit_block(current, statement.body);
    return current;
}

fn emit_if(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut current = emit_decorators(builder, statement.decorators);
    let line = "if " + format_expression(statement.condition);
    current = builder_emit_line(current, line);
    current = emit_block(current, statement.then_block);
    if statement.else_branch != null {
        current = emit_else_branch(current, statement.else_branch);
    }
    return current;
}

fn emit_else_branch(builder -> TextBuilder, branch -> ElseBranch) -> TextBuilder {
    if branch.body != null {
        let current = builder_emit_line(builder, "else");
        return emit_block(current, branch.body);
    }
    if branch.statement != null {
        if branch.statement.variant == "IfStatement" {
            let current = builder_emit_line(builder, "else if " + format_expression(branch.statement.condition));
            let after = emit_block(current, branch.statement.then_block);
            if branch.statement.else_branch != null {
                return emit_else_branch(after, branch.statement.else_branch);
            }
            return after;
        }
        let current = builder_emit_line(builder, "else");
        return emit_block_statement(current, branch.statement);
    }
    return builder;
}

fn emit_for(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut current = emit_decorators(builder, statement.decorators);
    let header = "for " + format_for_clause(statement.clause);
    current = builder_emit_line(current, header);
    return emit_block(current, statement.body);
}

fn emit_match(builder -> TextBuilder, statement -> Statement) -> TextBuilder {
    let mut current = emit_decorators(builder, statement.decorators);
    let header = "match " + format_expression(statement.expression);
    current = builder_emit_line(current, header);
    current = builder_emit_line(current, "{");
    current = builder_push_indent(current);
    let mut index -> number = 0;
    loop {
        if index >= statement.cases.length {
            break;
        }
        current = emit_match_case(current, statement.cases[index]);
        index += 1;
    }
    current = builder_pop_indent(current);
    return builder_emit_line(current, "}");
}

fn emit_match_case(builder -> TextBuilder, case -> MatchCase) -> TextBuilder {
    let mut line -> string = "case " + format_expression(case.pattern);
    if case.guard != null {
        line = line + " if " + format_expression(case.guard);
    }
    line = line + " => {";
    let mut current = builder_emit_line(builder, line);
    current = builder_push_indent(current);
    current = emit_block_body(current, case.body);
    current = builder_pop_indent(current);
    return builder_emit_line(current, "}");
}

fn emit_block_start(builder -> TextBuilder) -> TextBuilder {
    let current = builder_emit_line(builder, "{");
    return builder_push_indent(current);
}

fn emit_block_end(builder -> TextBuilder) -> TextBuilder {
    let current = builder_pop_indent(builder);
    return builder_emit_line(current, "}");
}

fn emit_decorators_then_line(builder -> TextBuilder, decorators -> Decorator[], line -> string) -> TextBuilder {
    let current = emit_decorators(builder, decorators);
    return builder_emit_line(current, line);
}

fn emit_decorators(builder -> TextBuilder, decorators -> Decorator[]) -> TextBuilder {
    let mut current = builder;
    let mut index -> number = 0;
    loop {
        if index >= decorators.length {
            break;
        }
        current = builder_emit_line(current, format_decorator(decorators[index]));
        index += 1;
    }
    return current;
}

fn format_decorator(decorator -> Decorator) -> string {
    let mut line -> string = "@" + decorator.name;
    if decorator.arguments.length == 0 {
        return line;
    }
    let mut parts -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= decorator.arguments.length {
            break;
        }
        parts = append_string(parts, format_decorator_argument(decorator.arguments[index]));
        index += 1;
    }
    return line + "(" + join_with_separator(parts, ", ") + ")";
}

fn format_decorator_argument(argument -> DecoratorArgument) -> string {
    let value = format_expression(argument.expression);
    if argument.name == null {
        return value;
    }
    return argument.name + ": " + value;
}

fn format_for_clause(clause -> ForClause) -> string {
    let target = format_expression(clause.target);
    let iterable = format_expression(clause.iterable);
    if target.length == 0 || iterable.length == 0 {
        return tokens_to_source(clause.tokens);
    }
    return target + " in " + iterable;
}

fn format_function_header(signature -> FunctionSignature) -> string {
    return format_signature_line("fn", signature);
}

fn format_method_header(signature -> FunctionSignature) -> string {
    return format_signature_line("fn", signature);
}

fn format_callable_header(keyword -> string, signature -> FunctionSignature) -> string {
    return format_signature_line(keyword, signature);
}

fn format_signature_line(keyword -> string, signature -> FunctionSignature) -> string {
    let mut prefix -> string = "";
    if signature.is_async {
        prefix = "async ";
    }
    let mut line -> string = prefix + keyword + " " + signature.name;
    line = line + format_type_parameters(signature.type_parameters);
    line = line + "(" + format_parameters(signature.parameters) + ")";
    if signature.return_type != null {
        line = line + " -> " + signature.return_type.text;
    }
    let effects = format_effects(signature.effects);
    if effects.length > 0 {
        line = line + " " + effects;
    }
    return line;
}

fn format_field(field -> FieldDeclaration) -> string {
    let mut line -> string = "";
    if field.mutable {
        line = line + "mut ";
    }
    line = line + field.name;
    line = line + " -> " + field.type_annotation.text;
    return line;
}

fn format_enum_variant(variant -> EnumVariant) -> string {
    if variant.fields.length == 0 {
        return variant.name;
    }
    let mut parts -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= variant.fields.length {
            break;
        }
        parts = append_string(parts, format_field(variant.fields[index]));
        index += 1;
    }
    return variant.name + " { " + join_with_separator(parts, "; ") + " }";
}

fn format_parameters(parameters -> Parameter[]) -> string {
    if parameters.length == 0 {
        return "";
    }
    let mut parts -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= parameters.length {
            break;
        }
        parts = append_string(parts, format_parameter(parameters[index]));
        index += 1;
    }
    return join_with_separator(parts, ", ");
}

fn format_parameter(parameter -> Parameter) -> string {
    let mut line -> string = "";
    if parameter.mutable {
        line = "mut " + parameter.name;
    } else {
        line = parameter.name;
    }
    if parameter.type_annotation != null {
        line = line + " -> " + parameter.type_annotation.text;
    }
    if parameter.default_value != null {
        line = line + " = " + format_expression(parameter.default_value);
    }
    return line;
}

fn format_type_parameters(parameters -> TypeParameter[]) -> string {
    if parameters.length == 0 {
        return "";
    }
    let mut names -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= parameters.length {
            break;
        }
        let parameter = parameters[index];
        let mut part -> string = parameter.name;
        if parameter.bound != null {
            part = part + " : " + parameter.bound.text;
        }
        names = append_string(names, part);
        index += 1;
    }
    return "<" + join_with_separator(names, ", ") + ">";
}

fn format_type_annotation(annotation -> TypeAnnotation?) -> string {
    if annotation == null {
        return "";
    }
    return " -> " + annotation.text;
}

fn format_initializer(initializer -> Expression?) -> string {
    if initializer == null {
        return "";
    }
    let value = format_expression(initializer);
    if value.length == 0 {
        return "";
    }
    return " = " + value;
}

fn format_effects(effects -> string[]) -> string {
    if effects.length == 0 {
        return "";
    }
    return "![" + join_with_separator(effects, ", ") + "]";
}

fn join_type_annotations(values -> TypeAnnotation[]) -> string {
    if values.length == 0 {
        return "";
    }
    let mut parts -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= values.length {
            break;
        }
        parts = append_string(parts, values[index].text);
        index += 1;
    }
    return join_with_separator(parts, ", ");
}

fn format_expression(expression -> Expression) -> string {
    if expression.variant == "Identifier" {
        return expression.name;
    }
    if expression.variant == "NumberLiteral" {
        return expression.value;
    }
    if expression.variant == "BooleanLiteral" {
        if expression.value {
            return "true";
        }
        return "false";
    }
    if expression.variant == "NullLiteral" {
        return "null";
    }
    if expression.variant == "StringLiteral" {
        return quote_string(expression.value);
    }
    if expression.variant == "Unary" {
        let operand = format_expression(expression.operand);
        if expression.operator == "!" {
            return "!" + operand;
        }
        return expression.operator + operand;
    }
    if expression.variant == "Binary" {
        let left = format_expression(expression.left);
        let right = format_expression(expression.right);
        let op = expression.operator;
        let spaced = " " + op + " ";
        return left + spaced + right;
    }
    if expression.variant == "Member" {
        return format_expression(expression.object) + "." + expression.member;
    }
    if expression.variant == "Call" {
        let mut rendered -> string[] = [];
        let mut index -> number = 0;
        loop {
            if index >= expression.arguments.length {
                break;
            }
            rendered = append_string(rendered, format_expression(expression.arguments[index]));
            index += 1;
        }
        let args = join_with_separator(rendered, ", ");
        return format_expression(expression.callee) + "(" + args + ")";
    }
    if expression.variant == "Index" {
        let target = format_expression(expression.sequence);
        let offset = format_expression(expression.index);
        return target + "[" + offset + "]";
    }
    if expression.variant == "Array" {
        let mut rendered -> string[] = [];
        let mut index -> number = 0;
        loop {
            if index >= expression.elements.length {
                break;
            }
            rendered = append_string(rendered, format_expression(expression.elements[index]));
            index += 1;
        }
        let contents = join_with_separator(rendered, ", ");
        return "[" + contents + "]";
    }
    if expression.variant == "Object" {
        let mut rendered -> string[] = [];
        let mut index -> number = 0;
        loop {
            if index >= expression.fields.length {
                break;
            }
            let field = expression.fields[index];
            let value = format_expression(field.value);
            rendered = append_string(rendered, field.name + ": " + value);
            index += 1;
        }
        let body = join_with_separator(rendered, ", ");
        return "{" + " " + body + " " + "}";
    }
    if expression.variant == "Struct" {
        let type_name = join_with_separator(expression.type_name, ".");
        let mut rendered -> string[] = [];
        let mut index -> number = 0;
        loop {
            if index >= expression.fields.length {
                break;
            }
            let field = expression.fields[index];
            let value = format_expression(field.value);
            rendered = append_string(rendered, field.name + ": " + value);
            index += 1;
        }
        let body = join_with_separator(rendered, ", ");
        return type_name + " { " + body + " }";
    }
    if expression.variant == "Range" {
        let start_value = format_expression(expression.start);
        let end_value = format_expression(expression.end);
        return start_value + ".." + end_value;
    }
    if expression.variant == "Lambda" {
        return format_lambda_expression(expression);
    }
    if expression.variant == "Raw" {
        return trim_text(expression.text);
    }
    return "";
}

fn format_lambda_expression(expression -> Expression) -> string {
    let params = format_lambda_parameters(expression.parameters);
    let mut header -> string = "fn " + params;
    if expression.return_type != null {
        header = header + " -> " + expression.return_type.text;
    }

    let body = format_lambda_body(expression.body);
    return header + " " + body;
}

fn format_lambda_parameters(parameters -> Parameter[]) -> string {
    let mut rendered -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= parameters.length {
            break;
        }
        let param = parameters[index];
        let mut entry -> string = param.name;
        if param.type_annotation != null {
            entry = entry + " -> " + param.type_annotation.text;
        }
        rendered = append_string(rendered, entry);
        index += 1;
    }
    let args = join_with_separator(rendered, ", ");
    return "(" + args + ")";
}

fn format_lambda_body(body -> Block) -> string {
    let mut lines -> string[] = [];
    if body.statements.length == 0 {
        lines = append_string(lines, "// empty body");
    } else {
        let mut index -> number = 0;
        loop {
            if index >= body.statements.length {
                break;
            }
            lines = append_string(lines, format_lambda_statement(body.statements[index]));
            index += 1;
        }
    }

    let indented = indent_lines(lines, 1);
    return "{\n" + join_with_separator(indented, "\n") + "\n}";
}

fn format_lambda_statement(statement -> Statement) -> string {
    if statement.variant == "ReturnStatement" {
        if statement.expression == null {
            return "return;";
        }
        return "return " + format_expression(statement.expression) + ";";
    }
    if statement.variant == "ExpressionStatement" {
        return format_expression(statement.expression) + ";";
    }
    if statement.variant == "VariableDeclaration" {
        let mut line -> string = "let ";
        if statement.mutable {
            line = line + "mut ";
        }
        line = line + statement.name;
        if statement.type_annotation != null {
            line = line + " -> " + statement.type_annotation.text;
        }
        if statement.initializer != null {
            line = line + " = " + format_expression(statement.initializer);
        }
        return line + ";";
    }
    if statement.variant == "Unknown" {
        return "// original: " + collapse_whitespace(statement.text);
    }
    return "// TODO: unsupported lambda statement: " + statement.variant;
}

fn indent_lines(lines -> string[], depth -> number) -> string[] {
    let mut result -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= lines.length {
            break;
        }
        let mut prefix -> string = "";
        let mut count -> number = 0;
        loop {
            if count >= depth {
                break;
            }
            prefix = prefix + "    ";
            count += 1;
        }
        result = append_string(result, prefix + lines[index]);
        index += 1;
    }
    return result;
}

fn quote_string(value -> string) -> string {
    let mut result -> string = "\"";
    let mut index -> number = 0;
    loop {
        if index >= value.length {
            break;
        }
        result = result + escape_string_char(value[index]);
        index += 1;
    }
    result = result + "\"";
    return result;
}

fn escape_string_char(ch -> string) -> string {
    if ch == "\"" {
        return "\\\"";
    }
    if ch == "\\" {
        return "\\\\";
    }
    if ch == "\n" {
        return "\\n";
    }
    if ch == "\r" {
        return "\\r";
    }
    if ch == "\t" {
        return "\\t";
    }
    return ch;
}

fn format_test_name(name -> string) -> string {
    return quote_string(name);
}

fn is_identifier(value -> string) -> boolean {
    if value.length == 0 {
        return false;
    }
    let first = value[0];
    if !is_identifier_start(first) {
        return false;
    }
    let mut index -> number = 1;
    loop {
        if index >= value.length {
            break;
        }
        if !is_identifier_part(value[index]) {
            return false;
        }
        index += 1;
    }
    return true;
}

fn is_identifier_start(ch -> string) -> boolean {
    if ch == "_" {
        return true;
    }
    let code = char_code(ch);
    return (code >= char_code("a") && code <= char_code("z"))
        || (code >= char_code("A") && code <= char_code("Z"));
}

fn is_identifier_part(ch -> string) -> boolean {
    if is_identifier_start(ch) {
        return true;
    }
    let code = char_code(ch);
    return code >= char_code("0") && code <= char_code("9");
}

fn trim_block_body(text -> string) -> string {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return trimmed;
    }
    if trimmed[0] == "{" && trimmed[trimmed.length - 1] == "}" {
        return trim_text(substring(trimmed, 1, trimmed.length - 1));
    }
    return trimmed;
}

fn collapse_whitespace(value -> string) -> string {
    let mut result -> string = "";
    let mut index -> number = 0;
    let mut last_space -> boolean = false;
    loop {
        if index >= value.length {
            break;
        }
        let ch = value[index];
        let is_space = ch == " " || ch == "\n" || ch == "\r" || ch == "\t";
        if is_space {
            if !last_space {
                result = result + " ";
                last_space = true;
            }
        } else {
            result = result + ch;
            last_space = false;
        }
        index += 1;
    }
    return trim_text(result);
}

fn tokens_to_source(tokens -> Token[]) -> string {
    if tokens.length == 0 {
        return "";
    }
    let mut parts -> string[] = [];
    let mut index -> number = 0;
    loop {
        if index >= tokens.length {
            break;
        }
        parts = append_string(parts, tokens[index].lexeme);
        index += 1;
    }
    return collapse_whitespace(join_with_separator(parts, ""));
}

fn builder_new() -> TextBuilder {
    return TextBuilder { lines: [], indent: 0 };
}

fn builder_emit_line(builder -> TextBuilder, line -> string) -> TextBuilder {
    let mut prefix -> string = "";
    let mut count -> number = 0;
    loop {
        if count >= builder.indent {
            break;
        }
        prefix = prefix + "    ";
        count += 1;
    }
    let full_line = prefix + trim_right(line);
    let lines = append_string(builder.lines, full_line);
    return TextBuilder { lines: lines, indent: builder.indent };
}

fn builder_emit_blank(builder -> TextBuilder) -> TextBuilder {
    let lines = append_string(builder.lines, "");
    return TextBuilder { lines: lines, indent: builder.indent };
}

fn builder_push_indent(builder -> TextBuilder) -> TextBuilder {
    return TextBuilder { lines: builder.lines, indent: builder.indent + 1 };
}

fn builder_pop_indent(builder -> TextBuilder) -> TextBuilder {
    let mut indent = builder.indent;
    if indent > 0 {
        indent -= 1;
    }
    return TextBuilder { lines: builder.lines, indent: indent };
}

fn builder_to_string(builder -> TextBuilder) -> string {
    let content = join_with_separator(builder.lines, "\n");
    if content.length == 0 {
        return "";
    }
    return content + "\n";
}

fn trim_right(value -> string) -> string {
    let mut end -> number = value.length;
    loop {
        if end <= 0 {
            break;
        }
        let ch = value[end - 1];
        if ch == " " || ch == "\t" {
            end -= 1;
            continue;
        }
        break;
    }
    if end == value.length {
        return value;
    }
    return substring(value, 0, end);
}

fn append_string(values -> string[], value -> string) -> string[] {
    return values.concat([value]);
}

fn join_with_separator(values -> string[], separator -> string) -> string {
    if values.length == 0 {
        return "";
    }
    let mut result -> string = values[0];
    let mut index -> number = 1;
    loop {
        if index >= values.length {
            break;
        }
        result = result + separator + values[index];
        index += 1;
    }
    return result;
}

fn trim_text(value -> string) -> string {
    let mut start -> number = 0;
    let mut end -> number = value.length;
    loop {
        if start >= end {
            break;
        }
        let ch = value[start];
        if is_trim_char(ch) {
            start += 1;
            continue;
        }
        break;
    }
    loop {
        if end <= start {
            break;
        }
        let ch = value[end - 1];
        if is_trim_char(ch) {
            end -= 1;
            continue;
        }
        break;
    }
    if start == 0 && end == value.length {
        return value;
    }
    return substring(value, start, end);
}

fn is_trim_char(ch -> string) -> boolean {
    return ch == " " || ch == "\n" || ch == "\r" || ch == "\t";
}
