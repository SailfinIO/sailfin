// compiler/src/version.sfn
//
// Stage2 CLI/compiler version string.
//
// Release tooling (python-semantic-release) bumps the `__version__` string.
let __version__ = "0.1.1-alpha.82";

fn sailfin_stage2_version() -> string {
    // Avoid relying on module-top-level string initialization (not yet reliable
    // in the self-hosted pipeline). This literal is synced automatically by CI
    // (see .github/workflows/build.yml semantic-release step).
    return "0.1.1-alpha.80";
}
