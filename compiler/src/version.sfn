// compiler/src/version.sfn
//
// Native compiler CLI/compiler version string.
//
// Release tooling (python-semantic-release) bumps the `__version__` string.
let __version__ = "0.1.1-alpha.119";

fn sailfin_version() -> string {
    return __version__;
}

// Legacy name preserved for compatibility with older callers.
fn sailfin_stage2_version() -> string {
    return sailfin_version();
}
