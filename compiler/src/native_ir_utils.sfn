fn parse_decimal_number(text -> string) -> NumberParseResult {
    let trimmed = trim_text(text);
    if trimmed.length == 0 {
        return NumberParseResult { success: false, value: 0 };
    }
    let zero = char_code("0");
    let nine = char_code("9");
    let mut index -> number = 0;
    let mut value -> number = 0;
    loop {
        if index >= trimmed.length {
            break;
        }
        let ch = trimmed[index];
        let code = char_code(ch);
        let mut _if386 -> boolean = false;
        if code < zero { _if386 = true; }
        if code > nine { _if386 = true; }
        if _if386 {
            return NumberParseResult { success: false, value: 0 };
        }
        let digit = code - zero;
        value = value * 10 + digit;
        index += 1;
    }
    return NumberParseResult { success: true, value: value };
}

fn split_lines(value -> string) -> string[] {
    let value_len = value.length;
    let mut lines -> string[] = [];
    let mut start -> number = 0;
    let mut index -> number = 0;
    loop {
        if index >= value_len {
            break;
        }
        let ch = value[index];
        if ch == "\n" {
            lines.push(substring_unchecked(value, start, index));
            start = index + 1;
        }
        index += 1;
    }
    lines.push(substring_unchecked(value, start, value_len));
    return lines;
}

