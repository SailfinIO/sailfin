    if size_found {
        if align_found {
            if diagnostics.length == 0 {
                _let374 = true;
            }
        }
    }
    let success = _let374;
    return StructLayoutHeaderParse { success: success, name: name_value, size: size_value, align: align_value, diagnostics: diagnostics };
