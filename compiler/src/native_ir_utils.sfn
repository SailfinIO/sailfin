        } else if ch == ">" {
            if depth > 0 {
                depth -= 1;
                if depth == 0 {
                    return index;
                }
            } else {
                return index;
            }
        }
        index += 1;
    }
    return -1;
}

fn find_matching_paren(text -> string, start_index -> number) -> number {
