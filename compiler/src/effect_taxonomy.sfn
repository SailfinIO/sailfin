// compiler/src/effect_taxonomy.sfn
//
// Canonical effect taxonomy for the Sailfin language. The set of
// effect names a function can declare in its `![effect, ...]` clause
// is locked at 1.0 and lives here so every consumer (the effect
// checker, the diagnostic renderer, future capability cross-checks)
// agrees on which strings are recognized.
//
// Decisions captured in `docs/proposals/0008-effect-validation.md` (locked
// 2026-04-26):
//   - `clock` stays distinct from `io` (§7.1) — determinism boundary.
//   - `model` is reserved at 1.0 even though `sfn/ai` is post-1.0
//     (§7.2) — prevents a future breaking change to the taxonomy.
//   - `gpu` is reserved at 1.0 for the same reason — tensor-on-GPU
//     work is post-1.0 but the effect surface stays stable.
//
// The list is intentionally short. Six concepts cover every
// runtime-visible side effect a Sailfin function can have today, and
// each maps cleanly onto a capability the capsule manifest can
// require in `[capabilities] required = [...]`. Adding a seventh
// effect post-1.0 means breaking the lock — do not extend without an
// explicit RFC.
//
// The list is also stored in canonical sort order so callers that
// render `missing_effects` see deterministic output. `![clock, io]`
// always renders the same way regardless of detection order, which
// matters when effect strings show up in error messages that get
// pasted into bug reports and code-review threads.
fn canonical_effects() -> string[] {
    return ["clock", "gpu", "io", "model", "net", "rand"];
}

fn is_canonical_effect(name: string) -> boolean {
    let canonical = canonical_effects();
    let mut i: int = 0;
    loop {
        if i >= canonical.length { break; }
        if canonical[i] == name { return true; }
        i += 1;
    }
    return false;
}

// `pure` is a sentinel meaning "this routine declares no effects" —
// always allowed regardless of the capsule's capability surface, and
// never satisfies a real effect requirement. Documented in the test-
// infrastructure proposal
// (`docs/proposals/0010-test-infra/01-preconditions.md` §P3) as the
// annotation `![pure]` for `pure_assert_*` matchers and pure tests.
//
// Distinct from the canonical taxonomy: `pure` is not a capability the
// capsule manifest can grant or deny; it's a no-op marker that makes
// the empty effect set explicit at the call site. Adding it to
// `canonical_effects()` would conflate the two concepts and break the
// 1.0 lock on the canonical six.
fn is_universally_allowed_effect(name: string) -> boolean {
    return name == "pure";
}

// The refinement root of a (possibly dotted) effect string: the
// segment before the first `.`. `"io.fs.read" -> "io"`, `"io" -> "io"`.
// SFEP-0017 D1 — sub-effects are dotted-name strings whose first
// segment must be one of the canonical six; this extracts that segment
// so recognition and subsumption key off the locked root, never a
// seventh atom.
fn effect_root(name: string) -> string {
    let mut i: int = 0;
    loop {
        if i >= name.length { break; }
        if name[i] == "." { return substring(name, 0, i); }
        i += 1;
    }
    return name;
}

// A (possibly dotted) effect string is recognized iff it is the `pure`
// sentinel or its refinement root is one of the canonical six
// (SFEP-0017 D1). `canonical_effects()` is untouched — `io.fs` is
// recognized by root membership, not by extending the locked set, so
// no seventh atom is added. An unrecognized root (`disk`, or the `fs`
// left behind if `io.fs` ever mis-split into `["io","fs"]`) is rejected
// by the checker's E0404 pass, which is the live consumer of this
// predicate.
fn is_recognized_effect(name: string) -> boolean {
    if is_universally_allowed_effect(name) { return true; }
    return is_canonical_effect(effect_root(name));
}

// Subsumption in the refinement lattice (SFEP-0017 D2): a broad grant
// subsumes a narrower requirement. `grant` subsumes `requirement` iff
// `requirement ⊑ grant` — `requirement == grant`, or `grant` is a
// strict dotted prefix of `requirement`. So `io` subsumes `io.fs`
// (`io.fs ⊑ io`), `io.fs` does not subsume `io`, siblings `io.fs` /
// `io.console` are unordered, and cross-root pairs never subsume. The
// prefix must land on a `.` boundary so `io` does not spuriously
// subsume `iox`.
fn effect_subsumes(grant: string, requirement: string) -> boolean {
    if requirement == grant { return true; }
    if requirement.length <= grant.length { return false; }
    if substring(requirement, 0, grant.length) != grant { return false; }
    return requirement[grant.length] == ".";
}

export {
    canonical_effects,
    is_canonical_effect,
    is_universally_allowed_effect,
    effect_root,
    is_recognized_effect,
    effect_subsumes
};
