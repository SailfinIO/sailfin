import { prepare_stage2_aot_modules } from "../src/aot_prepare";

fn _index_of(haystack -> string, needle -> string) -> number {
    if needle.length == 0 {
        return 0;
    }
    if haystack.length < needle.length {
        return -1;
    }
    let mut i -> number = 0;
    loop {
        if i + needle.length > haystack.length {
            break;
        }
        let mut j -> number = 0;
        let mut matches -> boolean = true;
        loop {
            if j >= needle.length {
                break;
            }
            if haystack[i + j] != needle[j] {
                matches = false;
                break;
            }
            j += 1;
        }
        if matches {
            return i;
        }
        i += 1;
    }
    return -1;
}

fn _contains(haystack -> string, needle -> string) -> boolean {
    return _index_of(haystack, needle) >= 0;
}

test "integration: aot_prepare injects round declare" {
    // Multi-line concatenation exercises native-text instruction gathering.
    let ir = "source_filename = \"m1.ll\"\n\n" +
        "define double @foo(double %x) {\n" +
        "entry:\n" +
        "  %y = call double @round(double %x)\n" +
        "  ret double %y\n" +
        "}\n";

    let out = prepare_stage2_aot_modules(["m1"], [ir]);
    if out.length != 1 {
        runtime_raise_value_error_fn("expected 1 rewritten module");
    }
    let rewritten = out[0];

    let decl = "declare double @round(double)";
    if !_contains(rewritten, decl) {
        runtime_raise_value_error_fn("missing round decl");
    }

    // Insert after the source_filename line.
    let source_at = _index_of(rewritten, "source_filename");
    let decl_at = _index_of(rewritten, decl);
    if source_at < 0 {
        runtime_raise_value_error_fn("missing source_filename");
    }
    if decl_at <= source_at {
        runtime_raise_value_error_fn("decl not after source_filename");
    }
}
