struct Person {
    id -> number;

    fn id_plus(self, x -> number) -> number {
        return self.id + x;
    }
}

async fn make_person(id -> number) -> Person {
    return Person { id: id };
}

test "integration: async struct return stress" {
    let mut i -> number = 0;
    loop {
        if i >= 200 {
            break;
        }

        // Await a FuturePtr in a typed context so the lowering unboxes + frees.
        let person -> Person = await make_person(i);
        assert person.id_plus(1) == (i + 1);

        i += 1;
    }
}
