// examples/advanced/matrix-multiplication.sfn

fn multiply(a: int[][], b: int[][]) -> int[][] {
    let rowsA = a.length;
    let colsA = a[0].length;
    let colsB = b[0].length;

    return (0..rowsA).map(fn(row) -> int[] {
        return (0..colsB).map(fn(col) -> int {
            return (0..colsA).reduce(0, fn(acc, k) -> int {
                return acc + a[row][k] * b[k][col];
            });
        });
    });
}

fn main() ![io] {
    let a = [[1, 2], [3, 4]];
    let b = [[5, 6], [7, 8]];
    let result = multiply(a, b);
    // Print each cell of the product (a·b = [[19, 22], [43, 50]]). Nested
    // `int[][]` values do not yet render through `{{ }}` interpolation, so the
    // scalar cells are printed directly.
    print("Result:");
    let mut i: int = 0;
    loop {
        if i >= result.length { break; }
        let row = result[i];
        let mut j: int = 0;
        loop {
            if j >= row.length { break; }
            print(row[j]);
            j = j + 1;
        }
        i = i + 1;
    }
}
