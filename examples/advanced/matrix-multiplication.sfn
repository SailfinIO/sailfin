// examples/advanced/matrix-multiplication.sfn
fn multiply(a: int[][], b: int[][]) -> int[][] {
    let rowsA = a.length;
    let colsA = a[0].length;
    let colsB = b[0].length;

    return (0 .. rowsA).map(fn (row) -> int[] {
        return (0 .. colsB).map(fn (col) -> int {
            return (0 .. colsA).reduce(0, fn (acc, k) -> int {
                return acc + a[row][k] * b[k][col];
            });
        });
    });
}

fn main() ![io] {
    let a = [[1, 2], [3, 4]];
    let b = [[5, 6], [7, 8]];
    let result = multiply(a, b);
    print("Result: {{result}}");
}
