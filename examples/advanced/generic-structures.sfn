// examples/advanced/generic-structures.sfn
struct List<T> {
    items: T[];

    fn new() -> List<T> {
        return List<T> {
            items: []
        };
    }

    fn add(self, item: T) -> void { self.items.push(item); }

    fn get(self, index: int) -> T | null {
        if index < 0 || index >= self.items.length { return null; }
        return self.items[index];
    }
}

fn main() ![io] {
    let numbers: List<int> = List.new();
    numbers.add(1);
    numbers.add(2);
    print("{{numbers.get(0)}}");
}
