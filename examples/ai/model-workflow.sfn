// examples/ai/model-workflow.sfn

model Summarizer : Model<Text, Summary> {
    engine = "mock@1";
    schema = Summary;
    max_tok = 2000;
}

fn seed(value -> number) -> void {
    // placeholder deterministic scope helper
}

fn temperature(value -> number) -> void {
    // placeholder temperature helper
}

fn call_model(name -> string, input -> string) -> string ![model] {
    return "{{name}}::{{input}}";
}

fn summarize(doc -> string) -> string ![model] {
    prompt system {
        "Summarize the document precisely.";
    }
    prompt user {
        doc;
    }
    return call_model("summarizer", doc);
}

tool FetchTitle(id -> string) -> string ![net] {
    return "title:" + id;
}

pipeline summarize_all(docs -> Array<string>) -> void ![model, io] {
    for doc in docs {
        summarize(doc);
    }
}

fn main() -> void ![model, io] {
    with seed(42), temperature(0.2) {
        let result -> string = summarize("Design doc");
        print(result);
    }
}
