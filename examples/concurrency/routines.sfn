// examples/concurrency/routines.sfn
fn main() ![io] {
    // The earlier named-routine preview (`routine "name" { ... }`) was
    // superseded and is not language syntax:
    //
    //     routine "named" {
    //         print("This is routine 1");
    //     }
    // `routine { ... }` is the shipped structured-concurrency nursery.
    routine { print("This is an unnamed routine"); }
}
