// examples/concurrency/producer-consumer.sfn
import { Channel, channel } from "sync";

fn main() ![io] {
    // A bounded channel sized to hold the whole batch. The producer runs in a
    // structured-concurrency `routine` nursery that fills the buffer and joins;
    // `main` then drains every item. Two runtime notes shape this example:
    //   - `await` works on futures created by `spawn`, not on a synchronous
    //     channel receive (see examples/concurrency/channels.sfn), so the
    //     consumer receives directly into a typed `int`.
    //   - a `for i in ..` range variable is a float; the pointer-width int
    //     channel round-trips cleanly only for int payloads, so the producer
    //     sends an explicit `int` counter.
    let buffer: Channel<int> = channel(20);

    let mut n: int = 0;
    routine {
        for _ in 1..20 {
            n = n + 1;
            print("Producing {{n}}");
            buffer.send(n);
        }
    }

    for _ in 1..20 {
        let item: int = buffer.receive();
        print("Consumed {{item}}");
    }
}
