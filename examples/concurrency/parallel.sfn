// examples/concurrency/parallel.sfn

fn computeTask1() -> int {
    return 21;
}

fn computeTask2() -> int {
    return 21;
}

fn main() ![io] {
    let results = parallel [
        fn() -> int { return computeTask1(); },
        fn() -> int { return computeTask2(); },
    ];

    print("Results: {{results}}");
}
