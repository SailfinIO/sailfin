// runtime/sfn/string.sfn
//
// First wave of Sailfin-native `SfnString` operations (M2.4a, #396).
// The module pins the future shape of the five non-allocating
// `sfn_str_*` helpers — `len`, `eq`, `slice`, `to_cstr`,
// `from_cstr` — and ships into the compiler binary as the live
// Sailfin bodies (the retired C runtime is deleted).
//
// Status: real Sailfin bodies. The architect plan in
// `docs/proposals/0025-native-runtime-architecture.md` `#33-string-subsystem` specifies these helpers
// against the SfnString aggregate (`{i8*, i64}` by value) so
// `sfn_str_len` is a single field load and `sfn_str_eq` is a length
// compare + `memcmp`. The M1.A.2 type-mapping flip has landed —
// the Sailfin frontend now lowers `string` to the `{i8*, i64}`
// aggregate (`compiler/src/llvm/type_mapping.sfn`) — but these
// bodies still take their payloads as NUL-terminated `* u8` by the
// registry ABI and bridge through libc, so the body rewrite over
// the aggregate field-read shape is still future work. The function
// *names* are the migration unit — that rewrite can land in-place
// over the aggregate shape without touching any caller.
//
// Naming: the `sfn_str_sfn_*` infix originally let the Sailfin
// module coexist with the retired C runtime's matching `sfn_str_*`
// exports without a link-time collision (mirrors the arena module's
// `sfn_arena_sfn_*` infix; see `runtime/sfn/memory/arena.sfn` for
// the same rationale). With the C trampolines deleted, the
// canonical user-facing names — the ones the compiler emits
// `call`s against — are the bare `sfn_str_*` Sailfin bodies here;
// the `_sfn_` infix migration is complete.
//
// Effects: none. String primitives live below the I/O layer (same
// discipline as `runtime/sfn/memory/arena.sfn`). The `![io]`
// annotations attach to *adapters* that wrap these primitives,
// never to the primitives themselves.
//
// #1289 / #1283 Gap 1: `OwnedBuf` and its grow-at-tip constructor
// (`owned_buf_new`) come from the canonical `./memory/ownedbuf` module
// rather than being inlined here. The inline copy #1217 (Phase R1) shipped
// existed only because the runtime-sfn-source emit path could not resolve a
// cross-module struct-returning call — the `OwnedBuf` aggregate return died
// at `core_call_emission.sfn` with `cannot resolve return type for call to …`
// (an inline `extern fn` can't carry the struct either — C-ABI only, E0805).
// #1288 taught `_compile_runtime_sfn_sources` to stage sibling runtime
// modules' `.sfn-asm` into the import-context the lowering consults, so the
// call now resolves; with a seed containing #1288 pinned, this consumer
// collapses the duplication. `ownedbuf.sfn` and `arena.sfn` are linked
// alongside this module via `runtime/capsule.toml`'s `sfn-sources`.
//
// #1318 retired the OwnedBuf-returning `sfn_str_sfn_concat` / `_append`
// proof-of-life wrappers; the real `sfn_str_concat` / `sfn_str_append` bodies
// below allocate through the arena directly to match the registry's SfnString
// `{i8*, i64}` ABI, so `owned_buf_append` is no longer imported. `owned_buf_new`
// is still used by the number/int formatters (`sfn_int_to_str` /
// `sfn_number_to_str`).
import { OwnedBuf, owned_buf_new } from "./memory/ownedbuf";

// Why inline the libc externs? The same reason `arena.sfn` does:
// the released seed compiler snapshots `runtime/sfn/platform/libc.sfn`
// at build time. Inlining keeps this module self-contained for
// every seed, regardless of which libc declarations have shipped.
// Once the seed catches up, a follow-up PR can flip these to a
// cross-module import without touching the bodies.
extern fn memcmp(a: * u8, b: * u8, n: usize) -> i32;

extern fn memchr(s: * u8, c: i32, n: usize) -> * u8;

// #1318: `sfn_str_concat` / `sfn_str_append` copy the operand payloads
// into arena storage with `memcpy`, and read the `SAILFIN_MAX_STRING_CONCAT`
// concat-limit env var with `getenv`. Inlined for the same seed-snapshot
// reason as the libc externs above (the `arena.sfn` / `io.sfn` discipline).
extern fn memcpy(dst: * u8, src: * u8, n: usize) -> * u8;

extern fn getenv(name: * u8) -> * u8;

// #1372: bounded length scan (16 MiB cap) for `sfn_str_len`/`sfn_str_eq`.
extern fn strnlen(s: * u8, n: usize) -> usize;

// M2.5 (#403): `strtod` powers the real Sailfin `sfn_str_to_number`
// body below (#1372) — the architect spec calls for a
// stack-buffered NUL-terminated copy of an SfnString followed by
// `strtod` parsing. Today's `* u8` payload is already
// NUL-terminated (literal lowering + arena-routed concat preserve
// the +1 byte), so the wrapper passes the data pointer straight
// through and discards the endptr by passing `null`.
extern fn strtod(nptr: * u8, endptr: * * u8) -> f64;

// #1308: the legacy C `sailfin_runtime_string_concat` / `_append` externs were
// deleted here — they had zero callers (the canonical `sfn_str_concat` /
// `sfn_str_append` have been real Sailfin bodies since #1318, and the last
// Sailfin demand on the legacy concat — `resolve_runtime_root` in exec.sfn —
// was retargeted to the native `+` path). The C definitions are now purely
// C-internal and retire with the C runtime at #822.
// #1315 (C4 of epic #1308): the accessor family — `byte_at`/`find_byte`/
// `codepoint`/`grapheme_at`/`grapheme_count` — are now real Sailfin
// bodies below (bare-named emission targets; the C defs are `static`).
// They cannot, under today's seed, single-byte-load a `* u8` or reproduce
// the platform-gated grapheme production, so they call two narrow C bridge
// primitives (`sailfin_runtime.c`). These retire with the SfnString
// aggregate flip (#1283). The immediate-codepoint decode is already gone:
// the `(byte << 32)` encoding is retired (#1420/#822).
//
// `codepoint`/`grapheme_count` return `f64` (not `i64`): the registry
// rows (`runtime_helpers.sfn:617,993`) expose them to callers as `i64`
// via a `double` C-ABI return + a `round + fptosi` coercion at the call
// site. Returning `f64` here keeps that ABI byte-identical, so no
// registry edit and no seed cut are needed (the seed still emits the
// `double`-coerced call sites).
// #1308 (immediate-encoding teardown): the `(byte << 32)` tagged
// pseudo-pointer encoding is fully retired — the producer flip (#1420) means
// no immediate can exist at runtime, and the C runtime it decoded against is
// deleted (#822). The `sfn_str_immediate_codepoint` classifier and
// `sfn_str_decode_owned` identity bridge, and the dead `if cp >= 0 { ... }`
// consumer arms they guarded, have been removed; the bodies below handle only
// the real-pointer case.
//
// #1308: `read_byte` / `grapheme_byte` are now native Sailfin (the C defs are
// deleted, seed 0.7.0-alpha.41 carries the `load_byte` builtin). They read a
// single byte from `real` via `load_byte` (compiler/src/llvm/byte_load.sfn) — a
// true `load i8` + `zext`, sound at any alignment, unlike the word-load
// `_owned_buf_load_byte` which over-reads the enclosing 8-aligned word and is
// only safe on padded `owned_buf_new` storage. `read_byte` is byte-identical to
// the C `(int64_t)(unsigned char)real[idx]`; `grapheme_byte` reuses
// `sfn_str_from_byte` (the arena-backed single-byte producer) for the 1-byte
// buffer the C body built with `malloc(2)`.
fn sfn_str_read_byte(s: * u8, idx: i64) -> i64 {
    return load_byte((s as i64) + idx);
}

fn sfn_str_grapheme_byte(real: * u8, idx: i64) -> * u8 {
    return sfn_str_from_byte(load_byte((real as i64) + idx));
}

// `sfn_str_from_codepoint(cp)` — #1308 (C5): real Sailfin UTF-8 encode of a
// single codepoint into a fresh arena-backed NUL-terminated buffer (the C
// `sfn_str_from_codepoint` def is now `static`). Validation mirrors the C
// body: reject negative, `> 0x10FFFF` (1114111), and the surrogate range
// `0xD800..0xDFFF` (55296..57343), returning the empty string for an invalid
// codepoint. Reuses the `_sfn_utf8_byte_len` / `_sfn_utf8_byte` width+byte
// helpers (#1372) and the concat arena-alloc + `_num_put_byte` byte-write
// discipline (#1318): a `roundup8(n + 1)` allocation at 8-byte alignment keeps
// the word read-modify-write in-bounds. No `_runtime_enter` (the concat-reuse
// window is vestigial) and no owned-string tracking (the arena reclaims).
// Decimal literals (the seed lexer has no `0x`).
fn sfn_str_from_codepoint(cp: i64) -> * u8 {
    if cp < 0 {
        let empty: string = "";
        return empty as * u8;
    }
    if cp > 1114111 {
        let empty: string = "";
        return empty as * u8;
    }
    if cp >= 55296 && cp <= 57343 {
        let empty: string = "";
        return empty as * u8;
    }

    let n: i64 = _sfn_utf8_byte_len(cp);
    let arena: * u8 = sfn_arena_global();
    let cap: i64 = ((n + 1 + 7) / 8) * 8;
    let data: * u8 = sfn_arena_alloc(arena, cap as usize, 8 as usize);
    if (data as i64) == 0 {
        let empty: string = "";
        return empty as * u8;
    }

    let mut i: i64 = 0;
    loop {
        if i >= n { break; }
        _num_put_byte(data as i64 + i, _sfn_utf8_byte(cp, n, i));
        i = i + 1;
    }
    _num_put_byte(data as i64 + n, 0);
    return data;
}

// `sfn_str_from_byte(byte_value)` — #874 / #1308 (C5): native Sailfin raw
// single-byte string constructor (the C `sfn_str_from_byte` def is now
// `static`). Unlike `from_codepoint` (UTF-8 encode), this writes the byte
// value verbatim — the write counterpart to the byte read. Returns a fresh
// arena-backed NUL-terminated 1-byte buffer for 1..255; the empty string for 0
// (unrepresentable under the NUL-terminated model) and out-of-range values.
// Same arena-alloc + `_num_put_byte` discipline as `sfn_str_from_codepoint`.
fn sfn_str_from_byte(byte_value: i64) -> * u8 {
    if byte_value < 1 {
        let empty: string = "";
        return empty as * u8;
    }
    if byte_value > 255 {
        let empty: string = "";
        return empty as * u8;
    }
    let arena: * u8 = sfn_arena_global();
    let data: * u8 = sfn_arena_alloc(arena, 8 as usize, 8 as usize);
    if (data as i64) == 0 {
        let empty: string = "";
        return empty as * u8;
    }
    _num_put_byte(data as i64, byte_value & 255);
    _num_put_byte(data as i64 + 1, 0);
    return data;
}

// #1217 (Phase R1): the process-global arena `concat` builds into, and
// the arena-mode probe that gates it. `sfn_arena_global()` ALWAYS
// returns a live arena handle — it is NOT null when the arena is
// disabled — so callers must gate on `sfn_arena_enabled()` first (the
// discipline every other runtime module follows, e.g.
// `runtime/sfn/memory/arena.sfn`'s mark/rewind). Under
// `SAILFIN_USE_ARENA=0` (ASAN / diagnostics), `concat` therefore passes
// `arena_addr = 0` and `owned_buf_new` falls back to libc storage. Both
// are C-ABI (`-> * u8` / `-> bool`), so they stay inline externs (same
// discipline as the libc externs above).
extern fn sfn_arena_global() -> * u8;

extern fn sfn_arena_enabled() -> bool;

// #1318: the arena bump allocator + grow-at-tip realloc backing the
// `sfn_str_concat` / `sfn_str_append` bodies. Both `sfn_arena_alloc`
// (#1309) and `sfn_arena_realloc` (#1308) are now the Sailfin exports in
// `runtime/sfn/memory/arena.sfn`. Both are reached as C-ABI externs, the
// same discipline `ownedbuf.sfn` follows for `sfn_arena_sfn_*`.
extern fn sfn_arena_alloc(arena: * u8, size: usize, align: usize) -> * u8;

extern fn sfn_arena_realloc(arena: * u8, ptr: * u8, old_size: usize, new_size: usize, align: usize) -> * u8;

// #1318: the concat/append limit gate raises ValueError (which aborts the
// process) when a concatenation would exceed `SAILFIN_MAX_STRING_CONCAT`
// or overflow. #1308: routed to the native Sailfin `sfn_raise_value_error`
// (`runtime/sfn/exception.sfn` — write(2) + abort, the canonical emission
// target for `runtime_raise_value_error_fn`) instead of the legacy C
// `sailfin_runtime_raise_value_error`, resolved as a cross-module extern.
extern fn sfn_raise_value_error(message: * u8) -> void;

// #1372: UTF-8 byte length of a validated codepoint — mirrors the
// branch widths of the C `_utf8_encode`. Used to size a codepoint's UTF-8
// encoding before writing its bytes (see the encoder above).
// NB: decimal literals (128/2048/65536) deliberately — the seed lexer has no
// `0x` hex support (hex literals silently lower to 0). Decimal is exact and
// portable across seeds; flip to hex once the lexer learns `0x`.
fn _sfn_utf8_byte_len(cp: i64) -> i64 {
    if cp < 128 { return 1; }
    if cp < 2048 { return 2; }
    if cp < 65536 { return 3; }
    return 4;
}

// #1372: the `i`-th UTF-8 byte (0-based) of a validated codepoint `cp`
// whose encoded length is `n`. Byte-for-byte the C `_utf8_encode` layout.
// Decimal masks (seed lexer has no `0x`): 0xff=255, 0xc0=192, 0x3f=63,
// 0x80=128, 0xe0=224, 0xf0=240.
fn _sfn_utf8_byte(cp: i64, n: i64, i: i64) -> i64 {
    if n == 1 { return cp & 255; }
    if n == 2 {
        if i == 0 { return 192 | (cp >> 6); }
        return 128 | (cp & 63);
    }
    if n == 3 {
        if i == 0 { return 224 | (cp >> 12); }
        if i == 1 { return 128 | ((cp >> 6) & 63); }
        return 128 | (cp & 63);
    }
    if i == 0 { return 240 | (cp >> 18); }
    if i == 1 { return 128 | ((cp >> 12) & 63); }
    if i == 2 { return 128 | ((cp >> 6) & 63); }
    return 128 | (cp & 63);
}

// `sfn_str_len(s)` — #1372 (C5 of epic #1308): the real Sailfin body for
// the `string.length` emission target (the C `sfn_str_len` def is now
// `static`). A real pointer is bounded-scanned with libc `strnlen`
// (16 MiB cap). Byte-identical to the retired `sailfin_runtime_string_length`
// delegator, whose non-ASAN path is exactly `strnlen(s, 16 MiB)`.
fn sfn_str_len(s: * u8) -> i64 {
    if (s as i64) == 0 { return 0; }
    return strnlen(s, 16777216) as i64;
}

// `sfn_str_eq(a, b)` — #1372: the real Sailfin body for the string `==`
// emission target (the C `sfn_str_eq` def is now `static`). Reproduces
// `_strings_equal_fast` arm-for-arm: pointer-equal (covers both-null) is
// equal; exactly-one-null is not; two real strings compare by length +
// `memcmp`.
fn sfn_str_eq(a: * u8, b: * u8) -> bool {
    if (a as i64) == (b as i64) { return true; }
    if (a as i64) == 0 { return false; }
    if (b as i64) == 0 { return false; }
    let la2: i64 = strnlen(a, 16777216) as i64;
    let lb2: i64 = strnlen(b, 16777216) as i64;
    if la2 != lb2 { return false; }
    return memcmp(a, b, la2 as usize) == 0;
}

// `sfn_str_eq_lv(a_data, a_len, b_data, b_len)` — #1704: length-aware (`_lv`)
// equality over the `{i8*, i64}` SfnString aggregate. Consumes the carried byte
// lengths instead of `strnlen`, so a non-NUL-terminated interior view (#1454)
// is compared strictly within its bounds (no over-read into the source tail).
// A length mismatch is an O(1) reject; `memcmp` over the shared length decides.
// The bare `sfn_str_eq` is left untouched as the old `(i8*, i8*)` ABI symbol the
// pinned seed emits during `make compile` and that `rlimit.sfn` externs;
// freshly-emitted IR (the hardcoded `==`/`!=` site in `core_operands.sfn`)
// targets this `_lv` symbol with both aggregate fields.
fn sfn_str_eq_lv(a_data: * u8, a_len: i64, b_data: * u8, b_len: i64) -> bool {
    if a_len != b_len { return false; }
    if (a_data as i64) == (b_data as i64) { return true; }
    if a_len == 0 { return true; }
    if (a_data as i64) == 0 { return false; }
    if (b_data as i64) == 0 { return false; }
    return memcmp(a_data, b_data, a_len as usize) == 0;
}

// `sfn_str_cmp(a, b)` — #1365: lexicographic ordering for the string `<`/`>`/
// `<=`/`>=` emission target. Returns <0 / 0 / >0 like libc `strcmp`, ordering
// by unsigned byte value with the shorter string first on a shared prefix. The
// lowering (`core_operands.sfn`) calls this and `icmp`s the result against 0 —
// previously these operators fell through to an empty predicate and the guarded
// branch was silently dropped (no `{i8*, i64}` arm in
// `comparison_predicate_for_symbol`). Mirrors `sfn_str_eq` arm-for-arm:
// pointer-equal (both-null) is 0; a single null sorts first (null < any real
// string); real operands compare via `memcmp` over the common length with a
// length tie-break.
fn sfn_str_cmp(a: * u8, b: * u8) -> i32 {
    if (a as i64) == (b as i64) { return 0; }
    if (a as i64) == 0 { return -1; }
    if (b as i64) == 0 { return 1; }
    let la2: i64 = strnlen(a, 16777216) as i64;
    let lb2: i64 = strnlen(b, 16777216) as i64;
    let mut m: i64 = la2;
    if lb2 < m { m = lb2; }
    let r: i32 = memcmp(a, b, m as usize);
    if r != 0 { return r; }
    if la2 < lb2 { return -1; }
    if la2 > lb2 { return 1; }
    return 0;
}

// `sfn_str_cmp_lv(a_data, a_len, b_data, b_len)` — #1704: length-aware (`_lv`)
// lexicographic compare over the aggregate. `memcmp` over `min(a_len, b_len)`
// then the shorter view sorts first; carried lengths replace `strnlen`, so a
// non-terminated interior view (#1454) orders strictly within its bounds. The
// bare `sfn_str_cmp` is left as the old `(i8*, i8*)` ABI symbol the seed emits;
// the hardcoded `<`/`<=`/`>`/`>=` site in `core_operands.sfn` targets this one.
fn sfn_str_cmp_lv(a_data: * u8, a_len: i64, b_data: * u8, b_len: i64) -> i32 {
    if (a_data as i64) == (b_data as i64) {
        if a_len == b_len { return 0; }
    }
    if (a_data as i64) == 0 { return -1; }
    if (b_data as i64) == 0 { return 1; }
    let mut m: i64 = a_len;
    if b_len < m { m = b_len; }
    if m > 0 {
        let r: i32 = memcmp(a_data, b_data, m as usize);
        if r != 0 { return r; }
    }
    if a_len < b_len { return -1; }
    if a_len > b_len { return 1; }
    return 0;
}

// `_sfn_substring_unchecked(text, start, end)` — #1308 (M1.A.2): the i64-indexed
// substring entrypoint, a real Sailfin body. Two arms:
//   1. NULL text → the empty string.
//   2. Real pointer: truly unchecked — trust the caller's bounds (already
//      validated via `.length`), clamping only `start >= 0` and `end >= start`,
//      then `memcpy [start, end)`.
// The immediate-codepoint pseudo-pointer arm is gone: the `(byte << 32)`
// encoding is retired (#1420/#822), so `text` is always a real pointer.
// Arena-backed (the process-global arena, like `sfn_str_concat` /
// `sfn_str_from_codepoint`) rather than the C body's `_rt_malloc` + owned-string
// tracking: the arena reclaims on rewind, the discipline the rest of the ported
// string surface already follows. The `roundup8(length + 1)` 8-aligned alloc +
// `_num_put_byte` trailing NUL keeps the word read-modify-write in-bounds (the
// seed cannot lower a single-byte `* u8` store). A non-owning `Slice` view stays
// blocked on #1283 (the SfnString aggregate flip).
fn _sfn_substring_unchecked(text: * u8, start: i64, end: i64) -> * u8 {
    if (text as i64) == 0 {
        let empty: string = "";
        return empty as * u8;
    }

    let mut rs: i64 = start;
    if rs < 0 { rs = 0; }
    let mut re: i64 = end;
    if re < rs { re = rs; }
    let length2: i64 = re - rs;
    let cap2: i64 = ((length2 + 1 + 7) / 8) * 8;
    let arena2: * u8 = sfn_arena_global();
    let out2: * u8 = sfn_arena_alloc(arena2, cap2 as usize, 8 as usize);
    if (out2 as i64) == 0 {
        let empty: string = "";
        return empty as * u8;
    }
    if length2 > 0 {
        memcpy(out2, (text as i64 + rs) as * u8, length2 as usize);
    }
    _num_put_byte(out2 as i64 + length2, 0);
    return out2;
}

// `sfn_str_slice(text, start, end)` — #1372: the real Sailfin body for the
// `substring` / `string.slice` emission target (the C `sfn_str_slice` def is
// now `static`). Keeps the ALLOCATING shape: clamps the `f64` indices to i64
// and calls the Sailfin i64 substring entrypoint `_sfn_substring_unchecked`
// (#1308 M1.A.2), which materialises a real, decode-safe buffer. The `f64 -> i64`
// clamp is inlined: NaN maps to 0 (`v != v`), in-range doubles truncate toward
// zero; substring indices are small, so the C `_clamp_to_i64` INT64 saturation
// arms are unnecessary.
fn sfn_str_slice(text: * u8, start: f64, end: f64) -> * u8 {
    let mut si: i64 = 0;
    if start == start { si = start as i64; }
    let mut ei: i64 = 0;
    if end == end { ei = end as i64; }
    return _sfn_substring_unchecked(text, si, ei);
}

// `sfn_str_to_cstr(s_data, s_len, arena_slot)` — #1705 (M2.4b, SFEP-0025 §3.3):
// the runtime-FFI boundary `process.sfn` / `assert.sfn` call to materialize a
// real NUL-terminated C string for `execve` / `posix_spawn` / `fwrite`. The body
// is no longer the identity: it copies the carried `s_len` bytes into the arena
// and writes a trailing NUL, so a non-NUL-terminated interior view (`{data+start,
// end-start}`, #1454) yields a correctly-terminated buffer with NO over-read into
// the source remainder. The length is the CARRIED aggregate field (callers pass
// `x.length`, a direct `extractvalue`), never a `strnlen` scan — scanning a
// non-terminated view is exactly the over-read this fixes. No registry emission
// row — it is runtime-to-runtime FFI, resolved at link.
//
// Arena. `_sfn_resolve_arena(arena_slot)` derefs the slot (or falls back to the
// process-global arena when it is null — callers pass `null`), the same
// resolution `sfn_str_concat` uses. The `roundup8(s_len + 1)` 8-aligned alloc +
// `_num_put_byte` trailing NUL keeps the word read-modify-write in-bounds (the
// seed cannot lower a single-byte `* u8` store). Like `concat`, it is
// unconditionally arena-backed (the `SAILFIN_USE_ARENA=0` opt-out routes only
// the legacy C entrypoints), so it never gates on `sfn_arena_enabled()`.
fn sfn_str_to_cstr(s_data: * u8, s_len: i64, arena_slot: * u8) -> * u8 {
    if (s_data as i64) == 0 {
        let empty: string = "";
        return empty as * u8;
    }
    let mut n: i64 = s_len;
    if n < 0 { n = 0; }
    let arena: * u8 = _sfn_resolve_arena(arena_slot);
    let cap: i64 = ((n + 1 + 7) / 8) * 8;
    let data: * u8 = sfn_arena_alloc(arena, cap as usize, 8 as usize);
    if (data as i64) == 0 {
        let oom: string = "";
        return oom as * u8;
    }
    if n > 0 { memcpy(data, s_data, n as usize); }
    _num_put_byte(data as i64 + n, 0);
    return data;
}

// `sfn_str_sfn_to_cstr(s_data, s_len, arena_slot)` — the `_sfn_` infix alias the
// emit contract still expects a define for; forwards to the bare body so both
// symbols share one arena-copy implementation.
fn sfn_str_sfn_to_cstr(s_data: * u8, s_len: i64, arena_slot: * u8) -> * u8 {
    return sfn_str_to_cstr(s_data, s_len, arena_slot);
}

// `sfn_str_sfn_from_cstr(s)` — #1705 (M2.4b, SFEP-0025 §3.3): adopt a
// NUL-terminated C buffer as an SfnString. Recovers the byte length by scanning
// for the terminating NUL with `memchr` (bounded to the 16 MiB string cap) and
// returns the `{data, len}` aggregate: the `-> SfnString` return spelling routes
// the definition onto the by-value `{i8*, i64}` ABI (M1.A.2), and the return-path
// coercion wraps `{s, len}` — byte-identical to this memchr scan because `s` is
// NUL-terminated. The explicit `memchr` makes the recovery load-bearing (a buffer
// with no NUL within the cap is rejected as the empty string rather than wrapped
// into an unbounded view). No copy: the foreign buffer is adopted in place.
fn sfn_str_sfn_from_cstr(s: * u8) -> SfnString {
    if (s as i64) == 0 {
        let empty: string = "";
        return empty;
    }
    let nul: * u8 = memchr(s, 0, 16777216 as usize);
    if (nul as i64) == 0 {
        let uncapped: string = "";
        return uncapped;
    }
    return s;
}

// #1318 (C5 of epic #1308): real Sailfin `sfn_str_concat` / `sfn_str_append`
// bodies over the registry's SfnString `{i8*, i64}` ABI. The bare names ARE
// the emission targets (`runtime_helpers.sfn`: `string.concat` →
// `return_type "{i8*, i64}"`, `parameter_types ["{i8*, i64}", "{i8*, i64}",
// "ptr"]`, `native_signature "sfn_str_concat"`); the C defs in
// `sailfin_runtime.c` are now `static`, so the linker binds every `a + b`
// call site to these definitions. The retired `sfn_str_sfn_concat` /
// `sfn_str_sfn_append` OwnedBuf proof-of-life wrappers had the wrong ABI (an
// infix the registry never targeted).
//
// ABI. A `{i8*, i64}` operand passed by value is two integer eightbytes
// (System V / AAPCS), so each `SfnString` parameter splits into a
// `(data: * u8, len: i64)` scalar pair — the same register classification
// `io.sfn`'s `sfn_getenv` relies on, and the only self-host-safe spelling
// under the seed (an `SfnString`-typed *parameter* hits the aggregate-by-value
// gap `io.sfn` documents). The bodies return a bare `* u8`; the `-> SfnString`
// return-path coercion wraps it into `{i8*, i64}`, recovering the length via
// `sfn_str_len` (a NUL scan) — byte-identical to the C body's `{data, total}`
// because the buffer is NUL-terminated at `total` and the `* u8` string model
// carries no embedded NULs.
//
// ⚠️ Reuse-window. The C `sfn_str_concat` is window-agnostic — the
// `_concat_reuse_*` globals it once warned about are vestigial (declared,
// never read/written). These bodies mirror that exactly: they allocate fresh
// per call and introduce NO `_runtime_enter` / reuse-seq bump. (Over-bumping a
// hot path was the O(n²)/8 GiB-OOM failure mode of the abandoned real-buffer
// attempt; avoided here by construction.) With the immediate-codepoint
// encoding retired (#1420/#822), operands are always real pointers, so the
// chained `a + b + c` hot path performs no extra allocation.
// `_sfn_resolve_arena(arena_slot)` derefs the `SfnArena **` slot once to the
// live arena handle, falling back to the process-global arena when the slot
// or its contents are null (the C `sfn_str_concat`'s defensive resolution).
// Concat is unconditionally arena-backed by design — the `SAILFIN_USE_ARENA=0`
// opt-out routes only the legacy C entrypoints — so this never gates on
// `sfn_arena_enabled()`.
fn _sfn_resolve_arena(arena_slot: * u8) -> * u8 {
    if (arena_slot as i64) != 0 {
        let slot: * i64 = arena_slot as * i64;
        let handle: i64 = atomic_load(slot);
        if handle != 0 { return handle as * u8; }
    }
    return sfn_arena_global();
}

// Cached `SAILFIN_MAX_STRING_CONCAT` limit (`-1` = unprobed). Mirrors the C
// `_sfn_str_check_concat_limit` default of 20000000; a negative env value
// clamps to 0 (disabled). The env literal is bound to a `string` local before
// the `* u8` cast — the proven env-read pattern (`arena.sfn` / `io.sfn`); the
// inline `getenv("…" as * u8)` form miscompiles under the seed. A provisional
// value is published before the read for the same re-entrancy discipline as
// `arena.sfn`.
let mut _sfn_concat_limit_state: i64 = -1;

fn _sfn_concat_limit() -> i64 {
    if _sfn_concat_limit_state < 0 {
        _sfn_concat_limit_state = 20000000;
        let name: string = "SAILFIN_MAX_STRING_CONCAT";
        let env: * u8 = getenv(name as * u8);
        if (env as i64) != 0 {
            let parsed: i64 = strtod(env, null) as i64;
            if parsed < 0 { _sfn_concat_limit_state = 0; } else {
                _sfn_concat_limit_state = parsed;
            }
        }
    }
    return _sfn_concat_limit_state;
}

// `_sfn_check_concat_limit(alen, blen)` raises ValueError (aborting the
// process) when `alen + blen` exceeds the configured limit — byte-faithful to
// the C gate so a runaway concat can't silently exhaust the arena.
fn _sfn_check_concat_limit(alen: i64, blen: i64) -> void {
    let limit: i64 = _sfn_concat_limit();
    if limit > 0 {
        if (alen + blen) > limit {
            let msg: string = "string concat limit exceeded";
            sfn_raise_value_error(msg as * u8);
        }
    }
}

// `sfn_str_concat(a, b, arena_slot)` — bump `a.len + b.len + 1` bytes into the
// resolved arena, memcpy both payloads, NUL-terminate, and return the
// `{data, total}` aggregate. See the family comment above.
//
// Allocation. The C body requested `sfn_arena_alloc(arena, total + 1, 1)`;
// this asks for `roundup8(total + 1)` bytes at 8-byte alignment instead. That
// is ABI-invisible (the returned `* u8` still points at `total` bytes + a NUL)
// but required: the seed cannot lower a direct single-byte `* u8` store, so
// the trailing NUL is written with the word read-modify-write `_num_put_byte`,
// which must stay inside an 8-aligned allocation whose capacity is a multiple
// of 8 (the `ownedbuf.sfn` word-load discipline) to avoid an over-read past
// the page tip.
fn sfn_str_concat(a_data: * u8, a_len: i64, b_data: * u8, b_len: i64, arena_slot: * u8) -> SfnString {
    let mut alen: i64 = a_len;
    if alen < 0 { alen = 0; }
    let mut blen: i64 = b_len;
    if blen < 0 { blen = 0; }
    _sfn_check_concat_limit(alen, blen);
    let total: i64 = alen + blen;
    // i64 overflow guard (mirrors the C `alen > SIZE_MAX - blen` arm).
    if total < alen {
        let overflow: string = "";
        return overflow;
    }

    let arena: * u8 = _sfn_resolve_arena(arena_slot);
    let cap: i64 = ((total + 1 + 7) / 8) * 8;
    let data: * u8 = sfn_arena_alloc(arena, cap as usize, 8 as usize);
    if (data as i64) == 0 {
        let empty: string = "";
        return empty;
    }

    // `alen` / `blen` are already the UTF-8 byte widths the caller computed.
    if alen > 0 {
        if (a_data as i64) != 0 { memcpy(data, a_data, alen as usize); }
    }
    if blen > 0 {
        if (b_data as i64) != 0 {
            memcpy((data as i64 + alen) as * u8, b_data, blen as usize);
        }
    }
    _num_put_byte(data as i64 + total, 0);
    return data;
}

// `sfn_str_append(dst, suffix, arena_slot)` — grow `dst` in place (or relocate)
// to hold `dst.len + suffix.len` bytes via the arena's grow-if-at-tip realloc,
// memcpy the suffix at the tail, NUL-terminate, and write
// the updated `{data, len}` back through `dst` (a `SfnString *`). No emission
// site targets this (`native_signature: null` at `runtime_helpers.sfn`); it is
// ported for link-completeness, sharing concat's arena / limit machinery. The
// `dst` fields are read/written through the `{data@0, len@8}` layout with the
// `atomic_load` / `atomic_store` word discipline the runtime uses for `* T`
// field access under the seed. A null `dst.data` has no real buffer to grow,
// so the body no-ops (the C body's guard).
fn sfn_str_append(dst: * u8, suffix_data: * u8, suffix_len: i64, arena_slot: * u8) -> void {
    if (dst as i64) == 0 { return; }
    if suffix_len <= 0 { return; }
    if (suffix_data as i64) == 0 { return; }

    let data_slot: * i64 = dst as * i64;
    let len_slot: * i64 = (dst as i64 + 8) as * i64;
    let old_data: i64 = atomic_load(data_slot);
    let old_len: i64 = atomic_load(len_slot);
    if old_data == 0 { return; }

    let mut olen: i64 = old_len;
    if olen < 0 { olen = 0; }
    let mut slen: i64 = suffix_len;
    if slen < 0 { slen = 0; }
    _sfn_check_concat_limit(olen, slen);
    let new_len: i64 = olen + slen;
    if new_len < olen { return; }

    let arena: * u8 = _sfn_resolve_arena(arena_slot);
    let new_cap: i64 = ((new_len + 1 + 7) / 8) * 8;
    let grown: * u8 = sfn_arena_realloc(arena, old_data as * u8, (olen + 1) as usize, new_cap as usize, 8 as usize);
    if (grown as i64) == 0 { return; }

    if slen > 0 {
        if (suffix_data as i64) != 0 {
            memcpy((grown as i64 + olen) as * u8, suffix_data, slen as usize);
        }
    }
    _num_put_byte(grown as i64 + new_len, 0);
    atomic_store(data_slot, grown as i64);
    atomic_store(len_slot, new_len);
}

// #1315 (C4 of epic #1308) — real Sailfin accessor bodies.
//
// The bare names below ARE the emission targets (the C defs in
// `sailfin_runtime.c` are now `static`); the `sfn_str_sfn_*` proof-of-life
// infix wrappers they replace are retired (mirroring #1314's number/int
// flip). Each body owns its control flow in Sailfin and calls the two
// narrow C bridges (`sfn_str_read_byte` / `sfn_str_grapheme_byte`) only for
// the operations the seed cannot express in Sailfin today: a single-byte
// `* u8` load and the platform-gated grapheme production. Behaviour is
// byte-identical to the prior C trampolines — including the bootstrap "treat
// each UTF-8 byte as a grapheme" simplification and the first-byte
// `codepoint` for multi-byte sequences. These bridges retire with the
// SfnString aggregate flip (#1283). The immediate-codepoint decode bridge is
// already gone: the `(byte << 32)` encoding is retired (#1420/#822).
//
// `codepoint` / `grapheme_count` return `f64`, not `i64`: their registry
// rows (`runtime_helpers.sfn:617,993`) keep a `double` C-ABI return + a
// `round + fptosi` coercion at the call site. Returning `f64` preserves
// that ABI byte-for-byte, so no registry edit and no seed cut are needed.
// `sfn_str_grapheme_count(s)` — grapheme count of `s`. Bootstrap
// simplification: the UTF-8 byte length (one byte == one grapheme),
// exactly as the legacy walker computed.
fn sfn_str_grapheme_count(s: * u8) -> f64 {
    let len: i64 = strnlen(s, 16777216) as i64;
    return len as f64;
}

// `sfn_str_grapheme_count_lv(s_data, s_len)` — #1704: length-aware (`_lv`)
// grapheme count over the aggregate. Bootstrap simplification (one byte == one
// grapheme) reads the carried `s_len` instead of NUL-scanning, so a
// non-terminated interior view (#1454) counts only its own bytes. The bare
// `sfn_str_grapheme_count` stays the old `(i8*)`/`double` ABI symbol the seed
// emits; the repointed descriptor (`runtime_grapheme_count_fn`) targets this one.
fn sfn_str_grapheme_count_lv(s_data: * u8, s_len: i64) -> f64 {
    if s_len < 0 { return 0.0; }
    return s_len as f64;
}

// `sfn_str_grapheme_at(s, idx)` — the `idx`-th grapheme of `s`, produced as a
// 1-byte string by the platform-gated `sfn_str_grapheme_byte` bridge.
// Out-of-range or non-integral indices yield the empty string. The
// `string_length` guard bounds the `grapheme_byte` dereference (a corrupted
// pointer scans to length 0).
fn sfn_str_grapheme_at(s: * u8, idx: f64) -> * u8 {
    if (s as i64) == 0 { return sfn_str_from_byte(0); }
    let iidx: i64 = idx as i64;
    if (iidx as f64) != idx { return sfn_str_from_byte(0); }
    if iidx < 0 { return sfn_str_from_byte(0); }
    let len: i64 = strnlen(s, 16777216) as i64;
    if len <= 0 { return sfn_str_from_byte(0); }
    if iidx >= len { return sfn_str_from_byte(0); }
    return sfn_str_grapheme_byte(s, iidx);
}

// `sfn_str_grapheme_at_lv(s_data, s_len, idx)` — #1704: length-aware (`_lv`)
// grapheme accessor over the aggregate. Bounds `idx` against the carried
// `s_len` (bootstrap: one byte == one grapheme) instead of NUL-scanning, so a
// non-terminated interior view (#1454) cannot index past its bytes. The bare
// `sfn_str_grapheme_at` stays the old `(i8*, double)` ABI symbol the seed emits
// via its descriptor; the repointed descriptor targets this `_lv` symbol.
fn sfn_str_grapheme_at_lv(s_data: * u8, s_len: i64, idx: f64) -> * u8 {
    if (s_data as i64) == 0 { return sfn_str_from_byte(0); }
    let iidx: i64 = idx as i64;
    if (iidx as f64) != idx { return sfn_str_from_byte(0); }
    if iidx < 0 { return sfn_str_from_byte(0); }
    if s_len <= 0 { return sfn_str_from_byte(0); }
    if iidx >= s_len { return sfn_str_from_byte(0); }
    return sfn_str_grapheme_byte(s_data, iidx);
}

// `sfn_str_byte_at(s_data, s_len, idx)` — #1704: raw byte at offset `idx`, or -1
// string / out-of-range index. Length-aware: bounds `idx` against the carried
// `s_len` instead of NUL-scanning, then reads the byte via `sfn_str_read_byte`.
// Runtime-internal (no descriptor, no caller today); re-signatured in place so
// a non-terminated interior view (#1454) cannot read past its bytes.
fn sfn_str_byte_at(s_data: * u8, s_len: i64, idx: i64) -> i64 {
    if (s_data as i64) == 0 { return -1; }
    if idx < 0 { return -1; }
    if idx >= s_len { return -1; }
    return sfn_str_read_byte(s_data, idx);
}

// `sfn_str_find_byte(s_data, s_len, byte_value, start)` — #1704: first offset
// >= `start` at which `byte_value` (low 8 bits) occurs within the carried
// `s_len`, or -1. Length-aware forward scan (no NUL-scan); a negative `start`
// clamps to 0. Runtime-internal (no descriptor, no caller today); re-signatured
// in place so a non-terminated interior view (#1454) cannot scan past its bytes.
fn sfn_str_find_byte(s_data: * u8, s_len: i64, byte_value: i64, start_index: i64) -> i64 {
    if (s_data as i64) == 0 { return -1; }
    let mut start: i64 = start_index;
    if start < 0 { start = 0; }
    if start >= s_len { return -1; }
    let target: i64 = byte_value & 255;
    let mut i: i64 = start;
    loop {
        if i >= s_len { break; }
        if sfn_str_read_byte(s_data, i) == target { return i; }
        i = i + 1;
    }
    return -1;
}

// `sfn_str_codepoint(s)` — first codepoint of `s`, or -1 for a null/empty
// string. Preserves the legacy `char_code` semantics exactly: returns the
// first byte of the string (the documented bootstrap simplification for
// multi-byte sequences). With the immediate-codepoint encoding retired
// (#1420/#822), `s` is always a real pointer.
fn sfn_str_codepoint(s: * u8) -> f64 {
    if (s as i64) == 0 { return -1.0; }
    let len: i64 = strnlen(s, 16777216) as i64;
    if len <= 0 { return -1.0; }
    return sfn_str_read_byte(s, 0) as f64;
}

// `sfn_str_codepoint_lv(s_data, s_len)` — #1704: length-aware (`_lv`) first
// codepoint over the aggregate. Empty is gated by the carried `s_len` instead
// of a NUL-scan; returns the first byte (the bootstrap simplification for
// multi-byte sequences), or -1 for a null/empty view. The bare `sfn_str_codepoint`
// stays the old `(i8*)`/`double` ABI symbol the seed emits; the repointed
// descriptor (`runtime_char_code_fn`) targets this `_lv` symbol.
fn sfn_str_codepoint_lv(s_data: * u8, s_len: i64) -> f64 {
    if (s_data as i64) == 0 { return -1.0; }
    if s_len <= 0 { return -1.0; }
    return sfn_str_read_byte(s_data, 0) as f64;
}

// `sfn_str_sfn_from_codepoint(cp)` — 1-4 byte UTF-8 encode of
// `cp`. Architect spec allocates into the supplied arena and
// returns the SfnString aggregate; today's body trampolines
// through the C wave-2 entrypoint which `malloc`s a fresh
// NUL-terminated buffer (no arena threading yet at the Sailfin
// call surface). Invalid codepoints (negative, > U+10FFFF, or
// in the UTF-16 surrogate range) produce an empty string per
// the C body's invariant.
fn sfn_str_sfn_from_codepoint(cp: i64) -> * u8 {
    return sfn_str_from_codepoint(cp);
}

// `sfn_str_sfn_from_byte(byte_value)` — raw single-byte string build
// (#874). Proof-of-life Sailfin trampoline following the
// `from_codepoint` discipline: today's body forwards to the C wave-2
// entrypoint `sfn_str_from_byte` (which `malloc`s the 1-byte
// NUL-terminated buffer), because the Sailfin call surface can't thread
// an arena yet (M1.A.2). The prelude's `char_from_code` wraps this and
// casts the `* u8` result to `string`. Byte 0 and out-of-range values
// yield the empty string — see the C body for the NUL-termination
// limitation deferred to the SfnString aggregate flip.
fn sfn_str_sfn_from_byte(byte_value: i64) -> * u8 {
    return sfn_str_from_byte(byte_value);
}

// `sfn_str_to_number(s)` — #1372: the real Sailfin body for the
// `string.to_number` emission target (the C `sfn_str_to_number` def is
// now `static`). With the immediate-codepoint encoding retired (#1420/#822),
// `s` is always a real, deref-safe pointer, so `strtod` parses the
// NUL-terminated payload directly (`endptr` discarded via `null`). Null
// yields `0.0`.
fn sfn_str_to_number(s: * u8) -> f64 {
    if (s as i64) == 0 { return 0.0; }
    return strtod(s, null);
}

// `sfn_str_to_number_lv(s_data, s_len)` — #1722 (M2.4b, SFEP-0025 §3.3): the
// length-aware `string.to_number` over the `{i8*, i64}` SfnString aggregate.
// `strtod` cannot be length-bounded directly — it scans to a NUL — so the body
// mirrors the #1705 `sfn_str_to_cstr` boundary copy: copy the carried `s_len`
// bytes + a trailing NUL into the process-global arena and `strtod` the copy.
// A non-NUL-terminated interior view (`{data+start, end-start}`, #1454) then
// parses ONLY its bytes and never over-reads into the source tail. The carried
// length is the aggregate field, never a NUL scan — scanning a non-terminated
// view is exactly the over-read this fixes. The null/empty fast path is
// preserved so numeric results stay byte-identical to `sfn_str_to_number`
// for NUL-terminated inputs. The bare body above is retained
// as the old-`i8*` ABI trampoline for the pinned seed during `make compile`; the
// `string.to_number` descriptor's `native_signature` resolves freshly-emitted IR
// to this `_lv` symbol. The `roundup8(s_len + 1)` 8-aligned alloc + `_num_put_byte`
// trailing NUL keeps the word read-modify-write in-bounds (the seed cannot lower a
// single-byte `* u8` store), the same discipline `sfn_str_to_cstr` / `sfn_str_concat`
// use.
fn sfn_str_to_number_lv(s_data: * u8, s_len: i64) -> f64 {
    if (s_data as i64) == 0 { return 0.0; }
    let mut n: i64 = s_len;
    if n < 0 { n = 0; }
    if n == 0 { return 0.0; }
    let arena: * u8 = sfn_arena_global();
    let cap: i64 = ((n + 1 + 7) / 8) * 8;
    let data: * u8 = sfn_arena_alloc(arena, cap as usize, 8 as usize);
    if (data as i64) == 0 { return 0.0; }
    memcpy(data, s_data, n as usize);
    _num_put_byte(data as i64 + n, 0);
    return strtod(data, null);
}

// ====================================================================
// Number / int formatting — real hand-rolled Sailfin bodies (#1314, C3
// of epic #1308). The bare `sfn_int_to_str` / `sfn_number_to_str`
// (emission targets, formerly C trampolines in `sailfin_runtime.c`,
// now `static`) are defined here in Sailfin; the linker binds every
// fresh emission to these bodies. The bare names ARE the real bodies —
// the proof-of-life `sfn_number_to_str_sfn` / `sfn_int_to_str_sfn` infix
// wrappers are retired (the migration they marked is complete), and the
// `f64` call-resolution gap (see `sfn_number_to_str` below) makes an
// `f64`-forwarding infix unrepresentable under the seed anyway.
//
// Byte assembly. Like `ownedbuf.sfn`, the seed compiler does not lower
// a direct single-byte store through a `* u8` slot, so digits are
// written via read-modify-write of the enclosing 8-aligned i64 word
// (`atomic_load` + clear-the-byte + `atomic_store`). The result is
// allocated through the process-global arena when arena mode is on
// (gated on `sfn_arena_enabled()`, the discipline `concat` follows),
// else libc storage; a 64-byte buffer covers every worst case (sci
// "-1.23456789012346e-308" = 22 bytes + NUL; fixed "-0.000<15 digits>"
// ≈ 22 bytes + NUL). The buffer is NUL-terminated so the `* u8`
// C-string consumers (`sailfin_runtime_string_length`, etc.) recover
// the length by scan.
//
// Float formatting reproduces libc `%.15g`: P=15 significant digits;
// fixed (`%f`) style when the decimal exponent X satisfies
// -4 <= X < 15, else scientific (`d.ddde±NN`, exponent >= 2 digits with
// sign); trailing zeros and a bare trailing point stripped. Integer-
// valued doubles below 1e15 take an exact i64 fast path (no rounding) —
// this covers the self-host hot path (`%t` temp-name emission) bit-for-
// bit. The general path scales `m * 10^(14 - X)` and rounds; for the
// fixed range that is a single exact power-of-ten multiply (10^k,
// k <= 22, is exact in f64), so rounding is correct there. Correctness
// ceiling (documented, out of the suite): values landing exactly on a
// half-ulp tie at the 15th significant digit round half-up rather than
// libc's half-to-even; extreme subnormals (|X| > ~300) and -0.0 (prints
// "0") may diverge. A bignum dtoa (Ryu/Dragon) is post-1.0 if exactness
// for those is ever required.
// `_num_put_byte(addr, value)` writes the low byte of `value` at byte
// address `addr` via read-modify-write of the enclosing i64 word.
// `word - (word & mask)` clears the target byte without a bitwise NOT
// (the seed-unverified `~`, avoided per the arena module); the new byte
// ORs in (the cleared bits make `+` equivalent to `|`). The enclosing
// word is always in-bounds: every backing allocation is 8-aligned with
// a capacity that is a multiple of 8 (`owned_buf_new` discipline).
fn _num_put_byte(addr: i64, value: i64) -> void {
    let word_addr: i64 = (addr / 8) * 8;
    let shift: i64 = (addr - word_addr) * 8;
    let slot: * i64 = word_addr as * i64;
    let word: i64 = atomic_load(slot);
    let mask: i64 = 255 << shift;
    let current: i64 = word & mask;
    let placed: i64 = (value & 255) << shift;
    atomic_store(slot, (word - current) + placed);
}

// `_num_emit_char(base, pos, ch)` writes one byte and returns the next
// position.
fn _num_emit_char(base: i64, pos: i64, ch: i64) -> i64 {
    _num_put_byte(base + pos, ch);
    return pos + 1;
}

// `_num_finish(base, pos)` NUL-terminates and returns the buffer base
// as a `* u8` C-string.
fn _num_finish(base: i64, pos: i64) -> * u8 {
    _num_put_byte(base + pos, 0);
    return base as * u8;
}

// `_num_pow10_i64(k)` — 10^k as i64 for k in [0, 18] (fits i64).
fn _num_pow10_i64(k: i64) -> i64 {
    let mut r: i64 = 1;
    let mut i: i64 = 0;
    loop {
        if i >= k { break; }
        r = r * 10;
        i = i + 1;
    }
    return r;
}

// `_num_count_digits(value)` — decimal digit count of a non-negative
// i64 (0 has one digit).
fn _num_count_digits(value: i64) -> i64 {
    if value == 0 { return 1; }
    let mut n: i64 = 0;
    let mut v: i64 = value;
    loop {
        if v == 0 { break; }
        v = v / 10;
        n = n + 1;
    }
    return n;
}

// `_num_emit_uint(base, pos, value, min_digits)` writes `value` (>= 0)
// most-significant digit first, zero-padded to at least `min_digits`.
// Returns the next position.
fn _num_emit_uint(base: i64, pos: i64, value: i64, min_digits: i64) -> i64 {
    let mut width: i64 = _num_count_digits(value);
    if min_digits > width { width = min_digits; }
    let mut divisor: i64 = _num_pow10_i64(width - 1);
    let mut p: i64 = pos;
    let mut i: i64 = 0;
    loop {
        if i >= width { break; }
        let digit: i64 = (value / divisor) % 10;
        p = _num_emit_char(base, p, 48 + digit);
        divisor = divisor / 10;
        i = i + 1;
    }
    return p;
}

// `_num_emit_int_cstr(base, value)` formats a signed i64 as decimal text
// (optional `-`, digits most-significant-first, trailing NUL) into the
// 8-aligned scratch buffer at `base`, returning the byte length (NUL
// excluded). It is the batched-store fast path for the two integer
// hot paths (`sfn_int_to_str` and the exact-integer arm of
// `sfn_number_to_str`).
//
// Perf (#1511): the per-byte emitters (`_num_emit_char` /
// `_num_emit_uint` → `_num_put_byte`) pay a seq_cst `atomic_load` +
// `atomic_store` for *every* digit, so a 6-digit format costs ~7 full
// memory barriers. This emitter instead streams output bytes into one
// i64 accumulator and flushes a whole 8-byte word with a single
// `atomic_store` each time the accumulator fills (and once more at the
// end) — ~1 barrier per 8 bytes, and no read-back at all. The read is
// unnecessary because the scratch buffer is 8-aligned with a capacity
// that is a multiple of 8 (`owned_buf_new` discipline) and every byte of
// each word is authored sequentially from offset 0: the store overwrites
// all 8 bytes, and the unwritten high bytes are zero, so the trailing
// NUL and word padding are emitted for free.
//
// INT64_MIN is safe without a magnitude (whose positive has no i64
// form): digit extraction stays in the operand's own sign domain
// (`value / divisor` and `% 10` truncate toward zero; negative
// remainders are negated per digit). Any i64 has at most 19 digits, so
// the leading divisor `10^(nd-1)` never exceeds `10^18`, which is
// i64-representable.
fn _num_emit_int_cstr(base: i64, value: i64) -> i64 {
    let mut neg: bool = false;
    if value < 0 { neg = true; }
    let nd: i64 = _num_count_digits(value);
    let mut total: i64 = nd;
    if neg { total = total + 1; }

    let mut word_acc: i64 = 0;
    let mut word_off: i64 = 0;
    let mut k: i64 = 0;

    if neg {
        word_acc = word_acc + (45 << ((k & 7) * 8));
        k = k + 1;
    }

    let mut divisor: i64 = _num_pow10_i64(nd - 1);
    let mut di: i64 = 0;
    loop {
        if di >= nd { break; }
        let mut d: i64 = (value / divisor) % 10;
        if d < 0 { d = 0 - d; }
        word_acc = word_acc + ((48 + d) << ((k & 7) * 8));
        k = k + 1;
        if (k & 7) == 0 {
            let slot: * i64 = (base + word_off) as * i64;
            atomic_store(slot, word_acc);
            word_off = word_off + 8;
            word_acc = 0;
        }
        divisor = divisor / 10;
        di = di + 1;
    }

    // Flush the word holding the final digits and the NUL terminator.
    // The NUL at position `total` is the zero high byte already present
    // in `word_acc`; any bytes past it are zero padding inside the owned
    // scratch buffer, so a single full-word store completes the string.
    let slot2: * i64 = (base + word_off) as * i64;
    atomic_store(slot2, word_acc);
    return total;
}

// `sfn_number_to_str(value)` — the bare emission target (#1314), render
// `value` as a `%.15g`-style decimal string into arena/libc storage. See
// the family comment above for the algorithm and its correctness ceiling.
//
// The whole float pipeline (exponent walk + 15-digit scaling) is inlined
// here rather than split into helpers: an UNregistered internal Sailfin
// function taking/returning `f64` mis-resolves under the seed — its call
// site defaults the `f64` to `i8*` and coerces the argument through
// `sfn_number_to_str` (visible in the seed's emission of the
// `sfn_str_sfn_slice` proof-of-life wrapper). `sfn_number_to_str` itself
// resolves correctly because it carries a runtime-helper descriptor
// (`number.to_string` → `["double"]`); the i64-only helpers it calls
// (`_num_emit_*`, `_num_pow10_i64`) resolve fine. Keeping every `f64`
// inside this one descriptor-backed body sidesteps the gap.
fn sfn_number_to_str(value: f64) -> * u8 {
    let mut arena_addr: i64 = 0;
    if sfn_arena_enabled() { arena_addr = sfn_arena_global() as i64; }
    let buf: OwnedBuf = owned_buf_new(arena_addr, 64);
    let base: i64 = buf.ptr_addr;
    if base == 0 { return null; }
    let mut pos: i64 = 0;

    // NaN (libc prints "nan").
    if value != value {
        pos = _num_emit_char(base, pos, 110);
        pos = _num_emit_char(base, pos, 97);
        pos = _num_emit_char(base, pos, 110);
        return _num_finish(base, pos);
    }

    let mut neg: bool = false;
    let mut m: f64 = value;
    if value < 0.0 {
        neg = true;
        m = 0.0 - value;
    }

    // Infinity (libc prints "inf" / "-inf"). NaN is already handled, so
    // `m - m` is 0 for every finite m and NaN (!= 0) only for +inf.
    if (m - m) != 0.0 {
        if neg { pos = _num_emit_char(base, pos, 45); }
        pos = _num_emit_char(base, pos, 105);
        pos = _num_emit_char(base, pos, 110);
        pos = _num_emit_char(base, pos, 102);
        return _num_finish(base, pos);
    }

    // Zero (covers -0.0 -> "0", a documented divergence from libc's "-0").
    if m == 0.0 {
        pos = _num_emit_char(base, pos, 48);
        return _num_finish(base, pos);
    }

    // Exact integer fast path: integer-valued magnitudes below 1e15
    // format as plain integers (no rounding) — the self-host hot path.
    if m < 1000000000000000.0 {
        let ip: i64 = m as i64;
        if (ip as f64) == m {
            // `ip` is the non-negative magnitude (m = |value|); restore
            // the sign and emit via the batched whole-word fast path.
            let mut signed_ip: i64 = ip;
            if neg { signed_ip = 0 - ip; }
            let _len: i64 = _num_emit_int_cstr(base, signed_ip);
            return base as * u8;
        }
    }

    // ---- General 15-significant-digit path ----
    // Exponent estimate X = floor(log10(m)) via a power-of-ten walk. Any
    // one-ulp boundary error is corrected by the normalization loop below.
    // Powers overflow to +inf past ~1e308, terminating each walk.
    let mut x_exp: i64 = 0;
    if m >= 1.0 {
        loop {
            // p = 10^(x_exp + 1), recomputed inline.
            let target: i64 = x_exp + 1;
            let mut p: f64 = 1.0;
            let mut j: i64 = 0;
            loop {
                if j >= target { break; }
                p = p * 10.0;
                j = j + 1;
            }
            if m >= p { x_exp = x_exp + 1; } else { break; }
        }
    } else {
        loop {
            // p = 10^(-x_exp); `m * p >= 1.0` iff `m >= 10^x_exp`.
            let nx: i64 = 0 - x_exp;
            let mut p: f64 = 1.0;
            let mut j: i64 = 0;
            loop {
                if j >= nx { break; }
                p = p * 10.0;
                j = j + 1;
            }
            if m * p >= 1.0 { break; }
            x_exp = x_exp - 1;
        }
    }

    // 10^18 chunk constant (exact in f64; reused by the scaling below).
    let mut chunk: f64 = 1.0;
    let mut ci: i64 = 0;
    loop {
        if ci >= 18 { break; }
        chunk = chunk * 10.0;
        ci = ci + 1;
    }

    // Scale to a 15-digit significant integer D = round(m * 10^(14 - X)),
    // normalizing X so D lands in [1e14, 1e15). The scale factor is one
    // exact 10^kk multiply when |14 - X| <= 18 (the whole fixed-form
    // range, so rounding is correct there), chunked by the exact 10^18
    // otherwise. Round-half-up is the documented tie ceiling. `guard`
    // bounds the normalization (1-2 corrections suffice) so extreme
    // subnormals cannot loop forever.
    let mut d15: i64 = 0;
    let mut guard: i64 = 0;
    loop {
        let k: i64 = 14 - x_exp;
        let mut r: f64 = m;
        if k >= 0 {
            let mut kk: i64 = k;
            loop {
                if kk < 18 { break; }
                r = r * chunk;
                kk = kk - 18;
            }
            let mut p: f64 = 1.0;
            let mut j: i64 = 0;
            loop {
                if j >= kk { break; }
                p = p * 10.0;
                j = j + 1;
            }
            r = r * p;
        } else {
            let mut kk: i64 = 0 - k;
            loop {
                if kk < 18 { break; }
                r = r / chunk;
                kk = kk - 18;
            }
            let mut p: f64 = 1.0;
            let mut j: i64 = 0;
            loop {
                if j >= kk { break; }
                p = p * 10.0;
                j = j + 1;
            }
            r = r / p;
        }
        d15 = (r + 0.5) as i64;

        if guard >= 5 { break; }
        guard = guard + 1;
        if d15 < 100000000000000 { x_exp = x_exp - 1; } else if d15 >= 1000000000000000 {
            x_exp = x_exp + 1;
        } else { break; }
    }

    // Strip trailing zeros from the 15-digit significant integer.
    let mut s: i64 = 15;
    loop {
        if d15 % 10 != 0 { break; }
        d15 = d15 / 10;
        s = s - 1;
    }

    if neg { pos = _num_emit_char(base, pos, 45); }

    if x_exp >= -4 {
        if x_exp < 15 {
            // Fixed (`%f`) form.
            if x_exp >= 0 {
                let intlen: i64 = x_exp + 1;
                if s <= intlen {
                    pos = _num_emit_uint(base, pos, d15, s);
                    let mut zpad: i64 = intlen - s;
                    loop {
                        if zpad <= 0 { break; }
                        pos = _num_emit_char(base, pos, 48);
                        zpad = zpad - 1;
                    }
                } else {
                    let fracdigits: i64 = s - intlen;
                    let pdiv: i64 = _num_pow10_i64(fracdigits);
                    let high: i64 = d15 / pdiv;
                    let low: i64 = d15 % pdiv;
                    pos = _num_emit_uint(base, pos, high, intlen);
                    pos = _num_emit_char(base, pos, 46);
                    pos = _num_emit_uint(base, pos, low, fracdigits);
                }
            } else {
                pos = _num_emit_char(base, pos, 48);
                pos = _num_emit_char(base, pos, 46);
                let mut lz: i64 = (0 - x_exp) - 1;
                loop {
                    if lz <= 0 { break; }
                    pos = _num_emit_char(base, pos, 48);
                    lz = lz - 1;
                }
                pos = _num_emit_uint(base, pos, d15, s);
            }
            return _num_finish(base, pos);
        }
    }

    // Scientific (`d.ddde±NN`) form.
    let lead_div: i64 = _num_pow10_i64(s - 1);
    let lead: i64 = d15 / lead_div;
    let rest: i64 = d15 % lead_div;
    pos = _num_emit_uint(base, pos, lead, 1);
    if s > 1 {
        pos = _num_emit_char(base, pos, 46);
        pos = _num_emit_uint(base, pos, rest, s - 1);
    }
    pos = _num_emit_char(base, pos, 101);
    if x_exp >= 0 { pos = _num_emit_char(base, pos, 43); } else {
        pos = _num_emit_char(base, pos, 45);
    }
    let mut absx: i64 = x_exp;
    if absx < 0 { absx = 0 - absx; }
    pos = _num_emit_uint(base, pos, absx, 2);
    return _num_finish(base, pos);
}

// `sfn_int_to_str(value)` — the bare emission target (#1314), decimal i64
// formatting into arena/libc storage. Digit extraction runs in the
// negative domain so INT64_MIN (whose positive has no i64 representation)
// formats without overflow: `value % 10` / `value / 10` truncate toward
// zero, yielding negative remainders that are negated per digit. All
// parameters/locals are i64, so the seed resolves the call surface
// correctly (the `f64` mis-resolution that forced `sfn_number_to_str` to
// inline its helpers does not apply here).
fn sfn_int_to_str(value: i64) -> * u8 {
    let mut arena_addr: i64 = 0;
    if sfn_arena_enabled() { arena_addr = sfn_arena_global() as i64; }
    let buf: OwnedBuf = owned_buf_new(arena_addr, 32);
    let base: i64 = buf.ptr_addr;
    if base == 0 { return null; }

    // Batched whole-word emit (#1511): one `atomic_store` per 8 bytes
    // instead of a per-digit read-modify-write. `_num_emit_int_cstr`
    // handles the zero case, the sign, and the NUL terminator.
    let _len: i64 = _num_emit_int_cstr(base, value);
    return base as * u8;
}

// #925 (sub-issue of #390): Cat-C char-predicate ports. The legacy C
// bodies (`sailfin_runtime_is_alpha_char` / `_is_decimal_digit` /
// `_is_whitespace_char`) took a `double` codepoint; the runtime-helper
// descriptor ABI is `(i8) -> i1`, so these bare `sfn_str_is_*` bodies
// take a `u8` byte (lowers to LLVM `i8`) and widen to `i64` for the
// range comparisons. ASCII semantics preserved byte-for-byte. Nested
// `if` accumulators (not `&&`) match the self-host-safe idiom used
// across the runtime/sfn modules.
fn sfn_str_is_digit(ch: u8) -> bool {
    let c: i64 = ch as i64;
    let mut result: bool = false;
    if c >= 48 {
        if c <= 57 { result = true; }
    }
    return result;
}

fn sfn_str_is_whitespace(ch: u8) -> bool {
    let c: i64 = ch as i64;
    let mut result: bool = false;
    if c == 32 { result = true; }
    if c == 9 { result = true; }
    if c == 10 { result = true; }
    if c == 13 { result = true; }
    return result;
}

fn sfn_str_is_alpha(ch: u8) -> bool {
    let c: i64 = ch as i64;
    let mut result: bool = false;
    if c >= 97 {
        if c <= 122 { result = true; }
    }
    if c >= 65 {
        if c <= 90 { result = true; }
    }
    return result;
}

// #925: `sfn_to_debug_string(value)` — identity port of the C
// `sailfin_runtime_to_debug_string`, which returns its argument
// unchanged (debug rendering is value-side type tagging, deferred).
// Descriptor ABI is `(i8*) -> i8*`.
fn sfn_to_debug_string(value: * u8) -> * u8 { return value; }
