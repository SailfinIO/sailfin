// runtime/sfn/string.sfn
//
// First wave of Sailfin-native `SfnString` operations (M2.4a, #396).
// The module pins the future shape of the five non-allocating
// `sfn_str_*` helpers — `len`, `eq`, `slice`, `to_cstr`,
// `from_cstr` — and ships into the compiler binary alongside the
// C runtime so the migration footprint is visible at link time.
//
// Status: trampoline bodies. The architect plan in
// `docs/runtime_architecture.md` §2.2 specifies these helpers
// against the SfnString aggregate (`{i8*, i64}` by value) so
// `sfn_str_len` is a single field load and `sfn_str_eq` is a length
// compare + `memcmp`. Today's Sailfin frontend lowers `string` to
// `i8*` for parameters/locals (M1.A only locked the literal/aggregate
// shape, not the type-mapping flip slated for M1.A.2), so these
// bodies still bridge through the legacy NUL-terminated C
// entrypoints. The function *names* are the migration unit — once
// M1.A.2 lands the bodies can be rewritten in-place over the
// aggregate shape without touching any caller.
//
// Naming: every export uses the `sfn_str_sfn_*` infix so the
// Sailfin module coexists with the C runtime's matching
// `sfn_str_*` exports without a link-time collision (mirrors the
// arena module's `sfn_arena_sfn_*` infix; see
// `runtime/sfn/memory/arena.sfn` for the same rationale). The
// canonical user-facing names — the ones the new compiler emits
// `call`s against — are `sfn_str_*` (no infix), provided by the C
// trampolines in `runtime/native/src/sailfin_runtime.c`. This
// module's exports are presence-only proof of life today and the
// migration unit for M2.4b: when the aggregate-typed parameter
// flip lands, the C trampolines retire and these `_sfn_` names
// rename to the bare canonical form in a single rollback-safe PR.
//
// Effects: none. String primitives live below the I/O layer (same
// discipline as `runtime/sfn/memory/arena.sfn`). The `![io]`
// annotations attach to *adapters* that wrap these primitives,
// never to the primitives themselves.
//
// #1289 / #1283 Gap 1: `OwnedBuf` and its grow-at-tip constructor /
// append (`owned_buf_new` / `owned_buf_append`) come from the canonical
// `./memory/ownedbuf` module rather than being inlined here. The inline
// copy #1217 (Phase R1) shipped existed only because the
// runtime-sfn-source emit path could not resolve a cross-module
// struct-returning call — the `OwnedBuf` aggregate return died at
// `core_call_emission.sfn` with `cannot resolve return type for call
// to …` (an inline `extern fn` can't carry the struct either — C-ABI
// only, E0805). #1288 taught `_compile_runtime_sfn_sources` to stage
// sibling runtime modules' `.sfn-asm` into the import-context the
// lowering consults, so the call now resolves; with a seed containing
// #1288 pinned, this consumer collapses the duplication. `concat` /
// `append` therefore route growth through `ownedbuf.sfn`'s arena
// externs (`sfn_arena_sfn_*`); `ownedbuf.sfn` and `arena.sfn` are
// linked alongside this module via `runtime/native/capsule.toml`'s
// `sfn-sources`.
import { OwnedBuf, owned_buf_new, owned_buf_append } from "./memory/ownedbuf";

// Why inline the libc externs? The same reason `arena.sfn` does:
// the released seed compiler snapshots `runtime/sfn/platform/libc.sfn`
// at build time. Inlining keeps this module self-contained for
// every seed, regardless of which libc declarations have shipped.
// Once the seed catches up, a follow-up PR can flip these to a
// cross-module import without touching the bodies.
extern fn memcmp(a: * u8, b: * u8, n: usize) -> i32;

extern fn memchr(s: * u8, c: i32, n: usize) -> * u8;

// #1372: bounded length scan (16 MiB cap) for `sfn_str_len`/`sfn_str_eq`.
extern fn strnlen(s: * u8, n: usize) -> usize;

// M2.5 (#403): `strtod` powers the real Sailfin `sfn_str_to_number`
// body below (#1372) — the architect spec calls for a
// stack-buffered NUL-terminated copy of an SfnString followed by
// `strtod` parsing. Today's `* u8` payload is already
// NUL-terminated (literal lowering + arena-routed concat preserve
// the +1 byte), so the wrapper passes the data pointer straight
// through and discards the endptr by passing `null`.
extern fn strtod(nptr: * u8, endptr: * * u8) -> f64;

// Trampolines into the legacy C runtime. M2.4b (the concat/append
// wave gated on #328 drop emission) replaces these with native
// arena-backed Sailfin bodies; until then the C bodies do the
// allocation work and these wrappers exist only to give this
// module a legal Sailfin call surface for its proof-of-life
// emission.
extern fn sailfin_runtime_string_length(s: * u8) -> i64;

// #1372: i64-indexed substring entrypoint for `sfn_str_slice`. NOT the
// `substring_unchecked` C wrapper — that is a registry target whose
// `native_signature` is `sfn_str_slice`, so a Sailfin call to it re-lowers
// to `@sfn_str_slice` (infinite self-recursion). `sailfin_runtime_*` carries
// no registry row, so it lowers to a plain direct call.
extern fn sailfin_runtime_substring_unchecked(text: * u8, start: i64, end: i64) -> * u8;

// M2.4b (#398) + #715: the C-side allocating ops. The Sailfin
// trampolines below preserve the `sfn_str_sfn_*` infix pattern
// (proof-of-life presence under the Sailfin namespace) while the
// canonical `sfn_str_concat` / `sfn_str_append` symbols live on
// the C side (#715 promoted these from their interim `_arena`
// suffix to the bare canonical names). The two `* u8` parameters
// mirror the wave-1a pattern — today's Sailfin frontend can't
// pass / return the SfnString aggregate by value, so the bodies
// bridge through the legacy NUL-terminated concat. The user IR
// emission lands directly on `@sfn_str_concat` (the C entrypoint
// with the new arena-aware ABI); these wrappers are not on the
// hot path.
extern fn sailfin_runtime_string_concat(a: * u8, b: * u8) -> * u8;

extern fn sailfin_runtime_string_append(buf: * u8, suffix: * u8) -> * u8;

// `sailfin_runtime_string_to_number` is the still-C `strtod` boundary
// `to_number` delegates to (allocating-op family — retires in #1318/#822).
// Returns `double` (System V x86_64 `%xmm0`), matched exactly here.
extern fn sailfin_runtime_string_to_number(s: * u8) -> f64;

// #1315 (C4 of epic #1308): the accessor family — `byte_at`/`find_byte`/
// `codepoint`/`grapheme_at`/`grapheme_count` — are now real Sailfin
// bodies below (bare-named emission targets; the C defs are `static`).
// They cannot, under today's seed, single-byte-load a `* u8`, decode the
// immediate-codepoint pseudo-pointer encoding, or reproduce the
// platform-gated grapheme production, so they call these four narrow C
// bridge primitives (`sailfin_runtime.c`). All retire with the
// immediate-encoding deletion (#1283 / #822).
//
// `codepoint`/`grapheme_count` return `f64` (not `i64`): the registry
// rows (`runtime_helpers.sfn:617,993`) expose them to callers as `i64`
// via a `double` C-ABI return + a `round + fptosi` coercion at the call
// site. Returning `f64` here keeps that ABI byte-identical, so no
// registry edit and no seed cut are needed (the seed still emits the
// `double`-coerced call sites).
extern fn sfn_str_decode_owned(s: * u8) -> * u8;

extern fn sfn_str_immediate_codepoint(s: * u8) -> i64;

extern fn sfn_str_read_byte(s: * u8, idx: i64) -> i64;

extern fn sfn_str_grapheme_byte(real: * u8, idx: i64) -> * u8;

extern fn sfn_str_from_codepoint(cp: i64) -> * u8;

// #874: raw single-byte string constructor. Unlike `from_codepoint`
// (UTF-8 encode), this writes the byte value verbatim — the write
// counterpart to the already-working byte read (`char_code(s[i])`).
// Returns a fresh NUL-terminated 1-byte buffer for 1..255; the empty
// string for 0 (unrepresentable under the NUL-terminated model — see
// the C body) and out-of-range values.
extern fn sfn_str_from_byte(byte_value: i64) -> * u8;

// #1217 (Phase R1): the process-global arena `concat` builds into, and
// the arena-mode probe that gates it. `sfn_arena_global()` ALWAYS
// returns a live arena handle — it is NOT null when the arena is
// disabled — so callers must gate on `sfn_arena_enabled()` first (the
// discipline every other runtime module follows, e.g.
// `runtime/sfn/memory/arena.sfn`'s mark/rewind). Under
// `SAILFIN_USE_ARENA=0` (ASAN / diagnostics), `concat` therefore passes
// `arena_addr = 0` and `owned_buf_new` falls back to libc storage. Both
// are C-ABI (`-> * u8` / `-> bool`), so they stay inline externs (same
// discipline as the libc externs above).
extern fn sfn_arena_global() -> * u8;

extern fn sfn_arena_enabled() -> bool;

// #1372: UTF-8 byte length of a validated codepoint — mirrors the
// branch widths of the C `_utf8_encode`. Used to size an immediate-
// codepoint pseudo-pointer's grapheme without materialising it (the
// owning `sfn_str_decode_owned` bridge mallocs per call, which would
// leak unboundedly on the `char_at`-result hot path — see `sfn_str_len`).
// NB: decimal literals (128/2048/65536) deliberately — the seed lexer has no
// `0x` hex support (hex literals silently lower to 0). Decimal is exact and
// portable across seeds; flip to hex once the lexer learns `0x`.
fn _sfn_utf8_byte_len(cp: i64) -> i64 {
    if cp < 128 { return 1; }
    if cp < 2048 { return 2; }
    if cp < 65536 { return 3; }
    return 4;
}

// #1372: the `i`-th UTF-8 byte (0-based) of a validated codepoint `cp`
// whose encoded length is `n`. Byte-for-byte the C `_utf8_encode` layout.
// Decimal masks (seed lexer has no `0x`): 0xff=255, 0xc0=192, 0x3f=63,
// 0x80=128, 0xe0=224, 0xf0=240.
fn _sfn_utf8_byte(cp: i64, n: i64, i: i64) -> i64 {
    if n == 1 { return cp & 255; }
    if n == 2 {
        if i == 0 { return 192 | (cp >> 6); }
        return 128 | (cp & 63);
    }
    if n == 3 {
        if i == 0 { return 224 | (cp >> 12); }
        if i == 1 { return 128 | ((cp >> 6) & 63); }
        return 128 | (cp & 63);
    }
    if i == 0 { return 240 | (cp >> 18); }
    if i == 1 { return 128 | ((cp >> 12) & 63); }
    if i == 2 { return 128 | ((cp >> 6) & 63); }
    return 128 | (cp & 63);
}

// #1372: compare an immediate codepoint `cp` (a single grapheme) against
// a real, deref-safe string `real` of byte length `len`. Reproduces the
// `strcmp(utf8(cp), real)` arm of the C `_strings_equal_fast` without
// allocating — the loop is bounded by the UTF-8 width (<= 4).
fn _sfn_imm_eq_real(cp: i64, real: * u8, len: i64) -> bool {
    let n: i64 = _sfn_utf8_byte_len(cp);
    if len != n { return false; }
    let mut i: i64 = 0;
    loop {
        if i >= n { break; }
        if sfn_str_read_byte(real, i) != _sfn_utf8_byte(cp, n, i) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

// `sfn_str_len(s)` — #1372 (C5 of epic #1308): the real Sailfin body for
// the `string.length` emission target (the C `sfn_str_len` def is now
// `static`). Classifies an immediate-codepoint pseudo-pointer FIRST via the
// non-allocating `sfn_str_immediate_codepoint` bridge (the #714/#716 crash
// class — `char_at` results arrive tagged; `decode_owned` would malloc per
// call and leak on this hot path), returning the codepoint's UTF-8 byte
// width. A real pointer is bounded-scanned with libc `strnlen` (16 MiB cap)
// after `decode_owned` (a pass-through that does NOT allocate for real
// pointers but bumps the call-seq, matching the #1315 accessor discipline).
// Byte-identical to the retired `sailfin_runtime_string_length` delegator,
// whose non-ASAN path is exactly `strnlen(s, 16 MiB)`.
fn sfn_str_len(s: * u8) -> i64 {
    if (s as i64) == 0 { return 0; }
    let cp: i64 = sfn_str_immediate_codepoint(s);
    if cp >= 0 { return _sfn_utf8_byte_len(cp); }
    let real: * u8 = sfn_str_decode_owned(s);
    return strnlen(real, 16777216) as i64;
}

// `sfn_str_eq(a, b)` — #1372: the real Sailfin body for the string `==`
// emission target (the C `sfn_str_eq` def is now `static`). Reproduces
// `_strings_equal_fast` arm-for-arm: pointer-equal (covers both-null and two
// identical immediates, whose `(cp<<32)` values match) is equal;
// exactly-one-null is not; two immediates compare by codepoint; an immediate
// vs a real string compares the codepoint's UTF-8 bytes against the real
// bytes (`_sfn_imm_eq_real`); two real strings compare by length + `memcmp`.
// Immediates are classified via the non-allocating `sfn_str_immediate_codepoint`
// bridge first — string `==` compares `char_at` results (tagged pseudo-
// pointers, #714/#716), so an unconditional `decode_owned` would malloc per
// comparison and leak. The real-involved paths route the (real) operand
// through `decode_owned` (pass-through, no alloc) for its call-seq bump,
// preserving the #892 concat-reuse invalidation the C `sfn_str_eq` made on entry.
fn sfn_str_eq(a: * u8, b: * u8) -> bool {
    if (a as i64) == (b as i64) { return true; }
    if (a as i64) == 0 { return false; }
    if (b as i64) == 0 { return false; }
    let ca: i64 = sfn_str_immediate_codepoint(a);
    let cb: i64 = sfn_str_immediate_codepoint(b);
    if ca >= 0 {
        if cb >= 0 { return ca == cb; }
        let rb: * u8 = sfn_str_decode_owned(b);
        let lb: i64 = strnlen(rb, 16777216) as i64;
        return _sfn_imm_eq_real(ca, rb, lb);
    }
    let ra: * u8 = sfn_str_decode_owned(a);
    if cb >= 0 {
        let la: i64 = strnlen(ra, 16777216) as i64;
        return _sfn_imm_eq_real(cb, ra, la);
    }
    let la2: i64 = strnlen(ra, 16777216) as i64;
    let lb2: i64 = strnlen(b, 16777216) as i64;
    if la2 != lb2 { return false; }
    return memcmp(ra, b, la2 as usize) == 0;
}

// `sfn_str_slice(text, start, end)` — #1372: the real Sailfin body for the
// `substring` / `string.slice` emission target (the C `sfn_str_slice` def is
// now `static`). Keeps the ALLOCATING shape: clamps the `f64` indices to i64
// and calls the i64 substring entrypoint `sailfin_runtime_substring_unchecked`,
// which materialises a real, decode-safe buffer. It does NOT call the
// `substring_unchecked` C wrapper (a registry target whose `native_signature`
// is `sfn_str_slice` → infinite self-recursion). The `f64 -> i64` clamp is
// inlined: NaN maps to 0 (`v != v`), in-range doubles truncate toward zero;
// substring indices are small, so the C `_clamp_to_i64` INT64 saturation arms
// are unnecessary. This requires the f64-parameter codegen fix
// (`core_type_mapping.sfn`, this PR) to be present in the building seed —
// hence the seed bump to 0.7.0-alpha.37. A non-owning `Slice` view stays
// blocked on #1283 (an immediate-codepoint pseudo-pointer has no real
// `text + start` address).
fn sfn_str_slice(text: * u8, start: f64, end: f64) -> * u8 {
    let mut si: i64 = 0;
    if start == start { si = start as i64; }
    let mut ei: i64 = 0;
    if end == end { ei = end as i64; }
    return sailfin_runtime_substring_unchecked(text, si, ei);
}

// `sfn_str_sfn_to_cstr(s)` — NUL-terminated C string view of `s`.
// Today's strings already carry a trailing NUL (the literal
// lowering in `core_strings.sfn::lower_string_literal` writes one
// past the byte payload), so the boundary is the identity
// function. M2.4b reworks the body once the aggregate carries
// arbitrary (potentially non-terminated) byte ranges and an arena
// must be threaded for the copy.
fn sfn_str_sfn_to_cstr(s: * u8) -> * u8 { return s; }

// `sfn_str_sfn_from_cstr(s)` — adopt a NUL-terminated C buffer as
// an SfnString. The architect spec scans for the NUL terminator
// with `memchr` to recover the byte length and constructs the
// aggregate `{s, len}` view; today's body still hands back the
// bare `i8*` because there's no SfnString slot to populate.
// `memchr` is declared above so the M2.4b body rewrite (over the
// aggregate shape) doesn't need to add it then.
fn sfn_str_sfn_from_cstr(s: * u8) -> * u8 { return s; }

// `sfn_str_sfn_concat(a, b)` — proof-of-life Sailfin trampoline
// for the M2.4b allocating wave. Architect spec
// (`runtime_architecture.md` §2.2): bump `a.len + b.len` bytes
// into the supplied arena, memcpy both payloads, return the
// `SfnString` aggregate. Today's body delegates to the legacy
// NUL-terminated `sailfin_runtime_string_concat` because the
// Sailfin frontend can't take an SfnString aggregate by value
// (M1.A.2 hasn't landed). The user-emission hot path bypasses
// this wrapper entirely and lands on the C entrypoint
// `sfn_str_concat`, which has the real arena ABI.
//
// #1217 (Phase R1): `concat` returns an owned `OwnedBuf` (proposal
// §5.1 "concat returns owned") built by appending both operands into a
// fresh buffer via the canonical `owned_buf_new` / `owned_buf_append`
// (imported from `./memory/ownedbuf` — #1289 collapsed the inlined
// `_str_buf_*` copy once #1288's sibling-staging let the cross-module
// `OwnedBuf`-returning call resolve). The result is the unique owner of
// its bytes, so the chained-append grow-at-tip the architect spec
// describes is sound by construction — no aliasing of either input's
// storage (the #1205 hazard class). Storage is the process-global arena
// when arena mode is on, gated on `sfn_arena_enabled()` so the
// `SAILFIN_USE_ARENA=0` opt-out (ASAN / diagnostics) is honored — when
// disabled, `arena_addr` is `0` and `owned_buf_new` falls back to
// libc-backed storage. Params are unchanged (`* u8`, `* u8`) — the byte
// lengths are recovered via the local `sfn_str_len`. The two
// `owned_buf_append` calls are moves of the unique buffer
// (consume-and-return); the raw extern interior they route through sits
// behind `unsafe` inside `ownedbuf.sfn`.
fn sfn_str_sfn_concat(a: * u8, b: * u8) -> OwnedBuf {
    let a_len: i64 = sfn_str_len(a);
    let b_len: i64 = sfn_str_len(b);
    let mut arena_addr: i64 = 0;
    if sfn_arena_enabled() { arena_addr = sfn_arena_global() as i64; }
    let total: i64 = a_len + b_len;
    let buf: OwnedBuf = owned_buf_new(arena_addr, total);
    let grown: OwnedBuf = owned_buf_append(buf, a as i64, a_len);
    return owned_buf_append(grown, b as i64, b_len);
}

// `sfn_str_sfn_append(buf, suffix_addr, suffix_len)` — #1217 (Phase
// R1): the append hot path, a **move** over `OwnedBuf` (proposal §5.1
// "`sfn_str_sfn_append` takes/returns `OwnedBuf` (move)"). It consumes
// the unique `buf`, appends `suffix_len` bytes from `suffix_addr`, and
// returns the (possibly relocated) buffer — delegating to the canonical
// `owned_buf_append` (imported from `./memory/ownedbuf`), which routes
// growth through the arena's grow-if-at-tip realloc. Because the
// caller's `buf` is the unique live owner (the ownership checker proves
// it; no alias), the in-place grow-at-tip is sound — this is the
// structural close of the #1205 aliasing hazard. The delegation routes
// through `ownedbuf.sfn`; the raw extern interior sits behind `unsafe`
// there. The compiler has no callers of `string.append` yet (the
// descriptor row is symbol-parking), so the signature flip breaks no
// call site.
fn sfn_str_sfn_append(buf: OwnedBuf, suffix_addr: i64, suffix_len: i64) -> OwnedBuf {
    return owned_buf_append(buf, suffix_addr, suffix_len);
}

// #1315 (C4 of epic #1308) — real Sailfin accessor bodies.
//
// The bare names below ARE the emission targets (the C defs in
// `sailfin_runtime.c` are now `static`); the `sfn_str_sfn_*` proof-of-life
// infix wrappers they replace are retired (mirroring #1314's number/int
// flip). Each body owns its control flow in Sailfin and calls the four
// narrow C bridges (`sfn_str_decode_owned` / `sfn_str_immediate_codepoint`
// / `sfn_str_read_byte` / `sfn_str_grapheme_byte`) only for the operations
// the seed cannot express in Sailfin today: a single-byte `* u8` load, the
// immediate-codepoint pseudo-pointer decode, and the platform-gated
// grapheme production. Behaviour is byte-identical to the prior C
// trampolines — including the bootstrap "treat each UTF-8 byte as a
// grapheme" simplification and the first-byte `codepoint` for multi-byte
// sequences. The bridges (and this dance) retire with the SfnString
// aggregate flip / immediate-encoding deletion (#1283 / #822).
//
// `codepoint` / `grapheme_count` return `f64`, not `i64`: their registry
// rows (`runtime_helpers.sfn:617,993`) keep a `double` C-ABI return + a
// `round + fptosi` coercion at the call site. Returning `f64` preserves
// that ABI byte-for-byte, so no registry edit and no seed cut are needed.
// `sfn_str_grapheme_count(s)` — grapheme count of `s`. Bootstrap
// simplification: the UTF-8 byte length (one byte == one grapheme),
// exactly as the legacy walker computed.
fn sfn_str_grapheme_count(s: * u8) -> f64 {
    let real: * u8 = sfn_str_decode_owned(s);
    return sailfin_runtime_string_length(real) as f64;
}

// `sfn_str_grapheme_at(s, idx)` — the `idx`-th grapheme of `s`. An
// immediate-codepoint input is a single grapheme at index 0 (returned
// unchanged, never dereferenced); a real ASCII byte is produced as an
// immediate pseudo-pointer (Linux) or a 1-byte buffer by the platform-
// gated `sfn_str_grapheme_byte` bridge. Out-of-range or non-integral
// indices yield the empty string. The decode + `string_length` guard the
// `grapheme_byte` dereference (a corrupted pointer scans to length 0).
fn sfn_str_grapheme_at(s: * u8, idx: f64) -> * u8 {
    if (s as i64) == 0 { return sfn_str_from_byte(0); }
    let iidx: i64 = idx as i64;
    if (iidx as f64) != idx { return sfn_str_from_byte(0); }
    let imm: i64 = sfn_str_immediate_codepoint(s);
    if imm >= 0 {
        if iidx == 0 { return s; }
        return sfn_str_from_byte(0);
    }
    if iidx < 0 { return sfn_str_from_byte(0); }
    let real: * u8 = sfn_str_decode_owned(s);
    let len: i64 = sailfin_runtime_string_length(real);
    if len <= 0 { return sfn_str_from_byte(0); }
    if iidx >= len { return sfn_str_from_byte(0); }
    return sfn_str_grapheme_byte(real, iidx);
}

// `sfn_str_byte_at(s, idx)` — raw byte at offset `idx`, or -1 for a null
// string / out-of-range index. Decodes an immediate input to real bytes
// first, bounds against the NUL-scanned length, then reads the byte via
// the `sfn_str_read_byte` bridge.
fn sfn_str_byte_at(s: * u8, idx: i64) -> i64 {
    if (s as i64) == 0 { return -1; }
    if idx < 0 { return -1; }
    let real: * u8 = sfn_str_decode_owned(s);
    let len: i64 = sailfin_runtime_string_length(real);
    if idx >= len { return -1; }
    return sfn_str_read_byte(real, idx);
}

// `sfn_str_find_byte(s, byte_value, start)` — first offset >= `start` at
// which `byte_value` (low 8 bits) occurs in `s`, or -1. A pure-Sailfin
// forward scan, byte-identical to the legacy `memchr` walk; a negative
// `start` clamps to 0.
fn sfn_str_find_byte(s: * u8, byte_value: i64, start_index: i64) -> i64 {
    if (s as i64) == 0 { return -1; }
    let real: * u8 = sfn_str_decode_owned(s);
    let len: i64 = sailfin_runtime_string_length(real);
    let mut start: i64 = start_index;
    if start < 0 { start = 0; }
    if start >= len { return -1; }
    let target: i64 = byte_value & 255;
    let mut i: i64 = start;
    loop {
        if i >= len { break; }
        if sfn_str_read_byte(real, i) == target { return i; }
        i = i + 1;
    }
    return -1;
}

// `sfn_str_codepoint(s)` — first codepoint of `s`, or -1 for a null/empty
// string. Preserves the legacy `char_code` semantics exactly: an immediate
// input returns its codepoint value (via `sfn_str_immediate_codepoint`, no
// dereference); a real string returns its first byte (the documented
// bootstrap simplification for multi-byte sequences).
fn sfn_str_codepoint(s: * u8) -> f64 {
    if (s as i64) == 0 { return -1.0; }
    let imm: i64 = sfn_str_immediate_codepoint(s);
    if imm >= 0 { return imm as f64; }
    let real: * u8 = sfn_str_decode_owned(s);
    let len: i64 = sailfin_runtime_string_length(real);
    if len <= 0 { return -1.0; }
    return sfn_str_read_byte(real, 0) as f64;
}

// `sfn_str_sfn_from_codepoint(cp)` — 1-4 byte UTF-8 encode of
// `cp`. Architect spec allocates into the supplied arena and
// returns the SfnString aggregate; today's body trampolines
// through the C wave-2 entrypoint which `malloc`s a fresh
// NUL-terminated buffer (no arena threading yet at the Sailfin
// call surface). Invalid codepoints (negative, > U+10FFFF, or
// in the UTF-16 surrogate range) produce an empty string per
// the C body's invariant.
fn sfn_str_sfn_from_codepoint(cp: i64) -> * u8 {
    return sfn_str_from_codepoint(cp);
}

// `sfn_str_sfn_from_byte(byte_value)` — raw single-byte string build
// (#874). Proof-of-life Sailfin trampoline following the
// `from_codepoint` discipline: today's body forwards to the C wave-2
// entrypoint `sfn_str_from_byte` (which `malloc`s the 1-byte
// NUL-terminated buffer), because the Sailfin call surface can't thread
// an arena yet (M1.A.2). The prelude's `char_from_code` wraps this and
// casts the `* u8` result to `string`. Byte 0 and out-of-range values
// yield the empty string — see the C body for the NUL-termination
// limitation deferred to the SfnString aggregate flip.
fn sfn_str_sfn_from_byte(byte_value: i64) -> * u8 {
    return sfn_str_from_byte(byte_value);
}

// `sfn_str_to_number(s)` — #1372: the real Sailfin body for the
// `string.to_number` emission target (the C `sfn_str_to_number` def is
// now `static`). Classifies an immediate-codepoint pseudo-pointer FIRST
// via the non-allocating `sfn_str_immediate_codepoint` bridge — the C
// body decoded inline before `strtod` because the operand can arrive
// tagged (#714/#716), and an unconditional owning decode would leak. An
// immediate is a single codepoint: an ASCII digit yields its value, any
// other single character yields `0.0` — exactly what `strtod` returns for
// the equivalent one-character string. A real pointer is already
// deref-safe, so `strtod` parses the NUL-terminated payload directly
// (`endptr` discarded via `null`). Null yields `0.0`.
fn sfn_str_to_number(s: * u8) -> f64 {
    if (s as i64) == 0 { return 0.0; }
    let cp: i64 = sfn_str_immediate_codepoint(s);
    if cp >= 0 {
        if cp >= 48 && cp <= 57 { return (cp - 48) as f64; }
        return 0.0;
    }
    return strtod(s, null);
}

// ====================================================================
// Number / int formatting — real hand-rolled Sailfin bodies (#1314, C3
// of epic #1308). The bare `sfn_int_to_str` / `sfn_number_to_str`
// (emission targets, formerly C trampolines in `sailfin_runtime.c`,
// now `static`) are defined here in Sailfin; the linker binds every
// fresh emission to these bodies. The bare names ARE the real bodies —
// the proof-of-life `sfn_number_to_str_sfn` / `sfn_int_to_str_sfn` infix
// wrappers are retired (the migration they marked is complete), and the
// `f64` call-resolution gap (see `sfn_number_to_str` below) makes an
// `f64`-forwarding infix unrepresentable under the seed anyway.
//
// Byte assembly. Like `ownedbuf.sfn`, the seed compiler does not lower
// a direct single-byte store through a `* u8` slot, so digits are
// written via read-modify-write of the enclosing 8-aligned i64 word
// (`atomic_load` + clear-the-byte + `atomic_store`). The result is
// allocated through the process-global arena when arena mode is on
// (gated on `sfn_arena_enabled()`, the discipline `concat` follows),
// else libc storage; a 64-byte buffer covers every worst case (sci
// "-1.23456789012346e-308" = 22 bytes + NUL; fixed "-0.000<15 digits>"
// ≈ 22 bytes + NUL). The buffer is NUL-terminated so the `* u8`
// C-string consumers (`sailfin_runtime_string_length`, etc.) recover
// the length by scan.
//
// Float formatting reproduces libc `%.15g`: P=15 significant digits;
// fixed (`%f`) style when the decimal exponent X satisfies
// -4 <= X < 15, else scientific (`d.ddde±NN`, exponent >= 2 digits with
// sign); trailing zeros and a bare trailing point stripped. Integer-
// valued doubles below 1e15 take an exact i64 fast path (no rounding) —
// this covers the self-host hot path (`%t` temp-name emission) bit-for-
// bit. The general path scales `m * 10^(14 - X)` and rounds; for the
// fixed range that is a single exact power-of-ten multiply (10^k,
// k <= 22, is exact in f64), so rounding is correct there. Correctness
// ceiling (documented, out of the suite): values landing exactly on a
// half-ulp tie at the 15th significant digit round half-up rather than
// libc's half-to-even; extreme subnormals (|X| > ~300) and -0.0 (prints
// "0") may diverge. A bignum dtoa (Ryu/Dragon) is post-1.0 if exactness
// for those is ever required.
// `_num_put_byte(addr, value)` writes the low byte of `value` at byte
// address `addr` via read-modify-write of the enclosing i64 word.
// `word - (word & mask)` clears the target byte without a bitwise NOT
// (the seed-unverified `~`, avoided per the arena module); the new byte
// ORs in (the cleared bits make `+` equivalent to `|`). The enclosing
// word is always in-bounds: every backing allocation is 8-aligned with
// a capacity that is a multiple of 8 (`owned_buf_new` discipline).
fn _num_put_byte(addr: i64, value: i64) -> void {
    let word_addr: i64 = (addr / 8) * 8;
    let shift: i64 = (addr - word_addr) * 8;
    let slot: * i64 = word_addr as * i64;
    let word: i64 = atomic_load(slot);
    let mask: i64 = 255 << shift;
    let current: i64 = word & mask;
    let placed: i64 = (value & 255) << shift;
    atomic_store(slot, (word - current) + placed);
}

// `_num_emit_char(base, pos, ch)` writes one byte and returns the next
// position.
fn _num_emit_char(base: i64, pos: i64, ch: i64) -> i64 {
    _num_put_byte(base + pos, ch);
    return pos + 1;
}

// `_num_finish(base, pos)` NUL-terminates and returns the buffer base
// as a `* u8` C-string.
fn _num_finish(base: i64, pos: i64) -> * u8 {
    _num_put_byte(base + pos, 0);
    return base as * u8;
}

// `_num_pow10_i64(k)` — 10^k as i64 for k in [0, 18] (fits i64).
fn _num_pow10_i64(k: i64) -> i64 {
    let mut r: i64 = 1;
    let mut i: i64 = 0;
    loop {
        if i >= k { break; }
        r = r * 10;
        i = i + 1;
    }
    return r;
}

// `_num_count_digits(value)` — decimal digit count of a non-negative
// i64 (0 has one digit).
fn _num_count_digits(value: i64) -> i64 {
    if value == 0 { return 1; }
    let mut n: i64 = 0;
    let mut v: i64 = value;
    loop {
        if v == 0 { break; }
        v = v / 10;
        n = n + 1;
    }
    return n;
}

// `_num_emit_uint(base, pos, value, min_digits)` writes `value` (>= 0)
// most-significant digit first, zero-padded to at least `min_digits`.
// Returns the next position.
fn _num_emit_uint(base: i64, pos: i64, value: i64, min_digits: i64) -> i64 {
    let mut width: i64 = _num_count_digits(value);
    if min_digits > width { width = min_digits; }
    let mut divisor: i64 = _num_pow10_i64(width - 1);
    let mut p: i64 = pos;
    let mut i: i64 = 0;
    loop {
        if i >= width { break; }
        let digit: i64 = (value / divisor) % 10;
        p = _num_emit_char(base, p, 48 + digit);
        divisor = divisor / 10;
        i = i + 1;
    }
    return p;
}

// `sfn_number_to_str(value)` — the bare emission target (#1314), render
// `value` as a `%.15g`-style decimal string into arena/libc storage. See
// the family comment above for the algorithm and its correctness ceiling.
//
// The whole float pipeline (exponent walk + 15-digit scaling) is inlined
// here rather than split into helpers: an UNregistered internal Sailfin
// function taking/returning `f64` mis-resolves under the seed — its call
// site defaults the `f64` to `i8*` and coerces the argument through
// `sfn_number_to_str` (visible in the seed's emission of the
// `sfn_str_sfn_slice` proof-of-life wrapper). `sfn_number_to_str` itself
// resolves correctly because it carries a runtime-helper descriptor
// (`number.to_string` → `["double"]`); the i64-only helpers it calls
// (`_num_emit_*`, `_num_pow10_i64`) resolve fine. Keeping every `f64`
// inside this one descriptor-backed body sidesteps the gap.
fn sfn_number_to_str(value: f64) -> * u8 {
    let mut arena_addr: i64 = 0;
    if sfn_arena_enabled() { arena_addr = sfn_arena_global() as i64; }
    let buf: OwnedBuf = owned_buf_new(arena_addr, 64);
    let base: i64 = buf.ptr_addr;
    if base == 0 { return null; }
    let mut pos: i64 = 0;

    // NaN (libc prints "nan").
    if value != value {
        pos = _num_emit_char(base, pos, 110);
        pos = _num_emit_char(base, pos, 97);
        pos = _num_emit_char(base, pos, 110);
        return _num_finish(base, pos);
    }

    let mut neg: bool = false;
    let mut m: f64 = value;
    if value < 0.0 {
        neg = true;
        m = 0.0 - value;
    }

    // Infinity (libc prints "inf" / "-inf"). NaN is already handled, so
    // `m - m` is 0 for every finite m and NaN (!= 0) only for +inf.
    if (m - m) != 0.0 {
        if neg { pos = _num_emit_char(base, pos, 45); }
        pos = _num_emit_char(base, pos, 105);
        pos = _num_emit_char(base, pos, 110);
        pos = _num_emit_char(base, pos, 102);
        return _num_finish(base, pos);
    }

    // Zero (covers -0.0 -> "0", a documented divergence from libc's "-0").
    if m == 0.0 {
        pos = _num_emit_char(base, pos, 48);
        return _num_finish(base, pos);
    }

    // Exact integer fast path: integer-valued magnitudes below 1e15
    // format as plain integers (no rounding) — the self-host hot path.
    if m < 1000000000000000.0 {
        let ip: i64 = m as i64;
        if (ip as f64) == m {
            if neg { pos = _num_emit_char(base, pos, 45); }
            pos = _num_emit_uint(base, pos, ip, 1);
            return _num_finish(base, pos);
        }
    }

    // ---- General 15-significant-digit path ----
    // Exponent estimate X = floor(log10(m)) via a power-of-ten walk. Any
    // one-ulp boundary error is corrected by the normalization loop below.
    // Powers overflow to +inf past ~1e308, terminating each walk.
    let mut x_exp: i64 = 0;
    if m >= 1.0 {
        loop {
            // p = 10^(x_exp + 1), recomputed inline.
            let target: i64 = x_exp + 1;
            let mut p: f64 = 1.0;
            let mut j: i64 = 0;
            loop {
                if j >= target { break; }
                p = p * 10.0;
                j = j + 1;
            }
            if m >= p { x_exp = x_exp + 1; } else { break; }
        }
    } else {
        loop {
            // p = 10^(-x_exp); `m * p >= 1.0` iff `m >= 10^x_exp`.
            let nx: i64 = 0 - x_exp;
            let mut p: f64 = 1.0;
            let mut j: i64 = 0;
            loop {
                if j >= nx { break; }
                p = p * 10.0;
                j = j + 1;
            }
            if m * p >= 1.0 { break; }
            x_exp = x_exp - 1;
        }
    }

    // 10^18 chunk constant (exact in f64; reused by the scaling below).
    let mut chunk: f64 = 1.0;
    let mut ci: i64 = 0;
    loop {
        if ci >= 18 { break; }
        chunk = chunk * 10.0;
        ci = ci + 1;
    }

    // Scale to a 15-digit significant integer D = round(m * 10^(14 - X)),
    // normalizing X so D lands in [1e14, 1e15). The scale factor is one
    // exact 10^kk multiply when |14 - X| <= 18 (the whole fixed-form
    // range, so rounding is correct there), chunked by the exact 10^18
    // otherwise. Round-half-up is the documented tie ceiling. `guard`
    // bounds the normalization (1-2 corrections suffice) so extreme
    // subnormals cannot loop forever.
    let mut d15: i64 = 0;
    let mut guard: i64 = 0;
    loop {
        let k: i64 = 14 - x_exp;
        let mut r: f64 = m;
        if k >= 0 {
            let mut kk: i64 = k;
            loop {
                if kk < 18 { break; }
                r = r * chunk;
                kk = kk - 18;
            }
            let mut p: f64 = 1.0;
            let mut j: i64 = 0;
            loop {
                if j >= kk { break; }
                p = p * 10.0;
                j = j + 1;
            }
            r = r * p;
        } else {
            let mut kk: i64 = 0 - k;
            loop {
                if kk < 18 { break; }
                r = r / chunk;
                kk = kk - 18;
            }
            let mut p: f64 = 1.0;
            let mut j: i64 = 0;
            loop {
                if j >= kk { break; }
                p = p * 10.0;
                j = j + 1;
            }
            r = r / p;
        }
        d15 = (r + 0.5) as i64;

        if guard >= 5 { break; }
        guard = guard + 1;
        if d15 < 100000000000000 { x_exp = x_exp - 1; } else if d15 >= 1000000000000000 {
            x_exp = x_exp + 1;
        } else { break; }
    }

    // Strip trailing zeros from the 15-digit significant integer.
    let mut s: i64 = 15;
    loop {
        if d15 % 10 != 0 { break; }
        d15 = d15 / 10;
        s = s - 1;
    }

    if neg { pos = _num_emit_char(base, pos, 45); }

    if x_exp >= -4 {
        if x_exp < 15 {
            // Fixed (`%f`) form.
            if x_exp >= 0 {
                let intlen: i64 = x_exp + 1;
                if s <= intlen {
                    pos = _num_emit_uint(base, pos, d15, s);
                    let mut zpad: i64 = intlen - s;
                    loop {
                        if zpad <= 0 { break; }
                        pos = _num_emit_char(base, pos, 48);
                        zpad = zpad - 1;
                    }
                } else {
                    let fracdigits: i64 = s - intlen;
                    let pdiv: i64 = _num_pow10_i64(fracdigits);
                    let high: i64 = d15 / pdiv;
                    let low: i64 = d15 % pdiv;
                    pos = _num_emit_uint(base, pos, high, intlen);
                    pos = _num_emit_char(base, pos, 46);
                    pos = _num_emit_uint(base, pos, low, fracdigits);
                }
            } else {
                pos = _num_emit_char(base, pos, 48);
                pos = _num_emit_char(base, pos, 46);
                let mut lz: i64 = (0 - x_exp) - 1;
                loop {
                    if lz <= 0 { break; }
                    pos = _num_emit_char(base, pos, 48);
                    lz = lz - 1;
                }
                pos = _num_emit_uint(base, pos, d15, s);
            }
            return _num_finish(base, pos);
        }
    }

    // Scientific (`d.ddde±NN`) form.
    let lead_div: i64 = _num_pow10_i64(s - 1);
    let lead: i64 = d15 / lead_div;
    let rest: i64 = d15 % lead_div;
    pos = _num_emit_uint(base, pos, lead, 1);
    if s > 1 {
        pos = _num_emit_char(base, pos, 46);
        pos = _num_emit_uint(base, pos, rest, s - 1);
    }
    pos = _num_emit_char(base, pos, 101);
    if x_exp >= 0 { pos = _num_emit_char(base, pos, 43); } else {
        pos = _num_emit_char(base, pos, 45);
    }
    let mut absx: i64 = x_exp;
    if absx < 0 { absx = 0 - absx; }
    pos = _num_emit_uint(base, pos, absx, 2);
    return _num_finish(base, pos);
}

// `sfn_int_to_str(value)` — the bare emission target (#1314), decimal i64
// formatting into arena/libc storage. Digit extraction runs in the
// negative domain so INT64_MIN (whose positive has no i64 representation)
// formats without overflow: `value % 10` / `value / 10` truncate toward
// zero, yielding negative remainders that are negated per digit. All
// parameters/locals are i64, so the seed resolves the call surface
// correctly (the `f64` mis-resolution that forced `sfn_number_to_str` to
// inline its helpers does not apply here).
fn sfn_int_to_str(value: i64) -> * u8 {
    let mut arena_addr: i64 = 0;
    if sfn_arena_enabled() { arena_addr = sfn_arena_global() as i64; }
    let buf: OwnedBuf = owned_buf_new(arena_addr, 32);
    let base: i64 = buf.ptr_addr;
    if base == 0 { return null; }
    let mut pos: i64 = 0;

    if value == 0 {
        pos = _num_emit_char(base, pos, 48);
        return _num_finish(base, pos);
    }

    let mut neg: bool = false;
    if value < 0 { neg = true; }

    // Count digits (loop toward zero works for either sign).
    let mut nd: i64 = 0;
    let mut t: i64 = value;
    loop {
        if t == 0 { break; }
        t = t / 10;
        nd = nd + 1;
    }

    if neg { pos = _num_emit_char(base, pos, 45); }

    // Write digits least-significant first into the reserved span.
    let mut wp: i64 = pos + nd - 1;
    let mut x: i64 = value;
    loop {
        if x == 0 { break; }
        let mut d: i64 = x % 10;
        if d < 0 { d = 0 - d; }
        _num_put_byte(base + wp, 48 + d);
        wp = wp - 1;
        x = x / 10;
    }
    pos = pos + nd;
    return _num_finish(base, pos);
}

// #925 (sub-issue of #390): Cat-C char-predicate ports. The legacy C
// bodies (`sailfin_runtime_is_alpha_char` / `_is_decimal_digit` /
// `_is_whitespace_char`) took a `double` codepoint; the runtime-helper
// descriptor ABI is `(i8) -> i1`, so these bare `sfn_str_is_*` bodies
// take a `u8` byte (lowers to LLVM `i8`) and widen to `i64` for the
// range comparisons. ASCII semantics preserved byte-for-byte. Nested
// `if` accumulators (not `&&`) match the self-host-safe idiom used
// across the runtime/sfn modules.
fn sfn_str_is_digit(ch: u8) -> bool {
    let c: i64 = ch as i64;
    let mut result: bool = false;
    if c >= 48 {
        if c <= 57 { result = true; }
    }
    return result;
}

fn sfn_str_is_whitespace(ch: u8) -> bool {
    let c: i64 = ch as i64;
    let mut result: bool = false;
    if c == 32 { result = true; }
    if c == 9 { result = true; }
    if c == 10 { result = true; }
    if c == 13 { result = true; }
    return result;
}

fn sfn_str_is_alpha(ch: u8) -> bool {
    let c: i64 = ch as i64;
    let mut result: bool = false;
    if c >= 97 {
        if c <= 122 { result = true; }
    }
    if c >= 65 {
        if c <= 90 { result = true; }
    }
    return result;
}

// #925: `sfn_to_debug_string(value)` — identity port of the C
// `sailfin_runtime_to_debug_string`, which returns its argument
// unchanged (debug rendering is value-side type tagging, deferred).
// Descriptor ABI is `(i8*) -> i8*`.
fn sfn_to_debug_string(value: * u8) -> * u8 { return value; }
