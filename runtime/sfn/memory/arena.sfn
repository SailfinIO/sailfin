// runtime/sfn/memory/arena.sfn
//
// Sailfin-native bump allocator backed by a linked list of pages.
// First fully-implemented runtime module in the M2 rewrite — ships
// alongside the C arena (the retired C runtime, formerly
// `sailfin_arena.c`) so downstream callers stay on the production
// allocator until M3
// flips the C namesakes to `static` and retires the C source. M2.2
// per `docs/proposals/0025-native-runtime-architecture.md` `#321-arenas` and issue #477 (epic
// #389 M2 — Core Runtime in Sailfin).
//
// API surface (mirrors the C arena's five core entry points):
//
//   sfn_arena_sfn_create(default_page_size)  → arena handle
//   sfn_arena_sfn_alloc(arena, size, align)  → payload pointer
//   sfn_arena_sfn_reset(arena)               → zero every page's used
//   sfn_arena_sfn_destroy(arena)             → free pages + arena
//   sfn_arena_sfn_realloc(arena, ptr, old, new, align) → grow-if-at-tip
//
// Layout. `Arena` is a 24-byte (three i64 slot) handle that owns a
// chain of `ArenaPage` records (#822: the two transition-only counters
// that mirrored the deleted C `SfnArena` are gone — see the `struct
// Arena` comment). Each `ArenaPage` is a 32-byte (four
// i64 slot) header followed by a separately-malloc'd byte buffer.
// Pointer-typed fields ride as `i64` slots — same workaround as
// `runtime/sfn/memory/rc.sfn` and `runtime/sfn/exception.sfn` because
// the seed compiler silently drops stores to `* T` struct fields
// routed through a `* StructTy` pointer (verified during M2.3
// development). The `_addr` suffix on every storage field reflects
// that storage truth: the bytes are a 64-bit address, not a typed
// pointer.
//
// Bump discipline. Allocations round the page's `used` cursor up to
// the request's alignment, advance it by `size`, and return the byte
// at the rounded offset. When the current page can't fit the
// request, the allocator walks the `next_addr` chain looking for a
// downstream page with room (the chain stays intact across resets so
// the next burst can reuse pages), then falls back to allocating a
// fresh page sized `max(default_page_size, size + align)`. The new
// page splices in after the current page so any pages strictly after
// the current one survive for reuse.
//
// Grow-if-at-tip realloc. When `ptr + old_size` lands exactly at the
// current page's bump tip and the page has room for `new_size -
// old_size`, the bump cursor extends in place — no copy. Otherwise
// the allocator falls back to fresh-alloc + memcpy. The old buffer
// is "leaked" into the arena (reclaimed at the next reset/destroy),
// matching the C arena's contract documented in
// `docs/proposals/0025-native-runtime-architecture.md` `#321-arenas`.
//
// Coexistence with the C arena. As of #1309 the arena *core* — the
// process-global handle plus the hot bump path — is Sailfin-owned: the
// bare `sfn_arena_create` / `sfn_arena_alloc` / `sfn_arena_global` /
// `sfn_arena_enabled` exports below replace the C namesakes (now
// removed from `sailfin_arena.c`), so the linker binds every caller
// (the `mem.sfn` externs and the bare call sites) here. The
// `sfn_arena_sfn_*` infix family is retained for
// `ownedbuf.sfn`'s externs and is the implementation the bare
// `create`/`alloc` forward to. As of #822 the C runtime
// (`sailfin_runtime.c` / `sailfin_arena.c`) is deleted, so
// `realloc`/`reset`/`destroy`/`print_stats`/`mark`/`rewind` are all
// Sailfin too and nothing outside this module touches the handle's
// bytes — the C-layout-match constraint is retired and the two
// transition-only counters (`total_allocated`/`total_pages`) are
// dropped, shrinking the handle from 40 back to its natural 24 bytes.
//
// Effects: none. Memory primitives sit below the I/O layer (same
// discipline as `runtime/sfn/memory/rc.sfn` and the other
// `runtime/sfn/*` modules). The `![io]` / `![clock]` annotations
// attach to adapters that wrap these primitives, never to the
// primitives themselves.
//
// Why inline `extern fn malloc / free / memcpy` rather than
// `import { malloc, free, memcpy } from "../platform/libc"`? The
// same reason `runtime/sfn/memory/rc.sfn`, `runtime/sfn/string.sfn`,
// and `runtime/sfn/array.sfn` inline their externs: cross-module
// extern resolution through the seed compiler hits the `cannot
// resolve return type for call to …` fatal (the struct-return gap of
// #1283 Gap 1; #1288 fixed the runtime-sfn-source emit path, but
// de-inlining these C-ABI externs is separate follow-up work),
// surfacing during emission. Inlining the three
// declarations we need keeps this module self-contained for every
// seed. Once the cross-module path lands, a follow-up PR flips
// these to imports without touching the bodies. Note that libc
// `realloc` is deliberately NOT declared here — the arena's
// `realloc` body uses fresh-alloc + `memcpy` for the not-at-tip
// path (the old buffer "leaks" into the arena and is reclaimed at
// reset/destroy per `docs/proposals/0025-native-runtime-architecture.md` `#321-arenas`), so no
// libc-realloc call survives the lowering.
//
// Null handling. The C arena returns `NULL` on OOM and treats
// `arena == NULL` / `size == 0` as no-ops returning `NULL`. The
// Sailfin port preserves the same contract — callers compare the
// returned `* u8` against `null` (or equivalently against `as i64 ==
// 0`) until `Result<T, E>` + `?` ship (Phase 1 of the runtime
// prereqs in CLAUDE.md). The destroy path treats null arenas as a
// no-op so the cleanup loop is safe at any state.
//
// Pinned by `compiler/tests/e2e/test_runtime_memory_arena.sh`:
// typecheck + fmt + LLVM `define` shape over the five exports +
// `declare`s for the libc externs (`malloc` / `free` / `memcpy`) +
// a clang-linked roundtrip harness that exercises create → alloc →
// realloc-grow-in-place → realloc-copy-on-overflow → page-overflow
// → reset → re-alloc → destroy and asserts the destroy free-count
// equals the page-chain length (2 pages × header+data + arena
// handle = 5 frees).
extern fn malloc(size: usize) -> *u8;

extern fn free(ptr: *u8) -> void;

extern fn memcpy(dst: *u8, src: *u8, n: usize) -> *u8;

// libc helpers backing the process-global handle + arena-mode probe
// ported from `sailfin_arena.c` in #1309. `getenv`/`strcmp` reproduce
// `_init_arena_enabled`'s `SAILFIN_USE_ARENA` decision; `abort`
// reproduces `_init_global_arena`'s fatal-on-OOM termination. Inlined
// for the same cross-module extern-resolution reason as `malloc`/`free`
// above.
extern fn getenv(name: *u8) -> *u8;

extern fn strcmp(a: *u8, b: *u8) -> i32;

extern fn abort() -> void;

// Telemetry path (#1309 `sfn_arena_print_stats` port). `strlen`
// measures each NUL-terminated literal/rendered piece and `write`
// emits straight to fd 2 (stderr). The raw libc write avoids the
// `{i8*, i64}` aggregate-string ABI hazard a `* u8 as string` round-trip
// would carry (cf. the #1372 note in `runtime/sfn/platform/rlimit.sfn`)
// and keeps the snapshot bytes exact. Integers are rendered inline (see
// `_arena_write_i64`) rather than via `string.sfn`'s `sfn_int_to_str`:
// arena.sfn is emitted and linked **standalone** by
// `test_runtime_memory_arena.sh`, so it must depend on nothing beyond
// libc + the symbols that harness stubs — a cross-module
// `sfn_int_to_str` reference would fail that link.
extern fn strlen(s: *u8) -> usize;

extern fn write(fd: i32, buf: *u8, count: usize) -> i64;

// `ArenaPage` is the per-page bookkeeping header (32 bytes, four
// i64 slots). `data_addr` points at the page's backing byte buffer
// (malloc'd separately from this header). `capacity` is the buffer
// size in bytes, `used` is the bump offset into the buffer, and
// `next_addr` links to the next page in the chain (`0` = null = end
// of chain). Layout pinned by the IR-shape assertions in
// `test_runtime_memory_arena.sh`.
struct ArenaPage {
    data_addr: i64;
    capacity: i64;
    used: i64;
    next_addr: i64;
}

// `Arena` is the public handle (24 bytes, three i64 slots).
// `current_addr` is the page that satisfies the next bump; `first_addr`
// is the chain head (for reset and destroy walks); `default_page_size`
// is the size of fresh pages spawned when the chain overflows.
//
// History (#1309 → #822): the handle previously carried two trailing
// `total_allocated@24` / `total_pages@32` counters padding it to 40
// bytes, byte-identical to the deleted C `SfnArena`. During the
// dual-runtime transition the still-C `sfn_arena_realloc`/`print_stats`
// dereferenced those offsets on the shared handle, so a short handle
// would have been a #1205-class out-of-bounds write. With the C runtime
// deleted (#822) nothing outside this module touches the handle's bytes:
// the counters retire (`print_stats` derives the page count and byte
// totals from the page-chain walk instead), shrinking the handle to its
// natural 24 bytes.
struct Arena {
    current_addr: i64;
    first_addr: i64;
    default_page_size: i64;
}

// `_sfn_arena_align_up(value, align)` rounds `value` up to the next
// multiple of `align`. Integer-division form so the body avoids `%`
// and bitwise NOT (both unverified in the seed compiler at the time
// this module was written). For `align == 8` and `value == 0` this
// returns `0`; for `value == 9` it returns `16`. Behavior matches the
// C arena's `_align_up` (the retired C runtime, formerly `sailfin_arena.c:19`)
// bit-for-bit on every power-of-two `align`.
fn _sfn_arena_align_up(value: i64, align: i64) -> i64 {
    let stepped: i64 = (value + align - 1) / align;
    return stepped * align;
}

// `_sfn_arena_page_create(capacity)` allocates a fresh page header
// plus a `capacity`-byte backing buffer. Returns the page address as
// a raw `* u8` (the caller casts to `* ArenaPage` to touch fields).
// On OOM either step bails — when the header allocation succeeds but
// the buffer alloc fails the header is freed before returning null so
// no orphaned allocation leaks into the chain.
fn _sfn_arena_page_create(capacity: i64) -> *u8 {
    let header_ptr: *u8 = malloc(32 as usize);
    if header_ptr as i64 == 0 { return header_ptr; }
    let data_ptr: *u8 = malloc(capacity as usize);
    if data_ptr as i64 == 0 {
        free(header_ptr);
        return data_ptr;
    }
    let page: *ArenaPage = header_ptr as *ArenaPage;
    page.data_addr = data_ptr as i64;
    page.capacity = capacity;
    page.used = 0;
    page.next_addr = 0;
    return header_ptr;
}

// `_sfn_arena_page_destroy(page_addr)` releases a single page (its
// backing buffer and its header). Null-safe: a `0` address is a
// no-op. The C arena's matching helper sat at
// `sailfin_arena.c:44` in the retired C runtime.
fn _sfn_arena_page_destroy(page_addr: i64) -> void {
    if page_addr == 0 { return; }
    let page: *ArenaPage = page_addr as *ArenaPage;
    let data_addr: i64 = page.data_addr;
    if data_addr != 0 { free(data_addr as *u8); }
    free(page_addr as *u8);
}

// `sfn_arena_sfn_create(default_page_size)` allocates an arena
// handle plus a single seed page sized `default_page_size`. A
// request of `0` selects the C arena's 1 MiB compiler default
// (`sailfin_arena.c:59`). On OOM either step bails and returns null;
// the partial allocation is freed before returning so no leak
// escapes. Returns the arena handle as `* u8` — callers re-cast to
// `* Arena` only inside this module.
fn sfn_arena_sfn_create(default_page_size: usize) -> *u8 {
    let mut page_size: i64 = default_page_size as i64;
    if page_size == 0 { page_size = 1048576; }

    let arena_ptr: *u8 = malloc(24 as usize);
    if arena_ptr as i64 == 0 { return arena_ptr; }

    let first_ptr: *u8 = _sfn_arena_page_create(page_size);
    if first_ptr as i64 == 0 {
        free(arena_ptr);
        return first_ptr;
    }

    let arena: *Arena = arena_ptr as *Arena;
    arena.current_addr = first_ptr as i64;
    arena.first_addr = first_ptr as i64;
    arena.default_page_size = page_size;
    return arena_ptr;
}

// `sfn_arena_sfn_alloc(arena, size, align)` bumps `size` bytes
// (aligned to `align`, defaulting to 8 when the caller passes 0) out
// of the current page. When the current page can't fit, walks the
// downstream chain (pages strictly after `current` survived a prior
// reset and may still have room), then falls back to a fresh page
// sized `max(default_page_size, size + align)` spliced in after the
// current page. Null arena, zero size, or OOM on the fresh-page path
// returns null.
fn sfn_arena_sfn_alloc(arena: *u8, size: usize, align: usize) -> *u8 {
    if arena as i64 == 0 { return null; }
    let size_i: i64 = size as i64;
    if size_i == 0 { return null; }
    let mut align_i: i64 = align as i64;
    if align_i == 0 { align_i = 8; }

    let a: *Arena = arena as *Arena;
    let cur_addr: i64 = a.current_addr;
    if cur_addr == 0 { return null; }
    let page: *ArenaPage = cur_addr as *ArenaPage;

    let offset: i64 = _sfn_arena_align_up(page.used, align_i);
    let cap: i64 = page.capacity;
    if offset <= cap {
        let space: i64 = cap - offset;
        if size_i <= space {
            page.used = offset + size_i;
            let result_addr: i64 = page.data_addr + offset;
            return result_addr as *u8;
        }
    }

    // Walk forward through pages spliced in after the current page.
    // `sfn_arena_sfn_reset` leaves zeroed pages attached so the next
    // burst can refill them without growing the chain — same
    // discipline as the C arena's mark/rewind path
    // (`sailfin_arena.c:172`). The walk is bounded by post-reset
    // pages; in steady state it's usually one hop.
    let mut candidate_addr: i64 = page.next_addr;
    loop {
        if candidate_addr == 0 { break; }
        let candidate: *ArenaPage = candidate_addr as *ArenaPage;
        let cand_cap: i64 = candidate.capacity;
        let cand_offset: i64 = _sfn_arena_align_up(candidate.used, align_i);
        if cand_offset <= cand_cap {
            let cand_space: i64 = cand_cap - cand_offset;
            if size_i <= cand_space {
                candidate.used = cand_offset + size_i;
                a.current_addr = candidate_addr;
                let cand_result_addr: i64 = candidate.data_addr + cand_offset;
                return cand_result_addr as *u8;
            }
        }
        candidate_addr = candidate.next_addr;
    }

    // No reusable downstream page — allocate a fresh one sized for
    // the request (worst-case alignment padding included).
    let mut new_page_size: i64 = a.default_page_size;
    let needed: i64 = size_i + align_i;
    if needed > new_page_size { new_page_size = needed; }

    let new_page_ptr: *u8 = _sfn_arena_page_create(new_page_size);
    if new_page_ptr as i64 == 0 { return new_page_ptr; }

    // Splice the new page in after the current page so any pages
    // already downstream of `current` (carried over from a prior
    // reset) remain reachable for the next burst.
    let new_page: *ArenaPage = new_page_ptr as *ArenaPage;
    new_page.next_addr = page.next_addr;
    page.next_addr = new_page_ptr as i64;
    a.current_addr = new_page_ptr as i64;

    let new_offset: i64 = _sfn_arena_align_up(new_page.used, align_i);
    new_page.used = new_offset + size_i;
    let new_result_addr: i64 = new_page.data_addr + new_offset;
    return new_result_addr as *u8;
}

// ====================================================================
// Bare-named arena core (#1309, C1 of epic #1308).
//
// The C `sfn_arena_create` / `sfn_arena_alloc` / `sfn_arena_global` /
// `sfn_arena_enabled` were removed from the (now-deleted)
// `sailfin_arena.c`; these bare Sailfin exports own those symbol names
// so the linker binds every caller — the `mem.sfn` externs and the
// bare call sites — to the Sailfin definitions. As of #822 the whole
// C arena is gone, so `realloc`/`reset`/`destroy`/`print_stats`/
// `mark`/`rewind` are Sailfin too and operate on the same Sailfin
// 24-byte handle these produce.
//
// `create` and `alloc` are thin forwarders to the `sfn_arena_sfn_*`
// infix bodies above (which own the bump discipline) so there is a
// single implementation of each. The infix family stays exported for
// `ownedbuf.sfn`'s externs.
// `sfn_arena_create(default_page_size)` — bare-named entry point.
// Forwards to `sfn_arena_sfn_create`, which allocates the 24-byte
// handle.
fn sfn_arena_create(default_page_size: usize) -> *u8 {
    return sfn_arena_sfn_create(default_page_size);
}

// `sfn_arena_alloc(arena, size, align)` — bare-named entry point, the
// hot-path bump allocator `mem.sfn`'s `sfn_alloc_struct` and the other
// runtime call sites route through. Forwards to `sfn_arena_sfn_alloc`.
fn sfn_arena_alloc(arena: *u8, size: usize, align: usize) -> *u8 {
    return sfn_arena_sfn_alloc(arena, size, align);
}

// Process-global arena handle (`_global_arena`) + arena-mode flag
// (`_arena_enabled`), lazily initialised. `-1` = unchecked, `0` =
// disabled, `1` = enabled; the address `0` for the global handle
// doubles as "not yet created".
//
// **Thread-safety (known regression vs the C arena — deliberate).** The
// C original guarded both lazy globals with `pthread_once`
// (`sailfin_arena.c:253-254,306,323`). This port replaces that with an
// unsynchronised check-and-set, matching every other lazy global in the
// `runtime/sfn` layer (`mem.sfn:sfn_mem_get_field_buf_addr`,
// `type_meta.sfn`'s registry, `future.sfn`'s scheduler globals) and the
// single-threaded assumption `sfn_alloc_struct` already bakes in. That
// holds for the compiler toolchain itself (compilation is
// single-threaded) but NOT for emitted user binaries that spawn
// `routine`/future threads: two threads racing the first allocation can
// double-create the global arena or observe the provisional `0` mid-
// probe. This is acceptable pre-1.0 — the structured-concurrency runtime
// is not yet shipped (see CLAUDE.md "Deferred / Not Yet Shipped") — and
// is the same exposure the rest of the `runtime/sfn` alloc path carries.
// Re-introducing a `pthread_once`-equivalent is a concurrency-runtime
// concern, tracked there, not part of this M2→M3 arena port.
let mut _sfn_arena_enabled_state: i64 = -1;

let mut _sfn_arena_global_addr: i64 = 0;

// `sfn_arena_enabled()` — `SAILFIN_USE_ARENA` probe, faithful port of
// `_init_arena_enabled` + `sfn_arena_enabled` (`sailfin_arena.c:256,
// 304`). Unset → on (the default). Empty / `0` / `false` → off.
// Anything else → on. Cached after the first probe. The empty-string
// case uses `strcmp(env, "")` rather than a single-byte load — the
// seed compiler's `* u8` byte-load gap (see the file header) makes the
// `env[0] == '\0'` form unavailable here.
fn sfn_arena_enabled() -> bool {
    if _sfn_arena_enabled_state < 0 {
        // Re-entrancy guard (the load-bearing subtlety of this port).
        // A `string` / `* u8` literal lowers to an `sfn_alloc_struct`
        // call that copies the bytes into freshly-allocated memory
        // (verified in the emitted IR: `call i8* @sfn_alloc_struct(i64
        // 18)` for "SAILFIN_USE_ARENA\0"). `sfn_alloc_struct` calls
        // back here to choose arena-vs-calloc, so the env-probe
        // literals below would recurse infinitely from the very first
        // call (the startup `_sfn_default_arena_init` constructor).
        // Publishing a provisional non-negative state BEFORE any
        // allocation breaks the cycle: the re-entrant call sees
        // `state >= 0` and returns immediately. Provisional `0`
        // (disabled) routes the probe's own SfnString allocations
        // through the libc `calloc` fallback rather than forcing the
        // global arena into existence mid-probe.
        _sfn_arena_enabled_state = 0;
        // Bind each literal to a `string` local before the `as * u8`
        // cast — the proven env-read pattern from `rlimit.sfn` /
        // `http.sfn`. The inline form `getenv("…" as * u8)` miscompiles
        // under the seed: the call is elided and its result lowered to a
        // null store, so every env value reads as "unset". The `string`
        // local materialises the `SfnString` (allocated via
        // `sfn_alloc_struct` — safe now, the provisional state above
        // routes it through the libc fallback) and the cast extracts its
        // data pointer correctly.
        let name: string = "SAILFIN_USE_ARENA";
        let env: *u8 = getenv(name as *u8);
        if env as i64 == 0 {
            // Unset: take the default (arena on).
            _sfn_arena_enabled_state = 1;
        } else {
            let empty: string = "";
            let zero: string = "0";
            let f: string = "false";
            if strcmp(env, empty as *u8) == 0 { _sfn_arena_enabled_state = 0; } else if strcmp(env, zero as *u8) == 0 {
                _sfn_arena_enabled_state = 0;
            } else if strcmp(env, f as *u8) == 0 {
                _sfn_arena_enabled_state = 0;
            } else { _sfn_arena_enabled_state = 1; }
        }
    }
    return _sfn_arena_enabled_state == 1;
}

// `sfn_arena_global()` — lazy process-global arena (4 MiB pages for the
// compiler), faithful port of `_init_global_arena` + `sfn_arena_global`
// (`sailfin_arena.c:310,321`). Creates the handle on first call;
// `abort()`s if creation fails (the lowered call sites GEP+store into
// the returned base with no null-check, so a silent NULL would surface
// as a bare SIGSEGV — `abort` turns OOM into a clean SIGABRT).
//
// The C original printed "[sailfin-arena] fatal: …" before aborting,
// but a message here is unshippable: emitting one builds an `SfnString`
// via `sfn_alloc_struct`, which (arena enabled) re-enters
// `sfn_arena_global` with `_sfn_arena_global_addr` still 0 and recurses
// until the stack overflows — turning a clean OOM abort into a crash.
// The bare `abort()` (SIGABRT) is the faithful, recursion-free signal.
fn sfn_arena_global() -> *u8 {
    if _sfn_arena_global_addr == 0 {
        let created: *u8 = sfn_arena_sfn_create(4194304 as usize);
        if created as i64 == 0 {
            unsafe { abort(); }
        }
        _sfn_arena_global_addr = created as i64;
    }
    return _sfn_arena_global_addr as *u8;
}

// `sfn_arena_sfn_reset(arena)` zeroes the `used` cursor on every
// page in the chain and parks the bump target on the first page.
// Pages keep their backing buffers — the chain stays intact so the
// next burst reuses memory rather than re-malloc'ing pages. Null
// arena is a no-op.
fn sfn_arena_sfn_reset(arena: *u8) -> void {
    if arena as i64 == 0 { return; }
    let a: *Arena = arena as *Arena;
    let first_addr: i64 = a.first_addr;
    let mut walker: i64 = first_addr;
    loop {
        if walker == 0 { break; }
        let p: *ArenaPage = walker as *ArenaPage;
        p.used = 0;
        walker = p.next_addr;
    }
    a.current_addr = first_addr;
    // The page chain stays intact for reuse — only the per-page `used`
    // cursors (zeroed above) and the bump target reset.
}

// `sfn_arena_sfn_destroy(arena)` frees every page in the chain and
// the arena handle itself. Null arena is a no-op so cleanup paths
// can call destroy unconditionally.
fn sfn_arena_sfn_destroy(arena: *u8) -> void {
    if arena as i64 == 0 { return; }
    let a: *Arena = arena as *Arena;
    let mut walker: i64 = a.first_addr;
    loop {
        if walker == 0 { break; }
        let page: *ArenaPage = walker as *ArenaPage;
        let next_addr: i64 = page.next_addr;
        _sfn_arena_page_destroy(walker);
        walker = next_addr;
    }
    free(arena);
}

// `sfn_arena_sfn_realloc(arena, ptr, old_size, new_size, align)`
// implements the grow-if-at-tip optimization the `string_append` hot
// path depends on. When `ptr + old_size` is exactly the current
// page's bump tip and the page has room for the delta, extend the
// bump cursor in place — no copy. Otherwise fresh-alloc + memcpy and
// "leak" the old buffer into the arena (reclaimed at the next
// reset/destroy). Behaviour matches `sailfin_arena.c:208` exactly.
// Special cases: null arena returns null; null `ptr` forwards to
// `sfn_arena_sfn_alloc`; `new_size <= old_size` returns `ptr`
// unchanged.
fn sfn_arena_sfn_realloc(arena: *u8, ptr: *u8, old_size: usize, new_size: usize, align: usize) -> *u8 {
    if arena as i64 == 0 { return null; }
    if ptr as i64 == 0 {
        return sfn_arena_sfn_alloc(arena, new_size, align);
    }

    let old_size_i: i64 = old_size as i64;
    let new_size_i: i64 = new_size as i64;
    if new_size_i <= old_size_i { return ptr; }

    let a: *Arena = arena as *Arena;
    let cur_addr: i64 = a.current_addr;
    if cur_addr == 0 { return null; }
    let page: *ArenaPage = cur_addr as *ArenaPage;

    let data_addr: i64 = page.data_addr;
    let used: i64 = page.used;
    let tip_addr: i64 = data_addr + used;
    let ptr_addr: i64 = ptr as i64;
    let extra: i64 = new_size_i - old_size_i;

    // Grow-if-at-tip: `ptr` was the last allocation on this page AND
    // the page can fit `extra` more bytes. The in-place bump and the
    // relocate+memcpy fallback are the author-asserted raw region
    // (#1217, proposal §5.1): soundness is guaranteed by the *caller*
    // holding a unique `OwnedBuf` (`owned_buf_append`), which the
    // ownership checker proves — the in-place mutation of a
    // possibly-aliased buffer (the #1205 hazard) is unreachable from
    // safe code. The bump arithmetic stays `unsafe`-internal.
    unsafe {
        if ptr_addr + old_size_i == tip_addr {
            if used + extra <= page.capacity {
                page.used = used + extra;
                return ptr;
            }
        }

        // Otherwise: fresh allocation + memcpy. The old buffer stays
        // resident in the arena (reclaimed at reset/destroy).
        let new_ptr: *u8 = sfn_arena_sfn_alloc(arena, new_size, align);
        if new_ptr as i64 == 0 { return new_ptr; }
        memcpy(new_ptr, ptr, old_size_i as usize);
        return new_ptr;
    }
}

// `sfn_arena_realloc(arena, ptr, old_size, new_size, align)` — bare-named
// entry point. Forwards to `sfn_arena_sfn_realloc`, which owns the
// grow-if-at-tip discipline. Mirrors the `sfn_arena_alloc` forwarder
// (#1309): the C `sfn_arena_realloc` body retires, this becomes the link
// target for both the `string.sfn` concat/append path and the C-internal
// `sailfin_runtime.c` callers (which bind to it through the surviving
// `sailfin_arena.h` prototype). Faithful to `sailfin_arena.c:113`.
fn sfn_arena_realloc(arena: *u8, ptr: *u8, old_size: usize, new_size: usize, align: usize) -> *u8 {
    return sfn_arena_sfn_realloc(arena, ptr, old_size, new_size, align);
}

// ====================================================================
// Mark / rewind over the process-global arena (#927, sub-issue of
// #390). Port of the double-encoding wrappers
// `sailfin_intrinsic_runtime_arena_mark` /
// `sailfin_intrinsic_runtime_arena_rewind`
// (the retired C runtime, formerly `sailfin_runtime.c:7811,7834`), NOT the
// low-level struct-returning `sfn_arena_mark` /  `sfn_arena_rewind`
// (`sailfin_arena.c:94,104`). The runtime-helper descriptors flip
// `sailfin_intrinsic_runtime_arena_mark` →
// `native_signature: "sfn_arena_sfn_mark"` and `…_rewind` →
// `"sfn_arena_sfn_rewind"`, so the in-process `sfn check` / `sfn test`
// scratch loop (the only caller) routes here.
//
// Export naming: the directed `sfn_arena_mark` / `sfn_arena_rewind`
// names in the issue collide with the C arena's *live* exports of
// exactly those names (`nm` shows `T sfn_arena_mark` /
// `T sfn_arena_rewind`; they retire only at M3). Defining Sailfin
// bodies under those names would be a duplicate-symbol link failure.
// We therefore use this module's established `sfn_arena_sfn_*` infix —
// the same collision-avoidance the five core arena exports use.
//
// The mark is encoded as a Sailfin `number` (LLVM `double`): the C
// wrapper packs `(page_index << 32) | (used & 0xFFFFFFFF)` into the
// low 53 mantissa bits and round-trips it through `double`. Bit-shift
// / mask / `i64 ⇄ f64` round-tripping is verified to lower and execute
// correctly on the seed.
//
// Semantics of the encoded value `0` (matching the C wrapper exactly):
//   - When the arena is **disabled** (`!sfn_arena_enabled()`),
//     `sfn_arena_sfn_mark` returns `0.0` and `sfn_arena_sfn_rewind`
//     early-returns before decoding — so a mark/rewind pair around a
//     disabled arena is a genuine no-op.
//   - When the arena is **enabled**, `0` decodes to `page_index = 0,
//     used = 0`, i.e. "rewind the first page to offset 0 and zero
//     every later page." That is a real *partial reset to the chain
//     head*, NOT a no-op. A caller that took a mark *after* allocating
//     on page 0 and then rewinds `0` will discard those allocations.
//     Callers must therefore pair a rewind with the value an actual
//     `sfn_arena_sfn_mark` returned, never a hardcoded `0`, unless a
//     reset-to-head is the intent.
//
// The arena structs are read by raw field offset (the `_addr`
// discipline this module already uses):
//   Arena      { current@0, first@8, default_page_size@16 }
//   ArenaPage  { data@0, capacity@8, used@16, next@24 }
// (#822: the C `SfnArena` and its `sailfin_arena.h` header are deleted;
// the handle dropped the transition-only `total_allocated@24` /
// `total_pages@32` counters back to its natural 24-byte layout.)
// arena-mode probe + process-global arena handle. As of #1309 both are
// **defined above** in this module (the bare `sfn_arena_enabled` /
// `sfn_arena_global` Sailfin exports that replaced the C namesakes), so
// mark/rewind call them directly — no extern needed.
// `sfn_arena_sfn_mark()` snapshots the global arena's current page +
// used offset, encoded as `(page_index << 32) | used` cast to a
// `number`. Returns `0.0` when the arena is disabled or has no current
// page (round-trips to a no-op rewind). Faithful port of
// `sailfin_intrinsic_runtime_arena_mark`. Descriptor ABI: `() ->
// double`.
fn sfn_arena_sfn_mark() -> number {
    if !sfn_arena_enabled() { return 0.0; }

    let arena_ptr: *u8 = sfn_arena_global();
    if arena_ptr as i64 == 0 { return 0.0; }

    let arena: *Arena = arena_ptr as *Arena;
    let current_addr: i64 = arena.current_addr;
    if current_addr == 0 { return 0.0; }

    // Snapshot the current page's used offset.
    let current_page: *ArenaPage = current_addr as *ArenaPage;
    let used: i64 = current_page.used;

    // Index of the current page within the first→next chain.
    let mut page_index: i64 = 0;
    let mut walker: i64 = arena.first_addr;
    loop {
        if walker == 0 { break; }
        if walker == current_addr { break; }
        let p: *ArenaPage = walker as *ArenaPage;
        walker = p.next_addr;
        page_index = page_index + 1;
    }

    let encoded: i64 = (page_index << 32) | (used & 4294967295);
    return encoded as number;
}

// `sfn_arena_sfn_rewind(encoded_mark)` walks back to the marked page,
// zeroes `used` on every page strictly after it, rewinds the marked
// page to its snapshot offset, and re-parks `current` there. Out-of-
// range / corrupt marks bail silently (better than crashing). No-op
// when the arena is disabled or empty. Faithful port of
// `sailfin_intrinsic_runtime_arena_rewind`. Descriptor ABI: `(double)
// -> void`.
fn sfn_arena_sfn_rewind(encoded_mark: number) -> void {
    if !sfn_arena_enabled() { return; }

    let arena_ptr: *u8 = sfn_arena_global();
    if arena_ptr as i64 == 0 { return; }
    let arena: *Arena = arena_ptr as *Arena;
    if arena.first_addr == 0 { return; }

    let encoded: i64 = encoded_mark as i64;
    let page_index: i64 = encoded >> 32;
    let used: i64 = encoded & 4294967295;

    // Walk to the marked page. If page_index runs off the end (arena
    // reset between mark and rewind, corrupt mark, etc.) bail.
    let mut walker: i64 = arena.first_addr;
    let mut i: i64 = 0;
    loop {
        if walker == 0 { break; }
        if i >= page_index { break; }
        let p: *ArenaPage = walker as *ArenaPage;
        walker = p.next_addr;
        i = i + 1;
    }
    if walker == 0 { return; }

    let mark_page: *ArenaPage = walker as *ArenaPage;

    // Zero `used` on every page strictly after the marked page so the
    // next burst reuses their capacity instead of growing the chain.
    let mut after_addr: i64 = mark_page.next_addr;
    loop {
        if after_addr == 0 { break; }
        let after_page: *ArenaPage = after_addr as *ArenaPage;
        after_page.used = 0;
        after_addr = after_page.next_addr;
    }

    // Rewind the marked page to the snapshot offset and make it the
    // current allocation target.
    mark_page.used = used;
    arena.current_addr = walker;
}

// ====================================================================
// Arena statistics (#1309). Port of the atexit telemetry helper
// `sfn_arena_print_stats` (`sailfin_arena.c:139`), the last live
// consumer of which is the C runtime's process-exit path
// (`sailfin_runtime.c:713`). The bare `sfn_arena_print_stats` forwarder
// below is the link target that caller binds to by name.
//
// Telemetry precision is non-contractual, so this renders raw byte
// counts as plain integers (no float MB formatting) and utilization as
// an integer percent — sidestepping float formatting entirely while
// keeping the grep-recognizable token shape:
//   [sailfin-arena] pages=<N> capacity=<bytes> used=<bytes> allocated=<bytes> utilization=<pct>%
//
// Integers are formatted inline — arena.sfn is emitted and linked
// **standalone** by `test_runtime_memory_arena.sh`, so it must not
// reference `string.sfn`'s `sfn_int_to_str` (which would fail that
// link). The byte stores reuse the same word-aligned
// `atomic_load`/`atomic_store` discipline as `string.sfn`'s
// `_num_put_byte`, so a single-byte write never races a neighbouring
// byte in the same 8-byte word.
// `_arena_put_byte(addr, value)` stores one byte at `addr` via a
// read-modify-write on its enclosing 8-byte word. Same construction as
// `string.sfn::_num_put_byte`.
fn _arena_put_byte(addr: i64, value: i64) -> void {
    let word_addr: i64 = (addr / 8) * 8;
    let shift: i64 = (addr - word_addr) * 8;
    let slot: *i64 = word_addr as *i64;
    let word: i64 = atomic_load(slot);
    let mask: i64 = 255 << shift;
    let current: i64 = word & mask;
    let placed: i64 = (value & 255) << shift;
    atomic_store(slot, (word - current) + placed);
}

// `_arena_write_lit(s)` writes a NUL-terminated string literal to fd 2
// using its `strlen`. Used for the fixed label tokens.
fn _arena_write_lit(s: *u8) -> void ![io] {
    if s as i64 == 0 { return; }
    let _ = write(2, s, strlen(s));
}

// `_arena_write_i64(value)` renders a non-negative i64 as decimal into a
// small malloc'd scratch buffer and writes it to fd 2. The stats values
// (page count, byte sums, percent) are all non-negative, so no sign
// handling is needed; a 20-byte buffer holds any i64's decimal digits.
fn _arena_write_i64(value: i64) -> void ![io] {
    let buf: *u8 = malloc(24 as usize);
    if buf as i64 == 0 { return; }
    let base: i64 = buf as i64;

    if value == 0 {
        _arena_put_byte(base, 48);
        let _ = write(2, buf, 1 as usize);
        free(buf);
        return;
    }

    // Count digits.
    let mut nd: i64 = 0;
    let mut t: i64 = value;
    loop {
        if t == 0 { break; }
        t = t / 10;
        nd = nd + 1;
    }

    // Write least-significant digit first into the reserved span.
    let mut wp: i64 = nd - 1;
    let mut x: i64 = value;
    loop {
        if x == 0 { break; }
        let d: i64 = x % 10;
        _arena_put_byte(base + wp, 48 + d);
        wp = wp - 1;
        x = x / 10;
    }

    let _ = write(2, buf, nd as usize);
    free(buf);
}

// `sfn_arena_sfn_print_stats(arena)` walks the page chain summing each
// page's `capacity` and `used` and counting pages. **All sums/counts
// are computed first** so the reported numbers are a clean snapshot —
// the subsequent rendering `malloc`s scratch from libc (not this
// arena), but even so the figures are already captured into locals and
// cannot be perturbed. Null arena is a no-op.
//
// #822: the `allocated=` token (the old raw-requested-byte counter)
// retired with the handle's `total_allocated` field — `used=` (bumped
// bytes, derived from the page walk) is the surviving consumption
// metric. Telemetry precision is non-contractual (#1432); only the
// `pages=`/`used=` tokens are pinned by tests.
fn sfn_arena_sfn_print_stats(arena: *u8) -> void ![io] {
    if arena as i64 == 0 { return; }
    let a: *Arena = arena as *Arena;

    // Snapshot pass: walk first→next summing capacity/used and counting
    // pages before any rendering happens.
    let mut total_capacity: i64 = 0;
    let mut total_used: i64 = 0;
    let mut page_count: i64 = 0;
    let mut walker: i64 = a.first_addr;
    loop {
        if walker == 0 { break; }
        let p: *ArenaPage = walker as *ArenaPage;
        total_capacity = total_capacity + p.capacity;
        total_used = total_used + p.used;
        page_count = page_count + 1;
        walker = p.next_addr;
    }

    // Integer-percent utilization (0 when there is no capacity).
    let mut utilization: i64 = 0;
    if total_capacity > 0 {
        utilization = (total_used * 100) / total_capacity;
    }

    // Render after the snapshot is fully captured.
    let prefix: string = "[sailfin-arena] pages=";
    let sep_capacity: string = " capacity=";
    let sep_used: string = " used=";
    let sep_util: string = " utilization=";
    let suffix: string = "%\n";

    _arena_write_lit(prefix as *u8);
    _arena_write_i64(page_count);
    _arena_write_lit(sep_capacity as *u8);
    _arena_write_i64(total_capacity);
    _arena_write_lit(sep_used as *u8);
    _arena_write_i64(total_used);
    _arena_write_lit(sep_util as *u8);
    _arena_write_i64(utilization);
    _arena_write_lit(suffix as *u8);
}

// `sfn_arena_print_stats(arena)` — bare-named entry point. Forwards to
// `sfn_arena_sfn_print_stats`. Mirrors the `sfn_arena_realloc` forwarder
// (#1309): the C `sfn_arena_print_stats` body retires, this becomes the
// link target the C-runtime atexit telemetry path
// (`sailfin_runtime.c:713`) binds to by name.
fn sfn_arena_print_stats(arena: *u8) -> void ![io] {
    sfn_arena_sfn_print_stats(arena);
}

// `sfn_arena_telemetry_dump(label)` — emit the arena-stats telemetry line
// to stderr if `SAILFIN_DUMP_ARENA_STATS` is truthy. Sailfin replacement
// for the retired C atexit hook `sailfin_runtime_install_arena_telemetry`
// (#822 / #1308): the install-an-atexit-callback mechanism needed a
// frontend address-of-function primitive that does not exist, so the dump
// is invoked inline at the single exit funnel of `fn main`
// (`compiler/src/cli_main.sfn`) instead — covering every normal `sfn`
// completion (the only loss vs. atexit is a dump on a mid-build abort,
// which is acceptable for debug-only telemetry).
//
// Output shape (the C `_arena_stats_atexit` this replaced is deleted):
//   enabled : `[sailfin-arena] label=<label> ` + `sfn_arena_print_stats`
//   disabled: `[sailfin-arena] label=<label> stats=disabled (SAILFIN_USE_ARENA="<v>" opt-out)\n`
// Pinned by `compiler/tests/e2e/arena_default_on_test.sfn` and
// `compiler/tests/e2e/test_check_resolver_scan_memo.sh` (both assert
// only the `pages=` token, not the retired `allocated=` field).
//
// `SAILFIN_DUMP_ARENA_STATS` gate mirrors the C
// `_arena_stats_telemetry_enabled`: truthy means non-null, non-empty, and
// first byte != '0'. `load_byte` reads the first byte directly (the seed's
// `* u8` byte-load gap is closed as of the pinned seed; `string.sfn`
// already relies on it). Each literal is bound to a `string` local before
// the `as * u8` cast — the proven env-read pattern (`getenv("…" as * u8)`
// miscompiles inline under the seed; see `sfn_arena_enabled` above).
fn sfn_arena_telemetry_dump(label: *u8) -> void ![io] {
    let dump_name: string = "SAILFIN_DUMP_ARENA_STATS";
    let flag: *u8 = getenv(dump_name as *u8);
    if flag as i64 == 0 { return; }
    let b0: i64 = load_byte(flag as i64);
    if b0 == 0 { return; }
    if b0 == 48 { return; }

    let prefix: string = "[sailfin-arena] label=";
    let sep: string = " ";
    _arena_write_lit(prefix as *u8);
    _arena_write_lit(label);
    _arena_write_lit(sep as *u8);

    if sfn_arena_enabled() {
        sfn_arena_sfn_print_stats(sfn_arena_global());
    } else {
        let use_name: string = "SAILFIN_USE_ARENA";
        let optout: *u8 = getenv(use_name as *u8);
        let head: string = "stats=disabled (SAILFIN_USE_ARENA=\"";
        let tail: string = "\" opt-out)\n";
        _arena_write_lit(head as *u8);
        if optout as i64 != 0 { _arena_write_lit(optout); }
        _arena_write_lit(tail as *u8);
    }
}
