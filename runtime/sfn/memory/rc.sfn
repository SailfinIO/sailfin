// runtime/sfn/memory/rc.sfn
//
// Sailfin-native reference counting primitive linked into the
// `build/bin/sfn` binary. M2.3
// (issue #395, epic #389) lights up the second Sailfin-defined
// runtime module after `runtime/sfn/memory/arena.sfn`.
//
// Header layout (16 bytes, per `docs/proposals/0025-native-runtime-architecture.md`
// `#322-reference-counting`):
//
//   offset 0:  refcount (i64)   — atomic refcount, init 1
//   offset 8:  drop_fn  (* u8)  — `fn(*u8) -> void` storage
//
// The header sits at `payload - 16`; `sfn_rc_sfn_alloc` returns
// the payload pointer so user code never sees the bookkeeping
// slot. `sfn_rc_sfn_retain` / `sfn_rc_sfn_release` step back to
// the refcount field via pointer arithmetic and emit LLVM
// `atomicrmw add` / `atomicrmw sub` with `seq_cst` ordering —
// the IR shape that the test harness pins as the M2.3 proof of
// life.
//
// drop_fn storage is a proper `* u8` pointer field. The #713
// fix (pointer-typed struct-field layout + store, in the pinned
// seed) lets `header.drop_fn = drop_fn;` emit a real `store i8*`
// with no `as i64` / `ptrtoint` bridge — the `i64`-slot
// workaround introduced in M2.3 (PR #712) is retired here (#1115).
// The architecture spec's `drop_fn: fn(*u8) -> void` shape still
// degrades to `* u8` at the export boundary — the typed
// function-pointer slot is gated separately on
// `is_c_abi_function_pointer` accepting the `fn (...)` form
// (tracked for M2.4/M2.6, where `sfn_drop_SfnString` /
// `sfn_drop_SfnArray` callers light up).
//
// drop_fn **invocation** lives in the issue's `Out:` list and
// is deferred to M2.4/M2.6. M2.3 stores the address but never
// dereferences it; releases that hit zero call `free` directly
// and skip the destructor hook. The roundtrip test in
// `compiler/tests/e2e/test_runtime_memory_rc.sh` passes a null
// drop_fn so this gap is explicitly modeled.
//
// Naming: every export uses the `sfn_rc_sfn_*` infix so the
// Sailfin module coexists with the C runtime's existing
// `sfn_rc_release` no-op stub in
// the retired C runtime (formerly `sailfin_runtime.c:1885`, M1.5.2 placeholder
// from #326) without a link-time collision. Mirrors the
// `sfn_arena_sfn_*` infix in `runtime/sfn/memory/arena.sfn` and
// the same rationale documented there. When M3 retires the C
// stub, these symbols rename to the bare canonical form
// (`sfn_rc_alloc` / `sfn_rc_retain` / `sfn_rc_release`) in a
// single rollback-safe PR.
//
// Effects: none. Memory primitives live below the I/O layer
// (same discipline as `runtime/sfn/memory/arena.sfn` and the
// other `runtime/sfn/*` modules). The `![io]` / `![clock]`
// annotations attach to *adapters* that wrap these primitives,
// never to the primitives themselves.
//
// Why inline `extern fn malloc / free`? The same reason
// `arena.sfn` does: importing from `runtime/sfn/platform/libc.sfn`
// would force a typecheck of `sailfin_runtime_sleep(milliseconds:
// float)` and trip the seed's pre-`float` extern accept-list
// (E0805). Inlining the two declarations we need keeps this
// module self-contained for every seed, regardless of the
// libc.sfn declaration surface.
extern fn malloc(size: usize) -> *u8;

extern fn free(ptr: *u8) -> void;

// `RcHeader` lays out the 16-byte bookkeeping prefix. The
// architecture spec's `drop_fn: fn(*u8) -> void` field appears
// here as `drop_fn: * u8` — see the file-header note for the
// storage-type rationale. The pointer field is 8 bytes, so the
// header stays 16 bytes with refcount @0 and drop_fn @8.
struct RcHeader {
    refcount: i64;
    drop_fn: *u8;
}

// `sfn_rc_sfn_alloc(size, drop_fn)` allocates a 16-byte header
// plus `size` payload bytes, initializes the refcount to 1,
// stores `drop_fn` in the header drop-fn slot, and returns the
// payload pointer. The header is
// reachable from the payload via `payload - 16`. Returns `null`
// when libc `malloc` reports OOM — guarding the header
// initialisation stores against a NULL deref. The C convention
// (callers check the return) holds until `Result<T, E>` + `?`
// ship (Phase 1 of the runtime prereqs in CLAUDE.md). Architect
// spec: `docs/proposals/0025-native-runtime-architecture.md` `#322-reference-counting`.
fn sfn_rc_sfn_alloc(size: i64, drop_fn: *u8) -> *u8 {
    // Raw allocation + header-init interior (#1218 / E9, proposal §5.1):
    // the libc `malloc`, the raw-pointer header field stores, and the
    // payload pointer arithmetic are the author-asserted unsafe region.
    // The freshly-allocated block is uniquely owned by construction — no
    // alias exists yet — so the in-place header initialisation is sound.
    // Completes the memory-core migration after E8 (#1217) by giving
    // rc.sfn the same explicit unsafe boundary the arena/string hot path
    // already carries.
    unsafe {
        let header_ptr = malloc((size + 16) as usize);
        if header_ptr as i64 == 0 { return header_ptr; }
        let header = header_ptr as *RcHeader;
        header.refcount = 1;
        header.drop_fn = drop_fn;
        return header_ptr + 16;
    }
}

// `sfn_rc_sfn_retain(payload)` atomically increments the
// refcount of the value at `payload`. Steps back 16 bytes
// (two 8-byte slots — the `i64` refcount at slot 0, the `* u8`
// drop_fn at slot 1) to reach the refcount field, then emits
// `atomicrmw add ptr %p,
// i64 1 seq_cst, align 8`. The previous-value return from
// `atomic_add` is intentionally discarded — retains do not need
// to observe the old count.
fn sfn_rc_sfn_retain(payload: *u8) -> void {
    let slots = payload as *i64;
    let refcount_ptr = slots - 2;
    atomic_add(refcount_ptr, 1);
}

// `sfn_rc_sfn_release(payload)` atomically decrements the
// refcount and frees the allocation when the previous value was
// 1 (i.e. this release dropped the last reference). Emits
// `atomicrmw sub ptr %p, i64 1 seq_cst, align 8`. drop_fn
// invocation is deferred to M2.4/M2.6 per the issue's `Out:`
// scope; the released allocation is freed directly via libc
// `free` once SfnString / SfnArray drop synthesis ships, this
// body inserts a `drop_fn(payload)` call ahead of the `free`.
fn sfn_rc_sfn_release(payload: *u8) -> void {
    let slots = payload as *i64;
    let refcount_ptr = slots - 2;
    let prev = atomic_sub(refcount_ptr, 1);
    // Release-to-zero disposal (#1218 / E9, proposal §5.1): the `prev ==
    // 1` guard proves this release dropped the *last* live reference —
    // no other alias can still observe the header — so the raw libc
    // `free` is sound. This is the structural analogue of the ownership
    // checker's no-live-alias proof for `E0903` (use-after-free): the
    // raw-pointer free is the author-asserted unsafe region, and the
    // atomic refcount reaching zero is the uniqueness proof.
    if prev == 1 {
        unsafe { free(refcount_ptr as *u8); }
    }
}
