// runtime/sfn/adapters/http.sfn
//
// First-wave Sailfin-native HTTP/1.1 client adapter (M3, #818 —
// epic #390 / tracker #321). Replaces the curl-subprocess HTTP
// path (`sailfin_runtime_http_get` / `_post_json` / `_download`
// in the retired C runtime, which shell out to
// `curl -sfS`) with a pure-Sailfin socket client built on the
// BSD-sockets surface declared in `runtime/sfn/platform/net.sfn`.
// Mirrors the migration shape of `runtime/sfn/adapters/filesystem.sfn`
// (M3.1, #814/#815) and `runtime/sfn/process.sfn` (M2.9).
//
// Scope: HTTP and outbound HTTPS. The `https://` path (get / post /
// download, via `_http_send`, typed fetch via `sfn_http_request_raw`, and
// keep-alive via `sfn_http_conn_*`) TLS-wraps its connected socket through
// `../platform/tls.sfn` (OpenSSL, SFEP-0036 gap B1 / #1782): default port
// 443, SNI = host, peer chain verified AND hostname checked (RFC 6125);
// system trust-store discovery hardening is #3.
//
// ABI. `compiler/src/llvm/runtime_helpers.sfn` flips the curl
// registry rows by setting `native_signature` to the symbols
// defined here, exactly as the `fs.*` rows were flipped to
// `sfn_fs_*` (the legacy C `symbol` stays for seed compat):
//   - `http.get_body`  (url)               -> `sfn_http_get`
//   - `http.post_json` (url, body, auth)   -> `sfn_http_post`
//   - `http.download`  (url, output_path)  -> `sfn_http_download`
//   - `http_get`       (url)               -> `sfn_http_get`
//   - `http_post`      (request, body)      -> `sfn_http_post2`
// All descriptors keep their existing `i8*`-in / `i8*`-out shape
// (raw NUL-terminated `* u8` buffers, no arena threading) — the
// same plain-pointer ABI the `sfn_fs_*` adapters use. The issue's
// `*Arena` / `SfnString` shorthand would require retyping the
// descriptors to the aggregate ABI and threading an arena through
// `core_call_lowering.sfn` (not in this issue's Files Affected);
// matching the proven `fs.*` raw-pointer shape keeps the flip
// self-contained.
//
// The two POST arities exist because the registry carries two
// rows of different arity: `http.post_json` is (url, body,
// auth_header) and the `http_post` alias is (request, body). The
// alias points at `sfn_http_post2`, a 2-arg wrapper that forwards
// to `sfn_http_post` with an empty auth header.
//
// Return semantics (matching the curl bodies they replace):
//   - get / post: the response BODY (headers stripped), null on a
//     socket/connect failure or an HTTP status >= 400 (mirrors
//     curl `-f`).
//   - download: the literal `"ok"` on success, null on failure
//     (mirrors `sailfin_runtime_http_download`'s contract). Writes
//     the body to `output_path` in binary mode.
//
// Host resolution: numeric dotted-quad IPv4 (`atoi` per octet, each
// validated to 0..255), a `localhost` -> 127.0.0.1 special case, and real
// DNS via `getaddrinfo` for any other hostname (#1540 B2 — first IPv4/A
// record only, no AAAA, no caching, no happy-eyeballs).
//
// `Transfer-Encoding: chunked` responses ARE decoded on the
// get/post/download body-extraction path (`_extract_body` ->
// `_decode_chunked`, #1708): the chunk framing is stripped and the
// chunk data concatenated into the body. HTTP 3xx redirects are
// followed (up to a bounded hop limit) so GitHub release-asset URLs —
// which 302 to a signed CDN URL — download faithfully (SFN-213); see
// `_http_send`. Response bodies are length-tracked end-to-end
// (`_recv_all` -> `_extract_body`), so binary payloads with embedded
// NULs download faithfully even though the get/post `i8*` return is
// also NUL-terminated for string use.
//
// Effects: `![net]` for get/post, `![net, io]` for download (it
// opens a file). The flipped descriptors carry the same effects, so
// calling `http.get_body` / `http.post_json` without `![net]` (or
// `http.download` without `![net, io]`) on the call chain remains a
// compile-time error after the flip.
//
// Why inline the externs rather than `import` from
// `../platform/net.sfn` / `../platform/libc.sfn`? Same rationale as
// every other `runtime/sfn/*.sfn` module (see `filesystem.sfn`
// header, ~line 108): the seed compiler reaches the cross-module
// extern resolver through a path #306 has not closed, so inlining
// the declarations keeps this module self-contained for every seed.
// A follow-up PR flips these to imports once #306 lands, without
// touching the bodies. Declaring the same C symbol in two modules
// is safe — each emits its own LLVM `declare` and the linker
// resolves both to the single libc / libc-socket entrypoint (see
// the `net.sfn` symbol-collision note).
//
// Decimal byte constants (no char/octal literals in the seed):
//   46 = '.'   47 = '/'   58 = ':'   32 = ' '   48 = '0'
//   111 = 'o'  107 = 'k'
// AF_INET = 2, SOCK_STREAM = 1 (identical on Linux x86_64 and
// macOS arm64, the two targets this runtime builds for).
//
// Pinned by `compiler/tests/e2e/test_runtime_adapter_http.sh`
// (typecheck + fmt + emit-define shape over the exports + an IR
// routing probe + a behavioral round-trip against a localhost
// listener).
// TLS client wrappers (SFEP-0036, gap B1): the `https://` path wraps its
// connected socket via these helpers, whose bodies live in
// `../platform/tls.sfn`. Declared here as `extern fn` FORWARD-DECLARATIONS
// rather than `import`ed for the SAME #306 reason the libc externs below
// are inlined: a cross-module `import` is resolved from a staged
// import-context that the standalone per-module runtime emit (the
// `ci-cross-windows` bridge, which emits `http.sfn` in isolation) does not
// stage, so lowering fails with "callee signature is not known". A forward
// declaration makes this module self-contained for every emit path; the
// linker resolves each `@tls_*` symbol to `tls.sfn`'s definition in the
// full runtime link (unmangled external linkage, same as the `sfn_http_*`
// exports). On the Windows cross-build — where `tls.sfn` is excluded (it
// pulls OpenSSL, deferred to #1485 M10) — they resolve to the no-op stubs
// in `runtime/ir/windows_stubs.ll`, so `https://` degrades to a clean null
// there. (The runtime effect is identical to the prior `import`; only the
// resolution mechanism changes.)
extern fn tls_client_ctx() -> *u8;

extern fn tls_ctx_free(ctx: *u8) -> void;

extern fn tls_connect_fd(ctx: *u8, fd: i32, host: *u8) -> *u8;

extern fn tls_read(ssl: *u8, buf: *u8, n: i64) -> i64;

extern fn tls_write(ssl: *u8, buf: *u8, n: i64) -> i64;

extern fn tls_shutdown_free(ssl: *u8) -> void;

// Keep-alive TLS registry head. Plain HTTP handles remain the raw fd; HTTPS
// handles are the same fd plus a registry row that owns SSL*/SSL_CTX*.
extern var http_conn_tls_head: *u8 = null;

// ── libc memory + string helpers ──────────────────────────────
extern fn malloc(size: usize) -> *u8;

extern fn free(ptr: *u8) -> void;

extern fn realloc(ptr: *u8, new_size: usize) -> *u8;

extern fn memset(dst: *u8, byte: i32, n: usize) -> *u8;

extern fn memcpy(dst: *u8, src: *u8, n: usize) -> *u8;

extern fn strlen(s: *u8) -> usize;

extern fn strchr(s: *u8, c: i32) -> *u8;

extern fn strstr(haystack: *u8, needle: *u8) -> *u8;

extern fn strcmp(a: *u8, b: *u8) -> i32;

// C `int atoi(const char *)` — parses a leading decimal integer,
// stops at the first non-digit. Declared `-> i32` to match the C
// 32-bit return (a 64-bit declaration would read undefined upper
// bits); octet / port values fit comfortably.
extern fn atoi(s: *u8) -> i32;

// ── BSD sockets (libc) ────────────────────────────────────────
// `addr` is spelled `* u8` (the `net.sfn` opaque-handle policy:
// adapters cast the family-specific sockaddr struct through `* u8`
// at the call site). Identical C ABI to `const struct sockaddr *`.
extern fn socket(domain: i32, ty: i32, protocol: i32) -> i32;

extern fn connect(sockfd: i32, addr: *u8, addrlen: i32) -> i32;

extern fn send(sockfd: i32, buf: *u8, len: i64, flags: i32) -> i64;

extern fn recv(sockfd: i32, buf: *u8, len: i64, flags: i32) -> i64;

extern fn close(fd: i32) -> i32;

// `setsockopt` — arm SO_RCVTIMEO / SO_SNDTIMEO (recv/send deadlines) on
// the client socket (#1581). `optval` is the `struct timeval` byte buffer
// cast through `* u8` (the `net.sfn` opaque-handle policy — no struct-by-
// value at the boundary). Identical C ABI to
// `int setsockopt(int, int, int, const void *, socklen_t)`. Declared
// inline (not imported) per the same #306 cross-module-extern workaround
// as the other socket externs above.
extern fn setsockopt(sockfd: i32, level: i32, optname: i32, optval: *u8, optlen: i32) -> i32;

// ── DNS resolution (libc) ─────────────────────────────────────
// `int getaddrinfo(const char *node, const char *service,
//                  const struct addrinfo *hints, struct addrinfo **res)`
// and `void freeaddrinfo(struct addrinfo *res)`. `node` is the hostname,
// `service` NULL (the caller owns the port). `hints` and the `res` out-list
// are opaque `struct addrinfo` buffers cast through `* u8` (the `net.sfn`
// opaque-handle policy); `res` is a `struct addrinfo **` out-param
// (`* * u8`, on the extern accept-list). Declared inline per the same #306
// cross-module-extern workaround as the socket externs above.
extern fn getaddrinfo(node: *u8, service: *u8, hints: *u8, res: **u8) -> i32;

extern fn freeaddrinfo(res: *u8) -> void;

// ── libc stdio (download write path) ──────────────────────────
extern fn fopen(path: *u8, mode: *u8) -> *File;

extern fn fwrite(buf: *u8, size: usize, nmemb: usize, f: *File) -> usize;

extern fn fclose(f: *File) -> i32;

// `_ptr_off(p, off)` — byte-stride pointer arithmetic for a
// variable offset. Mirrors `filesystem.sfn`'s `(buf as i64) + len`
// idiom; centralized here because the HTTP paths offset by runtime
// values throughout (recv cursor, response scan, sockaddr fields).
fn _ptr_off(p: *u8, off: i64) -> *u8 {
    let addr: i64 = (p as i64) + off;
    return addr as *u8;
}

// `_strdup_n(src, n)` — copy `n` bytes from `src` into a fresh
// libc-`malloc`'d NUL-terminated buffer the caller owns. Returns
// null on OOM. `n == 0` yields a valid empty string.
fn _strdup_n(src: *u8, n: i64) -> *u8 {
    let buf: *u8 = malloc((n + 1) as usize);
    if buf as i64 == 0 { return null; }
    if n > 0 { memcpy(buf, src, n as usize); }
    memset(_ptr_off(buf, n), 0, 1 as usize);
    return buf;
}

// `_uint_to_str(value)` — render a non-negative i64 as a freshly
// allocated decimal string (used for the POST `Content-Length`
// header). Returns null on OOM.
fn _uint_to_str(value: i64) -> *u8 {
    if value <= 0 {
        let zero: *u8 = malloc(2 as usize);
        if zero as i64 == 0 { return null; }
        memset(_ptr_off(zero, 0), 48, 1 as usize);
        memset(_ptr_off(zero, 1), 0, 1 as usize);
        return zero;
    }
    let mut count: i64 = 0;
    let mut probe: i64 = value;
    loop {
        if probe == 0 { break; }
        probe = probe / 10;
        count = count + 1;
    }
    let buf: *u8 = malloc((count + 1) as usize);
    if buf as i64 == 0 { return null; }
    memset(_ptr_off(buf, count), 0, 1 as usize);
    let mut remaining: i64 = value;
    let mut idx: i64 = count - 1;
    loop {
        if remaining == 0 { break; }
        let digit: i64 = remaining % 10;
        memset(_ptr_off(buf, idx), (48 + digit) as i32, 1 as usize);
        remaining = remaining / 10;
        idx = idx - 1;
    }
    return buf;
}

// `_first_is_digit(p)` — is the first byte at `p` an ASCII digit
// (`'0'`..`'9'` = 48..57)? Used to reject a non-numeric label before
// `atoi` (which returns 0 for `"foo"`) can smuggle a hostname through the
// dotted-quad parser as octet 0. Reads the byte via the pointer-read
// intrinsic and masks the low 8 bits.
fn _first_is_digit(p: *u8) -> bool {
    let b: i64 = (sailfin_intrinsic_pointer_read_i32(p) as i64) & 255;
    return b >= 48 && b <= 57;
}

// `_parse_quad(host, out)` — parse `host` as a numeric dotted-quad IPv4
// address, writing the four octets to `out[0..4]`. Returns false on
// anything that is not a clean `N.N.N.N` (each octet a leading-digit value
// in 0..255 separated by `.`), leaving the caller to fall through to DNS.
fn _parse_quad(host: *u8, out: *u8) -> bool {
    let mut cursor: *u8 = host;
    let mut i: i64 = 0;
    loop {
        if i >= 4 { break; }
        // Each octet must start with a digit — `atoi("foo")` is 0, which
        // would otherwise pass a hostname label off as octet 0 instead of
        // routing it to DNS.
        if !_first_is_digit(cursor) { return false; }
        let octet: i64 = atoi(cursor) as i64;
        // Reject malformed octets — `atoi` happily returns values
        // outside 0..255 (or negative), which would silently
        // wrap/truncate into one byte and connect to an unintended
        // address.
        if octet < 0 || octet > 255 { return false; }
        memset(_ptr_off(out, i), octet as i32, 1 as usize);
        if i < 3 {
            let dot: *u8 = strchr(cursor, 46);
            if dot as i64 == 0 { return false; }
            cursor = _ptr_off(dot, 1);
        }
        i = i + 1;
    }
    return true;
}

// `_sockaddr_octets(sa, out)` — given the address of a `sockaddr_in`
// (`sa`, as an i64), validate it is an AF_INET address and copy its four
// `sin_addr` octets to `out[0..4]`. Returns false for a null pointer or a
// non-INET family. The family lives at the front of the struct, spelled
// differently per target (Linux: u16 `sin_family` at byte 0 → low byte 2;
// macOS/BSD: u8 `sin_len` at byte 0, u8 `sin_family` at byte 1 → byte1 2),
// so we accept AF_INET (2) in either the low or the second byte. The
// address octets sit at offset 4 on both layouts. The control byte 2 never
// appears as the first byte of a hostname string, so this also rejects an
// `ai_canonname` char-pointer mistaken for a sockaddr (see `_resolve_dns`).
fn _sockaddr_octets(sa: i64, out: *u8) -> bool {
    if sa == 0 { return false; }
    let head4: i64 = sailfin_intrinsic_pointer_read_i32(sa as *u8) as i64;
    let b0: i64 = head4 & 255;
    let b1: i64 = (head4 >> 8) & 255;
    if b0 != 2 && b1 != 2 { return false; }
    memcpy(out, (sa + 4) as *u8, 4 as usize);
    return true;
}

// `_resolve_dns(host, out)` — resolve a hostname to its first IPv4 (A)
// address via libc `getaddrinfo`, writing the four octets to `out[0..4]`.
// Returns false when resolution fails, so the caller surfaces the existing
// typed failure (a null body / closed connection) — never a hang or crash.
//
// v0 scope (epic #1540 B2): IPv4 only (hints restrict to AF_INET +
// SOCK_STREAM), first A record only (no happy-eyeballs), no caching, no
// AAAA. `service` is NULL — only the address is resolved; the caller owns
// the port. `res` is a `struct addrinfo **`: an 8-byte pointer slot whose
// `*res` (read with the pointer-read intrinsic) is the head of the result
// list, freed with `freeaddrinfo`.
//
// `struct addrinfo` is 48 bytes on both targets, but the order of its two
// trailing pointers differs: `ai_addr` is at byte offset 24 on Linux and
// 32 on macOS/BSD (the other slot is `ai_canonname`, NULL because
// AI_CANONNAME is not requested). The platform-agnostic emitted IR cannot
// branch on the target, so we read both candidate slots and let
// `_sockaddr_octets` pick the one that validates as an AF_INET sockaddr.
fn _resolve_dns(host: *u8, out: *u8) -> bool ![net] {
    let hints: *u8 = malloc(48 as usize);
    if hints as i64 == 0 { return false; }
    memset(hints, 0, 48 as usize);
    // ai_family = AF_INET (2) at offset 4; ai_socktype = SOCK_STREAM (1)
    // at offset 8 — identical offsets on both targets.
    memset(_ptr_off(hints, 4), 2, 1 as usize);
    memset(_ptr_off(hints, 8), 1, 1 as usize);
    let res: *u8 = malloc(8 as usize);
    if res as i64 == 0 {
        free(hints);
        return false;
    }
    memset(res, 0, 8 as usize);
    let rc: i32 = getaddrinfo(host, null, hints, res as **u8);
    free(hints);
    if rc != 0 {
        free(res);
        return false;
    }
    let head: i64 = sailfin_intrinsic_pointer_read_i64(res);
    free(res);
    if head == 0 { return false; }
    let cand_a: i64 = sailfin_intrinsic_pointer_read_i64((head + 24) as *u8);
    let cand_b: i64 = sailfin_intrinsic_pointer_read_i64((head + 32) as *u8);
    let mut ok: bool = false;
    if _sockaddr_octets(cand_a, out) { ok = true; } else {
        if _sockaddr_octets(cand_b, out) { ok = true; }
    }
    freeaddrinfo(head as *u8);
    return ok;
}

// `_host_ip4(host, out)` — resolve `host` to four IPv4 octets, written to
// `out[0..4]`. Handles the `localhost` alias and numeric dotted-quad
// addresses directly; anything else (a real hostname) falls through to DNS
// via `getaddrinfo` (#1540 B2). `out` must point at >= 4 writable bytes.
fn _host_ip4(host: *u8, out: *u8) -> bool ![net] {
    let localhost: string = "localhost";
    if strcmp(host, localhost as *u8) == 0 {
        memset(_ptr_off(out, 0), 127, 1 as usize);
        memset(_ptr_off(out, 1), 0, 1 as usize);
        memset(_ptr_off(out, 2), 0, 1 as usize);
        memset(_ptr_off(out, 3), 1, 1 as usize);
        return true;
    }
    if _parse_quad(host, out) { return true; }
    return _resolve_dns(host, out);
}

// `_http_io_timeout_secs()` — the recv/send socket-timeout budget
// (seconds) for the client. A dead or slow upstream must not pin a
// worker thread forever (#1581, gap B3 of epic #1540 — blocker for the
// ~150 ms hot-path SLA). 10s is generous for a healthy localhost peer yet
// bounds a black-hole upstream to a clean failure (`null` return).
fn _http_io_timeout_secs() -> i64 { return 10; }

// `_set_socket_timeouts(fd)` — arm SO_RCVTIMEO + SO_SNDTIMEO on a socket
// so a recv/send against a non-responsive peer returns (EAGAIN → a clean
// failure) instead of blocking forever.
//
// `struct timeval { tv_sec; tv_usec; }` is 16 bytes on both targets this
// runtime builds for (Linux x86_64: i64 + i64; macOS arm64: i64 + i32 +
// 4 pad). `tv_sec` is an i64 at offset 0 on both, so zeroing the 16 bytes
// and writing the seconds as the low byte at offset 0 (both targets are
// little-endian) yields `{sec, 0}` portably for any budget < 256s.
//
// The SOL_SOCKET / SO_*TIMEO option numbers DIFFER by platform and the
// platform-agnostic emitted IR cannot branch on the target (the same
// constraint as the dual `sockaddr_in` layout in `_connect_tcp`), so we
// issue both the Linux and the macOS variant and ignore failures: the
// wrong-platform call returns ENOPROTOOPT and leaves the socket at its
// prior (blocking) state — the pre-fix status quo, never an error
// surfaced to the caller.
//   - Linux x86_64: SOL_SOCKET=1,      SO_RCVTIMEO=20,     SO_SNDTIMEO=21.
//   - macOS arm64:  SOL_SOCKET=0xffff, SO_RCVTIMEO=0x1006, SO_SNDTIMEO=0x1005.
fn _set_socket_timeouts(fd: i32) -> void {
    let tv: *u8 = malloc(16 as usize);
    if tv as i64 == 0 { return; }
    memset(tv, 0, 16 as usize);
    memset(_ptr_off(tv, 0), _http_io_timeout_secs() as i32, 1 as usize);
    setsockopt(fd, 1, 20, tv, 16);
    setsockopt(fd, 1, 21, tv, 16);
    setsockopt(fd, 65535, 4102, tv, 16);
    setsockopt(fd, 65535, 4101, tv, 16);
    free(tv);
}

// `_connect_tcp(host, port)` — build an IPv4 `sockaddr_in`, open a
// stream socket, and connect. Returns the connected fd, or -1 on
// any failure.
//
// `sockaddr_in` byte layout differs across the two targets this
// runtime builds for, and the platform-agnostic emitted IR cannot
// branch on it, so we try both layouts (fresh socket each time,
// first success wins):
//   - Linux:     `sin_family` is a u16 at offset 0 → low byte = 2
//                (AF_INET), high byte 0.
//   - macOS/BSD: `sin_len` (u8) at offset 0, `sin_family` (u8) at
//                offset 1 → byte0 = 16 (struct size), byte1 = 2.
// On Linux the macOS layout yields `sin_family = 16 | (2<<8) = 528`
// (EAFNOSUPPORT) and vice-versa, so the wrong-layout attempt fails
// fast without connecting anywhere. For localhost (the v0 target)
// the live attempt succeeds or refuses immediately, so the extra
// attempt costs nothing observable. `sin_port` is big-endian
// (network byte order); the four address octets sit at offset 4.
fn _connect_tcp(host: *u8, port: i64) -> i32 ![net] {
    let mut attempt: i64 = 0;
    loop {
        if attempt >= 2 { break; }
        let addr: *u8 = malloc(16 as usize);
        if addr as i64 == 0 { return 0 - 1; }
        memset(addr, 0, 16 as usize);
        if attempt == 0 {
            // Linux: u16 sin_family at offset 0.
            memset(_ptr_off(addr, 0), 2, 1 as usize);
        } else {
            // macOS/BSD: u8 sin_len at 0, u8 sin_family at 1.
            memset(_ptr_off(addr, 0), 16, 1 as usize);
            memset(_ptr_off(addr, 1), 2, 1 as usize);
        }
        // sin_port (network byte order = big-endian).
        memset(_ptr_off(addr, 2), ((port >> 8) & 255) as i32, 1 as usize);
        memset(_ptr_off(addr, 3), (port & 255) as i32, 1 as usize);
        // sin_addr octets at offset 4..8.
        if _host_ip4(host, _ptr_off(addr, 4)) {
            let fd: i32 = socket(2, 1, 0);
            if fd < 0 {
                free(addr);
                return 0 - 1;
            }
            // Bound recv/send so a connected-but-silent upstream cannot
            // pin this worker forever (#1581).
            _set_socket_timeouts(fd);
            let rc: i32 = connect(fd, addr, 16);
            free(addr);
            if rc == 0 { return fd; }
            close(fd);
        } else {
            free(addr);
            return 0 - 1;
        }
        attempt = attempt + 1;
    }
    return 0 - 1;
}

// `_send_all(fd, ssl, buf, total)` — write `total` bytes, retrying on
// short sends. When `ssl` is non-null the bytes go through `tls_write`
// (TLS record layer); otherwise raw `send` on `fd`. Returns false if a
// write ever fails.
fn _send_all(fd: i32, ssl: *u8, buf: *u8, total: i64) -> bool ![net] {
    let mut sent: i64 = 0;
    loop {
        if sent >= total { break; }
        let mut n: i64 = 0;
        if ssl as i64 != 0 {
            n = tls_write(ssl, _ptr_off(buf, sent), total - sent);
        } else {
            n = send(fd, _ptr_off(buf, sent), total - sent, 0);
        }
        if n <= 0 { return false; }
        sent = sent + n;
    }
    return true;
}

// `_recv_all(fd, ssl, len_slot)` — drain the socket into a growing libc
// buffer (doubling like `filesystem.sfn`'s slurp), NUL-terminated
// and caller-owned, writing the exact byte count received through
// `len_slot` (so binary bodies with embedded NULs are length-known,
// not `strlen`-truncated). Returns null on OOM or a `recv` error
// (`n < 0`); a clean EOF (`n == 0`, guaranteed by the request's
// `Connection: close`) ends the loop and returns the buffer. The
// trailing NUL keeps the buffer usable as a C string for the
// text-body get/post paths.
//
// The buffer is over-allocated by 4 trailing bytes (not just the 1
// for the NUL) so the chunked decoder's single-byte reads — which use
// the 4-byte `sailfin_intrinsic_pointer_read_i32` load masked to its
// low byte — never fault on a 4-byte load issued at the final in-body
// offset (`off <= len`, load touches `off..off+3 <= len+3`).
fn _recv_all(fd: i32, ssl: *u8, len_slot: *i64) -> *u8 ![net] {
    let mut capacity: i64 = 8192;
    let mut len: i64 = 0;
    let mut buf: *u8 = malloc((capacity + 4) as usize);
    if buf as i64 == 0 { return null; }
    let chunk: i64 = 8192;
    loop {
        if len + chunk > capacity {
            let new_cap: i64 = capacity * 2;
            let new_buf: *u8 = realloc(buf, (new_cap + 4) as usize);
            if new_buf as i64 == 0 {
                free(buf);
                return null;
            }
            buf = new_buf;
            capacity = new_cap;
        }
        let mut n: i64 = 0;
        if ssl as i64 != 0 {
            n = tls_read(ssl, _ptr_off(buf, len), chunk);
        } else {
            n = recv(fd, _ptr_off(buf, len), chunk, 0);
        }
        // Distinguish a socket error from a clean close: a partial
        // buffer from an errored socket must not look like success.
        if n < 0 {
            free(buf);
            return null;
        }
        if n == 0 { break; }
        len = len + n;
    }
    memset(_ptr_off(buf, len), 0, 1 as usize);
    atomic_store(len_slot, len);
    return buf;
}

// `_byte_at(base, off)` — read the byte at `base + off` as 0..255. Uses the
// 4-byte pointer-read intrinsic masked to its low byte (both targets are
// little-endian, the same idiom as `_first_is_digit`). The caller MUST keep
// `off` within the in-bounds region; the recv buffer is over-allocated by 4
// bytes so a 4-byte load at the final in-body offset never faults.
fn _byte_at(base: *u8, off: i64) -> i64 {
    return (sailfin_intrinsic_pointer_read_i32(_ptr_off(base, off)) as i64) & 255;
}

// `_lc(b)` — ASCII-lowercase a byte value ('A'..'Z' → 'a'..'z'); other bytes
// unchanged. For case-insensitive header-name / token matching.
fn _lc(b: i64) -> i64 {
    if b >= 65 && b <= 90 { return b + 32; }
    return b;
}

// `_hex_val(b)` — value 0..15 of an ASCII hex-digit byte, or -1 if `b` is not
// a hex digit. Used to parse the chunk-size line of a chunked body.
fn _hex_val(b: i64) -> i64 {
    if b >= 48 && b <= 57 { return b - 48; }
    if b >= 97 && b <= 102 { return (b - 97) + 10; }
    if b >= 65 && b <= 70 { return (b - 65) + 10; }
    return 0 - 1;
}

// `_ci_find(base, limit, needle, nlen)` — first index in `[0, limit)` where the
// `nlen`-byte `needle` matches case-insensitively, or -1. Strictly bounded: it
// never reads at or beyond `limit`, so it is safe over the NUL-free,
// length-known header region (no `strstr`, which would stop at an embedded NUL).
fn _ci_find(base: *u8, limit: i64, needle: *u8, nlen: i64) -> i64 {
    if nlen <= 0 { return 0 - 1; }
    let mut i: i64 = 0;
    loop {
        if i + nlen > limit { break; }
        let mut j: i64 = 0;
        let mut matched: bool = true;
        loop {
            if j >= nlen { break; }
            if _lc(_byte_at(base, i + j)) != _lc(_byte_at(needle, j)) {
                matched = false;
                break;
            }
            j = j + 1;
        }
        if matched { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

// `_resp_is_chunked(resp, header_len)` — does the response header block (the
// `header_len` bytes before the `\r\n\r\n` terminator) declare a chunked
// transfer encoding? Finds a `Transfer-Encoding` header (case-insensitive),
// then scans the remainder of that line for `chunked`. v0 treats any
// `chunked` token in the value as chunked framing (no coding-list ordering).
fn _resp_is_chunked(resp: *u8, header_len: i64) -> bool {
    let te: string = "transfer-encoding";
    let idx: i64 = _ci_find(resp, header_len, te as *u8, 17);
    if idx < 0 { return false; }
    let value_start: i64 = idx + 17;
    // End of this header line (the next LF, or the header-block end).
    let mut line_end: i64 = value_start;
    loop {
        if line_end >= header_len { break; }
        if _byte_at(resp, line_end) == 10 { break; }
        line_end = line_end + 1;
    }
    let chunked: string = "chunked";
    let found: i64 = _ci_find(_ptr_off(resp, value_start), line_end - value_start, chunked as *u8, 7);
    return found >= 0;
}

// `_decode_chunked(resp, body_off, total_len, out_len_slot)` — decode a
// `Transfer-Encoding: chunked` body in `resp[body_off..total_len)` into a fresh
// caller-owned NUL-terminated buffer, writing the decoded length through
// `out_len_slot`. Each chunk is `<hex-size>[;ext]\r\n<size bytes>\r\n`,
// terminated by a `0\r\n` (trailers, if any, are ignored). The decoded body is
// never larger than the raw chunked body, so one allocation suffices.
//
// Every read is bounded by `total_len` and every chunk length is validated
// against the remaining bytes, so a malformed size (non-hex, overflowing, or
// claiming more bytes than remain) or a missing CRLF fails cleanly to null —
// never an unbounded read. Length is tracked explicitly (never `strlen`), so an
// embedded NUL inside a chunk survives.
fn _decode_chunked(resp: *u8, body_off: i64, total_len: i64, out_len_slot: *i64) -> *u8 {
    atomic_store(out_len_slot, 0);
    let raw_len: i64 = total_len - body_off;
    if raw_len < 0 { return null; }
    let out: *u8 = malloc((raw_len + 1) as usize);
    if out as i64 == 0 { return null; }
    let mut out_len: i64 = 0;
    let mut pos: i64 = body_off;
    loop {
        // Parse the hex chunk-size, stopping at the first non-hex byte.
        let mut size: i64 = 0;
        let mut digits: i64 = 0;
        loop {
            if pos >= total_len {
                free(out);
                return null;
            }
            let hv: i64 = _hex_val(_byte_at(resp, pos));
            if hv < 0 { break; }
            size = size * 16 + hv;
            // A size larger than the bytes that remain is malformed — also
            // guards the accumulator against overflow on a runaway length.
            if size > raw_len {
                free(out);
                return null;
            }
            digits = digits + 1;
            pos = pos + 1;
        }
        // A chunk header with no hex size is malformed framing.
        if digits == 0 {
            free(out);
            return null;
        }
        // Skip any chunk extension (";...") up to the line's CR/LF.
        loop {
            if pos >= total_len {
                free(out);
                return null;
            }
            let b: i64 = _byte_at(resp, pos);
            if b == 13 || b == 10 { break; }
            pos = pos + 1;
        }
        // Consume the size-line terminator (CRLF, or a tolerated bare LF).
        if pos < total_len && _byte_at(resp, pos) == 13 { pos = pos + 1; }
        if pos >= total_len || _byte_at(resp, pos) != 10 {
            free(out);
            return null;
        }
        pos = pos + 1;
        // A zero-size chunk terminates the body.
        if size == 0 { break; }
        // Copy the chunk data; it must fit within the received bytes.
        if pos + size > total_len {
            free(out);
            return null;
        }
        memcpy(_ptr_off(out, out_len), _ptr_off(resp, pos), size as usize);
        out_len = out_len + size;
        pos = pos + size;
        // Require the CRLF (or tolerated bare LF) that follows chunk data.
        if pos < total_len && _byte_at(resp, pos) == 13 { pos = pos + 1; }
        if pos >= total_len || _byte_at(resp, pos) != 10 {
            free(out);
            return null;
        }
        pos = pos + 1;
    }
    memset(_ptr_off(out, out_len), 0, 1 as usize);
    atomic_store(out_len_slot, out_len);
    return out;
}

// `_extract_body(resp, total_len, body_len_slot)` — given a raw
// HTTP response buffer of `total_len` bytes, check the status line
// and return a fresh copy of the body (everything after the first
// `\r\n\r\n`), writing the body's exact byte length through
// `body_len_slot`. The length is computed as `total_len - body_off`
// (NOT `strlen`), so bodies containing embedded NULs are copied
// whole — required for `http.download` to be a faithful binary
// download. Returns null when the status code is >= 400 (mirrors
// curl `-f`) or when no header terminator is found. The status line
// and headers are ASCII (no NUL before the body), so `strchr` /
// `strstr` over them are safe. `resp` is left untouched; the caller
// frees it.
//
// `Transfer-Encoding: chunked` responses are decoded: the chunk
// framing is stripped and the chunk data concatenated into the body
// (still length-tracked, never `strlen`). A malformed chunked body
// fails cleanly to null. Trailers and chunk extensions are skipped.
fn _extract_body(resp: *u8, total_len: i64, body_len_slot: *i64) -> *u8 {
    atomic_store(body_len_slot, 0);
    if resp as i64 == 0 { return null; }
    // Status code: the first space precedes "NNN reason".
    let space: *u8 = strchr(resp, 32);
    if space as i64 != 0 {
        let code: i64 = atoi(_ptr_off(space, 1)) as i64;
        if code >= 400 { return null; }
    }
    let terminator: string = "\r\n\r\n";
    let header_end: *u8 = strstr(resp, terminator as *u8);
    if header_end as i64 == 0 { return null; }
    let header_len: i64 = (header_end as i64) - (resp as i64);
    let body_off: i64 = header_len + 4;
    let body_len: i64 = total_len - body_off;
    if body_len < 0 { return null; }
    // Chunked framing → decode into the actual body bytes.
    if _resp_is_chunked(resp, header_len) {
        return _decode_chunked(resp, body_off, total_len, body_len_slot);
    }
    let body: *u8 = _strdup_n(_ptr_off(resp, body_off), body_len);
    if body as i64 == 0 { return null; }
    atomic_store(body_len_slot, body_len);
    return body;
}

// `_tls_teardown(ssl, ctx)` — shut down and free a client `SSL*` handle
// and its `SSL_CTX*`. Both may be null (the plaintext-http path), making
// this a no-op there, so it can be called unconditionally on every
// post-handshake exit of a TLS-capable request. `tls_shutdown_free`
// writes a close_notify over the fd, so this must run before `close(fd)`.
fn _tls_teardown(ssl: *u8, ctx: *u8) -> void ![net] {
    if ssl as i64 != 0 { tls_shutdown_free(ssl); }
    if ctx as i64 != 0 { tls_ctx_free(ctx); }
}

// `_http_status_code(resp)` — the numeric status from the response's
// status line ("HTTP/1.1 NNN reason"). 0 when the line is absent/malformed.
fn _http_status_code(resp: *u8) -> i64 {
    if resp as i64 == 0 { return 0; }
    let space: *u8 = strchr(resp, 32);
    if space as i64 == 0 { return 0; }
    return atoi(_ptr_off(space, 1)) as i64;
}

// `_http_header_len(resp)` — byte length of the header block (up to, not
// including, the `\r\n\r\n` terminator), or -1 when no terminator is found.
fn _http_header_len(resp: *u8) -> i64 {
    if resp as i64 == 0 { return 0 - 1; }
    let terminator: string = "\r\n\r\n";
    let he: *u8 = strstr(resp, terminator as *u8);
    if he as i64 == 0 { return 0 - 1; }
    return (he as i64) - (resp as i64);
}

// `_http_resolve_relative(base_url, rel)` — resolve an absolute-path
// `Location` (starting `/`) against `base_url`'s `scheme://authority`,
// returning a fresh NUL-terminated URL. Null on OOM or a base without a
// scheme separator. Only the absolute-path form is resolved here; a fully
// absolute `Location` (with `://`) is used verbatim by the caller, and any
// other relative form fails closed.
fn _http_resolve_relative(base_url: *u8, rel: *u8) -> *u8 {
    let sep: string = "://";
    let scheme_sep: *u8 = strstr(base_url, sep as *u8);
    if scheme_sep as i64 == 0 { return null; }
    let auth_start: *u8 = _ptr_off(scheme_sep, 3);
    let slash: *u8 = strchr(auth_start, 47);
    let mut prefix_len: i64 = 0;
    if slash as i64 != 0 { prefix_len = (slash as i64) - (base_url as i64); } else {
        prefix_len = strlen(base_url) as i64;
    }
    let rel_len: i64 = strlen(rel) as i64;
    let out: *u8 = malloc((prefix_len + rel_len + 1) as usize);
    if out as i64 == 0 { return null; }
    memcpy(out, base_url, prefix_len as usize);
    memcpy(_ptr_off(out, prefix_len), rel, rel_len as usize);
    memset(_ptr_off(out, prefix_len + rel_len), 0, 1 as usize);
    return out;
}

// `_http_location_dup(resp, header_len, base_url)` — extract the redirect
// target from a response's `Location` header as a fresh NUL-terminated URL,
// or null when absent/unresolvable. Case-insensitive header match, bounded to
// the header block (never reads the body). An absolute `Location` (with
// `://`) is returned verbatim; an absolute-path `Location` (leading `/`) is
// resolved against `base_url`; any other form fails closed (null).
fn _http_location_dup(resp: *u8, header_len: i64, base_url: *u8) -> *u8 {
    if resp as i64 == 0 { return null; }
    let needle: string = "\r\nlocation:";
    let idx: i64 = _ci_find(resp, header_len, needle as *u8, 11);
    if idx < 0 { return null; }
    let mut vs: i64 = idx + 11;
    loop {
        if vs >= header_len { break; }
        let b: i64 = _byte_at(resp, vs);
        if b == 32 || b == 9 { vs = vs + 1; } else { break; }
    }
    let mut ve: i64 = vs;
    loop {
        if ve >= header_len { break; }
        let b: i64 = _byte_at(resp, ve);
        if b == 13 || b == 10 { break; }
        ve = ve + 1;
    }
    let vlen: i64 = ve - vs;
    if vlen <= 0 { return null; }
    let val: *u8 = _strdup_n(_ptr_off(resp, vs), vlen);
    if val as i64 == 0 { return null; }
    let sep: string = "://";
    if strstr(val, sep as *u8) as i64 != 0 { return val; }
    if _byte_at(val, 0) == 47 {
        let resolved: *u8 = _http_resolve_relative(base_url, val);
        free(val);
        return resolved;
    }
    free(val);
    return null;
}

// `_http_send_once(url, is_post, body, auth_header, ...)` — one
// request/response round trip. Parses `url` (scheme/host/port/path),
// connects, writes the request head (plus body for POST), drains the
// response, and returns the extracted body (or null on any failure).
// `auth_header`, when non-null and non-empty, is emitted as an
// `Authorization:` header (POST only). Writes the response status through
// `status_slot` and, for a 3xx with a `Location`, a fresh NUL-terminated
// redirect-target URL (as an `i64`-cast pointer the caller owns and frees)
// through `location_slot` — the redirect loop in `_http_send` consumes both.
fn _http_send_once(url: *u8, is_post: bool, body: *u8, auth_header: *u8, body_len_slot: *i64, status_slot: *i64, location_slot: *i64) -> *u8 ![net] {
    // Detect the `https://` scheme — TLS-wrap the connection below.
    let https: string = "https://";
    let is_https: bool = (strstr(url, https as *u8) as i64) == (url as i64);

    // Locate the authority: skip past "scheme://" if present.
    let sep: string = "://";
    let mut host_start: *u8 = url;
    let scheme: *u8 = strstr(url, sep as *u8);
    if scheme as i64 != 0 { host_start = _ptr_off(scheme, 3); }

    // Path begins at the first '/' after the authority; default "/".
    let slash: *u8 = strchr(host_start, 47);
    let mut authority_len: i64 = 0;
    if slash as i64 != 0 {
        authority_len = (slash as i64) - (host_start as i64);
    } else { authority_len = strlen(host_start) as i64; }
    let authority: *u8 = _strdup_n(host_start, authority_len);
    if authority as i64 == 0 { return null; }

    // Split host:port (terminate host in place at the colon). Default
    // port is 443 for https, 80 for http; an explicit `:port` overrides.
    let mut port: i64 = 80;
    if is_https { port = 443; }
    let colon: *u8 = strchr(authority, 58);
    if colon as i64 != 0 {
        port = atoi(_ptr_off(colon, 1)) as i64;
        memset(colon, 0, 1 as usize);
    }

    let root: string = "/";
    let mut path: *u8 = root as *u8;
    if slash as i64 != 0 { path = slash; }

    let fd: i32 = _connect_tcp(authority, port);
    if fd < 0 {
        free(authority);
        return null;
    }

    // For https, TLS-wrap the connected socket: build a client ctx and
    // handshake (SNI = host, peer chain verified). `ssl`/`tls_ctx` stay
    // null for plaintext http, so the single `_send_all`/`_recv_all` path
    // below routes bytes through TLS or raw sockets accordingly. Every
    // post-handshake exit runs `_tls_teardown(ssl, tls_ctx)` (a no-op on
    // http) before `close(fd)`.
    let mut ssl: *u8 = null;
    let mut tls_ctx: *u8 = null;
    if is_https {
        tls_ctx = tls_client_ctx();
        if tls_ctx as i64 == 0 {
            free(authority);
            close(fd);
            return null;
        }
        ssl = tls_connect_fd(tls_ctx, fd, authority);
        if ssl as i64 == 0 {
            tls_ctx_free(tls_ctx);
            free(authority);
            close(fd);
            return null;
        }
    }

    // ── Build and send the request head ──
    let host_line: string = " HTTP/1.1\r\nHost: ";
    let tail: string = "\r\nConnection: close\r\n\r\n";
    let path_len: i64 = strlen(path) as i64;
    let host_len: i64 = strlen(authority) as i64;

    if is_post {
        let verb: string = "POST ";
        let ctype: string = "\r\nContent-Type: application/json\r\nContent-Length: ";
        let body_len: i64 = strlen(body) as i64;
        let clen: *u8 = _uint_to_str(body_len);
        if clen as i64 == 0 {
            _tls_teardown(ssl, tls_ctx);
            free(authority);
            close(fd);
            return null;
        }
        // Optional Authorization header.
        let auth_label: string = "\r\nAuthorization: ";
        let mut has_auth: bool = false;
        let mut auth_len: i64 = 0;
        if auth_header as i64 != 0 {
            auth_len = strlen(auth_header) as i64;
            if auth_len > 0 { has_auth = true; }
        }
        let mut total: i64 = (strlen(verb as *u8) as i64) + path_len + (strlen(host_line as *u8) as i64)
            + host_len
            + (strlen(ctype as *u8) as i64)
            + (strlen(clen) as i64)
            + (strlen(tail as *u8) as i64);
        if has_auth {
            total = total + (strlen(auth_label as *u8) as i64) + auth_len;
        }
        let head: *u8 = malloc((total + 1) as usize);
        if head as i64 == 0 {
            _tls_teardown(ssl, tls_ctx);
            free(clen);
            free(authority);
            close(fd);
            return null;
        }
        let mut off: i64 = 0;
        off = _append(head, off, verb as *u8);
        off = _append(head, off, path);
        off = _append(head, off, host_line as *u8);
        off = _append(head, off, authority);
        off = _append(head, off, ctype as *u8);
        off = _append(head, off, clen);
        if has_auth {
            off = _append(head, off, auth_label as *u8);
            off = _append(head, off, auth_header);
        }
        off = _append(head, off, tail as *u8);
        memset(_ptr_off(head, off), 0, 1 as usize);
        free(clen);

        let head_ok: bool = _send_all(fd, ssl, head, off);
        free(head);
        if head_ok {
            if _send_all(fd, ssl, body, body_len) {
                // fall through to recv
            } else {
                _tls_teardown(ssl, tls_ctx);
                free(authority);
                close(fd);
                return null;
            }
        } else {
            _tls_teardown(ssl, tls_ctx);
            free(authority);
            close(fd);
            return null;
        }
    } else {
        let verb: string = "GET ";
        let total: i64 = (strlen(verb as *u8) as i64) + path_len + (strlen(host_line as *u8) as i64)
            + host_len
            + (strlen(tail as *u8) as i64);
        let head: *u8 = malloc((total + 1) as usize);
        if head as i64 == 0 {
            _tls_teardown(ssl, tls_ctx);
            free(authority);
            close(fd);
            return null;
        }
        let mut off: i64 = 0;
        off = _append(head, off, verb as *u8);
        off = _append(head, off, path);
        off = _append(head, off, host_line as *u8);
        off = _append(head, off, authority);
        off = _append(head, off, tail as *u8);
        memset(_ptr_off(head, off), 0, 1 as usize);

        let head_ok: bool = _send_all(fd, ssl, head, off);
        free(head);
        if head_ok {
            // fall through to recv
        } else {
            _tls_teardown(ssl, tls_ctx);
            free(authority);
            close(fd);
            return null;
        }
    }

    free(authority);
    let mut total_len: i64 = 0;
    let resp: *u8 = _recv_all(fd, ssl, & total_len);
    _tls_teardown(ssl, tls_ctx);
    close(fd);
    // Surface the status + any redirect target BEFORE body extraction, so the
    // `_http_send` loop can follow a 3xx (whose body is empty) rather than
    // returning it. `url` (unfreed) is the base for a relative `Location`.
    atomic_store(status_slot, _http_status_code(resp));
    let hlen: i64 = _http_header_len(resp);
    let mut loc: *u8 = null;
    if hlen >= 0 { loc = _http_location_dup(resp, hlen, url); }
    atomic_store(location_slot, loc as i64);
    let result: *u8 = _extract_body(resp, total_len, body_len_slot);
    if resp as i64 != 0 { free(resp); }
    return result;
}

// `_http_send(url, is_post, body, auth_header)` — the shared request core,
// following HTTP 3xx redirects (301/302/303/307/308) up to a bounded hop
// limit. GitHub release-asset URLs always 302-redirect to a signed CDN URL,
// so redirect following is required for the toolchain fetch/verify path
// (SFN-213). Fail-closed: a redirect with no `Location`, or one past the hop
// limit, returns null rather than a misleading empty body. Security: the
// `Authorization` header is never forwarded across a redirect (the signed CDN
// URL carries its own query-string auth), and 301/302/303 downgrade to GET
// (dropping the body); 307/308 preserve the method and body.
fn _http_send(url: *u8, is_post: bool, body: *u8, auth_header: *u8, body_len_slot: *i64) -> *u8 ![net] {
    if url as i64 == 0 { return null; }
    let mut cur: *u8 = _strdup_n(url, strlen(url) as i64);
    if cur as i64 == 0 { return null; }
    let mut post: bool = is_post;
    let mut auth_eff: *u8 = auth_header;
    let mut hops: i64 = 0;
    let max_hops: i64 = 5;
    let mut out: *u8 = null;
    loop {
        let mut status: i64 = 0;
        let mut loc_i: i64 = 0;
        let result: *u8 = _http_send_once(cur, post, body, auth_eff, body_len_slot, & status, & loc_i);
        let loc: *u8 = loc_i as *u8;
        let is_redirect: bool = status == 301 || status == 302 || status == 303
            || status == 307
            || status == 308;
        if !is_redirect {
            if loc as i64 != 0 { free(loc); }
            free(cur);
            out = result;
            break;
        }
        // A redirect we cannot follow (no `Location`, or past the hop limit)
        // fails closed — never hand back the empty 3xx body as if it were the
        // resource.
        if loc as i64 == 0 || hops >= max_hops {
            if loc as i64 != 0 { free(loc); }
            free(cur);
            if result as i64 != 0 { free(result); }
            out = null;
            break;
        }
        free(cur);
        cur = loc;
        if result as i64 != 0 { free(result); }
        atomic_store(body_len_slot, 0);
        // 301/302/303 → GET (drop body); 307/308 preserve method + body.
        if status != 307 && status != 308 { post = false; }
        auth_eff = null;
        hops = hops + 1;
    }
    return out;
}

// `_append(dst, off, src)` — copy the NUL-terminated `src` into
// `dst` at byte offset `off`, returning the new offset. The caller
// pre-sizes `dst` from the summed piece lengths.
fn _append(dst: *u8, off: i64, src: *u8) -> i64 {
    let n: i64 = strlen(src) as i64;
    memcpy(_ptr_off(dst, off), src, n as usize);
    return off + n;
}

// `sfn_http_get(url)` — GET `url`, returning a caller-owned copy of
// the response body. Null on a null url, connect failure, or HTTP
// status >= 400.
fn sfn_http_get(url: *u8) -> *u8 ![net] {
    if url as i64 == 0 { return null; }
    // get/post return an `i8*` C string, so the body length is
    // unused here — pass a throwaway slot.
    let mut body_len: i64 = 0;
    return _http_send(url, false, null, null, & body_len);
}

// `sfn_http_post(url, body, auth_header)` — POST `body` to `url`
// with `Content-Type: application/json`. When `auth_header` is
// non-empty it is sent verbatim as the `Authorization:` value
// (matching the curl `sailfin_runtime_http_post_json` contract).
// Returns a caller-owned copy of the response body, null on
// failure or status >= 400.
fn sfn_http_post(url: *u8, body: *u8, auth_header: *u8) -> *u8 ![net] {
    if url as i64 == 0 { return null; }
    if body as i64 == 0 { return null; }
    let mut body_len: i64 = 0;
    return _http_send(url, true, body, auth_header, & body_len);
}

// `sfn_http_post2(url, body)` — 2-arg POST for the `http_post`
// registry alias; forwards to `sfn_http_post` with no auth header.
fn sfn_http_post2(url: *u8, body: *u8) -> *u8 ![net] {
    return sfn_http_post(url, body, null);
}

// `sfn_http_request_raw(method, url, headers, body)` — perform an
// arbitrary HTTP/1.1 request and return the FULL raw response (status
// line + headers + body) as a caller-owned NUL-terminated buffer, or
// null on a socket/connect/TLS verification failure. This is the additive
// primitive behind the typed `fetch` client (sfn/http, Wave 4 / #1325):
// unlike `sfn_http_get` / `sfn_http_post` it neither strips the headers nor
// filters on the status code, so the capsule's response parser can surface
// the real status + headers. Same v0 limits as the rest of this adapter:
// no chunked decoding, no redirect following.
//
// `headers` is a pre-serialized header block — zero or more
// "Name: value\r\n" lines, possibly empty — emitted verbatim after the
// `Host` line (the capsule joins its `string[]`). The framing headers
// `Host`, `Content-Length` (only when a body is present), and
// `Connection: close` are owned here, matching the GET/POST paths.
fn sfn_http_request_raw(method: *u8, url: *u8, headers: *u8, body: *u8) -> *u8 ![net] {
    if url as i64 == 0 { return null; }
    if method as i64 == 0 { return null; }

    let https: string = "https://";
    let is_https: bool = (strstr(url, https as *u8) as i64) == (url as i64);

    // Locate the authority: skip past "scheme://" if present.
    let sep: string = "://";
    let mut host_start: *u8 = url;
    let scheme: *u8 = strstr(url, sep as *u8);
    if scheme as i64 != 0 { host_start = _ptr_off(scheme, 3); }

    // Path begins at the first '/' after the authority; default "/".
    let slash: *u8 = strchr(host_start, 47);
    let mut authority_len: i64 = 0;
    if slash as i64 != 0 {
        authority_len = (slash as i64) - (host_start as i64);
    } else { authority_len = strlen(host_start) as i64; }
    let authority: *u8 = _strdup_n(host_start, authority_len);
    if authority as i64 == 0 { return null; }

    // Split host:port (terminate host in place at the colon).
    let mut port: i64 = 80;
    if is_https { port = 443; }
    let colon: *u8 = strchr(authority, 58);
    if colon as i64 != 0 {
        port = atoi(_ptr_off(colon, 1)) as i64;
        memset(colon, 0, 1 as usize);
    }

    let root: string = "/";
    let mut path: *u8 = root as *u8;
    if slash as i64 != 0 { path = slash; }

    let fd: i32 = _connect_tcp(authority, port);
    if fd < 0 {
        free(authority);
        return null;
    }

    let mut ssl: *u8 = null;
    let mut tls_ctx: *u8 = null;
    if is_https {
        tls_ctx = tls_client_ctx();
        if tls_ctx as i64 == 0 {
            free(authority);
            close(fd);
            return null;
        }
        ssl = tls_connect_fd(tls_ctx, fd, authority);
        if ssl as i64 == 0 {
            tls_ctx_free(tls_ctx);
            free(authority);
            close(fd);
            return null;
        }
    }

    // ── Build the request head ──
    // "<METHOD> <path> HTTP/1.1\r\nHost: <authority>\r\n" + <headers>
    //   [+ "Content-Length: <n>\r\n"] + "Connection: close\r\n\r\n"
    let sp: string = " ";
    let proto: string = " HTTP/1.1\r\nHost: ";
    let crlf: string = "\r\n";
    let clen_label: string = "Content-Length: ";
    let conn_close: string = "Connection: close\r\n\r\n";

    let method_len: i64 = strlen(method) as i64;
    let path_len: i64 = strlen(path) as i64;
    let host_len: i64 = strlen(authority) as i64;
    let mut headers_len: i64 = 0;
    if headers as i64 != 0 { headers_len = strlen(headers) as i64; }
    let mut body_len: i64 = 0;
    if body as i64 != 0 { body_len = strlen(body) as i64; }

    // Optional Content-Length line — only when a body is present (a
    // bare GET emits no Content-Length, matching `_http_send`).
    let mut clen: *u8 = null;
    let mut clen_len: i64 = 0;
    if body_len > 0 {
        clen = _uint_to_str(body_len);
        if clen as i64 == 0 {
            _tls_teardown(ssl, tls_ctx);
            free(authority);
            close(fd);
            return null;
        }
        clen_len = strlen(clen) as i64;
    }

    let mut total: i64 = method_len + (strlen(sp as *u8) as i64) + path_len + (strlen(proto as *u8) as i64)
        + host_len
        + (strlen(crlf as *u8) as i64)
        + headers_len
        + (strlen(conn_close as *u8) as i64);
    if body_len > 0 {
        total = total + (strlen(clen_label as *u8) as i64) + clen_len + (strlen(crlf as *u8) as i64);
    }
    let head: *u8 = malloc((total + 1) as usize);
    if head as i64 == 0 {
        if clen as i64 != 0 { free(clen); }
        _tls_teardown(ssl, tls_ctx);
        free(authority);
        close(fd);
        return null;
    }
    let mut off: i64 = 0;
    off = _append(head, off, method);
    off = _append(head, off, sp as *u8);
    off = _append(head, off, path);
    off = _append(head, off, proto as *u8);
    off = _append(head, off, authority);
    off = _append(head, off, crlf as *u8);
    if headers_len > 0 { off = _append(head, off, headers); }
    if body_len > 0 {
        off = _append(head, off, clen_label as *u8);
        off = _append(head, off, clen);
        off = _append(head, off, crlf as *u8);
    }
    off = _append(head, off, conn_close as *u8);
    memset(_ptr_off(head, off), 0, 1 as usize);
    if clen as i64 != 0 { free(clen); }

    let head_ok: bool = _send_all(fd, ssl, head, off);
    free(head);
    if !head_ok {
        _tls_teardown(ssl, tls_ctx);
        free(authority);
        close(fd);
        return null;
    }
    if body_len > 0 {
        if !_send_all(fd, ssl, body, body_len) {
            _tls_teardown(ssl, tls_ctx);
            free(authority);
            close(fd);
            return null;
        }
    }

    free(authority);
    let mut total_len: i64 = 0;
    let resp: *u8 = _recv_all(fd, ssl, & total_len);
    _tls_teardown(ssl, tls_ctx);
    close(fd);
    // Return the full raw response verbatim — the capsule parses the
    // status code and headers out of it. `_recv_all` NUL-terminates the
    // buffer; null (socket/recv error) propagates to the caller.
    return resp;
}

// ── keep-alive client (single-connection reuse, #1711) ────────────
// Optional single-connection reuse for back-to-back requests to the same
// authority (gap B4 of epic #1540). Unlike `sfn_http_get` / `_post` /
// `_request_raw` — which open a fresh connection, send `Connection: close`,
// and drain the response to EOF — these helpers keep one connection open
// across calls: `sfn_http_conn_open` connects, `sfn_http_conn_send` issues a
// request with `Connection: keep-alive` and reads exactly one Content-Length-
// framed response (so the connection stays open), and `sfn_http_conn_close`
// closes it. v0 limits match the rest of the adapter plus: the kept-alive
// response MUST be
// Content-Length framed (the Sailfin keep-alive server always sends it) —
// chunked or close-delimited keep-alive responses are out of scope, and HTTP
// pipelining is not used (one request per round-trip).
// `_resp_content_length(resp, header_end)` — the declared response
// `Content-Length` from the head `[0, header_end)`, or -1 if absent. Anchored
// to a header-line start (`\r\ncontent-length:`) and bounded to the head;
// case-insensitive (RFC 7230 §3.2). Leading OWS before the value is skipped.
fn _resp_content_length(resp: *u8, header_end: i64) -> i64 {
    let needle: string = "\r\ncontent-length:";
    let idx: i64 = _ci_find(resp, header_end, needle as *u8, 17);
    if idx < 0 { return 0 - 1; }
    // The value starts after the 17-char "\r\ncontent-length:" token.
    let mut pos: i64 = idx + 17;
    loop {
        if pos >= header_end { break; }
        let ws: i64 = _byte_at(resp, pos);
        if ws == 32 || ws == 9 {
            pos = pos + 1;
            continue;
        }
        break;
    }
    let mut value: i64 = 0;
    let mut digits: i64 = 0;
    loop {
        if pos >= header_end { break; }
        let b: i64 = _byte_at(resp, pos);
        if b < 48 || b > 57 { break; }
        value = value * 10 + (b - 48);
        digits = digits + 1;
        pos = pos + 1;
    }
    if digits == 0 { return 0 - 1; }
    return value;
}

// `_recv_one_response(fd, len_slot)` — read exactly ONE HTTP/1.1 response from
// a (possibly kept-alive) connection, delimited by `Content-Length` rather
// than EOF. Returns the FULL raw response (status line + headers + body),
// NUL-terminated and caller-owned, with the exact byte length via `len_slot`;
// null on a recv error or a missing header terminator. Unlike `_recv_all`
// (which drains to EOF, relying on the server's `Connection: close`), this
// stops at the response boundary so the connection stays open for the next
// request. A response with no `Content-Length` is taken as head-only (the v0
// keep-alive server always frames with `Content-Length`). The buffer is
// over-allocated by 4 trailing bytes so the masked 4-byte reads in
// `_resp_content_length` never fault at the final head offset.
fn _recv_one_response(fd: i32, ssl: *u8, len_slot: *i64) -> *u8 ![net] {
    atomic_store(len_slot, 0);
    let mut capacity: i64 = 8192;
    let mut len: i64 = 0;
    let mut buf: *u8 = malloc((capacity + 4) as usize);
    if buf as i64 == 0 { return null; }
    let chunk: i64 = 8192;
    let terminator: string = "\r\n\r\n";

    // Phase 1 — read until the `\r\n\r\n` header terminator (or EOF/error).
    let mut header_end: i64 = 0 - 1;
    loop {
        if len + chunk > capacity {
            let new_cap: i64 = capacity * 2;
            let new_buf: *u8 = realloc(buf, (new_cap + 4) as usize);
            if new_buf as i64 == 0 {
                free(buf);
                return null;
            }
            buf = new_buf;
            capacity = new_cap;
        }
        let mut n: i64 = 0;
        if ssl as i64 != 0 {
            n = tls_read(ssl, _ptr_off(buf, len), chunk);
        } else {
            n = recv(fd, _ptr_off(buf, len), chunk, 0);
        }
        if n < 0 {
            free(buf);
            return null;
        }
        if n == 0 { break; }
        len = len + n;
        memset(_ptr_off(buf, len), 0, 1 as usize);
        let term_ptr: *u8 = strstr(buf, terminator as *u8);
        if (term_ptr as i64) != 0 {
            header_end = ((term_ptr as i64) - (buf as i64)) + 4;
            break;
        }
    }
    if header_end < 0 {
        free(buf);
        return null;
    }

    // Phase 2 — drain exactly `Content-Length` body bytes, if any.
    let content_length: i64 = _resp_content_length(buf, header_end);
    if content_length <= 0 {
        memset(_ptr_off(buf, len), 0, 1 as usize);
        atomic_store(len_slot, len);
        return buf;
    }
    let body_target: i64 = header_end + content_length;
    loop {
        if len >= body_target { break; }
        if body_target + 4 > capacity {
            let mut new_cap: i64 = capacity;
            loop {
                if new_cap >= body_target + 4 { break; }
                new_cap = new_cap * 2;
            }
            let new_buf: *u8 = realloc(buf, (new_cap + 4) as usize);
            if new_buf as i64 == 0 {
                free(buf);
                return null;
            }
            buf = new_buf;
            capacity = new_cap;
        }
        let want: i64 = body_target - len;
        let mut n: i64 = 0;
        if ssl as i64 != 0 {
            n = tls_read(ssl, _ptr_off(buf, len), want);
        } else {
            n = recv(fd, _ptr_off(buf, len), want, 0);
        }
        if n < 0 {
            free(buf);
            return null;
        }
        // Server closed before sending the full declared body: return what
        // arrived (a short body rather than a hang).
        if n == 0 { break; }
        len = len + n;
    }
    memset(_ptr_off(buf, len), 0, 1 as usize);
    atomic_store(len_slot, len);
    return buf;
}

// Keep-alive TLS registry row layout (32 bytes):
//   +0 fd (i64), +8 SSL* (i64), +16 SSL_CTX* (i64), +24 next row (i64).
// The public keep-alive ABI stays a single `i64` handle by returning the fd
// and associating TLS state in this process-local list. The list is tiny in
// normal use and scoped to explicit `sfn_http_conn_close` cleanup.
fn _conn_tls_lookup(fd: i64) -> *u8 {
    let mut row: *u8 = http_conn_tls_head;
    loop {
        if row as i64 == 0 { break; }
        if atomic_load(row as *i64) == fd { return row; }
        row = atomic_load(_ptr_off(row, 24) as *i64) as *u8;
    }
    return null;
}

fn _conn_tls_register(fd: i64, ssl: *u8, ctx: *u8) -> bool {
    let row: *u8 = malloc(32 as usize);
    if row as i64 == 0 { return false; }
    atomic_store(row as *i64, fd);
    atomic_store(_ptr_off(row, 8) as *i64, ssl as i64);
    atomic_store(_ptr_off(row, 16) as *i64, ctx as i64);
    atomic_store(_ptr_off(row, 24) as *i64, http_conn_tls_head as i64);
    http_conn_tls_head = row;
    return true;
}

fn _conn_tls_ssl(fd: i64) -> *u8 {
    let row: *u8 = _conn_tls_lookup(fd);
    if row as i64 == 0 { return null; }
    return atomic_load(_ptr_off(row, 8) as *i64) as *u8;
}

fn _conn_tls_remove(fd: i64) -> void ![net] {
    let mut prev: *u8 = null;
    let mut row: *u8 = http_conn_tls_head;
    loop {
        if row as i64 == 0 { break; }
        let next: *u8 = atomic_load(_ptr_off(row, 24) as *i64) as *u8;
        if atomic_load(row as *i64) == fd {
            if prev as i64 == 0 { http_conn_tls_head = next; } else {
                atomic_store(_ptr_off(prev, 24) as *i64, next as i64);
            }
            let ssl: *u8 = atomic_load(_ptr_off(row, 8) as *i64) as *u8;
            let ctx: *u8 = atomic_load(_ptr_off(row, 16) as *i64) as *u8;
            _tls_teardown(ssl, ctx);
            free(row);
            return;
        }
        prev = row;
        row = next;
    }
}

// `sfn_http_conn_open(url)` — open a keep-alive TCP connection to the
// authority in `url`. Returns the connected fd as an i64 (>= 0), or -1 on a
// null url, an authority parse failure, a connect failure, or an HTTPS TLS
// verification failure. HTTPS connections keep their SSL*/SSL_CTX* in the
// process-local registry above so the public handle remains the fd.
fn sfn_http_conn_open(url: *u8) -> i64 ![net] {
    if url as i64 == 0 { return 0 - 1; }
    let https: string = "https://";
    let is_https: bool = (strstr(url, https as *u8) as i64) == (url as i64);

    // Locate the authority: skip past "scheme://" if present.
    let sep: string = "://";
    let mut host_start: *u8 = url;
    let scheme: *u8 = strstr(url, sep as *u8);
    if scheme as i64 != 0 { host_start = _ptr_off(scheme, 3); }

    let slash: *u8 = strchr(host_start, 47);
    let mut authority_len: i64 = 0;
    if slash as i64 != 0 {
        authority_len = (slash as i64) - (host_start as i64);
    } else { authority_len = strlen(host_start) as i64; }
    let authority: *u8 = _strdup_n(host_start, authority_len);
    if authority as i64 == 0 { return 0 - 1; }

    let mut port: i64 = 80;
    if is_https { port = 443; }
    let colon: *u8 = strchr(authority, 58);
    if colon as i64 != 0 {
        port = atoi(_ptr_off(colon, 1)) as i64;
        memset(colon, 0, 1 as usize);
    }
    let fd: i32 = _connect_tcp(authority, port);
    if fd < 0 {
        free(authority);
        return fd as i64;
    }
    if is_https {
        let ctx: *u8 = tls_client_ctx();
        if ctx as i64 == 0 {
            free(authority);
            close(fd);
            return 0 - 1;
        }
        let ssl: *u8 = tls_connect_fd(ctx, fd, authority);
        if ssl as i64 == 0 {
            tls_ctx_free(ctx);
            free(authority);
            close(fd);
            return 0 - 1;
        }
        if !_conn_tls_register(fd as i64, ssl, ctx) {
            _tls_teardown(ssl, ctx);
            free(authority);
            close(fd);
            return 0 - 1;
        }
    }
    free(authority);
    return fd as i64;
}

// `sfn_http_conn_send(fd, method, url, headers, body)` — send ONE request over
// an already-open keep-alive connection `fd` and read ONE Content-Length-
// framed response (the FULL raw response: status line + headers + body),
// caller-owned and NUL-terminated; null on a send/recv error. Emits
// `Connection: keep-alive` so the server keeps the connection open for the
// next call. `url` is re-parsed only for the request path and the `Host`
// authority; the connection's authority is assumed unchanged from
// `sfn_http_conn_open` (the caller's "same authority" contract). `headers` is
// a pre-serialized "Name: value\r\n" block (possibly empty); a `Content-Length`
// line is emitted only when `body` is non-empty. Same v0 limits as
// `sfn_http_request_raw`.
fn sfn_http_conn_send(fd: i64, method: *u8, url: *u8, headers: *u8, body: *u8) -> *u8 ![net] {
    if fd < 0 { return null; }
    if url as i64 == 0 { return null; }
    if method as i64 == 0 { return null; }

    // Parse authority (for the Host line) and path from the url.
    let sep: string = "://";
    let mut host_start: *u8 = url;
    let scheme: *u8 = strstr(url, sep as *u8);
    if scheme as i64 != 0 { host_start = _ptr_off(scheme, 3); }

    let slash: *u8 = strchr(host_start, 47);
    let mut authority_len: i64 = 0;
    if slash as i64 != 0 {
        authority_len = (slash as i64) - (host_start as i64);
    } else { authority_len = strlen(host_start) as i64; }
    let authority: *u8 = _strdup_n(host_start, authority_len);
    if authority as i64 == 0 { return null; }

    let root: string = "/";
    let mut path: *u8 = root as *u8;
    if slash as i64 != 0 { path = slash; }

    // ── Build the request head with Connection: keep-alive ──
    let sp: string = " ";
    let proto: string = " HTTP/1.1\r\nHost: ";
    let crlf: string = "\r\n";
    let clen_label: string = "Content-Length: ";
    let conn_keep: string = "Connection: keep-alive\r\n\r\n";

    let method_len: i64 = strlen(method) as i64;
    let path_len: i64 = strlen(path) as i64;
    let host_len: i64 = strlen(authority) as i64;
    let mut headers_len: i64 = 0;
    if headers as i64 != 0 { headers_len = strlen(headers) as i64; }
    let mut body_len: i64 = 0;
    if body as i64 != 0 { body_len = strlen(body) as i64; }

    let mut clen: *u8 = null;
    let mut clen_len: i64 = 0;
    if body_len > 0 {
        clen = _uint_to_str(body_len);
        if clen as i64 == 0 {
            free(authority);
            return null;
        }
        clen_len = strlen(clen) as i64;
    }

    let mut total: i64 = method_len + (strlen(sp as *u8) as i64) + path_len + (strlen(proto as *u8) as i64)
        + host_len
        + (strlen(crlf as *u8) as i64)
        + headers_len
        + (strlen(conn_keep as *u8) as i64);
    if body_len > 0 {
        total = total + (strlen(clen_label as *u8) as i64) + clen_len + (strlen(crlf as *u8) as i64);
    }
    let head: *u8 = malloc((total + 1) as usize);
    if head as i64 == 0 {
        if clen as i64 != 0 { free(clen); }
        free(authority);
        return null;
    }
    let mut off: i64 = 0;
    off = _append(head, off, method);
    off = _append(head, off, sp as *u8);
    off = _append(head, off, path);
    off = _append(head, off, proto as *u8);
    off = _append(head, off, authority);
    off = _append(head, off, crlf as *u8);
    if headers_len > 0 { off = _append(head, off, headers); }
    if body_len > 0 {
        off = _append(head, off, clen_label as *u8);
        off = _append(head, off, clen);
        off = _append(head, off, crlf as *u8);
    }
    off = _append(head, off, conn_keep as *u8);
    memset(_ptr_off(head, off), 0, 1 as usize);
    if clen as i64 != 0 { free(clen); }
    free(authority);

    let ssl: *u8 = _conn_tls_ssl(fd);
    let head_ok: bool = _send_all(fd as i32, ssl, head, off);
    free(head);
    if !head_ok { return null; }
    if body_len > 0 {
        if !_send_all(fd as i32, ssl, body, body_len) { return null; }
    }

    let mut total_len: i64 = 0;
    return _recv_one_response(fd as i32, ssl, & total_len);
}

// `sfn_http_conn_close(fd)` — close a keep-alive connection opened by
// `sfn_http_conn_open`. A no-op on a negative (failed-open) fd.
fn sfn_http_conn_close(fd: i64) -> void ![net] {
    if fd >= 0 {
        _conn_tls_remove(fd);
        close(fd as i32);
    }
}

// `sfn_http_download(url, output_path)` — GET `url` and write the
// body to `output_path` in binary mode. Returns the literal `"ok"`
// on success, null on failure (matching the curl
// `sailfin_runtime_http_download` contract). Uses the exact body
// length reported by `_http_send` (not `strlen`), so binary
// payloads with embedded NULs are written whole.
fn sfn_http_download(url: *u8, output_path: *u8) -> *u8 ![net, io] {
    if url as i64 == 0 { return null; }
    if output_path as i64 == 0 { return null; }
    let mut body_len: i64 = 0;
    let body: *u8 = _http_send(url, false, null, null, & body_len);
    if body as i64 == 0 { return null; }

    let mode: string = "wb";
    let f: *File = fopen(output_path, mode as *u8);
    if f as i64 == 0 {
        free(body);
        return null;
    }
    if body_len > 0 {
        fwrite(body, 1 as usize, body_len as usize, f);
    }
    fclose(f);
    free(body);

    let ok: *u8 = malloc(3 as usize);
    if ok as i64 == 0 { return null; }
    memset(_ptr_off(ok, 0), 111, 1 as usize);
    memset(_ptr_off(ok, 1), 107, 1 as usize);
    memset(_ptr_off(ok, 2), 0, 1 as usize);
    return ok;
}
