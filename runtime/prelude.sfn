// runtime/prelude.sfn
//
// Runtime facade for Sailfin programs emitted by the self-hosted compiler.
// These helpers delegate to the bootstrap runtime so Sailfin sources can run
// without bespoke Python shims once the compiler self-hosts.
//
// M2.12a (#407) added explicit imports of the seven `runtime/sfn/*.sfn`
// modules and flipped `runtime_sleep_fn` onto `sfn_sleep`. M2.12b (#408)
// extended the flip to the M2.10 type-meta cluster (`runtime_is_*_fn`,
// `runtime_resolve_runtime_type_fn`, `runtime_instance_of_fn` — see the
// per-cluster comment near each binding).
//
// M4.8 (#823) — the C runtime is now deleted (#822): there is no
// `runtime/native/src/sailfin_runtime.c` left. Every `runtime.X` member
// these delegates reach now lowers (via the descriptor registry in
// `compiler/src/llvm/runtime_helpers.sfn`) to a Sailfin body under
// `runtime/sfn/**`, so the dead namespace-handle bindings (`console`,
// `fs`, `http`, `websocket`) and the unused `runtime_assert_fail_fn`
// delegate — none of which were read in this module; dotted call sites
// like `console.log` / `fs.exists` resolve through the descriptor
// registry independently of the binding — were dropped here.
//
// The remaining `let runtime_X_fn = runtime.X` delegates below stay as
// `runtime.X` magic-namespace accesses rather than direct imports
// because the backing Sailfin bodies take raw C-ABI types (`* u8`,
// `f64`, `i64`) and rely on the descriptor registry's
// `native_signature` / `c_abi_return_type` rows to insert the
// `string ↔ * u8` / `int ↔ float` boundary casts at each call site. A
// direct `import` would bypass that bridging and is the follow-up the
// #823 audit-only `In:` list explicitly defers:
//   * `runtime_raise_value_error_fn` → `sfn_raise_value_error`
//     (`runtime/sfn/exception.sfn`).
//   * `runtime_monotonic_millis_fn` → `sfn_clock_millis`
//     (`runtime/sfn/clock.sfn`).
//   * `runtime_serve_fn` → `sailfin_runtime_serve`
//     (`runtime/sfn/concurrency/serve.sfn`, a no-op stub).
//   * `runtime_array_map_fn`, `runtime_array_filter_fn`,
//     `runtime_array_reduce_fn` → `sfn_array_sfn_map/filter/reduce`
//     (`runtime/sfn/array.sfn`, placeholders returning the input;
//     real bodies gated on closures-with-capture).
//   * `runtime_char_code_fn`, `runtime_grapheme_count_fn`,
//     `runtime_grapheme_at_fn` → `sfn_str_codepoint` /
//     `sfn_str_grapheme_count` / `sfn_str_grapheme_at`
//     (`runtime/sfn/string.sfn`).
//
// Retiring the `runtime.X` magic namespace wholesale (and with it the
// now-permanently-`null` `@runtime` global in
// `runtime/sfn/runtime_globals.sfn`) is seed-gated: the pinned seed still
// emits `@runtime = external global` in every module it compiles, so
// the definition must survive until a post-flip seed is cut. See
// the Runtime Migration table in `docs/status.md` for the full per-symbol table.
import { sfn_array_sfn_map } from "./sfn/array";
import { sfn_sleep } from "./sfn/clock";
import { sfn_throw } from "./sfn/exception";
import { sfn_log_execution, sfn_print_sfn } from "./sfn/io";
import { sfn_process_run } from "./sfn/process";
import { sfn_to_debug_string } from "./sfn/string";
import {
    sfn_instance_of,
    sfn_is_array,
    sfn_is_boolean,
    sfn_is_callable,
    sfn_is_number,
    sfn_is_string,
    sfn_is_void,
    sfn_resolve_type
} from "./sfn/type_meta";

let runtime_sleep_fn = sfn_sleep;
let runtime_monotonic_millis_fn = runtime.monotonic_millis;
let runtime_log_execution_fn = sfn_log_execution;
let runtime_to_debug_string_fn = sfn_to_debug_string;
let runtime_raise_value_error_fn = runtime.raise_value_error;
// M2.12b (#408): type-meta predicates point at their Sailfin-native
// definitions in `runtime/sfn/type_meta.sfn`. The compiler's helper
// registry still carries each descriptor's `native_signature: "sfn_*"`
// (PR #749 / M2.10 #402), so emitted IR is unchanged — this flip
// removes the Sailfin-source delegate through the magic
// `runtime.X` namespace. `runtime_is_void_fn` joined the flip under
// #925, which added the `sfn_is_void` body to
// `runtime/sfn/type_meta.sfn` and flipped its descriptor.
let runtime_is_string_fn = sfn_is_string;
let runtime_is_number_fn = sfn_is_number;
let runtime_is_boolean_fn = sfn_is_boolean;
let runtime_is_void_fn = sfn_is_void;
let runtime_is_array_fn = sfn_is_array;
let runtime_is_callable_fn = sfn_is_callable;
let runtime_resolve_runtime_type_fn = sfn_resolve_type;
let runtime_instance_of_fn = sfn_instance_of;
let runtime_serve_fn = runtime.serve;
let runtime_char_code_fn = runtime.char_code;
let runtime_array_map_fn = runtime.array_map;
let runtime_array_filter_fn = runtime.array_filter;
let runtime_array_reduce_fn = runtime.array_reduce;
let runtime_grapheme_count_fn = runtime.grapheme_count;
let runtime_grapheme_at_fn = runtime.grapheme_at;

// Standard bound interfaces (SFEP-0038 §3.4). Inert in v1: they exist so a
// generic type-parameter bound (`T: Comparable`) resolves to a real interface
// at declaration time (#1868). Satisfaction checking (E0820) and
// monomorphization are the enforcement siblings, not part of this slice.
interface Eq {
    fn eq(self, other: Self) -> boolean;
}

interface Comparable {
    fn compare(self, other: Self) -> int;
}

interface Hashable {
    fn hash(self) -> int;
}

interface Display {
    fn to_string(self) -> string;
}

// `from` is a static factory (no `self`), mirroring Rust's `From::from`.
interface From<T> {
    fn from (value: T) -> Self;
}

struct EnumField {
    name: string;
    value: any;
}

struct EnumVariantDefinition {
    name: string;
    field_names: string[];
}

struct EnumType {
    name: string;
    variants: EnumVariantDefinition[];
}

struct EnumInstance {
    type: EnumType;
    variant: string;
    fields: EnumField[];
}

struct StructField {
    name: string;
    value: any;
}

struct TypeDescriptor {
    kind: string;
    name: string?;
    items: TypeDescriptor[];
}

// Canonical typed-error result. `Result<T, E>` carries an `Ok` payload of
// the success type and an `Err` payload of the error type; the generic
// payloads are monomorphised per instantiation (#829/#830) so `value` and
// `error` read by value rather than type-erasing to `i8*`. The `?` operator
// (R.3 — #833) and emitter support (R.4 — #834) build on this declaration;
// an `E: Error` bound / `From` coercion is deferred until generic
// constraints land. See docs/proposals/0025-native-runtime-architecture.md.
enum Result<T, E> {
    Ok { value: T },
    Err { error: E }
}

// Default error payload for `Result<T, Error>`. A bare message today;
// structured fields (code, cause) follow once generic constraints allow an
// `E: Error` bound.
struct Error {
    message: string;
}

// alias-coverage: runtime helper double-ABI seam — `runtime_sleep_fn`
// (and the underlying `sfn_sleep` Sailfin definition in
// `runtime/sfn/clock.sfn`, which calls libc `nanosleep` directly
// as of PR 2 of the sleep migration / issue #397) still takes
// `double`. Cast at the boundary so the post-#556 symmetric
// int↔float refusal stays clean.
fn sleep(milliseconds: int) ![clock] {
    runtime_sleep_fn(milliseconds as float);
}

fn monotonic_millis() -> int ![clock] { return runtime_monotonic_millis_fn(); }

fn logExecution(callable: any) -> any ![io] {
    return runtime_log_execution_fn(callable);
}

fn array_map(items: any[], mapper: any) -> any[] {
    return runtime_array_map_fn(items, mapper);
}

fn array_filter(items: any[], predicate: any) -> any[] {
    return runtime_array_filter_fn(items, predicate);
}

fn array_reduce(items: any[], initial: any, reducer: any) -> any {
    return runtime_array_reduce_fn(items, initial, reducer);
}

fn char_at(value: string, index: int) -> string {
    if value.length == 0 { return ""; }
    if index < 0 { return ""; }
    if index >= value.length { return ""; }
    // alias-coverage: runtime helper double-ABI seam (see `sleep` above).
    return runtime_grapheme_at_fn(value, index as float);
}

fn enum_type(name: string) -> EnumType {
    return EnumType { name: name, variants: [] };
}

fn enum_field(name: string, value: any) -> EnumField {
    return EnumField { name: name, value: value };
}

fn enum_define_variant(enum_type: EnumType, variant_name: string, field_names: string[]) -> EnumType {
    let variant = EnumVariantDefinition {
        name: variant_name,
        field_names: field_names
    };
    let updated = enum_type.variants.concat([variant]);
    return EnumType { name: enum_type.name, variants: updated };
}

fn enum_lookup_field(fields: EnumField[], name: string) -> EnumField? {
    let mut index = 0;
    loop {
        if index >= fields.length { break; }
        let field = fields[index];
        if field.name == name { return field; }
        index = index + 1;
    }
    return null;
}

fn enum_find_variant(enum_type: EnumType, variant_name: string) -> EnumVariantDefinition? {
    let mut index = 0;
    loop {
        if index >= enum_type.variants.length { break; }
        let variant = enum_type.variants[index];
        if variant.name == variant_name { return variant; }
        index = index + 1;
    }
    return null;
}

fn enum_normalize_fields(definition: EnumVariantDefinition?, provided: EnumField[]) -> EnumField[] {
    if definition == null { return provided; }
    let expected = definition.field_names;
    if expected.length == 0 { return []; }
    let mut normalized: EnumField[] = [];
    let mut index = 0;
    loop {
        if index >= expected.length { break; }
        let field_name = expected[index];
        let candidate = enum_lookup_field(provided, field_name);
        let value = null;
        if candidate != null { value = candidate.value; }
        normalized = normalized.concat([EnumField {
            name: field_name, value: value
        }]);
        index = index + 1;
    }
    return normalized;
}

fn enum_instantiate(enum_type: EnumType, variant_name: string, provided: EnumField[]) -> EnumInstance {
    let definition = enum_find_variant(enum_type, variant_name);
    let fields = enum_normalize_fields(definition, provided);
    return EnumInstance {
        type: enum_type,
        variant: variant_name,
        fields: fields
    };
}

fn enum_get_field(instance: EnumInstance, name: string) -> any {
    let mut index = 0;
    loop {
        if index >= instance.fields.length { break; }
        let field = instance.fields[index];
        if field.name == name { return field.value; }
        index = index + 1;
    }
    return null;
}

fn struct_field(name: string, value: any) -> StructField {
    return StructField { name: name, value: value };
}

fn struct_repr(name: string, fields: StructField[]) -> string {
    let mut result = name + "(";
    let mut index = 0;
    loop {
        if index >= fields.length { break; }
        if index > 0 { result = result + ", "; }
        let field = fields[index];
        let value_text = to_debug_string(field.value);
        result = result + field.name + "=" + value_text;
        index = index + 1;
    }
    result = result + ")";
    return result;
}

fn to_debug_string(value: any) -> string {
    return runtime_to_debug_string_fn(value);
}

fn format_interpolated(parts: string[], values: any[]) -> string {
    let mut result = "";
    let mut index = 0;
    loop {
        if index >= parts.length { break; }
        result = result + parts[index];
        if index < values.length {
            result = result + to_debug_string(values[index]);
        }
        index = index + 1;
    }
    return result;
}

fn type_descriptor(kind: string, name: string?, items: TypeDescriptor[]) -> TypeDescriptor {
    return TypeDescriptor { kind: kind, name: name, items: items };
}

fn type_descriptor_primitive(name: string) -> TypeDescriptor {
    return type_descriptor("primitive", name, []);
}

fn type_descriptor_union(descriptors: TypeDescriptor[]) -> TypeDescriptor {
    return type_descriptor("union", null, descriptors);
}

fn type_descriptor_intersection(descriptors: TypeDescriptor[]) -> TypeDescriptor {
    return type_descriptor("intersection", null, descriptors);
}

fn type_descriptor_array(inner: TypeDescriptor) -> TypeDescriptor {
    return type_descriptor("array", null, [inner]);
}

fn type_descriptor_function() -> TypeDescriptor {
    return type_descriptor("function", null, []);
}

fn type_descriptor_named(name: string) -> TypeDescriptor {
    return type_descriptor("named", name, []);
}

fn type_descriptor_unknown() -> TypeDescriptor {
    return type_descriptor("unknown", null, []);
}

fn descriptor_trim(value: string) -> string {
    let mut start = 0;
    let mut end = value.length;
    loop {
        if start >= end { break; }
        let ch = grapheme_at(value, start);
        if ch == " " || ch == "\n" || ch == "\t" || ch == "\r" {
            start = start + 1;
            continue;
        }
        break;
    }
    loop {
        if end <= start { break; }
        let ch = grapheme_at(value, end - 1);
        if ch == " " || ch == "\n" || ch == "\t" || ch == "\r" {
            end = end - 1;
            continue;
        }
        break;
    }
    return substring(value, start, end);
}

fn string_starts_with(value: string, prefix: string) -> boolean {
    if prefix.length > value.length { return false; }
    let mut index = 0;
    loop {
        if index >= prefix.length { break; }
        let value_ch = grapheme_at(value, index);
        let prefix_ch = grapheme_at(prefix, index);
        if value_ch != prefix_ch { return false; }
        index = index + 1;
    }
    return true;
}

fn string_ends_with(value: string, suffix: string) -> boolean {
    if suffix.length > value.length { return false; }
    let mut offset = value.length - suffix.length;
    let mut index = 0;
    loop {
        if index >= suffix.length { break; }
        let value_ch = grapheme_at(value, offset + index);
        let suffix_ch = grapheme_at(suffix, index);
        if value_ch != suffix_ch { return false; }
        index = index + 1;
    }
    return true;
}

fn descriptor_find_top_level(value: string, needle: string) -> int {
    let trimmed = descriptor_trim(value);
    if needle.length != 1 { return -1; }
    let target = grapheme_at(needle, 0);
    let mut index = 0;
    let mut paren_depth = 0;
    let mut angle_depth = 0;
    let mut bracket_depth = 0;
    loop {
        if index >= trimmed.length { break; }
        let ch = grapheme_at(trimmed, index);
        if ch == "(" { paren_depth = paren_depth + 1; } else if ch == ")" {
            if paren_depth > 0 { paren_depth = paren_depth - 1; }
        } else if ch == "<" { angle_depth = angle_depth + 1; } else if ch == ">" {
            if angle_depth > 0 { angle_depth = angle_depth - 1; }
        } else if ch == "[" { bracket_depth = bracket_depth + 1; } else if ch == "]" {
            if bracket_depth > 0 { bracket_depth = bracket_depth - 1; }
        }
        if ch == target && paren_depth == 0 && angle_depth == 0 && bracket_depth == 0 {
            return index;
        }
        index = index + 1;
    }
    return -1;
}

fn descriptor_strip_outer_parens(value: string) -> string {
    let mut current = descriptor_trim(value);
    loop {
        if current.length < 2 { return current; }
        if grapheme_at(current, 0) != "(" { return current; }
        if grapheme_at(current, current.length - 1) != ")" { return current; }
        let mut depth = 0;
        let mut index = 0;
        let mut valid = true;
        loop {
            if index >= current.length { break; }
            let ch = grapheme_at(current, index);
            if ch == "(" { depth = depth + 1; } else if ch == ")" {
                depth = depth - 1;
                if depth < 0 {
                    valid = false;
                    break;
                }
                if depth == 0 && index < current.length - 1 {
                    valid = false;
                    break;
                }
            }
            index = index + 1;
        }
        if !valid || depth != 0 { return current; }
        current = descriptor_trim(substring(current, 1, current.length - 1));
    }
    return current;
}

fn split_descriptor(value: string, separator: string) -> string[] {
    let trimmed = descriptor_trim(value);
    if separator.length != 1 { return [trimmed]; }
    let mut parts: string[] = [];
    let mut start = 0;
    let mut index = 0;
    let mut paren_depth = 0;
    let mut angle_depth = 0;
    let mut bracket_depth = 0;
    let target = grapheme_at(separator, 0);
    loop {
        if index >= trimmed.length { break; }
        let ch = grapheme_at(trimmed, index);
        if ch == "(" { paren_depth = paren_depth + 1; } else if ch == ")" {
            if paren_depth > 0 { paren_depth = paren_depth - 1; }
        } else if ch == "<" { angle_depth = angle_depth + 1; } else if ch == ">" {
            if angle_depth > 0 { angle_depth = angle_depth - 1; }
        } else if ch == "[" { bracket_depth = bracket_depth + 1; } else if ch == "]" {
            if bracket_depth > 0 { bracket_depth = bracket_depth - 1; }
        }
        if ch == target && paren_depth == 0 && angle_depth == 0 && bracket_depth == 0 {
            let segment = substring(trimmed, start, index);
            parts = parts.concat([descriptor_trim(segment)]);
            start = index + 1;
        }
        index = index + 1;
    }
    let tail = substring(trimmed, start, trimmed.length);
    let cleaned_tail = descriptor_trim(tail);
    if cleaned_tail.length > 0 || parts.length == 0 {
        parts = parts.concat([cleaned_tail]);
    }
    return parts;
}

fn parse_descriptor_list(parts: string[]) -> TypeDescriptor[] {
    let mut descriptors: TypeDescriptor[] = [];
    let mut index = 0;
    loop {
        if index >= parts.length { break; }
        let entry = parts[index];
        if entry.length > 0 {
            descriptors = descriptors.concat([parse_type_descriptor(entry)]);
        }
        index = index + 1;
    }
    return descriptors;
}

fn parse_type_descriptor(text: string) -> TypeDescriptor {
    let trimmed = descriptor_strip_outer_parens(text);
    if trimmed.length == 0 { return type_descriptor_unknown(); }
    let union_parts = split_descriptor(trimmed, "|");
    if union_parts.length > 1 {
        return type_descriptor_union(parse_descriptor_list(union_parts));
    }
    let intersection_parts = split_descriptor(trimmed, "&");
    if intersection_parts.length > 1 {
        return type_descriptor_intersection(parse_descriptor_list(intersection_parts));
    }
    if string_ends_with(trimmed, "[]") {
        let inner_text = substring(trimmed, 0, trimmed.length - 2);
        return type_descriptor_array(parse_type_descriptor(inner_text));
    }
    if string_starts_with(trimmed, "fn(") {
        return type_descriptor_function();
    }
    if grapheme_at(trimmed, trimmed.length - 1) == "?" {
        let base_text = substring(trimmed, 0, trimmed.length - 1);
        let base_descriptor = parse_type_descriptor(base_text);
        let void_descriptor = type_descriptor_primitive("void");
        return type_descriptor_union([base_descriptor, void_descriptor]);
    }
    let generic_index = descriptor_find_top_level(trimmed, "<");
    let mut normalized = trimmed;
    if generic_index >= 0 {
        normalized = descriptor_trim(substring(trimmed, 0, generic_index));
    }
    if string_starts_with(normalized, "runtime.") {
        normalized = descriptor_trim(substring(normalized, 8, normalized.length));
    }
    if normalized == "string" || normalized == "number" || normalized == "boolean"
        || normalized == "void" {
        return type_descriptor_primitive(normalized);
    }
    return type_descriptor_named(normalized);
}

fn check_type_primitive(value: any, name: string) -> boolean {
    if name == "string" { return runtime_is_string_fn(value); }
    if name == "number" {
        return runtime_is_number_fn(value);
    }  // alias-coverage: runtime type-guard predicate keyword
    if name == "boolean" { return runtime_is_boolean_fn(value); }
    if name == "void" { return runtime_is_void_fn(value); }
    return false;
}

fn check_type_descriptor(value: any, descriptor: TypeDescriptor) -> boolean {
    if descriptor.kind == "primitive" {
        if descriptor.name == null { return false; }
        return check_type_primitive(value, descriptor.name);
    }
    if descriptor.kind == "union" {
        let mut index = 0;
        loop {
            if index >= descriptor.items.length { break; }
            if check_type_descriptor(value, descriptor.items[index]) {
                return true;
            }
            index = index + 1;
        }
        return false;
    }
    if descriptor.kind == "intersection" {
        let mut index = 0;
        loop {
            if index >= descriptor.items.length { break; }
            if !check_type_descriptor(value, descriptor.items[index]) {
                return false;
            }
            index = index + 1;
        }
        return descriptor.items.length > 0;
    }
    if descriptor.kind == "array" {
        if descriptor.items.length == 0 { return runtime_is_array_fn(value); }
        if !runtime_is_array_fn(value) { return false; }
        let element_descriptor = descriptor.items[0];
        let mut index = 0;
        loop {
            if index >= value.length { break; }
            if !check_type_descriptor(value[index], element_descriptor) {
                return false;
            }
            index = index + 1;
        }
        return true;
    }
    if descriptor.kind == "function" { return runtime_is_callable_fn(value); }
    if descriptor.kind == "named" {
        if descriptor.name == null { return false; }
        let resolved = runtime_resolve_runtime_type_fn(descriptor.name);
        return runtime_instance_of_fn(value, resolved);
    }
    if descriptor.kind == "unknown" { return false; }
    return false;
}

fn check_type(value: any, descriptor: string) -> boolean {
    let parsed = parse_type_descriptor(descriptor);
    return check_type_descriptor(value, parsed);
}

fn serve(handler: any, config: any? = null) -> void ![io, net] {
    runtime_serve_fn(handler, config);
}

fn clamp(value: int, minimum: int, maximum: int) -> int {
    if value < minimum { return minimum; }
    if value > maximum { return maximum; }
    return value;
}

fn substring(text: string, start: int, end: int) -> string {
    let length = text.length;
    if length == 0 { return ""; }
    let mut normalized_start = clamp(start, 0, length);
    let mut normalized_end = clamp(end, 0, length);
    if normalized_start >= normalized_end { return ""; }
    // Use the O(N) runtime intrinsic. The prior Sailfin-level loop did
    // `result = result + grapheme_at(text, i)` per index, which is O(N^2)
    // memory under the zero-GC runtime. grapheme_at is byte-indexed in the
    // runtime, so byte-range memcpy produces the same byte sequence as the
    // old loop. Removes ~8M of ~9M string_concat calls per module compile.
    // alias-coverage: runtime helper double-ABI seam — `substring_unchecked`
    // takes `double` start/end at the C-ABI boundary. Cast explicitly so the
    // post-#556 symmetric int↔float refusal stays clean.
    return substring_unchecked(text, normalized_start as float, normalized_end as float);
}

fn strings_equal(left: string, right: string) -> boolean {
    if left.length != right.length { return false; }
    let mut index = 0;
    loop {
        if index >= left.length { break; }
        let left_char = grapheme_at(left, index);
        let right_char = grapheme_at(right, index);
        if runtime_char_code_fn(left_char) != runtime_char_code_fn(right_char) {
            return false;
        }
        index = index + 1;
    }
    return true;
}

// Pure-Sailfin record equality for the test runner's MatchResult /
// AssertFailure records (sfn/test, issue #973). Both records reduce to a
// (boolean discriminator, string message) pair for equality purposes —
// MatchResult { ok, message } and AssertFailure { present, file, line,
// col, message } (file/line/col stay "" / 0 today; see sfn/test mod.sfn).
// A *generic* `_struct_eq` / `to_equal_record` needs the generic-struct
// monomorphization the frontend lacks, so it is deferred to the
// generic-constraints epic; this concrete helper is the pre-generics
// interim the runner needs.
fn record_eq_flag_message(left_flag: boolean, left_message: string, right_flag: boolean, right_message: string) -> boolean {
    if left_flag != right_flag { return false; }
    return strings_equal(left_message, right_message);
}

fn find_char(text: string, character: string, start: int = 0) -> int {
    let length = text.length;
    if length == 0 { return -1; }

    let mut normalized_start = start;
    if normalized_start < 0 { normalized_start = 0; }
    if normalized_start >= length { return -1; }

    let mut target = character;
    if target.length == 2 && grapheme_at(target, 0) == "\\" {
        let escape = grapheme_at(target, 1);
        if escape == "n" { target = "\n"; } else if escape == "r" {
            target = "\r";
        } else if escape == "t" { target = "\t"; }
    }

    // Fast path (#1511): a single-byte ASCII target resolves via a
    // non-allocating raw byte scan (the `load_byte` builtin — a true
    // `load i8` + `zext`) instead of the grapheme loop below, which
    // allocates a fresh grapheme string at every position (the dominant
    // cost of the `string_find_format` runtime benchmark). For an ASCII
    // needle this is exact: an ASCII byte (< 0x80) can only match a
    // standalone ASCII grapheme in UTF-8 (lead and continuation bytes are
    // all >= 0x80), and for ASCII text the byte offset equals the
    // grapheme index the slow path returns.
    if target.length == 1 {
        let code = char_code(target);
        if code >= 0 && code < 128 {
            let addr = (text as *u8) as i64;
            let mut bi = normalized_start;
            loop {
                if bi >= length { break; }
                if load_byte(addr + bi) == code { return bi; }
                bi = bi + 1;
            }
            return -1;
        }
    }

    let mut index = normalized_start;
    loop {
        if index >= length { break; }
        if strings_equal(grapheme_at(text, index), target) { return index; }
        index = index + 1;
    }

    return -1;
}

fn match_exhaustive_failed(value: any) -> void {
    let message = "Non-exhaustive match for value {{ value }}";
    runtime_raise_value_error_fn(message);
}

fn char_code(character: string) -> int {
    if character.length == 0 { return -1; }

    // Performance note: this function sits on hot paths in the compiler.
    // Prefer the runtime intrinsic instead of scanning through ASCII tables.
    // `char_at` returns a single grapheme; `runtime_char_code_fn` returns the
    // corresponding Unicode code point.
    return runtime_char_code_fn(grapheme_at(character, 0));
}

// `char_from_code(code)` — build a 1-byte string from the raw byte value
// `code` (1..255). The write counterpart to `char_code`'s read: pure-Sailfin
// code can now both read (`char_code(s[i])`) and construct (`char_from_code`)
// arbitrary single bytes, removing the `char_from_code()`-pending workarounds
// in `capsules/sfn/cli/src/style.sfn` and `capsules/sfn/crypto/src/mod.sfn`
// (#874). Unlike a codepoint encoder this writes the byte verbatim — no UTF-8
// expansion for 128..255 — so `char_code(char_from_code(n)) == n` round-trips
// across 1..255.
//
// Byte 0 returns the empty string: a lone NUL is unrepresentable under the
// current NUL-terminated `string` model (`.length` is `strlen`-recovered).
// Faithful embedded-NUL bytes arrive with the SfnString aggregate flip
// (M1.A.2); out-of-range `code` (< 0 or > 255) also yields "". The `* u8`→
// `string` cast on an alloca-backed local lowers correctly (the seed's cast
// bug is literal-only — see `runtime/sfn/platform/exec.sfn`).
//
// The backing symbol is declared `extern` here rather than imported from
// `./sfn/string`: prelude emission runs before cross-module import contexts
// are staged (#306), so a call to the imported `sfn_str_sfn_from_byte` cannot
// resolve its return type during the seed's prelude build. Re-declaring the C
// entrypoint inline is the same #306 workaround `exec.sfn` / `process.sfn`
// use; the `runtime/sfn/string.sfn` wrapper remains the migration unit that
// absorbs the body once M1.A.2 lets it consume the aggregate directly.
extern fn sfn_str_from_byte(byte_value: i64) -> *u8;

fn char_from_code(code: int) -> string {
    let bytes: *u8 = sfn_str_from_byte(code);
    return bytes as string;
}

fn grapheme_count(text: string) -> int {
    return runtime_grapheme_count_fn(text);
}

fn grapheme_at(text: string, index: int) -> string {
    // alias-coverage: runtime helper double-ABI seam (see `sleep` above).
    return runtime_grapheme_at_fn(text, index as float);
}

export {
    clamp,
    substring,
    find_char,
    record_eq_flag_message,
    grapheme_count,
    grapheme_at,
    char_code,
    char_from_code,
    match_exhaustive_failed,
    enum_type,
    enum_define_variant,
    enum_field,
    enum_instantiate,
    enum_get_field,
    struct_field,
    struct_repr,
    check_type,
    parse_type_descriptor,
    format_interpolated
};
