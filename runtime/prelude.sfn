// runtime/prelude.sfn
//
// Runtime facade for Sailfin programs emitted by the self-hosted compiler.
// These helpers delegate to the bootstrap runtime so Sailfin sources can run
// without bespoke Python shims once the compiler self-hosts.

let console = runtime.console;
let fs = runtime.fs;
let http = runtime.http;
let websocket = runtime.websocket;

struct EnumField {
name -> string;
value -> any;
}

struct EnumVariantDefinition {
name -> string;
field_names -> string[];
}

struct EnumType {
name -> string;
variants -> EnumVariantDefinition[];
}

struct EnumInstance {
type -> EnumType;
variant -> string;
fields -> EnumField[];
}

struct StructField {
name -> string;
value -> any;
}

fn sleep(milliseconds -> number) ![clock] {
runtime.sleep(milliseconds);
}

fn channel<T>(capacity -> number = 0) ![io] {
return runtime.channel(capacity);
}

fn parallel(tasks) ![io] {
let mut results = [];
for task in tasks {
let value = task();
results = results.concat([value]);
}
return results;
}

fn spawn(task, name -> string = "") ![io] {
if name.length == 0 {
runtime.spawn(task);
return;
}
runtime.spawn(task, name);
}

fn logExecution(callable) {
return runtime.logExecution(callable);
}

fn array_map(items, mapper) {
let mut result = [];
for item in items {
let mapped = mapper(item);
result = result.concat([mapped]);
}
return result;
}

fn array_filter(items, predicate) {
let mut result = [];
for item in items {
if predicate(item) {
result = result.concat([item]);
}
}
return result;
}

fn array_reduce(items, initial, reducer) {
let mut accumulator = initial;
for item in items {
accumulator = reducer(accumulator, item);
}
return accumulator;
}

fn enum_type(name -> string) -> EnumType {
return EnumType { name: name, variants: [] };
}

fn enum_field(name -> string, value) -> EnumField {
return EnumField { name: name, value: value };
}

fn enum_define_variant(enum_type -> EnumType, variant_name -> string, field_names -> string[]) -> EnumType {
let variant = EnumVariantDefinition { name: variant_name, field_names: field_names };
let updated = enum_type.variants.concat([variant]);
return EnumType { name: enum_type.name, variants: updated };
}

fn enum_lookup_field(fields -> EnumField[], name -> string) -> EnumField? {
let mut index = 0;
loop {
if index >= fields.length {
break;
}
let field = fields[index];
if field.name == name {
return field;
}
index = index + 1;
}
return null;
}

fn enum_find_variant(enum_type -> EnumType, variant_name -> string) -> EnumVariantDefinition? {
let mut index = 0;
loop {
if index >= enum_type.variants.length {
break;
}
let variant = enum_type.variants[index];
if variant.name == variant_name {
return variant;
}
index = index + 1;
}
return null;
}

fn enum_normalize_fields(definition -> EnumVariantDefinition?, provided -> EnumField[]) -> EnumField[] {
if definition == null {
return provided;
}
let expected = definition.field_names;
if expected.length == 0 {
return [];
}
let mut normalized -> EnumField[] = [];
let mut index = 0;
loop {
if index >= expected.length {
break;
}
let field_name = expected[index];
let candidate = enum_lookup_field(provided, field_name);
let value = null;
if candidate != null {
value = candidate.value;
}
normalized = normalized.concat([EnumField { name: field_name, value: value }]);
index = index + 1;
}
return normalized;
}

fn enum_instantiate(enum_type -> EnumType, variant_name -> string, provided -> EnumField[]) -> EnumInstance {
let definition = enum_find_variant(enum_type, variant_name);
let fields = enum_normalize_fields(definition, provided);
return EnumInstance { type: enum_type, variant: variant_name, fields: fields };
}

fn enum_get_field(instance -> EnumInstance, name -> string) {
let mut index = 0;
loop {
if index >= instance.fields.length {
break;
}
let field = instance.fields[index];
if field.name == name {
return field.value;
}
index = index + 1;
}
return null;
}

fn struct_field(name -> string, value) -> StructField {
return StructField { name: name, value: value };
}

fn struct_repr(name -> string, fields -> StructField[]) -> string {
let mut result = name + "(";
let mut index = 0;
loop {
if index >= fields.length {
break;
}
if index > 0 {
result = result + ", ";
}
let field = fields[index];
let value_text = to_debug_string(field.value);
result = result + field.name + "=" + value_text;
index = index + 1;
}
result = result + ")";
return result;
}

fn to_debug_string(value) -> string {
return runtime.to_debug_string(value);
}

fn serve(handler, config = null) ![io, net] {
runtime.serve(handler, config);
}

fn clamp(value -> number, minimum -> number, maximum -> number) -> number {
if value < minimum {
return minimum;
}
if value > maximum {
return maximum;
}
return value;
}

fn substring(text -> string, start -> number, end -> number) -> string {
let length = text.length;
if length == 0 {
return "";
}

let mut normalized_start = clamp(start, 0, length);
let mut normalized_end = clamp(end, 0, length);

if normalized_start >= normalized_end {
return "";
}

let mut index = normalized_start;
let mut result = "";
loop {
if index >= normalized_end {
break;
}
result = result + text[index];
index = index + 1;
}
return result;
}

fn find_char(text -> string, character -> string, start -> number = 0) -> number {
let length = text.length;
if length == 0 {
return -1;
}

let mut normalized_start = start;
if normalized_start < 0 {
normalized_start = 0;
}
if normalized_start >= length {
return -1;
}

let mut target = character;
if target.length == 2 && target[0] == "\\" {
let escape = target[1];
if escape == "n" {
target = "\n";
} else if escape == "r" {
target = "\r";
} else if escape == "t" {
target = "\t";
}
}

let mut index = normalized_start;
loop {
if index >= length {
break;
}
if text[index] == target {
return index;
}
index = index + 1;
}

return -1;
}

fn match_exhaustive_failed(value) -> void {
let message = "Non-exhaustive match for value {{ value }}";
runtime.raise_value_error(message);
}

fn char_code(character -> string) -> number {
if character.length == 0 {
return -1;
}

let ch = character[0];

let digits = "0123456789";
let digit_index = find_char(digits, ch, 0);
if digit_index >= 0 {
return 48 + digit_index;
}

let lowercase = "abcdefghijklmnopqrstuvwxyz";
let lowercase_index = find_char(lowercase, ch, 0);
if lowercase_index >= 0 {
return 97 + lowercase_index;
}

let uppercase = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
let uppercase_index = find_char(uppercase, ch, 0);
if uppercase_index >= 0 {
return 65 + uppercase_index;
}

if ch == " " {
return 32;
}
if ch == "\n" {
return 10;
}
if ch == "\r" {
return 13;
}
if ch == "\t" {
return 9;
}
if ch == "\"" {
return 34;
}
if ch == "\\" {
return 92;
}
if ch == "_" {
return 95;
}

let encoded = ch.encode("utf-8");
let count = encoded.length;
if count == 0 {
return -1;
}
if count > 4 {
return -1;
}

let mut index = 0;
let mut code = 0;
loop {
if index >= count {
break;
}

let byte = encoded[index];
if index == 0 {
if byte < 128 {
return byte;
}

if byte >= 192 && byte <= 223 {
code = byte - 192;
} else if byte >= 224 && byte <= 239 {
code = byte - 224;
} else if byte >= 240 && byte <= 247 {
code = byte - 240;
} else {
return -1;
}
} else {
if byte < 128 || byte > 191 {
return -1;
}
code = (code * 64) + (byte - 128);
}

index = index + 1;
}

return code;
}

export { clamp, substring, find_char, char_code, match_exhaustive_failed, enum_type, enum_define_variant, enum_field, enum_instantiate, enum_get_field, struct_field, struct_repr };
