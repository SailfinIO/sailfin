// Tests for sfn/losses — regression and classification loss functions.
//
// Moved from compiler/tests/unit/losses_test.sfn. The previous version
// re-implemented every helper with `_`-prefixed copies; this version imports
// the real capsule API directly via the sibling src/mod.sfn.

import {
    mse,
    mae,
    huber,
    hinge,
    squared_error,
    absolute_error,
} from "../src/mod";

test "losses: mse computes mean squared error" {
    assert mse([1, 2, 3], [1, 2, 3]) == 0;
    // [1,2,3] vs [4,5,6] => (9+9+9)/3 = 9
    assert mse([1, 2, 3], [4, 5, 6]) == 9;
    // [0] vs [1] => 1/1 = 1
    assert mse([0], [1]) == 1;
}

test "losses: mae computes mean absolute error" {
    assert mae([1, 2, 3], [1, 2, 3]) == 0;
    // [1,2,3] vs [4,5,6] => (3+3+3)/3 = 3
    assert mae([1, 2, 3], [4, 5, 6]) == 3;
    // [0] vs [3] => 3/1 = 3
    assert mae([0], [3]) == 3;
}

test "losses: huber loss with delta=1" {
    // Small errors: quadratic (same as 0.5*MSE)
    assert huber([1], [1], 1) == 0;
    // [0] vs [0.5] => 0.5 * 0.25 = 0.125
    assert huber([0], [0.5], 1) == 0.125;
}

test "losses: hinge loss for binary classification" {
    // prediction=2, target=1 => margin = 1-2 = -1 < 0 => 0
    assert hinge([2], [1]) == 0;
    // prediction=-2, target=-1 => margin = 1-2 = -1 < 0 => 0
    assert hinge([-2], [-1]) == 0;
    // Misclassification: prediction=0.5, target=-1 => margin = 1-(-0.5) = 1.5
    assert hinge([0.5], [-1]) == 1.5;
}

test "losses: squared_error single sample" {
    assert squared_error(3, 1) == 4;
    assert squared_error(0, 0) == 0;
    assert squared_error(-1, 1) == 4;
}

test "losses: absolute_error single sample" {
    assert absolute_error(3, 1) == 2;
    assert absolute_error(0, 0) == 0;
    assert absolute_error(-1, 1) == 2;
    assert absolute_error(1, 3) == 2;
}

test "losses: empty arrays return zero" {
    assert mse([], []) == 0;
    assert mae([], []) == 0;
    assert huber([], [], 1) == 0;
    assert hinge([], []) == 0;
}

test "losses: mismatched lengths return zero" {
    // targets shorter than predictions
    assert mse([1, 2, 3], [1]) == 0;
    assert mae([1, 2, 3], [1]) == 0;
}
