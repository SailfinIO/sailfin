// sfn/nn — Neural network training and inference utilities for Sailfin.
//
// Provides higher-level abstractions for training loops, gradient descent,
// and common activation functions.
//
// GPU-accelerated dispatch is planned but not yet implemented.
// All operations currently execute on the CPU.
//
// Usage:
//   import { sigmoid, tanh, softmax } from "nn"
//
// Training loops and automatic differentiation are planned for a future
// release once the `gpu` effect runtime is available.
// ---- Activation functions ----
fn relu(x: float) -> float {
    // Rectified linear unit: max(0, x).
    if x > 0 { return x; }
    return 0;
}

fn relu_array(input: float[]) -> float[] {
    // Apply ReLU element-wise.
    let mut out: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= input.length { break; }
        out.push(relu(input[i]));
        i += 1;
    }
    return out;
}

fn leaky_relu(x: float, alpha: float = 0.01) -> float {
    // Leaky ReLU: x if x > 0, else alpha * x.
    if x > 0 { return x; }
    return alpha * x;
}

// sigmoid is not yet implemented.
// Requires exp() runtime support (math intrinsic) for a correct implementation.
// A piecewise linear placeholder was removed because its error bounds
// (up to 0.12 absolute error, wrong curvature everywhere) make it
// unsuitable as an activation function — it would produce incorrect
// gradients and misleading outputs.
fn step(x: float) -> float {
    // Heaviside step function.
    if x >= 0 { return 1; }
    return 0;
}

// ---- Normalization ----
fn normalize(input: float[]) -> float[] {
    // Min-max normalization to [0, 1] range.
    if input.length == 0 { return []; }
    let mut min_v: float = input[0];
    let mut max_v: float = input[0];
    let mut i: int = 1;
    loop {
        if i >= input.length { break; }
        if input[i] < min_v { min_v = input[i]; }
        if input[i] > max_v { max_v = input[i]; }
        i += 1;
    }
    let range = max_v - min_v;
    if range == 0 { return input; }
    let mut out: float[] = [];
    i = 0;
    loop {
        if i >= input.length { break; }
        out.push((input[i] - min_v) / range);
        i += 1;
    }
    return out;
}

fn standardize(input: float[], mean_val: float, std_val: float) -> float[] {
    // Z-score standardization: (x - mean) / std.
    if std_val == 0 { return input; }
    let mut out: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= input.length { break; }
        out.push((input[i] - mean_val) / std_val);
        i += 1;
    }
    return out;
}

// ---- Utility ----
fn argmax(input: float[]) -> int {
    // Index of the maximum value.
    if input.length == 0 { return -1; }
    let mut best_idx: int = 0;
    let mut best_val: float = input[0];
    let mut i: int = 1;
    loop {
        if i >= input.length { break; }
        if input[i] > best_val {
            best_val = input[i];
            best_idx = i;
        }
        i += 1;
    }
    return best_idx;
}

fn argmin(input: float[]) -> int {
    // Index of the minimum value.
    if input.length == 0 { return -1; }
    let mut best_idx: int = 0;
    let mut best_val: float = input[0];
    let mut i: int = 1;
    loop {
        if i >= input.length { break; }
        if input[i] < best_val {
            best_val = input[i];
            best_idx = i;
        }
        i += 1;
    }
    return best_idx;
}

fn one_hot(index: int, size: int) -> float[] {
    // Create a one-hot encoded vector.
    let mut out: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= size { break; }
        if i == index { out.push(1); } else { out.push(0); }
        i += 1;
    }
    return out;
}

fn clip(x: float, lo: float, hi: float) -> float {
    // Clip a value to [lo, hi].
    if x < lo { return lo; }
    if x > hi { return hi; }
    return x;
}
