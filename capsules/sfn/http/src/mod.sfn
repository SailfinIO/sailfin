// sfn/http — HTTP server and request handling for Sailfin.
//
// This capsule provides the core HTTP primitives for building web services.
// It wraps the runtime's net capabilities behind a safe, typed API.

struct Request {
    method -> string;
    path -> string;
    headers -> string[];
    body -> string;
}

struct Response {
    status -> number;
    headers -> string[];
    body -> string;
}

struct ServerConfig {
    port -> number;
    host -> string;
}

fn response(body -> string) -> Response {
    return Response {
        status: 200,
        headers: [],
        body: body,
    };
}

fn response_with_status(status -> number, body -> string) -> Response {
    return Response {
        status: status,
        headers: [],
        body: body,
    };
}

fn serve(handler -> any, config -> any?) -> void ![io, net] {
    // Delegates to the runtime's serve intrinsic.
