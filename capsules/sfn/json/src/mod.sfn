// sfn/json — JSON parsing and serialization for Sailfin.
//
// Provides functions for converting between Sailfin values and JSON strings.
// No effects required — pure data transformation.
struct JsonValue {
    kind: string;  // "string", "number", "boolean", "null", "array", "object"
    string_value: string;
    number_value: float;
    bool_value: boolean;
    items: JsonValue[];  // for arrays
    keys: string[];  // for objects
    values: JsonValue[];  // for objects (parallel with keys)
}

fn string_val(value: string) -> JsonValue {
    return JsonValue {
        kind: "string",
        string_value: value,
        number_value: 0,
        bool_value: false,
        items: [],
        keys: [],
        values: []
    };
}

fn number_val(value: float) -> JsonValue {
    return JsonValue {
        kind: "number",
        string_value: "",
        number_value: value,
        bool_value: false,
        items: [],
        keys: [],
        values: []
    };
}

fn bool_val(value: boolean) -> JsonValue {
    return JsonValue {
        kind: "boolean",
        string_value: "",
        number_value: 0,
        bool_value: value,
        items: [],
        keys: [],
        values: []
    };
}

fn null_val() -> JsonValue {
    return JsonValue {
        kind: "null",
        string_value: "",
        number_value: 0,
        bool_value: false,
        items: [],
        keys: [],
        values: []
    };
}

fn array_val(items: JsonValue[]) -> JsonValue {
    return JsonValue {
        kind: "array",
        string_value: "",
        number_value: 0,
        bool_value: false,
        items: items,
        keys: [],
        values: []
    };
}

fn object_val(keys: string[], values: JsonValue[]) -> JsonValue {
    return JsonValue {
        kind: "object",
        string_value: "",
        number_value: 0,
        bool_value: false,
        items: [],
        keys: keys,
        values: values
    };
}

// ---- Escape helpers (shared by parse + stringify) ----
// Real UTF-8 encode of a single code point via the runtime helper
// (rejects surrogates / out-of-range, returning ""). The `\uXXXX` decoder
// reuses this rather than hand-rolling UTF-8. Same `* u8 as string` cast
// surface the prelude's `char_from_code` uses.
extern fn sfn_str_from_codepoint(cp: i64) -> * u8;

fn _from_codepoint(cp: int) -> string {
    let bytes: * u8 = sfn_str_from_codepoint(cp);
    return bytes as string;
}

fn _hex_val(ch: string) -> int {
    let c = char_code(ch);
    if c >= 48 && c <= 57 { return c - 48; }
    if c >= 97 && c <= 102 { return c - 87; }
    if c >= 65 && c <= 70 { return c - 55; }
    return -1;
}

fn _read_hex(text: string, p: int, n: int) -> int {
    if p + n > text.length { return -1; }
    let mut val: int = 0;
    let mut i: int = 0;
    loop {
        if i >= n { break; }
        let d = _hex_val(text[p + i]);
        if d < 0 { return -1; }
        val = val * 16 + d;
        i += 1;
    }
    return val;
}

fn _hex_digit_char(n: int) -> string {
    let digits = "0123456789ABCDEF";
    return digits[n];
}

fn _hex2(code: int) -> string {
    return _hex_digit_char((code / 16) % 16) + _hex_digit_char(code % 16);
}

// ---- Serialization ----
fn _escape_json_string(s: string) -> string {
    let mut out: string = "";
    let mut i: int = 0;
    loop {
        if i >= s.length { break; }
        let ch = s[i];
        let code = char_code(ch);
        if ch == "\"" { out = out + "\\\""; } else if ch == "\\" {
            out = out + "\\\\";
        } else if code == 8 { out = out + "\\b"; } else if code == 9 {
            out = out + "\\t";
        } else if code == 10 { out = out + "\\n"; } else if code == 12 {
            out = out + "\\f";
        } else if code == 13 { out = out + "\\r"; } else if code >= 0 && code < 32 {
            out = out + "\\u00" + _hex2(code);
        } else { out = out + ch; }
        i += 1;
    }
    return out;
}

fn stringify(value: JsonValue) -> string {
    // Serialize a JsonValue to a JSON string.
    if strings_equal(value.kind, "string") {
        return "\"" + _escape_json_string(value.string_value) + "\"";
    }
    if strings_equal(value.kind, "number") {
        return number_to_string(value.number_value);
    }
    if strings_equal(value.kind, "boolean") {
        if value.bool_value { return "true"; }
        return "false";
    }
    if strings_equal(value.kind, "null") { return "null"; }
    if strings_equal(value.kind, "array") {
        let mut out: string = "[";
        let mut i: int = 0;
        loop {
            if i >= value.items.length { break; }
            if i > 0 { out = out + ","; }
            out = out + stringify(value.items[i]);
            i += 1;
        }
        return out + "]";
    }
    if strings_equal(value.kind, "object") {
        let mut out: string = "{";
        let mut i: int = 0;
        loop {
            if i >= value.keys.length { break; }
            if i > 0 { out = out + ","; }
            out = out + "\"" + _escape_json_string(value.keys[i]) + "\":"
                + stringify(value.values[i]);
            i += 1;
        }
        return out + "}";
    }
    return "null";
}

// ---- Parsing ----
// Minimal recursive-descent JSON parser.
//
// Hardened against stack-exhaustion DoS (#1585, SFN-156): recursion depth
// and total input length are bounded by a caller-supplied `ParseLimits`.
// Adversarial JSON-RPC reaches this parser on the proxy hot path, so a
// pathologically deep document (e.g. thousands of nested `[`) must be
// rejected at the cap rather than overflowing the native stack, and the
// caller must be able to tighten the caps for its own trust boundary.
struct ParseLimits {
    max_depth: int;  // maximum nesting depth before a clean reject
    max_input_len: int;  // maximum input length (text.length) before a clean reject
}

// Sane defaults used by the bare `parse(text)` entry point. Callers that
// inspect untrusted traffic under a tighter budget pass their own limits to
// `parse_with_limits`.
fn default_limits() -> ParseLimits {
    return ParseLimits { max_depth: 1000, max_input_len: 10000000 };
}

// Outcome of a bounded parse: `ok` is false when a guard was breached, with
// `error` carrying a stable human-readable reason ("" when ok). `value` holds
// the (possibly partial) tree so callers that only need best-effort data can
// still read it.
struct ParseOutcome {
    ok: boolean;
    error: string;
    value: JsonValue;
}

fn _skip_whitespace(text: string, pos: int) -> int {
    let mut p: int = pos;
    loop {
        if p >= text.length { break; }
        let ch = text[p];
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" { p += 1; } else {
            break;
        }
    }
    return p;
}

fn parse(text: string) -> JsonValue {
    // Parse a JSON string into a JsonValue tree using the default limits.
    // Returns null_val() on over-length input; on a depth breach it returns
    // the best-effort (partial) tree without crashing. Callers that need to
    // distinguish a guard breach from valid data use `parse_with_limits`.
    return parse_with_limits(text, default_limits()).value;
}

fn parse_with_limits(text: string, limits: ParseLimits) -> ParseOutcome {
    // Parse under caller-supplied depth/size caps, reporting a clean error
    // rather than crashing when either is breached. The size cap is checked
    // up front; the depth cap is enforced during recursion and its breach is
    // propagated out through `_ParseResult.error`.
    if text.length > limits.max_input_len {
        return ParseOutcome {
            ok: false,
            error: "input exceeds maximum size",
            value: null_val()
        };
    }
    let result = _parse_value(text, 0, 0, limits);
    if result.error.length > 0 {
        return ParseOutcome {
            ok: false,
            error: result.error,
            value: result.value
        };
    }
    return ParseOutcome { ok: true, error: "", value: result.value };
}

struct _ParseResult {
    value: JsonValue;
    pos: int;
    error: string;  // "" on success; a guard-breach reason otherwise
}

fn _parse_result(value: JsonValue, pos: int) -> _ParseResult {
    return _ParseResult { value: value, pos: pos, error: "" };
}

fn _parse_result_err(value: JsonValue, pos: int, error: string) -> _ParseResult {
    return _ParseResult { value: value, pos: pos, error: error };
}

fn _parse_value(text: string, start: int, depth: int, limits: ParseLimits) -> _ParseResult {
    let pos = _skip_whitespace(text, start);
    if pos >= text.length { return _parse_result(null_val(), pos); }
    // Bound recursion: reject input that nests past the depth cap instead
    // of recursing until the native stack overflows (#1585).
    if depth > limits.max_depth {
        return _parse_result_err(null_val(), pos, "maximum nesting depth exceeded");
    }
    let ch = text[pos];
    if ch == "\"" { return _parse_string(text, pos); }
    if ch == "{" {
        return _parse_object(text, pos, depth, limits);
    }
    if ch == "[" {
        return _parse_array(text, pos, depth, limits);
    }
    if ch == "t" || ch == "f" { return _parse_bool(text, pos); }
    if ch == "n" { return _parse_result(null_val(), pos + 4); }
    // Must be a number
    return _parse_number(text, pos);
}

fn _parse_string(text: string, start: int) -> _ParseResult {
    // start points at opening "
    let mut p: int = start + 1;
    let mut out: string = "";
    loop {
        if p >= text.length { break; }
        let ch = text[p];
        if ch == "\"" { return _parse_result(string_val(out), p + 1); }
        if ch == "\\" {
            p += 1;
            if p < text.length {
                let esc = text[p];
                if esc == "\"" { out = out + "\""; } else if esc == "\\" {
                    out = out + "\\";
                } else if esc == "/" { out = out + "/"; } else if esc == "b" {
                    out = out + _from_codepoint(8);
                } else if esc == "f" { out = out + _from_codepoint(12); } else if esc == "n" {
                    out = out + "\n";
                } else if esc == "r" { out = out + "\r"; } else if esc == "t" {
                    out = out + "\t";
                } else if esc == "u" {
                    let cp = _read_hex(text, p + 1, 4);
                    if cp < 0 { out = out + esc; } else {
                        p += 4;
                        if cp >= 55296 && cp <= 56319 {
                            // High surrogate: combine with a following low
                            // surrogate \uXXXX into the astral code point.
                            let mut combined: int = -1;
                            if p + 2 < text.length && text[p + 1] == "\\"
                                && text[p
                                + 2] == "u" {
                                let lo = _read_hex(text, p + 3, 4);
                                if lo >= 56320 && lo <= 57343 {
                                    combined = 65536 + (cp - 55296) * 1024 + (lo - 56320);
                                    p += 6;
                                }
                            }
                            if combined >= 0 {
                                out = out + _from_codepoint(combined);
                            } else { out = out + _from_codepoint(65533); }
                        } else if cp >= 56320 && cp <= 57343 {
                            // Lone low surrogate: emit U+FFFD replacement.
                            out = out + _from_codepoint(65533);
                        } else { out = out + _from_codepoint(cp); }
                    }
                } else { out = out + esc; }
            }
        } else { out = out + ch; }
        p += 1;
    }
    return _parse_result(string_val(out), p);
}

fn _parse_number(text: string, start: int) -> _ParseResult {
    let mut p: int = start;
    loop {
        if p >= text.length { break; }
        let ch = text[p];
        if ch == "," || ch == "}" || ch == "]" || ch == " " || ch == "\n" || ch == "\r"
            || ch == "\t" { break; }
        p += 1;
    }
    let num_str = substring(text, start, p);
    // Use a simple string-to-number conversion
    // Full implementation will use a runtime intrinsic
    let mut value: float = 0.0;
    let mut i: int = 0;
    let mut negative: boolean = false;
    let mut decimal_place: int = 0;
    if num_str.length > 0 && num_str[0] == "-" {
        negative = true;
        i = 1;
    }
    loop {
        if i >= num_str.length { break; }
        let ch = num_str[i];
        if ch == "." { decimal_place = 1; } else {
            let digit = char_code(ch) - 48;
            if decimal_place > 0 {
                let mut divisor: float = 1.0;
                let mut d: int = 0;
                loop {
                    if d >= decimal_place { break; }
                    divisor = divisor * 10.0;
                    d += 1;
                }
                value = value + (digit as float) / divisor;
                decimal_place += 1;
            } else { value = value * 10.0 + (digit as float); }
        }
        i += 1;
    }
    if negative { value = 0.0 - value; }
    return _parse_result(number_val(value), p);
}

fn _parse_bool(text: string, start: int) -> _ParseResult {
    if text[start] == "t" {
        return _parse_result(bool_val(true), start + 4);
    }
    return _parse_result(bool_val(false), start + 5);
}

fn _parse_array(text: string, start: int, depth: int, limits: ParseLimits) -> _ParseResult {
    let mut p: int = start + 1;  // skip [
    let mut items: JsonValue[] = [];
    p = _skip_whitespace(text, p);
    if p < text.length && text[p] == "]" {
        return _parse_result(array_val(items), p + 1);
    }
    loop {
        if p >= text.length { break; }
        let item = _parse_value(text, p, depth + 1, limits);
        items.push(item.value);
        // Propagate a guard breach (e.g. depth cap) out with the partial tree
        // instead of continuing to parse structurally-broken input.
        if item.error.length > 0 {
            return _parse_result_err(array_val(items), item.pos, item.error);
        }
        p = _skip_whitespace(text, item.pos);
        if p < text.length && text[p] == "," { p += 1; } else { break; }
    }
    p = _skip_whitespace(text, p);
    if p < text.length && text[p] == "]" { p += 1; }
    return _parse_result(array_val(items), p);
}

fn _parse_object(text: string, start: int, depth: int, limits: ParseLimits) -> _ParseResult {
    let mut p: int = start + 1;  // skip {
    let mut keys: string[] = [];
    let mut values: JsonValue[] = [];
    p = _skip_whitespace(text, p);
    if p < text.length && text[p] == "}" {
        return _parse_result(object_val(keys, values), p + 1);
    }
    loop {
        if p >= text.length { break; }
        p = _skip_whitespace(text, p);
        // Parse key
        let key_result = _parse_string(text, p);
        keys.push(key_result.value.string_value);
        p = _skip_whitespace(text, key_result.pos);
        if p < text.length && text[p] == ":" { p += 1; }
        // Parse value
        let val_result = _parse_value(text, p, depth + 1, limits);
        values.push(val_result.value);
        if val_result.error.length > 0 {
            return _parse_result_err(object_val(keys, values), val_result.pos, val_result.error);
        }
        p = _skip_whitespace(text, val_result.pos);
        if p < text.length && text[p] == "," { p += 1; } else { break; }
    }
    p = _skip_whitespace(text, p);
    if p < text.length && text[p] == "}" { p += 1; }
    return _parse_result(object_val(keys, values), p);
}

// ---- Convenience accessors ----
fn get_string(obj: JsonValue, key: string) -> string {
    // Get a string value from a JSON object by key.
    if !strings_equal(obj.kind, "object") { return ""; }
    let mut i: int = 0;
    loop {
        if i >= obj.keys.length { break; }
        if strings_equal(obj.keys[i], key) {
            return obj.values[i].string_value;
        }
        i += 1;
    }
    return "";
}

fn get_number(obj: JsonValue, key: string) -> float {
    if !strings_equal(obj.kind, "object") { return 0; }
    let mut i: int = 0;
    loop {
        if i >= obj.keys.length { break; }
        if strings_equal(obj.keys[i], key) {
            return obj.values[i].number_value;
        }
        i += 1;
    }
    return 0;
}

fn get_object(obj: JsonValue, key: string) -> JsonValue {
    if !strings_equal(obj.kind, "object") { return null_val(); }
    let mut i: int = 0;
    loop {
        if i >= obj.keys.length { break; }
        if strings_equal(obj.keys[i], key) { return obj.values[i]; }
        i += 1;
    }
    return null_val();
}

fn get_array(obj: JsonValue, key: string) -> JsonValue[] {
    if !strings_equal(obj.kind, "object") { return []; }
    let mut i: int = 0;
    loop {
        if i >= obj.keys.length { break; }
        if strings_equal(obj.keys[i], key) { return obj.values[i].items; }
        i += 1;
    }
    return [];
}

fn get_bool(obj: JsonValue, key: string) -> boolean {
    // Get a boolean value from a JSON object by key. Returns false if not found.
    if !strings_equal(obj.kind, "object") { return false; }
    let mut i: int = 0;
    loop {
        if i >= obj.keys.length { break; }
        if strings_equal(obj.keys[i], key) {
            return obj.values[i].bool_value;
        }
        i += 1;
    }
    return false;
}

fn get_value(obj: JsonValue, key: string) -> JsonValue {
    // Get any value from a JSON object by key. Returns null_val() if not found.
    if !strings_equal(obj.kind, "object") { return null_val(); }
    let mut i: int = 0;
    loop {
        if i >= obj.keys.length { break; }
        if strings_equal(obj.keys[i], key) { return obj.values[i]; }
        i += 1;
    }
    return null_val();
}

fn has_key(obj: JsonValue, key: string) -> boolean {
    // Returns true if the JSON object contains the given key.
    if !strings_equal(obj.kind, "object") { return false; }
    let mut i: int = 0;
    loop {
        if i >= obj.keys.length { break; }
        if strings_equal(obj.keys[i], key) { return true; }
        i += 1;
    }
    return false;
}

fn array_length(value: JsonValue) -> int {
    // Returns the number of items in a JSON array, or 0 if not an array.
    if !strings_equal(value.kind, "array") { return 0; }
    return value.items.length;
}

fn array_at(value: JsonValue, index: int) -> JsonValue {
    // Get an item from a JSON array by index. Returns null_val() if out of bounds.
    if !strings_equal(value.kind, "array") { return null_val(); }
    if index < 0 || index >= value.items.length { return null_val(); }
    return value.items[index];
}

fn stringify_pretty(value: JsonValue, indent: int = 2) -> string {
    // Serialize a JsonValue to a pretty-printed JSON string.
    return _stringify_indented(value, 0, indent);
}

fn _make_indent(level: int, size: int) -> string {
    let mut out: string = "";
    let mut i: int = 0;
    let total = level * size;
    loop {
        if i >= total { break; }
        out = out + " ";
        i += 1;
    }
    return out;
}

fn _stringify_indented(value: JsonValue, level: int, size: int) -> string {
    if strings_equal(value.kind, "string") {
        return "\"" + _escape_json_string(value.string_value) + "\"";
    }
    if strings_equal(value.kind, "number") {
        return number_to_string(value.number_value);
    }
    if strings_equal(value.kind, "boolean") {
        if value.bool_value { return "true"; }
        return "false";
    }
    if strings_equal(value.kind, "null") { return "null"; }
    if strings_equal(value.kind, "array") {
        if value.items.length == 0 { return "[]"; }
        let inner = level + 1;
        let pad = _make_indent(inner, size);
        let close_pad = _make_indent(level, size);
        let mut out: string = "[\n";
        let mut i: int = 0;
        loop {
            if i >= value.items.length { break; }
            if i > 0 { out = out + ",\n"; }
            out = out + pad + _stringify_indented(value.items[i], inner, size);
            i += 1;
        }
        return out + "\n" + close_pad + "]";
    }
    if strings_equal(value.kind, "object") {
        if value.keys.length == 0 { return "{}"; }
        let inner = level + 1;
        let pad = _make_indent(inner, size);
        let close_pad = _make_indent(level, size);
        let mut out: string = "{\n";
        let mut i: int = 0;
        loop {
            if i >= value.keys.length { break; }
            if i > 0 { out = out + ",\n"; }
            out = out + pad + "\"" + _escape_json_string(value.keys[i]) + "\": "
                + _stringify_indented(value.values[i], inner, size);
            i += 1;
        }
        return out + "\n" + close_pad + "}";
    }
    return "null";
}
