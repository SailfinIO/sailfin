// Tests for sfn/crypto SHA-256 (pure-Sailfin, FIPS 180-4).
//
// Known-answer vectors covering the empty string, the canonical "abc"
// vector, and a >64-byte input that forces multi-block processing plus
// length-padding into a second block.
import { sha256, sha256_hex } from "../src/mod";

test "sha256_hex: empty string" {
    assert sha256_hex("") == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855";
}

test "sha256_hex: abc" {
    assert sha256_hex("abc") == "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad";
}

test "sha256_hex: 448-bit two-block vector" {
    assert sha256_hex("abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq") == "248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1";
}

test "sha256_hex: 64-byte block boundary" {
    // Exactly 64 bytes: padding spills into a second block.
    assert sha256_hex("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa") == "ffe054fe7ae0cb6dc65c3af9b61d5209f439851db43d0ba5997337df154668eb";
}

test "sha256: prefixed digest" {
    assert sha256("abc") == "sha256:ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad";
}

test "sha256_hex: non-ASCII UTF-8 (single multibyte char)" {
    // "é" is the two UTF-8 bytes 0xc3 0xa9; byte-oriented indexing hashes
    // them raw, matching `printf 'é' | sha256sum`.
    assert sha256_hex("é") == "4a99557e4033c3539de2eb65472017cad5f9557f7a0625a09f1c3f6e2ba69c4c";
}

test "sha256_hex: non-ASCII UTF-8 (mixed ASCII + multibyte)" {
    assert sha256_hex("héllo wörld") == "a1003f7d04a4115711d0b48a2eaf1359ce565d2d2a6fd65098dfcffadeeef59f";
}
