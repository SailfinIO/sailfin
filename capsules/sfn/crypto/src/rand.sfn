// capsules/sfn/crypto/src/rand.sfn
//
// random_bytes(n) — cryptographically secure random bytes from the host OS
// entropy source, the CSPRNG piece of SFEP-0048 Phase D (SFN-123). Unlike
// every other sfn/crypto primitive (pure, deterministic, effect-free), this
// reads the kernel CSPRNG and is therefore the capsule's one effectful
// function: it carries `![rand]`.
//
// The entropy syscall lives in the runtime (`runtime/sfn/platform/rand.sfn`,
// `sfn_rand_fill`), linked into every Sailfin binary via `runtime/capsule.toml`
// `sfn-sources`; this wrapper reaches it by the same symbol-name-only extern
// pattern `capsules/sfn/net` uses for `sfn_net_connect`. An effect cannot sit
// on the raw extern (E0804), so the `![rand]` gate lives here on the public
// Sailfin wrapper, where it propagates to callers.
//
// Fail-closed: on any entropy-source error `random_bytes` returns `[]` (an
// empty array) — never a zeroed or partially initialised buffer. A caller that
// needs `n` bytes must check `result.length == n`. Binary output is `int[]`,
// not `string`, because a NUL byte is unrepresentable in a Sailfin string
// (SFEP-0048 §3.3).
// Runtime ABI. `sfn_rand_fill(buf, n)` is defined in
// `runtime/sfn/platform/rand.sfn` and linked into every binary; it fills `buf`
// with `n` secure random bytes and returns 1 on success, 0 on failure. Externs
// carry no effect (E0804); the `![rand]` gate is on `random_bytes` below.
extern fn sfn_rand_fill(buf: *u8, n: i64) -> i32;

extern fn malloc(size: usize) -> *u8;

extern fn free(ptr: *u8) -> void;

// `_rand_ptr_off(p, off)` — byte-stride pointer arithmetic (copy of the
// ed25519.sfn helper).
fn _rand_ptr_off(p: *u8, off: i64) -> *u8 {
    let addr: i64 = (p as i64) + off;
    return addr as *u8;
}

// random_bytes(n) — return exactly `n` cryptographically secure random bytes,
// or `[]` if `n <= 0` or the OS entropy source fails (fail-closed). `![rand]`.
fn random_bytes(n: int) -> int[] ![rand] {
    if n <= 0 { return []; }
    // Over-allocate 4 bytes so the final `pointer_read_i32` byte load (which
    // reads a 4-byte word at `buf[n-1]`) stays in-bounds — the same
    // over-allocation invariant websocket.sfn's mask buffer holds for
    // `_ws_byte_at`. Only the first `n` bytes are filled with entropy.
    let buf: *u8 = malloc((n + 4) as usize);
    if buf as i64 == 0 { return []; }
    if sfn_rand_fill(buf, n as i64) != 1 {
        free(buf);
        return [];
    }
    let mut out: int[] = [];
    let mut i: int = 0;
    loop {
        if i >= n { break; }
        let b: int = (sailfin_intrinsic_pointer_read_i32(_rand_ptr_off(buf, i as i64)) as int) & 255;
        out.push(b);
        i = i + 1;
    }
    free(buf);
    return out;
}
