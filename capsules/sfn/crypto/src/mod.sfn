} from "./bits";

export { chacha20_block, chacha20_xor } from "./chacha20";

// CSPRNG — secure random bytes from the host OS entropy source. The capsule's
// one effectful primitive: `random_bytes` carries `![rand]` (SFEP-0048 Phase D).
export { random_bytes } from "./rand";

export { chacha20poly1305_seal, chacha20poly1305_open } from "./aead_chacha20poly1305";

// TLS 1.3 record layer (RFC 8446 §5) — TLSCiphertext framing, per-record nonce
// derivation, and AEAD seal/open with the record header as AAD (SFEP-0048
// Phase B).
