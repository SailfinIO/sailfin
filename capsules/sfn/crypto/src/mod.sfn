// sfn/crypto — Cryptographic hashing, encoding, and signature functions.
//
// Provides SHA-256 hashing (data integrity, checksums, content-addressable
// storage), base64 encode/decode, and verify-only Ed25519 signature
// verification (RFC 8032). No effects required — pure computation.
import { hmac_sha256_bytes } from "./hkdf";

export { ed25519_verify, ed25519_verify_utf8 } from "./ed25519";

export { sha1_hex } from "./sha1";

export { sha384_hex } from "./sha384";

export { hmac_sha256_bytes, hkdf_sha256_extract, hkdf_sha256_expand } from "./hkdf";

// TLS 1.3 key schedule (RFC 8446 §7.1) — HKDF-Expand-Label / Derive-Secret and
// the Early -> Handshake -> Master secret ladder (SFEP-0048 Phase B).
export {
    hkdf_expand_label,
    derive_secret,
    tls13_early_secret,
    tls13_handshake_secret,
    tls13_master_secret,
    tls13_client_handshake_traffic_secret,
    tls13_server_handshake_traffic_secret,
    tls13_client_application_traffic_secret,
    tls13_server_application_traffic_secret
} from "./tls13_schedule";

export { poly1305_mac } from "./poly1305";

// Constant-time / masking helpers shared by the Phase A hash and cipher
// primitives (SFEP-0048 §3.3-3.4).
export {
