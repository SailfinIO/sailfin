// sfn/tensor — Tensor primitives and operations for Sailfin.
//
// Provides multi-dimensional array types and element-wise operations
// for numerical computing and machine learning workloads.
//
// Usage:
//   import { Tensor, zeros, ones, from_array } from "tensor"
//
//   let a = from_array([1, 2, 3, 4], [2, 2]);
//   let b = ones([2, 2]);
//   let c = add(a, b);
//
// GPU-accelerated dispatch is planned but not yet implemented.
// All operations currently execute on the CPU.
// ---- Types ----
struct Tensor {
    data: float[];  // flat storage (row-major)
    shape: int[];  // dimensions, e.g. [2, 3] for a 2x3 matrix
    size: int;  // total element count (product of shape)
}

// ---- Constructors ----
fn zeros(shape: int[]) -> Tensor {
    // Create a tensor filled with zeros.
    let n = _shape_size(shape);
    let mut data: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= n { break; }
        data.push(0);
        i += 1;
    }
    return Tensor { data: data, shape: shape, size: n };
}

fn ones(shape: int[]) -> Tensor {
    // Create a tensor filled with ones.
    let n = _shape_size(shape);
    let mut data: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= n { break; }
        data.push(1);
        i += 1;
    }
    return Tensor { data: data, shape: shape, size: n };
}

fn fill(shape: int[], value: float) -> Tensor {
    // Create a tensor filled with a constant value.
    let n = _shape_size(shape);
    let mut data: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= n { break; }
        data.push(value);
        i += 1;
    }
    return Tensor { data: data, shape: shape, size: n };
}

fn from_array(data: float[], shape: int[]) -> Tensor {
    // Create a tensor from a flat data array and a shape.
    // Data length must match the product of shape dimensions.
    // If mismatched, uses the smaller of data.length and shape size.
    let n = _shape_size(shape);
    let actual = _min_size(data.length, n);
    return Tensor { data: data, shape: shape, size: actual };
}

fn scalar(value: float) -> Tensor {
    // Create a scalar (0-dimensional) tensor.
    return Tensor { data: [value], shape: [], size: 1 };
}

// ---- Element access ----
fn get(t: Tensor, indices: int[]) -> float {
    // Get a single element by multi-dimensional index.
    let flat = _flat_index(t.shape, indices);
    return t.data[flat];
}

fn set(t: Tensor, indices: int[], value: float) -> Tensor {
    // Return a new tensor with one element replaced.
    let flat = _flat_index(t.shape, indices);
    let mut new_data: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= t.size { break; }
        if i == flat { new_data.push(value); } else {
            new_data.push(t.data[i]);
        }
        i += 1;
    }
    return Tensor { data: new_data, shape: t.shape, size: t.size };
}

// ---- Element-wise operations ----
fn add(a: Tensor, b: Tensor) -> Tensor {
    // Element-wise addition. Shapes must match.
    let n = _min_size(a.size, b.size);
    let mut out: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= n { break; }
        out.push(a.data[i] + b.data[i]);
        i += 1;
    }
    return Tensor { data: out, shape: a.shape, size: n };
}

fn subtract(a: Tensor, b: Tensor) -> Tensor {
    // Element-wise subtraction. Shapes must match.
    let n = _min_size(a.size, b.size);
    let mut out: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= n { break; }
        out.push(a.data[i] - b.data[i]);
        i += 1;
    }
    return Tensor { data: out, shape: a.shape, size: n };
}

fn multiply(a: Tensor, b: Tensor) -> Tensor {
    // Element-wise multiplication (Hadamard product). Shapes must match.
    let n = _min_size(a.size, b.size);
    let mut out: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= n { break; }
        out.push(a.data[i] * b.data[i]);
        i += 1;
    }
    return Tensor { data: out, shape: a.shape, size: n };
}

fn scale(t: Tensor, s: float) -> Tensor {
    // Multiply every element by a scalar.
    let mut out: float[] = [];
    let mut i: int = 0;
    loop {
        if i >= t.size { break; }
        out.push(t.data[i] * s);
        i += 1;
    }
    return Tensor { data: out, shape: t.shape, size: t.size };
}

fn negate(t: Tensor) -> Tensor {
    // Negate every element.
    return scale(t, -1);
}

// ---- Reductions ----
fn sum(t: Tensor) -> float {
    // Sum all elements.
    let mut total: float = 0.0;
    let mut i: int = 0;
    loop {
        if i >= t.size { break; }
        total = total + t.data[i];
        i += 1;
    }
    return total;
}

fn mean(t: Tensor) -> float {
    // Arithmetic mean of all elements.
    if t.size == 0 { return 0; }
    return sum(t) / (t.size as float);
}

fn max_val(t: Tensor) -> float {
    // Maximum element value.
    if t.size == 0 { return 0; }
    let mut best: float = t.data[0];
    let mut i: int = 1;
    loop {
        if i >= t.size { break; }
        if t.data[i] > best { best = t.data[i]; }
        i += 1;
    }
    return best;
}

fn min_val(t: Tensor) -> float {
    // Minimum element value.
    if t.size == 0 { return 0; }
    let mut best: float = t.data[0];
    let mut i: int = 1;
    loop {
        if i >= t.size { break; }
        if t.data[i] < best { best = t.data[i]; }
        i += 1;
    }
    return best;
}

// ---- Shape utilities ----
fn reshape(t: Tensor, new_shape: int[]) -> Tensor {
    // Reshape a tensor (data stays the same, shape changes).
    return Tensor { data: t.data, shape: new_shape, size: t.size };
}

fn rank(t: Tensor) -> int {
    // Number of dimensions.
    return t.shape.length;
}

// ---- Linear algebra (2D) ----
// Tile edge for the cache-blocked `matmul`. Chosen so an a/b/out tile trio of
// f64s stays comfortably within a typical L1/L2 working set; a future SIMD or
// autotuning pass (SFEP-0052) can revisit it without changing the kernel's
// numerics.
let MATMUL_BLOCK: int = 64;

fn dot(a: Tensor, b: Tensor) -> float {
    // Dot product of two 1D tensors (vectors).
    let mut total: float = 0.0;
    let mut i: int = 0;
    loop {
        if i >= a.size { break; }
        total = total + a.data[i] * b.data[i];
        i += 1;
    }
    return total;
}

fn matmul(a: Tensor, b: Tensor) -> Tensor {
    // Cache-blocked (tiled) matrix multiplication for 2D tensors.
    // a: [M, K], b: [K, N] => result: [M, N]
    // Both tensors must be rank-2 with matching inner dimensions.
    //
    // Tiling into MATMUL_BLOCK-sized submatrices keeps the working set in cache
    // and reuses each loaded a[i][p] across a row of b, beating the naive triple
    // loop on larger matrices. The inner i-p-j order accumulates every output
    // element's K-sum in strictly increasing p (each tile contributes its p
    // range once, in order), so the float additions happen in the same sequence
    // as the naive row-major kernel — the result is bit-identical, which is what
    // lets this stay the CPU reference oracle (SFEP-0052).
    if a.shape.length != 2 || b.shape.length != 2 { return zeros([0]); }
    if a.shape[1] != b.shape[0] { return zeros([0]); }
    let m = a.shape[0];
    let k = a.shape[1];
    let n = b.shape[1];
    let count = m * n;
    let mut out: float[] = [];
    let mut z: int = 0;
    loop {
        if z >= count { break; }
        out.push(0.0);
        z += 1;
    }
    let bs = MATMUL_BLOCK;
    let mut ii: int = 0;
    loop {
        if ii >= m { break; }
        let i_max = _min_size(ii + bs, m);
        let mut kk: int = 0;
        loop {
            if kk >= k { break; }
            let p_max = _min_size(kk + bs, k);
            let mut jj: int = 0;
            loop {
                if jj >= n { break; }
                let j_max = _min_size(jj + bs, n);
                let mut i: int = ii;
                loop {
                    if i >= i_max { break; }
                    let row_out = i * n;
                    let row_a = i * k;
                    let mut p: int = kk;
                    loop {
                        if p >= p_max { break; }
                        let aip = a.data[row_a + p];
                        let row_b = p * n;
                        let mut j: int = jj;
                        loop {
                            if j >= j_max { break; }
                            out[row_out + j] = out[row_out + j] + aip * b.data[row_b
                                + j];
                            j += 1;
                        }
                        p += 1;
                    }
                    i += 1;
                }
                jj += bs;
            }
            kk += bs;
        }
        ii += bs;
    }
    return Tensor {
        data: out,
        shape: [m, n],
        size: count
    };
}

fn transpose(t: Tensor) -> Tensor {
    // Transpose a 2D tensor.
    let rows = t.shape[0];
    let cols = t.shape[1];
    let mut out: float[] = [];
    let mut j: int = 0;
    loop {
        if j >= cols { break; }
        let mut i: int = 0;
        loop {
            if i >= rows { break; }
            out.push(t.data[i * cols + j]);
            i += 1;
        }
        j += 1;
    }
    return Tensor {
        data: out,
        shape: [cols, rows],
        size: t.size
    };
}

// ---- Internal helpers ----
fn _shape_size(shape: int[]) -> int {
    if shape.length == 0 { return 1; }
    let mut n: int = 1;
    let mut i: int = 0;
    loop {
        if i >= shape.length { break; }
        n = n * shape[i];
        i += 1;
    }
    return n;
}

fn _flat_index(shape: int[], indices: int[]) -> int {
    let mut flat: int = 0;
    let mut stride: int = 1;
    let mut i: int = shape.length;
    loop {
        if i <= 0 { break; }
        i -= 1;
        flat = flat + indices[i] * stride;
        stride = stride * shape[i];
    }
    return flat;
}

fn _min_size(a: int, b: int) -> int {
    if a <= b { return a; }
    return b;
}
