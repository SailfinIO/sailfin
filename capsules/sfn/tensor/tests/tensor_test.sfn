import {
    Tensor,
    add,
    dot,
    fill,
    from_array,
    get,
    matmul,
    mean,
    multiply,
    negate,
    ones,
    rank,
    reshape,
    scalar,
    scale,
    set,
    subtract,
    sum,
    transpose,
    zeros
} from "../src/mod";

// -- Tests --
test "tensor: zeros and ones constructors" {
    let z = zeros([2, 3]);
    assert z.size == 6;
    assert z.data[0] == 0;
    assert z.data[5] == 0;

    let o = ones([3]);
    assert o.size == 3;
    assert o.data[0] == 1;
    assert o.data[2] == 1;
}

test "tensor: fill and from_array" {
    let f = fill([2, 2], 5);
    assert f.size == 4;
    assert f.data[0] == 5;
    assert f.data[3] == 5;

    let a = from_array([1, 2, 3, 4], [2, 2]);
    assert a.size == 4;
    assert a.data[0] == 1;
    assert a.data[3] == 4;
}

test "tensor: scalar creates 0-dimensional tensor" {
    let s = scalar(42);
    assert s.size == 1;
    assert s.data[0] == 42;
    assert s.shape.length == 0;
}

test "tensor: get and set element access" {
    let t = from_array([1, 2, 3, 4, 5, 6], [2, 3]);
    assert get(t, [0, 0]) == 1;
    assert get(t, [0, 2]) == 3;
    assert get(t, [1, 0]) == 4;
    assert get(t, [1, 2]) == 6;

    let t2 = set(t, [1, 1], 99);
    assert get(t2, [1, 1]) == 99;
    assert get(t2, [0, 0]) == 1;
}

test "tensor: add and subtract element-wise" {
    let a = from_array([1, 2, 3], [3]);
    let b = from_array([4, 5, 6], [3]);
    let c = add(a, b);
    assert c.data[0] == 5;
    assert c.data[1] == 7;
    assert c.data[2] == 9;

    let d = subtract(b, a);
    assert d.data[0] == 3;
    assert d.data[1] == 3;
    assert d.data[2] == 3;
}

test "tensor: multiply, scale, negate" {
    let a = from_array([2, 3, 4], [3]);
    let b = from_array([5, 6, 7], [3]);
    let m = multiply(a, b);
    assert m.data[0] == 10;
    assert m.data[1] == 18;
    assert m.data[2] == 28;

    let s = scale(a, 3);
    assert s.data[0] == 6;
    assert s.data[1] == 9;
    assert s.data[2] == 12;

    let n = negate(a);
    assert n.data[0] == -2;
    assert n.data[1] == -3;
    assert n.data[2] == -4;
}

test "tensor: sum and mean reductions" {
    let t = from_array([1, 2, 3, 4], [4]);
    assert sum(t) == 10;
    assert mean(t) == 2.5;
}

test "tensor: reshape and rank" {
    let t = from_array([1, 2, 3, 4, 5, 6], [6]);
    assert rank(t) == 1;
    let r = reshape(t, [2, 3]);
    assert rank(r) == 2;
    assert r.shape[0] == 2;
    assert r.shape[1] == 3;
    assert r.data[0] == 1;
}

test "tensor: dot product of vectors" {
    let a = from_array([1, 2, 3], [3]);
    let b = from_array([4, 5, 6], [3]);
    assert dot(a, b) == 32;
}

test "tensor: matmul 2x2 matrices" {
    // [[1,2],[3,4]] * [[5,6],[7,8]] = [[19,22],[43,50]]
    let a = from_array([1, 2, 3, 4], [2, 2]);
    let b = from_array([5, 6, 7, 8], [2, 2]);
    let c = matmul(a, b);
    assert c.data[0] == 19;
    assert c.data[1] == 22;
    assert c.data[2] == 43;
    assert c.data[3] == 50;
    assert c.shape[0] == 2;
    assert c.shape[1] == 2;
}

test "tensor: transpose 2x3 matrix" {
    // [[1,2,3],[4,5,6]] => [[1,4],[2,5],[3,6]]
    let t = from_array([1, 2, 3, 4, 5, 6], [2, 3]);
    let tr = transpose(t);
    assert tr.shape[0] == 3;
    assert tr.shape[1] == 2;
    assert tr.data[0] == 1;
    assert tr.data[1] == 4;
    assert tr.data[2] == 2;
    assert tr.data[3] == 5;
    assert tr.data[4] == 3;
    assert tr.data[5] == 6;
}
