// Tests for sfn/math — pure-arithmetic helpers.
//
// Moved from compiler/tests/unit/math_test.sfn. The colocated test would
// like to import the real capsule API, but doing so currently surfaces a
// compiler bug where forward-declarations of `round` (used by the array-
// indexing lowering) are emitted twice for the same module, producing an
// LLVM `invalid redefinition of function 'round'` error. Until that's fixed,
// this test continues to use inline `_`-prefixed copies of the capsule
// helpers — same coverage as before the move, just colocated with the
// capsule it documents.
//
// FOLLOW-UP — switch to `import { ... } from "../src/mod"` once:
//   1. The duplicate-`declare round` emission bug is fixed (affects every
//      capsule whose imported function uses array indexing internally).
//   2. The runtime `_truncate` / `floor` / `round` chain returns correct
//      values (currently mis-parses `number_to_string` for some inputs).

fn _abs(x: number) -> number {
    if x < 0 { return 0 - x; }
    return x;
}

fn _min(a: number, b: number) -> number {
    if a <= b { return a; }
    return b;
}

fn _max(a: number, b: number) -> number {
    if a >= b { return a; }
    return b;
}

fn _clamp(x: number, lo: number, hi: number) -> number {
    if x < lo { return lo; }
    if x > hi { return hi; }
    return x;
}

fn _sign(x: number) -> number {
    if x < 0 { return -1; }
    if x > 0 { return 1; }
    return 0;
}

fn _sum(values: number[]) -> number {
    let mut total: number = 0;
    let mut i: number = 0;
    loop {
        if i >= values.length { break; }
        total = total + values[i];
        i += 1;
    }
    return total;
}

fn _mean(values: number[]) -> number {
    if values.length == 0 { return 0; }
    return _sum(values) / values.length;
}

test "math: abs" {
    assert _abs(5) == 5;
    assert _abs(-5) == 5;
    assert _abs(0) == 0;
    assert _abs(-0.5) == 0.5;
}

test "math: min and max" {
    assert _min(3, 7) == 3;
    assert _min(-1, 1) == -1;
    assert _min(5, 5) == 5;
    assert _max(3, 7) == 7;
    assert _max(-1, 1) == 1;
    assert _max(5, 5) == 5;
}

test "math: clamp" {
    assert _clamp(5, 0, 10) == 5;
    assert _clamp(-5, 0, 10) == 0;
    assert _clamp(15, 0, 10) == 10;
    assert _clamp(0, 0, 10) == 0;
    assert _clamp(10, 0, 10) == 10;
}

test "math: sign" {
    assert _sign(42) == 1;
    assert _sign(-42) == -1;
    assert _sign(0) == 0;
    assert _sign(0.001) == 1;
    assert _sign(-0.001) == -1;
}

test "math: sum" {
    assert _sum([1, 2, 3, 4, 5]) == 15;
    assert _sum([]) == 0;
    assert _sum([10]) == 10;
    assert _sum([-1, 1]) == 0;
}

test "math: mean" {
    assert _mean([2, 4, 6]) == 4;
    assert _mean([10]) == 10;
    assert _mean([]) == 0;
}

// Note: floor, ceil, round, pow, mod, is_integer require either:
//   (a) the bug fixes in the capsule (import path), or
//   (b) inlined `_truncate` re-implementation here.
// Skipped to keep the test file scoped to coverage that holds today.
