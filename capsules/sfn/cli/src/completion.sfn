// sfn/cli — shell-completion script generation.
//
// `render_completion(node, shell)` walks the same render-agnostic
// `HelpNode` tree the `--help` text and `--help --json` renderers consume
// (help.sfn), so a newly registered command or flag flows into completion
// output automatically — there is no hand-maintained command list to drift
// (SFEP-0027 Phase D, carried from SFEP-0009 §5). The shell dispatch is
// table-driven via `completion_shells`: adding a target shell is a new
// generator function, not a structural change.
import { HelpNode } from "./types";

fn completion_shells() -> string[] {
    // The shells `render_completion` can emit a script for. Callers validate
    // the requested `<shell>` against this list; adding a generator below
    // grows it.
    return ["bash"];
}

fn render_completion(node: HelpNode, shell: string) -> string {
    // Render a completion script for `shell` from the command tree. Returns
    // "" for a shell absent from `completion_shells()`; the caller reports
    // the unsupported shell.
    if strings_equal(shell, "bash") { return _completion_bash(node); }
    return "";
}

fn _completion_join(names: string[]) -> string {
    if names.length == 0 { return ""; }
    let mut out = names[0];
    let mut i: int = 1;
    loop {
        if i >= names.length { break; }
        out = out + " " + names[i];
        i += 1;
    }
    return out;
}

fn _completion_top_words(node: HelpNode) -> string {
    // Top-level candidates: every registered subcommand name plus the
    // built-in help/version flags.
    let mut words: string[] = [];
    let mut i: int = 0;
    loop {
        if i >= node.subcommands.length { break; }
        words.push(node.subcommands[i].name);
        i += 1;
    }
    words.push("-h");
    words.push("--help");
    if node.version.length > 0 {
        words.push("-V");
        words.push("--version");
    }
    return _completion_join(words);
}

fn _completion_command_words(cmd: HelpNode) -> string {
    // Per-command candidates: nested subcommand names, each flag's long and
    // short forms, and the built-in `-h` / `--help`. The parser accepts a
    // flag's short form and `-h` at every level, so completion offers both.
    let mut words: string[] = [];
    let mut si: int = 0;
    loop {
        if si >= cmd.subcommands.length { break; }
        words.push(cmd.subcommands[si].name);
        si += 1;
    }
    let mut fi: int = 0;
    loop {
        if fi >= cmd.flags.length { break; }
        // Guard the `--<long>` join against an empty long name, matching the
        // parser's own invariant (parser.sfn) — every builder requires a long
        // name today, so this only forecloses a bare `--` candidate if a
        // short-only flag is ever added.
        if cmd.flags[fi].long_name.length > 0 {
            words.push("--" + cmd.flags[fi].long_name);
        }
        if cmd.flags[fi].short_name.length > 0 {
            words.push("-" + cmd.flags[fi].short_name);
        }
        fi += 1;
    }
    words.push("-h");
    words.push("--help");
    return _completion_join(words);
}

fn _completion_bash(node: HelpNode) -> string {
    // A bash `complete -F` function: word 1 completes the subcommand set,
    // later words complete the matched subcommand's flags/subcommands. The
    // `${COMP_WORDS[...]}` tokens are literal bash — Sailfin interpolation is
    // `{{ }}`, and `${ }` is parser-reserved-but-inactive, so the dollar-brace
    // forms pass through unexpanded.
    let program = node.name;
    let mut out: string = "";
    out = out + "# bash completion for " + program + " (generated by '"
        + program
        + " completion bash').\n";
    out = out + "_" + program + "_complete() {\n";
    out = out + "    local cur\n";
    out = out + "    cur=\"${COMP_WORDS[COMP_CWORD]}\"\n";
    out = out + "    if [ \"${COMP_CWORD}\" -eq 1 ]; then\n";
    out = out + "        COMPREPLY=( $(compgen -W \"" + _completion_top_words(node)
        + "\" -- \"${cur}\") )\n";
    out = out + "        return 0\n";
    out = out + "    fi\n";
    out = out + "    case \"${COMP_WORDS[1]}\" in\n";
    let mut i: int = 0;
    loop {
        if i >= node.subcommands.length { break; }
        let sub = node.subcommands[i];
        out = out + "    " + sub.name + ")\n";
        out = out + "        COMPREPLY=( $(compgen -W \""
            + _completion_command_words(sub)
            + "\" -- \"${cur}\") )\n";
        out = out + "        ;;\n";
        i += 1;
    }
    out = out + "    esac\n";
    out = out + "    return 0\n";
    out = out + "}\n";
    out = out + "complete -F _" + program + "_complete " + program + "\n";
    return out;
}
