// Tests for the sfn/test snapshot matcher (#977).
//
// Every behavior is exercised through `snapshot_match_in`, whose
// directory and update flag are explicit parameters — so the tests do
// not depend on cwd or the `--update-snapshots` environment flag. Each
// test works in its own subdirectory of `SAILFIN_TEST_SCRATCH` and
// deletes its golden file up front via `_reset`, so a run is
// deterministic even when the runner's scratch is a persistent
// directory (single-file `sfn test <file>` resolves it to `build/sailfin`,
// which survives between runs). `expect_snapshot` is the thin
// env+default-dir wrapper over this same core (see `snapshot.sfn`).
//
// Tests are `![io]`: `snapshot_match_in` writes/reads golden files,
// `env.get` reads the scratch path, and `_reset` deletes a stale golden
// — all of which require `![io]`.
import { find } from "sfn/strings";

import { snapshot_match_in } from "../src/mod";

// Return a per-test snapshot directory and remove any `key.snap` left by
// a previous run, so each test starts from "golden absent" regardless of
// scratch persistence. Prefers the runner's `SAILFIN_TEST_SCRATCH`; falls
// back to `/tmp` for a direct invocation that didn't export it.
fn _reset(name: string, key: string) -> string ![io] {
    let scratch = env.get("SAILFIN_TEST_SCRATCH");
    let mut dir = "/tmp/sfn-snap-" + name;
    if scratch.length > 0 { dir = scratch + "/snap-" + name; }
    fs.createDirectory(dir, true);
    let path = dir + "/" + key + ".snap";
    if fs.exists(path) { fs.deleteFile(path); }
    return dir;
}

// First run (golden absent) writes and passes; a second compare against
// the just-written golden then matches.
test "snapshot: first run writes and passes" ![io] {
    let dir = _reset("first", "greeting");
    let written = snapshot_match_in("hello\nworld", dir, "greeting", false);
    assert written.ok;
    let compared = snapshot_match_in("hello\nworld", dir, "greeting", false);
    assert compared.ok;
}

// Identical content compares equal.
test "snapshot: match on identical content" ![io] {
    let dir = _reset("match", "doc");
    let first = snapshot_match_in("line-a\nline-b", dir, "doc", false);
    assert first.ok;
    let again = snapshot_match_in("line-a\nline-b", dir, "doc", false);
    assert again.ok;
}

// A changed line fails and the diagnostic names the first divergent
// line index (via the inlined `_snapshot_line_diff`, which mirrors the
// message shape of #973's `matcher_eq_str_array`).
test "snapshot: mismatch fails with line diff" ![io] {
    let dir = _reset("mismatch", "doc");
    let written = snapshot_match_in("alpha\nbeta\ngamma", dir, "doc", false);
    assert written.ok;
    let changed = snapshot_match_in("alpha\nBETA\ngamma", dir, "doc", false);
    assert ! changed.ok;
    assert changed.message.length > 0;
    assert find(changed.message, "index 1", 0) >= 0;
}

// A length-divergent body fails with a length-mismatch diagnostic.
test "snapshot: length-divergent content fails" ![io] {
    let dir = _reset("lendiff", "doc");
    let written = snapshot_match_in("one\ntwo", dir, "doc", false);
    assert written.ok;
    let longer = snapshot_match_in("one\ntwo\nthree", dir, "doc", false);
    assert ! longer.ok;
    assert find(longer.message, "length", 0) >= 0;
}

// `update == true` overwrites a stale golden; without it the same change
// fails. After the update, a plain compare against the new golden passes.
test "snapshot: update overwrites stale snapshot" ![io] {
    let dir = _reset("update", "doc");
    let written = snapshot_match_in("v1", dir, "doc", false);
    assert written.ok;
    let stale = snapshot_match_in("v2", dir, "doc", false);
    assert ! stale.ok;
    let updated = snapshot_match_in("v2", dir, "doc", true);
    assert updated.ok;
    let after = snapshot_match_in("v2", dir, "doc", false);
    assert after.ok;
}

// An empty key is rejected, and a key with a path separator is rejected,
// before any filesystem write happens.
test "snapshot: invalid keys are rejected" ![io] {
    let dir = _reset("invalid", "doc");
    let empty = snapshot_match_in("x", dir, "", false);
    assert ! empty.ok;
    let nested = snapshot_match_in("x", dir, "a/b", false);
    assert ! nested.ok;
    assert find(nested.message, "path separator", 0) >= 0;
}
