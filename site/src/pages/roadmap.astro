---
import BaseLayout from "../layouts/BaseLayout.astro";

type Status = "done" | "in-progress" | "planned";

interface RoadmapItem {
  label: string;
  status: Status;
  url?: string;
}

interface RoadmapCategory {
  title: string;
  description?: string;
  items: RoadmapItem[];
  url?: string;
  open?: number;
  closed?: number;
  epicsLoadFailed?: boolean;
  state?: "open" | "closed";
}

// Linear API types
interface LinearProject {
  id: string;
  name: string;
  url: string;
  state: string | null;
}

interface LinearInitiative {
  id: string;
  name: string;
  description: string | null;
  url: string;
  projects: { nodes: LinearProject[] };
}

interface LinearInitiativesResponse {
  data?: {
    initiatives?: { nodes: LinearInitiative[] };
  };
  errors?: unknown[];
}

const REPO = "SailfinIO/sailfin";

function mapStatus(type: string | undefined): Status {
  if (type === "completed") return "done";
  if (type === "started") return "in-progress";
  return "planned";
}

// Records why the Linear fetch fell back, logged to the build output so a
// failed roadmap load is diagnosable from the Cloudflare build log.
let loadDiagnostic: string | null = null;

async function fetchInitiatives(): Promise<LinearInitiative[] | null> {
  // Cloudflare Pages injects build secrets into process.env; Astro/Vite only
  // exposes PUBLIC_-prefixed vars on import.meta.env, so read process.env for
  // this non-public key.
  const apiKey = import.meta.env.LINEAR_API_KEY || process.env.LINEAR_API_KEY;
  if (!apiKey) {
    loadDiagnostic = "LINEAR_API_KEY not found in the build environment";
    return null;
  }
  try {
    const res = await fetch("https://api.linear.app/graphql", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: apiKey,
      },
      body: JSON.stringify({
        query: `query { initiatives(first: 50) { nodes { id name description url projects(first: 100) { nodes { id name url state } } } } }`,
      }),
    });
    if (!res.ok) {
      let body = "";
      try {
        body = (await res.text()).slice(0, 300);
      } catch {}
      loadDiagnostic = `Linear API returned HTTP ${res.status} ${res.statusText}${body ? ` — ${body}` : ""}`;
      return null;
    }
    const json = (await res.json()) as LinearInitiativesResponse;
    if (json.errors && json.errors.length > 0) {
      const msgs = json.errors
        .map((e) => (e as { message?: string })?.message ?? String(e))
        .join("; ");
      loadDiagnostic = `Linear GraphQL error: ${msgs}`;
      return null;
    }
    if (!json.data?.initiatives) {
      loadDiagnostic = "Linear response contained no initiatives field";
      return null;
    }
    return json.data.initiatives.nodes;
  } catch (err) {
    loadDiagnostic = `Linear fetch threw: ${err instanceof Error ? err.message : String(err)}`;
    return null;
  }
}

const initiatives = await fetchInitiatives();
const apiAvailable = initiatives !== null;
if (!apiAvailable && loadDiagnostic) {
  console.warn("[roadmap] Linear fetch failed:", loadDiagnostic);
}

// Hide initiatives with no projects at all — these contribute no signal.
const populatedInitiatives = (initiatives ?? []).filter(
  (i) => i.projects.nodes.length > 0,
);

const v1Categories: RoadmapCategory[] = apiAvailable
  ? populatedInitiatives.map((initiative) => {
      const projects = initiative.projects.nodes;
      const items: RoadmapItem[] = projects.map((p) => ({
        label: p.name,
        status: mapStatus(p.state ?? undefined),
        url: p.url,
      }));
      const closed = projects.filter((p) => p.state === "completed").length;
      const open = projects.length - closed;
      return {
        title: initiative.name,
        description: initiative.description ?? undefined,
        items,
        url: initiative.url,
        open,
        closed,
        state: open > 0 ? "open" : "closed",
      };
    })
  : [];

// Aggregate progress across all v1 initiatives.
const v1ItemsOpen = v1Categories.reduce((s, c) => s + (c.open ?? 0), 0);
const v1ItemsClosed = v1Categories.reduce((s, c) => s + (c.closed ?? 0), 0);
const v1ItemsTotal = v1ItemsOpen + v1ItemsClosed;

const postV1Ai: RoadmapCategory = {
  title: "Enterprise Hardening & AI Integration",
  description: "Library-level AI support, taint tracking, and advanced safety features — delivered as capsules, not language syntax.",
  items: [
    { label: "sfn/ai capsule — model invocation, prompt templating, generation provenance (replaces the removed model/prompt/tool/pipeline keywords)", status: "planned" },
    { label: "Secret<T> / PII<T> taint tracking integrated with the effect system", status: "planned" },
    { label: "sfn lsp — language server for IDE integration", status: "planned" },
    { label: "sfn audit enhancements — transitive capability analysis, SBOM generation", status: "planned" },
    { label: "User-facing ownership & full borrow checking (&T, &mut T, shared borrows, lifetimes) — Phase U, widening the 1.0 runtime memory-safety floor (epic #1209) to user code.", status: "planned" },
  ],
};

const postV1Platform: RoadmapCategory = {
  title: "Platform & Ecosystem",
  description: "Runtime, tooling, and ecosystem infrastructure for post-1.0 growth.",
  items: [
    { label: "Async runtime — Sailfin-native event loop and async I/O (the v0 task scheduler, channels, spawn/await, and parallel shipped pre-1.0; post-1.0 scope is the non-blocking event loop and TLS/keep-alive network integration)", status: "planned" },
    { label: "Runtime diagnostics — structured tracing and allocation telemetry", status: "planned" },
    { label: "WebAssembly emission target", status: "planned" },
    { label: "Native test framework — golden, adversarial, and replay test types", status: "planned" },
    { label: "|> pipeline operator with async and lazy semantics", status: "planned" },
    { label: "GPU effect enforcement and tensor dispatch", status: "planned" },
  ],
};

const exploration: RoadmapItem[] = [
  { label: "Perf-parity native backend — the post-1.0 long tail beyond the seal-sufficient backend (#1640): full optimization and codegen maturity after the 1.0 capability seal lands", status: "planned" },
  { label: "Structured concurrency (v0 shipped) — routine, channel, spawn/await, parallel, scheduler work today; atomics beyond channel-send and richer sync primitives are post-1.0", status: "in-progress" },
  { label: "Effect system hardening — validate_effects() is a build gate (shipped); Raw-degradation holes closed for cast (#1627), ternary (#1690), and is type-guard (#1753); remaining: prefix */& and assignment-as-expression (#1180-c); hierarchical sub-effects (detection + manifest tightening) shipped (SFEP-0017); effect polymorphism post-1.0", status: "in-progress" },
  { label: "Phase 2 containers — closures with capture, generic constraints, drop emission", status: "planned" },
  { label: "Documentation expansion — production-quality site coverage, remove legacy stage references", status: "planned" },
  { label: "LLM adoption levers — llms.txt, sfn check --json, MCP server, Rosetta Code corpus", status: "planned" },
  { label: "Release pipeline hardening — signed checksums, installer CI, self-hosted-only artifacts", status: "planned" },
  { label: "unsafe capability enforcement", status: "planned" },
  { label: "Currency literals ($0.05) and time literals (1s, 150ms)", status: "planned" },
  { label: "Notebook and interactive tooling", status: "planned" },
  { label: "Effect handlers (algebraic effect semantics)", status: "planned" },
];

function percent(done: number, total: number) {
  return total === 0 ? 0 : Math.round((done / total) * 100);
}

const v1Percent = percent(v1ItemsClosed, v1ItemsTotal);

const statusLabel = (s: Status) =>
  s === "done" ? "Done" : s === "in-progress" ? "In progress" : "Planned";

const lastUpdated = new Date().toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title="Roadmap" description="Sailfin's development roadmap toward 1.0 and beyond.">
  <div class="page">
    <div class="container">

      <!-- Header -->
      <header class="roadmap-header">
        <h1>Roadmap</h1>
        <p class="lead">
          Sailfin's path from alpha to a stable 1.0 release and beyond.
        </p>
        <p class="meta">
          Built {lastUpdated} from the <a href="https://linear.app">Linear roadmap</a> at deploy time.
        </p>
      </header>

      <!-- Legend -->
      <div class="legend">
        <span class="legend-item"><span class="status-dot done" aria-hidden="true"></span> Done</span>
        <span class="legend-item"><span class="status-dot in-progress" aria-hidden="true"></span> In progress</span>
        <span class="legend-item"><span class="status-dot planned" aria-hidden="true"></span> Planned</span>
      </div>

      {!apiAvailable && (
        <div class="api-warning">
          Could not load roadmap data from Linear at build time.
        </div>
      )}

      <!-- 1.0 Overview -->
      {apiAvailable && (
        <section class="v1-overview">
          <div class="v1-overview-header">
            <h2>Release 1.0</h2>
            <span class="v1-stat">{v1ItemsClosed} of {v1ItemsTotal} items closed across {v1Categories.length} milestones</span>
          </div>
          <div
            class="progress-bar-track"
            role="progressbar"
            aria-valuenow={v1ItemsClosed}
            aria-valuemin={0}
            aria-valuemax={v1ItemsTotal}
            aria-label={`Release 1.0 progress: ${v1ItemsClosed} of ${v1ItemsTotal} items closed`}
          >
            <div class="progress-bar-fill" style={`width: ${v1Percent}%`}></div>
          </div>
        </section>
      )}

      <!-- 1.0 Categories -->
      <div class="categories">
        {v1Categories.map((cat) => {
          const total = (cat.open ?? 0) + (cat.closed ?? 0);
          const closed = cat.closed ?? 0;
          const pct = percent(closed, total);
          return (
            <section class="category-card">
              <div class="category-header">
                <div>
                  <h3>
                    {cat.url ? <a href={cat.url} class="category-link">{cat.title}</a> : cat.title}
                  </h3>
                  {cat.description && <p class="category-desc">{cat.description}</p>}
                </div>
                <span class="category-count">{closed}/{total}</span>
              </div>
              <div
                class="progress-bar-track small"
                role="progressbar"
                aria-valuenow={closed}
                aria-valuemin={0}
                aria-valuemax={total}
                aria-label={`${cat.title} progress: ${closed} of ${total} items closed`}
              >
                <div
                  class:list={["progress-bar-fill", { empty: pct === 0 }]}
                  style={`width: ${Math.max(pct, 0)}%`}
                ></div>
              </div>
              {cat.epicsLoadFailed ? (
                <p class="empty-note epics-error">
                  Could not load projects for this initiative. {cat.url && <a href={cat.url}>View initiative</a>}
                </p>
              ) : cat.items.length > 0 ? (
                <ul class="item-list">
                  {cat.items.map((item) => (
                    <li class:list={["item", item.status]}>
                      <span class={`status-dot ${item.status}`} aria-label={statusLabel(item.status)}></span>
                      {item.url
                        ? <a class="item-label item-link" href={item.url}>{item.label}</a>
                        : <span class="item-label">{item.label}</span>}
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="empty-note">
                  No projects yet in this initiative. {cat.url && <a href={cat.url}>View initiative</a>}
                </p>
              )}
            </section>
          );
        })}
      </div>

      <!-- Post-1.0 -->
      <div class="post-v1">
        <h2>Post-1.0</h2>
        <p class="section-desc">These workstreams begin after a stable self-hosted toolchain ships.</p>

        <div class="post-v1-grid">
          {[postV1Ai, postV1Platform].map((cat) => (
            <section class="category-card future">
              <div class="category-header">
                <div>
                  <h3>{cat.title}</h3>
                  {cat.description && <p class="category-desc">{cat.description}</p>}
                </div>
                <span class="category-count">{cat.items.length} items</span>
              </div>
              <ul class="item-list">
                {cat.items.map((item) => (
                  <li class:list={["item", item.status]}>
                    <span class={`status-dot ${item.status}`} aria-label={statusLabel(item.status)}></span>
                    <span class="item-label">{item.label}</span>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </div>

      <!-- Exploration Backlog -->
      <section class="exploration">
        <h2>Backlog & Exploration</h2>
        <p class="section-desc">
          Workstreams without an architected Linear initiative yet. Some will graduate into initiatives once design work lands; others stay exploratory.
        </p>
        <ul class="item-list exploration-list">
          {exploration.map((item) => (
            <li class:list={["item", item.status]}>
              <span class={`status-dot ${item.status}`} aria-label={statusLabel(item.status)}></span>
              <span class="item-label">{item.label}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Contribute -->
      <section class="contribute">
        <h2>Contributing</h2>
        <p>
          Open an issue or start a discussion in a pull request. Tag it with the appropriate milestone
          label so it can be triaged against the 1.0 scope. Major design changes that affect the language
          or ABI should reference a written proposal in <code>docs/proposals/</code> before implementation begins.
        </p>
        <div class="contribute-actions">
          <a href={`https://github.com/${REPO}/issues`} class="btn btn-primary">Open an Issue</a>
          <a href="/docs/contributing/guide" class="btn btn-secondary">Contributor Guide</a>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 3rem 0 5rem;
  }

  /* Header */
  .roadmap-header {
    margin-bottom: 2rem;
  }

  .roadmap-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .lead {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 40rem;
    margin-bottom: 0.5rem;
  }

  .meta {
    font-size: 0.85rem;
    color: var(--color-text-tertiary);
  }

  .meta code {
    font-size: 0.8rem;
  }

  /* Legend */
  .legend {
    display: flex;
    gap: 1.5rem;
    padding: 0.75rem 0;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  /* API warning */
  .api-warning {
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-primary);
    border-radius: 4px;
    background: var(--color-bg-alt);
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  /* Status dots */
  .status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-dot.done {
    background: #16a34a;
  }

  .status-dot.in-progress {
    background: var(--color-primary);
  }

  .status-dot.planned {
    background: var(--color-text-tertiary);
  }

  /* 1.0 Overview */
  .v1-overview {
    margin-bottom: 2rem;
  }

  .v1-overview-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .v1-overview-header h2 {
    font-size: 1.5rem;
    margin: 0;
  }

  .v1-stat {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  /* Progress bars */
  .progress-bar-track {
    width: 100%;
    height: 8px;
    background: var(--color-muted-surface);
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-bar-track.small {
    height: 4px;
    margin-bottom: 1rem;
  }

  .progress-bar-fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 4px;
    transition: width 0.4s ease;
    min-width: 0;
  }

  .progress-bar-fill.empty {
    width: 0 !important;
  }

  /* Category cards */
  .categories {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 3.5rem;
  }

  .category-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    background: var(--color-bg);
  }

  .category-card.future {
    background: var(--color-bg-alt);
  }

  .category-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .category-header h3 {
    font-size: 1.05rem;
    margin: 0;
    color: var(--color-text);
  }

  .category-link {
    color: inherit;
    text-decoration: none;
  }

  .category-link:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .category-desc {
    font-size: 0.825rem;
    color: var(--color-text-tertiary);
    line-height: 1.5;
    margin-top: 0.25rem;
  }

  .category-count {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    background: var(--color-bg-alt);
    padding: 0.2rem 0.6rem;
    border-radius: 10px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .empty-note {
    font-size: 0.85rem;
    color: var(--color-text-tertiary);
    margin: 0;
    padding: 0.4rem 0;
  }

  .empty-note.epics-error {
    color: var(--color-text-secondary);
    border-left: 2px solid var(--color-primary);
    padding-left: 0.6rem;
  }

  /* Item lists */
  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.4rem 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-text);
  }

  .item .status-dot {
    margin-top: 0.35rem;
  }

  .item.done .item-label {
    color: var(--color-text-secondary);
  }

  .item.planned .item-label {
    color: var(--color-text-secondary);
  }

  .item-link {
    color: inherit;
    text-decoration: none;
  }

  .item-link:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  /* Post-1.0 */
  .post-v1 {
    margin-bottom: 3.5rem;
  }

  .post-v1 > h2 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .section-desc {
    font-size: 0.925rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  .post-v1-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  /* Exploration */
  .exploration {
    margin-bottom: 3.5rem;
  }

  .exploration > h2 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .exploration-list {
    max-width: 36rem;
  }

  /* Contribute */
  .contribute {
    border-top: 1px solid var(--color-border);
    padding-top: 2.5rem;
  }

  .contribute h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .contribute p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 40rem;
    margin-bottom: 1.5rem;
  }

  .contribute-actions {
    display: flex;
    gap: 0.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.15s;
  }

  .btn:hover {
    text-decoration: none;
  }

  .btn-primary {
    background: var(--color-primary);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
  }

  .btn-secondary {
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-bg-alt);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .categories {
      grid-template-columns: 1fr;
    }

    .post-v1-grid {
      grid-template-columns: 1fr;
    }

    .roadmap-header h1 {
      font-size: 2rem;
    }

    .v1-overview-header {
      flex-direction: column;
    }

    .contribute-actions {
      flex-direction: column;
    }

    .btn {
      text-align: center;
      justify-content: center;
    }
  }
</style>
