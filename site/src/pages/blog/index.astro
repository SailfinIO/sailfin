---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Blog" description="News and updates from the Sailfin project.">
  <div class="blog-index">
    <div class="container">
      <h1>Blog</h1>
      <p class="lead">News, design decisions, and release notes from the Sailfin project.</p>

      <div class="posts">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card">
            <h2>{post.data.title}</h2>
            <div class="post-meta">
              <time datetime={post.data.date}>
                {new Date(post.data.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
              {post.data.author && <span>by {post.data.author}</span>}
            </div>
            {post.data.description && <p>{post.data.description}</p>}
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .blog-index {
    padding: 3rem 0 5rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .lead {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .posts {
    max-width: 48rem;
  }

  .post-card {
    display: block;
    padding: 1.5rem 2rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .post-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(0, 114, 206, 0.08);
    text-decoration: none;
  }

  .post-card h2 {
    font-size: 1.35rem;
    margin-bottom: 0.4rem;
  }

  .post-meta {
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .post-card p {
    color: var(--color-text-secondary);
    font-size: 0.925rem;
    line-height: 1.5;
  }
</style>
