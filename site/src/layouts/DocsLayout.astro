---
import BaseLayout from "./BaseLayout.astro";
import DocsSidebar from "../components/DocsSidebar.astro";

interface Props {
  title: string;
  description?: string;
  section?: string;
}

const { title, description, section } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="docs-wrapper">
    <DocsSidebar activeSection={section} />
    <article class="docs-content">
      <h1>{title}</h1>
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .docs-wrapper {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    min-height: calc(100vh - var(--header-height) - 200px);
  }

  .docs-content {
    flex: 1;
    min-width: 0;
    padding: 2.5rem 3rem;
    max-width: 52rem;
  }

  .docs-content h1 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .docs-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .docs-content :global(h3) {
    font-size: 1.2rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .docs-content :global(p) {
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .docs-content :global(ul),
  .docs-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .docs-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .docs-content :global(th),
  .docs-content :global(td) {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .docs-content :global(th) {
    background: var(--color-bg-alt);
    font-weight: 600;
  }

  .docs-content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--sfn-blue-light);
    border-radius: 0 6px 6px 0;
  }

  @media (max-width: 768px) {
    .docs-wrapper {
      flex-direction: column;
    }

    .docs-content {
      padding: 1.5rem;
    }
  }
</style>
