---
interface Props {
  activeSection?: string;
}

const { activeSection } = Astro.props;
const currentPath = Astro.url.pathname;

const sections = [
  {
    title: "Getting Started",
    id: "getting-started",
    links: [
      { label: "Installing Sailfin", href: "/docs/getting-started/install" },
      { label: "Downloads", href: "/dl" },
      { label: "Editor Setup", href: "/docs/getting-started/editor-setup" },
      { label: "Hello, World!", href: "/docs/getting-started/hello-world" },
      { label: "Tour of Sailfin", href: "/docs/getting-started/tour" },
    ],
  },
  {
    title: "Learning Sailfin",
    id: "learn",
    links: [
      { label: "Language Basics", href: "/docs/learn/basics" },
      { label: "Functions & Methods", href: "/docs/learn/functions" },
      { label: "Types & Structs", href: "/docs/learn/types" },
      { label: "The Effect System", href: "/docs/learn/effects" },
      { label: "Ownership & Borrowing", href: "/docs/learn/ownership" },
      { label: "Error Handling", href: "/docs/learn/error-handling" },
      { label: "Concurrency", href: "/docs/learn/concurrency" },
      { label: "AI Constructs", href: "/docs/learn/ai-constructs" },
      { label: "Testing", href: "/docs/learn/testing" },
      { label: "Effective Sailfin", href: "/docs/learn/effective-sailfin" },
    ],
  },
  {
    title: "Reference",
    id: "reference",
    links: [
      { label: "Language Spec", href: "/docs/reference/spec" },
      { label: "Grammar (EBNF)", href: "/docs/reference/grammar" },
      { label: "Keywords", href: "/docs/reference/keywords" },
      { label: "Effect System", href: "/docs/reference/effects" },
      { label: "Standard Library", href: "/docs/reference/standard-library" },
      { label: "CLI Reference", href: "/docs/reference/cli" },
      { label: "Runtime ABI", href: "/docs/reference/runtime-abi" },
    ],
  },
  {
    title: "Advanced",
    id: "advanced",
    links: [
      { label: "Capsules & Packages", href: "/docs/advanced/capsules" },
      { label: "Workspaces", href: "/docs/advanced/workspaces" },
      { label: "Models & Pipelines", href: "/docs/advanced/ai-constructs" },
      { label: "Unsafe & FFI", href: "/docs/advanced/ffi" },
    ],
  },
  {
    title: "Contributing",
    id: "contributing",
    links: [
      { label: "Contributor Guide", href: "/docs/contributing/guide" },
      { label: "Compiler Architecture", href: "/docs/contributing/architecture" },
      { label: "Style Guide", href: "/docs/contributing/style-guide" },
      { label: "Roadmap", href: "/docs/contributing/roadmap" },
    ],
  },
];
---

<aside class="docs-sidebar">
  <nav aria-label="Documentation">
    {sections.map((section) => (
      <div class:list={["sidebar-section", { active: activeSection === section.id }]}>
        <h3 class="sidebar-heading">{section.title}</h3>
        <ul>
          {section.links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={["sidebar-link", { current: currentPath === link.href || currentPath === link.href + "/" }]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .docs-sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    padding: 2rem 1.5rem;
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
    position: sticky;
    top: var(--header-height);
    height: calc(100vh - var(--header-height));
  }

  .sidebar-section {
    margin-bottom: 1.75rem;
  }

  .sidebar-heading {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    padding: 0 0.5rem;
  }

  .docs-sidebar ul {
    list-style: none;
    padding: 0;
  }

  .sidebar-link {
    display: block;
    padding: 0.35rem 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
  }

  .sidebar-link:hover {
    color: var(--color-text);
    background: var(--color-bg-alt);
    text-decoration: none;
  }

  .sidebar-link.current {
    color: var(--color-primary);
    background: var(--sfn-blue-light);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .docs-sidebar {
      display: none;
    }
  }
</style>
