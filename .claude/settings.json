{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",

      "Bash(make *)",
      "Bash(ulimit *)",
      "Bash(build/native/sailfin *)",
      "Bash(timeout * build/native/sailfin *)",
      "Bash(build/native/sailfin-seedcheck *)",
      "Bash(timeout * build/native/sailfin-seedcheck *)",
      "Bash(timeout 120 valgrind --tool=memcheck --track-origins=yes --error-exitcode=0 build/native/sailfin-seedcheck test compiler/tests/unit/function_signatures_test.sfn)",

      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git pull origin *)",
      "Bash(git add *)",
      "Bash(git commit -m*)",
      "Bash(git commit -F*)",
      "Bash(git checkout -b claude/*)",
      "Bash(git checkout claude/*)",
      "Bash(git switch -c claude/*)",
      "Bash(git switch claude/*)",
      "Bash(git stash*)",
      "Bash(git rev-parse*)",
      "Bash(git rev-list*)",
      "Bash(git ls-files*)",
      "Bash(git push -u origin claude/*)",
      "Bash(git push origin claude/*)",

      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh api *)",
      "Bash(gh workflow *)",
      "Bash(gh release view*)",
      "Bash(gh release list*)",

      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat compiler/**)",
      "Bash(cat docs/**)",
      "Bash(cat runtime/**)",
      "Bash(cat site/**)",
      "Bash(cat examples/**)",
      "Bash(cat .github/**)",
      "Bash(cat .claude/**)",
      "Bash(find compiler *)",
      "Bash(find docs *)",
      "Bash(find runtime *)",
      "Bash(find site *)",
      "Bash(find examples *)",
      "Bash(find .github *)",
      "Bash(find .claude *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(du -sh *)",

      "WebFetch(domain:sailfin.dev)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fX*)",
      "Bash(git branch -D main*)",
      "Bash(git branch -D master*)",
      "Bash(git update-ref -d*)",
      "Bash(git checkout --*)",
      "Bash(git restore --*)",
      "Bash(git commit*--no-verify*)",
      "Bash(git commit*--no-gpg-sign*)",
      "Bash(gh release delete*)",
      "Bash(gh repo delete*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/session-start.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/inject-git-context.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/check-ulimit.sh" }
        ]
      }
    ]
  }
}
